u80a1\u5e02\uff0c\u53ca\u8981\u5be6\u65bd\u4e00\u7cfb\u5217\u63d0\u632f\u7d93\u6fdf\u653f\u7b56\u7576\u5468\u7684\u5e02\u6cc1\u3002</p>\n\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u672c\u5468CCL\u4ecd\u8655\u65bc\u903e8\u5e74\u4f4e\u4f4d\uff0c\u57282016\u5e749\u6708\u5e95\u6c34\u5e73\u5f98\u5f8a\uff0c2024\u5e74\u6a13\u50f9\u6700\u7d42\u7d2f\u8dcc6.50%\u3002\u6307\u6578\u8f032024\u5e749\u6708\u9996\u6b21\u6e1b\u606f\u524d135.86\u9ede\u4f4e\u4f4d\u53471.31%\uff0c\u8f032021\u5e748\u6708191.34\u9ede\u6b77\u53f2\u9ad8\u4f4d\u8dcc28.07%\uff0c\u8f032024\u5e743\u6708\u64a4\u8fa3\u524d\u7684\u4f4e\u4f4d143.02\u9ede\u8dcc3.76%\u3002</p>\n<p class=\"font-size-scaler-control\" data-font=\"16\">1\u67082\u65e5\u7b72\u7b95\u7063\u50b2\u83ef\u6e1b\u50f9\u91cd\u63a850\u4f19\uff0c\u4ee5\u53ca\u6e2f\u80a1\u5931\u5b882\u842c\u9ede\u6536\u5e02\uff0c\u5275\u8fd1\u4e00\u500b\u6708\u4f4e\u4f4d\uff0c\u5c0d\u672c\u5730\u4e8c\u624b\u6a13\u50f9\u7684\u5f71\u97ff\u5c07\u65bc2025\u5e741\u6708\u4e0b\u65ec\u516c\u4f48\u7684CCL\u624d\u958b\u59cb\u53cd\u6620\u3002</p>\n\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u4e2d\u539f\u57ce\u5e02\u5927\u578b\u5c4b\u82d1\u9818\u5148\u6307\u6578CCL Mass\u5831138.13\u9ede\uff0c\u6309\u5468\u53470.67%\u3002CCL(\u4e2d\u5c0f\u578b\u55ae\u4f4d)\u5831137.00\u9ede\uff0c\u6309\u5468\u53470.58%\u3002CCL(\u5927\u578b\u55ae\u4f4d)\u5831140.85\u9ede\uff0c\u6309\u5468\u8dcc0.68%\uff0c\u9023\u8dcc2\u5468\u51711.29%\u3002CCL Mass\u53caCCL(\u4e2d\u5c0f\u578b\u55ae\u4f4d)\u9f4a\u8655\u65bc2016\u5e749\u6708\u4e2d\u6c34\u5e73\uff0c\u800cCCL(\u5927\u578b\u55ae\u4f4d)\u5247\u8655\u65bc2016\u5e749\u6708\u5e95\u6c34\u5e73\u3002</p>\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u56db\u5340\u6a13\u50f9\u6307\u6578\uff0c\u6e2f\u4e5d\u5e02\u5340\u5347\uff0c\u65b0\u754c\u5169\u5340\u8dcc\u3002\u6e2f\u5cf6CCL_Mass\u5831138.57\u9ede\uff0c\u6309\u5468\u53471.64%\u3002\u4e5d\u9f8dCCL_Mass\u5831133.81\u9ede\uff0c\u6309\u5468\u53471.19%\u3002\u65b0\u754c\u6771CCL_Mass\u5831148.38\u9ede\uff0c\u6309\u5468\u8dcc0.32%\uff0c\u9023\u8dcc3\u5468\u51711.59%\u3002\u65b0\u754c\u897fCCL_Mass\u5831128.36\u9ede\uff0c\u6309\u5468\u8dcc0.33%\uff0c\u7d50\u675f2\u5468\u9023\u5347\u3002</p>\n\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u6e2f\u5cf6\u3001\u4e5d\u9f8d\u3001\u65b0\u754c\u6771\u53ca\u65b0\u754c\u897f\u6307\u6578\uff0c\u5206\u5225\u65bc2016\u5e747\u6708\u521d\u30018\u6708\u5e95\u300110\u6708\u521d\u53ca12\u6708\u4e2d\u6c34\u5e73\u5f98\u5f8a\u3002</p>\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u4ee5\u6b63\u5f0f\u8cb7\u8ce3\u5408\u7d04\u65e5\u671f\u8a08\uff0c\u6307\u6578\u82072023\u5e74\u5e95\u76f8\u6bd4\uff0c2024\u5e74\u5168\u5e74CCL\u8dcc6.50%\uff0cCCL Mass\u8dcc6.23%\uff0cCCL(\u4e2d\u5c0f\u578b\u55ae\u4f4d)\u8dcc6.16%\uff0cCCL(\u5927\u578b\u55ae\u4f4d)\u8dcc8.12%\uff0c\u6e2f\u5cf6\u8dcc4.87%\uff0c\u4e5d\u9f8d\u8dcc5.62%\uff0c\u65b0\u754c\u6771\u8dcc8.01%\uff0c\u65b0\u754c\u897f\u8dcc6.99%\u3002</p>\n</div>", "link": "https://www.bastillepost.com/hongkong/article/14611144-%e4%b8%ad%e5%8e%9f%e9%a0%98%e5%85%88%e6%8c%87%e6%95%b82024%e5%b9%b4%e5%a0%b1137-64-%e6%8c%89%e5%b9%b4%e8%b7%8c6-5", "image": "https://image.bastillepost.com/704x369/wp-content/uploads/hongkong/2024/08/20240726_PP_PROPERTY_INDEX_FB.png.webp", "pub_date": "2025-01-03 16:20:26", "source": "bastillepost", "kind": 2, "language": "zh-HK"}, {"title": "\u6703\u5fb7\u8c50\u65e5\u51fa\u5eb7\u57ceGRAND SEASONS\u9996\u63a8\u6700\u5c11130\u4f19", "description": "<div class=\"article-body\">\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u6703\u5fb7\u8c50\u5730\u7522\u8207\u6e2f\u9435(00066)\u5c07\u8ecd\u6fb3\u65e5\u51fa\u5eb7\u57ce\u7b2c12C\u671fGRAND SEASONS\u6700\u5feb\u4e0b\u5468\u4e00(6\u65e5)\u516c\u5e03\u9996\u5f35\u50f9\u55ae\uff0c\u9996\u6279\u4e0d\u5c11\u65bc130\u4f19\u3002</p>\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u6703\u5fb7\u8c50\u5730\u7522\u526f\u4e3b\u5e2d\u517c\u5e38\u52d9\u8463\u4e8b\u9ec3\u5149\u8000\u8868\u793a\uff0cGRAND SEASONS\u81ea\u6628\u5929\u547d\u540d\u53ca\u4e0a\u8f09\u6a13\u66f8\u5f8c\uff0c\u5df2\u63a5\u7372\u7d041000\u500b\u67e5\u8a62\uff0c\u5167\u5730\u5ba2\u4f54\u4e09\u6210\uff0c\u56e0\u6b64\u5c07\u52a0\u5feb\u63a8\u76e4\u6b65\u4f10\uff0c\u6700\u5feb\u4e0b\u5468\u4e00\u516c\u5e03\u9996\u5f35\u50f9\u55ae\uff0c\u9996\u6279\u4e0d\u5c11\u65bc130\u4f19\uff0c\u6236\u578b\u6db5\u84cb1\u623f\u81f33\u623f\u3002</p>\n<p class=\"font-size-scaler-control\" data-font=\"16\">GRAND SEASONS\u660e\u5929\u958b\u653e\u5c55\u92b7\u5ef3\u53ca\u793a\u7bc4\u55ae\u4f4d\u4e88\u6e96\u8cb7\u5bb6\u53c3\u89c0\uff0c\u793a\u7bc4\u55ae\u4f4d\u4ee51B\u5ea738\u6a13A\u5ba4\u70ba\u85cd\u672c\uff0c\u5be6\u7528\u9762\u7a4d716\u65b9\u544e\uff0c\u63a13\u623f1\u5957\u9023\u5de5\u4f5c\u9593\u53ca\u5ec1\u9593\u9694\uff0c\u5c6c\u9762\u7a4d\u6700\u5927\u7684\u6a19\u6e96\u6236\u3002</p>\n</div>", "link": "https://www.bastillepost.com/hongkong/article/14611101-%e6%9c%83%e5%be%b7%e8%b1%90%e6%97%a5%e5%87%ba%e5%ba%b7%e5%9f%8egrand-seasons%e9%a6%96%e6%8e%a8%e6%9c%80%e5%b0%91130%e4%bc%99", "image": "https://image.bastillepost.com/704x369/wp-content/uploads/hongkong/2024/10/pp_new-flat-transaction_fb.png.webp", "pub_date": "2025-01-03 16:05:25", "source": "bastillepost", "kind": 2, "language": "zh-HK"}, {"title": "\u5167\u573011\u6708\u624b\u6a5f\u51fa\u8ca8\u91cf\u6309\u5e74\u6e1b\u534a\u6210", "description": "<div class=\"article-body\">\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u4e2d\u570b\u4fe1\u901a\u9662\u516c\u5e03\uff0c\u5167\u5730\u53bb\u5e7411\u6708\u5e02\u5834\u624b\u6a5f\u51fa\u8ca8\u91cf2960.6\u842c\u90e8\uff0c\u6309\u5e74\u6e1b5.1%\uff0c\u5176\u4e2d5G\u624b\u6a5f\u4f542731.9\u842c\u90e8\uff0c\u6309\u5e74\u589e0.8%\uff0c\u4f54\u624b\u6a5f\u51fa\u8ca8\u91cf92.3%\u3002</p>\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u53e6\u5916\uff0c\u53bb\u5e741\u81f311\u6708\uff0c\u5167\u5730\u5e02\u5834\u624b\u6a5f\u51fa\u8ca8\u91cf2.8\u5104\u90e8\uff0c\u53477.2%\uff0c\u5176\u4e2d5G\u624b\u6a5f\u6d892.41\u5104\u90e8\uff0c\u6f3212%\uff0c\u4f54\u624b\u6a5f\u51fa\u8ca8\u91cf86.2%\u3002</p>\n</div>", "link": "https://www.bastillepost.com/hongkong/article/14611091-%e5%85%a7%e5%9c%b011%e6%9c%88%e6%89%8b%e6%a9%9f%e5%87%ba%e8%b2%a8%e9%87%8f%e6%8c%89%e5%b9%b4%e6%b8%9b%e5%8d%8a%e6%88%90", "image": "https://image.bastillepost.com/704x369/wp-content/uploads/hongkong/2024/12/20211215-CH-%E6%89%8B%E6%A9%9F%E7%94%A8%E6%88%B61_FB_source-licensed__704px.jpg.webp", "pub_date": "2025-01-03 16:00:39", "source": "bastillepost", "kind": 2, "language": "zh-HK"}, {"title": "\u4e16\u90a6\u9b4f\u7406\u4ed5\u9810\u671f1 \u6708\u6210\u4ea4\u91cf\u7dad\u6301\u73fe\u6c34\u5e73", "description": "<div class=\"article-body\">\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u571f\u5730\u8a3b\u518a\u8655\u767c\u88682024\u5e7412\u6708\u4efd\u7d71\u8a08\u6578\u5b57\uff0c\u4e16\u90a6\u9b4f\u7406\u4ed5\u9810\u671f\uff0c1\u6708\u4efd\u6210\u4ea4\u91cf\u5c07\u7dad\u6301\u5728\u76ee\u524d\u6c34\u5e73\u3002</p>\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u4e16\u90a6\u9b4f\u7406\u4ed5\u9999\u6e2f\u4f30\u503c\u53ca\u8aee\u8a62\u670d\u52d9\u90e8\u57f7\u884c\u8463\u4e8b\u90ed\u5049\u6069\u8868\u793a\uff0c\u6210\u4ea4\u91cf\u5728\u9023\u5f48\u5169\u500b\u6708\u5f8c\u56de\u8edf\uff0c12\u6708\u4f4f\u5b85\u6a13\u5b87\u8cb7\u8ce3\u5408\u7d04\u8f03\u4e0a\u500b\u6708\u4e0b\u8dcc34.9%\u81f34103\u5b97\u30022024\u5e74\u5168\u5e74\u8a08\uff0c\u6210\u4ea4\u91cf\u905453099\u5b97\uff0c\u8f032023\u5e74\u591a10000\u5b97\u6210\u4ea4\uff0c\u5e02\u5834\u4ea4\u6295\u4e0a\u5347\u4e3b\u8981\u53d7\u60e0\u65bc\u653f\u5e9c\u64a4\u8fa3\u53ca\u6e1b\u606f\uff0c\u800c\u7576\u4e2d\u5347\u5e45\u4e3b\u8981\u4f86\u81ea\u4e00\u624b\u5e02\u5834\uff0c\u6309\u63ed\u5229\u7387\u6301\u7e8c\u4e0b\u8abf\u5438\u5f15\u8cb7\u5bb6\u9678\u7e8c\u5165\u5e02\uff0c\u4f46\u662f12\u6708\u6210\u4ea4\u91cf\u4e0b\u8dcc\u4e3b\u8981\u53d7\u5230\u5b63\u7bc0\u6027\u56e0\u7d20\u5f71\u97ff\u3002<br/> <br/>  \u6a13\u5e02\u5c55\u671b\u65b9\u9762\uff0c\u516c\u53f8\u9810\u671f1\u6708\u4efd\u6210\u4ea4\u91cf\u5c07\u7dad\u6301\u5728\u76ee\u524d\u6c34\u5e73\uff0c\u9810\u8a08\u767c\u5c55\u5546\u5c07\u65bc\u8fb2\u66c6\u65b0\u5e74\u5f8c\u63a8\u51fa\u66f4\u591a\u65b0\u9805\u76ee\uff0c\u5c4a\u6642\u6210\u4ea4\u91cf\u53ef\u80fd\u6703\u589e\u52a0\u3002</p>\n</div>", "link": "https://www.bastillepost.com/hongkong/article/14611048-%e4%b8%96%e9%82%a6%e9%ad%8f%e7%90%86%e4%bb%95%e9%a0%90%e6%9c%9f1-%e6%9c%88%e6%88%90%e4%ba%a4%e9%87%8f%e7%b6%ad%e6%8c%81%e7%8f%be%e6%b0%b4%e5%b9%b3", "image": "https://image.bastillepost.com/704x369/wp-content/uploads/hongkong/2024/10/HKProperty-1.jpg.webp", "pub_date": "2025-01-03 15:55:24", "source": "bastillepost", "kind": 2, "language": "zh-HK"}, {"title": "\u6703\u5fb7\u8c50\u4eca\u5e74\u63a8\u903e2400\u500b\u55ae\u4f4d", "description": "<div class=\"article-body\">\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u6703\u5fb7\u8c50\u5730\u7522\u526f\u4e3b\u5e2d\u517c\u5e38\u52d9\u8463\u4e8b\u9ec3\u5149\u8000\u9810\u671f\uff0c\u8a72\u96c6\u5718\u4eca\u5e74\u6703\u63a8\u51fa4\u81f35\u500b\u9805\u76ee\uff0c\u6d89\u53ca\u8d85\u904e2400\u500b\u55ae\u4f4d\u3002\u4ed6\u6307\u51fa\uff0c\u96c6\u5718\u53bb\u5e74\u5171\u552e\u51fa1881\u4f19\uff0c\u76f8\u4fe1\u4eca\u5e74\u6703\u552e\u51fa\u63a5\u8fd1\uff0c\u751a\u81f3\u8d85\u904e\u53bb\u5e74\u7684\u6578\u76ee\u3002</p>\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u9ec3\u5149\u8000\u5728\u8a18\u8005\u6703\u8868\u793a\uff0c\u300cGRAND SEASONS\u300d\u5c07\u65bc\u660e\u65e5\u8d77\u958b\u653e\u793a\u7bc4\u55ae\u4f4d\u53ca\u5c55\u92b7\u5ef0\uff0c\u6700\u5feb\u4e0b\u5468\u4e00\u958b\u50f9\uff0c\u5168\u500b\u9805\u76ee\u6709650\u4f19\uff0c\u9996\u6279\u63a8\u51fa\u4e0d\u5c11\u65bc130\u4f19\uff0c\u7576\u4e2d\u5305\u62ec1\u623f\u30012\u623f\u53ca3\u623f\u6236\u3002</p>\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u4ed6\u6307\u51fa\uff0c\u300cGRAND SEASONS\u300d \u9996\u6279\u958b\u50f9\u6703\u53c3\u8003\u300cPARK SEASONS\u300d\uff0c\u6599\u552e\u50f9\u6703\u4e0a\u8abf5%\uff0c\u5168\u90e8\u4ee5\u50f9\u55ae\u5f62\u5f0f\u767c\u552e\u3002</p>\n\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u9ec3\u5149\u8000\u7a31\uff0c\u4eca\u5e74\u672c\u6e2f\u6a13\u5e02\u6599\u4ecd\u4ee5\u4e00\u624b\u70ba\u4e3b\uff0c\u6545\u4e0a\u534a\u5e74\u6a13\u50f9\u6703\u5e73\u7a69\uff0c\u5f85\u767c\u5c55\u5546\u53bb\u8ca8\u7406\u60f3\uff0c\u552e\u50f9\u53ef\u671b\u8abf\u5347\uff0c\u52a0\u4e0a\u4f30\u8a08\u672c\u6e2f\u4eca\u5e74\u4e0b\u534a\u5e74\u4ecd\u6709\u6e1b\u606f\u6a5f\u6703\uff0c\u6545\u9019\u4e9b\u56e0\u7d20\u5747\u652f\u6301\u6a13\u50f9\u4e0a\u5347\u3002</p>\n</div>", "link": "https://www.bastillepost.com/hongkong/article/14611041-14611041", "image": "https://image.bastillepost.com/704x369/wp-content/uploads/hongkong/2024/02/%E6%9C%83%E5%BE%B7%E8%B1%90%E5%9C%B0%E7%94%A2%E5%AE%98%E7%B6%B22.jpg.webp", "pub_date": "2025-01-03 15:50:28", "source": "bastillepost", "kind": 2, "language": "zh-HK"}, {"title": "\u4f4f\u5b85\u8cb7\u5408\u7d04\u7e3d\u503c\u6309\u5e74\u5347\u8fd134%", "description": "<div class=\"article-body\">\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u571f\u5730\u8a3b\u518a\u8655\u516c\u5e03\uff0c\u53bb\u5e7412\u6708\u4efd\u9001\u4ea4\u8a3b\u518a\u7684\u6240\u6709\u7a2e\u985e\u6a13\u5b87\u8cb7\u8ce3\u5408\u7d04\u51715510\u4efd\uff0c\u6309\u6708\u8dcc28.3%\uff0c\u6309\u5e74\u5247\u4e0a\u534746.4%\uff1b\u6d89\u53ca\u5408\u7d04\u7e3d\u503c428\u5104\u5143\uff0c\u6309\u6708\u8dcc33.3%\uff0c\u6309\u5e74\u5247\u4e0a\u534727.4%\u3002</p>\n<p class=\"font-size-scaler-control\" data-font=\"16\">\u4e0a\u8ff0\u8cb7\u8ce3\u5408\u7d04\u4e2d\uff0c\u4f4f\u5b85\u6a13\u5b87\u8cb7\u8ce3\u5408\u7d04\u4f544103\u4efd\uff0c\u6309\u6708\u8dcc34.9%\uff0c\u6309\u5e74\u5247\u4e0a\u534740.1%\uff1b\u6d89\u53ca\u5408\u7d04\u7e3d\u503c326\u5104\u5143\uff0c\u6309\u6708\u8dcc43.1%\uff0c\u6309\u5e74\u5247\u4e0a\u534733.9%\u3002</p>\n</div>", "link": "https://www.bastillepost.com/hongkong/article/14611032-%e4%bd%8f%e5%ae%85%e8%b2%b7%e5%90%88%e7%b4%84%e7%b8%bd%e5%80%bc%e6%8c%89%e5%b9%b4%e5%8d%87%e8%bf%9134", "image": "https://image.bastillepost.com/704x369/wp-content/uploads/hongkong/2024/10/20241023_CR_SSP4_source-bp_02.jpeg.webp", "pub_date": "2025-01-03 15:50:30", "source": "bastillepost", "kind": 2, "language": "zh-HK"}]}