n<img alt=\"恒基提供圖片\" loading=\"lazy\" src=\"https://image.bastillepost.com/528x/wp-content/uploads/hongkong/2026/01/20260120_cr_souce-licensed_The-Henderson_02.jpg.webp\"/>\n</div>\n<h3 class=\"h3 fancy-main__title bpcategory-special-color\">恒基提供圖片</h3>\n</a>\n</div>\n<div class=\"swiper-slide\">\n<a class=\"fancy-main__slide\" data-caption=\"恒基提供圖片\" data-fancybox=\"slider-gallery\" href=\"https://image.bastillepost.com/528x/wp-content/uploads/hongkong/2026/01/20260120_cr_souce-licensed_The-Henderson_03.jpg.webp\">\n<div class=\"fancy-main__image\">\n<img alt=\"恒基提供圖片\" loading=\"lazy\" src=\"https://image.bastillepost.com/528x/wp-content/uploads/hongkong/2026/01/20260120_cr_souce-licensed_The-Henderson_03.jpg.webp\"/>\n</div>\n<h3 class=\"h3 fancy-main__title bpcategory-special-color\">恒基提供圖片</h3>\n</a>\n</div>\n<div class=\"swiper-slide\">\n<a class=\"fancy-main__slide\" data-caption=\"恒基提供圖片\" data-fancybox=\"slider-gallery\" href=\"https://image.bastillepost.com/1200x/wp-content/uploads/hongkong/2026/01/20260120_CR_Source-web_HK_02.jpeg.webp\">\n<div class=\"fancy-main__image\">\n<img alt=\"恒基提供圖片\" loading=\"lazy\" src=\"https://image.bastillepost.com/644x392/wp-content/uploads/hongkong/2026/01/20260120_CR_Source-web_HK_02.jpeg.webp\"/>\n</div>\n<h3 class=\"h3 fancy-main__title bpcategory-special-color\">恒基提供圖片</h3>\n</a>\n</div>\n</div>\n</div>\n<div class=\"fancy-main__controls\">\n<div class=\"fancy-main__controls-text bpcategory-special-color\">更多相片</div>\n<div class=\"fancy-main__buttons\">\n<div class=\"fancy-main__button __prev fancy-main-prev\" style=\"border-right: 8px solid #54446b\"></div>\n<div class=\"rule\"></div>\n<div class=\"fancy-main__button __next fancy-main-next\" style=\"border-left: 8px solid #54446b\"></div>\n</div>\n</div>\n<div class=\"fancy-thumbs\">\n<div class=\"swiper-wrapper\">\n<div class=\"swiper-slide\">\n<div class=\"fancy-thumbs__image\">\n<img alt=\"其中包括國際級別大獎「World’s Best Property （世界最佳物業）」。恒基提供圖片\" loading=\"lazy\" src=\"