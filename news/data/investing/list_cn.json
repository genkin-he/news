\u662f\u4e00\u4efd\u6807\u51c6\u201c\u5b89\u5fc3\u975e\u519c\u201d\u5e94\u8be5\u6709\u7684\u6837\u5b50\u3002\u73b0\u5728\u8ddd\u79bb\u4e24\u5468\u540e\u7684\u7f8e\u8054\u50a8\u51b3\u8bae\uff0c\u8fd8\u6709\u4e00\u4efd\u4e0b\u5468\u7684CPI\u6570\u636e\uff0c\u5c4a\u65f6\u6295\u8d44\u8005\u4eec\u5e94\u8be5\u4f1a\u5bf9\u964d\u606f\u4e8b\u5b9c\u6709\u66f4\u660e\u786e\u7684\u5224\u65ad\u3002\u6469\u6839\u5927\u901a\u9996\u5e2d\u7f8e\u56fd\u7ecf\u6d4e\u5b66\u5bb6Michael Feroli\u8ba4\u4e3a\uff0cCPI\u6570\u636e\u5f97\u6709\u975e\u5e38\u5927\u7684\u610f\u5916\uff0c\u624d\u6709\u53ef\u80fd\u6539\u53d8\u7f8e\u8054\u50a8\u7684\u60f3\u6cd5\u3002CME\u201c\u7f8e\u8054\u50a8\u89c2\u5bdf\u201d\u5de5\u5177\u663e\u793a\uff0c\u5229\u7387\u671f\u8d27\u5e02\u573a\u53cd\u6620\u768412\u6708\u964d\u606f\u6982\u7387\u5347\u81f385%\uff0c\u524d\u4e00\u5929\u4e3a71%\u3002\uff08\u6765\u6e90\uff1aCME\uff09\nClearBridge Investments\u7684\u6295\u8d44\u7b56\u7565\u5206\u6790\u5e08Josh Jamner\u89e3\u8bfb\u79f0\uff0c\u201c\u6070\u5230\u597d\u5904\u201d\u7684\u975e\u519c\u62a5\u544a\u5e94\u8be5\u5bf9\u98ce\u9669\u8d44\u4ea7\u6784\u6210\u8fb9\u9645\u5229\u597d\u3002\u8fd9\u4efd\u62a5\u544a\u5e94\u8be5\u5904\u4e8e\u201c\u9002\u4e2d\u201d\u7684\u533a\u95f4\uff0c\u5728\u57fa\u672c\u60c5\u51b5\u7a33\u5b9a\u7684\u60c5\u51b5\u4e0b\uff0c\u7f8e\u8054\u50a8\u672a\u6765\u51e0\u4e2a\u6708\u5e94\u8be5\u4f1a\u5904\u4e8e\u80fd\u7ee7\u7eed\u653e\u5bbd\u8d27\u5e01\u653f\u7b56\u7684\u4f4d\u7f6e\uff0c\u6700\u8fd1\u7684\u4e00\u7cfb\u5217\u53d1\u8a00\u4e5f\u8868\u660e\uff0c\u4ed6\u4eec\u4f1a\u57282025\u5e74\u91c7\u53d6\u66f4\u52a0\u6e10\u8fdb\u5f0f\u7684\u964d\u606f\u3002\u70ed\u95e8\u80a1\u8868\u73b0\u79d1\u6280\u5de8\u5934\u7531\u4e8e\u5404\u79cd\u5404\u6837\u7684\u539f\u56e0\u6da8\u8dcc\u4e92\u73b0\u3002\u53d7\u5230TikTok\u7981\u4ee4\u4e0a\u8bc9\u7ed3\u679c\u5f71\u54cd\uff0c\u793e\u4ea4\u5a92\u4f53\u548c\u6570\u5b57\u5e7f\u544a\u7ade\u54c1Meta\u6da82.44%\u3001\u8c37\u6b4cC\u6da81.25%\uff0c\u8ba8\u597d\u4fdd\u5b88\u4e3b\u4