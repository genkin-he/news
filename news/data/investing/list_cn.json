7ade\u62cd\u8005\u201cX0231\u201d\u5c55\u5f00\u6fc0\u70c8\u89d2\u9010\uff0c\u4ea4\u66ff\u52a0\u4ef7\u3002\u6700\u7ec8\u7ade\u62cd\u8005\u201cG5961\u201d\u4ee514.1\u4e07\u5143\u62cd\u5f978\u4e07\u80a1\u80a1\u6743\uff0c\u76f8\u5f53\u4e8e1.76\u5143/\u80a1\u3002\n                        \n                        1\u5143\u8d77\u62cd\uff0c\u6700\u7ec8141001\u5143\u6210\u4ea4\u00a0 \u00a0\u56fe\u7247\u6765\u6e90\uff1a\u963f\u91cc\u62cd\u5356\u5e73\u53f0\n                    \n                        \n                        \u5feb\u7ed3\u675f\u768430\u79d2\u8fd8\u6709\u56db\u6b21\u7ade\u62cd\u8bb0\u5f55\u00a0 \u00a0\u56fe\u7247\u6765\u6e90\uff1a\u963f\u91cc\u62cd\u5356\u5e73\u53f0\n                    \u201c1\u5143\u8d77\u62cd\u201d\u5b9e\u4e3a\u5438\u5f15\u66f4\u591a\u5ba2\u6237\u53c2\u4e0e\uff1f\u6b66\u6c49\u519c\u5546\u884c\u8fd1\u5e74\u7ecf\u8425\u60c5\u51b5\u6709\u6240\u4e0b\u6ed1\u30022023\u5e74\uff0c\u6b66\u6c49\u519c\u5546\u884c\u96c6\u56e2\u53e3\u5f84\u8425\u6536\u540c\u6bd4\u4e0b\u6ed13.62%\u3002\u4ece\u94f6\u884c\u53e3\u5f84\u6765\u770b\uff0c\u6b66\u6c49\u519c\u5546\u884c\u7684\u8425\u4e1a\u6536\u5165\u5df2\u8fde\u7eed\u4e24\u5e74\u4e0b\u6ed1\uff0c\u4f46\u8be5\u884c\u5f52\u6bcd\u51c0\u5229\u6da6\u8fde\u7eed\u4e24\u5e74\u589e\u957f\u30022023\u5e74\uff0c\u6b66\u6c49\u519c\u5546\u884c\u7684\u8d44\u672c\u5145\u8db3\u7387\u3001\u4e00\u7ea7\u8d44\u672c\u5145\u8db3\u7387\u3001\u6838\u5fc3\u4e00\u7ea7\u8d44\u672c\u5145\u8db3\u7387\u5206\u522b\u4e3a11.29%\u30019.54%\u548c9.30%\uff0c\u4e0d\u826f\u7387\u4e3a2.91%\uff0c\u62e8\u5907\u8986\u76d6\u7387158.20%\uff0c\u5747\u6ee1\u8db3\u76d1\u7ba1\u8981\u6c42\uff0c\u4f46\u5df2\u63a5\u8fd1\u76d1\u7ba1\u8981\u6c42\u7684\u4e34\u754c\u503c\u3002\n                        \n                        \u56fe\u7247\u6765\u6e90\uff1a\u6b66\u6c49\u519c\u5546\u884c\u8d22\u62a5\n                    \u5c3d\u7ba1\u7ecf\u8425\u4e1a\u7ee9\u4e00\u822c\uff0c\u4f46\u6b66\u6c49\u519c\u5546\u884c\u80a1\u6743\u5728\u62cd\u5356\u5e02\u573a\u7ecf\u5e38\u4eae\u76f8\uff0c\u5df2\u4e0d\u662f\u9996\u6b21\u201c\u4e00\u5143\u62cd\u5356\u201d\u3002\u65f6\u4ee3\u8d22\u7ecf\u53d1\u73b0\uff0c\u5728\u963f\u91cc\u8d44\u4ea7\u62cd\u5356\u5e73\u53f0\u4e0a\uff0c2024\u5e7412\u670821\u65e5\u548c2025\u5e741\u67084\u65e5\u8fd8\u5373\u5c06\u6709\u4e24\u7b14\u201c1\u5143\u8d77\u62cd\u201d\u7684\u6b66\u6c49\u519c\u5546\u884c\u80a1\u6743\u5373\u5c06\u5f00\u62cd\uff0c\u800c\u57282024\u5e742\u6708\u81f311\u6708\u7684\u6bcf\u4e2a\u6708\u5747\u6709\u7c7b\u4f3c\u62cd\u5356\u3002\u4ee511\u670815\u65e5\u4e00\u7b148.8\u4e07\u80a1\u6b66\u6c49\u519c\u5546\u884c\u81ea\u7136\u4eba\u80a1\u6743\u201c1\u5143\u8d77\u62cd\u201d\u4e3a\u4f8b\uff0c\u6700\u7ec8\u7ecf\u538655\u6b21\u7ade\u5356\u300140\u6b21\u5ef6\u65f6\u7684\u6fc0\u70c8\u7ade\u62cd\u4e4b\u540e\u88ab\u4ee516.5\u4e07\u7684\u4ef7\u683c\u62cd\u4e0b\uff0c\u76f8\u5f53\u4e8e1.875\u5143/\u80a1\u3002\u65f6\u4ee3\u8d22\u7ecf\u81f4\u7535\u963f\u91cc\u8d44\u4ea7\u62cd\u5356\u5e73\u53f0\uff0c\u76f8\u5173\u5de5\u4f5c\u4eba\u5458\u8868\u793a\uff1a\u201c\u4f4e\u4ef7\u8d77\u62cd\uff0c\u4f46\u6700\u7ec8\u7684\u6210\u4ea4\u4ef7\u4e0d\u4e00\u5b9a\u4f4e\uff0c\u4f4e\u4ef7\u8d77\u62cd\u662f\u4e3a\u4e86\u5438\u5f15\u66f4\u591a\u5ba2\u6237\u8fdb\u6765\u53c2\u4e0e\u3002\u201d\n                        \n                        \u56fe\u7247\u6765\u6e90\uff1a\u963f\u91cc\u62cd\u5356\u5e73\u53f0\n                    12\u67086\u65e5\uff0c\u65f6\u4ee3\u8d22\u7ecf\u5c31\u80a1\u6743\u62cd\u5356\u4e8b\u4ef6\u81f4\u7535\u6b66\u6c49\u519c\u5546\u884c\u8463\u529e\u3002\u4e00\u540d\u5de5\u4f5c\u4eba\u5458\u8868\u793a\uff0c\u4ed6\u4eec\u4e4b\u524d\u5df2\u5bf9\u963f\u91cc\u62cd\u5356\u5e73\u53f0\u505a\u8fc7\u8be6\u7ec6\u6df1\u5165\u8c03\u67e5\uff0c\u8be5\u884c\u5728\u963f\u91cc\u62cd\u5356\u5e73\u53f0\u4e0a\u7684\u4ea4\u6613\u5927\u90e8\u5206\u662f\u865a\u5047\u7684\u3002\u201c\u4e0a\u9762\u6bcf\u5e74\u5341\u51e0\u6761\u7684\u4ea4\u6613\u8bb0\u5f55\uff0c\u4f46\u6211\u4eec\u5728\u6b66\u6c49\u80a1\u6743\u6258\u7ba1\u4ea4\u6613\u4e2d\u5fc3\u662f\u67e5\u4e0d\u5230\u7684\u3002\u62ff\u51fa\u80a1\u6743\u62cd\u5356\u7684\u516c\u53f8\uff0c\u53ef\u80fd\u5b58\u5728\u771f\u5b9e\u7684\u5c11\u90e8\u5206\u80a1\u6743\uff0c\u4f46\u4ed6\u4eec\u4e0d\u4f1a\u6709\u771f\u5b9e\u610f\u613f\u53bb\u62cd\u30021\u5143\u8d77\u62cd\u4e5f\u4f1a\u6709\u5185\u90e8\u4eba\u5458\u52a0\u4ef7\uff0c\u7b49\u52a0\u5230\u5e02\u573a\u4ef7\u7684\u65f6\u5019\u5c31\u4e0d\u52a0\u4ef7\u4e86\u3002\u5916\u90e8\u4e70\u5bb6\u5e76\u6ca1\u6709\u529e\u6cd5\u6361\u6f0f\uff0c\u800c\u662f\u7528\u5e02\u573a\u4ef7\u751a\u81f3\u9ad8\u4e8e\u5e02\u573a\u4ef7\u4e70\u5230\u3002\u5982\u679c\u6ca1\u6709\u5916\u90e8\u4e70\u5bb6\u52a0\u5230\u5e02\u573a\u4ef7\u4ee5\u4e0a\uff0c\u90a3\u8fd9\u7b14\u80a1\u6743\u8fc7\u4e00\u6bb5\u65f6\u95f4\u53c8\u4f1a\u91cd\u65b0\u4e0a\u67b6\u3002\u201d\u6b66\u6c49\u519c\u5546\u884c\u8463\u529e\u5de5\u4f5c\u4eba\u5458\u8bf4\u3002\u65f6\u4ee3\u8d22\u7ecf\u6ce8\u610f\u5230\uff0c12\u67086\u65e5\u540c\u65e5\uff0c\u5728\u963f\u91cc\u62cd\u5356\u5e73\u53f0\u8fd8\u6709\u4e09\u7b1410\u4e07\u80a1\u6b66\u6c49\u519c\u5546\u884c\u81ea\u7136\u4eba\u80a1\u6743\u5747\u4ee516.5\u4e07\u5143\u8d77\u62cd\uff0c\u6298\u5408\u6bcf\u80a11.65\u5143\uff0c\u8bc4\u4f30\u4ef7\u6bcf\u80a14.25\u5143\uff0c\u76f8\u5f53\u4e8e3.88\u6298\u3002\u4f46\u8fd9\u4e09\u7b14\u4ee5\u6b63\u5e38\u4ef7\u8d77\u62cd\u7684\u80a1\u6743\u5219\u51b7\u6e05\u4e86\u8bb8\u591a\uff0c\u6700\u591a\u7684\u4e00\u7b14\u4ec5\u6709\u4e09\u6b21\u7ade\u62cd\u8bb0\u5f55\uff0c\u6700\u7ec8\u8fd9\u4e09\u7b14\u80a1\u6743\u5206\u522b\u4ee516.7\u4e07\u5143\u300116.6\u4e07\u5143\u548c16.5\u4e07\u5143\u6210\u4ea4\uff0c\u6298\u5408\u6bcf\u80a11.65-1.67\u4e07\u5143\u3002\n                        \n                        \u6b63\u5e38\u4ef7\u8d77\u62cd\u7684\u80a1\u6743\u7ade\u62cd\u8005\u5be5\u5be5\uff1b\u56fe\u7247\u6765\u6e90\uff1a\u963f\u91cc\u62cd\u5356\u5e73\u53f0\n                    \u4e5f\u5c31\u662f\u8bf4\uff0c\u201c1\u5143\u8d77\u62cd\u201d\u7684\u80a1\u6743\u770b\u4f3c\u4fbf\u5b9c\u3001\u7ade\u4e89\u6fc0\u70c8\uff0c\u4f46\u6700\u7ec8\u6210\u4ea4\u4ef7\u6298\u5408\u540e\u8fd8\u9ad8\u4e8e\u4ee5\u6b63\u5e38\u4ef7\u8d77\u62cd\u7684\u80a1\u6743\u3002\u4f4e\u4ef7\u95e8\u69db\uff0c\u9650\u65f6\u7529\u5356\uff0c\u4ee5\u53ca\u7d27\u5f20\u523a\u6fc0\u3001\u201c\u5206\u79d2\u5fc5\u4e89\u201d\u7684\u62cd\u5356\u73af\u8282\u90fd\u4fc3\u6210\u4e86\u66f4\u9ad8\u7684\u6210\u4ea4\u4ef7\u683c\u3002\u4e0a\u4ebf\u5143\u80a1\u6743\u4ea4\u6613\u771f\u5b9e\u6027\u5982\u4f55\uff1f\u5728\u963f\u91cc\u62cd\u5356\u5e73\u53f0\u4e0a\uff0c\u6b66\u6c49\u519c\u5546\u884c\u5305\u62ec\u6cd5\u4eba\u80a1\u548c\u81ea\u7136\u4eba\u80a1\u5728\u5185\u7684\u80a1\u6743\u62cd\u5356\u4fe1\u606f\u4f17\u591a\uff0c\u9664\u4e86\u4e0a\u8ff0\u591a\u7b14\u201c1\u5143\u8d77\u62cd\u201d\u7684\u80a1\u6743\u4ee5\u5916\uff0c\u5728\u963f\u91cc\u62cd\u5356\u5e73\u53f0\u4e0a\u8fd8\u6709\u591a\u7b14\u91d1\u989d\u4e0a\u4ebf\u7684\u6b66\u6c49\u519c\u5546\u884c\u80a1\u6743\u3002\u636e\u963f\u91cc\u62cd\u5356\u5e73\u53f0\u4e0a\uff0c2023\u5e746\u670825\u65e5\u6709\u4e00\u7b14\u91d1\u989d\u8fd11.35\u4ebf\u5143\u7684\u6b66\u6c49\u519c\u5546\u884c3968.02\u4e07\u80a1\u80a1\u6743\u6210\u4ea4\u3002\u8be5\u7b14\u80a1\u6743\u7531\u6b66\u6c49\u4e09\u5c71\u7ecf\u6d4e\u53d1\u5c55\u96c6\u56e2\u6301\u6709\uff0c\u663e\u793a\u57286\u670825\u65e5\u4e0a\u534810\u70b926\u5206\u7531\u6b66\u6c49\u5149\u8c37\u91d1\u878d\u63a7\u80a1\u96c6\u56e2\u6709\u9650\u516c\u53f8\uff08\u4e0b\u79f0\u201c\u5149\u8c37\u91d1\u63a7\u201d\uff09\u901a\u8fc7\u7ade\u4e70\u53f7E1193\u7ade\u5f97\uff0c\u5904\u7f6e\u5355\u4f4d\u4e3a\u6b66\u6c49\u5e02\u4e2d\u7ea7\u4eba\u6c11\u6cd5\u9662\u3002\n                        \n                        \u56fe\u7247\u6765\u6e90\uff1a\u963f\u91cc\u62cd\u5356\u5e73\u53f0\n                    \u636e\u6b66\u6c49\u519c\u5546\u884c2023\u5e74\u62a5\uff0c\u5149\u8c37\u91d1\u63a7\u4e3a\u6b66\u6c49\u519c\u5546\u884c\u7b2c\u4e00\u5927\u80a1\u4e1c\uff0c\u6301\u80a1\u6bd4\u4f8b9.98%\u3002\u201c2023\u5e74\uff0c\u5728\u5e02\u653f\u5e9c\u7684\u4e3b\u5bfc\u4e0b\uff0c\u5149\u8c37\u91d1\u63a7\u53d7\u8ba9\u539f\u80a1\u4e1c\u6b66\u6c49\u6d77\u87ba\u7f6e\u4e1a\u53d1\u5c55\u6709\u9650\u516c\u53f8\u53ca\u5176\u5173\u8054\u65b9\u3001\u6b66\u6c49\u65b0\u534e\u5927\u996d\u5e97\u6709\u9650\u516c\u53f8\u7b495\u6237\u5171\u8ba19.98%\u80a1\u4efd\uff0c\u6210\u4e3a\u6211\u884c\u7b2c\u4e00\u5927\u80a1\u4e1c\u3002\u201d\u7136\u800c\uff0c\u6b66\u6c49\u519c\u5546\u884c\u8463\u529e\u5de5\u4f5c\u4eba\u5458\u5bf9\u4e8e\u8fd9\u7b14\u4e0a\u4ebf\u7684\u80a1\u6743\u4ea4\u6613\u5374\u8868\u793a\uff1a\u201c\u90a3\u4e0d\u662f\u5728\u963f\u91cc\u5e73\u53f0\u4e70\u7684\uff0c\u800c\u662f\u6cd5\u9662\u51fa\u5177\u53f8\u6cd5\u88c1\u5b9a\u6587\u4e66\u540e\uff0c\u4ed6\u4eec\u53bb\u6b66\u6c49\u80a1\u6743\u6258\u7ba1\u4ea4\u6613\u4e2d\u5fc3\u505a\u4ea4\u5272\uff0c\u548c\u963f\u91cc\u5e73\u53f0\u4e00\u70b9\u5173\u7cfb\u90fd\u6ca1\u6709\u3002\u201d12\u670819\u65e5\uff0c\u963f\u91cc\u62cd\u5356\u5e73\u53f0\u4e0a\u8fd8\u5c06\u6709\u4e24\u7b14\u5927\u989d\u80a1\u6743\u5f00\u62cd\uff0c\u8fd9\u4e24\u7b14\u80a1\u6743\u56e0\u65e0\u4eba\u51fa\u4ef7\u6216\u8005\u81ea\u884c\u64a4\u56de\u5df2\u6d41\u62cd\u591a\u6b21\u3002\u4e00\u7b14\u662f\u7531\u6b66\u6c49\u6b66\u94a2\u5317\u6e56\u7ecf\u6d4e\u5f00\u53d1\u516c\u53f8\u6301\u6709\u76844399.33\u4e07\u80a1\u6b66\u6c49\u519c\u5546\u884c\u80a1\u6743\uff0c\u8d77\u62cd\u4ef71.04\u4ebf\u5143\uff0c\u6298\u5408\u6bcf\u80a12.368\u5143\uff0c\u8be5\u7b14\u80a1\u6743\u8bc4\u4f30\u4ef7\u663e\u793a\u4e3a1.45\u4ebf\u5143\uff0c\u6298\u5408\u6bcf\u80a13.289\u5143\uff0c\u76f8\u5f53\u4e8e\u8bc4\u4f30\u4ef7\u76847.2\u6298\u3002\u53e6\u4e00\u7b14\u662f\u7531\u6b66\u6c49\u4e0a\u5584\u81f3\u9ad8\u7f6e\u4e1a\u96c6\u56e2\u6709\u9650\u516c\u53f8\u6301\u6709\u76842932.88\u4e07\u80a1\u6b66\u6c49\u519c\u5546\u884c\u80a1\u6743\uff0c\u8d77\u62cd\u4ef76698.41\u4e07\u5143\uff0c\u6298\u5408\u6bcf\u80a12.284\u5143\uff0c\u8be5\u7b14\u80a1\u6743\u8bc4\u4f30\u4ef7\u663e\u793a\u4e0e\u8d77\u62cd\u4ef7\u76f8\u540c\u3002\u5bf9\u4e8e\u8fd9\u4e24\u7b14\u56e0\u7834\u4ea7\u800c\u62cd\u5356\u7684\u80a1\u6743\uff0c\u6b66\u6c49\u519c\u5546\u884c\u8463\u529e\u5de5\u4f5c\u4eba\u5458\u80af\u5b9a\u4e86\u4ea4\u6613\u7684\u771f\u5b9e\u6027\uff0c\u201c\u90a3\u662f\u4f01\u4e1a\u6b63\u5e38\u7ecf\u8425\u7834\u4ea7\uff0c\u6cd5\u9662\u6709\u6307\u5b9a\u5f8b\u6240\u4f5c\u4e3a\u7ba1\u7406\u4eba\u3002\u201d", "link": "https://cn.investing.com/news/stock-market-news/article-2594264", "pub_date": "2024-12-09 00:06:01"}]}