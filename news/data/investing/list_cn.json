57f\u9884\u8ba1\u901a\u80c0\u5c06\u4e8e\u660e\u5e74\u964d\u81f3\u76ee\u6807\u6c34\u5e73\uff0c\u5e76\u4ecd\u4e3a\u7ecf\u6d4e\u4f1a\u66f4\u52a0\u75b2\u8f6f\u3002\u4e9a\u592a\u80a1\u5e02\u5347\u8dcc\u4e92\u73b0\u3002\u7f8e\u5143\u6307\u6570\u671f\u8d27\u3001\u7f8e\u5143\u6307\u6570\u4e0a\u5347\u3002\u91d1\u4ef7\u4e0a\u5347\uff0c\u76d8\u4e2d\u518d\u521b\u5386\u53f2\u65b0\u9ad8\uff0c\u7ebd\u7ea6\u5546\u54c1\u671f\u8d27\u4ea4\u6613\u6240Comex\u9ec4\u91d1\u671f\u8d27\u4ef7\u683c\u4e00\u5ea6\u5347\u81f32704.15\u7f8e\u5143\uff0c\u73b0\u8d27\u9ec4\u91d1\u4ef7\u683c\u4e00\u5ea6\u5347\u81f32688.81\u7f8e\u5143\u3002\u4f26\u6566\u5e03\u4f26\u7279\u539f\u6cb9\u3001\u7f8e\u56fdWTI\u539f\u6cb9\u671f\u8d27\u4ef7\u683c\u57fa\u672c\u6301\u5e73\u3002\u8d22\u62a5\u76d8\u540e\uff1a\u5948\u98de\u516c\u53f8 (NASDAQ:NFLX)\uff0c\u76f4\u89c9\u5916\u79d1\u516c\u53f8 (NASDAQ:ISRG)\uff0c\u963f\u83b1\u6069\u65af\u897f\u90e8\u94f6\u884c (NYSE:WAL)\u3002\u5168\u90e8\u4eca\u65e5\u8d22\u62a5\u8bf7\u8bbf\u95ee\u82f1\u4e3a\u8d22\u60c5Investing.com\u8d22\u62a5\u65e5\u5386\u3002 \u7ecf\u6d4e\u8d44\u6599\u548c\u4e8b\u4ef6\u66f4\u591a\u7ecf\u6d4e\u8d44\u6599\u8bf7\u8bbf\u95ee\u82f1\u4e3a\u8d22\u60c5Investing.com\u8d22\u7ecf\u65e5\u5386\u3002 \u4f7f\u7528InvestingPro\uff0c\u8f7b\u677e\u638c\u63e1\u4f30\u503c\u6570\u636e\uff1a\u5206\u6790\u5e08\u4f30\u503c\uff0c\u4f30\u503c\u6a21\u578b\u4f30\u503c\u2014\u2014\u4e24\u79cd\u7ef4\u5ea6\uff0c\u5168\u9762\u4e86\u89e3\u80a1\u7968\u4f30\u503c\u3002\u591a\u79cd\u597d\u5904\uff1a(1)\u907f\u96f7\u6ce1\u6cab\u80a1\u3001\u80a1\u4ef7\u8fc7\u9ad8\u80a1\u7968\uff1b(2)\u53d1\u73b0\u53ef\u80fd\u906d\u4f4e\u4f30\u7684\u80a1\u7968\uff1b(3)\u8f85\u52a9\u786e\u8ba4\u4e70\u70b9\u5356\u70b9\u3002\u70b9\u51fb\u6b64\u5904\u8fdb\u4e00\u6b65\u4e86\u89e3InvestingPro\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2518568", "pub_date": "2024-10-17 21:15:07"}, {"id": 2518574, "title": "10\u670817\u65e5\u7f8e\u5e02\u652f\u6491\u963b\u529b\uff1a\u91d1\u94f6\u539f\u6cb9+\u7f8e\u5143\u6307\u6570\u7b49\u516b\u5927\u8d27\u5e01\u5bf9", "description": "\n10\u670817\u65e5\u7f8e\u5e02\u9ec4\u91d1\u3001\u767d\u94f6\u3001\u539f\u6cb9\u3001\u7f8e\u5143\u6307\u6570\u3001\u6b27\u5143\u3001\u82f1\u9551\u3001\u65e5\u5143\u3001\u745e\u90ce\u3001\u6fb3\u5143\u3001\u52a0\u5143\u3001\u7ebd\u5143\u652f\u6491\u963b\u529b\u4f4d\u4e00\u89c8\u3002\n", "link": "https://cn.investing.com/news/forex-news/article-2518574", "pub_date": "2024-10-17 21:20:15"}, {"id": 2518504, "title": "\u6b27\u6d32\u592e\u884c\u518d\u964d\u606f25\u57fa\u70b9\uff0c\u6b27\u5143\u51b2\u9ad8\u56de\u843d", "description": "\n\u5317\u4eac\u65f6\u95f410\u670817\u65e5\uff0c\u6b27\u6d32\u592e\u884c(ECB)\u5ba3\u5e03\u4e86\u4eca\u5e74\u7684\u7b2c\u4e09\u6b21\u964d\u606f\uff0c\u5c06\u5b58\u6b3e\u5229\u7387\u4e0b\u8c0325\u4e2a\u57fa\u70b9\u81f33.25%\uff0c\u8fd9\u4e00\u51b3\u5b9a\u7b26\u5408\u77e5\u540d\u673a\u6784\u5206\u6790\u5e08\u7684\u9884\u6d4b\u3002ECB\u7684\u8fd9\u4e00\u4e3e\u63aa\uff0c\u662f\u5bf9\u7ecf\u6d4e\u589e\u957f\u653e\u7f13\u3001\u52b3\u52a8\u529b\u5e02\u573a\u51fa\u73b0\u8f6f\u5316\u8ff9\u8c61\u4ee5\u53ca\u6d88\u8d39\u8005\u4ef7\u683c\u538b\u529b\u7f13\u89e3\u7684\u76f4\u63a5\u56de\u5e94\u3002\u5c3d\u7ba1\u901a\u80c0\u7387\u5df2\u964d\u81f32%\u4ee5\u4e0b\uff0c\u4f46ECB\u5728\u58f0\u660e\u4e2d\u5e76\u672a\u5c31\u4e0b\u4e00\u6b65\u884c\u52a8\u7ed9\u51fa\u660e\u786e\u6307\u5f15\uff0c\u5e02\u573a\u9884\u8ba1\u5728\u672a\u6765\u4e09\u6b21\u4f1a\u8bae\u4e0a\u53ef\u80fd\u4f1a\u6709\u7c7b\u4f3c\u7684\u964d\u606f\u52a8\u4f5c\u3002\u5e02\u573a\u8d70\u52bf\u5206\u6790\u5728ECB\u7684\u5229\u7387\u51b3\u7b56\u516c\u5e03\u540e\uff0c\u6b27\u6d32\u80a1\u5e02\u7684\u53cd\u5e94\u76f8\u5bf9\u5e73\u6de1\u3002\u6b27\u6d32\u65af\u6258\u514b600\u6307\u6570\u5728\u6d88\u606f\u516c\u5e03\u540e\u4ec5\u5c0f\u5e45\u4e0a\u6da80.64%\u3002\u4e0e\u6b64\u540c\u65f6\uff0c\u6b27\u5143\u533a\u56fd\u503a\u6536\u76ca\u7387\u57fa\u672c\u6301\u5e73\uff0c\u5fb7\u56fd10\u5e74\u671f\u56fd\u503a\u6536\u76ca\u7387\u4ec5\u4e0a\u53472\u4e2a\u57fa\u70b9\u81f32.20%\u3002\u8fd9\u8868\u660e\u5e02\u573a\u5df2\u7ecf\u5bf9\u964d\u606f\u4ee5\u53ca\u672a\u6765\u7684\u964d\u606f\u9884\u671f\u6709\u6240\u6d88\u5316\u3002\u5728\u5916\u6c47\u5e02\u573a\uff0c\u6b27\u5143\u5151\u7f8e\u5143EUR/USD\u5728ECB\u51b3\u8bae\u516c\u5e03\u540e\u77ed\u7ebf\u8d70\u9ad8\u903e10\u70b9\u540e\u8fc5\u901f\u56de\u843d\uff0c\u73b0\u62a51.0846\u3002\u5206\u6790\u5e08Justin Low\u8868\u793a\uff0c\u9664\u4e86\u964d\u606f\u672c\u8eab\uff0cECB\u7684\u653f\u7b56\u6c9f\u901a\u6ca1\u6709\u4efb\u4f55\u53d8\u5316\uff0c\u56e0\u6b64\u5e02\u573a\u5bf9\u8fd9\u4efd\u58f0\u660e\u7684\u53cd\u5e94\u76f8\u5bf9\u5e73\u7a33\u3002\u4ea4\u6613\u5458\u4eec\u9884\u8ba1\uff0cECB\u572812\u6708\u5c06\u518d\u6b21\u964d\u606f25\u4e2a\u57fa\u70b9\uff0c\u5230\u660e\u5e746\u6708\u8fd8\u4f1a\u6709\u5927\u7ea6122\u4e2a\u57fa\u70b9\u7684\u964d\u606f\u3002\u5927\u5b97\u5546\u54c1\u5e02\u573a\u5728\u5927\u5b97\u5546\u54c1\u5e02\u573a\uff0c\u73b0\u8d27\u94c2\u91d1\u548cNymex\u94c2\u91d1\u671f\u8d27\u4e3b\u529b\u5408\u7ea6\u5747\u51fa\u73b0\u4e86\u4e0a\u6da8\uff0c\u5206\u522b\u62a51010.05\u7f8e\u5143/\u76ce\u53f8\u548c1019.3\u7f8e\u5143/\u76ce\u53f8\uff0c\u65e5\u5185\u6da8\u5e45\u5206\u522b\u4e3a1.63%\u548c1.67%\u3002\u8fd9\u53ef\u80fd\u53cd\u6620\u4e86\u5e02\u573a\u5bf9ECB\u964d\u606f\u4ee5\u53ca\u672a\u6765\u66f4\u591a\u964d\u606f\u7684\u9884\u671f\uff0c\u56e0\u4e3a\u964d\u606f\u901a\u5e38\u4f1a\u964d\u4f4e\u6301\u6709\u975e\u6536\u76ca\u8d44\u4ea7\u7684\u673a\u4f1a\u6210\u672c\uff0c\u4ece\u800c\u5bf9\u8d35\u91d1\u5c5e\u4ef7\u683c\u6784\u6210\u652f\u6491\u3002\u672a\u6765\u5c55\u671b\u5206\u6790\u5e08\u6307\u51fa\uff0c\u5982\u679c10\u6708\u548c11\u6708\u7684\u901a\u80c0\u548cPMI\u6570\u636e\u7ee7\u7eed\u51fa\u4eba\u610f\u6599\u5730\u4e0b\u884c\uff0c\u90a3\u4e48\u572812\u6708\u7684\u4e0b\u4e00\u6b21\u4f1a\u8bae\u4e0a\u964d\u606f50\u4e2a\u57fa\u70b9\u662f\u6709\u53ef\u80fd\u7684\u3002\u5f53\u524d\u7684\u8d22\u62a5\u5b63\u66f4\u6709\u53ef\u80fd\u4e3b\u5bfc\u5e02\u573a\u8d70\u52bf\uff0c\u800cECB\u7684\u964d\u606f\u51b3\u7b56\u5df2\u7ecf\u88ab\u5e02\u573a\u6240\u9884\u671f\u3002\u5728\u8fd9\u573a\u8fa9\u8bba\u4e2d\uff0cECB\u7684\u9e70\u6d3e\u548c\u9e3d\u6d3e\u5b98\u5458\u4e4b\u95f4\u7684\u5206\u6b67\u4f3c\u4e4e\u5e76\u672a\u5f97\u5230\u89e3\u51b3\u3002\u9e70\u6d3e\u5b98\u5458\u53ef\u80fd\u4f1a\u53cd\u5bf9\u5feb\u901f\u964d\u606f\uff0c\u56e0\u4e3a\u4ed6\u4eec\u62c5\u5fc3\u901a\u80c0\u5728\u672a\u6765\u51e0\u4e2a\u6708\u53ef\u80fd\u4f1a\u4e0a\u5347\u3002\u800c\u9e3d\u6d3e\u5b98\u5458\u5219\u8ba4\u4e3a\uff0c\u9274\u4e8e\u589e\u957f\u7684\u75b2\u8f6f\uff0cECB\u9700\u8981\u8fc5\u901f\u91c7\u53d6\u884c\u52a8\u4ee5\u652f\u6491\u6b27\u5143\u533a\uff0c\u5426\u5219\u901a\u80c0\u53ef\u80fd\u4f1a\u4f4e\u4e8e\u76ee\u6807\u6c34\u5e73\u3002\u603b\u7684\u6765\u8bf4\uff0cECB\u7684\u964d\u606f\u51b3\u7b56\u7b26\u5408\u5e02\u573a\u9884\u671f\uff0c\u4f46\u5e02\u573a\u5bf9ECB\u672a\u6765\u7684\u653f\u7b56\u8def\u5f84\u4ecd\u7136\u5b58\u5728\u4e0d\u786e\u5b9a\u6027\u3002\u6295\u8d44\u8005\u9700\u8981\u5bc6\u5207\u5173\u6ce8\u5373\u5c06\u53d1\u5e03\u7684\u7ecf\u6d4e\u6570\u636e\uff0c\u4ee5\u53caECB\u5b98\u5458\u7684\u8bb2\u8bdd\uff0c\u4ee5\u5bfb\u627e\u66f4\u591a\u5173\u4e8e\u672a\u6765\u653f\u7b56\u65b9\u5411\u7684\u7ebf\u7d22\u3002\n", "link": "https://cn.investing.com/news/forex-news/article-2518504", "pub_date": "2024-10-17 21:00:16"}, {"id": 2518505, "title": "\u4e24\u7ec4\u503c\u5f97\u5173\u6ce8\u7684\u4ea4\u6613\u5bf9\uff1a\u6b27\u5143/\u7f8e\u5143\u3001\u82f1\u9551/\u7f8e\u5143", "description": "\n\u5468\u56db\uff0810\u670817\u65e5\uff09\u6b27\u76d8\u65f6\u6bb5\uff0c\u6b27\u5143/\u7f8e\u5143\u4e0b\u8dcc\u3002\u5728\u82f1\u56fd\u901a\u80c0\u6570\u636e\u4e3a\u8fdb\u4e00\u6b65\u964d\u606f\u94fa\u5e73\u9053\u8def\u540e\uff0c\u82f1\u9551/\u7f8e\u5143\u5f98\u5f8a\u57281.30\u9644\u8fd1\u4ea4\u6613\u3002\u6b27\u5143/\u7f8e\u5143\u8dcc\u7834200\u5747\u7ebf\u6b27\u5143/\u7f8e\u5143\u8fde\u7eed\u7b2c\u56db\u5929\u4e0b\u8dcc\u3002\u4eca\u65e5\uff0c\u6b27\u6d32\u592e\u884c\u516c\u5e03\u964d\u606f25\u4e2a\u57fa\u70b9\uff0c\u5b58\u6b3e\u5229\u7387\u964d\u81f33.25%\u3002\u8fd9\u662f\u6b27\u6d32\u592e\u884c\u81ea6\u6708\u4efd\u5f00\u59cb\u964d\u606f\u4ee5\u6765\u7684\u7b2c\u4e09\u6b21\u964d\u606f\uff0c\u4e5f\u662f\u6b27\u6d32\u592e\u884c\u81ea2013\u5e74\u4ee5\u6765\u9996\u6b21\u8fde\u7eed\u964d\u606f\u3002\u7531\u4e8e\u901a\u8d27\u81a8\u80c0\u7387\u81ea2021\u5e74\u4ee5\u6765\u9996\u6b21\u4f4e\u4e8e2%\u7684\u76ee\u6807\uff0c\u52a0\u4e0a\u7ecf\u6d4e\u524d\u666f\u4e0d\u65ad\u6076\u5316\uff0c\u6b27\u6d32\u592e\u884c\u4f3c\u4e4e\u6b63\u5728\u52a0\u5feb\u964d\u606f\u6b65\u4f10\u3002\u8003\u8651\u5230\u964d\u606f\u5df2\u88ab\u5e02\u573a\u6d88\u5316\uff0c\u4eba\u4eec\u7684\u6ce8\u610f\u529b\u5c06\u96c6\u4e2d\u5728\u6b27\u6d32\u592e\u884c\u7684\u6307\u5f15\u4e0a\uff0c\u6b27\u6d32\u592e\u884c\u7684\u6307\u5f15\u5fc5\u987b\u6e29\u548c\uff0c\u624d\u80fd\u62c9\u4f4e\u6b27\u5143\u3002\u5e02\u573a\u9884\u8ba1\u6b27\u6d32\u592e\u884c\u5c06\u572812\u6708\u518d\u6b21\u964d\u606f\u3002\u4e0e\u6b64\u540c\u65f6\uff0c\u7531\u4e8e\u5e02\u573a\u9884\u671f\u7f8e\u8054\u50a8\u53ef\u80fd\u653e\u6162\u964d\u606f\u6b65\u4f10\uff0c\u7f8e\u5143\u5151\u4e3b\u8981\u8d27\u5e01\u6c47\u7387\u8fbe\u5230\u4e86\u4e24\u4e2a\u534a\u6708\u6765\u7684\u9ad8\u70b9\u3002\u9274\u4e8e\u8fd1\u671f\u7f8e\u56fd\u7ecf\u6d4e\u6570\u636e\u7684\u5f39\u6027\uff0c\u4ee5\u53ca\u7279\u6717\u666e\u5c06\u572811\u6708\u8d62\u5f97\u5927\u9009\u7684\u9884\u671f\u4e0a\u5347\uff0c\u7279\u6717\u666e\u7684\u6838\u5fc3\u653f\u7b56\u662f\u901a\u80c0\uff0c\u8fd9\u53ef\u80fd\u652f\u6301\u7f8e\u5143\u8fdb\u4e00\u6b65\u4e0a\u6da8\u3002\u6b27\u5143/\u7f8e\u5143\u6280\u672f\u5206\u6790\uff08\u6b27\u5143/\u7f8e\u5143\u65e5\u56fe \u6765\u6e90\uff1a\u6613\u6c47\u901a\uff09\u6b27\u5143/\u7f8e\u5143\u57281.12\u5f62\u6210\u53cc\u9876\uff0c\u968f\u540e\u53cd\u5f39\u81f3\u4f4e\u4f4d\uff0c\u5e76\u8dcc\u78341.10\u652f\u6491\u4f4d\u548c200\u5747\u7ebf\u3002\u4ef7\u683c\u7a33\u5b9a\u57281.0850\u4e00\u7ebf\u3002\u867d\u7136\u4ef7\u683c\u4ecd\u4f4e\u4e8e1.10\uff0c\u4f46\u5356\u5bb6\u63e1\u6709\u63a7\u5236\u6743\u3002\u5356\u65b9\u5c06\u5bfb\u6c42\u8dcc\u78341.08\u548c1.0780\u76848\u6708\u4f4e\u70b9\u3002\u4e70\u5bb6\u5c06\u9700\u8981\u4e0a\u6da8\u81f3200\u5747\u7ebf1.0870\u4e0a\u65b9\uff0c\u624d\u80fd\u5c06\u6536\u76ca\u6269\u5927\u81f31.10\u3002\u5982\u679c\u4ef7\u683c\u6500\u5347\u52301.10\u4e4b\u4e0a\uff0c\u6700\u8fd1\u7684\u4e0b\u964d\u8d8b\u52bf\u5c06\u88ab\u5426\u5b9a\u3002\u82f1\u9551/\u7f8e\u5143\u8dcc\u81f31.30\u4ee5\u4e0b\u5728\u6628\u5929\u82f1\u56fd\u516c\u5e03\u4e86\u4f4e\u4e8e\u9884\u671f\u7684\u901a\u80c0\u6570\u636e\u540e\uff0c\u82f1\u9551/\u7f8e\u5143\u8dcc\u81f3\u4e24\u4e2a\u6708\u4f4e\u70b91.30\u4ee5\u4e0b\u3002\u7531\u4e8e\u901a\u8d27\u81a8\u80c0\u7387\u8fdc\u4f4e\u4e8e\u82f1\u683c\u5170\u94f6\u884c2%\u7684\u76ee\u6807\uff0c\u670d\u52a1\u4e1a\u901a\u8d27\u81a8\u80c0\u7387\u4e0b\u964d\u5e45\u5ea6\u4e3a2020\u5e74\u4ee5\u6765\u6700\u5927\uff0c\u4eba\u4eec\u666e\u904d\u9884\u8ba1\u82f1\u683c\u5170\u94f6\u884c\u5c06\u5728\u4e0b\u4e2a\u6708\u964d\u606f25\u4e2a\u57fa\u70b9\uff0c\u5e76\u53ef\u80fd\u572812\u6708\u8fdb\u4e00\u6b65\u964d\u606f25\u4e2a\u57fa\u70b9\u3002\u4eca\u5929\u82f1\u56fd\u7684\u7ecf\u6d4e\u65e5\u5386\u5f88\u5e73\u9759\uff0c\u8ba9\u6295\u8d44\u8005\u7ee7\u7eed\u7422\u78e8\u6628\u5929\u7684\u901a\u80c0\u6570\u636e\u3002\u7f8e\u5143\u5151\u4e3b\u8981\u8d27\u5e01\u5bf9\u5347\u81f32.5\u4e2a\u6708\u9ad8\u4f4d\uff0c\u6b64\u524d\u8fd1\u671f\u7684\u5f3a\u52b2\u6570\u636e\u7a81\u663e\u51fa\u7f8e\u56fd\u7ecf\u6d4e\u7684\u97e7\u6027\uff0c\u5e76\u4fc3\u4f7f\u6295\u8d44\u8005\u6291\u5236\u7f8e\u8054\u50a8\u5927\u4e3e\u964d\u606f\u7684\u62bc\u6ce8\u3002\u7279\u6717\u666e\u4ea4\u6613\u4e5f\u652f\u6301\u7f8e\u5143\uff0c\u56e0\u4e3a\u7279\u6717\u666e\u5728\u4e00\u4e9b\u6c11\u610f\u8c03\u67e5\u4e2d\u5904\u4e8e\u9886\u5148\u5730\u4f4d\uff0c\u8868\u660e\u4ed6\u53ef\u80fd\u5728\u5373\u5c06\u5230\u6765\u7684\u7f8e\u56fd\u5927\u9009\u4e2d\u83b7\u80dc\u3002\u7279\u6717\u666e\u56f4\u7ed5\u5173\u7a0e\u3001\u79fb\u6c11\u548c\u7a0e\u6536\u7684\u653f\u7b56\u4f1a\u5bfc\u81f4\u901a\u80c0\uff0c\u5e76\u53ef\u80fd\u8fdb\u4e00\u6b65\u964d\u4f4e\u7f8e\u8054\u50a8\u5728\u6574\u4e2a\u5468\u671f\u5185\u5927\u4e3e\u964d\u606f\u7684\u9884\u671f\u3002\u5c55\u671b\u672a\u6765\uff0c\u7f8e\u56fd\u96f6\u552e\u9500\u552e\u5c06\u53d7\u5230\u5173\u6ce8\uff0c\u7ee78\u6708\u4efd\u589e\u957f0.1%\u4e4b\u540e\uff0c\u9884\u8ba1\u5c06\u589e\u957f0.3%\u3002\u7f8e\u56fd\u7533\u8bf7\u5931\u4e1a\u6551\u6d4e\u4eba\u6570\u4e5f\u5c06\u53d7\u5230\u5173\u6ce8\uff0c\u9884\u8ba1\u5c06\u4fdd\u6301\u572825.8\u4e07\u4eba\uff0c\u4e0e\u4e0a\u5468\u76f8\u540c\uff0c\u662f\u4e00\u5e74\u6765\u7684\u6700\u9ad8\u6c34\u5e73\u3002\u82f1\u9551/\u7f8e\u5143\u6280\u672f\u5206\u6790\uff08\u82f1\u9551/\u7f8e\u5143\u65e5\u56fe \u6765\u6e90\uff1a\u6613\u6c47\u901a\uff09\u572850\u5747\u7ebf\u4e0b\u65b9\u76841.3020 - 1.31\u4e4b\u95f4\u76d8\u6574\u540e\uff0c\u82f1\u9551/\u7f8e\u5143\u76d8\u4e2d\u8dcc\u78341.30\u5173\u952e\u652f\u6491\u4f4d\u3002\u5728\u8dcc\u78341.30\u548cRSI\u8dcc\u783450\u7684\u652f\u6491\u4e0b\uff0c\u5356\u65b9\u53ef\u80fd\u4f1a\u5c06\u635f\u5931\u6269\u5927\u81f3100\u5747\u7ebf1.2950\uff0c\u4e4b\u540e\u662f\u4e0a\u5347\u8d8b\u52bf\u7ebf\u652f\u6491\u4f4d1.29\u3002\u5982\u679c\u4e70\u5bb6\u8bbe\u6cd5\u593a\u56de1.30\u963b\u529b\u4f4d\uff0c\u5219\u9700\u8981\u5347\u7a7f1.3020 -1.31\u963b\u529b\u4f4d\u533a\u57df\uff0c\u624d\u80fd\u5c06\u6536\u76ca\u6269\u5927\u81f31.32\u3002\u5317\u4eac\u65f6\u95f420:41\uff0c\u6b27\u5143/\u7f8e\u5143\u62a51.0842\uff0c\u8dcc\u5e450.18%\u3002\u82f1\u9551/\u7f8e\u5143\u62a51.2999\uff0c\u6da8\u5e450.08%\u3002\n", "link": "https://cn.investing.com/news/forex-news/article-2518505", "pub_date": "2024-10-17 21:00:31"}, {"id": 2518467, "title": "\u767d\u94f6\u9884\u6d4b\uff1a\u9ec4\u91d1\u7684\u521b\u7eaa\u5f55\u98d9\u5347\u4f1a\u63a8\u52a8\u767d\u94f6\u7a81\u783434.96\u7f8e\u5143\u5417\uff1f", "description": "\n\u5468\u56db\uff0810\u670817\u65e5\uff09\u6b27\u76d8\u65f6\u6bb5\uff0c\u73b0\u8d27\u767d\u94f6\u4ef7\u683c\u5c0f\u5e45\u4e0a\u5347\uff0c\u4ecd\u4f4e\u4e8e10\u67084\u65e5\u7684\u4e3b\u9ad8\u70b932.96\u7f8e\u5143\u3002\u7136\u800c\uff0c\u91d1\u4ef7\u8fd1\u671f\u98d9\u5347\u81f3\u5386\u53f2\u9ad8\u70b9\uff0c\u4ee4\u767d\u94f6\u4ea4\u6613\u5546\u4fdd\u6301\u9ad8\u5ea6\u8b66\u60d5\uff0c\u5bc6\u5207\u5173\u6ce8\u6f5c\u5728\u7684\u6ea2\u51fa\u6548\u5e94\uff0c\u8fd9\u53ef\u80fd\u63a8\u52a8\u94f6\u4ef7\u5347\u81f334.35\u7f8e\u5143\u7684\u591a\u5e74\u9ad8\u70b9\u3002\u767d\u94f6\u5e02\u573a\u5c55\u671b\u5f53\u9ec4\u91d1\u56e0\u5176\u7834\u7eaa\u5f55\u7684\u8868\u73b0\u800c\u6210\u4e3a\u5934\u6761\u65b0\u95fb\u65f6\uff0c\u767d\u94f6\u4e00\u76f4\u5728\u5173\u952e\u963b\u529b\u4f4d\u4e0b\u65b9\u76d8\u6574\u300232.96\u7f8e\u5143\u7684\u5173\u53e3\u65e2\u662f\u94f6\u4ef7\u7684\u963b\u529b\uff0c\u4e5f\u662f\u94f6\u4ef7\u7684\u6f5c\u5728\u8df3\u677f\u3002\u8fd9\u4e00\u7a81\u7834\u53ef\u80fd\u4f1a\u5f15\u53d1\u767d\u94f6\u52a0\u901f\u4e0a\u6da8\uff0c\u53ef\u80fd\u4f1a\u6a21\u4eff\u9ec4\u91d1\u6700\u8fd1\u7684\u6210\u529f\u3002\u9ec4\u91d1\u5bf9\u767d\u94f6\u7684\u5f71\u54cd\u767d\u94f6\u4ea4\u6613\u5546\u6b63\u5bc6\u5207\u5173\u6ce8\u9ec4\u91d1\u7684\u4ef7\u683c\u8d70\u52bf\uff0c\u56e0\u4e3a\u8fd9\u4e24\u79cd\u8d35\u91d1\u5c5e\u7684\u8d70\u52bf\u5f80\u5f80\u76f8\u4e92\u5173\u8054\u3002\u9ec4\u91d1\u4fdd\u6301\u6da8\u52bf\u7684\u80fd\u529b\u53ef\u80fd\u4e3a\u767d\u94f6\u7a81\u7834\u5f53\u524d\u533a\u95f4\u63d0\u4f9b\u5fc5\u8981\u7684\u52a8\u529b\u3002\u9ec4\u91d1\u548c\u767d\u94f6\u4e4b\u95f4\u7684\u8fd9\u79cd\u5173\u7cfb\u5bf9\u4e8e\u60f3\u8981\u5229\u7528\u767d\u94f6\u4e0a\u6da8\u673a\u4f1a\u7684\u4ea4\u6613\u5458\u6765\u8bf4\u81f3\u5173\u91cd\u8981\u3002\u652f\u6301\u8d35\u91d1\u5c5e\u7684\u56e0\u7d20\u6709\u51e0\u4e2a\u5173\u952e\u56e0\u7d20\u4fc3\u6210\u4e86\u8d35\u91d1\u5c5e\u5e02\u573a\u7684\u79ef\u6781\u60c5\u7eea\uff1a\u5bf9\u7f8e\u8054\u50a8\u8fdb\u4e00\u6b65\u964d\u606f\u7684\u9884\u671f\u6301\u7eed\u7684\u5730\u7f18\u653f\u6cbb\u4e0d\u786e\u5b9a\u6027\u5373\u5c06\u5230\u6765\u7684\u7f8e\u56fd\u5927\u9009\u7ed9\u5e02\u573a\u589e\u52a0\u4e86\u53e6\u4e00\u5c42\u4e0d\u786e\u5b9a\u6027\u8fd9\u4e9b\u56e0\u7d20\u4e3b\u8981\u4f7f\u9ec4\u91d1\u53d7\u76ca\uff0c\u4f46\u5b83\u4eec\u7684\u5f71\u54cd\u53ef\u80fd\u4e5f\u4f1a\u5ef6\u4f38\u5230\u767d\u94f6\u3002\u767d\u94f6\u5e02\u573a\u9884\u6d4b\u5728\u4f26\u6566\u91d1\u94f6\u5e02\u573a\u534f\u4f1a\uff08London Bullion Market Association\uff09\u7684\u5e74\u5ea6\u4f1a\u8bae\u4e0a\uff0c\u4ee3\u8868\u4eec\u9884\u6d4b\u9ec4\u91d1\u548c\u767d\u94f6\u90fd\u5c06\u8868\u73b0\u5f3a\u52b2\u3002\u76db\u5b9d\u94f6\u884c\uff08Saxo Bank\uff09\u5927\u5b97\u5546\u54c1\u7b56\u7565\u4e3b\u7ba1\u5965\u52d2\u00b7\u6c49\u68ee\uff08Ole Hansen\uff09\u6307\u51fa\uff0c\u9884\u6d4b\u663e\u793a\uff0c\u672a\u6765\u4e00\u5e74\u767d\u94f6\u7684\u8868\u73b0\u751a\u81f3\u53ef\u80fd\u8d85\u8fc7\u9ec4\u91d1\u3002\u8fd9\u79cd\u4e50\u89c2\u7684\u524d\u666f\u6b63\u5438\u5f15\u8d8a\u6765\u8d8a\u591a\u7684\u4eba\u5173\u6ce8\u767d\u94f6\u8fd9\u4e00\u53ef\u80fd\u88ab\u4f4e\u4f30\u7684\u8d44\u4ea7\u3002\u7ecf\u6d4e\u6570\u636e\u53ca\u5176\u5bf9\u767d\u94f6\u7684\u5f71\u54cd\u4ea4\u6613\u5546\u6b63\u5173\u6ce8\u5373\u5c06\u516c\u5e03\u7684\u7f8e\u56fd\u7ecf\u6d4e\u6570\u636e\uff0c\u5305\u62ec\u96f6\u552e\u9500\u552e\u3001\u5de5\u4e1a\u751f\u4ea7\u548c\u6bcf\u5468\u521d\u8bf7\u5931\u4e1a\u91d1\u4eba\u6570\u3002\u4ee4\u4eba\u5931\u671b\u7684\u6570\u636e\u53ef\u80fd\u4f1a\u5168\u9762\u63d0\u632f\u8d35\u91d1\u5c5e\u4ef7\u683c\u3002\u767d\u94f6\u517c\u5177\u8d35\u91d1\u5c5e\u548c\u5de5\u4e1a\u91d1\u5c5e\u7684\u53cc\u91cd\u89d2\u8272\uff0c\u5982\u679c\u7ecf\u6d4e\u4e0d\u786e\u5b9a\u6027\u4e0a\u5347\uff0c\u767d\u94f6\u7684\u9700\u6c42\u53ef\u80fd\u4f1a\u589e\u52a0\u3002\u5e02\u573a\u9884\u6d4b\uff08\u73b0\u8d27\u767d\u94f6\u65e5\u56fe \u6765\u6e90\uff1a\u6613\u6c47\u901a\uff09\u767d\u94f6\u7684\u77ed\u671f\u524d\u666f\u4f3c\u4e4e\u8c28\u614e\u770b\u6da8\u3002\u867d\u7136\u767d\u94f6\u76ee\u524d\u843d\u540e\u4e8e\u9ec4\u91d1\u7684\u5f3a\u52b2\u6da8\u5e45\uff0c\u4f46\u5982\u679c\u5b83\u80fd\u7a81\u7834\u5173\u952e\u963b\u529b\u4f4d\uff0c\u767d\u94f6\u6709\u671b\u4e0a\u6da8\u3002\u8fdb\u4e00\u6b65\u964d\u606f\u7684\u53ef\u80fd\u6027\u548c\u6301\u7eed\u7684\u5168\u7403\u7ecf\u6d4e\u4e0d\u786e\u5b9a\u6027\u4e3a\u8d35\u91d1\u5c5e\u521b\u9020\u4e86\u6709\u5229\u7684\u73af\u5883\uff0c\u767d\u94f6\u7684\u5b9a\u4f4d\u53ef\u80fd\u4f1a\u7f29\u5c0f\u4e0e\u9ec4\u91d1\u7684\u5dee\u8ddd\u3002\u4ea4\u6613\u8005\u5e94\u8be5\u5173\u6ce8\u767d\u94f6\u8ddf\u968f\u9ec4\u91d1\u8d70\u5f3a\u7684\u4efb\u4f55\u8ff9\u8c61\uff0c\u7279\u522b\u662f\u5982\u679c\u767d\u94f6\u80fd\u591f\u7ef4\u6301\u572832.96\u7f8e\u5143\u4ee5\u4e0a\u7684\u6c34\u5e73\u3002\u5317\u4eac\u65f6\u95f420:17\uff0c\u73b0\u8d27\u767d\u94f6\u62a531.722\u7f8e\u5143/\u76ce\u53f8\uff0c\u6da8\u5e450.21%\u3002COMEX\u767d\u94f6\u62a531.930\u7f8e\u5143/\u76ce\u53f8\uff0c\u8dcc\u5e450.14%\u3002\n", "link": "https://cn.investing.com/news/forex-news/article-2518467", "pub_date": "2024-10-17 20:40:16"}, {"id": 2518419, "title": "\u82f1\u4f1f\u8fbe\u53473%\uff0cAMD\u53472.5%\uff0c\u82af\u7247\u80a1\u96c6\u4f53\u72c2\u6b22", "description": "\u82f1\u4e3a\u8d22\u60c5Investing.com - \u5468\u56db\uff0817\u65e5\uff09\u76d8\u524d\uff0c\u82af\u7247\u80a1\u666e\u5347\uff0c\u5f97\u76ca\u4e8e\u53f0\u79ef\u7535(NYSE:TSM)\u516c\u5e03\u4e86\u9753\u4e3d\u7684\u8d22\u62a5\u3002\n\u82f1\u4f1f\u8fbe(NASDAQ:NVDA\u53473%\uff0cAMD (NASDAQ:AMD)\u53472.5%\uff0c\u535a\u901a(NASDAQ:AVGO)\u53472.9%\u3002\n\u6b64\u5916\uff0c\u82f1\u7279\u5c14(NASDAQ:INTC)\u53471%\uff0c\u9ad8\u901a(NASDAQ:QCOM)\u53472.5%\uff0c\u7f8e\u5149\u79d1\u6280(NASDAQ:MU)\u53472.2%\u3002\n\n\u4e00\u7ad9\u5f0f\u67e5\u770b\u5168\u7403\u80a1\u5e02\u8d22\u62a5\u9884\u6d4b\uff0c\u5b63\u5ea6\u3001\u5e74\u5ea6\u3001\u8fc7\u53bb\u3001\u73b0\u5728\u3001\u672a\u6765\u5168\u90fd\u6709\uff0c\u5c31\u5728InvestingPro\uff0c\u70b9\u51fb\u6b64\u5904\u4e86\u89e3\u8be6\u60c5\u3002\n\n\u6839\u636e\u53f0\u79ef\u7535\u8d22\u62a5\uff0c\u516c\u53f87-9\u6708\u51c0\u5229\u6da6\u589e\u957f54%\u81f33253\u4ebf\u65b0\u53f0\u5e01\uff08101\u4ebf\u7f8e\u5143\uff09\uff0c\u4e3b\u8981\u53d7\u76ca\u4e0eAI\u5e94\u7528\u9a71\u52a8\u7684\u9700\u6c42\uff0c\u8d85\u8fc7\u9884\u671f\u76843002\u4ebf\u65b0\u53f0\u5e01\u3002\n\u7b2c\u4e09\u5b63\u5ea6\u51c0\u6536\u5165\u8fbe235\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f36%\u3002\u516c\u53f87-9\u6708\u6bdb\u5229\u7387\u63d0\u5347\u81f357.8%\uff0c\u800c\u53bb\u5e74\u540c\u671f\u4e3a54.3%\u3002\n\u53f0\u79ef\u7535\u5728\u58f0\u660e\u4e2d\u8868\u793a\uff0c\u7b2c\u4e09\u5b63\u5ea6\u300c\u6211\u4eec\u7684\u4e1a\u52a1\u5f97\u5230\u4e86\u667a\u6167\u624b\u673a\u548cAI\u76f8\u5173\u9700\u6c42\u7684\u5f3a\u52b2\u652f\u6301\uff0c\u7279\u522b\u662f\u5bf9\u6211\u4eec\u9886\u5148\u4e1a\u754c\u76843nm\u548c5nm\u6280\u672f\u7684\u9700\u6c42\u3002\u300d\n\u5728\u8d22\u62a5\u7535\u8bdd\u4f1a\u8bae\u4e0a\uff0c\u53f0\u79ef\u7535\u8463\u4e8b\u957f\u517c\u9996\u5e2d\u6267\u884c\u5b98\u5f3a\u8c03\uff0cAI\u9700\u6c42\u662f\u771f\u5b9e\u7684\uff0c\u5e76\u6307\u51fa\u7531\u6b64\u516c\u53f8\u7ecf\u5386\u4e86\u8fd9\u4e2a\u884c\u4e1a\u4e2d\u6700\u6df1\u3001\u6700\u5e7f\u7684\u589e\u957f\u3002\n\u6839\u636eFactSet\u63d0\u4f9b\u7684\u7535\u8bdd\u4f1a\u8bae\u8bb0\u5f55\uff0c\u4ed6\u8868\u793a\uff1a\u6211\u4eec\u4e00\u76f4\u4e0e\u5ba2\u6237\u4fdd\u6301\u6c9f\u901a\uff0c\u5305\u62ec\u90a3\u4e9b\u6b63\u5728\u5f00\u53d1\u81ea\u5df1\u82af\u7247\u7684\u8d85\u5927\u89c4\u6a21\u5ba2\u6237\u3002\u51e0\u4e4e\u6bcf\u4e00\u4e2aAI\u521b\u65b0\u8005\u90fd\u5728\u4e0e\u53f0\u79ef\u7535\u5408\u4f5c\u3002\n\u53f0\u79ef\u7535\u73b0\u9884\u8ba1\u4eca\u5e74\u8d44\u672c\u652f\u51fa\u5c06\u7565\u9ad8\u4e8e300\u4ebf\u7f8e\u5143\u3002\u516c\u53f8\u7b2c\u4e09\u5b63\u5ea6\u8d44\u672c\u652f\u51fa\u5347\u81f364\u4ebf\u7f8e\u5143\uff0c\u9ad8\u4e8e\u524d\u4e09\u4e2a\u6708\u768463.6\u4ebf\u7f8e\u5143\u3002\nThemes ETFs\u9996\u5e2d\u8425\u6536\u5b98Paul Marino\u5bf9\u82f1\u4e3a\u8d22\u60c5Investing.com\u8868\u793a\uff1a\u53f0\u79ef\u7535\u662f\u8861\u91cfAI\u6d6a\u6f6e\u548c\u8d85\u5927\u89c4\u6a21\u6570\u636e\u4e2d\u5fc3\u80fd\u591a\u5feb\u5efa\u6210\uff0c\u4ee5\u53ca\u8be5\u9886\u57df\u4f9b\u5e94\u52a8\u6001\u6709\u591a\u5065\u5eb7\u7684\u91cd\u8981\u6307\u6807\u3002\n\u53f0\u79ef\u7535\u5728\u53f0\u5317\u4e0a\u5e02\u7684\u80a1\u7968\u4eca\u5e74\u8fc4\u4eca\u5df2\u98d9\u5347\u8fd180%\uff0c\u8fdc\u8d85\u5927\u76d828.57%\u7684\u5347\u5e45\u3002\n\u516c\u53f8\u5f3a\u52b2\u7684\u7b2c\u4e09\u5b63\u5ea6\u4e1a\u7ee9\u6709\u52a9\u4e8e\u6539\u5584\u6295\u8d44\u8005\u60c5\u7eea\uff0c\u6b64\u524d\u6b27\u6d32\u82af\u7247\u5236\u9020\u5546\u963f\u65af\u9ea6(AS:ASML)\u53d1\u5e03\u7684\u6307\u5f15\u548c\u4e1a\u7ee9\u4ee4\u4eba\u5931\u671b\u3002\u963f\u65af\u9ea6\u56e0\u7ed9\u51fa\u4f4e\u4e8e\u9884\u671f\u7684\u51c0\u9500\u552e\u9884\u6d4b\u800c\u80a1\u4ef7\u66b4\u8dcc\u3002\nMarino\u8bc4\u8bba\u9053\uff1a\u963f\u65af\u9ea6\u6307\u5f15\u5982\u6b64\u4e4b\u4f4e\uff0c\u8ba9\u6295\u8d44\u8005\u5bf9AI\u9700\u6c42\u662f\u5426\u5982\u9884\u671f\u7684\u90a3\u4e48\u5927\u4ea7\u751f\u4e86\u4e00\u4e9b\u7591\u8651\u3002\u8fd9\u4e5f\u8ba9\u672a\u6765\u6bcf\u5bb6\u534a\u5bfc\u4f53\u516c\u53f8\u62a5\u544a\u65f6\u7684\u6307\u5f15\u5907\u53d7\u5173\u6ce8\u3002\n\u300c\u8bdd\u867d\u5982\u6b64\uff0c\u6211\u786e\u5b9e\u8ba4\u4e3a\u50cfAMD\u548c\u82f1\u4f1f\u8fbe\u8fd9\u6837\u7684\u516c\u53f8\u5728\u9700\u6c42\u4e0a\u5b58\u5728\u663e\u8457\u5dee\u5f02\uff0c\u6295\u8d44\u8005\u5c06\u5728\u672c\u5b63\u5ea6\u665a\u4e9b\u65f6\u5019\u5b83\u4eec\u53d1\u5e03\u8d22\u62a5\u65f6\uff0c\u5bfb\u627e\u80fd\u591f\u8bc1\u660e\u5f53\u524d\u4f30\u503c\u5408\u7406\u6027\u7684\u5f3a\u52b2\u6307\u5f15\u3002\u300d\n\nNetflix\u8d22\u62a5\u4eca\u65e5\u6765\u88ad\uff0c\u70b9\u51fb\u6b64\u5904\u67e5\u770bNetflix\u8d22\u62a5\u9884\u6d4b\uff0c\u6db5\u76d6\u4eca\u65e5\u8d22\u62a5\uff0c\u5168\u8d22\u5e74\u4e1a\u7ee9\uff0c\u672a\u6765\u591a\u5e74\u7684\u4e1a\u7ee9\u9884\u6d4b\u3002\n\u67e5\u8be2\u8d22\u62a5\u9884\u6d4b\u6570\u636e\uff0c\u5c31\u4e0aInvestingPro\u3002\u70b9\u51fb\u6b64\u5904\u8fdb\u4e00\u6b65\u4e86\u89e3InvestingPro\u3002\n", "link": "https://cn.investing.com/news/stock-market-news/article-2518419", "pub_date": "2024-10-17 20:26:52"}]}