2%\uff0c\u62a52679.50\u7f8e\u5143/\u76ce\u53f8\u3002COMEX\u767d\u94f6\u671f\u8d27\u6da80.18%\uff0c\u62a531.685\u7f8e\u5143/\u76ce\u53f8\u3002\u3010\u539f\u6cb9\u3011\u7ebd\u7ea6\u5546\u54c1\u4ea4\u6613\u624011\u6708\u4ea4\u5272\u7684\u897f\u5f97\u5dde\u4e2d\u8d28\u539f\u6cb9(WTI)\u671f\u8d27\u4ef7\u683c\u6536\u8dcc3.25\u7f8e\u5143\uff0c\u8dcc\u5e45\u4e3a4.40%\uff0c\u6536\u4e8e\u6bcf\u687670.58\u7f8e\u5143\uff1b\u6b27\u6d32\u6d32\u9645\u4ea4\u6613\u624012\u6708\u4ea4\u5272\u7684\u5e03\u4f26\u7279\u539f\u6cb9\u671f\u8d27\u4ef7\u683c\u4e0b\u8dcc4.14%\uff0c\u6536\u4e8e\u6bcf\u687674.25\u7f8e\u5143\u3002\u3010\u91d1\u5c5e\u3011\u4f26\u6566\u91d1\u5c5e\u4e0b\u8dcc\uff0c\u4f26\u954d\u3001\u4f26\u94dc\u8dcc\u8d851.2%\uff0c\u4f26\u94dd\u8dcc0.96%\uff0c\u4f26\u950c\u8dcc\u8d851.3%\u3002\u3010\u5b8f\u89c2\u6d88\u606f\u3011\u7f8e\u8054\u50a8\u6234\u5229\uff1a\u592e\u884c\u5b98\u5458\u5fc5\u987b\u4fdd\u6301\u8b66\u60d5\u4ee5\u7ef4\u62a4\u7ecf\u6d4e\u589e\u957f\u3002\u65e7\u91d1\u5c71\u8054\u50a8\u4e3b\u5e2d\u6234\u5229\u8868\u793a\uff0c\u968f\u7740\u901a\u80c0\u4e0b\u964d\u800c\u52b3\u52a8\u529b\u5e02\u573a\u964d\u6e29\uff0c\u7f8e\u8054\u50a8\u5fc5\u987b\u4fdd\u6301\u8b66\u60d5\uff0c\u4e0d\u8fc7\u5979\u4e50\u89c2\u5730\u8ba4\u4e3a\u5b98\u5458\u80fd\u591f\u7ef4\u6301\u5f53\u524d\u7ecf\u6d4e\u6269\u5f20\u7684\u52bf\u5934\u3002\u6234\u5229\u8868\u793a\uff0c\u52b3\u52a8\u8005\u6b63\u53d7\u76ca\u4e8e\u5f3a\u52b2\u7684\u52b3\u52a8\u529b\u5e02\u573a\uff0c\u8be5\u5e02\u573a\u5438\u5f15\u4e86\u66f4\u591a\u4eba\u52a0\u5165\u52b3\u52a8\u529b\uff0c\u5e76\u7f29\u5c0f\u4e86\u6536\u5165\u5dee\u8ddd\uff0c\u5c31\u50cf\u8fc7\u53bb\u7684\u957f\u671f\u589e\u957f\u65f6\u671f\u4e00\u6837\u3002\u201c\u6211\u4eec\u5df2\u7ecf\u5728\u5f53\u524d\u7684\u6269\u5f20\u4e2d\u770b\u5230\u4e86\u4e00\u4e9b\u76f8\u540c\u7684\u6a21\u5f0f\u3002\u58ee\u5e74\u7684\u52b3\u52a8\u53c2\u4e0e\u7387\u8fbe\u5230\u65b0\u9ad8\uff0c\u201d\u6234\u5229\u8868\u793a\uff0c\u201c\u4e0e\u8fd1\u6765\u7684\u5386\u53f2\u76f8\u6bd4\uff0c\u5f53\u524d\u7684\u7ecf\u6d4e\u6269\u5f20\u4ecd\u5904\u4e8e\u76f8\u5bf9\u65e9\u671f\u3002\u201d\u6234\u5229\u8ba4\u4e3a\uff0c\u5728\u8d27\u5e01\u653f\u7b56\u56de\u5f52\u4e2d\u6027\u4e4b\u524d\uff0c\u7f8e\u8054\u50a8\u4ecd\u6709\u51e0\u6b21\u964d\u606f\u3002\u6234\u5229\u5728\u8c08\u5230\u8054\u90a6\u57fa\u91d1\u5229\u7387\u65f6\u8bf4\uff1a\u201c\u4e8b\u5b9e\u662f\uff0c\u6211\u4eec\u79bb\u53ef\u80fd\u8fbe\u5230\u7684\u6c34\u5e73\u8fd8\u6709\u5f88\u957f\u7684\u8def\u8981\u8d70\u3002\u201d\u5979\u8865\u5145\u8bf4\uff0c\u540d\u4e49\u4e2d\u6027\u5229\u7387\u6709\u53ef\u80fd\u5728\u75ab\u60c5\u7206\u53d1\u524d\u6709\u6240\u4e0a\u5347\uff0c\u4f46\u786e\u5207\u7684\u6c34\u5e73\u5f88\u96be\u51c6\u786e\u9884\u6d4b\u3002\u5979\u8868\u793a\uff0c3%\u53ef\u80fd\u662f\u4e2a\u4e0d\u9519\u7684\u731c\u6d4b\u3002\u7ebd\u7ea6\u8054\u50a8\u8c03\u67e5\uff1a\u9884\u671f\u5c06\u62d6\u6b20\u503a\u52a1\u7684\u7f8e\u56fd\u6d88\u8d39\u8005\u6bd4\u4f8b\u5347\u81f32020\u5e74\u6765\u6700\u9ad8\u3002\u6839\u636e\u7ebd\u7ea6\u8054\u90a6\u50a8\u5907\u94f6\u884c\u7684\u4e00\u9879\u8c03\u67e5\uff0c\u9884\u8ba1\u81ea\u5df1\u53ef\u80fd\u62d6\u6b20\u503a\u52a1\u7684\u7f8e\u56fd\u6d88\u8d39\u8005\u6bd4\u4f8b\u4e0a\u4e2a\u6708\u4e0a\u5347\u81f32020\u5e744\u6708\u4ee5\u6765\u7684\u6700\u9ad8\u6c34\u5e73\u3002\u6839\u636e\u5468\u4e8c\u516c\u5e03\u7684\u7ebd\u7ea6\u8054\u50a8\u6708\u5ea6\u6d88\u8d39\u8005\u9884\u671f\u8c03\u67e5\u7ed3\u679c\uff0c\u9884\u8ba1\u672a\u6765\u4e09\u4e2a\u6708\u65e0\u6cd5\u652f\u4ed8\u6700\u4f4e\u8fd8\u6b3e\u989d\u7684\u6d88\u8d39\u8005\u6bd4\u4f8b\u4e0a\u5347\u81f314.2%\uff0c\u8fde\u7eed\u7b2c\u56db\u4e2a\u6708\u8d70\u9ad8\u3002\u4e2d\u5e74\u53d7\u8bbf\u8005\u63a8\u52a8\u4e86\u8fd9\u4e00\u6bd4\u4f8b\u4e0a\u5347\u3002\u3002\u8fd9\u4e9b\u6570\u636e\u8fdb\u4e00\u6b65\u5370\u8bc1\u4e86\u8fd9\u6837\u4e00\u79cd\u89c2\u70b9\uff0c\u5373\u7f8e\u56fd\u7ecf\u6d4e\u6b63\u53d8\u5f97\u8d8a\u6765\u8d8a\u5206\u5316\uff0c\u4e00\u4e9b\u5bb6\u5ead\u8fc7\u5f97\u5f88\u597d\uff0c\u800c\u53e6\u4e00\u4e9b\u5bb6\u5ead\u5219\u5ea6\u65e5\u8270\u96be\u3002\u8fc7\u53bb\u51e0\u4e2a\u6708\uff0c\u80a1\u5e02\u4e0a\u6da8\u5e2e\u52a9\u63a8\u52a8\u6574\u4f53\u5bb6\u5ead\u51c0\u8d44\u4ea7\u8fbe\u5230\u521b\u7eaa\u5f55\u6c34\u5e73\uff0c\u4f46\u8bb8\u591a\u7f8e\u56fd\u4eba\u5e76\u6ca1\u6709\u5927\u91cf\u6301\u6709\u80a1\u7968\uff0c\u800c\u4e14\u8fd1\u5e74\u6765\u5728\u5229\u7387\u4e0a\u5347\u7684\u60c5\u51b5\u4e0b\u503a\u52a1\u589e\u52a0\u3002\u52a0\u62ff\u59279\u6708\u901a\u80c0\u7387\u964d\u81f31.6%\u3002\u52a0\u62ff\u5927\u7edf\u8ba1\u5c40\u5f53\u5730\u65f6\u95f415\u65e5\u53d1\u5e03\u62a5\u544a\u79f0\uff0c2024\u5e749\u6708\u52a0\u62ff\u5927\u6d88\u8d39\u8005\u4ef7\u683c\u6307\u6570\uff08CPI\uff09\u540c\u6bd4\u589e\u957f1.6%\uff0c\u4f4e\u4e8e8\u67082%\u7684\u6da8\u5e45\u3002\u8fd9\u662f\u81ea2021\u5e742\u6708\u4ee5\u6765\u7684\u6700\u5c0f\u6da8\u5e45\u3002\u62a5\u544a\u79f0\uff0c\u6c7d\u6cb9\u4ef7\u683c\u4e0b\u8dcc\u662f9\u6708\u6574\u4f53\u901a\u80c0\u7387\u4e0b\u964d\u7684\u4e3b\u8981\u539f\u56e0\u3002\u52a0\u62ff\u5927\u592e\u884c\u4eca\u5e74\u6765\u5df2\u7ecf3\u6b21\u4e0b\u8c03\u57fa\u51c6\u5229\u7387\uff0c\u6bcf\u6b21\u964d\u606f25\u4e2a\u57fa\u70b9\uff0c\u81f34.25%\u3002\u5206\u6790\u8ba4\u4e3a\uff0c9\u6708\u7684\u6570\u636e\u52a0\u5927\u4e86\u52a0\u62ff\u5927\u592e\u884c\u52a0\u5feb\u964d\u606f\u7684\u53ef\u80fd\u6027\u3002\u3010\u4e2a\u80a1\u6d88\u606f\u3011\u963f\u65af\u9ea6(ASML.US)Q3\u4e1a\u7ee9\u63d0\u524d\u516c\u5e03\uff0c\u516c\u53f8\u524d\u666f\u4ee4\u4eba\u5931\u671b\u3002\u5f53\u5730\u65f6\u95f4\u5468\u4e8c\u65e9\u4e9b\u65f6\u5019\uff0c\u963f\u65af\u9ea6\u539f\u672c\u5b9a\u4e8e\u5468\u4e09\u516c\u5e03Q3\u4e1a\u7ee9\u62a5\u544a\u56e0\u6280\u672f\u9519\u8bef\u88ab\u77ed\u6682\u5730\u63d0\u524d\u516c\u5e03\uff0c\u867d\u7136\u94fe\u63a5\u5f88\u5feb\u88ab\u5220\u9664\uff0c\u4f46\u62a5\u544a\u5728\u4e2d\u5348\u524d\u5c31\u5b8c\u5168\u516c\u5e03\u51fa\u6765\u3002\u62a5\u544a\u4e2d\u7684\u91cd\u5927\u65b0\u95fb\u662f\u8be5\u516c\u53f8\u4ee4\u4eba\u5931\u671b\u7684\u524d\u666f\uff0c\u6839\u636eFactSet\u7684\u6570\u636e\uff0c\u76ee\u524d\u9884\u8ba1\u963f\u65af\u9ea62025\u5e74\u7684\u603b\u51c0\u9500\u552e\u989d\u5c06\u8fbe\u5230300\u4ebf\u6b27\u5143\u81f3350\u4ebf\u6b27\u5143\uff0c\u800c\u5e02\u573a\u666e\u904d\u9884\u6d4b\u4e3a358\u4ebf\u6b27\u5143\u3002\u963f\u65af\u9ea6\u9996\u5e2d\u6267\u884c\u5b98Christophe Fouquet\u8868\u793a\uff0c\u201c\u5c3d\u7ba1\u4eba\u5de5\u667a\u80fd\u4ecd\u6709\u5f3a\u52b2\u7684\u53d1\u5c55\u548c\u4e0a\u5347\u6f5c\u529b\uff0c\u4f46\u5176\u4ed6\u7ec6\u5206\u5e02\u573a\u9700\u8981\u66f4\u957f\u7684\u65f6\u95f4\u624d\u80fd\u590d\u82cf\u3002\u73b0\u5728\u770b\u6765\uff0c\u7ecf\u6d4e\u590d\u82cf\u6bd4\u4e4b\u524d\u9884\u671f\u7684\u66f4\u4e3a\u7f13\u6162\u3002\u9884\u8ba1\u8fd9\u79cd\u60c5\u51b5\u5c06\u6301\u7eed\u52302025\u5e74\uff0c\u8fd9\u5bfc\u81f4\u5ba2\u6237\u6301\u8c28\u614e\u6001\u5ea6\u3002\u201dAI\u70ed\u6f6e\u63a8\u52a8\u82f9\u679c(AAPL.US)\u80a1\u4ef7\u521b\u76d8\u4e2d\u5386\u53f2\u65b0\u9ad8 \u7a33\u5750\u5e02\u503c\u7b2c\u4e00\u5b9d\u5ea7\u3002\u82f9\u679c\u516c\u53f8\u80a1\u4ef7\u5468\u4e8c\u6269\u5927\u6da8\u52bf\uff0c\u76d8\u4e2d\u5347\u81f3\u7eaa\u5f55\u9ad8\u4f4d\uff0c\u5f97\u76ca\u4e8e\u5e02\u573a\u4e50\u89c2\u9884\u671f\u8be5\u516c\u53f8\u5c06\u53d7\u76ca\u4e8e\u4eba\u5de5\u667a\u80fdiPhone\u7684\u63a8\u51fa\u3002\u8be5\u80a1\u4e00\u5ea6\u4e0a\u6da82.7%\uff0c\u81f3237.49\u7f8e\u5143\uff0c\u521b7\u6708\u4ee5\u6765\u9996\u4e2a\u7eaa\u5f55\u9ad8\u70b9\u3002\u8fd9\u6ce2\u6da8\u52bf\u5de9\u56fa\u4e86\u82f9\u679c\u4f5c\u4e3a\u5168\u7403\u6700\u5927\u516c\u53f8\u7684\u5730\u4f4d\uff0c\u5176\u5e02\u503c\u7a81\u78343.6\u4e07\u4ebf\u7f8e\u5143\u3002\u867d\u7136\u5927\u578b\u79d1\u6280\u516c\u53f8\u5e7f\u6cdb\u4e0a\u6da8\uff0c\u4f46\u82f9\u679c\u7684\u8868\u73b0\u5c24\u4e3a\u5f3a\u52b2\u3002\u8be5\u80a1\u5728\u8fc7\u53bb\u516d\u4e2a\u6708\u4e0a\u6da8\u4e8637%\uff0c\u662f\u7eb3\u65af\u8fbe\u514b100\u6307\u657015.5%\u6da8\u5e45\u7684\u4e24\u500d\u4ee5\u4e0a\u3002\u6ce2\u97f3(BA.US)\u6709\u671b\u7b79\u96c6\u9ad8\u8fbe250\u4ebf\u7f8e\u5143\u8d44\u91d1\u3002\u6ce2\u97f3\u8868\u793a\u53ef\u80fd\u901a\u8fc7\u53d1\u884c\u65b0\u80a1\u6216\u503a\u52a1\u7b79\u96c6\u9ad8\u8fbe250\u4ebf\u7f8e\u5143\u7684\u8d44\u91d1\uff0c\u4ee5\u7f13\u89e3\u591a\u5e74\u6765\u7684\u5de8\u989d\u4e8f\u635f\u5bf9\u5176\u8d22\u52a1\u72b6\u51b5\u7684\u538b\u529b\u3002\u8be5\u516c\u53f8\u8fd8\u8868\u793a\uff0c\u5df2\u4e0e\u591a\u5bb6\u7f8e\u56fd\u94f6\u884c\u8fbe\u6210\u4e86\u4e00\u9879100\u4ebf\u7f8e\u5143\u7684\u8865\u5145\u4fe1\u8d37\u534f\u8bae\u3002\u76d1\u7ba1\u6587\u4ef6\u663e\u793a\uff0c\u8be5\u516c\u53f8\u672a\u6765\u4e09\u5e74\u5185\u53ef\u80fd\u901a\u8fc7\u7b79\u96c6\u8d44\u91d1\u5e76\u4e0e\u8d37\u6b3e\u65b9\u8fbe\u6210\u65b0\u7684\u501f\u6b3e\u534f\u8bae\u6765\u5de9\u56fa\u5176\u8d22\u52a1\u72b6\u51b5\u3002\u81ea2019\u5e74\u521d\u4ee5\u6765\uff0c\u6ce2\u97f3\u516c\u53f8\u5df2\u635f\u5931\u8d85\u8fc7250\u4ebf\u7f8e\u5143\uff0c\u800c\u968f\u7740\u5176\u4e3b\u8981\u751f\u4ea7\u822a\u7a7a\u5ba2\u673a\u7684\u5de5\u4eba\u7f62\u5de5\u8fdb\u5165\u7b2c\u4e8c\u4e2a\u6708\uff0c\u516c\u53f8\u8d22\u52a1\u9762\u4e34\u65b0\u7684\u538b\u529b\u3002\u7f62\u5de5\u6b63\u5728\u5f71\u54cd\u516c\u53f8\u7684\u73b0\u91d1\u6d41\u3002\u6ce2\u97f3\u5df2\u6d88\u8017\u6389\u8d85\u8fc710\u4ebf\u7f8e\u5143\u7684\u73b0\u91d1\uff0c\u622a\u81f39\u6708\uff0c\u516c\u53f8\u5269\u4f59\u73b0\u91d1\u548c\u8bc1\u5238\u603b\u989d\u4e3a103\u4ebf\u7f8e\u5143\u3002\u4e0a\u5468\u4e94\uff0c\u6ce2\u97f3\u65b0\u4efb\u9996\u5e2d\u6267\u884c\u5b98Kelly Ortberg\u8868\u793a\uff0c\u516c\u53f8\u5c06\u88c1\u5458\u7ea610%\uff0c\u76f8\u5f53\u4e8e\u7ea617,000\u4e2a\u804c\u4f4d\uff0c\u5e76\u63a8\u8fdf\u4e86\u4e00\u6b3e\u65b0\u578b777\u5927\u578b\u5ba2\u673a\u7684\u53d1\u5e03\u8ba1\u5212\u3002\u7531\u4e8e\u7f62\u5de5\uff0c\u6ce2\u97f3\u516c\u53f8\u76ee\u524d\u7684777\u673a\u578b\u548c\u5176\u6700\u7545\u9500\u7684737 Max\u98de\u673a\u7684\u751f\u4ea7\u5df2\u88ab\u8feb\u505c\u6b62\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2516099", "pub_date": "2024-10-16 15:07:18"}]}