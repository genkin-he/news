6ae\u4e66\u8c03\u67e5\u663e\u793a\uff0c\u572810\u6708\u81f311\u6708\u4e2d\u65ec\u62a5\u544a\u671f\u5185\uff0c\u7ecf\u6d4e\u51fa\u73b0\u5c0f\u5e45\u6539\u5584\u7684\u540c\u65f6\uff0c\u7f8e\u56fd\u591a\u6570\u5730\u533a\u548c\u591a\u6570\u884c\u4e1a\u7684\u589e\u957f\u9884\u671f\u4e5f\u6709\u6240\u6539\u5584\u3002\u5728\u52b3\u52a8\u529b\u5e02\u573a\uff0c\u7f8e\u56fd\u5927\u90e8\u5206\u5730\u533a\u7684\u5c31\u4e1a\u6c34\u5e73\u6301\u5e73\u6216\u7565\u9ad8\uff0c\u5f88\u5c11\u6709\u516c\u53f8\u589e\u52a0\u5458\u5de5\u4eba\u6570\uff0c\u4f46\u5458\u5de5\u6d41\u52a8\u7387\u4ecd\u5f88\u4f4e\u3002\u591a\u6570\u5730\u533a\u85aa\u8d44\u589e\u901f\u653e\u7f13\u81f3\u66f4\u6e29\u548c\u6c34\u5e73\u3002\u8be5\u62a5\u544a\u63d0\u51fa\u4e86\u4e00\u4e9b\u66f4\u660e\u786e\u7684\u8b66\u544a\u3002\u8bb8\u591a\u9762\u5411\u6d88\u8d39\u8005\u7684\u4f01\u4e1a\u8868\u793a\uff0c\u6d88\u8d39\u8005\u5bf9\u4ef7\u683c\u53d8\u5f97\u66f4\u654f\u611f\u3002\u4f4f\u623f\u5e02\u573a\u7684\u75b2\u8f6f\u53cd\u6620\u5728\u5bb6\u5c45\u7528\u54c1\u652f\u51fa\u4e0b\u964d\u548c\u62b5\u62bc\u8d37\u6b3e\u9700\u6c42\u75b2\u8f6f\u4e0a\u3002\u53e6\u4e00\u65b9\u9762\uff0c\u7f8e\u8054\u50a8\u8868\u793a\uff0c\u79d1\u6280\u884c\u4e1a\u7684\u6570\u636e\u4e2d\u5fc3\u5efa\u8bbe\u63a8\u52a8\u4e86\u5bf9\u7535\u529b\u7684\u5f3a\u52b2\u9700\u6c42\uff0c\u4e00\u4e9b\u5730\u533a\u7684\u65c5\u6e38\u4e1a\u4e5f\u51fa\u73b0\u5f3a\u52b2\u589e\u957f\u3002\u603b\u4f53\u800c\u8a00\uff0c\u968f\u7740\u592e\u884c\u7ee7\u7eed\u63a7\u5236\u901a\u80c0\uff0c\u5927\u591a\u6570\u5730\u533a\u7269\u4ef7\u6e29\u548c\u4e0a\u6da8\u3002\u4e00\u4e9b\u5730\u533a\u62a5\u544a\u539f\u6750\u6599\u548c\u5176\u4ed6\u975e\u52b3\u52a8\u529b\u6295\u5165\u6210\u672c\u4e0b\u964d\u3002\u9c8d\u5a01\u5c14\uff1a\u4e0d\u8ba4\u4e3a\u201c\u5f71\u5b50\u7f8e\u8054\u50a8\u4e3b\u5e2d\u201d\u9700\u8981\u88ab\u8ba8\u8bba\u3002\u88ab\u7279\u6717\u666e\u63d0\u540d\u4e3a\u8d22\u957f\u7684\u8d1d\u68ee\u7279\u5728\u300a\u5df4\u4f26\u5468\u520a\u300b\u4e0a\u63d0\u8bae\uff0c\u7279\u6717\u666e\u4e00\u4e0a\u4efb\u5c31\u516c\u5f00\u4efb\u547d\u7f8e\u8054\u50a8\u4e3b\u5e2d\u9c8d\u5a01\u5c14\u7684\u7ee7\u4efb\u8005\uff0c\u8fd9\u5b9e\u9645\u4e0a\u662f\u521b\u9020\u4e86\u4e00\u4e2a\u201c\u5f71\u5b50\u7f8e\u8054\u50a8\u4e3b\u5e2d\u201d\uff0c\u9c8d\u5a01\u5c14\u5bf9\u6b64\u8868\u793a\u53cd\u5bf9\u3002\u9c8d\u5a01\u5c14\u5468\u4e09\u8868\u793a\uff1a\u201c\u6211\u8ba4\u4e3a\u8fd9\u6839\u672c\u4e0d\u5728\u8ba8\u8bba\u8303\u56f4\u5185\u3002\u201d\u201c\u7f8e\u8054\u50a8\u548c\u6bcf\u4e00\u5c4a\u653f\u5e9c\u4e4b\u95f4\u90fd\u5b58\u5728\u4e00\u7cfb\u5217\u5236\u5ea6\u5173\u7cfb\u3002\u6211\u5b8c\u5168\u8ba4\u4e3a\u6211\u4eec\u80fd\u4fdd\u6301\u540c\u6837\u7684\u5173\u7cfb\u3002\u201d\u9c8d\u5a01\u5c14\u7684\u4efb\u671f\u5c06\u4e8e2026\u5e74\u521d\u7ed3\u675f\u3002\u7279\u6717\u666e\u9009\u62e9Paul Atkins\u62c5\u4efbSEC\u4e3b\u5e2d \u52a0\u5bc6\u8d27\u5e01\u4e00\u5ea6\u8d70\u9ad8\u3002\u7f8e\u56fd\u5171\u548c\u515a\u5f53\u9009\u603b\u7edf\u5510\u7eb3\u5fb7\u00b7\u7279\u6717\u666e\u5468\u4e09\u8868\u793a\uff0c\u4ed6\u5c06\u63d0\u540dPaul Atkins\u62c5\u4efb\u7f8e\u56fd\u8bc1\u4ea4\u4f1a\uff08SEC\uff09\u4e3b\u5e2d\u3002\u6d88\u606f\u516c\u5e03\u540e\uff0c\u52a0\u5bc6\u8d27\u5e01\u77ed\u7ebf\u8d70\u9ad8\u3002\u73b0\u4efbSEC\u4e3b\u5e2d\u6839\u65af\u52d2\u662f\u5f3a\u786c\u6d3e\uff0c\u5176\u96c4\u5fc3\u52c3\u52c3\u7684\u8bae\u7a0b\u5bfc\u81f4\u4ed6\u4e0e\u534e\u5c14\u8857\u548c\u52a0\u5bc6\u884c\u4e1a\u53d1\u751f\u51b2\u7a81\u3002Atkins\u5219\u76f8\u4fe1\u7a33\u5065\u3001\u521b\u65b0\u7684\u8d44\u672c\u5e02\u573a\u80fd\u591f\u6ee1\u8db3\u6295\u8d44\u8005\u7684\u9700\u6c42\uff0c\u5e76\u63d0\u4f9b\u8d44\u91d1\u63a8\u52a8\u7f8e\u56fd\u7ecf\u6d4e\u7ee7\u7eed\u9886\u5148\u3002\u4ed6\u8fd8\u8ba4\u8bc6\u5230\uff0c\u6570\u5b57\u8d44\u4ea7\u548c\u5176\u4ed6\u521b\u65b0\u5bf9\u4e8e\u8ba9\u7f8e\u56fd\u4fdd\u6301\u9886\u5148\u81f3\u5173\u91cd\u8981\u3002\u9884\u8ba1Atkins\u5c06\u5ba1\u67e5\u6839\u65af\u52d2\u4efb\u4e0b\u7684\u591a\u9879\u89c4\u5219\u4ee5\u53ca\u6cd5\u9662\u6267\u6cd5\u884c\u52a8\uff0c\u5bf9\u52a0\u5bc6\u8d27\u5e01\u91c7\u53d6\u66f4\u6e29\u548c\u7684\u6001\u5ea6\uff0c\u5e76\u5bfb\u6c42\u65e8\u5728\u4fc3\u8fdb\u8d44\u672c\u5f62\u6210\u7684\u89c4\u5219\u53d8\u9769\u3002\u6cd5\u56fd\u56fd\u6c11\u8bae\u4f1a\u6295\u7968\u901a\u8fc7\u9488\u5bf9\u653f\u5e9c\u7684\u4e0d\u4fe1\u4efb\u52a8\u8bae \u603b\u7406\u5c06\u8f9e\u804c\u3002\u5f53\u5730\u65f6\u95f412\u67084\u65e5\uff0c\u6cd5\u56fd\u56fd\u6c11\u8bae\u4f1a\u6295\u7968\u901a\u8fc7\u4e86\u9488\u5bf9\u73b0\u4efb\u653f\u5e9c\u7684\u4e0d\u4fe1\u4efb\u52a8\u8bae\u3002\u6cd5\u56fd\u653f\u5e9c\u9762\u4e34\u518d\u6b21\u6539\u7ec4\u3002\u4f9d\u7167\u6cd5\u56fd\u5baa\u6cd5\uff0c\u603b\u7406\u5df4\u5c3c\u8036\u5c06\u4ee3\u8868\u653f\u5e9c\u5411\u603b\u7edf\u9012\u4ea4\u8f9e\u5448\u3002\u672c\u67082\u65e5\uff0c\u5df4\u5c3c\u8036\u7ed5\u8fc7\u56fd\u6c11\u8bae\u4f1a\uff0c\u5f3a\u884c\u901a\u8fc7\u4e00\u9879\u793e\u4f1a\u4fdd\u969c\u6cd5\u6848\uff0c\u5f15\u53d1\u6781\u53f3\u7ffc\u548c\u5de6\u7ffc\u653f\u515a\u5f3a\u70c8\u4e0d\u6ee1\u3002\u6781\u53f3\u7ffc\u56fd\u6c11\u8054\u76df\u548c\u5de6\u7ffc\u653f\u515a\u8054\u76df\u201c\u65b0\u4eba\u6c11\u9635\u7ebf\u201d\uff0c\u5747\u63d0\u4ea4\u4e86\u9488\u5bf9\u5df4\u5c3c\u8036\u653f\u5e9c\u7684\u4e0d\u4fe1\u4efb\u52a8\u8bae\u3002\u6cd5\u56fd\u56fd\u6c11\u8bae\u4f1a4\u65e5\u4e0b\u5348\u5c31\u9488\u5bf9\u653f\u5e9c\u7684\u4e0d\u4fe1\u4efb\u52a8\u8bae\u8fdb\u884c\u6295\u7968\u8868\u51b3\u524d\u8fa9\u8bba\u3002\u3010\u4e2a\u80a1\u6d88\u606f\u3011\u7f8e\u56fd\u8054\u5408\u5065\u5eb7(UNH.US)\u4fdd\u9669\u516c\u53f8CEO\u5728\u7ebd\u7ea6\u4e2d\u67aa\u8eab\u4ea1\u3002\u5916\u5a92\u63f4\u5f15\u8b66\u65b9\u6d88\u606f\u79f0\uff0c\u5f53\u5730\u65f6\u95f412\u67084\u65e5\u65e9\u6668\uff0c\u7f8e\u56fd\u7ebd\u7ea6\u53d1\u751f\u4e00\u8d77\u67aa\u51fb\u4e8b\u4ef6\u3002\u7f8e\u56fd\u8054\u5408\u5065\u5eb7\u96c6\u56e2\u65d7\u4e0b\u8054\u5408\u5065\u5eb7\u4fdd\u9669\u516c\u53f8\u9996\u5e2d\u6267\u884c\u5b98\uff08CEO\uff09\u5e03\u83b1\u6069\u00b7\u6c64\u666e\u68ee\u5728\u7ebd\u7ea6\u66fc\u54c8\u987f\u4e2d\u57ce\u533a\u5e0c\u5c14\u987f\u9152\u5e97\u5916\u906d\u67aa\u51fb\u8eab\u4ea1\u3002\u6c64\u666e\u68ee\u80f8\u90e8\u4e2d\u67aa\u540e\u88ab\u7d27\u6025\u9001\u5f80\u533b\u9662\uff0c\u7ecf\u62a2\u6551\u65e0\u6548\u6b7b\u4ea1\u3002\u636e\u6089\uff0c\u7f8e\u56fd\u8054\u5408\u5065\u5eb7\u4fdd\u9669\u516c\u53f8\u5f53\u5929\u6b63\u4e3e\u529e\u6295\u8d44\u8005\u65e5\u6d3b\u52a8\u3002\u636e\u7f8e\u56fd\u5a92\u4f53\u62a5\u9053\uff0c\u6c64\u666e\u68ee\u539f\u5b9a\u4e8e\u5f53\u5929\u4e0a\u5348\u53c2\u52a0\u8054\u5408\u5065\u5eb7\u96c6\u56e2\u5728\u8be5\u9152\u5e97\u53ec\u5f00\u7684\u5e74\u5ea6\u6295\u8d44\u4eba\u5927\u4f1a\u3002\u4e00\u540d\u8499\u9762\u67aa\u624b\u4e8b\u5148\u7b49\u5728\u9152\u5e97\u5916\uff0c\u5728\u6c64\u666e\u68ee\u62b5\u8fbe\u540e\u5411\u5176\u8fde\u5f00\u6570\u67aa\uff0c\u968f\u540e\u9003\u79bb\u73b0\u573a\u3002\u7ebd\u7ea6\u5e02\u957f\u4e9a\u5f53\u65af\u8bf4\uff0c\u6839\u636e\u8b66\u65b9\u521d\u6b65\u8c03\u67e5\uff0c\u8fd9\u662f\u4e00\u8d77\u6709\u9488\u5bf9\u6027\u7684\u88ad\u51fb\u3002\u53f0\u8fbe\u7535(TSM.US)\u62df\u6295\u8d444226\u4e07\u6b27\u5143\u5728\u8377\u5170\u5174\u5efaEMEA\u603b\u90e8\u300212\u67084\u65e5\uff0c\u53f0\u8fbe\u7535\u4ee3\u5b50\u516c\u53f8Delta International Holding\uff08\u7b80\u79f0DIH\uff09\u516c\u544a\uff0c\u4e0ePark 2020 Campus\u7b7e\u8ba2\u5de5\u7a0b\u5408\u7ea6\uff0c\u6295\u8d44\u5174\u5efaEMEA\u603b\u90e8\u529e\u516c\u5927\u697c\uff0c\u6682\u4f30\u5de5\u7a0b\u603b\u4ef7\u6b3e\u7ea63577\u4e07\u6b27\u5143\u3002\u53f0\u8fbe\u7535\u6307\u51fa\uff0cDIH\u8463\u4e8b\u4f1a\u4eca\u5929\u4e5f\u51b3\u8bae\u901a\u8fc7\u4ee5649\u4e07\u6b27\u5143\uff0c\u53d6\u5f97\u5ea7\u843d\u4e8e\u8377\u5170\u970d\u592b\u591a\u666e\uff08Hoofddorp\uff09\u7684\u571f\u5730\uff0c\u4ee5\u4f9b\u5174\u5efaEMEA\u603b\u90e8\u529e\u516c\u5ba4\u4f7f\u7528\u3002\u5305\u542b\u571f\u5730\u53d6\u5f97\u4e0e\u5de5\u7a0b\u6b3e\uff0c\u53f0\u8fbe\u7535\u9884\u8ba1\u6295\u8d444226\u4e07\u6b27\u5143\u5174\u5efaEMEA\u603b\u90e8\u529e\u516c\u5927\u697c\u3002\u53f0\u8fbe\u7535\u8868\u793a\uff0c\u6b64\u4e3a\u56e0\u5e94\u672a\u6765\u4e1a\u52a1\u53d1\u5c55\u6240\u9700\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2590096", "pub_date": "2024-12-05 06:36:41"}, {"id": 2589779, "title": "\u6295\u8d44\u8005\u62bc\u6ce8\u7f8e\u8054\u50a8\u8fdb\u4e00\u6b65\u653e\u677e\u8d27\u5e01\u653f\u7b56\u4e4b\u9645\uff0c\u9c8d\u5a01\u5c14\u5c06\u8ba8\u8bba\u8d27\u5e01\u653f\u7b56", "description": "\n\u5728\u8d8a\u6765\u8d8a\u591a\u7684\u4eba\u62bc\u6ce8\u8fdb\u4e00\u6b65\u653e\u677e\u8d27\u5e01\u653f\u7b56\u4e4b\u9645\uff0c\u7f8e\u8054\u50a8\u4e3b\u5e2d\u9c8d\u5a01\u5c14\u5c06\u8ba8\u8bba\u8d27\u5e01\u653f\u7b56\u3002\u5e02\u573a\u5c06\u5bc6\u5207\u5173\u6ce8\u7f8e\u8054\u50a8\u4e3b\u5e2d\u9c8d\u5a01\u5c14\u7684\u8bb2\u8bdd\uff0c\u4ece\u4e2d\u83b7\u53d6\u6709\u5173\u5229\u7387\u524d\u666f\u7684\u7ebf\u7d22\u3002\u7f8e\u8054\u50a8\u4e3b\u5e2d\u9c8d\u5a01\u5c14\u5c06\u4e8e\u5f53\u5730\u65f6\u95f4\u5468\u4e09\uff08\u5317\u4eac\u65f6\u95f4\u5468\u56db02:45\uff09\u5728\u7ebd\u7ea6\u4e3e\u884c\u7684\u300a\u7ebd\u7ea6\u65f6\u62a5\u300b\u4ea4\u6613\u8bb0\u5f55\u5cf0\u4f1a\uff08DealBook Summit\uff09\u4e0a\uff0c\u53c2\u52a0\u6709\u5173\u7ecf\u6d4e\u524d\u666f\u7684\u8ba8\u8bba\u3002\u6295\u8d44\u8005\u5c06\u5bc6\u5207\u5173\u6ce8\u4ed6\u7684\u8bb2\u8bdd\uff0c\u6e34\u671b\u770b\u5230\u6709\u5173\u672a\u6765\u8d27\u5e01\u653f\u7b56\u7684\u4efb\u4f55\u4fe1\u53f7\u3002\u5e02\u573a\u666e\u904d\u9884\u671f\u7f8e\u8054\u50a8\u5c06\u572812\u670817-18\u65e5\u7684\u4f1a\u8bae\u4e0a\u518d\u964d\u606f25\u4e2a\u57fa\u70b9\u3002\u7136\u800c\uff0c\u5728\u9c8d\u5a01\u5c14\u4e8e11\u670814\u65e5\u5728\u8fbe\u62c9\u65af\u7684\u4e00\u6b21\u6d3b\u52a8\u4e0a\u53d1\u8868\u8bb2\u8bdd\u540e\uff0c\u8fd9\u79cd\u9884\u671f\u5931\u53bb\u4e86\u4e00\u4e9b\u52a8\u529b\u3002\u9c8d\u5a01\u5c14\u5728\u8fbe\u62c9\u65af\u7684\u8bb2\u8bdd\u4e2d\u8868\u793a\uff0c\u7f8e\u8054\u50a8\u5728\u8fdb\u4e00\u6b65\u964d\u606f\u4e4b\u524d\u53ef\u80fd\u4f1a\u6162\u6162\u6765\u3002\u4ed6\u6307\u51fa\uff0c\u7a33\u5b9a\u7684\u7ecf\u6d4e\u589e\u957f\uff0c\u5f3a\u52b2\u7684\u52b3\u52a8\u529b\u5e02\u573a\uff0c\u4ee5\u53ca\u901a\u80c0\u7387\u4ecd\u9ad8\u4e8e\u7f8e\u8054\u50a82%\u7684\u76ee\u6807\uff0c\u90fd\u662f\u91c7\u53d6\u8c28\u614e\u63aa\u65bd\u7684\u7406\u7531\u3002\u4ed6\u7684\u8bc4\u8bba\u4e0e\u8054\u90a6\u516c\u5f00\u5e02\u573a\u59d4\u5458\u4f1a\uff08FOMC\uff09\u7406\u4e8b\u7c73\u6b47\u5c14\u00b7\u9c8d\u66fc\uff08Michelle Bowman\uff09\u7684\u89c2\u70b9\u4e00\u81f4\uff0c\u540e\u8005\u4e00\u76f4\u4e3b\u5f20\u5728\u5229\u7387\u8c03\u6574\u65b9\u9762\u91c7\u53d6\u8c28\u614e\u7684\u7acb\u573a\u3002\u6839\u636e\u829d\u52a0\u54e5\u5546\u54c1\u4ea4\u6613\u6240\u96c6\u56e2\uff08CME Group\uff09\u7684\u7f8e\u8054\u50a8\u89c2\u5bdf\u5de5\u5177\uff08FedWatch Tool\uff09\uff0c\u5230\u76ee\u524d\u4e3a\u6b62\uff0c\u672c\u6708\u964d\u606f25\u4e2a\u57fa\u70b9\u7684\u53ef\u80fd\u6027\u7ea6\u4e3a75%\u3002\u7136\u800c\uff0c\u6295\u8d44\u8005\u9884\u8ba1\u672a\u676512\u4e2a\u6708\u7684\u5bbd\u677e\u5e45\u5ea6\u4e0d\u4f1a\u8d85\u8fc775\u4e2a\u57fa\u70b9\u3002\u7f8e\u8054\u50a8\u548c\u7279\u6717\u666e\uff1a\u672a\u6765\u7684\u51b2\u7a81\u8def\u7ebf\uff1f\u7279\u6717\u666e\u91cd\u8fd4\u767d\u5bab\u5f15\u53d1\u4e86\u4eba\u4eec\u5bf9\u901a\u80c0\u538b\u529b\u91cd\u65b0\u62ac\u5934\u7684\u62c5\u5fe7\u3002\u4ed6\u63d0\u51fa\u7684\u653f\u7b56\u53ef\u80fd\u4f1a\u663e\u8457\u6539\u53d8\u7ecf\u6d4e\u683c\u5c40\uff0c\u5305\u62ec\u66f4\u5bbd\u677e\u7684\u8d22\u653f\u63aa\u65bd\uff0c\u5bf9\u6765\u81ea\u6b27\u6d32\u3001\u58a8\u897f\u54e5\u3001\u52a0\u62ff\u5927\u548c\u91d1\u7816\u56fd\u5bb6\u7684\u51fa\u53e3\u91cd\u65b0\u5f81\u6536\u5173\u7a0e\uff0c\u4ee5\u53ca\u66f4\u4e25\u683c\u7684\u79fb\u6c11\u653f\u7b56\u3002\u5c3d\u7ba1\u9c8d\u5a01\u5c14\u4e00\u518d\u62d2\u7edd\u731c\u6d4b\u7279\u6717\u666e\u65b0\u653f\u5e9c\u53ef\u80fd\u51fa\u53f0\u7684\u653f\u7b56\u5bf9\u7ecf\u6d4e\u7684\u5f71\u54cd\uff0c\u4f46\u901a\u80c0\u538b\u529b\u7684\u4efb\u4f55\u56de\u5347\u90fd\u53ef\u80fd\u5bfc\u81f4\u7f8e\u8054\u50a8\u6682\u505c\u751a\u81f3\u505c\u6b62\u5f53\u524d\u7684\u5bbd\u677e\u5468\u671f\u3002\u5728\u8fd9\u4e9b\u53d1\u5c55\u4e2d\uff0c\u7f8e\u5143\u6307\u6570\u5728\u8fdb\u5165\u76d8\u6574/\u4fee\u6b63\u671f\u4e4b\u524d\uff0c\u572810\u6708\u548c11\u6708\u98d9\u5347\u3002\u7136\u800c\uff0c\u8fd9\u79cd\u6682\u505c\u5e94\u8be5\u662f\u6682\u65f6\u7684\uff0c2025\u5e74\u7684\u4e50\u89c2\u524d\u666f\u4e0d\u4f1a\u6539\u53d8\u3002\n", "link": "https://cn.investing.com/news/forex-news/article-2589779", "pub_date": "2024-12-05 02:20:16"}, {"id": 2589725, "title": "\u4f9b\u5e94\u5f3a\u52b2\u548c\u6e29\u548c\u5929\u6c14\u63a8\u52a8\u671f\u8d27\u8fdb\u5165\u770b\u8dcc\u533a\u57df", "description": "\n\u5468\u4e09\uff0812\u67084\u65e5\uff09\u6b27\u76d8\u65f6\u6bb5\uff0c\u7f8e\u56fd\u5929\u7136\u6c14\u671f\u8d27\u8fde\u7eed\u7b2c\u4e09\u4e2a\u4ea4\u6613\u65e5\u4e0b\u8dcc\uff0c\u8dcc\u7834\u5173\u952e\u6280\u672f\u6c34\u5e73\u3002\u5e02\u573a\u76ee\u524d\u9762\u4e34\u7740\u6765\u81ea\u5f3a\u52b2\u4f9b\u5e94\u6c34\u5e73\u548c\u6e29\u548c\u5929\u6c14\u9700\u6c42\u7684\u538b\u529b\uff0c\u8fd9\u52a0\u5f3a\u4e86\u4ea4\u6613\u5458\u7684\u770b\u8dcc\u524d\u666f\u3002\u5173\u952e\u6280\u672f\u6c34\u5e73\u4fe1\u53f7\u75b2\u8f6f\u5e02\u573a\u5468\u4e8c\u8dcc\u783450\u65e5\u79fb\u52a8\u5747\u7ebf3.133\u7f8e\u5143\uff0c\u5c06\u8be5\u6c34\u51c6\u786e\u7acb\u4e3a\u65b0\u7684\u963b\u529b\u4f4d\u3002\u77ed\u671f\u533a\u95f4\u4e3a2.588 - 3.647\u7f8e\u5143\uff0c\u4ef7\u683c\u76ee\u524d\u6b63\u5728\u6d4b\u8bd53.118 - 2.993\u7f8e\u5143\u7684\u8f83\u4f4e\u56de\u64a4\u533a\u57df\u3002\u6301\u7eed\u8dcc\u78342.993\u7f8e\u5143\u53ef\u80fd\u5f15\u53d1\u52a0\u901f\u54112.762\u7f8e\u5143\u548c2.588\u7f8e\u5143\u7684\u652f\u6491\u4f4d\u629b\u76d8\u3002\u76f8\u53cd\uff0c\u5982\u679c\u5347\u78343.118\u7f8e\u5143\u548c50\u65e5\u79fb\u52a8\u5747\u7ebf\uff0c\u5219\u53ef\u80fd\u6062\u590d\u770b\u6da8\u52bf\u5934\u3002\u5c3d\u7ba1\u6ce8\u8d44\u4e0d\u8db3\uff0c\u4f46\u4f9b\u5e94\u4f9d\u7136\u5f3a\u52b2\uff08\u5929\u7136\u6c1401\u65e5\u56fe \u6765\u6e90\uff1a\u6613\u6c47\u901a\uff09\u7f8e\u56fd2024-25\u5e74\u51ac\u5b63\u5929\u7136\u6c14\u5e93\u5b58\u4e3a3922\u4ebf\u7acb\u65b9\u82f1\u5c3a\uff0c\u4e3a2016\u5e74\u4ee5\u6765\u7684\u6700\u9ad8\u6c34\u5e73\uff0c\u6bd4\u4e94\u5e74\u5e73\u5747\u6c34\u5e73\u9ad8\u51fa6%\u3002\u5c3d\u7ba1\u5728\u6ce8\u5165\u5b63\u8282\u7684\u51c0\u6ce8\u5165\u91cf\u6bd4\u5e73\u5747\u6c34\u5e73\u4f4e21%\uff0c\u4f46\u521d\u59cb\u5e93\u5b58\u5df2\u7ecf\u5f88\u5145\u8db3\uff0c\u51cf\u5c11\u4e86\u5927\u4e3e\u6ce8\u5165\u7684\u9700\u6c42\u3002\u4e2d\u5357\u90e8\u5730\u533a\u51fa\u73b0\u4e86\u72ec\u7279\u7684\u5b63\u8282\u6027\u6a21\u5f0f\uff0c\u590f\u5b63\u4e3a\u6ee1\u8db3\u5236\u51b7\u9700\u6c42\u800c\u64a4\u8d44\u3002\u5929\u6c14\u6a21\u5f0f\u589e\u52a0\u538b\u529b\u76ee\u524d\u7684\u5929\u6c14\u6a21\u578b\u663e\u793a\uff0c\u4e2d\u897f\u90e8\u548c\u4e1c\u90e8\u5730\u533a\u5c06\u51fa\u73b0\u971c\u51bb\u5929\u6c14\uff0c\u8fd9\u5c06\u652f\u6301\u5468\u4e94\u4e4b\u524d\u7684\u9ad8\u9700\u6c42\u3002\u7136\u800c\uff0c\u9884\u8ba1\u672a\u6765\u4e00\u5468\u5c06\u51fa\u73b0\u7684\u53d8\u6696\u8d8b\u52bf\u524a\u5f31\u4e86\u4eba\u4eec\u5bf9\u9700\u6c42\u6301\u7eed\u589e\u957f\u7684\u70ed\u60c5\u3002\u7f8e\u56fd\u897f\u90e8\u3001\u4e2d\u90e8\u548c\u5357\u90e8\u7684\u6e29\u548c\u5929\u6c14\uff0c\u52a0\u4e0a8-15\u5929\u7684\u5929\u6c14\u9700\u6c42\u653e\u7f13\uff0c\u589e\u52a0\u4e86\u4ef7\u683c\u4e0b\u8dcc\u7684\u538b\u529b\u3002\u5e02\u573a\u9884\u6d4b\u8003\u8651\u5230\u5f3a\u52b2\u7684\u4f9b\u5e94\u3001\u6e29\u548c\u7684\u9700\u6c42\u4ee5\u53ca\u5173\u952e\u7684\u6280\u672f\u6545\u969c\uff0c\u5929\u7136\u6c14\u671f\u8d27\u7684\u524d\u666f\u4ecd\u7136\u770b\u8dcc\u3002\u4ea4\u6613\u5458\u5e94\u5173\u6ce82.993\u7f8e\u5143\u548c2.762\u7f8e\u5143\u7684\u652f\u6491\u4f4d\uff0c\u5982\u679c\u7a81\u7834\u8fd9\u4e9b\u6c34\u5e73\uff0c\u53ef\u80fd\u4f1a\u8fdb\u4e00\u6b65\u4e0b\u884c\u3002\u77ed\u671f\u590d\u82cf\u9700\u8981\u7a81\u78343.134\u7f8e\u5143\u624d\u80fd\u91cd\u65b0\u83b7\u5f97\u4e0a\u884c\u52a8\u529b\u3002\u5317\u4eac\u65f6\u95f400:40\uff0c\u7f8e\u56fd\u5929\u7136\u6c14\u62a52.999\u7f8e\u5143/\u767e\u4e07\u82f1\u70ed\uff0c\u8dcc\u5e451.41%\u3002\n", "link": "https://cn.investing.com/news/forex-news/article-2589725", "pub_date": "2024-12-05 01:00:16"}, {"id": 2589664, "title": "\u8054\u5408\u5065\u5eb7(UNH.US)\u4fdd\u9669CEO\u906d\u67aa\u51fb\u8eab\u4ea1 \u6295\u8d44\u8005\u4f1a\u8bae\u4e2d\u6b62", "description": " \u667a\u901a\u8d22\u7ecfAPP\u83b7\u6089\uff0c\u636e\u62a5\u9053\uff0c\u7f8e\u56fd\u8054\u5408\u5065\u5eb7\u96c6\u56e2(UNH.US)\u4fdd\u9669\u90e8\u95e8\u9996\u5e2d\u6267\u884c\u5b98Brian Thompson\u4e8e\u7f8e\u4e1c\u65f6\u95f4\u5468\u4e09\u65e9\u6668\u5728\u66fc\u54c8\u987f\u4e2d\u57ce\u5e0c\u5c14\u987f\u9152\u5e97\u5916\u906d\u67aa\u51fb\u8eab\u4ea1\u3002\u6d88\u606f\u4eba\u58eb\u900f\u9732\uff0c\u4e8b\u4ef6\u53d1\u751f\u540e\uff0c\u8054\u5408\u5065\u5eb7\u96c6\u56e2\u968f\u5373\u53d6\u6d88\u4e86\u539f\u5b9a\u4e8e\u5468\u4e09\u4e3e\u884c\u7684\u6295\u8d44\u8005\u65e5\u6d3b\u52a8\u3002\u4f5c\u4e3a\u7f8e\u56fd\u6700\u5927\u7684\u79c1\u4eba\u5065\u5eb7\u4fdd\u9669\u516c\u53f8\uff0c\u8054\u5408\u5065\u5eb7\u96c6\u56e2\u5e02\u503c\u7ea65630\u4ebf\u7f8e\u5143\uff0c\u53bb\u5e74\u8425\u6536\u8d85\u8fc72810\u4ebf\u7f8e\u5143\u3002Thompson\u81ea2004\u5e74\u52a0\u5165\u516c\u53f8\u4ee5\u6765\u5df2\u5de5\u4f5c20\u4f59\u5e74\uff0c\u5e76\u4e8e2021\u5e744\u6708\u51fa\u4efb\u4fdd\u9669\u90e8\u95e8\u9996\u5e2d\u6267\u884c\u5b98\u3002\u5728\u4ed6\u7684\u9886\u5bfc\u4e0b\uff0c\u8054\u5408\u5065\u5eb7\u96c6\u56e2\u6210\u4e3a\u7f8e\u56fd\u533b\u7597\u884c\u4e1a\u7684\u5de8\u5934\u3002\u4e8b\u4ef6\u53d1\u751f\u540e\uff0c\u5c3d\u7ba1\u6d88\u606f\u4f20\u51fa\uff0c\u8054\u5408\u5065\u5eb7\u96c6\u56e2\u7684\u80a1\u4ef7\u5468\u4e09\u4f9d\u7136\u4e0a\u6da8\u8fd11%\u3002\u636e\u77e5\u60c5\u4eba\u58eb\u900f\u9732\uff0c\u67aa\u624b\u4e3a\u4e00\u540d\u767d\u4eba\u7537\u6027\uff0c\u8eab\u7a7f\u9ed1\u8272\u8fde\u5e3d\u886b\u3001\u9ed1\u8272\u88e4\u5b50\u3001\u9ed1\u8272\u8fd0\u52a8\u978b\uff0c\u978b\u8fb9\u5e26\u6709\u767d\u8272\u9970\u8fb9\uff0c\u5e76\u643a\u5e26\u4e00\u4e2a\u7070\u8272\u80cc\u5305\u3002\u636e\u6089\uff0c\u67aa\u624b\u4f7f\u7528\u4e86\u4e00\u628a\u88c5\u6709\u6d88\u97f3\u5668\u7684\u624b\u67aa\u3002\u7ebd\u7ea6\u8b66\u5bdf\u5c40\u53d1\u8a00\u4eba\u8bc1\u5b9e\uff0c\u5468\u4e09\u65e9\u4e0a6\u70b946\u5206\uff0c\u4e00\u540d50\u5c81\u7537\u6027\u5728\u66fc\u54c8\u987f\u4e2d\u57ce\u7f8e\u6d32\u5927\u90531335\u53f7\u5e0c\u5c14\u987f\u9152\u5e97\u95e8\u524d\u4e2d\u67aa\u3002\u8b66\u65b9\u8d76\u5230\u73b0\u573a\u65f6\uff0c\u53d7\u5bb3\u8005\u5df2\u5931\u53bb\u610f\u8bc6\uff0c\u80f8\u90e8\u4e2d\u5f39\uff0c\u88ab\u7d27\u6025\u9001\u5f80\u897f\u5948\u5c71\u897f\u90e8\u533b\u9662\u62a2\u6551\uff0c\u4f46\u6700\u7ec8\u4e0d\u6cbb\u8eab\u4ea1\u3002\u76ee\u524d\u5c1a\u65e0\u5acc\u7591\u4eba\u88ab\u6355\uff0c\u8c03\u67e5\u4ecd\u5728\u8fdb\u884c\u4e2d\u3002\u5f53\u65f6\u5728\u5e0c\u5c14\u987f\u9152\u5e97\u9644\u8fd1\u7684\u4e00\u540d\u70ed\u72d7\u644a\u8d29\u8868\u793a\uff0c\u867d\u7136\u6ca1\u6709\u542c\u5230\u67aa\u58f0\uff0c\u4f46\u6ce8\u610f\u5230\u7a81\u7136\u51fa\u73b0\u4e86\u5927\u91cf\u8b66\u5bdf\u3002\u53e6\u4e00\u540d\u65e9\u4e0a7\u70b9\u5f00\u59cb\u503c\u73ed\u7684\u5e0c\u5c14\u987f\u9152\u5e97\u95e8\u536b\u8868\u793a\uff0c\u9152\u5e97\u4e00\u5207\u770b\u4f3c\u201c\u76f8\u5f53\u6b63\u5e38\u201d\u3002\u4e24\u4eba\u5747\u8981\u6c42\u533f\u540d\u3002\u8054\u5408\u5065\u5eb7\u96c6\u56e2\u7684\u6295\u8d44\u8005\u65e5\u6d3b\u52a8\u539f\u5b9a\u4e8e\u5e0c\u5c14\u987f\u9152\u5e97\u4e3e\u884c\uff0c\u4f46\u56e0\u4e8b\u4ef6\u53d1\u751f\u800c\u4e2d\u6b62\u3002\u96c6\u56e2\u9996\u5e2d\u6267\u884c\u5b98Andrew Witty\u5728\u6d3b\u52a8\u4e2d\u8868\u793a\uff1a\u201c\u5f88\u9057\u61be\uff0c\u6211\u4eec\u7684\u4e00\u4f4d\u56e2\u961f\u6210\u5458\u6b63\u5728\u7ecf\u5386\u4e00\u573a\u975e\u5e38\u4e25\u91cd\u7684\u533b\u7597\u7d27\u6025\u60c5\u51b5\uff0c\u56e0\u6b64\u4e0d\u5f97\u4e0d\u4e2d\u6b62\u4eca\u5929\u7684\u6d3b\u52a8\uff0c\u5e0c\u671b\u5927\u5bb6\u80fd\u591f\u7406\u89e3\u3002\u201d\u76ee\u524d\uff0c\u8054\u5408\u5065\u5eb7\u96c6\u56e2\u5c1a\u672a\u5bf9\u6b64\u4e8b\u4ef6\u53d1\u8868\u8bc4\u8bba\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2589664", "pub_date": "2024-12-05 00:06:41"}, {"id": 2589665, "title": "\u7f8e\u80a1\u5f02\u52a8 | \u8fde\u7eed\u4e09\u4e2a\u5b63\u5ea6\u5b9e\u73b0\u76c8\u5229 \u71c3\u77f3\u533b\u5b66(BNR.US)\u6da8\u8fd114%", "description": " \u667a\u901a\u8d22\u7ecfAPP\u83b7\u6089\uff0c\u5468\u4e09\uff0c\u71c3\u77f3\u533b\u5b66(BNR.US)\u6da8\u8fd114%\uff0c\u62a56.95\u7f8e\u5143\u30022024\u5e74\u7b2c\u4e09\u5b63\u5ea6\uff0c\u71c3\u77f3\u533b\u5b66\u5b9e\u73b0\u8425\u65361.287\u4ebf\u4eba\u6c11\u5e01\uff0c\u540c\u6bd4\u589e\u957f1%\u3002\u5728Non-GAAP\u6bdb\u5229\u6263\u9664Non-GAAP\u9500\u552e\u53ca\u4e00\u822c\u884c\u653f\u548c\u7ba1\u7406\u8d39\u7528\u540e\uff0c\u4e09\u5b63\u5ea6\u5b9e\u73b0\u76c8\u52292520\u4e07\u5143\u4eba\u6c11\u5e01\u3002\u8fc4\u4eca\u4e3a\u6b62\uff0c\u71c3\u77f3\u533b\u5b66\u5df2\u8fde\u7eed\u4e09\u4e2a\u5b63\u5ea6\u5b9e\u73b0\u76c8\u5229\uff0c\u5e76\u5448\u73b0\u8fde\u7eed\u4e0a\u5347\u8d8b\u52bf\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2589665", "pub_date": "2024-12-05 00:06:43"}, {"id": 2589624, "title": "\u7f8e\u80a1\u5f02\u52a8 | \u516c\u53f8\u5ba3\u5e03\u56de\u8d2d5000\u4e07\u7f8e\u5143\u80a1\u7968 \u60a6\u4eab\u63a7\u80a1(CHR.US)\u6da8\u8d8513%", "description": " \u667a\u901a\u8d22\u7ecfAPP\u83b7\u6089\uff0c\u5468\u4e09\uff0c\u60a6\u4eab\u63a7\u80a1(CHR.US)\u6da8\u8d8513%\uff0c\u62a53.24\u7f8e\u5143\u3002\u6d88\u606f\u9762\u4e0a\uff0c\u8fd1\u65e5\uff0c\u60a6\u4eab\u63a7\u80a1\u5ba3\u5e03\uff0c\u8463\u4e8b\u4f1a\u6279\u51c6\u80a1\u7968\u56de\u8d2d\u8ba1\u5212\uff0c\u6388\u6743\u516c\u53f8\u572836\u4e2a\u6708\u5185\u56de\u8d2d5000\u4e07\u7f8e\u5143A\u7c7b\u666e\u901a\u80a1\uff0c\u516c\u53f8\u62e5\u6709\u5145\u8db3\u7684\u73b0\u91d1\u4e3a\u