a6\u66f4\u52a0\u9e70\u6d3e\u3002\u5c3d\u7ba1\u5982\u6b64\uff0c\u9053\u660e\u8bc1\u5238\u5927\u5b97\u5546\u54c1\u7b56\u7565\u5168\u7403\u4e3b\u7ba1Bart Melek\u8868\u793a\uff0c\u592e\u884c\u5bf9\u4e8e\u660e\u5e74\u5c06\u51cf\u5c11\u964d\u606f\u6b21\u6570\u7684\u4fe1\u53f7\u5bf9\u98ce\u9669\u8d44\u4ea7\uff0c\u77f3\u6cb9\u662f\u5176\u4e2d\u4e4b\u4e00\uff0c\u5e76\u4e0d\u662f\u4e2a\u975e\u5e38\u79ef\u6781\u7684\u52a8\u6001\u3002\u539f\u6cb9\u4ef7\u683c\u81ea10\u6708\u4e2d\u65ec\u4ee5\u6765\u4e00\u76f4\u5904\u4e8e\u533a\u95f4\u9707\u8361\u72b6\u6001\uff0c\u5168\u5e74\u4ea4\u6613\u533a\u95f4\u8fc8\u54112019\u5e74\u4ee5\u6765\u6700\u7a84\u3002\u3010\u91d1\u5c5e\u3011LME\u671f\u94dc\u6536\u6da858\u7f8e\u5143\uff0c\u62a58941\u7f8e\u5143/\u5428\u3002LME\u671f\u94dd\u6536\u6da828\u7f8e\u5143\uff0c\u62a52534\u7f8e\u5143/\u5428\u3002LME\u671f\u950c\u6536\u6da84\u7f8e\u5143\uff0c\u62a52972\u7f8e\u5143/\u5428\u3002LME\u671f\u94c5\u6536\u6da88\u7f8e\u5143\uff0c\u62a51980\u7f8e\u5143/\u5428\u3002LME\u671f\u954d\u6536\u6da8243\u7f8e\u5143\uff0c\u62a515356\u7f8e\u5143/\u5428\u3002LME\u671f\u9521\u6536\u6da8290\u7f8e\u5143\uff0c\u62a528689\u7f8e\u5143/\u5428\u3002LME\u671f\u94b4\u6536\u5e73\uff0c\u62a524300\u7f8e\u5143/\u5428\u3002\u3010\u5b8f\u89c2\u6d88\u606f\u3011\u7f8e\u56fd\u6d88\u8d39\u8005\u4fe1\u5fc3\u8fde\u7eed\u7b2c\u4e94\u4e2a\u6708\u4e0a\u5347 \u77ed\u671f\u901a\u80c0\u9884\u671f\u5c0f\u5e45\u8d70\u9ad8\u3002\u7f8e\u56fd12\u6708\u6d88\u8d39\u8005\u4fe1\u5fc3\u6307\u6570\u8fde\u7eed\u7b2c\u4e94\u4e2a\u6708\u4e0a\u5347\uff0c\u77ed\u671f\u901a\u80c0\u9884\u671f\u4e5f\u5c0f\u5e45\u8d70\u9ad8\u3002\u5bc6\u6b47\u6839\u5927\u5b6612\u6708\u6d88\u8d39\u8005\u4fe1\u5fc3\u6307\u6570\u7ec8\u503c\u4ece\u4e0a\u6708\u768471.8\u5347\u81f374\u3002\u5f6d\u535a\u8c03\u67e5\u7684\u7ecf\u6d4e\u5b66\u5bb6\u7684\u9884\u4f30\u4e2d\u503c\u4e3a74.2\u3002\u5468\u4e94\u516c\u5e03\u7684\u6570\u636e\u663e\u793a\uff0c\u6d88\u8d39\u8005\u5bf9\u672a\u6765\u4e00\u5e74\u7684\u901a\u80c0\u9884\u671f\u4e3a2.8%\u3002\u4ed6\u4eec\u9884\u8ba1\u672a\u6765\u4e94\u5230\u5341\u5e74\u901a\u80c0\u7387\u5c06\u4e0a\u53473%\u3002\u82b1\u65d7\uff1a\u901a\u80c0\u653e\u7f13\uff0c\u7f8e\u8054\u50a8\u964d\u606f\u5e45\u5ea6\u6216\u8d85\u8fc7\u76ee\u524d\u9884\u671f\u3002\u7f8e\u8054\u50a8\u5c062025\u5e74\u5e74\u5e95\u8054\u90a6\u57fa\u91d1\u5229\u7387\u76ee\u6807\u4e0a\u8c03\u4e860.5\u4e2a\u767e\u5206\u70b9\u3002\u82b1\u65d7\u7ecf\u6d4e\u5b66\u5bb6\u5b89\u5fb7\u9c81\u2022\u970d\u4f26\u970d\u65af\u7279\u8ba4\u4e3a\uff0c\u7f8e\u8054\u50a8\u53ef\u80fd\u4f1a\u9677\u5165\u624b\u8db3\u65e0\u63aa\u7684\u5883\u5730\u3002\u7531\u4e8e11\u6708\u4efd\u6838\u5fc3PCE\u73af\u6bd4\u4e0a\u6da80.1%\uff0c\u7269\u4ef7\u4e0a\u6da8\u6b63\u5728\u653e\u7f13\uff0c\u7f8e\u8054\u50a8\u6700\u7ec8\u7684\u964d\u606f\u5e45\u5ea6\u53ef\u80fd\u4f1a\u8d85\u8fc7\u76ee\u524d\u7684\u9884\u671f\u3002\u201c\u5728\u6211\u4eec\u7684\u57fa\u672c\u5047\u8bbe\u4e2d\uff0c\u52b3\u52a8\u529b\u5e02\u573a\u8d70\u8f6f\u4f1a\u5bfc\u81f4\u7f8e\u8054\u50a8\u5728\u63a5\u4e0b\u6765\u7684\u6bcf\u6b21\u4f1a\u8bae\u4e0a\u964d\u606f\u3002\u201d\u8fd9\u4e00\u89c2\u70b9\u4e0e\u5e02\u573a\u5bf9\u7f8e\u8054\u50a8\u5c06\u57281\u6708\u4efd\u6682\u505c\u964d\u606f\u7684\u9884\u671f\u76f8\u5de6\u3002\u201c\u4f46\u5373\u4f7f\u6211\u4eec\u9519\u4e86\uff0c\u5931\u4e1a\u7387\u6a2a\u76d8\u3001\u901a\u80c0\u653e\u7f13\u4e5f\u8db3\u4ee5\u6210\u4e3a\u81f3\u5c11\u57281\u6708\u4efd\u4ee5\u5916\u7684\u6bcf\u6b21\u4f1a\u8bae\u4e0a\u90fd\u964d\u606f\u7684\u7406\u7531\u3002\u201d\u7f8e\u8054\u50a8\u9694\u591c\u9006\u56de\u8d2d\u8dcc\u78341,000\u4ebf\u7f8e\u5143 \u653f\u7b56\u8c03\u6574\u52a9\u63a8\u4e86\u8d44\u91d1\u6d41\u51fa\u3002\u5728\u7f8e\u8054\u50a8\u51b3\u7b56\u8005\u672c\u5468\u8c03\u6574\u653f\u7b56\u4e4b\u540e\uff0c\u6295\u8d44\u8005\u5b58\u653e\u5728\u7f8e\u8054\u50a8\u4e00\u9879\u4e3b\u8981\u5de5\u5177\u7684\u8d44\u91d1\u89c4\u6a21\u81ea2021\u5e74\u4ee5\u6765\u9996\u6b21\u8dcc\u78341,000\u4ebf\u7f8e\u5143\u3002\u5468\u4e94\u7ea6\u670940\u4f4d\u5bf9\u624b\u65b9\u603b\u8ba1\u5c06984\u4ebf\u7f8e\u5143\u5b58\u5165\u7f8e\u8054\u50a8\u7684\u9694\u591c\u9006\u56de\u8d2d\u534f\u8bae(RRP)\u3002\u94f6\u884c\u3001\u653f\u5e9c\u652f\u6301\u673a\u6784\u548c\u8d27\u5e01\u5e02\u573a\u5171\u540c\u57fa\u91d1\u901a\u8fc7\u4f7f\u7528RRP\u53ef\u4ee5\u8d5a\u53d6\u5229\u606f\u3002\u6839\u636e\u7ebd\u7ea6\u8054\u50a8\u94f6\u884c\u7684\u6570\u636e\uff0c\u4e0e2022\u5e7412\u670830\u65e5\u521b\u7eaa\u5f55\u76842.55\u4e07\u4ebf\u7f8e\u5143\u76f8\u6bd4\uff0cRRP\u4f7f\u7528\u89c4\u6a21\u5df2\u7ecf\u5927\u5e45\u4e0b\u964d\u3002\u7f8e\u8054\u50a8\u5b98\u5458\u5468\u4e09\u5c06RRP\u76f8\u5bf9\u4e8e\u653f\u7b56\u5229\u7387\u76ee\u6807\u533a\u95f4\u4e0b\u9650\u4e0b\u8c03\u4e865\u4e2a\u57fa\u70b9\uff0c\u4ee5\u4fdd\u6301\u7f8e\u56fd\u878d\u8d44\u5e02\u573a\u5e73\u7a33\u8fd0\u884c\u3002\u8054\u90a6\u57fa\u91d1\u5229\u7387\u76ee\u6807\u533a\u95f4\u88ab\u4e0b\u8c03\u81f34.25%-4.50%\uff0c\u65b0\u7684RRP\u5229\u7387\u4e3a4.25%\uff0c\u8fd9\u662fRRP\u5229\u7387\u81ea2021\u5e74\u4ee5\u6765\u9996\u6b21\u4e0e\u653f\u7b56\u5229\u7387\u76ee\u6807\u533a\u95f4\u4e0b\u9650\u4fdd\u6301\u4e00\u81f4\u3002\u52a0\u62ff\u5927\u603b\u7406\u7279\u9c81\u591a\u6539\u7ec4\u5185\u9601\uff0c\u5e94\u5bf9\u56fd\u5185\u5916\u53cc\u91cd\u6311\u6218\u300212\u670820\u65e5\uff0c\u52a0\u62ff\u5927\u603b\u7406\u7279\u9c81\u591a\u6539\u7ec4\u5185\u9601\uff0c\u5c31\u4efb\u4eea\u5f0f\u5728\u603b\u7763\u5e9c\u4e3e\u884c\u3002\u636e\u4e86\u89e3\uff0c\u65b0\u5185\u9601\u7684\u516c\u5171\u5b89\u5168\u90e8\u957f\u7531\u539f\u52a0\u62ff\u5927\u56fd\u5bb6\u5b89\u5168\u4e0e\u60c5\u62a5\u59d4\u5458\u4f1a\u4e3b\u5e2d\u5927\u536b\u00b7\u9ea6\u575a\u8fea\uff08David McGuinty\uff09\u63a5\u4efb\u3002\u53e6\u4e00\u9879\u91cd\u8981\u4efb\u547d\u662f\u963f\u59ae\u5854\u00b7\u963f\u5357\u5fb7\u62c5\u4efb\u65b0\u8bbe\u7acb\u7684\u4ea4\u901a\u4e0e\u56fd\u5185\u8d38\u6613\u90e8\u957f\u3002\u8fd9\u4e00\u4efb\u547d\u8868\u660e\uff0c\u9762\u5bf9\u7279\u6717\u666e\u7684\u5173\u7a0e\u5a01\u80c1\uff0c\u65b0\u5185\u9601\u6709\u610f\u52a0\u5f3a\u56fd\u5185\u8d38\u6613\u7684\u53d1\u5c55\u3002\u6b64\u5916\uff0c\u8fd8\u6709\u591a\u9879\u804c\u52a1\u8c03\u6574\u3002\u3010\u4e2a\u80a1\u6d88\u606f\u3011\u5927\u4f17\u6c7d\u8f66(VWAGY.US)\u548c\u5de5\u4f1a\u540c\u610f\u524a\u51cf\u4ea7\u80fd\uff0c\u540c\u65f6\u4fdd\u6301\u5fb7\u56fd\u5de5\u5382\u7684\u6b63\u5e38\u8fd0\u8425\u3002\u5927\u4f17\u6c7d\u8f66\u96c6\u56e2\u4e0e\u5de5\u4f1a\u9886\u8896\u8fbe\u6210\u534f\u8bae\uff0c\u524a\u51cf\u5176\u540c\u540d\u54c1\u724c\u7684\u4ea7\u80fd\uff0c\u540c\u65f6\u907f\u514d\u5de5\u5382\u5173\u95ed\uff0c\u7ed3\u675f\u4e09\u4e2a\u6708\u7684\u7d27\u5f20\u8c08\u5224\uff0c\u5e76\u9632\u6b62\u8fdb\u4e00\u6b65\u7684\u5de5\u4f1a\u7f62\u5de5\u3002\u5927\u4f17\u6c7d\u8f66\u5de5\u4f1a\u5468\u4e94\u8868\u793a\uff0c\u5927\u4f17\u540c\u610f\u4fdd\u6301\u5176\u5728\u5fb7\u56fd\u768410\u5bb6\u5de5\u5382\u7684\u8fd0\u8425\uff0c\u5e76\u6062\u590d\u5c31\u4e1a\u4fdd\u969c\u534f\u8bae\uff0c\u76f4\u81f32030\u5e74\u3002\u4f5c\u4e3a\u4ea4\u6362\uff0c\u5de5\u4eba\u4eec\u540c\u610f\u653e\u5f03\u4e00\u4e9b\u5956\u91d1\uff0c\u51cf\u5c11\u83b7\u5f97\u6c38\u4e45\u5c31\u4e1a\u7684\u5b9e\u4e60\u751f\u6570\u91cf\uff0c\u5e76\u5c06\u4e94\u4e2a\u5de5\u5382\u7684\u4ea7\u80fd\u524a\u51cf\u6570\u5341\u4e07\u8f86\u3002\u8fd9\u4e9b\u63aa\u65bd\u7ecf\u8fc7\u4e94\u8f6e\u8c08\u5224\u6700\u7ec8\u6572\u5b9a\uff0c\u4e0e\u5927\u4f17\u6700\u521d\u63d0\u51fa\u7684\u5927\u5e45\u524a\u51cf\u8ba1\u5212\u76f8\u53bb\u751a\u8fdc\u3002\u5de5\u4f1a\u9886\u8896\u5f3a\u70c8\u53cd\u5bf9\u88c1\u5458\u6570\u5343\u4eba\u3001\u524a\u51cf\u6708\u85aa\u548c\u5173\u95ed\u4e09\u5bb6\u5fb7\u56fd\u5de5\u5382\u4ee5\u63d0\u9ad8\u5927\u4f17\u54c1\u724c\u7ade\u4e89\u529b\u7684\u8ba1\u5212\u3002\u5bf9\u51b2\u57fa\u91d1SkyBridge Capital\u521b\u59cb\u4eba\u517c\u6267\u884c\u5408\u4f19\u4eba\uff1a\u5bf9MicroStrategy(MSTR.US)\u503a\u52a1\u7684\u62c5\u5fe7\u88ab\u5938\u5927\u4e86\u3002\u5bf9\u51b2\u57fa\u91d1 SkyBridge Capital\u521b\u59cb\u4eba\u517c\u6267\u884c\u5408\u4f19\u4ebaAnthony Scaramucci\u8868\u793a\uff0c\u6240\u6709\u5173\u4e8eMicroStrategy\u5927\u91cf\u8d2d\u4e70\u6bd4\u7279\u5e01\u548c\u627f\u62c5\u503a\u52a1\u7684\u62c5\u5fe7\u90fd\u88ab\u5938\u5927\u4e86\u3002Scaramucci\u5728\u5468\u4e94\u63a5\u53d7\u91c7\u8bbf\u65f6\u8868\u793a\uff1a\u201c\u4eba\u4eec\u8ba4\u4e3a\uff0c\u5982\u679c\u6bd4\u7279\u5e01\u5d29\u6e83\uff0c\u5b83\u5c31\u4f1a\u5d29\u6e83\uff0c\u5176\u7ed3\u679c\u662f\uff0c\u7cfb\u7edf\u4e2d\u7684\u6760\u6746\u7387\u5c06\u4f1a\u4e0b\u964d\uff0c\u5e76\u5bfc\u81f4\u5d29\u6e83\u3002\u201d\u4ed6\u8bf4\uff1a\u201c\u4f46\u5982\u679c\u4f60\u8ba4\u771f\u7814\u7a76\u5b83\u7684\u8d44\u4ea7\u8d1f\u503a\u8868\uff0c\u5c31\u4f1a\u53d1\u73b0\u6709\u957f\u671f\u503a\u52a1\uff0c\u800c\u4e14\u8fd8\u6709\u6eda\u52a8\u7684\u957f\u671f\u503a\u52a1\u3002\u9664\u975e\u6bd4\u7279\u5e01\u7cfb\u7edf\u6027\u5d29\u6e83\uff0c\u800c\u4e14\u8fd9\u79cd\u60c5\u51b5\u8981\u6301\u7eed\u516d\u4e03\u5e74\uff0c\u624d\u4f1a\u51fa\u5c40\u3002\u201d\u7279\u6717\u666e\u5c06\u5176\u5728\u7279\u6717\u666e\u4f20\u5a92(DJT.US)\u7684\u80a1\u4efd\u8f6c\u5165\u53ef\u64a4\u9500\u4fe1\u6258\u57fa\u91d1\u3002\u7f8e\u56fd\u5f53\u9009\u603b\u7edf\u7279\u6717\u666e\u5df2\u5c06\u5176\u6301\u6709\u7684\u7279\u6717\u666e\u5a92\u4f53\u79d1\u6280\u516c\u53f8\u80a1\u4efd\u8f6c\u5165\u4e00\u4e2a\u53ef\u64a4\u9500\u4fe1\u6258\u57fa\u91d1\u3002\u8bc1\u5238\u6587\u4ef6\u663e\u793a\uff0c\u7279\u6717\u666e\u5c06\u5176\u6301\u6709\u76841.1475\u4ebf\u80a1\uff0c\u5373\u7279\u6717\u666e\u5a92\u4f53\u4e0e\u79d1\u6280\u516c\u53f8\u5df2\u53d1\u884c\u80a1\u7968\u768453%\uff0c\u8f6c\u8ba9\u7ed9\u4e86\u53ef\u64a4\u9500\u4fe1\u6258\uff0c\u4ed6\u662f\u8be5\u4fe1\u6258\u7684\u552f\u4e00\u53d7\u76ca\u4eba\u3002\u6309\u7167\u8be5\u516c\u53f8\u80a1\u7968\u6700\u540e\u6536\u76d8\u4ef735.41\u7f8e\u5143\u8ba1\u7b97\uff0c\u4ed6\u6240\u6301\u80a1\u4efd\u7684\u4ef7\u503c\u8d85\u8fc740\u4ebf\u7f8e\u5143\u3002\u7279\u6717\u666e\u66fe\u572811\u6708\u8868\u793a\uff0c\u4ed6\u65e0\u610f\u51fa\u552e\u4ed6\u5728\u8be5\u516c\u53f8\u7684\u80a1\u4efd\uff0c\u8be5\u516c\u53f8\u62e5\u6709Truth\u793e\u4ea4\u5a92\u4f53\u5e73\u53f0\u3002\u8bc1\u5238\u6587\u4ef6\u663e\u793a\uff0c\u7279\u6717\u666e\u7684\u957f\u5b50\u5c0f\u7279\u6717\u666e\u662f\u8be5\u4fe1\u6258\u7684\u552f\u4e00\u53d7\u6258\u4eba\uff0c\u5bf9\u5176\u6301\u6709\u7684\u8bc1\u5238\u62e5\u6709\u552f\u4e00\u7684\u6295\u7968\u6743\u548c\u6295\u8d44\u6743\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2612350", "pub_date": "2024-12-21 08:06:34", "source": "investing_cn", "kind": 1, "language": "zh-CN"}]}