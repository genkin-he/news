fd8\u670955%\u7684\u4f18\u60e0\u4e0d\u5bb9\u9519\u8fc7\uff0c\u6700\u540e\u56db\u5929\uff01", "link": "https://cn.investing.com/news/stock-market-news/article-2611642", "pub_date": "2024-12-20 20:58:59", "source": "investing_cn", "kind": 1, "language": "zh-CN"}, {"id": 2611640, "title": "\u7279\u6717\u666e\u5a01\u80c1\u6b27\u76df\uff1a\u82e5\u4e0d\u589e\u8d2d\u7f8e\u56fd\u77f3\u6cb9\u548c\u5929\u7136\u6c14\u5c06\u9762\u4e34\u5173\u7a0e", "description": "Investing.com - \u7f8e\u56fd\u5f53\u9009\u603b\u7edf\u5510\u7eb3\u5fb7\u00b7\u7279\u6717\u666e\u8b66\u544a\u6b27\u76df\uff08EU\uff09\uff0c\u5982\u679c\u6210\u5458\u56fd\u4e0d\u589e\u52a0\u8d2d\u4e70\u7f8e\u56fd\u77f3\u6cb9\u548c\u5929\u7136\u6c14\uff0c\u5176\u51fa\u53e3\u53ef\u80fd\u9762\u4e34\u7f8e\u56fd\u5173\u7a0e\u3002\u7279\u6717\u666e\u5728Truth Social\u4e0a\u53d1\u8868\u8fd9\u4e00\u58f0\u660e\uff0c\u8868\u793a\u6b27\u76df\u5fc5\u987b\u901a\u8fc7\u8d2d\u4e70\u66f4\u591a\u7f8e\u56fd\u77f3\u6cb9\u548c\u5929\u7136\u6c14\u6765\u62b5\u6d88\u4e0e\u7f8e\u56fd\u7684\u5de8\u5927\u8d38\u6613\u9006\u5dee\uff0c\u5426\u5219\u5c06\u9762\u4e34\u5173\u7a0e\u3002\u76ee\u524d\uff0c\u7f8e\u56fd\u662f\u4e16\u754c\u4e0a\u6700\u5927\u7684\u539f\u6cb9\u751f\u4ea7\u56fd\u548c\u6db2\u5316\u5929\u7136\u6c14\uff08LNG\uff09\u51fa\u53e3\u56fd\u3002\u5305\u62ec\u6b27\u76df\u548c\u8d8a\u5357\u5728\u5185\u7684\u51e0\u4e2aLNG\u4e70\u5bb6\u5df2\u8868\u793a\u6709\u5174\u8da3\u4ece\u7f8e\u56fd\u8d2d\u4e70\u66f4\u591a\u71c3\u6599\uff0c\u90e8\u5206\u539f\u56e0\u662f\u4e3a\u4e86\u907f\u514d\u53ef\u80fd\u7684\u5173\u7a0e\u3002\u636e\u7f8e\u56fd\u8d38\u6613\u4ee3\u8868\u529e\u516c\u5ba4\u62a5\u544a\uff0c2022\u5e74\u7f8e\u56fd\u4e0e\u6b27\u76df\u7684\u5546\u54c1\u548c\u670d\u52a1\u8d38\u6613\u9006\u5dee\u4e3a1,313\u4ebf\u7f8e\u5143\u3002\u5728\u7279\u6717\u666e\u4e0a\u6708\u8d62\u5f97\u9009\u4e3e\u80dc\u5229\u540e\uff0c\u6b27\u76df\u4e00\u76f4\u5728\u4e3a\u53ef\u80fd\u7684\u8d38\u6613\u653b\u52bf\u505a\u51c6\u5907\u30022017\u5e74\uff0c\u5f53\u7279\u6717\u666e\u5728\u4e0a\u4e00\u4efb\u603b\u7edf\u4efb\u671f\u5185\u4ee5\u56fd\u5bb6\u5b89\u5168\u4e3a\u7531\u5bf9\u6b27\u6d32\u94a2\u94dd\u5f81\u6536\u5173\u7a0e\u65f6\uff0c\u6b27\u76df\u63aa\u624b\u4e0d\u53ca\u3002\u4f5c\u4e3a\u56de\u5e94\uff0c\u6b27\u76df\u5df2\u7ecf\u6539\u9769\u4e86\u5176\u8d38\u6613\u539f\u5219\u5e76\u6269\u5927\u4e86\u5de5\u5177\u8303\u56f4\uff0c\u4e3a\u5e94\u5bf9\u6b64\u7c7b\u63aa\u65bd\u63d0\u4f9b\u4e86\u591a\u79cd\u9009\u62e9\u3002\u5fb7\u56fd\u5916\u4ea4\u90e8\u957f\u5b89\u5a1c\u83b1\u5a1c\u00b7\u8d1d\u5c14\u4f2f\u514b\u572811\u6708\u5e95\u610f\u5927\u5229\u4e03\u56fd\u96c6\u56e2\u4f1a\u8bae\u540e\u8868\u793a\uff0c\u6b27\u76df\u5df2\u4e3a\u65b0\u7f8e\u56fd\u653f\u5e9c\u4e0b\u53ef\u80fd\u51fa\u73b0\u7684\u53d8\u5316\u505a\u597d\u51c6\u5907\u3002\u5982\u679c\u7f8e\u56fd\u653f\u5e9c\u5728\u6c14\u5019\u6216\u8d38\u6613\u677f\u5757\u4f18\u5148\u8003\u8651\u5176\"\u7f8e\u56fd\u4f18\u5148\"\u653f\u7b56\uff0c\u6b27\u76df\u7684\u56de\u5e94\u5c06\u662f\"\u6b27\u6d32\u56e2\u7ed3\"\u3002\u6b27\u76df\u59d4\u5458\u4f1a\u4e3b\u5e2d\u4e4c\u5c14\u82cf\u62c9\u00b7\u51af\u5fb7\u83b1\u6069\u4e0a\u6708\u63d0\u51fa\uff0c\u6b27\u76df\u53ef\u4ee5\u7528\u7f8e\u56fdLNG\u8fdb\u53e3\u66ff\u4ee3\u4fc4\u7f57\u65afLNG\u6d88\u8d39\u3002\u5979\u5728\u4e0e\u7279\u6717\u666e\u901a\u7535\u8bdd\u540e\u63d0\u5230\u8fd9\u4e00\u70b9\uff0c\u79f0\u7f8e\u56fdLNG\u66f4\u4fbf\u5b9c\uff0c\u53ef\u4ee5\u964d\u4f4e\u6b27\u6d32\u80fd\u6e90\u4ef7\u683c\u3002\u672c\u6587\u7531\u4eba\u5de5\u667a\u80fd\u534f\u52a9\u7ffb\u8bd1\u3002\u66f4\u591a\u4fe1\u606f\uff0c\u8bf7\u53c2\u89c1\u6211\u4eec\u7684\u4f7f\u7528\u6761\u6b3e\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-93CH-2611640", "pub_date": "2024-12-20 20:59:54", "source": "investing_cn", "kind": 1, "language": "zh-CN"}, {"id": 2611623, "title": "\u82f1\u4f1f\u8fbe(NVDA.US)\u6536\u8d2d\u4ee5\u8272\u5217Run:ai\u83b7\u6b27\u76df\u65e0\u6761\u4ef6\u6279\u51c6", "description": " \u667a\u901a\u8d22\u7ecfAPP\u83b7\u6089\uff0c\u82f1\u4f1f\u8fbe(NVDA.US)\u6536\u8d2d\u4ee5\u8272\u5217\u521d\u521b\u516c\u53f8Run:ai\u83b7\u5f97\u6b27\u76df\u65e0\u6761\u4ef6\u6279\u51c6\uff0cRun:ai\u4e3b\u8981\u5f00\u53d1\u5904\u7406\u4eba\u5de5\u667a\u80fd\u8ba1\u7b97\u8d44\u6e90\u7684\u8f6f\u4ef6\u3002\u6b27\u76df\u59d4\u5458\u4f1a\u5468\u4e94\u5728\u4e00\u4efd\u58f0\u660e\u4e2d\u8868\u793a\uff0c\u5c3d\u7ba1\u82f1\u4f1f\u8fbe\u662f\u201c\u6b27\u76df\u53ca\u5176\u4ed6\u5730\u533a\u4eba\u5de5\u667a\u80fd\u5e94\u7528\u5173\u952e\u786c\u4ef6\u7684\u9886\u5148\u751f\u4ea7\u5546\u201d\uff0c\u4f46\u6b64\u6b21\u6536\u8d2d\u5e76\u672a\u5bf9\u6b27\u76df27\u4e2a\u6210\u5458\u56fd\u6784\u6210\u4efb\u4f55\u7ade\u4e89\u5a01\u80c1\u3002\u6b27\u76df\u65b0\u4efb\u53cd\u5784\u65ad\u4e13\u5458\u7279\u91cc\u8428\u00b7\u91cc\u8d1d\u62c9(Teresa \nRibera)\u5728\u58f0\u660e\u4e2d\u8868\u793a\uff1a\u201c\u6211\u4eec\u7684\u5e02\u573a\u8c03\u67e5\u5411\u6211\u4eec\u8bc1\u5b9e\uff0c\u4e0e\u82f1\u4f1f\u8fbe\u786c\u4ef6\u517c\u5bb9\u7684\u5176\u4ed6\u8f6f\u4ef6\u9009\u62e9\u4ecd\u5c06\u5728\u5e02\u573a\u4e0a\u63d0\u4f9b\u3002\u201dRun:ai\u57284\u6708\u4efd\u5ba3\u5e03\u6b64\u6b21\u6536\u8d2d\u65f6\u8868\u793a\uff0c\u8fd9\u5bb6\u603b\u90e8\u4f4d\u4e8e\u52a0\u5dde\u5723\u514b\u62c9\u62c9\u7684\u82af\u7247\u5236\u9020\u5546\u4e8e2018\u5e74\u7531Omri Geller\u548cRonen \nDar\u521b\u7acb\uff0c\u81ea2020\u5e74\u4ee5\u6765\u4e00\u76f4\u662f\u82f1\u4f1f\u8fbe\u7684\u5bc6\u5207\u5408\u4f5c\u4f19\u4f34\u3002\u8be5\u516c\u53f8\u6ca1\u6709\u62ab\u9732\u4ea4\u6613\u7684\u5177\u4f53\u6761\u6b3e\uff0c\u4f46\u4ee5\u8272\u5217\u62a5\u7eb8\u300aCalcalist\u300b\u4f30\u8ba1\u4ea4\u6613\u4ef7\u503c\u4e3a7\u4ebf\u7f8e\u5143\u3002\u82f1\u4f1f\u8fbe\u5728\u4ee5\u8272\u5217\u7684\u4e0a\u4e00\u7b14\u91cd\u5927\u4ea4\u6613\u662f\u57282020\u5e74\u4ee570\u4ebf\u7f8e\u5143\u6536\u8d2dMellanox \nTechnologies Ltd.\u3002\u82f1\u4f1f\u8fbe\u5728\u4eba\u5de5\u667a\u80fd\u82af\u7247\u5e02\u573a\u7684\u4e3b\u5bfc\u5730\u4f4d\u5df2\u5f15\u8d77\u56fd\u5185\u5916\u5bc6\u5207\u5173\u6ce8\u3002\u8be5\u516c\u53f8\u7684\u56fe\u5f62\u5904\u7406\u5668\u5355\u5143(GPU)\u6700\u521d\u662f\u5728\u89c6\u9891\u6e38\u620f\u4e2d\u6d41\u884c\u8d77\u6765\u7684\uff0c\u4f46\u73b0\u5728\u5bf9\u4e8e\u7528\u4e8e\u8bad\u7ec3\u5927\u578b\u8bed\u8a00\u6a21\u578b\u548c\u5176\u4ed6\u4eba\u5de5\u667a\u80fd\u7cfb\u7edf\u7684\u65b0\u7cfb\u7edf\u8d8a\u6765\u8d8a\u91cd\u8981\u3002\u867d\u7136\u4e9a\u9a6c\u900a(AMZN.US)\u7b49\u516c\u53f8\u6b63\u5728\u52aa\u529b\u653e\u677e\u82f1\u4f1f\u8fbe\u5bf9\u5e02\u573a\u7684\u63a7\u5236\uff0c\u4f46\u76ee\u524d\u5e02\u573a\u5bf9\u8fd9\u79cd\u82af\u7247\u4ecd\u6709\u5de8\u5927\u9700\u6c42\uff0c\u6bcf\u5757\u82af\u7247\u7684\u4ef7\u683c\u9ad8\u8fbe\u6570\u4e07\u7f8e\u5143\u800c\u4e14\u4f9b\u4e0d\u5e94\u6c42\u3002\u6b27\u76df\u5e76\u8d2d\u76d1\u7ba1\u673a\u6784\u662f\u5728\u610f\u5927\u5229\u7ade\u4e89\u76d1\u7ba1\u673a\u6784\u7684\u59d4\u6258\u4e0b\u5c55\u5f00\u8c03\u67e5\u7684\u3002\u610f\u5927\u5229\u7ade\u4e89\u76d1\u7ba1\u673a\u6784\u62e5\u6709\u7279\u6b8a\u6743\u529b\uff0c\u5141\u8bb8\u6b27\u76df\u5bf9\u672a\u8fbe\u5230\u6b27\u76df\u5ba1\u67e5\u6240\u9700\u6536\u5165\u95e8\u69db\u7684\u5e76\u8d2d(\u5305\u62ec\u79d1\u6280\u4ea4\u6613)\u8fdb\u884c\u8c03\u67e5\u3002\u6b27\u76df\u6cd5\u9662\u6700\u8fd1\u5bf9Illumina Inc.\u4ee570\u4ebf\u7f8e\u5143\u6536\u8d2d\u764c\u75c7\u68c0\u6d4b\u63d0\u4f9b\u5546Grail \nInc.\u7684\u6848\u4ef6\u4f5c\u51fa\u88c1\u51b3\u540e\uff0c\u8fd9\u4e9b\u6743\u529b\u53d7\u5230\u4e86\u9650\u5236\u3002\u6cd5\u5b98\u4eec\u8868\u793a\uff0c\u6b27\u76df\u5e76\u8d2d\u76d1\u7ba1\u673a\u6784\u975e\u6cd5\u9f13\u52b1\u56fd\u5bb6\u76d1\u7ba1\u673a\u6784\u8981\u6c42\u5176\u8c03\u67e5\u901a\u5e38\u4f4e\u4e8e\u6b27\u76df\u8c03\u67e5\u95e8\u69db\u7684\u4ea4\u6613\u3002\u53ea\u6709\u5f53\u56fd\u5bb6\u76d1\u7ba1\u673a\u6784\u8981\u6c42\u5bf9\u4e00\u9879\u5df2\u62e5\u6709\u8fdb\u884c\u81ea\u5df1\u8c03\u67e5\u7ba1\u8f96\u6743\u7684\u4ea4\u6613\u8fdb\u884c\u6b27\u76df\u5c42\u9762\u7684\u5ba1\u67e5\u65f6\uff0c\u6cd5\u9662\u624d\u5141\u8bb8\u4f7f\u7528\u8be5\u7cfb\u7edf\u3002\u6b27\u76df\u6cd5\u9662\u57289\u6708\u7684\u4e00\u4efd\u88c1\u51b3\u963b\u788d\u4e86\u6b27\u76df\u8ffd\u67e5\u5176\u4ed6\u53ef\u80fd\u5b58\u5728\u95ee\u9898\u7684\u4ea4\u6613\u7684\u80fd\u529b\uff0c\u6bd4\u5982\u5fae\u8f6f(MSFT.US)\u5bf9Inflection AI\u7684\u6295\u8d44\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2611623", "pub_date": "2024-12-20 20:36:56", "source": "investing_cn", "kind": 1, "language": "zh-CN"}, {"id": 2611574, "title": "\u4fc4\u7f57\u65af\u592e\u884c\u7ef4\u6301\u5173\u952e\u5229\u7387\u572821%\u4e0d\u53d8", "description": "Investing.com - \u5468\u4e94\uff0c\u4fc4\u7f57\u65af\u592e\u884c\u5ba3\u5e03\u5c06\u7ef4\u6301\u5176\u4e3b\u8981\u5229\u7387\u572821%\u4e0d\u53d8\u3002\u8fd9\u4e00\u51b3\u5b9a\u51fa\u4e4e\u610f\u6599\uff0c\u56e0\u4e3a\u5e02\u573a\u666e\u904d\u9884\u671f\u4f1a\u518d\u6b21\u4e0a\u8c03200\u4e2a\u57fa\u70b9\u3002\u592e\u884c\u89e3\u91ca\u8fd9\u4e00\u51b3\u5b9a\u662f\u57fa\u4e8e\u8d27\u5e01\u6761\u4ef6\u7684\u6539\u5584\uff0c\u8fd9\u53ef\u80fd\u6709\u52a9\u4e8e\u63a7\u5236\u9ad8\u901a\u80c0\u7387\u3002\u592e\u884c\u58f0\u660e\u663e\u793a\uff0c\u8d27\u5e01\u6761\u4ef6\u7684\u6536\u7d27\u7a0b\u5ea6\u8d85\u8fc7\u4e8610\u6708\u4efd\u5173\u952e\u5229\u7387\u51b3\u5b9a\u65f6\u7684\u9884\u671f\u3002\u5bfc\u81f4\u8fd9\u79cd\u6536\u7d27\u7684\u56e0\u7d20\u88ab\u63cf\u8ff0\u4e3a\"\u72ec\u7acb\u4e8e\"\u592e\u884c\u8d27\u5e01\u653f\u7b56\u7684\u3002\u592e\u884c\u6307\u51fa\uff0c\u501f\u8d37\u5229\u7387\u7684\u663e\u8457\u4e0a\u5347\u548c\u4fe1\u8d37\u6d3b\u52a8\u7684\u653e\u7f13\u5df2\u7ecf\u4e3a\u91cd\u542f\u901a\u7f29\u8fdb\u7a0b\u521b\u9020\u4e86\u5fc5\u8981\u6761\u4ef6\u3002\u5c3d\u7ba1\u5f53\u524d\u4ef7\u683c\u589e\u957f\u5f3a\u52b2\u4e14\u56fd\u5185\u9700\u6c42\u65fa\u76db\uff0c\u4f46\u8fd9\u53ef\u80fd\u5bfc\u81f4\u901a\u80c0\u6c34\u5e73\u56de\u5f52\u76ee\u6807\u6c34\u5e73\u300210\u6708\uff0c\u592e\u884c\u66fe\u4e0a\u8c03\u5229\u7387\u4ee5\u5e94\u5bf9\u901a\u80c0\uff0c\u901a\u80c0\u53d7\u5230\u4fc4\u7f57\u65af\u5728\u4e4c\u514b\u5170\u519b\u4e8b\u5e72\u9884\u7684\u8d22\u653f\u8d1f\u62c5\u4ee5\u53ca\u897f\u65b9\u56fd\u5bb6\u5bf9\u5176\u5173\u952e\u5927\u5b97\u5546\u54c1\u51fa\u53e3\u5b9e\u65bd\u5236\u88c1\u7684\u63a8\u52a8\u3002\u592e\u884c\u8868\u793a\uff0c\u5c06\u57282\u6708\u7684\u4e0b\u6b21\u4f1a\u8bae\u4e0a\u8003\u8651\u662f\u5426\u9700\u8981\u4e0a\u8c03\u5173\u952e\u5229\u7387\u3002\u592e\u884c\u76ee\u524d\u9884\u8ba1\uff0c\u52302026\u5e74\u5e74\u5ea6\u901a\u80c0\u7387\u5c06\u964d\u81f34%\uff0c\u5e76\u5728\u53ef\u9884\u89c1\u7684\u672a\u6765\u4fdd\u6301\u5728\u8fd9\u4e00\u6c34\u5e73\u3002\u4fc4\u7f57\u65af\u5f53\u524d\u7684\u6d88\u8d39\u8005\u4ef7\u683c\u6307\u6570\u662f\u8fd9\u4e00\u76ee\u6807\u7684\u4e24\u500d\u591a\u3002\u622a\u81f312\u670816\u65e5\uff0c\u5e74\u5ea6\u901a\u80c0\u7387\u62a5\u544a\u4e3a9.5%\uff0c\u5bb6\u5ead\u548c\u4f01\u4e1a\u677f\u5757\u5c24\u5176\u611f\u53d7\u5230\u6301\u7eed\u7684\u538b\u529b\u300211\u6708\u6d88\u8d39\u8005\u4ef7\u683c\u6307\u6570\u540c\u6bd4\u4e0a\u5347\u81f38.9%\uff0c\u9ad8\u4e8e10\u6708\u76848.5%\u3002\u8fd9\u4e00\u589e\u957f\u4e3b\u8981\u662f\u7531\u4e8e\u98df\u54c1\u6210\u672c\u4e0a\u6da8\uff0c\u5176\u4e2d\u725b\u5976\u548c\u4e73\u5236\u54c1\u4ef7\u683c\u4eca\u5e74\u51fa\u73b0\u663e\u8457\u4e0a\u6da8\u3002\u672c\u6587\u7531\u4eba\u5de5\u667a\u80fd\u534f\u52a9\u7ffb\u8bd1\u3002\u66f4\u591a\u4fe1\u606f\uff0c\u8bf7\u53c2\u89c1\u6211\u4eec\u7684\u4f7f\u7528\u6761\u6b3e\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-93CH-2611574", "pub_date": "2024-12-20 20:14:16", "source": "investing_cn", "kind": 1, "language": "zh-CN"}]}