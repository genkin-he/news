da81.27%\uff0c\u62a52694.10\u7f8e\u5143/\u76ce\u53f8\uff1bCOMEX\u9ec4\u91d1\u671f\u8d27\u6da81.28%\uff0c\u62a52720.00\u7f8e\u5143/\u76ce\u53f8\u3002\u3010\u539f\u6cb9\u3011\u7ebd\u7ea6\u5546\u54c1\u4ea4\u6613\u62401\u6708\u4ea4\u5272\u7684\u897f\u5f97\u5dde\u4e2d\u8d28\u539f\u6cb9(WTI)\u671f\u8d27\u4ef7\u683c\u4e0a\u6da822\u7f8e\u5206\uff0c\u6da8\u5e45\u4e3a0.32%\uff0c\u6536\u4e8e\u6bcf\u687668.59\u7f8e\u5143\u3002\u3010\u91d1\u5c5e\u3011LME\u671f\u94dc\u6536\u8dcc16\u7f8e\u5143\uff0c\u62a59216\u7f8e\u5143/\u5428\u3002LME\u671f\u94dd\u6536\u6da820\u7f8e\u5143\uff0c\u62a52608\u7f8e\u5143/\u5428\u3002LME\u671f\u950c\u6536\u6da89\u7f8e\u5143\uff0c\u62a53135\u7f8e\u5143/\u5428\u3002LME\u671f\u94c5\u6536\u8dcc3\u7f8e\u5143\uff0c\u62a52064\u7f8e\u5143/\u5428\u3002LME\u671f\u954d\u6536\u8dcc281\u7f8e\u5143\uff0c\u62a515715\u7f8e\u5143/\u5428\u3002LME\u671f\u9521\u6536\u8dcc142\u7f8e\u5143\uff0c\u62a529776\u7f8e\u5143/\u5428\u3002LME\u671f\u94b4\u6536\u5e73\uff0c\u62a524300\u7f8e\u5143/\u5428\u3002\u3010\u5b8f\u89c2\u6d88\u606f\u3011\u7f8e\u56fd\u52b3\u5de5\u7edf\u8ba1\u5c40\u6570\u636e\u53d1\u5e03\u5c61\u6b21\u5931\u8bef \u5173\u952e\u5916\u5305\u5c97\u4f4d\u88ab\u64a4\u3002\u5728\u7f8e\u56fd11\u6708CPI\u6570\u636e\u516c\u5e03\u7684\u524d\u5915\uff0c\u4e00\u4efd\u6700\u65b0\u53d1\u5e03\u7684\u62a5\u544a\u79f0\uff0c\u7f8e\u56fd\u52b3\u5de5\u7edf\u8ba1\u5c40\u9886\u5bfc\u5c42\u5e94\u5bf9\u4eca\u5e74\u7684\u4e00\u7cfb\u5217\u5931\u8bef\u8d1f\u8d23\u3002\u8fd9\u4e9b\u5931\u8bef\u4f7f\u8be5\u673a\u6784\u53d7\u5230\u5ba1\u89c6\u3002\u4e0d\u8fc7\uff0c\u7531\u653f\u5e9c\u548c\u79c1\u8425\u90e8\u95e8\u6210\u5458\u7ec4\u6210\u7684\u4e13\u5bb6\u56e2\u961f\u51fa\u5177\u7684\u8fd9\u4efd\u62a5\u544a\u79f0\uff0c\u8fd9\u4e9b\u4e8b\u4ef6\u5747\u4e0e\u8be5\u673a\u6784\u6838\u5fc3\u6570\u636e\u5de5\u4f5c\u7684\u8d28\u91cf\u6216\u51c6\u786e\u6027\u65e0\u5173\u3002\u62a5\u544a\u8fd8\u8865\u5145\u8bf4\uff0c\u5e76\u672a\u53d1\u73b0\u5b58\u5728\u4e0d\u8bda\u5b9e\u6216\u6076\u610f\u7684\u6f5c\u5728\u52a8\u673a\u3002\u6b64\u524d\uff0c\u7f8e\u56fd4\u6708CPI\u63d0\u524d\u6cc4\u9732\uff0c8\u6708\uff0c\u975e\u519c\u5c31\u4e1a\u62a5\u544a\u521d\u6b65\u5e74\u5ea6\u57fa\u51c6\u4fee\u6b63\u6570\u636e\u5728\u539f\u5b9a\u4e0a\u534810\u70b9\u7684\u53d1\u5e03\u65f6\u95f4\u8fc7\u540e\u5ef6\u8fdf\u4e8630\u591a\u5206\u949f\u624d\u53d1\u5e03\uff0c\u8c03\u67e5\u53d1\u73b0\uff0c\u8be5\u673a\u6784\u7684\u6280\u672f\u53ca\u8f6f\u4ef6\u73b0\u4ee3\u5316\u5de5\u4f5c\u56e0\u8d44\u91d1\u4e0d\u8db3\u800c\u53d7\u963b\uff0c\u8fd9\u4f7f\u5176\u65e0\u6cd5\u786e\u4fdd\u5176\u6d41\u7a0b\u548c\u7cfb\u7edf\u8ddf\u4e0a\u6280\u672f\u8fdb\u6b65\u7684\u6b65\u4f10\u3002\u8c03\u67e5\u5c0f\u7ec4\u63d0\u51fa\u91cd\u65b0\u89c4\u5212\u9488\u5bf9\u4e00\u7ebf\u5de5\u4f5c\u4eba\u5458\u7684\u4f01\u4e1a\u57f9\u8bad\uff0c\u5e76\u4fee\u8ba2\u5e94\u6025\u8ba1\u5212\u4ee5\u964d\u4f4e\u53d1\u5e03\u4e0d\u53ca\u65f6\u7684\u98ce\u9669\u3002\u636e\u6089\uff0c\u7f8e\u56fd\u52b3\u5de5\u7edf\u8ba1\u5c40\u5df2\u5c06\u627f\u5305\u5546\u4ece\u5173\u952e\u5c97\u4f4d\u4e0a\u64a4\u4e0b\uff0c\u5c06\u8fd9\u4e9b\u804c\u80fd\u9650\u5b9a\u7531\u8054\u90a6\u5de5\u4f5c\u4eba\u5458\u627f\u62c5\u3002\u7f8e\u56fd\u8d22\u653f\u90e8\u8fde\u7eed\u7b2c\u4e8c\u5468\u524a\u51cf4\u5468\u671f\u30018\u5468\u671f\u56fd\u5e93\u5238\u6807\u552e\u89c4\u6a21\u300212\u670810\u65e5\uff0c\u7f8e\u56fd\u8d22\u653f\u90e8\u524a\u51cf\u4e86\u671f\u9650\u6700\u77ed\u7684\u57fa\u51c6\u56fd\u5e93\u5238\u54c1\u79cd\u62db\u6807\u89c4\u6a21\u3002\u7f8e\u56fd\u8d22\u653f\u90e8\u8868\u793a\u8ba1\u5212\u5468\u56db\u53d1\u884c\u89c4\u6a21\u4e3a800\u4ebf\u7f8e\u5143\u76844\u5468\u671f\u56fd\u5e93\u5238\uff0c\u8f83\u4e4b\u524d\u540c\u671f\u9650\u54c1\u79cd\u56fd\u5e93\u5238\u7684\u53d1\u884c\u89c4\u6a21\u51cf\u5c11\u4e8650\u4ebf\u7f8e\u5143\u3002\u8be5\u90e8\u95e8\u8fd8\u5ba3\u5e03\u5468\u56db\u53d1\u884c750\u4ebf\u7f8e\u5143\u76848\u5468\u671f\u56fd\u5e93\u5238\uff0c\u89c4\u6a21\u4e5f\u51cf\u5c11\u4e8650\u4ebf\u7f8e\u5143\u3002\u62df\u4e8e\u5468\u4e09\u53d1\u884c\u768417\u5468\u671f\u56fd\u5e93\u5238\u6807\u552e\u89c4\u6a21\u7ef4\u6301\u5728640\u4ebf\u7f8e\u5143\u4e0d\u53d8\u3002\u7f8e\u56fd\u8d22\u653f\u90e8\u572810\u6708\u8868\u793a\uff0c\u8ba1\u5212\u622a\u81f311\u6708\u7ef4\u6301\u57fa\u51c6\u56fd\u5e93\u5238\u7684\u62db\u6807\u89c4\u6a21\uff0c\u5e76\u572812\u6708\u201c\u9002\u5ea6\u524a\u51cf\u201d\u77ed\u671f\u56fd\u5e93\u5238\u6807\u552e\u89c4\u6a21\u3002EIA\uff1a\u7f8e\u56fd2025\u5e74\u539f\u6cb9\u51c0\u8fdb\u53e3\u5c06\u5927\u964d20%\u3002\u7f8e\u56fd\u80fd\u6e90\u4fe1\u606f\u7f72\uff08EIA\uff09\u5468\u4e8c\u8868\u793a\uff0c\u9884\u8ba1\u660e\u5e74\u7f8e\u56fd\u539f\u6cb9\u51c0\u8fdb\u53e3\u91cf\u5c06\u4e0b\u964d20%\uff0c\u81f3190\u4e07\u6876/\u65e5\uff0c\u5c06\u4e3a1971\u5e74\u4ee5\u6765\u7684\u6700\u4f4e\u6c34\u5e73\uff0c\u6697\u793a\u7f8e\u56fd\u4ea7\u91cf\u589e\u52a0\uff0c\u70bc\u5382\u9700\u6c42\u4e0b\u964d\u3002EIA\u5728\u517612\u6708\u7684\u300a\u77ed\u671f\u80fd\u6e90\u5c55\u671b\u300b\u4e2d\u8868\u793a\uff0c\u9884\u8ba12025\u5e74\u7f8e\u56fd\u77f3\u6cb9\u4ea7\u91cf\u5c06\u4ece2024\u5e74\u76841,324\u4e07\u6876/\u65e5\u589e\u81f31,352\u4e07\u6876/\u65e5\u3002EIA\u8fd8\u79f0\uff0c2025\u5e74\u70bc\u5382\u7684\u539f\u6cb9\u52a0\u5de5\u91cf\u5c06\u4e3a1,600\u4e07\u6876/\u65e5\uff0c\u6bd42024\u5e74\u51cf\u5c1120\u4e07\u6876/\u65e5\u3002EIA\u73b0\u9884\u8ba12025\u5e74\u5e03\u5170\u7279\u539f\u6cb9\u73b0\u8d27\u5747\u4ef7\u4e3a\u6bcf\u687673.58\u7f8e\u5143\uff0c\u4f4e\u4e8e\u4e4b\u524d\u9884\u6d4b\u7684\u6bcf\u687676.06\u7f8e\u5143\u3002\u7f8e\u56fd\u539f\u6cb9\u73b0\u8d27\u5747\u4ef7\u4e3a\u6bcf\u687669.12\u7f8e\u5143\uff0c\u4f4e\u4e8e\u4e0a\u6b21\u9884\u6d4b\u7684\u6bcf\u687671.60\u7f8e\u5143\u3002\u3010\u4e2a\u80a1\u6d88\u606f\u3011\u6ce2\u97f3(BA.US)\u91cd\u542f737\u98de\u673a\u751f\u4ea7\u7ebf 11\u6708\u4ea4\u4ed8\u91cf\u521b\u56db\u5e74\u65b0\u4f4e\u3002\u7ecf\u5386\u4e8653\u5929\u7684\u7f62\u5de5\u540e\uff0c\u6ce2\u97f3\u8868\u793a\u5df2\u6062\u590d\u751f\u4ea7\u6700\u7545\u9500\u7684\u673a\u578b\uff0c\u540c\u65f6\u8be5\u516c\u53f811\u6708\u4ea4\u4ed8\u91cf\u964d\u81f3\u56db\u5e74\u4f4e\u70b9\u3002\u6ce2\u97f3\u80a1\u4ef7\u5728\u7ebd\u7ea6\u5e02\u573a\u4e00\u5ea6\u4e0a\u6da85.9%\uff0c\u622a\u81f3\u76ee\u524d\uff0c\u8be5\u80a1\u4e0a\u6da84.7%\u3002\u6ce2\u97f311\u6708\u4ea4\u4ed8\u4e869\u67b6737 Max\u98de\u673a\uff0c\u4ee5\u53ca\u4e24\u67b6787\u68a6\u60f3\u98de\u673a\u548c\u4e24\u67b6777\u98de\u673a\u3002\u6240\u6709\u8fd9\u4e9b\u98de\u673a\u90fd\u662f\u5728\u7f62\u5de5\u4e4b\u524d\u5236\u9020\u5e76\u4ea4\u4ed8\u7684\u5e93\u5b58\u3002\u8fd9\u5bb6\u98de\u673a\u5236\u9020\u5546\u8868\u793a\uff0c\u4f4d\u4e8e\u534e\u76db\u987f\u5dde\u897f\u96c5\u56fe\u5357\u90e8Renton\u5de5\u5382\u7684737\u98de\u673a\u751f\u4ea7\u7ebf\u5df2\u5168\u9762\u6062\u590d\u8fd0\u8425\u3002\u6ce2\u97f3\u5728\u7f62\u5de5\u7ed3\u675f\u540e\u7684\u51e0\u5468\u91cc\u4e0d\u5f97\u4e0d\u6574\u7406\u96f6\u4ef6\u548c\u5de5\u5177\uff0c\u540c\u65f6\u8fd8\u8981\u57f9\u8bad\u548c\u91cd\u65b0\u8ba4\u8bc1\u5728\u5408\u540c\u7ea0\u7eb7\u671f\u95f4\u7f62\u5de5\u7684\u8ba1\u65f6\u5de5\u3002\u7f8e\u56fd\u5546\u52a1\u90e8\u5ba3\u5e03\u5411\u82af\u7247\u4f01\u4e1a\u7f8e\u5149\u79d1\u6280(MU.US)\u63d0\u4f9b61\u4ebf\u7f8e\u5143\u8d44\u91d1\u300212\u670810\u65e5\uff0c\u767d\u5bab\u53d1\u5e03\u7684\u4e00\u4efd\u58f0\u660e\u663e\u793a\uff0c\u7f8e\u56fd\u5546\u52a1\u90e8\u5f53\u65e5\u4e0e\u7f8e\u56fd\u6700\u5927\u8ba1\u7b97\u673a\u5b58\u50a8\u82af\u7247\u5236\u9020\u5546\u7f8e\u5149\u79d1\u6280\u7b7e\u8ba2\u5408\u540c\uff0c\u5c06\u5411\u7f8e\u5149\u79d1\u6280\u63d0\u4f9b61\u4ebf\u7f8e\u5143\u8d44\u91d1\u3002\u6b64\u5916\uff0c\u7f8e\u56fd\u5546\u52a1\u90e8\u8fd8\u5ba3\u5e03\u5df2\u4e0e\u7f8e\u5149\u79d1\u6280\u8fbe\u6210\u521d\u6b65\u534f\u8bae\uff0c\u5c06\u989d\u5916\u63d0\u4f9b2.75\u4ebf\u7f8e\u5143\u8d44\u91d1\uff0c\u7528\u4e8e\u6269\u5efa\u7f8e\u5149\u79d1\u6280\u4f4d\u4e8e\u5f17\u5409\u5c3c\u4e9a\u5dde\u9a6c\u7eb3\u8428\u65af\u7684\u5de5\u5382\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2597747", "pub_date": "2024-12-11 06:36:42"}, {"id": 2597501, "title": "\u4f9b\u8fc7\u4e8e\u6c42\u548c\u6e29\u548c\u7684\u5929\u6c14\u4f7f\u671f\u8d27\u627f\u538b", "description": "\n\u5468\u4e8c\uff0812\u670810\u65e5\uff09\u7f8e\u76d8\u65f6\u6bb5\uff0c\u7f8e\u56fd\u5929\u7136\u6c14\u671f\u8d27\u4ef7\u683c\u5927\u5e45\u4e0b\u8dcc\uff0c\u56e0\u770b\u8dcc\u7684\u57fa\u672c\u9762\u7ee7\u7eed\u76d6\u8fc7\u77ed\u671f\u5bd2\u51b7\u5929\u6c14\u9884\u62a5\u7684\u5f71\u54cd\u3002\u5f3a\u52b2\u7684\u751f\u4ea7\u6c34\u5e73\u6301\u7eed\u5b58\u5728\uff0c\u800c\u6db2\u5316\u5929\u7136\u6c14\u51fa\u53e3\u9700\u6c42\u4ecd\u7136\u4f4e\u8ff7\uff0c\u52a0\u5267\u4e86\u4f9b\u8fc7\u4e8e\u6c42\u7684\u62c5\u5fe7\u3002\u636eEBW\u5206\u6790\u96c6\u56e2\u79f0\uff0c\u5e02\u573a\u4ecd\u5bf91\u6708\u4efd\u4e25\u5bd2\u9020\u6210\u7684\u6f5c\u5728\u4e2d\u65ad\u4fdd\u6301\u8b66\u60d5\uff0c\u4f46\u8fd1\u671f\u57fa\u672c\u9762\u8868\u660e\u5e02\u573a\u4f9b\u5e94\u5145\u8db3\u3002\u6700\u65b0\u7684\u5929\u6c14\u72b6\u51b5\u51e0\u4e4e\u65e0\u6cd5\u62b5\u6d88\u60b2\u89c2\u7684\u524d\u666f\u3002\u867d\u7136\u6700\u8fd1\u7684\u5929\u6c14\u9884\u62a5\u5728\u5468\u672b\u589e\u52a0\u4e86\u5927\u7ea620\u4e2a\u4f9b\u6696\u5ea6\u65e5\u6570\uff08HDD\uff09\uff0c\u4f46\u7f8e\u56fd\u5357\u90e8\u548c\u4e1c\u90e8\u7684\u6e29\u548c\u5929\u6c14\u6291\u5236\u4e86\u9700\u6c42\u3002\u9884\u8ba1\u4ece12\u670820\u65e5\u81f323\u65e5\uff0c\u4e00\u80a1\u77ed\u6682\u7684\u51b7\u950b\u5c06\u5e2d\u5377\u4e2d\u897f\u90e8\u548c\u4e1c\u90e8\uff0c\u4e2d\u897f\u90e8\u6700\u4f4e\u6c14\u6e29\u5c06\u8fbe\u52300\u534e\u6c0f\u5ea6\u81f320\u534e\u6c0f\u5ea6\uff0c\u5357\u90e8\u5c06\u77ed\u6682\u964d\u81f320\u534e\u6c0f\u5ea6\u81f330\u534e\u6c0f\u5ea6\u3002\u7136\u800c\uff0c\u66f4\u5e7f\u6cdb\u768415\u5929\u524d\u666f\u8868\u660e\uff0c\u6301\u7eed\u7684\u5bd2\u51b7\u6709\u9650\uff0c\u4f7f\u9700\u6c42\u4fdd\u6301\u6e29\u548c\u3002\u5468\u4e00\u9ad8\u5f00\u672a\u80fd\u7ef4\u6301\u7531\u4e8e\u5468\u672b\u5929\u6c14\u9884\u62a5\u504f\u51b7\uff0c\u5468\u4e00\u5929\u7136\u6c14\u671f\u8d27\u5f00\u76d8\u8d70\u9ad8\uff0c\u4f46\u672a\u80fd\u7ef4\u6301\u6da8\u52bf\uff0c\u6536\u4e8e3.182\u7f8e\u5143/\u767e\u4e07\u82f1\u70ed\uff0c\u76d8\u4e2d\u9ad8\u70b9\u4e3a3.324\u7f8e\u5143/\u767e\u4e07\u82f1\u70ed\u3002\u65e9\u76d8\u6da8\u52bf\u53cd\u6620\u4e86\u5e02\u573a\u5bf9\u786c\u76d8\u6570\u91cf\u589e\u52a0\u7684\u77ed\u6682\u53cd\u5e94\uff0c\u4f46\u4ea4\u6613\u5546\u5f88\u5feb\u6d88\u5316\u4e86\u524d\u666f\uff0c\u6062\u590d\u5230\u66f4\u4e3a\u8c28\u614e\u7684\u7acb\u573a\u3002\u6280\u672f\u5c55\u671b\u51f8\u663e\u4e0b\u884c\u98ce\u9669\uff08\u7f8e\u56fd\u5929\u7136\u6c1401\u65e5\u56fe \u6765\u6e90\uff1a\u6613\u6c47\u901a\uff09\u4ece\u6280\u672f\u4e0a\u8bb2\uff0c\u5929\u7136\u6c14\u671f\u8d27\u5df2\u7ecf\u56de\u5230\u5173\u952e\u652f\u6491\u4f4d\u3002\u7ebd\u7ea6\u5546\u54c1\u4ea4\u6613\u62401\u6708\u5408\u7ea6\u6b63\u5728\u6d4b\u8bd550\u65e5\u79fb\u52a8\u5747\u7ebf3.104\u7f8e\u5143/\u767e\u4e07\u82f1\u70ed\u548c50%\u56de\u64a4\u4f4d3.118\u7f8e\u5143/\u767e\u4e07\u82f1\u70ed\u3002\u5982\u679c\u6301\u7eed\u8dcc\u7834\u8fd9\u4e9b\u6c34\u5e73\uff0c\u53ef\u80fd\u4f1a\u5c06\u4ef7\u683c\u63a8\u54112.993\u7f8e\u5143/\u767e\u4e07\u82f1\u70ed\u7684\u6590\u6ce2\u90a3\u5951\u6c34\u5e73\uff0c\u5206\u6790\u5e08\u8ba4\u4e3a\u8fd9\u662f\u8fdb\u4e00\u6b65\u629b\u552e\u538b\u529b\u7684\u5173\u952e\u70b9\u3002\u7136\u800c\uff0c\u5982\u679c\u5929\u7136\u6c14\u4ef7\u683c\u6301\u7eed\u4e0a\u6da8\u81f33.118\u7f8e\u5143/\u767e\u4e07\u82f1\u70ed\u4ee5\u4e0a\uff0c\u5c06\u8868\u660e\u4e70\u76d8\u5174\u8da3\uff0c\u5e76\u53ef\u80fd\u9884\u793a\u7740\u6f5c\u5728\u7684\u770b\u6da8\u9006\u8f6c\u3002\u4ea4\u6613\u5458\u6b63\u5bc6\u5207\u5173\u6ce83.118\u7f8e\u5143\u81f33.094\u7f8e\u5143/\u767e\u4e07\u82f1\u70ed\u7684\u533a\u95f4\uff0c\u57283.104\u7f8e\u5143/\u767e\u4e07\u82f1\u70ed\u4ee5\u4e0b\uff0c\u770b\u8dcc\u7684\u57fa\u8c03\u53ef\u80fd\u5360\u4e3b\u5bfc\u5730\u4f4d\u3002\u5e02\u573a\u524d\u666f\uff1a\u770b\u8dcc\uff0c\u4e0a\u884c\u7a7a\u95f4\u6709\u9650\u753