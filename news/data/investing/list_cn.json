u79ef\u6781\u7684\u8f68\u9053\u4e0a\uff0c\u4efb\u4f55\u6f5c\u5728\u7684\u4e0b\u8dcc\u90fd\u53ef\u80fd\u5e26\u6765\u201c\u9022\u4f4e\u4e70\u5165\u201d\u7684\u673a\u4f1a\u3002\u8dcc\u78341.4150\u53ef\u80fd\u5f15\u53d1\u4e0b\u4e00\u4e2a\u770b\u8dcc\u52a8\u4f5c\uff0c\u800c\u4e0a\u78341.4200\u5219\u53ef\u80fd\u5c06\u6ce8\u610f\u529b\u8f6c\u79fb\u56de\u4e0a\u884c\u3002\u5317\u4eac\u65f6\u95f422:03\uff0c\u7f8e\u5143/\u65e5\u5143\u62a5152.247/60\uff0c\u6da8\u5e450.19%\u3002\u7f8e\u5143/\u52a0\u5143\u62a51.4169/71\uff0c\u8dcc\u5e450.07%\u3002\n", "link": "https://cn.investing.com/news/forex-news/article-2598984", "pub_date": "2024-12-11 22:20:16"}, {"id": 2598954, "title": "\u7f8e\u80a1\u5f02\u52a8 | \u524d\u4e09\u5b63\u5ea6\u7d2f\u8ba1\u51c0\u4e8f\u635f\u540c\u6bd4\u7f29\u51cf\u8fd162% \u4e91\u96c6(YJ.US)\u76d8\u524d\u6da8\u8fd133%", "description": " \u667a\u901a\u8d22\u7ecfAPP\u83b7\u6089\uff0c\u5468\u4e09\uff0c\u4e91\u96c6(YJ.US)\u7f8e\u80a1\u76d8\u524d\u6da8\u8fd133%\uff0c\u62a52.15\u7f8e\u5143\u30022024\u8d22\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u4e91\u96c6\u7d2f\u8ba1\u6536\u51653.21\u4ebf\u5143\uff0c\u53bb\u5e74\u540c\u671f\u7d2f\u8ba1\u6536\u5165\u4e3a4.91\u4ebf\u5143\uff0c\u540c\u6bd4\u51cf\u5c1134.73%\uff1b\u7d2f\u8ba1\u51c0\u4e8f\u635f3807.70\u4e07\u5143\uff0c\u53bb\u5e74\u540c\u671f\u7d2f\u8ba1\u51c0\u4e8f\u635f\u4e3a9926.90\u4e07\u5143\uff0c\u540c\u6bd4\u7f29\u51cf61.64%\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2598954", "pub_date": "2024-12-11 22:06:46"}, {"id": 2598955, "title": "\u82f9\u679c(AAPL.US)\u53d1\u5e03\u8f6f\u4ef6\u66f4\u65b0 Siri\u6b63\u5f0f\u63a5\u5165ChatGPT", "description": " \u667a\u901a\u8d22\u7ecfAPP\u83b7\u6089\uff0c\u82f9\u679c(AAPL.US)\u5468\u4e09\u5f00\u59cb\u5c06OpenAI\u7684ChatGPT\u96c6\u6210\u5230\u5176\u8bbe\u5907\u4e2d\uff0c\u8fd9\u662f\u4e00\u9879\u671f\u5f85\u5df2\u4e45\u7684\u529f\u80fd\uff0c\u6295\u8d44\u8005\u5e0c\u671b\u8fd9\u5c06\u6709\u52a9\u4e8e\u63a8\u52a8\u5176\u6700\u65b0\u6b3eiPhone\u7684\u9500\u552e\u3002\u6b64\u6b21\u63a8\u51fa\u662f\u5728iPhone\u3001iPad\u548cMac\u7535\u8111\u64cd\u4f5c\u7cfb\u7edf\u7684\u6700\u65b0\u66f4\u65b0\u4e2d\u66f4\u5e7f\u6cdb\u5730\u90e8\u7f72\u4eba\u5de5\u667a\u80fd\u9a71\u52a8\u5de5\u5177\u7684\u4e00\u90e8\u5206\u3002\u4f5c\u4e3aApple \nIntelligence\u53d1\u5e03\u7684\u4e00\u90e8\u5206\uff0cChatGPT\u96c6\u6210\u5c06\u5141\u8bb8\u8be5\u516c\u53f8\u7684Siri\u8bed\u97f3\u52a9\u624b\u5229\u7528\u804a\u5929\u673a\u5668\u4eba\u7684\u4e13\u4e1a\u77e5\u8bc6\uff0c\u5305\u62ec\u7528\u6237\u5bf9\u7167\u7247\u548c\u6f14\u793a\u6587\u7a3f\u7b49\u6587\u6863\u7684\u67e5\u8be2\u3002\u7528\u6237\u8fd8\u53ef\u4ee5\u8981\u6c42ChatGPT\u5728\u4efb\u4f55\u652f\u6301\u65b0\u7684\u4e66\u5199\u5de5\u5177\u529f\u80fd\u7684\u5e94\u7528\u7a0b\u5e8f\u4e2d\u521b\u5efa\u4e66\u9762\u5185\u5bb9\u3002\u4ed6\u4eec\u53ef\u4ee5\u4f7f\u7528\u804a\u5929\u673a\u5668\u4eba\u7684\u56fe\u50cf\u751f\u6210\u529f\u80fd\u6765\u6dfb\u52a0\u56fe\u50cf\u3002\u6b64\u6b21\u8f6f\u4ef6\u66f4\u65b0\u6b63\u503c\u5047\u65e5\u8d2d\u7269\u65fa\u5b63\uff0c\u8fd9\u662f\u82f9\u679c\u4e00\u5e74\u4e2d\u7684\u9500\u552e\u9ad8\u5cf0\u671f\u3002\u5230\u76ee\u524d\u4e3a\u6b62\uff0cApple Intelligence\u529f\u80fd\u7684\u7f13\u6162\u63a8\u51fa\u5f15\u53d1\u4e86\u4e00\u4e9b\u6295\u8d44\u8005\u5bf9iPhone \n16\u9500\u552e\u5468\u671f\u7684\u62c5\u5fe7\u3002\u4eba\u5de5\u667a\u80fd\u5c06\u5728\u6700\u65b0\u7684iPhone\u7cfb\u5217\u4ee5\u53ca\u4e4b\u524d\u7684iPhone 15\u7cfb\u5217\u7684Pro\u548cPro Max\u7248\u672c\u4e0a\u63d0\u4f9b\u3002\u914d\u5907A17 \nPro\u6216M1\u82af\u7247\u53ca\u66f4\u9ad8\u7248\u672c\u7684iPad\u7528\u6237\uff0c\u4ee5\u53ca\u914d\u5907M1\u82af\u7247\u53ca\u4ee5\u4e0a\u7248\u672c\u7684Mac\u7528\u6237\u4e5f\u53ef\u4ee5\u8bbf\u95ee\u8fd9\u4e9b\u5de5\u5177\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2598955", "pub_date": "2024-12-11 22:06:49"}, {"id": 2598883, "title": "RBC\uff1a\u9884\u8ba1Mobileye(MBLY.US)\u5c06\u8d62\u5f97\u65b0\u5408\u540c \u5408\u4f5c\u65b9\u6216\u5305\u62ec\u672c\u7530(HMC.US)\u3001\u4e30\u7530(TM.US)\u7b49", "description": " \u667a\u901a\u8d22\u7ecfAPP\u83b7\u6089\uff0cRBC Capital\u53d1\u8868\u7814\u62a5\u8868\u793a\uff0cMobileye \nGlobal(MBLY.US)\u5728\u6155\u5c3c\u9ed1\u4e3e\u884c\u7684\u6295\u8d44\u8005\u6d3b\u52a8\u4e2d\u53d1\u5e03\u7684\u4e00\u4efd\u6f14\u793a\u6587\u7a3f\u5185\u5bb9\u53ef\u80fd\u9884\u793a\u7740\u8be5\u516c\u53f8\u53ef\u80fd\u5373\u5c06\u8d62\u5f97\u4e00\u4efd\u5408\u540c\u3002\u5206\u6790\u5e08Tom \nNarayan\u8868\u793a\uff0c\u6f14\u793a\u6587\u7a3f\u4e2d\u7684\u4e00\u5f20\u5e7b\u706f\u7247\u53ef\u80fd\u8868\u660e\u8be5\u516c\u53f8\u5373\u5c06\u83b7\u5f97\u65e5\u672c\u539f\u59cb\u8bbe\u5907\u5236\u9020\u5546(OEM)\u7684\u63d0\u540d\u3002\u53e6\u4e00\u5f20\u5e7b\u706f\u7247\u663e\u793a\uff0c\u4e0b\u4e00\u4e2a\u63d0\u540d\u9636\u6bb5\u5199\u7740\u201c2-3\u4e2a\u6708\u201d\u3002\u5176\u4e2d\u8fd8\u5305\u62ec\u4e00\u5bb6\u6b27\u6d32OEM\uff0c\u8be5\u516c\u53f8\u53ef\u80fd\u5373\u5c06\u83b7\u5f97\u4e00\u4efd\u5173\u4e8eSurround \nADAS\u6280\u672f\u7684\u5408\u540c\u63d0\u540d\u3002\u7f8e\u56fd\u539f\u59cb\u8bbe\u5907\u5236\u9020\u5546\u88ab\u8ba4\u4e3a\u5904\u4e8e\u8c08\u5224\u548c\u51b3\u7b56\u9636\u6bb5\uff0c\u8be5\u5206\u6790\u5e08\u8865\u5145\u9053\uff0c\u8fd9\u662f\u5728\u63d0\u540d\u6b65\u9aa4\u4e4b\u524d\u3002Narayan\u6307\u51fa\uff0c\u867d\u7136\u8fd8\u6ca1\u6709\u83b7\u5f97\u6b63\u5f0f\u5408\u540c\uff0c\u4f46\u8fd9\u5bb6\u65e5\u672c\u539f\u59cb\u8bbe\u5907\u5236\u9020\u5546\u6240\u5904\u7684\u9636\u6bb5\u53ef\u80fd\u610f\u5473\u7740\u5b83\u5373\u5c06\u6388\u4e88\u3002\u4ed6\u8865\u5145\u9053\uff0c\u5728\u4e0e\u6295\u8d44\u8005\u7684\u5bf9\u8bdd\u4e2d\uff0c\u8fd9\u662f\u9996\u8981\u95ee\u9898\u2014\u2014Mobileye\u662f\u5426\u4f1a\u5ba3\u5e03OEM\u5173\u4e8e\u5176\u9a7e\u9a76\u8f85\u52a9\u7cfb\u7edfSuperVision\u7684\u5408\u540c\u3002Narayan\u8868\u793a\uff0c\u4ed6\u4eec\u5e76\u4e0d\u671f\u5f85\u5728\u6d3b\u52a8\u4e2d\u5ba3\u5e03\u8fbe\u6210\u534f\u8bae\uff0c\u4f46\u8be5\u516c\u53f8\u53ef\u80fd\u63a5\u8fd1\u8fbe\u6210\u7684\u53ef\u80fd\u6027\u662f\u4e00\u4e2a\u79ef\u6781\u7684\u56e0\u7d20\u3002\u5206\u6790\u5e08\u8ba4\u4e3a\uff0c\u53ef\u80fd\u53c2\u4e0e\u5176\u4e2d\u7684\u56db\u5bb6\u65e5\u672c\u539f\u59cb\u8bbe\u5907\u5236\u9020\u5546\u662f\u672c\u7530(HMC.US)\u3001\u4e30\u7530(TM.US)\u3001\u65e5\u4ea7(NASNY.US)\u548c\u9a6c\u81ea\u8fbe(MZDAY.US)\u3002\u5206\u6790\u5e08\u8868\u793a\uff0c\u8003\u8651\u5230\u9500\u91cf\uff0c\u4e0e\u672c\u7530\u6216\u4e30\u7530\u8fbe\u6210\u534f\u8bae\u53ef\u80fd\u610f\u4e49\u91cd\u5927\u3002\u672c\u7530\u53d1\u8a00\u4eba\u5bf9\u6b64\u5728\u4e00\u5c01\u7535\u5b50\u90ae\u4ef6\u4e2d\u8868\u793a\uff1a\u201c\u6211\u4eec\u4e0d\u4f1a\u8ba8\u8bba\u6211\u4eec\u7684\u4f9b\u5e94\u5546\u5173\u7cfb\uff0c\u4e5f\u4e0d\u4f1a\u5bf9\u8fd9\u79cd\u731c\u6d4b\u53d1\u8868\u8bc4\u8bba\u3002\u201dRBC\u5206\u6790\u5e08\u6000\u7591\uff0c\u662f\u5426\u5728\u8c08\u5224\u9636\u6bb5\u7684\u7f8e\u56fdOEM\u53ef\u80fd\u662f\u901a\u7528\u6c7d\u8f66(GM.US)\uff0c\u800c\u63a5\u8fd1\u8fbe\u6210\u4e0eSurround \nADAS\u6709\u5173\u534f\u8bae\u7684\u6b27\u6d32OEM\u53ef\u80fd\u662fStellantis (STLA.US)\u6216\u96f7\u8bfa(RNLSY.US)\u3002\u901a\u7528\u6c7d\u8f66\u5728\u4e00\u4efd\u7535\u5b50\u90ae\u4ef6\u58f0\u660e\u4e2d\u8868\u793a\uff1a\u201c\u6211\u4eec\u4e0d\u4f1a\u53c2\u4e0e\u8c23\u8a00\u548c\u731c\u6d4b\u3002\u201d\u5728\u672c\u62a5\u544a\u53d1\u5e03\u4e4b\u524d\uff0cMobileye\u3001\u4e30\u7530\u3001\u65e5\u4ea7\u3001Stellantis\u548c\u96f7\u8bfa\u6ca1\u6709\u56de\u5e94\u7f6e\u8bc4\u8bf7\u6c42\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2598883", "pub_date": "2024-12-11 21:37:19"}, {"id": 2598884, "title": "\u6700\u65b0\u6295\u6807\u62a5\u4ef7\u663e\u793a\u9a6c\u65af\u514b\u65d7\u4e0bSpaceX\u4f30\u503c\u8fbe3500\u4ebf\u7f8e\u5143", "description": " \u667a\u901a\u8d22\u7ecfAPP\u83b7\u6089\uff0c\u636e\u62a5\u9053\uff0c\u57c3\u9686\u00b7\u9a6c\u65af\u514b\u7684SpaceX\u53ca\u5176\u6295\u8d44\u8005\u5df2\u540c\u610f\u65a5\u8d44\u9ad8\u8fbe12.5\u4ebf\u7f8e\u5143\u6536\u8d2d\u5185\u90e8\u4eba\u80a1\u7968\uff0c\u6b64\u6b21\u4ea4\u6613\u5c06SpaceX\u7684\u4f30\u503c\u63a8\u81f3\u7ea63500\u4ebf\u7f8e\u5143\uff0c\u4f7f\u5176\u6210\u4e3a\u5168\u7403\u6700\u5177\u4ef7\u503c\u7684\u79c1\u8425\u521d\u521b\u516c\u53f8\u3002\u5176\u4e2d\uff0cSpaceX\u5355\u72ec\u63d0\u51fa\u8d2d\u4e70\u4ef7\u503c\u9ad8\u8fbe5\u4ebf\u7f8e\u5143\u7684\u80a1\u7968\u3002\u6b64\u6b21\u4ea4\u6613\u4ee5\u6bcf\u80a1185\u7f8e\u5143\u7684\u4ef7\u683c\u8fdb\u884c\uff0c\u8f83SpaceX\u4e0a\u6b21\u6bcf\u80a1112\u7f8e\u5143\u7684\u6536\u8d2d\u8981\u7ea6\u53ca11\u6708\u4e2d\u65ec\u63d0\u8bae\u7684\u6bcf\u80a1\u7ea6125\u7f8e\u5143\u7684\u4ef7\u683c\u5747\u6709\u5927\u5e45\u63d0\u5347\u3002\u8fd9\u4e00\u4ea4\u6613\u4e0d\u4ec5\u51f8\u663e\u4e86\u6295\u8d44\u8005\u5bf9SpaceX\u7684\u9ad8\u5ea6\u5174\u8da3\uff0c\u4e5f\u53cd\u6620\u4e86\u5e02\u573a\u5bf9\u9a6c\u65af\u514b\u53ca\u5176\u4f01\u4e1a\u672a\u6765\u53d1\u5c55\u7684\u4e50\u89c2\u9884\u671f\u3002\u503c\u5f97\u6ce8\u610f\u7684\u662f\uff0c\u9a6c\u65af\u514b\u4e0e\u5019\u4efb\u603b\u7edf\u5510\u7eb3\u5fb7\u00b7\u7279\u6717\u666e\u7684\u5bc6\u5207\u5173\u7cfb\u4e3a\u4ed6\u7684\u4f01\u4e1a\u5e26\u6765\u4e86\u6240\u8c13\u7684\u201c\u7279\u6717\u666e\u51b2\u51fb\u201d\uff0c\u8fdb\u4e00\u6b65\u63a8\u52a8\u4e86\u5176\u8d22\u5bcc\u7684\u589e\u957f\u3002\u6839\u636e\u5f6d\u535a\u4ebf\u4e07\u5bcc\u7fc1\u6307\u6570\uff0c\u9a6c\u65af\u514b\u7684\u4e2a\u4eba\u8d22\u5bcc\u5df2\u81a8\u80c0\u81f3\u7ea63840\u4ebf\u7f8e\u5143\uff0c\u4eca\u5e74\u589e\u957f\u4e861550\u4ebf\u7f8e\u5143\u3002\u6b64\u5916\uff0c\u9a6c\u65af\u514b\u7684\u4eba\u5de5\u667a\u80fd\u521d\u521b\u516c\u53f8xAI\u5728\u4e0a\u4e2a\u6708\u5b8c\u6210\u4e00\u8f6e\u878d\u8d44\u540e\uff0c\u4f30\u503c\u4e5f\u8fbe\u5230\u4e86500\u4ebf\u7f8e\u5143\u3002\u4e0e\u6b64\u540c\u65f6\uff0c\u7279\u65af\u62c9\u7684\u80a1\u4ef7\u81ea\u9009\u4e3e\u65e5\u4ee5\u6765\u98d9\u5347\u8fd160%\uff0c\u76ee\u524d\u5e02\u503c\u9ad8\u8fbe1.26\u4e07\u4ebf\u7f8e\u5143\u3002\u8fd9\u4e9b\u6210\u5c31\u5171\u540c\u5c55\u793a\u4e86\u9a6c\u65af\u514b\u5728\u591a\u4e2a\u9886\u57df\u7684\u5e7f\u6cdb\u5e03\u5c40\u548c\u663e\u8457\u6210\u679c\u3002", "link": "https://cn.investing.com/news/stock-market-news/article-2598884", "pub_date": "2024-12-11 21:37:21"}]}