9c0\u671b\u7279\u6717\u666e\u51fa\u62db\uff0c\u671f\u9593\u5927\u5e02\u8868\u73fe\u53ef\u80fd\u8f03\u6ce2\u52d5\uff0c\u4f46\u5f8c\u7e8c\u7684\u523a\u6fc0\u653f\u7b56\u6709\u6a5f\u6703\u5e36\u4f86\u9a5a\u559c\uff0c\u9810\u8a08\u4eca\u5e743\u6708\u5169\u6703\u8209\u884c\u524d\uff0c\u4eba\u884c\u5c07\u518d\u5ba3\u5e03\u8ca8\u5e63\u523a\u6fc0\u63aa\u65bd\uff0c\u5167\u623f\u65b9\u9762\u4e5f\u6709\u671b\u52a0\u63a8\u653f\u7b56\u3002\u5118\u7ba1\u5e02\u5834\u53ef\u671b\u56de\u7a69\uff0c\u60df...\n<p>\uff08\u7bc0\u9304\uff09</p>", "link": "https://www1.hkej.com/dailynews/headline/article/3967014/%E6%B3%95%E5%B7%B4%E8%B3%87%E7%AE%A1%E6%96%99%E5%85%A9%E6%9C%83%E5%89%8D%E5%86%8D%E5%87%BA%E6%8B%9B%E6%95%91%E5%85%A7%E6%88%BF", "pub_date": "2025-01-02 02:50:34", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u300a\u62c6\u5c40\u300b\uff0d\uff0d\u8b8a\u73fe\u9678\u7e8c\u6709\u4f86 \u4e0d\u5c40\u9650\u4e0a\u5e02\u516c\u53f8", "description": "<p id=\"date\">2025\u5e741\u67082\u65e5</p>\n<p class=\"info\">\t\n<span class=\"column\"><a href=\"https://search.hkej.com/template/fulltextsearch/php/search.php?q=\u62c6\u5c40\">\u62c6\u5c40</a></span>\n</p>\n    <h1 id=\"article-title\" class=\"sub_ex_article-title\">\u8b8a\u73fe\u9678\u7e8c\u6709\u4f86 \u4e0d\u5c40\u9650\u4e0a\u5e02\u516c\u53f8<br>    \n   \n    </h1>\n<p><a href=\"https://static.hkej.com/hkej/images/2025/01/02/3967013_e2a52219458bf19a62647c6eaabf1f67.jpg\" title=\"\u963f\u91cc\u9996\u5e2d\u57f7\u884c\u5b98\u5433\u6cf3\u9298\u65e9\u524d\u900f\u9732\uff0c\u975e\u6838\u5fc3\u696d\u52d9\u6703\u901a\u904e\u591a\u7a2e\u8cc7\u672c\u5316\u65b9\u5f0f\uff0c\u76e1\u5feb\u5be6\u73fe\u8cc7\u7522\u50f9\u503c\u3002\uff08\u4e2d\u65b0\u793e\u8cc7\u6599\u5716\u7247\uff09\" class=\"thickbox\"><img src=\"https://static.hkej.com/hkej/images/2025/01/02/3967013_e2a52219458bf19a62647c6eaabf1f67_620.jpg\" border=\"0\"></a></p>\n<span class='enlargeImg'><a href=\"https://static.hkej.com/hkej/images/2025/01/02/3967013_e2a52219458bf19a62647c6eaabf1f67.jpg\" title=\"\u963f\u91cc\u9996\u5e2d\u57f7\u884c\u5b98\u5433\u6cf3\u9298\u65e9\u524d\u900f\u9732\uff0c\u975e\u6838\u5fc3\u696d\u52d9\u6703\u901a\u904e\u591a\u7a2e\u8cc7\u672c\u5316\u65b9\u5f0f\uff0c\u76e1\u5feb\u5be6\u73fe\u8cc7\u7522\u50f9\u503c\u3002\uff08\u4e2d\u65b0\u793e\u8cc7\u6599\u5716\u7247\uff09\" class=\"thickbox\"><img src='https://static.hkej.com/hkej/ejweb/enlarge.gif' align='absmiddle' />\u653e\u5927\u5716\u7247</a> / <a href=\"https://static.hkej.com/hkej/images/2025/01/02/3967013_e2a52219458bf19a62647c6eaabf1f67.jpg\" target=\"_blank\" title=\"\u963f\u91cc\u9996\u5e2d\u57f7\u884c\u5b98\u5433\u6cf3\u9298\u65e9\u524d\u900f\u9732\uff0c\u975e\u6838\u5fc3\u696d\u52d9\u6703\u901a\u904e\u591a\u7a2e\u8cc7\u672c\u5316\u65b9\u5f0f\uff0c\u76e1\u5feb\u5be6\u73fe\u8cc7\u7522\u50f9\u503c\u3002\uff08\u4e2d\u65b0\u793e\u8cc7\u6599\u5716\u7247\uff09\">\u986f\u793a\u539f\u5716</a></span>\n<p></p>\n\u963f\u91cc\u5df4\u5df4\uff0809988\uff09\u8fd1\u5169\u5e74\u591a\u6b21\u91cd\u6574\u696d\u52d9\uff0c\u68b3\u7406\u6230\u7565\u512a\u5148\u7d1a\u3002\u73fe\u4efb\u4e3b\u5e2d\u8521\u5d07\u4fe1\u3001\u9996\u5e2d\u57f7\u884c\u5b98\u5433\u6cf3\u9298\u7b49\u65b0\u9818\u5c0e\u73ed\u5b50\u4e00\u5e74\u591a\u524d\u4e0a\u5834\u4ee5\u4f86\uff0c\u5c62\u6b21\u5f37\u8abf\u96c6\u5718\u9700\u805a\u7126\u96fb\u5546\u3001\u96f2\u8a08\u7b97\u5169\u5927\u6838\u5fc3\u696d\u52d9\uff0c\u975e\u6838\u5fc3\u696d\u52d9\u5247\u8981\u52a0\u5feb\u51fa\u552e\u8b8a\u73fe\u3002\n\u805a\u7126\u96fb\u5546\u96f2\u8a08\u7b97\n\u5e02\u5834\u4eba\u58eb\u8a8d\u70ba\uff0c\u963f\u91cc\u6301\u7e8c\u525d\u96e2\u975e\u6838\u5fc3\u8cc7\u7522\uff0c\u76f8\u4fe1\u9084\u6703\u6709\u66f4\u591a\u51fa\u552e\u52d5\u4f5c\uff0c\u4e14\u4e0d\u5c40\u9650\u65bc\u4e0a\u5e02\u516c\u53f8\u6301\u80a1\u3002\n\u65e9...\n<p>\uff08\u7bc0\u9304\uff09</p>", "link": "https://www1.hkej.com/dailynews/headline/article/3967013/%E8%AE%8A%E7%8F%BE%E9%99%B8%E7%BA%8C%E6%9C%89%E4%BE%86+%E4%B8%8D%E5%B1%80%E9%99%90%E4%B8%8A%E5%B8%82%E5%85%AC%E5%8F%B8", "pub_date": "2025-01-02 02:50:33", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u963f\u91cc131\u5104\u6089\u552e\u9ad8\u946b \u525d\u96e2\u975e\u6838\u5fc3\u696d", "description": "<p id=\"date\">2025\u5e741\u67082\u65e5</p>\n<p class=\"info\">\t\n</p>\n    <h1 id=\"article-title\" class=\"sub_ex_article-title\">\u963f\u91cc131\u5104\u6089\u552e\u9ad8\u946b \u525d\u96e2\u975e\u6838\u5fc3\u696d<br>    \n    \n    </h1>\n<p><span style=\"font-size-ignore:13pt;\">\u963f\u91cc\u5df4\u5df4\uff08<a target=\"_blank\" href=\"https://stock360.hkej.com/quotePlus/09988\">09988</a>\uff09\u7e7c\u4e0a\u6708\u4e2d\u6089\u552e\u9280\u6cf0\u767e\u8ca8\u80a1\u6b0a\u5f8c\uff0c\u518d\u525d\u96e2\u5be6\u9ad4\u96f6\u552e\u8cc7\u7522\u3002\u5728\u5167\u5730\u7d93\u71df\u5927\u8ce3\u5834\u300c\u5927\u6f64\u767c\u300d\u7684\u9ad8\u946b\u96f6\u552e\uff08<a target=\"_blank\" href=\"https://stock360.hkej.com/quotePlus/06808\">06808</a>\uff09\uff0c\u53bb\u5e7410\u6708\u62ab\u9732\u63a5\u7372\u6536\u8cfc\u610f\u5411\uff0c\u6700\u7d42\u843d\u5be6\u4ea4\u6613\uff0c\u963f\u91cc\u53ca\u5176\u63a7\u5236\u7684New Retail\u6240\u6301\u670975\u5104\u80a1\u9ad8\u946b\u80a1\u4efd\uff0c\u5c07\u5168\u90e8\u552e\u4e88\u5fb7\u5f18\u8cc7\u672c\uff08DCP Capital\uff09\uff0c\u4f54\u9ad8\u946b\u5df2\u767c\u884c\u80a1\u4efd78.7%\u3002\u4ea4\u6613\u4f5c\u50f9\u7d04116\u5104\u5143\uff0c\u76f8\u7576\u65bc\u6bcf\u80a11.55\u5143\uff0c\u8f03\u9ad8\u946b\u5468\u4e8c\uff0812\u670831\u65e5\uff09\u6536\u5e02\u50f92.48\u5143\u6298\u8b93\u8fd138%\uff0c\u82e5\u8a08\u53ca\u5229\u606f\uff0c\u6d89\u8cc7\u6700\u591a131\u5104\u5143\u3002</span></p>\n<p><strong>\u5fb7\u5f18\u8cc7\u672c\u627f\u63a5 \u64ec\u79c1\u6709\u5316</strong></p>\n<p>\u9ad8\u946b\u96f6\u552e\u767c\u5e03\u516c\u544a\uff0c\u5fb7\u5f18\u8cc7\u672c\u4f5c\u70ba\u8981\u7d04\u4eba\u5c07\u6839\u64da\u6536\u8cfc\u5b88\u5247\uff0c\u5c31\u516c\u53f8\u5168\u90e8\u5df2\u767c\u884c\u80a1\u4efd\u4f5c\u51fa\u5f37\u5236\u6027\u73fe\u91d1\u8981\u7d04\uff0c\u64ec\u628a\u9ad8\u946b\u79c1\u6709\u5316\u3002\u80a1\u6771\u82e5\u9078\u64c7\u9810\u4ed8\u7d50\u7b97\u65b9\u6848\uff0c\u8981\u7d04\u50f9\u70ba\u6bcf\u80a11.38\u5143\uff0c\u905e\u5ef6\u7d50\u7b97\u65b9\u6848\u5247\u6700\u9ad8\u53ef\u6536\u53d6\u6bcf\u80a11.58\u5143\u3002</p>\n<p><div><p style='text-align: center;'><a href='https://static.hkej.com/hkej/images/2025/01/02/3967012_e03a63dbf441a6e175fc8503754f179f.png' title='\u963f\u91cc\u843d\u5be6\u6089\u552e\u5728\u5167\u5730\u7d93\u71df\u5927\u8ce3\u5834\u300c\u5927\u6f64\u767c\u300d\u7684\u9ad8\u946b\u96f6\u552e\u5168\u6578\u80a1\u6b0a\u3002\uff08\u5f6d\u535a\u8cc7\u6599\u5716\u7247\uff09' class='thickbox'><img src='https://static.hkej.com/hkej/images/2025/01/02/3967012_e03a63dbf441a6e175fc8503754f179f_620.png' style='max-width:100%'></a></p></div></p>\n<p>2017\u5e74\u963f\u91cc\u9996\u6b21\u5165\u80a1\u9ad8\u946b\u96f6\u552e\uff0c\u52302020\u5e74\u9032\u4e00\u6b65\u589e\u6301\uff0c\u5176\u5f8c\u9ad8\u946b\u6210\u70ba\u963f\u91cc\u4f75\u8868\u5b50\u516c\u53f8\u3002\u963f\u91cc\u8868\u793a\uff0c\u4eca\u6b21\u51fa\u552e\u662f\u96c6\u5718\u628a\u975e\u6838\u5fc3\u8cc7\u7522\u8b8a\u73fe\u7684\u826f\u6a5f\uff0c\u53ef\u5229\u7528\u6240\u5f97\u6b3e\u9805\u66f4\u52a0\u805a\u7126\u65bc\u6838\u5fc3\u696d\u52d9\u767c\u5c55\uff0c\u4e26\u63d0\u5347\u80a1\u6771\u56de\u5831\uff0c\u53c8\u63d0\u5230\u59cb\u7d42\u5c0d\u4e2d\u570b\u6d88\u8cbb\u5e02\u5834\u7684\u6f5b\u529b\u5145\u6eff\u4fe1\u5fc3\u3002\u4e0d\u904e\uff0c\u6b64\u6b21\u8ce3\u76e4\u963f\u91cc\u6050\u9700\u640d\u624b\uff0c\u64da\u5176\u4f30\u7b97\uff0c\u51fa\u552e\u4e8b\u9805\u5c07\u7522\u751f\u80a1\u6771\u61c9\u4f54\u8667\u640d\u7d04132\u5104\u5143\u4eba\u6c11\u5e63\u3002</p>\n<p><strong>\u8fd1\u6708\u9023\u756a\u8ce3\u8d70\u96f6\u552e\u8cc7\u7522</strong></p>\n<p>\u4e0d\u8db3\u4e00\u500b\u6708\u524d\uff0c\u963f\u91cc\u5ba3\u5e03\u51fa\u552e\u5167\u5730\u4f01\u696d\u9280\u6cf0\u767e\u8ca8\u7684\u5168\u90e8\u80a1\u6b0a\uff0c\u6240\u5f97\u6b3e\u9805\u7d0474\u5104\u5143\u4eba\u6c11\u5e63\uff0c\u9810\u8a08\u6703\u9304\u5f97\u8667\u640d\u7d0493\u5104\u5143\u4eba\u6c11\u5e63\u3002</p>\n<p>\u5167\u5730\u6d88\u8cbb\u5e02\u9053\u75b2\u8edf\uff0c\u9ad8\u946b\u96f6\u552e\u8fd1\u5e74\u696d\u7e3e\u627f\u58d3\u3002\u622a\u81f3\u53bb\u5e743\u6708\u5e95\u6b62\u5e74\u5ea6\uff0c\u9ad8\u946b\u9304\u5f97\u8fd117\u5104\u5143\u4eba\u6c11\u5e63\u8667\u640d\uff0c\u6536\u5165\u4e0b\u6ed113%\u81f3726\u5104\u5143\u4eba\u6c11\u5e63\u30022025\u8ca1\u5e74\u4e0a\u534a\u5e74\uff0c\u5118\u7ba1\u516c\u53f8\u626d\u8667\u5be6\u73fe\u4e861.9\u5104\u5143\u4eba\u6c11\u5e63\u76c8\u5229\uff0c\u60df\u6536\u5165\u4ecd\u672a\u626d\u8f49\u8dcc\u52e2\uff0c\u6309\u5e74\u6e1b\u5c113%\u3002</p>\n<p>\u7136\u800c\uff0c\u9ad8\u946b\u96f6\u552e\u53bb\u5e7410\u6708\u62ab\u9732\u63a5\u7372\u6709\u610f\u8981\u7d04\u4eba\u767c\u51fa\u7684\u63a5\u89f8\u51fd\uff0c\u7576\u6642\u5916\u5a92\u5831\u9053\u5fb7\u5f18\u8cc7\u672c\u548c\u9ad8\u74f4\u8cc7\u672c\u7b49\u6f5b\u5728\u7af6\u8cfc\u65b9\u6b63\u8003\u616e\u6536\u8cfc\u963f\u91cc\u6240\u6301\u6709\u7684\u9ad8\u946b\u80a1\u4efd\uff0c\u5176\u5f8c\u9ad8\u946b\u80a1\u50f9\u7bc0\u7bc0\u4e0a\u63da\uff0c\u81f3\u4eca\u5df2\u7d2f\u6f32\u903e\u4e94\u6210\u3002\u5982\u679c\u4ee5\u6d88\u606f\u91cb\u51fa\u524d\u7684\u80a1\u50f9\u8a08\u7b97\uff0c\u6b64\u6b21\u4ea4\u6613\u6bcf\u80a11.55\u5143\u50f9\u683c\uff0c\u6298\u8b93\u5927\u7d044%\u3002</p>\n<p><strong>\u5206\u5169\u6b21\u4ed8\u6b3e \u8ce3\u65b9\u53ef\u6536\u5229\u606f</strong></p>\n<p>\u9700\u8981\u7559\u610f\u7684\u662f\uff0c\u7531\u65bc\u4ea4\u6613\u5206\u5169\u6b21\u4ed8\u6b3e\uff0c\u8ce3\u65b9\u6709\u6b0a\u5c31\u7b2c\u4e8c\u6b21\u4ed8\u6b3e\u6536\u53d6\u5229\u606f\uff0c\u5018\u9ad8\u946b\u65bc2027\u548c2028\u8ca1\u653f\u5e74\u5ea6\u7684\u5e73\u5747\u7d93\u8abf\u6574EBITDA\uff08\u9664\u606f\u7a05\u6298\u820a\u53ca\u6524\u92b7\u524d\u5229\u6f64\uff09\u4e0d\u4f4e\u65bc\u8a2d\u5b9a\u4e0a\u9650\uff0c\u8cb7\u65b9\u9700\u652f\u4ed8\u6bcf\u80a10.2\u5143\u5229\u606f\uff0c\u610f\u5473\u963f\u91cc\u4e00\u65b9\u6bcf\u80a1\u6700\u9ad8\u53ef\u6536\u53d61.75\u5143\uff0c\u4ee4\u7e3d\u91d1\u984d\u589e\u81f3131\u5104\u5143\u3002\u963f\u91cc\u7a31\uff0c\u51fa\u552e\u6240\u5f97\u6b3e\u9805\u6de8\u984d\u5c07\u7528\u65bc\u696d\u52d9\u767c\u5c55\u3001\u80a1\u6771\u56de\u5831\u53ca\u4e00\u822c\u516c\u53f8\u7528\u9014\u3002</p>\n<p>\u9ad8\u946b\u96f6\u552e\u5247\u5728\u516c\u544a\u4e2d\u63d0\u53ca\uff0c\u6210\u529f\u5b8c\u6210\u8981\u7d04\u5f8c\uff0c\u5fb7\u5f18\u8cc7\u672c\u64ec\u652f\u6301\u516c\u53f8\u73fe\u6709\u4e3b\u8981\u696d\u52d9\uff0c\u4e26\u7e7c\u7e8c\u8207\u7ba1\u7406\u5718\u968a\u7dca\u5bc6\u5408\u4f5c\uff0c\u7121\u8a08\u5283\u5c0d\u516c\u53f8\u50f1\u54e1\u7559\u8058\u4f5c\u51fa\u4efb\u4f55\u91cd\u5927\u8b8a\u52d5\uff0c\u9810\u8a08\u4e0d\u6703\u5927\u5e45\u91cd\u65b0\u90e8\u7f72\u516c\u53f8\u7684\u56fa\u5b9a\u8cc7\u7522\u3002\u5fb7\u5f18\u8cc7\u672c\u5c07\u5c0d\u9ad8\u946b\u96f6\u552e\u7684\u8cc7\u7522\u3001\u516c\u53f8\u67b6\u69cb\u3001\u8cc7\u672c\u5316\u3001\u71df\u904b\u3001\u7269\u696d\u3001\u653f\u7b56\u53ca\u7ba1\u7406\u9032\u884c\u7b56\u7565\u6027\u6aa2\u8a0e\uff0c\u4ee5\u78ba\u5b9a\u662f\u5426\u9069\u5b9c\u9032\u884c\u4efb\u4f55\u8b8a\u52d5\u3002</p>\n<p>\u00a0</p>\n<p>\uff08\u4fe1\u5831\u65b0\u66f8\u63a8\u85a6\u300a\u5225\u8e29\u904e\u754c\uff01\u300b\uff0c\u5fc3\u7406\u5b78\u5bb6\u5316\u89e3\u60c5\u7dd2\u75c5\u771f\u5be6\u6848\u4f8b\uff0c\u7acb\u5373\u8cfc\u8cb7\uff09</p>\n<p><div><p style='text-align: center;'><a href='https://static.hkej.com/hkej/images/2025/01/02/3967012_02c59d4c27ac25015c3af6b335ac0cf1.png' title='' class='thickbox'><img src='https://static.hkej.com/hkej/images/2025/01/02/3967012_02c59d4c27ac25015c3af6b335ac0cf1_620.png' style='max-width:100%'></a></p></div></p>\n<p>\u5be6\u9ad4\u66f8\u672c\u5730\u5305\u90f5\u512a\u60e0 : <a href=\"https://bit.ly/hkejbook178\" target=\"_blank\">bit.ly/hkejbook178</a></p>\n<p>\u96fb\u5b50\u66f8 : <a href=\"https://bit.ly/hkejp178\" target=\"_blank\">bit.ly/hkejp178</a></p>", "link": "https://www1.hkej.com/dailynews/headline/article/3967012/%E9%98%BF%E9%87%8C131%E5%84%84%E6%82%89%E5%94%AE%E9%AB%98%E9%91%AB+%E5%89%9D%E9%9B%A2%E9%9D%9E%E6%A0%B8%E5%BF%83%E6%A5%AD", "pub_date": "2025-01-02 02:50:32", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u91d1\u50f9\u4e00\u5e74\u5927\u6f32\u5169\u6210\u4e03 14\u8f09\u6700\u52c1", "description": "<p id=\"date\">2025\u5e741\u67081\u65e5</p>\n<p class=\"info\">\t\n</p>\n    <h1 id=\"article-title\" class=\"sub_ex_article-title\">\u91d1\u50f9\u4e00\u5e74\u5927\u6f32\u5169\u6210\u4e03 14\u8f09\u6700\u52c1<br>    \n   \n    </h1>\n<p><a href=\"https://static.hkej.com/hkej/images/2025/01/01/3966586_9f558bb2ac929a6806b5423a7583aa2c.png\" title=\"\" class=\"thickbox\"><img src=\"https://static.hkej.com/hkej/images/2025/01/01/3966586_9f558bb2ac929a6806b5423a7583aa2c_620.png\" border=\"0\"></a></p>\n<span class='enlargeImg'><a href=\"https://static.hkej.com/hkej/images/2025/01/01/3966586_9f558bb2ac929a6806b5423a7583aa2c.png\" title=\"\" class=\"thickbox\"><img src='https://static.hkej.com/hkej/ejweb/enlarge.gif' align='absmiddle' />\u653e\u5927\u5716\u7247</a> / <a href=\"https://static.hkej.com/hkej/images/2025/01/01/3966586_9f558bb2ac929a6806b5423a7583aa2c.png\" target=\"_blank\" title=\"\">\u986f\u793a\u539f\u5716</a></span>\n<p></p>\n\u7f8e\u80a1\u57282024\u5e74\u6700\u5f8c\u4e00\u500b\u4ea4\u6613\u65e5\u6b62\u8dcc\u53cd\u5f48\u4e4f\u529b\uff0c\u9053\u6307\u9ad8\u958b62\u9ede\u5f8c\uff0c\u5347\u5e45\u4e00\u5ea6\u64f4\u5927\u81f3\u6700\u591a205\u9ede\uff0c\u583142779\u9ede\uff0c\u4f46\u96a8\u5f8c\u5347\u5e45\u6536\u7a84\uff0c\u6a19\u6307\u66fe\u56de\u53470.48%\uff0c\u7d0d\u6307\u4e0a\u63da0.39%\u5f8c\u5012\u8dcc\u3002\u73fe\u8ca8\u91d1\u50f9\u6700\u591a\u53470.43%\uff0c\u6bcf\u76ce\u65af\u58312617.79\u7f8e\u5143\uff0c\u5168\u5e74\u5927\u6f3227%\uff0c\u70ba14\u5e74\u4f86\u6700\u52c1\uff0c\u8868\u73fe\u8dd1\u8d0f\u5927\u90e8\u5206\u5546\u54c1\uff0c\u4e3b\u8981\u53d7\u5230\u5730\u7de3\u653f\u5c40\u6301\u7e8c\u4e0