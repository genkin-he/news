B%E6%97%A9%E7%8F%AD%E8%BB%8A%E3%80%91%E5%8A%A0%E6%8B%BF%E5%A4%A7%E5%A4%B1%E6%A5%AD%E7%8E%87%E5%89%B5%E8%BF%918%E5%B9%B4%E9%AB%98+%E6%B8%9B%E6%81%AF%E5%8D%8A%E5%8E%98%E6%8F%A3%E6%B8%AC%E5%8D%87%E6%BA%AB"}, {"title": "\u570b\u969b\u6cb9\u50f9\u8dcc\u903e1% \u4f9b\u904e\u65bc\u6c42\u6182\u616e\u589e\u52a0", "description": "<p>\u77f3\u6cb9\u51fa\u53e3\u570b\u7d44\u7e54\u53ca\u76df\u53cb(OPEC+)\u62bc\u5f8c\u589e\u7522\u6642\u95933\u500b\u6708\uff0c\u52a0\u6df1\u5e02\u5834\u5c0d\u660e\u5e74\u539f\u6cb9\u4f9b\u904e\u65bc\u6c42\u7684\u6182\u616e\uff0c\u570b\u969b\u6cb9\u50f9\u5468\u4e94\u4e0b\u6ed1\u903e1%\u3002</p>\n<p>\u7d10\u7d04\u671f\u6cb9\u6536\u5e02\u8dcc1.1\u7f8e\u5143\u62161.61%\uff0c\u6bcf\u6876\u583167.2\u7f8e\u5143\uff0c\u672c\u5468\u7d2f\u8a08\u8dcc1.2%\u3002\u502b\u6566\u5e03\u862d\u7279\u671f\u6cb9\u6536\u5e02\u8dcc0.97\u7f8e\u5143\u62161.34%\uff0c\u6bcf\u6876\u583171.12\u7f8e\u5143\uff0c\u672c\u5468\u7d2f\u8a08\u8dcc1%\u3002</p>\n<p>\u8f03\u65e9\u6642\uff0c\u7f8e\u570b\u516c\u5e03\u672c\u5468\u6d3b\u8e8d\u6cb9\u4e95\u6578\u91cf\u4e0a\u5347\uff0c\u986f\u793a\u77f3\u6cb9\u7522\u91cf\u53ef\u80fd\u6273\u5347\u3002\u5e02\u5834\u4ecd\u5728\u89e3\u8b80OPEC+\u5468\u56db\u4f5c\u51fa\u62bc\u5f8c\u589e\u7522\u6c7a\u5b9a\u3002</p>\n<p>Mizuho\u80fd\u6e90\u7814\u7a76\u4e3b\u7ba1Bob Yawger\u8a8d\u70ba\uff0cOPEC+\u6c7a\u5b9a\u62bc\u5f8c\u589e\u7522\uff0c\u986f\u793a\u7d44\u7e54\u770b\u6de1\u539f\u6cb9\u77ed\u7dda\u9700\u6c42\u524d\u666f\uff0c\u4f46\u4ea6\u53cd\u6620\u9577\u9060\u4ecd\u671f\u671b\u589e\u7522\uff0c\u4ee4\u5230\u4f9b\u904e\u65bc\u6c42\u6182\u616e\u5347\u6eab\uff0c\u4e0d\u5229\u6cb9\u50f9\u8868\u73fe\u3002</p>\n<p>\u6ed9\u8c50\u4e5f\u6301\u6709\u540c\u985e\u770b\u6cd5\uff0c\u4f46\u4ecd\u8abf\u4f4e\u660e\u5e74\u77f3\u6cb9\u904e\u5269\u9810\u6e2c\uff0c\u7531\u6bcf\u65e550\u842c\u6876\u964d\u4f4e\u81f320\u842c\u6876\u3002</p>\n<p>\u7f8e\u9280\u76f8\u4fe1\uff0c\u539f\u6cb9\u904e\u5269\u5c07\u589e\u52a0\uff0c\u8abf\u4f4e\u5e03\u862d\u7279\u671f\u6cb9\u50f9\u683c\u660e\u5e74\u9810\u6e2c\u81f365\u7f8e\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3949309/%E5%9C%8B%E9%9A%9B%E6%B2%B9%E5%83%B9%E8%B7%8C%E9%80%BE1%25+%E4%BE%9B%E9%81%8E%E6%96%BC%E6%B1%82%E6%86%82%E6%85%AE%E5%A2%9E%E5%8A%A0"}, {"title": "\u73fe\u8ca8\u91d1\u50f9\u66fe\u53470.53%", "description": "<p>\u7f8e\u570b\u975e\u8fb2\u5c31\u696d\u6578\u64da\u8f03\u9810\u671f\u5f37\u52c1\uff0c\u4f46\u5e02\u5834\u5c0d\u806f\u5132\u5c40\u6e1b\u606f\u7684\u63e3\u6e2c\u672a\u6709\u6539\u8b8a\uff0c\u7f8e\u5143\u6ed9\u50f9\u5468\u4e09\u5448\u5f37\uff0c\u91d1\u50f9\u4ecd\u7136\u9020\u597d\u3002</p>\n<p>\u7d10\u7d04\u671f\u91d1\u53470.4%\uff0c\u6bcf\u76ce\u65af\u58312637.02\u7f8e\u5143\u3002\u73fe\u8ca8\u91d1\u50f9\u66fe\u53470.53%\uff0c\u6bcf\u76ce\u65af\u9ad8\u898b2645.68\u7f8e\u5143\uff0c\u5176\u5f8c\u4e00\u5ea6\u8f15\u5fae\u5012\u8dcc\u3002</p>\n<p>\u7f8e\u570b\u52de\u5de5\u90e8\u8f03\u65e9\u6642\u516c\u5e03\uff0c11\u6708\u975e\u8fb2\u696d\u8077\u4f4d\u589e\u52a022.7\u842c\u500b\uff0c\u5e02\u5834\u9810\u671f\u589e\u52a020\u842c\u500b\uff1b\u5931\u696d\u7387\u9304\u5f974.2%\u7b26\u5408\u9810\u671f\uff1b\u671f\u5167\uff0c\u5e73\u5747\u6642\u85aa\u6309\u6708\u589e\u52a00.4%\uff0c\u9810\u671f\u70ba\u589e\u95770.3%\u3002</p>\n<p>\u4ea4\u6613\u5546\u7a31\uff0c\u6578\u64da\u672a\u6709\u5f71\u97ff\u5132\u5c40\u672c\u6708\u6e1b\u606f0.25\u5398\u7684\u666e\u904d\u9810\u671f\uff0c\u56e0\u6b64\u7f8e\u6ed9\u6273\u5347\uff0c\u4e0d\u904e\u672a\u8db3\u4ee5\u4ee4\u8655\u65bc\u7a84\u5e45\u5f98\u4f6a\u7684\u91d1\u50f9\u660e\u986f\u8f49\u52e2\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3949307/%E7%8F%BE%E8%B2%A8%E9%87%91%E5%83%B9%E6%9B%BE%E5%8D%870.53%25"}, {"title": "\u6c99\u7279:OPEC+\u62bc\u5f8c\u589e\u7522\u662f\u9762\u5c0d\u73fe\u5be6", "description": "<p>\u6c99\u7279\u963f\u62c9\u4f2f\u80fd\u6e90\u90e8\u9577\u963f\u535c\u675c\u52d2\u963f\u9f4a\u8332(Abdulaziz bin Salman)\u8868\u793a\uff0c\u77f3\u6cb9\u51fa\u53e3\u570b\u7d44\u7e54\u53ca\u76df\u53cb(OPEC+)\u65e9\u524d\u6c7a\u5b9a\u62bc\u5f8c\u589e\u7522\u8a08\u5283\uff0c\u662f\u9762\u5c0d\u73fe\u5be6\u7684\u6c7a\u5b9a\u3002</p>\n<p>OPEC+\u5468\u56db\u8209\u884c\u90e8\u9577\u7d1a\u7db2\u4e0a\u6703\u8b70\u5f8c\uff0c\u4f5c\u51fa\u63a8\u90723\u500b\u6708\u3001<span style=\"font-size-ignore:13pt;\">\u81f3\u660e\u5e744\u6708\u624d\u555f\u52d5\u5206\u6bb5\u6bcf\u65e5\u589e\u7522220\u842c\u6876\u7684\u6c7a\u5b9a\u3002</span></p>\n<p>\u963f\u535c\u675c\u52d2\u963f\u9f4a\u8332\u63a5\u53d7\u7f8e\u570bCNBC\u8a2a\u554f\u6642\u7a31\uff0cOPEC+\u9808\u627f\u8a8d\u4f9b\u6c42\u51fa\u73fe\u8b8a\u5316\uff0c\u7136\u5f8c\u63a1\u53d6\u7b26\u5408\u73fe\u5be6\u7684\u6c7a\u5b9a\u3002</p>\n<p>\u4ed6\u8868\u793a\uff0c\u4e2d\u570b\u3001\u6b50\u6d32\u53ca\u5168\u7403\u7d93\u6fdf\u60c5\u6cc1\u51fa\u73fe\u8b8a\u6578\uff0c\u5f71\u97ff\u539f\u6cb9\u9700\u6c42\u524d\u666f\uff0c\u63a8\u9072\u589e\u7522\u662f\u5be9\u614e\u7684\u505a\u6cd5\u3002</p>\n<p>\u6839\u64daOPEC+\u5468\u56db\u6c7a\u5b9a\uff0c\u6574\u9ad4\u7522\u91cf\u5354\u5b9a\u6709\u6548\u9650\u671f\u4e5f\u7531\u539f\u5148\u76842025\u5e74\u5e95\uff0c\u63a8\u5c6c\u81f32026\u5e74\u5e95\uff0c\u53cd\u6620\u5404\u6210\u54e1\u570b\u9650\u5236\u7522\u91cf\u7684\u8a08\u5283\u6301\u7e8c\u81f3\u5f8c\u5e74\u3002</p>\n<p>\u963f\u535c\u675c\u52d2\u963f\u9f4a\u8332\u53c8\u63d0\u53ca\uff0c\u90e8\u5206\u6210\u54e1\u570b\u672a\u6709\u9075\u5b88\u7522\u91cf\u5354\u5b9a\uff0c\u4ee4\u4eba\u611f\u5230\u5931\u671b\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3949306/%E6%B2%99%E7%89%B9%3AOPEC%2B%E6%8A%BC%E5%BE%8C%E5%A2%9E%E7%94%A2%E6%98%AF%E9%9D%A2%E5%B0%8D%E7%8F%BE%E5%AF%A6"}, {"title": "\u5927\u6469\u7dad\u6301\u806f\u5132\u5c40\u672c\u6708\u6e1b\u606f0.25\u5398\u9810\u6e2c\u4e0d\u8b8a", "description": "<p>\u7f8e\u570b\u5c31\u696d\u6578\u64da\u8f03\u9810\u671f\u4f73\uff0c\u6469\u6839\u58eb\u4e39\u5229\u7dad\u6301\u806f\u5132\u5c40\u672c\u6708\u6e1b\u606f0.25\u5398\u7684\u9810\u6e2c\u4e0d\u8b8a\u3002</p>\n<p>\u7f8e\u570b\u52de\u5de5\u90e8\u8f03\u65e9\u6642\u516c\u5e03\uff0c11\u6708\u975e\u8fb2\u696d\u8077\u4f4d\u589e\u52a022.7\u842c\u500b\uff0c\u591a\u904e\u5e02\u5834\u9810\u671f\u7684\u589e\u52a020\u842c\u500b\uff1b\u5931\u696d\u7387\u58314.2%\uff0c\u7b26\u5408\u9810\u671f\uff1b\u671f\u5167\u5e73\u5747\u6642\u85aa\u6309\u6708\u589e\u52a00.4%\uff0c\u9810\u671f\u70ba\u589e\u95770.3%\uff1b10\u6708\u975e\u8fb2\u696d\u8077\u4f4d\u589e\u5e45\u5411\u4e0a\u4fee\u8a025.6\u842c\u500b\u3002</p>\n<p>\u5927\u6469\u6307\u51fa\uff0c\u6578\u64da\u4ee4\u904e\u53bb\u4e09\u500b\u6708\u5e73\u5747\u6bcf\u6708\u8077\u4f4d\u589e\u5e45\u4e0a\u5347\u81f317.3\u842c\u500b\uff0c\u9ad8\u65bc\u7b2c\u4e8c\u5b63\u53ca\u7b2c\u4e09\u5b63\u7684\u5e73\u5747\u503c\uff0c\u53cd\u6620\u5c31\u696d\u5e02\u5834\u5f37\u52c1\uff0c\u800c\u5e73\u5747\u6642\u85aa\u5e74\u7387\u5316\u5347\u5e45\u589e\u81f35.5%\uff0c\u6709\u671b\u4ee4\u7b2c\u56db\u5b63\u7684\u6d88\u8cbb\u958b\u652f\u53ca\u7522\u51fa\u4fdd\u6301\u7a69\u5b9a\u589e\u9577\u3002</p>\n<p>\u5927\u6469\u8a8d\u70ba\uff0c\u7121\u8ad6\u662f\u5c31\u696d\u6578\u64da\u6216\u901a\u8139\u6578\u64da\uff0c\u90fd\u53cd\u6620\u806f\u5132\u5c40\u6eab\u548c\u6e1b\u606f\u6b65\u4f10\u4e0d\u5b9c\u6709\u8b8a\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3949304/%E5%A4%A7%E6%91%A9%E7%B6%AD%E6%8C%81%E8%81%AF%E5%84%B2%E5%B1%80%E6%9C%AC%E6%9C%88%E6%B8%9B%E6%81%AF0.25%E5%8E%98%E9%A0%90%E6%B8%AC%E4%B8%8D%E8%AE%8A"}, {"title": "\u4e16\u9280\u7c4c\u96c61000\u5104\u7f8e\u5143\u8cc7\u91d1 \u52a9\u7aae\u570b\u7d13\u56f0", "description": "<p>\u4e16\u754c\u9280\u884c\u516c\u5e03\uff0c\u5df2\u7372\u5f97\u8db3\u5920\u627f\u8afe\uff0c\u4ee4\u5230\u8a72\u8de8\u570b\u6a5f\u69cb\u6709\u80fd\u529b\u65bc\u672a\u4f863\u5e74\uff0c\u5411\u6700\u8ca7\u7aae\u570b\u5bb6\u63d0\u4f9b1000\u5104\u7f8e\u5143\u8cc7\u91d1\u3002\u6b64\u524d\uff0c\u975e\u6d32\u570b\u5bb6\u6566\u4fc3\u5404\u570b\u70ba\u7aae\u570b\u7c4c\u96c61200\u5104\u7f8e\u5143\u8cc7\u91d1\u3002</p>\n<p>\u6839\u64da\u4e16\u9280\u5468\u4e94\u516c\u5e03\u7684\u8072\u660e\uff0c\u5bcc\u88d5\u570b\u5bb6\u540c\u610f\u901a\u904e\u65d7\u4e0b\u570b\u969b\u767c\u5c55\u6a5f\u69cb(IDA)\uff0c\u5411\u6700\u8ca7\u7aae\u570b\u5bb6\u63d0\u4f9b1000\u5104\u7f8e\u5143\u7684\u88dc\u52a9\u6216\u4f4e\u606f\u8cb8\u6b3e\uff0c\u91d1\u984d\u8f03IDA\u4e0a\u4e00\u6b21\u65bc2021\u5e74\u96c6\u8cc7\u7684930\u5104\u7f8e\u5143\u9ad8\u3002</p>\n<p>\u6839\u64da\u8072\u660e\uff0c\u4e00\u4e9b\u570b\u5bb6\u627f\u8afe\u63d0\u4f9b237\u5104\u7f8e\u5143\u6b3e\u9805\uff0c\u8f03\u4e0a\u4e00\u6b21\u7684235\u5104\u7f8e\u5143\u6709\u6240\u589e\u52a0\u3002\u4e16\u9280\u5c07\u901a\u904e\u767c\u50b5\u53ca\u5176\u4ed6\u8ca1\u52d9\u5de5\u5177\uff0c\u4ee4\u5230\u6709\u95dc\u88dc\u52a9\u8207\u4f4e\u606f\u8cb8\u6b3e\u984d\u9054\u52301000\u5104\u7f8e\u5143\u76ee\u6a19\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3949305/%E4%B8%96%E9%8A%80%E7%B1%8C%E9%9B%861000%E5%84%84%E7%BE%8E%E5%85%83%E8%B3%87%E9%87%91+%E5%8A%A9%E7%AA%AE%E5%9C%8B%E7%B4%93%E5%9B%B0"}, {"title": "\u70cf\u8ecd\u9996\u6b21\u7528\u6ce2\u862d\u65b0\u578b\u7121\u4eba\u8247 \u8972\u514b\u91cc\u7c73\u4e9e\u6a4b", "description": "<p>\u64da\u4fc4\u7f85\u65af\u5a92\u9ad4Mash\u5831\u9053\uff0c\u70cf\u514b\u862d\u6b66\u88dd\u90e8\u968a\u5468\u4e94(6\u65e5)\u9996\u6b21\u4f7f\u7528\u6ce2\u862d\u65b0\u578b\u300cGavia\u300d\u6c34\u4e0b\u7121\u4eba\u8247\uff0c\u5411\u514b\u91cc\u7c73\u4e9e\u5927\u6a4b\u767c\u52d5\u653b\u64ca\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u9ed1\u6d77\u8266\u968a\u822a\u7a7a\u5175\u5728\u514b\u91cc\u7c73\u4e9e\u5927\u6a4b\u53ca\u523b\u8d64\u6e2f\u5340\u57df\u5c0d\u7121\u4eba\u8247\u6b98\u9ab8\u9032\u884c\u5206\u6790\u5f8c\u8a8d\u70ba\uff0c\u5176\u4e2d\u90e8\u5206\u6b98\u9ab8\u5c6c\u65bc\u6ce2\u862d\u300cGavia\u300d\u6c34\u4e0b\u7121\u4eba\u8247\uff0c\u9019\u6b3e\u7121\u4eba\u8247\u65bc\u53bb\u5e7411\u6708\u624d\u5728\u6ce2\u862d\u6e2c\u8a66\u5b8c\u6210\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u6b64\u5916\uff0c\u70cf\u514b\u862d\u9084\u51fa\u52d5\u5176\u570b\u7522\u300cMagura -V5\u300d\u548c\u300cSea Baby\u300d\u7121\u4eba\u8247\u3002</span></p>\n<p>\u4fc4\u7f85\u65af\u570b\u9632\u90e8\u6307\u51fa\uff0c\u7576\u5929\u9ed1\u6d77\u8266\u968a\u822a\u7a7a\u5175\u5171\u6467\u6bc08\u8258\u70cf\u8ecd\u7121\u4eba\u8247\u3002\u514b\u91cc\u7c73\u4e9e\u5927\u6a4b\u7ba1\u7406\u90e8\u9580\u7684\u516c\u544a\u986f\u793a\uff0c\u5927\u6a4b\u7684\u516c\u8def\u4ea4\u901a\u66fe\u7d93\u66ab\u505c\u6578\u500b\u5c0f\u6642\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3949303/%E7%83%8F%E8%BB%8D%E9%A6%96%E6%AC%A1%E7%94%A8%E6%B3%A2%E8%98%AD%E6%96%B0%E5%9E%8B%E7%84%A1%E4%BA%BA%E8%89%87+%E8%A5%B2%E5%85%8B%E9%87%8C%E7%B1%B3%E4%BA%9E%E6%A9%8B"}, {"title": "\u8036\u502b\u4fc3\u7279\u6717\u666e\u653f\u5e9c\u52ff\u5f31\u5316\u91d1\u878d\u98a8\u96aa\u76e3\u7ba1", "description": "<p>\u4efb\u671f\u5373\u5c07\u7d50\u675f\u7684\u7f8e\u570b\u8ca1\u9577\u8036\u502b\u8868\u793a\uff0c\u76e3\u7ba1\u91d1\u878d\u98a8\u96aa\u7684\u5de5\u4f5c\u5f88\u91cd\u8981\uff0c\u6566\u4fc3\u4e0b\u6708\u4e0a\u4efb\u7684\u7279\u6717\u666e\u65b0\u653f\u5e9c\u4e0d\u61c9\u5f31\u5316\u898f\u7ba1\u3002</p>\n<p>\u8036\u502b\u6700\u5f8c\u4e00\u6b21\u4e3b\u6301\u91d1\u878d\u7a69\u5b9a\u76e3\u5bdf\u59d4\u54e1\u6703(FSOC)\u6703\u8b70\uff0c\u5979\u5728\u65b0\u805e\u7a3f\u5167\u6279\u8a55\uff0c\u7279\u6717\u666e\u7684\u9996\u500b\u7e3d\u7d71\u4efb\u671f\u5167\uff0cFSOC\u88ab\u5927\u5e45\u6536\u7e2e\u8077\u54e1\u4eba\u6578\u81f3\u53ea\u6709\u500b\u4f4d\u6578\uff0c\u62dc\u767b\u4e0a\u4efb\u5f8c\uff0c\u91cd\u65b0\u589e\u52a0\u8a72\u6a5f\u69cb\u7684\u8cc7\u6e90\uff0c\u4f7f\u5176\u80fd\u6709\u6548\u76e3\u7763\u91d1\u878d\u9ad4\u7cfb\u3002</p>\n<p>\u5019\u4efb\u7e3d\u7d71\u7279\u6717\u666e\u66fe\u7d93\u591a\u6b21\u63d0\u53ca\u8981\u653e\u5bec\u91d1\u878d\u76e3\u7ba1\u5de5\u4f5c\uff0c\u4f46\u672a\u6709\u63d0\u53ca\u5c0dFSOC\u7684\u770b\u6cd5\u3002</p>\n<p>\u6839\u64daFSOC\u5468\u4e94\u767c\u8868\u7684\u5e74\u5ea6\u5831\u544a\uff0c\u5f71\u97ff\u91d1\u878d\u9ad4\u7cfb\u7684\u6f5b\u5728\u98a8\u96aa\u4ecd\u7136\u662f\u5546\u696d\u7269\u696d\u50f9\u503c\u4e0b\u8dcc\u3001\u79c1\u4eba\u4fe1\u8cb8\u696d\u52d9\u84ec\u52c3\u3001\u865b\u64ec\u8ca8\u5e63\u50f9\u683c\u6025\u5347\u7b49\uff0c\u8207\u524d\u4e00\u4efd\u5831\u544a\u76f8\u82e5\u3002\u4e0d\u904e\u5831\u544a\u8a8d\u70ba\uff0c\u98a8\u96aa\u6b63\u5728\u52a0\u91cd\uff0c\u6566\u4fc3\u76e3\u7ba1\u6a5f\u69cb\u53ca\u4f01\u696d\u6ce8\u8996\u6709\u95dc\u56e0\u7d20\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3949301/%E8%80%B6%E5%80%AB%E4%BF%83%E7%89%B9%E6%9C%97%E6%99%AE%E6%94%BF%E5%BA%9C%E5%8B%BF%E5%BC%B1%E5%8C%96%E9%87%91%E8%9E%8D%E9%A2%A8%E9%9A%AA%E7%9B%A3%E7%AE%A1"}, {"title": "\u6052\u6307\u591c\u671f\u6536\u583119821 \u4f4e\u6c3445\u9ede", "description": "<p><span style=\"font-size-ignore:13pt;\">\u6052\u6307\u591c\u5e02\u671f\u6307\u6536\u583119821\u9ede\uff0c\u8dcc112\u9ede\uff0c\u8f03\u6628\u65e5\u6052\u6307\u6536\u5e0219865\u9ede\uff0c\u4f4e\u6c3445\u9ede\uff0c\u6210\u4ea412839\u5f35\u3002</span></p>\n<p>\u570b\u6307\u591c\u5e02\u671f\u6307\u6536\u58317123\u9ede\uff0c\u8f03\u6628\u65e5\u570b\u6307\u6536\u5e02\u4f4e\u6c3414\u9ede\u3002</p>\n<p>\u66f4\u591a\u5373\u5e02\u671f\u6307\u8cc7\u8a0a\uff0c\u8acb\u700f\u89bd\u3008<a href=\"http://stock360.hkej.com/indices/futures/HSI\" target=\"_blank\">\u6e2f\u80a1360</a>\u3009\u671f\u6307\u5c08\u9801</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3949302/%E6%81%92%E6%8C%87%E5%A4%9C%E6%9C%9F%E6%94%B6%E5%A0%B119821+%E4%BD%8E%E6%B0%B445%E9%BB%9E"}, {"title": "\u53e4\u723e\u65af\u6bd4:\u7f8e\u570b\u6574\u9ad4\u5c31\u696d\u5e02\u5834\u4ecd\u7a69\u5065", "description": "<p>\u829d\u52a0\u54e5\u806f\u5132\u9280\u884c\u7e3d\u88c1\u53e4\u723e\u65af\u6bd4(Austan Goolsbee)\u7a31\uff0c\u96d6\u7136\u7f8e\u570b\u5c31\u696d\u6578\u64da\u5c40\u90e8\u8868\u73fe\u504f\u5dee\uff0c\u4f46\u6574\u9ad4\u5c31\u696d\u5e02\u5834\u4ecd\u7136\u7a69\u5065\u3002</p>\n<p>\u53e4\u723e\u65af\u6bd4\u5728\u51fa\u5e2d\u6d3b\u52d5\u56de\u61c9\u63d0\u554f\u6642\u6307\u51fa\uff0c\u8fd1\u6578\u6708\u7684\u5e73\u5747\u65b0\u589e\u975e\u8fb2\u696d\u8077\u4f4d\u6578\u91cf\u76f8\u5c0d\u7a69\u5b9a\uff0c\u986f\u793a\u5145\u5206\u5c31\u696d\u7684\u5fb5\u5146\u3002</p>\n<p>\u53e4\u723e\u65af\u6bd4\u660e\u5e74\u624d\u5728\u806f\u90a6\u516c\u958b\u5e02\u5834\u59d4\u54e1\u6703(FOMC)\u64c1\u6709\u8ca8\u5e63\u653f\u7b56\u6295\u7968\u6b0a\uff0c\u4ed6\u672a\u56de\u61c9\u662f\u5426\u652f\u6301FOMC\u672c\u6708\u8b70\u606f\u6703\u8b70\u4f5c\u51fa\u6e1b\u606f\u6c7a\u5b9a\uff0c\u91cd\u7533\u5176\u4e00\u8cab\u770b\u6cd5\uff0c\u5373\u4e00\u5e74\u5f8c\u7684\u806f\u90a6\u57fa\u91d1\u5229\u7387\u5c07\u986f\u8457\u4f4e\u65bc\u73fe\u6c34\u5e73\u3002</p>\n<p>\u53e4\u723e\u65af\u6bd4\u8a8d\u70ba\uff0c\u5982\u679cFOMC\u505c\u6b62\u8fd1\u6708\u4f86\u7684\u6e1b\u606f\u6b65\u4f10\uff0c\u9810\u6599\u662f\u56e0\u70ba\u901a\u8139\u8207\u5c31\u696d\u6578\u64da\u51fa\u73fe\u8b8a\u5316\u3002\u4f46\u4ed6\u8a8d\u70ba\u901a\u8139\u8d70\u52e2\u4ee4\u4eba\u9f13\u821e\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3949299/%E5%8F%A4%E7%88%BE%E6%96%AF%E6%AF%94%3A%E7%BE%8E%E5%9C%8B%E6%95%B4%E9%AB%94%E5%B0%B1%E6%A5%AD%E5%B8%82%E5%A0%B4%E4%BB%8D%E7%A9%A9%E5%81%A5"}]}