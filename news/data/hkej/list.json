143\uff1b\u5e74\u5ea6\u7d93\u8abf\u6574\u5f8c\u6bcf\u80a1\u76c8\u5229\u5340\u9593\u9810\u6599\u4ecb\u4e4e9.98\u81f310.03\u5143\uff0c\u9810\u671f\u70ba10.11\u5143\uff1b\u7b2c\u56db\u5b63\u6bcf\u80a1\u76c8\u5229\u9810\u6599\u4ecb\u4e4e2.57\u81f32.62\u5143\uff0c\u9810\u671f\u70ba2.65\u5143\uff1b\u7b2c\u56db\u5b63\u6536\u5165\u9810\u6599\u4ecb\u4e4e99\u5104\u81f3101\u5104\u5143\uff0c\u9810\u671f\u70ba105\u5104\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3945535/Salesforce%E4%B8%8A%E5%AD%A3%E6%94%B6%E5%85%A5%E5%8B%9D%E9%A0%90%E6%9C%9F+%E8%AA%BF%E9%AB%98%E5%B9%B4%E5%BA%A6%E4%BC%B0%E8%A8%88"}, {"title": "\u4e2d\u6771\u5c40\u52e2\u8f49\u8da8\u7dca\u5f35 \u570b\u969b\u6cb9\u50f9\u5347\u903e2%", "description": "<p>\u4ee5\u8272\u5217\u5a01\u8105\u53d6\u6d88\u8207\u9ece\u5df4\u5ae9\u7c3d\u5b9a\u7684\u505c\u706b\u5354\u8b70\uff0c\u52a0\u4e0a\u5e02\u5834\u63e3\u6e2c\u77f3\u6cb9\u51fa\u53e3\u570b\u7d44\u7e54\u53ca\u76df\u53cb(OPEC+)\u5c07\u62bc\u5f8c\u589e\u7522\u8a08\u5283\uff0c\u570b\u969b\u6cb9\u50f9\u5468\u4e8c\u5347\u903e2%\uff0c\u5275\u4e0b\u5169\u5468\u4f86\u6700\u5927\u55ae\u65e5\u5347\u5e45\u3002</p>\n<p>\u7d10\u7d04\u671f\u6cb9\u6536\u5e02\u53471.84\u7f8e\u5143\u62162.7%\uff0c\u6bcf\u6876\u583169.94\u7f8e\u5143\u3002\u502b\u6566\u5e03\u862d\u7279\u671f\u6cb9\u6536\u5e02\u53471.79\u7f8e\u5143\u62162.49%\uff0c\u6bcf\u6876\u583173.62\u7f8e\u5143\u3002</p>\n<p>\u8f03\u65e9\u6642\uff0c\u4ee5\u8272\u5217\u8ecd\u65b9\u6307\u6458\u9ece\u5df4\u5ae9\u771f\u4e3b\u9ee8\u9055\u53cd\u505c\u706b\u5354\u8b70\uff0c\u56e0\u6b64\u5c0d\u771f\u4e3b\u9ee8\u6b66\u88dd\u6c11\u5175\u767c\u52d5\u653b\u64ca\u3002\u9ece\u5df4\u5ae9\u6566\u4fc3\u7f8e\u570b\u53ca\u6cd5\u570b\u963b\u6b62\u4ee5\u8272\u5217\u8ecd\u968a\u7684\u653b\u64ca\u884c\u52d5\u3002</p>\n<p>\u745e\u9280\u5206\u6790\u54e1Giovanni Staunovo\u6307\u51fa\uff0c\u4e2d\u6771\u5c40\u52e2\u53ef\u80fd\u518d\u5ea6\u60e1\u5316\uff0c\u727d\u52d5\u6cb9\u50f9\u4e0a\u63da\u3002</p>\n<p>\u53e6\u5916\uff0cOPEC+\u5468\u56db\u8209\u884c\u7db2\u4e0a\u90e8\u9577\u7d1a\u6703\u8b70\u524d\u5915\uff0c\u5e02\u5834\u7e7c\u7e8c\u50b3\u51faOPEC+\u62bc\u5f8c3\u500b\u6708\u589e\u7522\uff0c\u6d88\u606f\u540c\u6a23\u5229\u597d\u6cb9\u50f9\u3002\u9ad8\u76db\u4e5f\u9810\u671f\uff0cOPEC+\u5c07\u6703\u62bc\u5f8c\u589e\u7522\u6642\u95933\u500b\u6708\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3945533/%E4%B8%AD%E6%9D%B1%E5%B1%80%E5%8B%A2%E8%BD%89%E8%B6%A8%E7%B7%8A%E5%BC%B5+%E5%9C%8B%E9%9A%9B%E6%B2%B9%E5%83%B9%E5%8D%87%E9%80%BE2%25"}, {"title": "\u9632\u4e2d\u570b\u9ed1\u5ba2\u5165\u4fb5 \u7f8e\u5b98\u54e1\u4fc3\u6c11\u773e\u52a0\u5bc6\u500b\u4eba\u8a0a\u606f", "description": "<p>\u4e3b\u7ba1\u7db2\u7d61\u8207\u57fa\u5efa\u5b89\u5168\u7684\u7f8e\u570b\u653f\u5e9c\u5b98\u54e1\u683c\u6797(Jeff Greene)\u8868\u793a\uff0c\u7f8e\u570b\u6c11\u773e\u8981\u5c07\u500b\u4eba\u8a0a\u606f\u52a0\u5bc6\uff0c\u4ee5\u9632\u6b62\u4e2d\u570b\u9ed1\u5ba2\u901a\u904e\u5165\u4fb5\u7f8e\u570b\u96fb\u8a0a\u71df\u904b\u5546\u7cfb\u7d71\u800c\u53d6\u5f97\u6c11\u773e\u7684\u8cc7\u6599\u3002</p>\n<p>\u7f8e\u570b\u653f\u5e9c\u5468\u4e8c\u8209\u884c\u8a18\u8005\u6703\uff0c\u5c0d\u7f8e\u570b\u96fb\u8a0a\u5546\u9632\u6b62\u9ed1\u5ba2\u5165\u4fb5\u63d0\u51fa\u65b0\u6307\u5f15\u3002\u83ef\u5e9c\u5b98\u54e1\u6307\u7a31\uff0c\u4e2d\u570b\u9ed1\u5ba2\u5165\u4fb5\u7f8e\u570b\u96fb\u8a0a\u5546\u7cfb\u7d71\u60c5\u6cc1\u8d8a\u4f86\u8d8a\u56b4\u91cd\u3002\u4e2d\u570b\u653f\u5e9c\u5426\u8a8d\u6709\u95dc\u6307\u7a31\uff0c\u8868\u793a\u6beb\u7121\u6839\u64da\u3002</p>\n<p>\u683c\u6797\u7a31\uff0c\u96e3\u4ee5\u4f30\u8a08\u9ed1\u5ba2\u5c0d\u7f8e\u570b\u96fb\u8a0a\u57fa\u5efa\u7684\u5165\u4fb5\u80fd\u529b\u53ca\u4f55\u6642\u53d6\u5f97\u7528\u6236\u8cc7\u6599\uff0c\u6c11\u773e\u53ef\u4ee5\u505a\u7684\u4e8b\u60c5\u662f\u4e0d\u8981\u901a\u904e\u96fb\u8a0a\u516c\u53f8\u767c\u5e03\u6587\u5b57\u8a0a\u606f\uff0c\u4e26\u4e14\u8981\u5b78\u7fd2\u628a\u8a0a\u606f\u9032\u884c\u591a\u91cd\u52a0\u5bc6\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3945531/%E9%98%B2%E4%B8%AD%E5%9C%8B%E9%BB%91%E5%AE%A2%E5%85%A5%E4%BE%B5+%E7%BE%8E%E5%AE%98%E5%93%A1%E4%BF%83%E6%B0%91%E7%9C%BE%E5%8A%A0%E5%AF%86%E5%80%8B%E4%BA%BA%E8%A8%8A%E6%81%AF"}, {"title": "\u860b\u679c\u4f7f\u7528\u4e9e\u99ac\u905c\u6676\u7247\u8a13\u7df4AI\u6a21\u578b", "description": "<p>\u96fb\u5546\u5de8\u64d8\u4e9e\u99ac\u905c\u5728\u5e74\u5ea6\u96f2\u670d\u52d9AWS\u5927\u6703\u4e0a\u5ba3\u5e03\uff0c\u63a8\u51fa\u4eba\u5de5\u667a\u80fd(AI)\u65b0\u5e73\u53f0\u3002\u540c\u6642\uff0c\u860b\u679c\u4e5f\u5728AWS\u5927\u6703\u671f\u9593\u5ba3\u5e03\uff0c\u63a1\u7528\u4e9e\u99ac\u905c\u7814\u767c\u7684\u5ba2\u6236\u5c08\u7528AI\u6676\u7247\u3002</p>\n<p>\u4e9e\u99ac\u905c\u884c\u653f\u7e3d\u88c1\u8cc8\u897f(Andy Jassy)\u7a31\uff0c\u96c6\u5718\u958b\u767c\u7684AI\u6a21\u578bNova\u53ef\u4ee5\u8b93\u5ba2\u6236\u7372\u5f97\u66f4\u4f73\u9ad4\u9a57\u3002</p>\n<p>\u516c\u53f8\u7a31\uff0c\u77ed\u7247\u88fd\u4f5c\u5de5\u5177Nova Reel\u5c07\u6709\u52a9\u7db2\u6c11\u66f4\u4fbf\u5229\u5730\u3001\u5236\u4f5c\u5728\u4e9e\u99ac\u905c\u5e73\u53f0\u64ad\u653e\u7684\u5546\u54c1\u63a8\u4ecb\u77ed\u7247\u3002</p>\n<p>\u53e6\u5916\u5728AWS\u5e74\u6703\u671f\u9593\uff0c\u860b\u679c\u9ad8\u5c64Benoit Dupin\u62ab\u9732\uff0c\u6b63\u4f7f\u7528\u4e9e\u99ac\u905c\u958b\u767c\u7684AI\u6676\u7247\uff0c\u4ee5\u4f5c\u70ba\u5305\u62ecApple Intelligence\u5728\u5167\u7684AI\u6a21\u578b\u8a13\u7df4\u5de5\u4f5c\u3002</p>\n<p>Dupin\u7a31\uff0c\u4f7f\u7528\u4e9e\u99ac\u905c\u7684AI\u6676\u7247\u6548\u7387\u53ef\u63d0\u534740%\u3002\u860b\u679c\u8207\u4e9e\u99ac\u905c\u95dc\u4fc2\u4e00\u8cab\u5bc6\u5207\uff0c\u5305\u62ec\u4f7f\u7528AWS\u96f2\u670d\u52d9\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3945530/%E8%98%8B%E6%9E%9C%E4%BD%BF%E7%94%A8%E4%BA%9E%E9%A6%AC%E9%81%9C%E6%99%B6%E7%89%87%E8%A8%93%E7%B7%B4AI%E6%A8%A1%E5%9E%8B"}, {"title": "\u767c\u5c55\u4e2d\u570b\u5bb6\u53bb\u5e74\u50b5\u52d9\u958b\u652f\u5275\u65b0\u9ad8\u783410\u842c\u5104", "description": "<p>\u4e16\u754c\u9280\u884c\u6700\u65b0\u5831\u544a\u7a31\uff0c\u767c\u5c55\u4e2d\u570b\u5bb6\u53bb\u5e74\u82b1\u8cbb1.4\u842c\u5104\u7f8e\u5143(10.92\u842c\u5104\u6e2f\u5143)\u8cc7\u91d1\uff0c\u4ee5\u61c9\u4ed8\u50b5\u52d9\u76f8\u95dc\u670d\u52d9\u958b\u652f\uff0c\u91d1\u984d\u5275\u4e0b\u7d00\u9304\u65b0\u9ad8\uff0c\u4ee4\u5230\u9019\u4e9b\u570b\u5bb6\u82b1\u5728\u91ab\u7642\u3001\u6559\u80b2\u53ca\u74b0\u4fdd\u7684\u9810\u7b97\u958b\u652f\u53d7\u5230\u5f88\u5927\u5236\u8098\u3002</p>\n<p>\u6839\u64da\u4e16\u9280\u7684\u570b\u969b\u50b5\u52d9\u5831\u544a\uff0c\u767c\u5c55\u4e2d\u570b\u5bb6\u53bb\u5e74\u7528\u65bc\u511f\u9084\u5916\u50b5\u7684\u5229\u606f\u958b\u652f\u589e\u81f34060\u5104\u7f8e\u5143\uff0c\u5176\u4e2d962\u5104\u7f8e\u5143\u652f\u4ed8\u4e88\u4e16\u9280\u65d7\u4e0b\u570b\u969b\u767c\u5c55\u7d44\u7e54(International Development Association\uff0cIDA)\u3002\u671f\u5167\uff0c\u8a72\u7b49\u570b\u5bb6\u5411IDA\u511f\u9084\u7684\u672c\u91d1\u5df2\u6e1b\u5c118%\u81f3616\u5104\u7f8e\u5143\uff0c\u5229\u606f\u5247\u5275\u7d00\u9304\u65b0\u9ad8\u9054\u5230346\u5104\u7f8e\u5143\u3002</p>\n<p>\u5831\u544a\u7a31\uff0c\u5408\u8cc7\u683c\u5411IDA\u8cb8\u6b3e\u7684\u570b\u5bb6\u53bb\u5e74\u5e73\u5747\u5c07\u76f8\u7576\u65bc\u51fa\u53e3\u6536\u5165\u76846%\u7528\u65bc\u511f\u9084\u5916\u50b5\uff0c\u6bd4\u7387\u662f1999\u5e74\u4ee5\u4f86\u6700\u9ad8\uff0c\u90e8\u5206\u570b\u5bb6\u7684\u6bd4\u7387\u66f4\u905438%\u3002\u767c\u5c55\u4e2d\u570b\u5bb6\u622a\u81f3\u53bb\u5e74\u5e95\u6b62\u7684\u7e3d\u5916\u50b5\u70ba8.8\u842c\u5104\u7f8e\u5143\uff0c\u8f032020\u5e74\u53478%\u3002</p>\n<p>\u53e6\u5916\uff0c\u570b\u969b\u91d1\u878d\u5354\u6703(The Institute of International Finance\uff0cIIF)\u516c\u5e03\uff0c\u5168\u7403\u570b\u5bb6\u7684\u7e3d\u50b5\u52d9\u5728\u4eca\u5e74\u9996\u4e09\u5b63\u4e0a\u534712\u842c\u5104\u7f8e\u5143\uff0c\u7d2f\u8a08\u91d1\u984d\u9054\u5230323\u842c\u5104\u7f8e\u5143\uff0c\u5275\u4e0b\u7d00\u9304\u65b0\u9ad8\u3002</p>\n<p>IIF\u4f30\u8a08\uff0c\u5018\u82e5\u5404\u570b\u4e0d\u9650\u5236\u8ca1\u8d64\u589e\u9577\uff0c\u52302028\u5e74\uff0c\u5168\u7403\u570b\u5bb6\u7e3d\u50b5\u52d9\u5c07\u518d\u589e\u52a0\u4e09\u5206\u4e4b\u4e00\u6216130\u842c\u5104\u7f8e\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3945528/%E7%99%BC%E5%B1%95%E4%B8%AD%E5%9C%8B%E5%AE%B6%E5%8E%BB%E5%B9%B4%E5%82%B5%E5%8B%99%E9%96%8B%E6%94%AF%E5%89%B5%E6%96%B0%E9%AB%98%E7%A0%B410%E8%90%AC%E5%84%84"}, {"title": "\u82f1\u570b\u7528\u6236\u6307\u6536\u8cbb\u904e\u9ad8 Mastercard\u9054\u548c\u89e3", "description": "<p>\u5168\u7403\u4e3b\u8981\u767c\u5361\u5546\u842c\u4e8b\u9054\u5361(Mastercard)\u8207\u82f1\u570b\u4e00\u6279\u6d88\u8cbb\u8005<span style=\"font-size-ignore:13pt;\">\u9054\u6210\u548c\u89e3\u5354\u8b70\uff0c\u89e3\u6c7a\u7576\u5730\u4e00\u5b97\u8207\u6536\u8cbb\u76f8\u95dc\u7684\u96c6\u9ad4\u8a34\u8a1f\u3002</span></p>\n<p>\u9019\u662f\u82f1\u570b\u81ea2021\u5e74\u4ee5\u4f86\u9996\u5b97\u7372\u5f97\u6279\u51c6\u7684\u96c6\u9ad4\u8a34\u8a1f\u3002\u96d9\u65b9\u6c92\u6709\u63d0\u53ca\u548c\u89e3\u8cbb\uff0c\u4f46\u8def\u900f\u5f15\u8ff0\u6d88\u606f\u4eba\u58eb\u7a31\uff0cMastercard\u540c\u610f\u652f\u4ed82\u5104\u82f1\u938a(19.76\u5104\u6e2f\u5143)\u6b3e\u9805\uff0c\u4ee5\u7d50\u675f\u6709\u95dc\u8a34\u8a1f\u3002</p>\n<p>Walter Merricks\u4ee3\u88684600\u842c\u540d\u82f1\u570b\u6210\u5e74\u6d88\u8cbb\u8005\u65bc5\u5e74\u524d\u63d0\u51fa\u8a34\u8a1f\uff0c\u6307Mastercard\u6536\u8cbb\u4e0d\u5408\u7406\uff0c\u4ee4\u5230\u6d88\u8cbb\u8005\u984d\u5916\u652f\u4ed8\u5de8\u984d\u8cbb\u7528\uff0c\u56e0\u6b64\u8981\u6c42\u5176\u9000\u9084\u591a\u6536\u7684\u8cbb\u7528\u3002\u4eca\u5e7410\u6708\uff0c\u82f1\u570b\u7af6\u722d\u4e0a\u8a34\u5c40(CAT)\u88c1\u5b9aMastercard\u591a\u6536\u82f1\u570b\u6d88\u8cbb\u800510\u5104\u82f1\u938a\u5f8c\uff0cMastercard\u4e0a\u8a34\u81f3\u82f1\u570b\u6700\u9ad8\u6cd5\u9662\uff0c\u6848\u4ef6\u6392\u671f\u8046\u8a0a\u3002</p>\n<p>Mastercard\u5468\u4e8c\u7a31\uff0c\u8207Merricks\u9054\u6210\u539f\u5247\u6027\u7684\u548c\u89e3\u5354\u8b70\uff0c\u5354\u8b70\u4ecd\u5f85CAT\u6279\u51c6\u5f8c\u65b9\u624d\u751f\u6548\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3945527/%E8%8B%B1%E5%9C%8B%E7%94%A8%E6%88%B6%E6%8C%87%E6%94%B6%E8%B2%BB%E9%81%8E%E9%AB%98+Mastercard%E9%81%94%E5%92%8C%E8%A7%A3"}, {"title": "\u5357\u97d3\u7e3d\u7d71\u5c39\u932b\u6085\u5ba3\u5e03\u5c07\u89e3\u9664\u6212\u56b4\u4ee4", "description": "<p>\u5357\u97d3\u7e3d\u7d71\u5c39\u932b\u6085\u5468\u4e09\u51cc\u6668\u518d\u6b21\u767c\u8868\u8b1b\u8a71\uff0c\u8868\u793a\u5c0a\u91cd\u570b\u6703\u610f\u898b\uff0c\u64a4\u51fa\u6212\u56b4\u8ecd\u968a\uff0c\u4e26\u5c07\u53ec\u958b\u570b\u52d9\u6703\u8b70\u89e3\u9664\u6212\u56b4\u4ee4\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3945529/%E5%8D%97%E9%9F%93%E7%B8%BD%E7%B5%B1%E5%B0%B9%E9%8C%AB%E6%82%85%E5%AE%A3%E5%B8%83%E5%B0%87%E8%A7%A3%E9%99%A4%E6%88%92%E5%9A%B4%E4%BB%A4"}]}