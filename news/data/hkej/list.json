b\u52d5\u6c42\u8b8a\uff0c\u5805\u5b9a\u652f\u6301\u884c\u653f\u9577\u5b98\u548c\u7279\u5340\u653f\u5e9c\u4f9d\u6cd5\u65bd\u653f\uff0c\u5728\u63a8\u52d5\u9999\u6e2f\u7531\u6cbb\u53ca\u8208\u4e2d\u767c\u63ee\u66f4\u5927\u4f5c\u7528\uff0c\u70ba\u4ee5\u4e2d\u570b\u5f0f\u73fe\u4ee3\u5316\u5168\u9762\u63a8\u9032\u5f37\u570b\u5efa\u8a2d\u3001\u6c11\u65cf\u5fa9\u8208\u5049\u696d\u4f5c\u51fa\u65b0\u7684\u66f4\u5927\u8ca2\u737b\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3905651/%E5%A4%8F%E5%AF%B6%E9%BE%8D%E5%86%80%E5%B0%88%E6%A5%AD%E4%BA%BA%E5%A3%AB%E7%BA%8C%E8%81%9A%E7%84%A6%E5%9C%8B%E5%AE%B6%E6%89%80%E9%9C%80%E9%A6%99%E6%B8%AF%E6%89%80%E9%95%B7+%E7%B7%8A%E8%B7%9F%E6%99%82%E4%BB%A3%E6%AD%A5%E4%BC%90"}, {"title": "\u6e23\u7538\u5c71\u7368\u7acb\u5927\u5c4b\u610f\u5411\u50f92.3\u5104", "description": "<p>\u4ef2\u91cf\u806f\u884c\u4ee5\u516c\u958b\u9080\u8acb\u610f\u5411\u5f62\u5f0f\u51fa\u552e\u6e23\u7538\u5c71\u7562\u62c9\u5c71\u5f9150\u865f\u91d1\u78a7\u5712\u4e00\u5e62\u7368\u7acb\u5927\u5c4b\uff0c\u7269\u696d\u610f\u5411\u50f9\u7d042.3\u5104\u5143\uff0c\u8f03\u4f30\u503c\u4f4e\uff0c\u5c07\u65bc\u4eca\u5e7411\u67088\u65e5\u4e2d\u534812\u6642\u6b63\u622a\u6536\u610f\u5411\u3002</p>\n<p>\u4e0a\u8ff0\u7269\u696d\u6a13\u9ad8\u4e09\u5c64\uff0c\u4f54\u5730\u7d044999\u65b9\u544e\uff0c\u5be6\u7528\u9762\u7a4d\u7d043669.4\u65b9\u544e\uff0c\u70ba5\u623f4\u5957\u623f\u8a2d\u8a08\uff0c\u66f4\u9644\u8a2d\u7d044000\u591a\u65b9\u544e\u7684\u79c1\u4eba\u82b1\u5712\u53ca\u6cf3\u6c60\uff1b\u540c\u6642\uff0c\u914d\u5099\u79c1\u4eba\u96fb\u68af\u53ca\u7279\u5927\u96d9\u8eca\u4f4d\u8eca\u623f\u3002</p>\n<p>\u7269\u696d\u5c07\u4ee5\u300c\u73fe\u72c0\u300d\u53ca\u4ea4\u5409\u5f62\u5f0f\u51fa\u552e\uff0c\u4e26\u53ef\u4ee5\u516c\u53f8\u80a1\u6b0a\u8f49\u8b93\u6216\u7269\u696d\u4ea4\u6613\u65b9\u5f0f\u9032\u884c\u8cb7\u8ce3\u3002</p>\n<p>\u4ef2\u91cf\u806f\u884c\u8cc7\u672c\u5e02\u5834\u90e8\u57f7\u884c\u8463\u4e8b\u9127\u6f54\u7469\u8868\u793a\uff0c\u662f\u6b21\u653e\u552e\u7684\u6e23\u7538\u5c71\u7368\u7acb\u5c4b\u5c6c\u8d85\u7d1a\u8c6a\u5b85\u76e4\uff0c\u696d\u4e3b\u60dc\u552e\uff0c\u5e02\u5834\u76e4\u6e90\u91cf\u5c11\u73cd\u7f55\uff0c\u800c\u4e14\u5730\u7406\u4f4d\u7f6e\u512a\u8d8a\uff0c\u5750\u64c1\u6e23\u7538\u5c71\u7fe0\u7dd1\u7f8e\u666f\uff0c\u6295\u8cc7\u81ea\u4f4f\u5169\u76f8\u5b9c\u3002<br /><br /></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3905575/%E6%B8%A3%E7%94%B8%E5%B1%B1%E7%8D%A8%E7%AB%8B%E5%A4%A7%E5%B1%8B%E6%84%8F%E5%90%91%E5%83%B92.3%E5%84%84"}, {"title": "\u65bd\u653f\u5831\u544a\u4e28\u7c21\u6a38\u623f\u53d6\u66ff\u528f\u623f \u653f\u5e9c\u4eca\u5e74\u5e95\u8d77\u8aee\u8a62\u722d\u53d6\u660e\u5e74\u901a\u904e\u6cd5\u4f8b", "description": "<p><span style=\"font-size-ignore:13pt;\">\u300a\u65bd\u653f\u5831\u544a\u300b\u63d0\u51fa\u7acb\u6cd5\u53d6\u7de0\u52a3\u8cea\u528f\u623f\uff0c\u653f\u5e9c\u8a08\u5283\u4eca\u5e7412\u6708\u81f3\u660e\u5e742\u6708\u5c55\u958b\u8aee\u8a62\uff0c\u722d\u53d6\u660e\u5e74\u901a\u904e\u6cd5\u4f8b\uff0c\u9810\u6599\u5728\u660e\u5e74\u7b2c4\u5b63\u5c55\u958b1\u5e74\u81f31\u5e74\u534a\u7684\u767b\u8a18\u671f\uff0c\u4e0d\u5408\u6a19\u6e96\u7684\u528f\u623f\u55ae\u4f4d\u6709\u6700\u591a2\u5e74\u7684\u5bec\u9650\u671f\uff0c\u6539\u5efa\u6210\u7b26\u5408\u6a19\u6e96\u7684\u300c\u7c21\u6a38\u623f\u300d\u3002</span></p>\n<p>\u653f\u5e9c\u516c\u5e03\u66f4\u591a\u300c\u7c21\u6a38\u623f\u300d\u7684\u7d30\u7bc0\uff0c\u5305\u62ec\u55ae\u4f4d\u9762\u7a4d\u4e0d\u5c11\u65bc8\u5e73\u65b9\u7c73\u3001\u6a13\u5e95\u7531\u6a13\u9762\u91cf\u5ea6\u81f3\u5929\u82b1\u4e0d\u5c11\u65bc2.3\u7c73\uff1b\u6d88\u9632\u5b89\u5168\u8981\u6c42\u8a2d\u8db3\u5920\u95ca\u5ea6\u7684\u8d70\u5eca\u3001\u9632\u706b\u9580\u53ca\u7368\u7acb\u706b\u8b66\u5075\u6e2c\u5668\u7b49\uff1b\u7d50\u69cb\u8981\u6c42\u9593\u9694\u7684\u78da\u7246\u4e0d\u53ef\u81f4\u6a13\u5b87\u7d50\u69cb\u8ca0\u8377\u8d85\u91cd\u3002\u53e6\u5916\u8981\u6c42\u55ae\u4f4d\u6709\u81f3\u5c11\u4e00\u6247\u53ef\u958b\u555f\u7684\u7a97\u6236\u3001\u7368\u7acb\u6d17\u624b\u9593\u5bb9\u8a31\u300c\u9ed1\u5ec1\u300d\uff0c\u4f46\u5747\u9700\u8a2d\u6a5f\u68b0\u901a\u98a8\u8a2d\u65bd\uff1b\u53c8\u8981\u6c42\u4e0d\u53ef\u4f7f\u7528\u660e\u706b\u716e\u98df\u8a2d\u5099\u4e26\u8a2d\u7368\u7acb\u6c34\u9336\u53ca\u96fb\u9336\u7b49\u3002</p>\n<p>\u8ca1\u653f\u53f8\u526f\u53f8\u9577\u9ec3\u5049\u7db8\u88ab\u554f\u53ca\u300c\u7c21\u6a38\u623f\u300d\u540d\u7a31\u7684\u7531\u4f86\u6642\u8868\u793a\uff0c\u528f\u623f\u7684\u8ca0\u9762\u610f\u7fa9\u592a\u91cd\uff0c\u300c\u7c21\u6a38\u623f\u300d\u5373\u7c21\u55ae\u3001\u6a38\u5be6\uff0c\u6070\u7576\u53cd\u6620\u8a08\u5283\u7cbe\u9ad3\uff0c\u65e5\u5f8c\u7684\u300c\u7c21\u6a38\u623f\u300d\u662f\u7d93\u8a8d\u8b49\u7684\u55ae\u4f4d\uff0c\u7b26\u5408\u8981\u6c42\u6a19\u6e96\u3002</p>\n<p>\u5c0d\u65bc\u55ae\u4f4d\u9700\u8981\u6539\u52d5\u5f8c\u7684\u79df\u91d1\u6c34\u5e73\uff0c\u9ec3\u5049\u7db8\u8868\u793a\uff0c\u4e3b\u8981\u6d89\u53ca\u5e02\u5834\u4e0a\u7684\u4f9b\u6c42\u95dc\u4fc2\uff0c\u4e26\u975e\u4e00\u6b21\u6027\u7684\u958b\u92b7\u3002\u4ed6\u6307\u51fa\uff0c\u9810\u8a08\u5c07\u4f86\u6709\u4e03\u6210\u5206\u9593\u55ae\u4f4d\u53ef\u671b\u9054\u6a19\uff0c\u5373\u7d047\u842c\u591a\u500b\u55ae\u4f4d\uff0c\u81f3\u65bc\u9918\u4e0b\u4e09\u6210\u76ee\u524d\u76f8\u4fe1\u4e0d\u9054\u6a19\uff0c\u4f46\u7d93\u6539\u52d5\u4ea6\u6709\u671b\u9054\u6a19\uff0c\u8996\u4e4e\u696d\u4e3b\u60c5\u6cc1\u3002</p>\n<p>\u9ec3\u5049\u7db8\u8868\u793a\uff0c\u7576\u6cd5\u4f8b\u65e5\u5f8c\u5be6\u65bd\u5f8c\uff0c\u5982\u5206\u9593\u55ae\u4f4d\u4e26\u7121\u7372\u8a8d\u53ef\uff0c\u4f46\u696d\u4e3b\u7e7c\u7e8c\u7d93\u71df\uff0c\u696d\u4e3b\u8981\u627f\u64d4\u5211\u4e8b\u8cac\u4efb\uff0c\u4e0d\u53ea\u8981\u7f70\u6b3e\uff0c\u4ea6\u8981\u76e3\u7981\uff0c\u5211\u4e8b\u8cac\u4efb\u4e0d\u7528\u79df\u6236\u627f\u64d4\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3905637/%E6%96%BD%E6%94%BF%E5%A0%B1%E5%91%8A%E4%B8%A8%E7%B0%A1%E6%A8%B8%E6%88%BF%E5%8F%96%E6%9B%BF%E5%8A%8F%E6%88%BF+%E6%94%BF%E5%BA%9C%E4%BB%8A%E5%B9%B4%E5%BA%95%E8%B5%B7%E8%AB%AE%E8%A9%A2%E7%88%AD%E5%8F%96%E6%98%8E%E5%B9%B4%E9%80%9A%E9%81%8E%E6%B3%95%E4%BE%8B"}]}