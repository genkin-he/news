96\u7f6e\u4eba\u58eb\uff0c\u5fc3\u5100\u55ae\u4f4d\u50f9\u9322\u76f8\u5b9c\uff0c\u6545\u7747\u6a131\u6b21\u5f8c\u6c7a\u5b9a\u62cd\u677f\u5165\u5e02\u3002</p>\n<p>\u9999\u6e2f\u7f6e\u696d\u8868\u793a\uff0c\u539f\u696d\u4e3b\u65bc2018\u5e749\u6708\u4ee5781.5\u842c\u5143\u8cfc\u5165\u4e0a\u8ff0\u55ae\u4f4d\uff0c\u662f\u6b21\u6613\u624b\uff0c\u8cec\u9762\u8667\u640d\u7d04132.7\u842c\u5143\u621617%\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3910358/%E5%8C%AF%E7%92%BD%E4%BD%8E%E5%B1%A4%E4%B8%80%E6%88%BF%E8%9D%95132%E8%90%AC%E6%89%BF%E6%8E%A5"}, {"title": "\u6d77\u6d0b\u516c\u5712\u6b77\u96aa\u4e3b\u984c\u5340\u65992028\u5e74\u958b\u653e \u5c07\u5efa\u5de8\u578b\u98db\u7d22\u53ca\u7b28\u8c6c\u8df3\u7b49", "description": "<p>\u6d77\u6d0b\u516c\u5712\u8207\u4fe1\u5fb7\u96c6\u5718\u53caAJ Hackett International\u96c6\u5718\u6240\u5408\u7d44\u4e4b\u8ca1\u5718\u651c\u624b\u5408\u4f5c\uff0c\u767c\u5c55\u6d77\u6d0b\u516c\u5712\u6b77\u96aa\u4e3b\u984c\u5712\u5340\u3002\u5168\u65b0\u7684\u6b77\u96aa\u4e3b\u984c\u5340\u662f\u6d77\u6d0b\u516c\u5712\u672a\u4f86\u767c\u5c55\u7b56\u7565\u7576\u4e2d\u7684\u91cd\u8981\u4e00\u74b0\u3002\u6b77\u96aa\u4e3b\u984c\u5712\u9810\u8a08\u65bc2028\u5e74\u958b\u653e\u4e88\u516c\u773e\uff0c\u8a2a\u5ba2\u5c07\u53ef\u53e6\u8cfc\u9580\u7968\u9ad4\u9a57\u9019\u500b\u65b0\u5712\u5340\u3002</p>\n<p>\u6b77\u96aa\u4e3b\u984c\u5340\u4f4d\u65bc\u5c71\u4e0a\u9ad8\u5cf0\u6a02\u5712\u90e8\u5206\u81e8\u6d77\u5c71\u5dba\u5730\u6bb5\uff0c\u5712\u5340\u4f54\u5730\u7d0412\u842c\u5e73\u65b9\u7c73\uff0c\u662f\u5df2\u9000\u5f79\u7684\u7d93\u5178\u904a\u6a02\u8a2d\u65bd\u300c\u6ed1\u6d6a\u98db\u8239\u300d\u548c\u300c\u8d8a\u7926\u98db\u8eca\u300d\u7684\u820a\u5740\u3002\u6d77\u6d0b\u516c\u5712\u8868\u793a\uff0c\u5728\u6614\u65e5\u7684\u300c\u7f8e\u98df\u822b\u300d\u4f4d\u7f6e\u5c07\u8a2d\u6709\u5169\u689d\u5de8\u578b\u98db\u7d22(Ziplnes)\uff0c\u6bcf\u689d\u6ed1\u7d22\u9577\u7d041000\u7c73\uff0c\u8b93\u8a2a\u5ba2\u98fd\u89bd\u9999\u6e2f\u4ed4\u6d77\u5cfd\u53ca\u6e2f\u5cf6\u5357\u5cb8\u7684\u666f\u8272\uff1b\u5728\u300c\u6ed1\u6d6a\u98db\u8239\u300d\u7684\u820a\u5740\u5468\u570d\uff0c\u5c07\u5efa\u9020\u300c\u96d9\u4eba\u7b28\u8c6c\u8df3\u300d\u3001\u300c\u96d9\u4eba\u5929\u7a7a\u97a6\u97c6\u300d\u3001\u6236\u5916\u904a\u6a02\u5834\u3001\u6c34\u4e0a\u6b77\u96aa\u5340\uff0c\u4ee5\u53ca\u6500\u77f3\u7246\u7b49\u591a\u500b\u5a1b\u6a02\u8a2d\u65bd\u7b49\u3002</p>\n<p>\u6d77\u6d0b\u516c\u5712\u4e3b\u5e2d\u9f90\u5efa\u8cbd\u8868\u793a\uff0c\u9019\u662f\u6d77\u6d0b\u516c\u5712\u4ee5\u81f3\u9999\u6e2f\u65c5\u904a\u696d\u4ee4\u4eba\u632f\u596e\u7684\u91cc\u7a0b\u7891\uff0c\u6709\u4fe1\u5fc3\u6b77\u96aa\u4e3b\u984c\u5340\u53ef\u5438\u5f15\u611b\u597d\u6b77\u96aa\u8005\u53ca\u5bb6\u5ead\u8a2a\u5ba2\uff0c\u62d3\u95ca\u516c\u5712\u5ba2\u7fa4\uff0c\u4ee5\u53ca\u9032\u4e00\u6b65\u63d0\u5347\u6d77\u6d0b\u516c\u5712\u5ea6\u5047\u5340\u7684\u8a2a\u5ba2\u9ad4\u9a57\u53ca\u5e02\u5834\u7af6\u722d\u529b\u3002</p>\n<p>\u4fe1\u5fb7\u96c6\u5718\u57f7\u884c\u8463\u4e8b\u2014\u9152\u5e97\u53ca\u6d88\u9592\u90e8\u9580\u7e3d\u88c1\u5c39\u9865\u74a0\u8868\u793a\uff0c\u96c6\u5718\u4ee5\u652f\u6301\u672c\u5730\u65c5\u904a\u696d\u5347\u7d1a\u8f49\u578b\u70ba\u5df1\u4efb\uff0c\u81f4\u529b\u5f15\u4eba\u65b0\u7d93\u6fdf\u589e\u9577\u9ede\uff0c\u6210\u5c31\u570b\u969b\u7d1a\u6b77\u5947\u666f\u9ede\u843d\u6236\u9999\u6e2f\uff0c\u5448\u737b\u9019\u500b\u96c6\u5275\u610f\u6b77\u96aa\u53ca\u81ea\u7136\u4fdd\u80b2\u5143\u7d20\u65bc\u4e00\u8eab\u7684\u5168\u65b0\u65c5\u904a\u9ede\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3910570/%E6%B5%B7%E6%B4%8B%E5%85%AC%E5%9C%92%E6%AD%B7%E9%9A%AA%E4%B8%BB%E9%A1%8C%E5%8D%80%E6%96%992028%E5%B9%B4%E9%96%8B%E6%94%BE+%E5%B0%87%E5%BB%BA%E5%B7%A8%E5%9E%8B%E9%A3%9B%E7%B4%A2%E5%8F%8A%E7%AC%A8%E8%B1%AC%E8%B7%B3%E7%AD%89"}, {"title": "\u6fb3\u9580:\u4eca\u665a\u81f3\u660e\u65e9\u639b1\u865f\u6ce2 \u660e\u5348\u8a55\u4f30\u6216\u6539\u767c\u66f4\u9ad8\u8a0a\u865f", "description": "<p>\u6fb3\u9580\u6c23\u8c61\u5c40\u8868\u793a\uff0c\u71b1\u5e36\u6c23\u65cb\u300c\u6f6d\u7f8e\u300d\u5df2\u79fb\u5165\u5357\u6d77\uff0c\u9810\u6599\u672a\u4f86\u6578\u65e5\u5411\u504f\u897f\u65b9\u5411\u79fb\u52d5\uff0c\u5927\u81f4\u79fb\u5411\u6d77\u5357\u5cf6\u4e00\u5e36\u4e26\u5728\u8a72\u5340\u5f98\u5f8a\uff0c\u6309\u7167\u73fe\u6642\u9810\u6e2c\u8def\u5f91\uff0c\u5c07\u65bc\u4eca\u665a\u81f3\u660e\u65e5\u65e9\u4e0a\u9032\u5165\u6fb3\u9580800\u516c\u91cc\u7bc4\u570d\uff0c\u5c46\u6642\u6703\u767c\u51fa1\u865f\u98a8\u7403\u3002</p>\n<p>\u6c23\u8c61\u5c40\u7a31\uff0c\u96a8\u7740\u300c\u6f6d\u7f8e\u300d\u9032\u4e00\u6b65\u79fb\u8fd1\uff0c\u660e\u65e5\u4e0b\u5348\u81f3\u665a\u9593\u6fb3\u9580\u98a8\u529b\u6703\u9032\u4e00\u6b65\u589e\u5f37\uff0c\u96f2\u91cf\u53ca\u9a5f\u96e8\u6703\u589e\u591a\uff0c\u5c07\u8a55\u4f30\u767c\u51fa\u66f4\u9ad8\u71b1\u5e36\u6c23\u65cb\u8a0a\u865f\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3910591/%E6%BE%B3%E9%96%80%3A%E4%BB%8A%E6%99%9A%E8%87%B3%E6%98%8E%E6%97%A9%E6%8E%9B1%E8%99%9F%E6%B3%A2+%E6%98%8E%E5%8D%88%E8%A9%95%E4%BC%B0%E6%88%96%E6%94%B9%E7%99%BC%E6%9B%B4%E9%AB%98%E8%A8%8A%E8%99%9F"}, {"title": "\u5546\u52d9\u90e8\u5021\u96fb\u5546\u5e73\u53f0\u96d9\u5341\u4e00\u671f\u9593\u5275\u65b0\u670d\u52d9\u5834\u666f", "description": "<p>\u4e2d\u570b\u5546\u52d9\u90e8\u8868\u793a\uff0c\u5c07\u6703\u540c\u6709\u95dc\u90e8\u9580\u6307\u5c0e\u5404\u5730\u5168\u529b\u843d\u5be6\u597d\u5df2\u51fa\u53f0\u7684\u6d88\u8cbb\u54c1\u300c\u4ee5\u820a\u63db\u65b0\u300d\u653f\u7b56\uff0c\u6436\u6293\u300c\u96d9\u5341\u4e00\u300d\u91cd\u8981\u6d88\u8cbb\u7bc0\u9ede\uff0c\u9f13\u52f5\u96fb\u5546\u5e73\u53f0\u5728\u300c\u96d9\u5341\u4e00\u300d\u671f\u9593\u767c\u63ee\u6709\u6548\u9023\u63a5\u4f9b\u9700\u5169\u7aef\u3001\u806f\u52d5\u591a\u5143\u4e3b\u9ad4\u512a\u52e2\uff0c\u5275\u65b0\u670d\u52d9\u5834\u666f\uff0c\u63a8\u52d5\u300c\u4ee5\u820a\u63db\u65b0\u300d\u5de5\u4f5c\u53d6\u5f97\u66f4\u5927\u6210\u6548\u3002</p>\n<p>\u5546\u52d9\u90e8\u767c\u8a00\u4eba\u4f55\u4e9e\u6771\u5728\u65b0\u805e\u767c\u5e03\u6703\u6307\u51fa\uff0c\u5c07\u540c\u6709\u95dc\u90e8\u9580\u65bc11\u6708\u4efd\u7d44\u7e54\u4e0a\u6d77\u3001\u5317\u4eac\u3001\u5ee3\u5dde\u3001\u5929\u6d25\u3001\u91cd\u6176\uff0c\u806f\u52d5\u8209\u8fa6\u4e2d\u570b\u570b\u969b\u6d88\u8cbb\u4e2d\u5fc3\u57ce\u5e02\u7cbe\u54c1\u6d88\u8cbb\u6708\uff0c\u4f5c\u70ba\u5be6\u65bd\u300c\u63d0\u632f\u6d88\u8cbb\u884c\u52d5\u300d\u7684\u6a19\u8a8c\u6027\u6d3b\u52d5\u548c\u300c\u6d88\u8cbb\u4fc3\u9032\u5e74\u300d\u7684\u91cd\u982d\u6232\u3002</p>\n<p>\u5546\u52d9\u90e8\u4e0a\u6708\u5ba3\u5e03\u5c0d\u7f8e\u570bPVH\u96c6\u5718\u555f\u52d5\u4e0d\u53ef\u9760\u5be6\u9ad4\u6e05\u55ae\u8abf\u67e5\uff0c\u4f55\u4e9e\u6771\u8868\u793a\uff0c\u4e0d\u53ef\u9760\u5be6\u9ad4\u6e05\u55ae\u5de5\u4f5c\u6a5f\u5236\u6b63\u5728\u4f9d\u6cd5\u6709\u5e8f\u63a8\u9032\u91dd\u5c0d\u7f8e\u570bPVH\u96c6\u5718\u7684\u8abf\u67e5\u5de5\u4f5c\u3002\u8abf\u67e5\u671f\u9593\uff0c\u5c07\u5145\u5206\u4fdd\u8b77PVH\u96c6\u5718\u9673\u8ff0\u3001\u7533\u8faf\u6b0a\u5229\u3002\u4e4b\u5f8c\u5de5\u4f5c\u6a5f\u5236\u5c07\u4f9d\u7167\u898f\u5b9a\uff0c\u6839\u64da\u8abf\u67e5\u60c5\u6cc1\u4f5c\u51fa\u76f8\u61c9\u6c7a\u5b9a\u3002</p>\n<p>\u4f55\u4e9e\u6771\u6307\u51fa\uff0c\u4e2d\u65b9\u4e00\u8cab\u5be9\u614e\u8655\u7406\u4e0d\u53ef\u9760\u5be6\u9ad4\u6e05\u55ae\u554f\u984c\uff0c\u50c5\u91dd\u5c0d\u6975\u5c11\u6578\u7834\u58de\u5e02\u5834\u898f\u5247\uff0c\u4e26\u9055\u53cd\u4e2d\u570b\u6cd5\u5f8b\u7684\u5916\u570b\u5be6\u9ad4\uff0c\u8aa0\u4fe1\u5b88\u6cd5\u7684\u5916\u570b\u5be6\u9ad4\u5b8c\u5168\u6bcb\u9808\u64d4\u5fc3\u3002\u4e2d\u570b\u653f\u5e9c\u4e00\u5982\u65e2\u5f80\u5730\u6b61\u8fce\u4e16\u754c\u5404\u570b\u4f01\u696d\u4f86\u83ef\u6295\u8cc7\u8208\u696d\uff0c\u4e26\u81f4\u529b\u65bc\u70ba\u5b88\u6cd5\u5408\u898f\u7684\u5916\u8cc7\u4f01\u696d\u5728\u83ef\u7d93\u71df\u63d0\u4f9b\u7a69\u5b9a\u3001\u516c\u5e73\u548c\u53ef\u9810\u671f\u7684\u71df\u5546\u74b0\u5883\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3910580/%E5%95%86%E5%8B%99%E9%83%A8%E5%80%A1%E9%9B%BB%E5%95%86%E5%B9%B3%E5%8F%B0%E9%9B%99%E5%8D%81%E4%B8%80%E6%9C%9F%E9%96%93%E5%89%B5%E6%96%B0%E6%9C%8D%E5%8B%99%E5%A0%B4%E6%99%AF"}, {"title": "\u5305\u7acb\u8ce2\u8fad\u4efb\u5927\u9152\u5e97\u526f\u4e3b\u5e2d \u7c73\u9ad8\u5609\u9053\u7406\u5152\u5b50\u63a5\u4efb", "description": "<p>\u5927\u9152\u5e97(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00045' >00045</a>)\u5ba3\u5e03\uff0c\u5305\u7acb\u8ce2\u5c07\u8fad\u4efb\u8463\u4e8b\u5c40\u526f\u4e3b\u5e2d\uff0c\u4f46\u6703\u7e7c\u7e8c\u64d4\u4efb\u975e\u57f7\u884c\u8463\u4e8b\u3001\u8ca1\u52d9\u59d4\u54e1\u6703\u4e3b\u5e2d\u4ee5\u53ca\u5be9\u6838\u59d4\u54e1\u6703\u3001\u85aa\u916c\u59d4\u54e1\u6703\u53ca\u57f7\u884c\u59d4\u54e1\u6703\u6210\u54e1\uff0c\u7531\u4eca\u5e7412\u670831\u65e5\u8d77\u751f\u6548\u3002</p>\n<p>\u8a72\u516c\u53f8\u516c\u5e03\uff0c\u975e\u57f7\u884c\u8463\u4e8b\u6590\u6b77\u5609\u9053\u7406\u5c07\u7372\u59d4\u4efb\u70ba\u8463\u4e8b\u5c40\u526f\u4e3b\u5e2d\uff0c\u4ee5\u63a5\u66ff\u5305\u7acb\u8ce2\u3002\u4ed6\u4ea6\u5c07\u7372\u59d4\u4efb\u70ba\u57f7\u884c\u59d4\u54e1\u6703\u6210\u54e1\uff0c\u5747\u81ea\u660e\u5e741\u67081\u65e5\u8d77\u751f\u6548\u3002</p>\n<p>\u6590\u6b77\u5609\u9053\u7406\u70ba\u73fe\u5e7483\u6b72\u5927\u9152\u5e97\u4e3b\u5e2d\u7c73\u9ad8\u5609\u9053\u7406\u7684\u5152\u5b50\u3002\u7c73\u9ad8\u5609\u9053\u7406\u4eca\u5e745\u6708\u5728\u5927\u9152\u5e97\u80a1\u6771\u6703\u4e0a\uff0c\u88ab\u554f\u5230\u5927\u9152\u5e97\u7ba1\u7406\u5c64\u7684\u7e7c\u4efb\u8a08\u5283\uff0c\u4ed6\u76f4\u8a00\uff0c\u53ea\u8981\u8eab\u9ad4\u5065\u5eb7\uff0c\u81ea\u5df1\u5c0d\u96c6\u5718\u4ecd\u6709\u50f9\u503c\uff0c\u5c31\u6703\u4e00\u76f4\u7e7c\u7e8c\u5de5\u4f5c\uff0c\u53c8\u8b02\u5176\u5152\u5b50\u6590\u6b77\u5609\u9053\u7406\u5c0d\u52a0\u5165\u9152\u5e97\u5341\u5206\u611f\u8208\u8da3\uff0c\u4e26\u5df2\u53c3\u8207\u516c\u53f8\u904b\u4f5c\uff0c\u76f8\u4fe1\u5728\u9069\u7576\u6642\u5019\u6709\u80fd\u529b\u7e7c\u627f\u5bb6\u65cf\u4e8b\u696d\u3002</p>   </div>\n<p></p>\n<div class=\"hkej_hkex_notice_dl_btn_2014\">\n<a href=\"https://www1.hkexnews.hk/listedco/listconews/sehk/2024/1024/2024102400493_c.pdf\" target=\"_blank\">\u4e0b\u8f09\u6e2f\u4ea4\u6240\u901a\u544a\u539f\u6587</a>\n</div>\n        ", "link": "https://www2.hkej.com/instantnews/announcement/article/3910497/%E5%8C%85%E7%AB%8B%E8%B3%A2%E8%BE%AD%E4%BB%BB%E5%A4%A7%E9%85%92%E5%BA%97%E5%89%AF%E4%B8%BB%E5%B8%AD+%E7%B1%B3%E9%AB%98%E5%98%89%E9%81%93%E7%90%86%E5%85%92%E5%AD%90%E6%8E%A5%E4%BB%BB"}]}