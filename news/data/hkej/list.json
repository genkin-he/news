a\uff0c\u65b0\u8cb7\u5bb6\u70ba\u5916\u5340\u767d\u5c45\u4e8c\u4eba\u58eb\uff0c\u898b\u9644\u8fd1\u914d\u5957\u8a2d\u65bd\u5b8c\u5584\uff0c\u50f9\u683c\u76f8\u5b9c\uff0c\u6c7a\u5b9a\u5165\u5e02\u81ea\u4f4f\u3002</p>\n<p>\u539f\u696d\u4e3b\u5247\u65bc2020\u5e74\u4ee5\u7d04499\u842c\u5143\u8cb7\u5165\u55ae\u4f4d\uff0c\u6301\u8ca8\u7d044\u5e74\uff0c\u662f\u6b21\u6cbd\u51fa\u55ae\u4f4d\u8cec\u9762\u7372\u5229\u7d04151\u842c\u5143\uff0c\u55ae\u4f4d\u671f\u5167\u5347\u503c\u4e09\u6210\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3844149/%E5%86%A0%E5%BE%B7%E8%8B%91%E4%B8%89%E6%88%BF%E9%99%8D%E5%83%B9120%E8%90%AC%E8%BD%89%E6%89%8B"}, {"title": "\u674e\u5bb6\u8d85:\u5df4\u9ece\u6b98\u5967\u500b\u4eba\u91d1\u724c\u734e\u91d1\u9054150\u842c", "description": "<p><span style=\"font-size-ignore:13pt;\">\u5df4\u9ece\u6b98\u75be\u4eba\u5967\u904b\u6703\u5c07\u65bc\u672c\u670828\u65e5\u81f3\u4e0b\u67088\u65e5\u8209\u884c\u3002\u884c\u653f\u9577\u5b98\u674e\u5bb6\u8d85\u5728\u4e2d\u570b\u9999\u6e2f\u4ee3\u8868\u5718\u6388\u65d7\u5178\u79ae\u81f4\u8a5e\u8868\u793a\uff0c\u9999\u6e2f\u8cfd\u99ac\u6703\u8d0a\u52a9\u9ad4\u9662\u63a8\u51fa\u7684\u8cfd\u99ac\u6703\u512a\u79c0\u904b\u52d5\u54e1\u734e\u52f5\u8a08\u5283\uff0c\u5c31\u5df4\u9ece\u6b98\u5967\u6703\u7684\u734e\u52f5\u4eca\u5e74\u5c07\u6703\u300c\u52a0\u78bc\u300d\uff0c\u596c\u91d1\u8f03\u4e0a\u5c46\u5dee\u4e0d\u591a\u7ffb\u500d\uff0c\u500b\u4eba\u91d1\u724c\u7684\u734e\u91d1\u9054\u5230150\u842c\u5143\uff0c\u652f\u6301\u9999\u6e2f\u5065\u5152\u5728\u4eca\u5c46\u6b98\u5967\u6703\u4e2d\u529b\u722d\u4f73\u7e3e\u3002</span></p>\n<p>\u674e\u5bb6\u8d85\u8868\u793a\uff0c\u4eca\u5c46\u6b98\u5967\u6703\u9999\u6e2f\u5c07\u6d3e\u51fa23\u540d\u904b\u52d5\u54e1\u5230\u5df4\u9ece\u4f5c\u8cfd\uff0c\u7576\u4e2d\u6709\u591a\u4f4d\u5143\u8001\u7d1a\u4eba\u99ac\u5750\u93ae\uff0c\u6709\u4fe1\u5fc3\u4ed6\u5011\u5728\u4eca\u5c46\u8cfd\u4e8b\u6703\u5c55\u73fe\u7121\u6bd4\u6bc5\u529b\uff0c\u6bcf\u4eba\u90fd\u6709\u51fa\u8272\u7684\u8868\u73fe\u3002</p>\n<p>\u4ed6\u53c8\u8868\u793a\uff0c\u7279\u5340\u653f\u5e9c\u8cfc\u5165\u5df4\u9ece\u5967\u904b\u6703\u548c\u6b98\u5967\u6703\u7684\u96fb\u8996\u8f49\u64ad\u6b0a\uff0c\u8b93\u5e02\u6c11\u514d\u8cbb\u6536\u770b\u3002\u6b98\u5967\u6703\u5728\u4eca\u500b\u6708\u5e95\u958b\u5e55\u5f8c\uff0c\u76f8\u4fe1\u5e02\u6c11\u90fd\u6703\u548c\u4ed6\u4e00\u6a23\uff0c\u70ba\u5404\u4f4d\u7cbe\u82f1\u6253\u6c23\uff0c\u7e7c\u7e8c\u5c55\u73fe\u51fa\u9999\u6e2f\u7684\u5718\u7d50\u7cbe\u795e\u3002</p>\n<p>\u4ed6\u63d0\u5230\uff0c\u7279\u5340\u653f\u5e9c\u5168\u529b\u652f\u6301\u5c55\u80fd\u9ad4\u80b2\u767c\u5c55\uff0c\u57282024\u81f325\u5e74\u5ea6\uff0c\u653f\u5e9c\u63a8\u52d5\u6b98\u75be\u4eba\u58eb\u7684\u9ad4\u80b2\u767c\u5c55\u7684\u9810\u7b97\u958b\u652f\u81f3\u8d85\u904e1.3\u5104\u5143\uff0c\u662f10\u5e74\u524d\u7d044000\u842c\u5143\u7684\u8d85\u904e\u4e09\u500d\uff0c\u652f\u63f4\u6b98\u75be\u904b\u52d5\u54e1\u7684\u958b\u652f\uff0c\u4f54\u5c55\u80fd\u9ad4\u80b2\u767c\u5c55\u6574\u9ad4\u958b\u652f\u516b\u6210\u4ee5\u4e0a\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3844439/%E6%9D%8E%E5%AE%B6%E8%B6%85%3A%E5%B7%B4%E9%BB%8E%E6%AE%98%E5%A5%A7%E5%80%8B%E4%BA%BA%E9%87%91%E7%89%8C%E7%8D%8E%E9%87%91%E9%81%94150%E8%90%AC"}, {"title": "\u9ec3\u8272\u5de5\u4f5c\u6691\u71b1\u8b66\u544a\u53d6\u6d88", "description": "<p><span style=\"font-size-ignore:13pt;\">\u5929\u6587\u53f0\u5728\u4e0b\u53486\u6642\u53d6\u6d88\u9ec3\u8272\u5de5\u4f5c\u6691\u71b1\u8b66\u544a\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3844454/%E9%BB%83%E8%89%B2%E5%B7%A5%E4%BD%9C%E6%9A%91%E7%86%B1%E8%AD%A6%E5%91%8A%E5%8F%96%E6%B6%88"}, {"title": "\u8521\u82e5\u84ee\u5925\u7acb\u6cd5\u6703\u8b70\u54e1\u8a2a\u554f\u4e0a\u6d77", "description": "<p>\u6559\u80b2\u5c40\u5c40\u9577\u8521\u82e5\u84ee\u5c07\u65bc\u4e0b\u5468\u4e00(12\u65e5)\u81f3\u5468\u4e09(14\u65e5)\u806f\u540c\u7acb\u6cd5\u6703\u6559\u80b2\u4e8b\u52d9\u59d4\u54e1\u6703\u8a2a\u554f\u5718\u517114\u4f4d\u7acb\u6cd5\u6703\u8b70\u54e1\u8a2a\u554f\u4e0a\u6d77\uff0c\u4e86\u89e3\u7576\u5730\u611b\u570b\u4e3b\u7fa9\u6559\u80b2\u3001\u6578\u5b57\u5316\u6559\u80b2\u548c\u5275\u65b0\u79d1\u6280\u7684\u6700\u65b0\u767c\u5c55\u3002</p>\n<p>\u884c\u7a0b\u671f\u9593\uff0c\u8521\u82e5\u84ee\u8207\u8a2a\u554f\u5718\u5c07\u8207\u4e0a\u6d77\u5e02\u5b98\u54e1\u6703\u9762\uff0c\u4e26\u53c3\u8a2a\u611b\u570b\u4e3b\u7fa9\u6559\u80b2\u57fa\u5730\u3001\u7576\u5730\u7684\u5b78\u6821\u548c\u5927\u5b78\uff0c\u4ee5\u53ca\u79d1\u5275\u55ae\u4f4d\u3002\u4ed6\u5011\u4ea6\u6703\u8207\u5728\u6eec\u5b78\u7fd2\u6216\u5de5\u4f5c\u7684\u9999\u6e2f\u9752\u5e74\u4ea4\u6d41\u3002<span style=\"font-size-ignore:13pt;\">\u8521\u82e5\u84ee\u96e2\u6e2f\u671f\u9593\uff0c\u6559\u80b2\u5c40\u526f\u5c40\u9577\u65bd\u4fca\u8f1d\u5c07\u7f72\u4efb\u6559\u80b2\u5c40\u5c40\u9577\u3002</span></p>\n<p>\u7acb\u6cd5\u6703\u6559\u80b2\u4e8b\u52d9\u59d4\u54e1\u6703\u5c07\u65bc\u4e0b\u5468\u4e00\u51fa\u767c\u524d\u5f80\u4e0a\u6d77\u53ca\u8607\u5dde\uff0c\u9032\u884c\u70ba\u671f4\u65e5\u7684\u8077\u52d9\u8003\u5bdf\u3002</p>\n<p>\u662f\u6b21\u8077\u52d9\u8003\u5bdf\u65e8\u5728\u8b93\u8b70\u54e1\u4e86\u89e3\u4e0a\u6d77\u53ca\u8607\u5dde\u5982\u4f55\u63a8\u5c55\u611b\u570b\u4e3b\u7fa9\u6559\u80b2\u3001\u5f37\u5316\u7522\u5b78\u7814\u5408\u4f5c\u3001\u4fc3\u9032\u6559\u80b2\u6578\u5b57\u5316\u8f49\u578b\uff0c\u4ee5\u53ca\u63d0\u5347\u6559\u80b2\u670d\u52d9\u8cea\u91cf\u3002\u8003\u5bdf\u671f\u9593\uff0c\u8b70\u54e1\u6703\u8207\u5167\u5730\u76f8\u95dc\u90e8\u59d4\u548c\u5927\u5b78\u6703\u9762\uff0c\u63a2\u8a0e\u63a8\u9032\u300c\u4e00\u5e36\u4e00\u8def\u300d\u570b\u969b\u6559\u80b2\u7684\u5408\u4f5c\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3844435/%E8%94%A1%E8%8B%A5%E8%93%AE%E5%A4%A5%E7%AB%8B%E6%B3%95%E6%9C%83%E8%AD%B0%E5%93%A1%E8%A8%AA%E5%95%8F%E4%B8%8A%E6%B5%B7"}]}