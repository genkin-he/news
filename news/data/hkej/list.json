\u653f\u9ee8\u8a0e\u8ad6\u5c39\u932b\u6085\u6700\u5feb\u660e\u5e742\u6708\u8fad\u8077\u65b9\u6848", "description": "<p><span style=\"font-size-ignore:13pt;\">\u5357\u97d3\u6212\u56b4\u98a8\u6ce2\u6301\u7e8c\uff0c\u5916\u96fb\u5831\u9053\uff0c\u5357\u97d3\u57f7\u653f\u570b\u6c11\u529b\u91cf\u9ee8\u8868\u793a\uff0c\u8a0e\u8ad6\u8b93\u7e3d\u7d71\u5c39\u932b\u6085\u6700\u5feb\u660e\u5e742\u6708\u8fad\u8077\u4e0b\u53f0\u7684\u65b9\u6848\uff0c\u4e26\u5728\u660e\u5e744\u6708\u62165\u6708\u63d0\u524d\u8209\u884c\u7e3d\u7d71\u5927\u9078\u3002</span></p>\n<p>\u570b\u6c11\u529b\u91cf\u9ee8\u9ee8\u9b41\u97d3\u6771\u52f3\u65e9\u524d\u8868\u793a\uff0c\u57f7\u653f\u9ee8\u6703\u63a8\u52d5\u5c39\u932b\u6085\u6709\u79e9\u5e8f\u4e0b\u53f0\uff0c\u76e1\u91cf\u6e1b\u5c11\u6df7\u4e82\u3002</p>\n<p>\u9ee8\u5167\u8ca0\u8cac\u5236\u5b9a\u5c39\u932b\u6085\u6709\u5e8f\u4e0b\u53f0\u8a08\u5283\u7684\u5c08\u6848\u5c0f\u7d44\u8ca0\u8cac\u4eba\u674e\u967d\u79c0\u8868\u793a\uff0c\u5c0f\u7d44\u63d0\u51fa\u5c39\u932b\u6085\u5728\u660e\u5e742\u6708\u62163\u6708\u8fad\u8077\uff0c\u4e26\u5728\u4e4b\u5f8c\u7684\u5169\u500b\u6708\u5167\u63d0\u524d\u5927\u9078\uff0c\u9ee8\u5167\u66ab\u6642\u5c1a\u672a\u9054\u6210\u5171\u8b58\uff0c\u4eca\u65e5\u5c07\u8207\u6240\u6709\u57f7\u653f\u9ee8\u570b\u6703\u8b70\u54e1\u958b\u6703\u8a0e\u8ad6\u65b9\u6848\u3002</p>\n<p>\u5c39\u932b\u6085\u7684\u7e3d\u7d71\u4efb\u671f\u81f32027\u5e745\u6708\u3002\u6839\u64da\u5357\u97d3\u61b2\u6cd5\uff0c\u5982\u679c\u7e3d\u7d71\u57285\u5e74\u4efb\u671f\u5c46\u6eff\u4e4b\u524d\u4e0b\u53f0\uff0c\u5fc5\u9808\u572860\u5929\u5167\u8209\u884c\u7e3d\u7d71\u9078\u8209\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3951514/%E5%8D%97%E9%9F%93%E5%9F%B7%E6%94%BF%E9%BB%A8%E8%A8%8E%E8%AB%96%E5%B0%B9%E9%8C%AB%E6%82%85%E6%9C%80%E5%BF%AB%E6%98%8E%E5%B9%B42%E6%9C%88%E8%BE%AD%E8%81%B7%E6%96%B9%E6%A1%88"}, {"title": "\u878d\u5275\u4e2d\u570b\u5883\u5167\u50b5\u52d9\u91cd\u7d44\u8a08\u5283\u90e8\u5206\u7372\u50b5\u5238\u6301\u6709\u4eba\u6279\u51c6", "description": "<p>\u8def\u900f\u5f15\u8ff0\u6d88\u606f\u4eba\u58eb\u5831\u9053\uff0c\u878d\u5275\u4e2d\u570b(<a target='_blank' href='https://stock360.hkej.com/quotePlus/01918' >01918</a>)\u4e00\u9805\u901a\u904e\u91cd\u6574\u4ee5\u628a\u5883\u5167\u50b5\u52d9\u524a\u6e1b\u4e00\u534a\u7684\u8a08\u5283\uff0c\u5df2\u7d93\u8d0f\u5f97\u90e8\u5206\u50b5\u5238\u6301\u6709\u4eba\u7684\u6279\u51c6\u3002</p>\n<p>\u6d88\u606f\u4eba\u58eb\u7a31\uff0c\u91cd\u7d44\u4e2d\u768410\u6a94\u50b5\u5238\u4e2d\u67092\u6a94\u7372\u5f97\u4e86\u6301\u6709\u4eba\u7684\u5145\u5206\u652f\u6301\u3002\u8a72\u516c\u53f8\u5c07\u628a\u5176\u9918\u50b5\u5238\u7684\u6295\u7968\u622a\u6b62\u65e5\u671f\u63a8\u9072\u5169\u5468\u3002</p>\n<p>\u878d\u5275\u4e2d\u570b\u66fe\u662f\u4e2d\u570b\u524d\u5e7e\u5927\u5730\u7522\u958b\u767c\u5546\u4e4b\u4e00\uff0c\u662f\u4e2d\u570b\u9996\u5bb6\u529b\u5716\u901a\u904e\u91cd\u7d44\u4ee5\u5927\u5e45\u524a\u6e1b\u5176154\u5104\u5143\u5883\u5167\u50b5\u5238\u7684\u958b\u767c\u5546\u3002</p>\n<p>\u50b5\u5238\u6301\u6709\u4eba\u7684\u8868\u6c7a\u539f\u5b9a\u65bc\u5468\u4e00\u7d50\u675f\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/stock/article/3951493/%E8%9E%8D%E5%89%B5%E4%B8%AD%E5%9C%8B%E5%A2%83%E5%85%A7%E5%82%B5%E5%8B%99%E9%87%8D%E7%B5%84%E8%A8%88%E5%8A%83%E9%83%A8%E5%88%86%E7%8D%B2%E5%82%B5%E5%88%B8%E6%8C%81%E6%9C%89%E4%BA%BA%E6%89%B9%E5%87%86"}, {"title": "\u912d\u5bb6\u7d14\u5b7b\u4ed4\u5c0f\u767b\u79d1 \u653f\u5546\u731b\u4eba\u9f4a\u5230\u8cc0", "description": "<p>\u65b0\u4e16\u754c\u767c\u5c55(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00017' >00017</a>)\u912d\u6c0f\u5bb6\u65cf\u4eca\u65e5\u5bb6\u6709\u559c\u4e8b\uff0c\u4e3b\u5e2d\u912d\u5bb6\u7d14(\u7d14\u5b98)\u5b7b\u4ed4\u912d\u5fd7\u4eae(Christopher)\u5a36\u8001\u5a46\uff0c\u5728\u7470\u9e97\u9152\u5e97(Rosewood)\u4ee5Cocktail\u9152\u6703\u5f62\u5f0f\u641e\u5a5a\u79ae\uff0c\u5e7e\u4e4e\u5168\u57ce\u9054\u5b98\u8cb4\u4eba\u51fa\u52d5\u4f86\u98f2\u756a\u676f\uff0c\u64da\u8b1b\u6709\u8fd1\u5343\u540d\u5609\u8cd3\u5230\u5834\uff0c\u4e0b\u5348\u958b\u59cb\u63a5\u5f85\u8cd3\u5ba2\u81f3\u665a\u4e0a8\u6642\uff0c\u5834\u9762\u975e\u5e38\u71b1\u9b27\u3002\u7279\u9996\u674e\u5bb6\u8d85\u90fd\u6709\u4f86\u5230\u8cc0\uff0c\u4e26\u7531\u912d\u5bb6\u7d14\u9577\u5b50\u912d\u5fd7\u525b(Adrian)\u3001\u9577\u5973\u912d\u5fd7\u96ef(Sonia)\u53ca\u6b21\u5b50\u912d\u5fd7\u660e(Brian)\uff0c\u4e00\u540c\u4ee3\u8868\u5bb6\u65cf\u89aa\u81ea\u51fa\u9580\u8fce\u63a5\u3002</p>\n<p>\u73fe\u5728\u6240\u898b\uff0c\u51fa\u5e2d\u7684\u5546\u754c\u540d\u4eba\u5305\u62ec\u6ed9\u8c50\u9280\u884c\u4e3b\u5e2d\u738b\u51ac\u52dd\u3001\u83ef\u7f6e(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00127' >00127</a>)\u8001\u95c6\u5289\u947e\u96c4\u592b\u5a66\u3001\u9e97\u65b0\u4e3b\u5e2d\u6797\u5efa\u5cb3\u3001\u745e\u5b89\u7cfb\u7f85\u5eb7\u745e\u548c\u6731\u73b2\u73b2\u3001\u65b0\u98a8\u5929\u57df\u5275\u59cb\u4eba\u6881\u9326\u677e\u3001\u82f1\u7687\u96c6\u5718\u4e3b\u5e2d\u694a\u53d7\u6210\u3001\u300c\u73a9\u5177\u5927\u738b\u300d\u8521\u5fd7\u660e\u3001\u300c\u862d\u6842\u574a\u4e4b\u7236\u300d\u76db\u667a\u6587\u7b49\u3002</p>\n<p>\u653f\u754c\u65b9\u9762\u9664\u4e86\u7279\u9996\uff0c\u653f\u52d9\u53f8\u53f8\u9577\u9673\u570b\u57fa\u3001\u8ca1\u653f\u53f8\u53f8\u9577\u9673\u8302\u6ce2\u3001\u4fdd\u5b89\u5c40\u5c40\u9577\u9127\u70b3\u5f37\u3001\u8b66\u52d9\u8655\u8655\u9577\u856d\u6fa4\u9824\u3001\u5510\u82f1\u5e74\u592b\u5a66\u3001\u524d\u5f8b\u653f\u53f8\u53f8\u9577\u6881\u611b\u8a69\u3001\u6881\u632f\u82f1\u592a\u592a\u6881\u5510\u9752\u5100\u7b49\u5747\u6709\u5230\u5834\u3002</p>\n<p>\u64da\u8b1b\u7d14\u5b98\u81ea\u65e9\u4e0a\u8d77\u5fd9\u8db3\u5168\u65e5\uff0c\u665a\u4e0a\u6709\u5c11\u5c11\u5514\u5920\u96fb\uff0c\u5c31\u6c92\u6709\u843d\u6a13\u8fce\u8cd3\u6216\u898b\u50b3\u5a92\uff0c\u53ea\u7559\u5728\u5834\u5167\u548c\u5609\u8cd3\u62cd\u7167\u3002\u65b0\u5a18\u5b50Tina Huang\u70ba\u5167\u5730\u59d1\u5a18\uff0c\u64da\u8b1b\u5bb6\u5883\u751a\u5177\u5be6\u529b\uff0c\u65e9\u5e74\u5728\u7f8e\u570b\u5e38\u6625\u85e4\u5927\u5b78\u7562\u696d\uff0c\u5728\u9999\u6e2f\u5f9e\u4e8b\u91d1\u878d\uff0c\u4e26\u66fe\u65bc\u6295\u884c\u9ad8\u76db\u5de5\u4f5c\uff0c\u5f8c\u671f\u4ea6\u6709\u4e3b\u7406\u57fa\u91d1\u6295\u8cc7\uff0c\u5c0d\u79d1\u6280\u884c\u696d\u751a\u6709\u5fc3\u5f97\u3002\u5979\u8207Christopher\u7d93\u670b\u53cb\u4ecb\u7d39\u76f8\u8b58\uff0c\u62cd\u62d6\u591a\u5e74\u7d42\u5171\u8ae7\u9023\u7406\u3002\u7d14\u5b98\u81f4\u8fad\u6642\u4ea6\u795d\u798f\u4e00\u5c0d\u65b0\u4eba\u767d\u982d\u5230\u8001\uff0c\u6c38\u7d50\u540c\u5fc3\uff0c\u5152\u5b6b\u6eff\u5802\u5481\u8a71\u3002</p>\n<p>\u7d14\u5b98\u4ea6\u900f\u904e\u767c\u8a00\u4eba\u611f\u8b1d\u5404\u4f4d\u51fa\u5e2d\u7684\u8cd3\u5ba2\uff0c\u8a71\u5f88\u9ad8\u8208\u5fd7\u4eae\u627e\u5230\u4e00\u500b\u966a\u4f34\u4ed6\u4eba\u751f\u7684\u597d\u592a\u592a\u3002\u65b0\u90ce\u54e5Christopher\u4ea6\u8aaa\uff0c\u4e0d\u5c11\u8cd3\u5ba2\u662f\u770b\u7740\u81ea\u5df1\u9577\u5927\u7684\u524d\u8f29\uff0c\u672a\u80fd\u51fa\u5e2d\u8005\u4e5f\u7528\u4ed6\u5011\u7684\u65b9\u5f0f\u9001\u4e0a\u795d\u798f\uff0c\u975e\u5e38\u6709\u5fc3\u601d\uff0c\u5f88\u611f\u8b1d\u4ed6\u5011\u3002\u4ed6\u53c8\u7279\u5225\u611f\u8b1d\u7236\u6bcd\u3001\u5cb3\u7236\u5cb3\u6bcd\u53ca\u5bb6\u4eba\u670b\u53cb\uff0c\u5f62\u5bb9\u4ed6\u5011\u90fd\u662f\u81ea\u5df1\u548c\u592a\u592a\u4eba\u751f\u4e2d\u5f88\u91cd\u8981\u7684\u898b\u8b49\u8005\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3951482/%E9%84%AD%E5%AE%B6%E7%B4%94%E5%AD%BB%E4%BB%94%E5%B0%8F%E7%99%BB%E7%A7%91+%E6%94%BF%E5%95%86%E7%8C%9B%E4%BA%BA%E9%BD%8A%E5%88%B0%E8%B3%80"}, {"title": "\u300a\u7537\u5152\u7576\u5165\u6a3d\u300b\u624b\u904a\u767c\u884c\u5546DeNA\u7e2e\u6e1b\u5167\u5730\u696d\u52d9", "description": "<p><span style=\"font-size-ignore:13pt;\">\u65e5\u7d93\u4e2d\u6587\u7db2\u5831\u9053\uff0c\u5728\u4e2d\u570b\u958b\u767c\u4e26\u63a8\u51fa\u6f2b\u756b\u300a\u7537\u5152\u7576\u5165\u6a3d\u300b(\u5167\u5730\u53eb\u300a\u704c\u7c43\u9ad8\u624b\u300b)\u7b49\u71b1\u9580IP\u624b\u904a\u7684DeNA\uff0c\u7e2e\u6e1b\u5728\u4e2d\u570b\u7684\u696d\u52d9\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">DeNA\u8868\u793a\uff0c\u76ee\u524d\u4e0d\u8003\u616e\u5728\u4e2d\u570b\u63a8\u51fa\u65b0\u904a\u6232\uff0c\u516c\u53f8\u8207\u4e2d\u570b\u624b\u904a\u516c\u53f8\u68b5\u514b\u65af\u4e92\u52d5\u5a1b\u6a02\u9054\u6210\u8cc7\u672c\u696d\u52d9\u5408\u4f5c\uff0c</span><span style=\"font-size-ignore:13pt;\">\u65d7\u4e0b\u5df2\u4e0a\u7dda\u7684\u904a\u6232</span><span style=\"font-size-ignore:13pt;\">\u696d\u52d9</span><span style=\"font-size-ignore:13pt;\">\u5c07\u79fb\u4ea4\u7d66\u8207\u68b5\u514b\u65af\u4e92\u52d5\u5a1b\u6a02\u7684\u5b50\u516c\u53f8\u3002</span></p>\n<p>\u64da\u76f8\u95dc\u8cc7\u672c\u696d\u52d9\u5408\u4f5c\uff0cDeNA\u5411\u68b5\u514b\u65af\u4e92\u52d5\u5a1b\u6a02\u79d1\u6280\u5b50\u516c\u53f8\u874c\u86aa\u4e92\u52d5\u51fa\u8cc710%\uff0c\u4e26\u5c07DeNA\u5728\u4e2d\u570b\u7684\u624b\u904a\u696d\u52d9\u79fb\u4ea4\u7d66\u874c\u86aa\u4e92\u52d5\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3951486/%E3%80%8A%E7%94%B7%E5%85%92%E7%95%B6%E5%85%A5%E6%A8%BD%E3%80%8B%E6%89%8B%E9%81%8A%E7%99%BC%E8%A1%8C%E5%95%86DeNA%E7%B8%AE%E6%B8%9B%E5%85%A7%E5%9C%B0%E6%A5%AD%E5%8B%99"}, {"title": "\u5b6b\u7389\u83e1:\u63a8\u52d5\u793e\u798f\u754c\u6295\u5165\u570b\u5b89\u6559\u80b2 \u63d0\u5347\u611b\u570b\u611b\u6e2f\u60c5\u61f7", "description": "<p>\u52de\u5de5\u53ca\u798f\u5229\u5c40\u5c40\u9577\u5b6b\u7389\u83e1\u4eca\u65e5\u806f\u540c\u793e\u798f\u6a5f\u69cb\u4e3b\u5e2d\u53c3\u89c0\u9999\u6e2f\u7279\u5225\u884c\u653f\u5340\u570b\u5bb6\u5b89\u5168\u5c55\u89bd\u5ef3\u3002\u4ed6\u5728\u53c3\u89c0\u524d\u81f4\u8a5e\u8868\u793a\uff0c<span style=\"font-size-ignore:13pt;\">\u52de\u798f\u5c40\u548c\u793e\u7f72\u4e0d\u6642\u63d0\u9192\u5404\u793e\u798f\u6a5f\u69cb\uff0c\u5728\u65e5\u5e38\u904b\u4f5c\u53ca\u5411\u5e02\u6c11\u63d0\u4f9b\u670d\u52d9\u6642\uff0c\u9808\u606a\u5b88\u7dad\u8b77\u570b\u5bb6\u5b89\u5168\u7684\u6cd5\u5f8b\u548c\u689d\u4f8b\u3002\u70ba\u52a0\u5f37\u7dad\u8b77\u570b\u5bb6\u5b89\u5168\u63aa\u65bd\uff0c\u793e\u7f72\u5df2\u5c07\u300a\u9999\u6e2f\u570b\u5b89\u6cd5\u300b\u53ca\u300a\u7dad\u8b77\u570b\u5bb6\u5b89\u5168\u689d\u4f8b\u300b\u76f8\u7e7c\u5217\u5165\u53d7\u793e\u7f72\u8cc7\u52a9\u670d\u52d9\u7684\u300c\u670d\u52d9\u8cea\u7d20\u6a19\u6e96\u300d\u76f8\u95dc\u6587\u4ef6\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u540c\u6642\uff0c\u5728\u670d\u52d9\u898f\u683c\u8aaa\u660e\u66f8\u3001\u670d\u52d9\u5354\u8b70\u3001\u7269\u6599\u4f9b\u61c9\u53ca\u63a1\u8cfc\u898f\u5b9a\u52a0\u5165\u6709\u95dc\u7dad\u8b77\u570b\u5bb6\u5b89\u5168\u7684\u8cac\u4efb\u53ca\u898f\u5b9a\uff1b\u4ee5\u53ca\u5728\u7533\u8acb\u65bc\u516c\u773e\u5730\u65b9\u8209\u8fa6\u6148\u5584\u7c4c\u6b3e\u6d3b\u52d5\u7684\u6307\u5f15\u4e2d\uff0c\u5217\u660e\u6148\u5584\u7c4c\u6b3e\u7684\u6536\u5165\u4e0d\u53ef\u7528\u65bc\u5f9e\u4e8b\u6216\u652f\u6301\u4efb\u4f55\u975e\u6cd5\u6216\u4e0d\u5229\u65bc\u570b\u5bb6\u5b89\u5168\u7684\u884c\u70ba\u548c\u6d3b\u52d5\u7b49\u3002\u793e\u7f72\u81f3\u4eca\u6c92\u6709\u767c\u73fe\u4efb\u4f55\u9055\u898f\u60c5\u6cc1\uff0c\u4f46\u76f8\u95dc\u4fdd\u969c\u6709\u5fc5\u8981\u5b58\u5728\u3002</span></p>\n<p>\u793e\u7f72\u4eca\u5e7410\u6708\u516c\u5e03\u4e26\u61c9\u7528\u7684\u300a\u793e\u6703\u798f\u5229\u670d\u52d9\u6574\u7b46\u64a5\u6b3e\u6d25\u52a9\u624b\u518a\u300b\u4fee\u8a02\u7248\u4ea6\u8a02\u660e\uff0c\u6240\u6709\u71df\u8fa6\u6d25\u52a9\u798f\u5229\u670d\u52d9\u7684\u6a5f\u69cb\u5728\u63d0\u4f9b\u670d\u52d9\u6642\u9808\u638c\u63e1\u4e26\u9075\u5b88\u300a\u9999\u6e2f\u570b\u5b89\u6cd5\u300b\u53ca\u300a\u7dad\u8b77\u570b\u5bb6\u5b89\u5168\u689d\u4f8b\u300b\u3002</p>\n<p>\u5b6b\u7389\u83e1\u6307\u51fa\uff0c\u52de\u798f\u5c40\u548c\u793e\u7f72\u6703\u6301\u7e8c\u63a8\u52d5\u793e\u798f\u754c\u5927\u5bb6\u5ead\u6295\u5165\u570b\u5bb6\u5b89\u5168\u6559\u80b2\u53ca\u5ba3\u50b3\uff0c\u81f4\u529b\u63d0\u5347\u5927\u5bb6\u611b\u570b\u611b\u6e2f\u60c5\u61f7\u3002\u793e\u7f72\u5df2\u65bc\u4eca\u5e745\u6708\u63a8\u51fa\u70ba\u671f5\u5e74\u7684\u5c08\u9805\u57fa\u91d1\uff0c\u7528\u65bc\u71df\u8fa6\u6d25\u52a9\u798f\u5229\u670d\u52d9\u7684\u975e\u653f\u5e9c\u6a5f\u69cb\u4f5c\u54e1\u5de5\u57f9\u8a13\u53ca\u7cfb\u7d71\u63d0\u5347\uff0c\u7576\u4e2d\u9810\u75591\u5104\u5143\u5c08\u4f5c\u8cc7\u52a9\u6a5f\u69cb\u5b89\u6392\u54e1\u5de5\u53c3\u52a0\u570b\u60c5\u7814\u7fd2\u8ab2\u7a0b\uff0c\u5305\u62ec\u6709\u95dc\u300a\u9999\u6e2f\u570b\u5b89\u6cd5\u300b\u53ca\u300a\u7dad\u8b77\u570b\u5bb6\u5b89\u5168\u689d\u4f8b\u300b\u7684\u57f9\u8a13\u4ee5\u53ca\u8209\u8fa6\u5167\u5730\u4ea4\u6d41\u5718\uff0c\u5373\u5927\u5bb6\u76f8\u7576\u719f\u6089\u3001\u5df2\u8209\u8fa6\u4e09\u5718\u7684\u300c\u9999\u6e2f\u842c\u5343\u793e\u5de5\u770b\u7956\u570b\u300d\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3951476/%E5%AD%AB%E7%8E%89%E8%8F%A1%3A%E6%8E%A8%E5%8B%95%E7%A4%BE%E7%A6%8F%E7%95%8C%E6%8A%95%E5%85%A5%E5%9C%8B%E5%AE%89%E6%95%99%E8%82%B2+%E6%8F%90%E5%8D%87%E6%84%9B%E5%9C%8B%E6%84%9B%E6%B8%AF%E6%83%85%E6%87%B7"}]}