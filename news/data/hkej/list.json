055\u53cd\u300a\u6253\u64ca\u6d17\u9322\u689d\u4f8b\u300b\u8655\u4ee5400\u842c\u5143\u7f70\u6b3e\u3002</p>\n<p>\u8abf\u67e5\u6240\u767c\u73fe\u7684\u554f\u984c\u6d89\u53ca\u4e2d\u4fe1\u9280\u884c(\u570b\u969b)\u5728\u5176\u81ea\u52d5\u5316\u4ea4\u6613\u76e3\u63a7\u7cfb\u7d71\u4e2d\u672a\u80fd\u6b63\u78ba\u5be6\u65bd\u5075\u6e2c\u898f\u5247\u548c\u6838\u5fc3\u6a21\u578b\u898f\u5247\uff0c\u5c0e\u81f4\u8a72\u884c\u7684\u76e3\u63a7\u7cfb\u7d71\u65bc2015\u5e7411\u6708\u81f32018\u5e747\u6708\u671f\u9593\u672a\u80fd\u5c31\u76f8\u95dc\u53ef\u7591\u4ea4\u6613\u7522\u751f\u7cfb\u7d71\u8b66\u793a\u3002\u4e2d\u4fe1\u9280\u884c(\u570b\u969b)\u671f\u9593\u4ea6\u672a\u6709\u5be9\u67e5\u67d0\u4e9b\u5ba2\u6236\u4ea4\u6613\u7684\u80cc\u666f\u53ca\u76ee\u7684\uff0c\u4e26\u4ee5\u66f8\u9762\u5f62\u5f0f\u5217\u660e\u5176\u5be9\u67e5\u7d50\u679c\u3002</p>\n<p>\u91d1\u7ba1\u5c40\u52a9\u7406\u7e3d\u88c1(\u6cd5\u898f\u53ca\u6253\u64ca\u6e05\u6d17\u9ed1\u9322)\u9673\u666f\u5b8f\u8868\u793a\uff0c\u4ea4\u6613\u76e3\u63a7\u7cfb\u7d71\u7684\u5b8c\u6574\u6027\u548c\u7a69\u5065\u6027\u5c0d\u6301\u7e8c\u6253\u64ca\u91d1\u878d\u72af\u7f6a\u5341\u5206\u91cd\u8981\u3002\u9280\u884c\u9808\u78ba\u4fdd\u5176\u4ea4\u6613\u76e3\u63a7\u7cfb\u7d71\u7684\u8a2d\u7f6e\u5408\u9069\u4e26\u6709\u6548\u904b\u4f5c\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3948719/%E4%BF%A1%E9%8A%80%E5%9C%8B%E9%9A%9B%E9%81%95%E5%8F%8D%E6%89%93%E6%93%8A%E6%B4%97%E9%8C%A2%E6%A2%9D%E4%BE%8B%E8%A2%AB%E7%BD%B0%E6%AC%BE400%E8%90%AC"}, {"title": "\u4eca\u5e74\u9996\u5b97\u5f37\u62cd\u7533\u8acb \u6052\u5730\u7d05\u78e1\u5169\u5e62\u820a\u6a13\u4f30\u503c1.1\u5104", "description": "<p>\u571f\u5730\u5be9\u88c1\u8655\u4eca\u5e74\u6536\u5230\u9996\u5b97\u5f37\u62cd\u7533\u8acb\uff0c\u5c6c\u65bc\u6052\u5730(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00012' >00012</a>)\u4f75\u8cfc\u7684\u7d05\u78e1\u9ec3\u57d4\u8857\u4e00\u5e36\u820a\u6a13\uff0c\u4f30\u503c\u7d041.17\u5104\u5143\u3002</p>\n<p>\u524d\u8ff0\u5305\u62ec\u5169\u5e62\u820a\u6a13\uff1b\u5176\u4e2d\uff0c\u9ec3\u57d4\u885718\u81f320A\u865f\uff0c\u73fe\u70ba8\u5c64\u9ad8\u7684\u820a\u6a13\uff0c\u6a13\u9f6167\u5e74\uff0c\u6052\u5730\u6301\u6709\u7d0470.31%\u696d\u6b0a\u3002\u7531\u65bc\u5f37\u62cd\u7533\u8acb\u9580\u6abb\u4eca\u5929\u8d77\u4e0b\u8abf\uff0c\u4ee4\u8a72\u9805\u76ee\u7684\u7533\u8acb\u9580\u6abb\u7531\u4ee5\u5f80\u7684\u6700\u4f4e\u516b\u6210\uff0c\u964d\u4f4e\u81f370%\uff0c\u4ee4\u8a72\u5730\u6bb5\u5f97\u4ee5\u7b26\u5408\u7533\u8acb\u8cc7\u683c\u3002</p>\n<p>\u81f3\u65bc\u540c\u6642\u4e00\u4f75\u7d0d\u5165\u7533\u8acb\u7684\u5247\u70ba\u9ec3\u57d4\u885722\u81f324\u865f\u548c\u5fc5\u5609\u885788\u81f390A\u865f\uff0c\u540c\u6a23\u6a13\u9ad88\u5c64\u548c\u6a13\u9f6167\u5e74\uff0c\u6052\u5730\u672c\u8eab\u5df2\u7d93\u6301\u6709\u8a72\u9805\u76ee\u7684\u5168\u6578\u696d\u6b0a\u3002</p>\n<p>\u4ee5\u5169\u5e62\u820a\u6a13\u5408\u4f75\u8a08\u7b97\u7684\u8a71\uff0c\u6052\u5730\u6301\u6709\u6574\u500b\u7533\u8acb\u5730\u9ede\u7d0487.5%\u696d\u6b0a\u3002</p>\n<p>\u8cc7\u6599\u986f\u793a\uff0c\u6052\u5730\u4f75\u8cfc\u4e0a\u5740\u591a\u5e74\uff0c\u60df\u7531\u65bc\u5176\u4e2d\u4e00\u7d44\u5c0f\u696d\u4e3b\u6301\u6709\u7d04\u5169\u6210\u696d\u6b0a\uff0c\u9023\u540c\u5176\u4ed6\u5c0f\u696d\u4e3b\uff0c\u4ee4\u5230\u6052\u5730\u96e3\u9054\u5230\u4ee5\u5f80\u7684\u5f37\u62cd\u7533\u8acb\u9580\u6abb80%\uff0c\u4e00\u76f4\u7121\u6cd5\u7533\u8acb\u5f37\u62cd\uff0c\u96a8\u7740\u5f37\u62cd\u9580\u6abb\u6b63\u5f0f\u4e0b\u8abf\uff0c\u7d42\u53ef\u7533\u8acb\u5f37\u62cd\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3948750/%E4%BB%8A%E5%B9%B4%E9%A6%96%E5%AE%97%E5%BC%B7%E6%8B%8D%E7%94%B3%E8%AB%8B+%E6%81%92%E5%9C%B0%E7%B4%85%E7%A3%A1%E5%85%A9%E5%B9%A2%E8%88%8A%E6%A8%93%E4%BC%B0%E5%80%BC1.1%E5%84%84"}, {"title": "YOHO WEST\u4e00\u623f\u5411\u5357\u6708\u79df1.35\u842c", "description": "<p>\u5929\u6c34\u570dYOHO WEST 3A\u5ea7\u9ad8\u5c64A8\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d363\u65b9\u544e\uff0c1\u623f\u9023\u5132\u7269\u5ba4\u9593\u9694\uff0c\u5411\u5357\uff0c\u4ee5\u6708\u79df1.35\u842c\u5143\u79df\u51fa\uff0c\u5be6\u7528\u544e\u79df37.2\u5143\u3002</p>\n<p>\u4e2d\u539f\u5730\u7522\u8868\u793a\uff0c\u696d\u4e3b\u65bc2023\u5e7412\u6708\u4ee5507.1\u842c\u5143\u4e00\u624b\u8cb7\u5165\u55ae\u4f4d\uff0c\u79df\u91d1\u56de\u58313.2\u5398\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3948489/YOHO+WEST%E4%B8%80%E6%88%BF%E5%90%91%E5%8D%97%E6%9C%88%E7%A7%9F1.35%E8%90%AC"}, {"title": "\u7d05\u7403\u8a08\u5283\u4eca\u65e5\u8d77\u4e00\u902310\u65e5\u5168\u6e2f\u5c55\u51fa", "description": "<p>\u7531\u7f8e\u570b\u85dd\u8853\u5bb6Kurt Perschke\u5275\u4f5c\u7684\u300c\u7d05\u7403\u8a08\u5283\u300d\u4eca\u65e5\u8d77\u4e00\u902310\u65e5\u5168\u6e2f\u5c55\u51fa\uff0c\u5c55\u51fa\u6642\u9593\u7531\u65e9\u4e0a11\u9ede\u81f3\u4e0b\u53486\u9ede\uff0c\u9996\u7ad9\u662f\u4e2d\u74b010\u865f\u78bc\u982d\u3002</p>\n<p>\u300c\u7d05\u7403\u8a08\u5283\u300d\u88ab\u8b7d\u70ba\u300c\u4e16\u754c\u4e0a\u6700\u6709\u97cc\u529b\u7684\u8857\u982d\u85dd\u8853\u4f5c\u54c1\u300d\uff0c\u5373\u65e5\u8d77\u81f3\u672c\u670815\u65e5\uff0c\u5728\u9999\u6e2f\u768410\u500b\u4e0d\u540c\u5730\u9ede\u5de1\u5c55\uff0c\u660e\u5929\u7d05\u7403\u5c07\u300c\u5f48\u300d\u5230\u5c0d\u5cb8\u7684\u5c16\u6c99\u5480\uff0c\u878d\u5165\u9999\u6e2f\u85dd\u8853\u9928\uff0c\u6700\u5f8c\u4e00\u5929\u6703\u5728\u592a\u5e73\u5c71\u9802\u7345\u5b50\u4ead\u3002</p>\n<p>\u300c\u7d05\u7403\u8a08\u5283\u300d\u81ea2001\u5e74\u958b\u59cb\uff0c\u5728\u4e16\u754c\u5404\u5730\u5de1\u5c55\uff0c\u9999\u6e2f\u662f\u7b2c48\u7ad9\u3002Kurt Perschke\u8868\u793a\uff0c\u300c\u7d05\u7403\u8a08\u5283\u300d\u63d0\u4f9b\u8b93\u516c\u773e\u91cd\u65b0\u63a2\u7d22\u7368\u7279\u5efa\u7bc9\u7f8e\u5b78\u53ca\u80cc\u5f8c\u6b77\u53f2\u7684\u6a5f\u6703\uff0c\u5e0c\u671b\u900f\u904e\u8b93\u672c\u5730\u89c0\u773e\u3001\u85dd\u8853\u5bb6\u53ca\u65c5\u5ba2\u8207\u300c\u7d05\u7403\u300d\u4e92\u52d5\uff0c\u4ee5\u5d84\u65b0\u7684\u8996\u89d2\u770b\u5f85\u751f\u6d3b\u7684\u5730\u9ede\uff0c\u70ba\u751f\u6d3b\u589e\u6dfb\u65b0\u9bae\u611f\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3948738/%E7%B4%85%E7%90%83%E8%A8%88%E5%8A%83%E4%BB%8A%E6%97%A5%E8%B5%B7%E4%B8%80%E9%80%A310%E6%97%A5%E5%85%A8%E6%B8%AF%E5%B1%95%E5%87%BA"}, {"title": "\u745e\u9280:\u9996\u9078\u4e2d\u570b\u5e02\u5834 \u53ef\u8996\u70ba\u5206\u6563\u6295\u8cc7\u7b56\u7565\u767e\u642d\u724c", "description": "<p>\u745e\u9280\u8cc7\u7522\u7ba1\u7406\u767c\u5e03\u5e74\u7d42\u5831\u544a\u300aThe Red Thread\u300b\u8868\u793a\uff0c\u5c0d\u65bc\u73fe\u5728\u9019\u4e00\u5145\u6eff\u8003\u9a57\u7684\u6642\u671f\u800c\u8a00\uff0c\u53ef\u4ee5\u5c07\u4e2d\u570b\u8996\u4f5c\u5206\u6563\u6295\u8cc7\u7b56\u7565\u4e2d\u7684\u4e00\u5f35\u767e\u642d\u724c\u3002</p>\n<p>\u745e\u9280\u8cc7\u7ba1\u6307\u51fa\uff0c\u96a8\u7740\u5168\u7403\u5e02\u5834\u8da8\u5411\u96c6\u4e2d\u4e14\u96e3\u4ee5\u9810\u6e2c\uff0c\u5206\u6563\u6295\u8cc7\u518d\u6b21\u6210\u70ba\u6295\u8cc7\u5be6\u8e10\u7684\u6838\u5fc3\u539f\u5247\u3002\u745e\u9280\u8cc7\u7ba1\u5168\u7403\u6295\u8cc7\u7e3d\u76e3Barry Gill\u8868\u793a\uff0c\u4e2d\u570b\u5e02\u5834\u662f\u5176\u9996\u9078\uff0c\u662f\u76ee\u524d\u5168\u7403\u6700\u4fbf\u5b9c\u7684\u80a1\u7968\u5e02\u5834\u3002\u7121\u8ad6\u662f\u653f\u7b56\u523a\u6fc0\u9084\u662f\u4f01\u696d\u7684\u8cc7\u672c\u914d\u7f6e\u6c7a\u7b56\u7b49\uff0c\u4e2d\u570b\u5f9e\u8a31\u591a\u65b9\u9762\u90fd\u6709\u6f5b\u529b\u70ba\u6295\u8cc7\u8005\u5e36\u4f86\u9a5a\u559c\u3002\u76f8\u6bd4\u65bc\u6f5b\u5728\u7684\u56de\u5831\uff0c\u6295\u8cc7\u4e2d\u570b\u8cc7\u7522\u7684\u6210\u672c\u4e0d\u8db3\u70ba\u9053\u3002</p>\n<p><strong>\u672a\u4f8612\u81f318\u500b\u6708\u6216\u6709\u66f4\u679c\u65b7\u523a\u6fc0\u63aa\u65bd</strong></p>\n<p>\u745e\u9280\u8cc7\u7ba1\u8a8d\u70ba\uff0c\u4e2d\u570b\u5df2\u8de8\u8d8a\u8f49\u578b\u4e4b\u8def\u4e0a\u6700\u5177\u6311\u6230\u6027\u7684\u6642\u671f\uff0c\u76f8\u4fe1\u672a\u4f8612\u81f318\u500b\u6708\u5167\u53ef\u80fd\u6703\u51fa\u73fe\u66f4\u679c\u65b7\u7684\u523a\u6fc0\u63aa\u65bd\u4ee5\u53ca\u5e02\u5834\u8f49\u8b8a\uff0c\u5f9e\u800c\u70ba\u5404\u7a2e\u8cc7\u7522\u985e\u5225\u5e36\u4f86\u65b0\u7684\u9577\u671f\u8d85\u984d\u56de\u5831\u6a5f\u9047\uff0c\u5c24\u5176\u662f\u4e3b\u52d5\u578b\u591a\u5143\u8cc7\u7522\u7b56\u7565\u3002</p>\n<p><strong>\u91cd\u8996\u6d3e\u606f\u53ca\u56de\u8cfc\u7684\u516c\u53f8\u6709\u671b\u8868\u73fe\u826f\u597d</strong></p>\n<p>\u745e\u9280\u8cc7\u7ba1\u4e2d\u570b\u80a1\u7968\u4e3b\u7ba1\u65bd\u658c\u7a31\uff0c\u5728\u653f\u7b56\u8f49\u5411\u7684\u904e\u7a0b\u4e2d\uff0c\u8003\u616e\u5230\u773e\u591a\u512a\u8cea\u516c\u53f8\u7684\u4f30\u503c\u975e\u5e38\u5177\u6709\u5438\u5f15\u529b\uff0c\u6295\u8cc7\u4e2d\u570b\u80a1\u5e02\u7684\u6a5f\u9047\u975e\u5e38\u6a02\u89c0\uff0c\u5c24\u5176\u770b\u597d\u5728\u570b\u5916\u5e02\u5834\u4f54\u6709\u7387\u4e0d\u65b7\u589e\u9577\u7684\u516c\u53f8\u3002\u7531\u65bc\u6574\u9ad4\u4f01\u696d\u76c8\u5229\u589e\u9577\u5065\u5eb7\uff0c\u91cd\u8996\u4ee5\u6d3e\u606f\u53ca\u80a1\u7968\u56de\u8cfc\u56de\u994b\u6295\u8cc7\u8005\u7684\u516c\u53f8\u6709\u671b\u8868\u73fe\u826f\u597d\u3002</p>\n<p><strong>AI\u570b\u4f01\u53ca\u80fd\u6e90\u8f49\u578b\u7b49\u7e8c\u6210\u6295\u8cc7\u4e3b\u984c</strong></p>\n<p>\u745e\u9280O\u2019Connor\u4e2d\u570b\u80a1\u7968\u591a/\u7a7a\u7b56\u7565\u7814\u7a76\u4e3b\u7ba1\u8983\u7532\u6307\u51fa\uff0c\u5373\u4f7f\u5728\u540c\u4e00\u884c\u696d\u5167\uff0c\u80a1\u7968\u8868\u73fe\u4ea6\u53ef\u80fd\u5448\u73fe\u66f4\u5927\u7684\u5206\u5316\uff0c\u800c\u591a/\u7a7a\u6295\u8cc7\u7b56\u7565\u6216\u8a31\u53ef\u4ee5\u5f88\u597d\u5730\u628a\u63e1\u6ce2\u52d5\u5e36\u4f86\u7684\u6f5b\u5728\u6536\u76ca\u3002\u5c55\u671b\u672a\u4f86\uff0c\u4eba\u5de5\u667a\u6167(AI)\u3001\u570b\u6709\u4f01\u696d\u53ca\u80fd\u6e90\u8f49\u578b\u7b49\u677f\u584a\u6216\u8a31\u6703\u7e7c\u7e8c\u6210\u70ba\u745e\u9280\u7684\u4e3b\u8981\u6295\u8cc7\u4e3b\u984c\uff0c\u5728\u591a/\u7a7a\u982d\u90e8\u7f72\u4e2d\u5e36\u4f86\u8d85\u984d\u56de\u5831\u7684\u6295\u8cc7\u9748\u611f\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3948695/%E7%91%9E%E9%8A%80%3A%E9%A6%96%E9%81%B8%E4%B8%AD%E5%9C%8B%E5%B8%82%E5%A0%B4+%E5%8F%AF%E8%A6%96%E7%82%BA%E5%88%86%E6%95%A3%E6%8A%95%E8%B3%87%E7%AD%96%E7%95%A5%E7%99%BE%E6%90%AD%E7%89%8C"}]}