{"data": [{"title": "\u5348\u9593\u65b0\u805e\u7cbe\u9078:\u9673\u8302\u6ce2\u6599\u4eca\u8ca1\u5e74\u8ca1\u8d64\u5343\u5104 \u9060\u9ad8\u9810\u671f", "description": "<p><span style=\"font-size-ignore:13pt;\">1.</span><a style=\"font-size-ignore:13pt;\" href=\"https://m.hkej.com/landing/mobarticle2/id/3942053\" target=\"_blank\">\u9673\u8302\u6ce2\u6599\u672c\u8ca1\u5e74\u8d64\u5b571000\u5104 \u9060\u9ad8\u9810\u671f</a></p>\n<p>\u8ca1\u653f\u53f8\u53f8\u9577\u9673\u8302\u6ce2\u7a31\uff0c\u521d\u6b65\u4f30\u7b97\u672c\u8ca1\u653f\u5e74\u5ea6\u7684\u7d9c\u5408\u8d64\u5b57\u7d041000\u5104\u5143\uff0c\u9060\u9ad8\u65bc\u5e74\u521d\u9810\u6e2c\u7684481\u5104\u5143\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">2.<a href=\"https://m.hkej.com/landing/mobarticle2/id/3939540\" target=\"_blank\">\u7a05\u8cb8\u4e28\u4ea4\u7a05\u5b63\u7bc0\u6bba\u5230 \u9280\u884c\u7a05\u8cb8\u606f\u4e00\u89bd \u501f20\u842c\u3001100\u842c\u908a\u9593\u6700\u62b5</a></span></p>\n<p>\u6253\u5de5\u4ed4\u4ea4\u7a05\u65e5\u5b50\u6bba\u5230\uff0c\u8a08\u5283\u7533\u8acb\u7a05\u52d9\u8cb8\u6b3e\u61c9\u6025\u7684\u4eba\u58eb\uff0c\u903e10\u9593\u9280\u884c\u5229\u606f\u3001\u512a\u60e0\u540c\u4f60\u9010\u9593\u7747\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">3.<a href=\"https://m.hkej.com/landing/mobarticle2/id/3942149\" target=\"_blank\">\u5929</a></span><a href=\"https://m.hkej.com/landing/mobarticle2/id/3942149\" target=\"_blank\"><span style=\"font-size-ignore:13pt;\">\u8ce6\u6d77\u7063\u56db\u623f\u9023\u8eca\u4f4d\u7d2f\u6e1b780\u842c\u6cbd</span></a></p>\n<p>\u5927\u57d4\u767d\u77f3\u89d2\u5929\u8ce6\u6d77\u70632\u671f\u6e8b\u73a53\u5ea7\u4e2d\u5c64B\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d1522\u65b9\u544e\u9023\u8eca\u4f4d\uff0c\u653e\u552e\u5169\u5e74\uff0c\u7d2f\u6e1b780\u842c\u5143\u6cbd\u51fa\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">4.<a href=\"https://m.hkej.com/landing/mobarticle2/id/3942259\" target=\"_blank\">\u6e2f\u80a1\u534a\u65e5\u534744\u9ede\u5341\u5929\u7dda\u722d\u6301 \u860b\u6982\u80a1\u53d7\u6367 \u80fd\u6e90\u80a1\u5f31</a></span></p>\n<p>\u8ca1\u65b0\u4e2d\u570b11\u6708\u88fd\u9020\u696dPMI\u52dd\u9810\u671f\uff0c\u6e2f\u80a1\u4eca\u65e9\u9032\u4e00\u6b65\u8d70\u9ad8\uff0c\u6052\u6307\u66fe\u5347266\u9ede\uff0c\u4f46\u53d7\u5236\u5eff\u5929\u7dda(\u73fe\u865519806)\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">5.<a href=\"https://m.hkej.com/landing/mobarticle2/id/3941937\" target=\"_blank\">\u62dc\u767b\u8f49\u8eda \u7279\u8d66\u5152\u5b50\u4ea8\u7279</a></span></p>\n<p>\u7f8e\u570b\u7e3d\u7d71\u62dc\u767b\u8f49\u8eda\u7279\u8d66\u5176\u5152\u5b50\u4ea8\u7279(Hunter Biden)\uff0c\u7a31\u5e0c\u671b\u570b\u6c11\u7406\u89e3\u70ba\u4f55\u4e00\u4f4d\u7236\u89aa\u548c\u7e3d\u7d71\u6703\u505a\u51fa\u9019\u6a23\u7684\u6c7a\u5b9a\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3942308/%E5%8D%88%E9%96%93%E6%96%B0%E8%81%9E%E7%B2%BE%E9%81%B8%3A%E9%99%B3%E8%8C%82%E6%B3%A2%E6%96%99%E4%BB%8A%E8%B2%A1%E5%B9%B4%E8%B2%A1%E8%B5%A4%E5%8D%83%E5%84%84+%E9%81%A0%E9%AB%98%E9%A0%90%E6%9C%9F"}, {"title": "\u674e\u5bb6\u8d85:\u7a4d\u6975\u63a8\u9032\u56db\u5927\u6e1b\u78b3\u7b56\u7565 \u529b\u722d2050\u5e74\u524d\u5be6\u73fe\u78b3\u4e2d\u548c", "description": "<p>\u884c\u653f\u9577\u5b98\u674e\u5bb6\u8d85\u4eca\u65e5\u5728\u9999\u6e2f\u74b0\u5883\u5353\u8d8a\u5927\u596c\u9812\u734e\u5178\u79ae\u8996\u50cf\u81f4\u8a5e\u6642\u8868\u793a\uff0c\u4e09\u4e2d\u5168\u6703\u63d0\u51fa\u5fc5\u9808\u5b8c\u5584\u751f\u614b\u6587\u660e\u5236\u5ea6\u9ad4\u7cfb\uff0c\u5354\u540c\u63a8\u9032\u964d\u78b3\u3001\u6e1b\u6c61\u3001\u64f4\u7da0\u3001\u589e\u9577\uff0c\u7a4d\u6975\u61c9\u5c0d\u6c23\u5019\u8b8a\u5316\uff0c\u52a0\u5feb\u5b8c\u5584\u843d\u5be6\u7da0\u6c34\u9752\u5c71\u5c31\u662f\u91d1\u5c71\u9280\u5c71\u7406\u5ff5\u7684\u9ad4\u5236\u6a5f\u5236\u3002</p>\n<p>\u674e\u5bb6\u8d85\u6307\u51fa\uff0c\u70ba\u61c9\u5c0d\u6c23\u5019\u8b8a\u5316\uff0c\u7279\u5340\u653f\u5e9c\u7a4d\u6975\u901a\u904e\u63a8\u9032\u300c\u6de8\u96f6\u767c\u96fb\u300d\u3001\u300c\u7bc0\u80fd\u7da0\u5efa\u300d\u3001\u300c\u7da0\u8272\u904b\u8f38\u300d\u548c\u300c\u5168\u6c11\u6e1b\u5ee2\u300d\u56db\u5927\u6e1b\u78b3\u7b56\u7565\uff0c\u529b\u722d\u57282050\u5e74\u524d\u5be6\u73fe\u78b3\u4e2d\u548c\uff0c\u540c\u6642\u70ba\u570b\u5bb6\u7684\u300c\u96d9\u78b3\u300d\u76ee\u6a19\u4f5c\u51fa\u8ca2\u737b\uff0c\u53732030\u5e74\u524d\u5be6\u73fe\u78b3\u9054\u5cf0\u53ca2060\u524d\u5be6\u73fe\u78b3\u4e2d\u548c\u3002</p>\n<p>\u4ed6\u53c8\u7a31\uff0c\u65b0\u4e00\u4efd\u300a\u65bd\u653f\u5831\u544a\u300b\u63d0\u51fa\u4e00\u7cfb\u5217\u63aa\u65bd\uff0c\u9032\u4e00\u6b65\u4fc3\u9032\u7da0\u8272\u904b\u8f38\u7684\u767c\u5c55\uff0c\u5305\u62ec\u8cc7\u52a9\u7684\u58eb\u548c\u5c08\u71df\u5df4\u58eb\u696d\u754c\u8cfc\u8cb7\u96fb\u52d5\u8eca\u8f1b\uff0c\u4e26\u63a8\u51fa3\u5104\u5143\u65b0\u8a08\u5283\uff0c\u8cc7\u52a9\u79c1\u71df\u6a5f\u69cb\u5b89\u88dd\u9ad8\u901f\u5145\u96fb\u8a2d\u65bd\uff0c\u984d\u5916\u652f\u63f416\u842c\u8f1b\u96fb\u52d5\u8eca\u3002</p>\n<p>\u674e\u5bb6\u8d85\u5f37\u8abf\uff0c\u7279\u5340\u653f\u5e9c\u4e00\u76f4\u901a\u904e\u4f4e\u78b3\u7da0\u8272\u79d1\u7814\u57fa\u91d1\u548c\u5275\u65b0\u53ca\u79d1\u6280\u57fa\u91d1\u652f\u6301\u672c\u5730\u7da0\u8272\u79d1\u6280\u767c\u5c55\uff0c\u7d50\u5408\u9999\u6e2f\u5177\u570b\u969b\u6c34\u5e73\u7684\u5c08\u696d\u670d\u52d9\u548c\u6295\u878d\u8cc7\u512a\u52e2\uff0c\u8b93\u9999\u6e2f\u3001\u5167\u5730\uff0c\u4ee5\u81f3\u5168\u7403\u7684\u4f01\u696d\uff0c\u53ef\u4ee5\u5584\u7528\u9999\u6e2f\u4f5c\u7232\u300c\u8d85\u7d1a\u806f\u7e6b\u4eba\u300d\u548c\u300c\u8d85\u7d1a\u589e\u503c\u4eba\u300d\u7684\u89d2\u8272\uff0c\u4ee5\u9999\u6e2f\u4f5c\u70ba\u7da0\u8272\u79d1\u6280\u793a\u7bc4\u57fa\u5730\uff0c\u958b\u62d3\u65b0\u5e02\u5834\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3942294/%E6%9D%8E%E5%AE%B6%E8%B6%85%3A%E7%A9%8D%E6%A5%B5%E6%8E%A8%E9%80%B2%E5%9B%9B%E5%A4%A7%E6%B8%9B%E7%A2%B3%E7%AD%96%E7%95%A5+%E5%8A%9B%E7%88%AD2050%E5%B9%B4%E5%89%8D%E5%AF%A6%E7%8F%BE%E7%A2%B3%E4%B8%AD%E5%92%8C"}, {"title": "\u9999\u6e2f\u6545\u5bae\u6587\u5316\u535a\u7269\u9928II\u9996\u65e5\u5c01\u660e\u8d77\u767c\u552e \u90f5\u796817\u65e5\u63a8\u51fa", "description": "<p>\u200b\u9999\u6e2f\u90f5\u653f\u516c\u5e03\uff0c<span style=\"font-size-ignore:13pt;\">\u5468\u4e8c\u8d77\u767c\u552e\u300c\u9999\u6e2f\u6545\u5bae\u6587\u5316\u535a\u7269\u9928II\u300d\u7684\u6b63\u5f0f\u9996\u65e5\u5c01\uff0c\u7279\u5225\u90f5\u7968\u53ca\u76f8\u95dc\u90f5\u54c1\u5c07\u65bc\u672c\u670817\u65e5\u8d77\u767c\u552e\uff0c\u800c\u90f5\u8cc7\u5df2\u4ed8\u5716\u7247\u5361(\u7a7a\u90f5\u90f5\u8cc7)\u3001\u73cd\u85cf\u5957\u88dd\u53ca\u8cbc\u6709\u7279\u5225\u90f5\u7968\u7684\u5df2\u84cb\u92b7\u9996\u65e5\u5c01\u53ea\u9650\u5728\u96c6\u90f5\u5c40\u767c\u552e\u3002</span><span style=\"font-size-ignore:13pt;\">\u5404\u90f5\u653f\u5c40\u5c07\u65bc17\u65e5\u70ba\u6240\u6709\u6b63\u5f0f\u9996\u65e5\u5c01/\u7d00\u5ff5\u5c01/\u8a3b\u660e\u9996\u65e5\u5b57\u6a23\u548c\u672c\u5730\u5730\u5740\u7684\u81ea\u88fd\u5c01\uff0c\u63d0\u4f9b\u5373\u6642\u4eba\u624b\u84cb\u5370\u670d\u52d9\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u7e7c2022\u5e74\u767c\u884c\u300c\u9999\u6e2f\u6545\u5bae\u6587\u5316\u535a\u7269\u9928\u300d\u7279\u5225\u90f5\u7968\uff0c\u9999\u6e2f\u90f5\u653f\u7e8c\u4ee5\u300c\u9999\u6e2f\u6545\u5bae\u6587\u5316\u535a\u7269\u9928II\u300d\u70ba\u984c\u767c\u884c\u4e00\u5957\u516d\u679a\u90f5\u7968\u3001\u5169\u6b3e\u90f5\u7968\u5c0f\u578b\u5f35\u53ca\u76f8\u95dc\u96c6\u90f5\u54c1\uff0c\u5c55\u793a\u66f4\u591a\u4f86\u81ea\u6545\u5bae\u535a\u7269\u9662\u7684\u73cd\u8cb4\u85dd\u8853\u6587\u5316\u85cf\u54c1\uff0c\u5305\u62ec\u300c\u6390\u7d72\u743a\u746f\u592a\u5e73\u6709\u8c61\u300d\u3001\u300c\u6390\u7d72\u743a\u746f\u82b1\u5349\u7d0b\u706b\u934b\u300d\u3001\u300c\u91d1\u5d4c\u7389\u77f3\u5bf6\u5854\u300d\u3001\u300c\u756b\u743a\u746f\u82b1\u5349\u958b\u5149\u4eba\u7269\u7d0b\u57f7\u58fa\u300d\u3001\u300c\u91d1\u5927\u5409\u846b\u8606\u639b\u5c4f\u300d\u3001\u300c\u78a7\u7389\u752a\u7aef\u9999\u7210\u300d\u3001\u300c\u9285\u934d\u91d1\u756b\u743a\u746f\u56db\u9762\u76e4\u9418\u300d\u53ca\u300c\u91d1\u4ea4\u9f8d\u7d10\u300e\u5929\u5b50\u4e4b\u5bf6\u300f\u300d\uff0c\u9ad4\u73fe\u4e2d\u83ef\u6587\u660e\u7684\u535a\u5927\u7cbe\u6df1\uff0c\u4e26\u63a8\u52d5\u516c\u773e\u5c0d\u4e2d\u570b\u85dd\u8853\u548c\u6587\u5316\u7684\u7814\u7a76\u548c\u6b23\u8cde\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3942185/%E9%A6%99%E6%B8%AF%E6%95%85%E5%AE%AE%E6%96%87%E5%8C%96%E5%8D%9A%E7%89%A9%E9%A4%A8II%E9%A6%96%E6%97%A5%E5%B0%81%E6%98%8E%E8%B5%B7%E7%99%BC%E5%94%AE+%E9%83%B5%E7%A5%A817%E6%97%A5%E6%8E%A8%E5%87%BA"}, {"title": "\u6e2f\u9435\u5c6f\u9580\u5357\u5ef6\u7dda\u6cb3\u4e0a\u9ad8\u67b6\u6a4b\u5de5\u7a0b\u660e\u5e74\u5c55\u958b \u65992028\u5e74\u5b8c\u5de5", "description": "<p>\u6e2f\u9435\u5c6f\u9580\u5357\u5ef6\u7dda\u9805\u76ee\uff0c\u660e\u5e74\u5c07\u5c55\u958b\u5728\u5c6f\u9580\u6cb3\u4e0a\u5efa\u9020\u9ad8\u67b6\u6a4b\u5de5\u7a0b\uff0c\u9810\u8a08\u7d042028\u5e74\u5b8c\u5de5\uff0c\u6574\u500b\u5c6f\u9580\u5357\u5ef6\u7dda\u9805\u76ee\u9810\u8a08\u65bc2030\u5e74\u843d\u6210\u3002</p>\n<p>\u9805\u76ee\u5c07\u8208\u5efa2\u500b\u65b0\u8eca\u7ad9\uff0c\u5305\u62ec\u7b2c16\u5340\u4e2d\u9014\u7ad9\u53ca\u5c6f\u9580\u5357\u65b0\u7d42\u9ede\u7ad9\uff0c\u5176\u4e2d\u9ad8\u67b6\u6a4b\u6bb5\u9577\u7d041.7\u516c\u91cc\uff0c\u9023\u540c\u4e00\u689d\u9577\u7d04250\u7c73\u7684\u8de8\u6cb3\u9435\u8def\u6a4b\uff0c\u903e75%\u6a4b\u6bb5\u5750\u843d\u65bc\u5c6f\u9580\u6cb3\u4e0a\u3002</p>\n<p>\u6e2f\u9435\u8868\u793a\uff0c\u6703\u4ee5\u8f49\u63db\u6a11\u53d6\u4ee3\u8208\u5efa\u65bc\u6cb3\u9053\u5167\u7684\u6a01\u5e3d\uff0c\u800c\u8de8\u6cb3\u9435\u8def\u6a4b\u6703\u4ee52\u500bV\u578b\u6a4b\u58a9\u627f\u6258\u7d041.1\u842c\u516c\u5678\u6a4b\u8eab\uff0c\u76e1\u91cf\u6e1b\u5c11\u6a4b\u58a9\u6578\u91cf\uff0c\u53ca\u63a1\u7528\u66f4\u7e96\u5de7\u8a2d\u8a08\uff0c\u6e1b\u5c11\u4f54\u7528\u6cb3\u9053\u7684\u9762\u7a4d\uff0c\u4ee5\u4fdd\u7559\u5c6f\u9580\u6cb3\u958b\u95ca\u7684\u8996\u91ce\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3942258/%E6%B8%AF%E9%90%B5%E5%B1%AF%E9%96%80%E5%8D%97%E5%BB%B6%E7%B7%9A%E6%B2%B3%E4%B8%8A%E9%AB%98%E6%9E%B6%E6%A9%8B%E5%B7%A5%E7%A8%8B%E6%98%8E%E5%B9%B4%E5%B1%95%E9%96%8B+%E6%96%992028%E5%B9%B4%E5%AE%8C%E5%B7%A5"}, {"title": "\u6703\u8ca1\u5c40\u8209\u8fa6\u8ad6\u58c7\u91cd\u5efa\u516c\u773e\u5c0d\u6703\u8a08\u53ca\u5be9\u8a08\u5c08\u696d\u4fe1\u5fc3", "description": "<p>\u6703\u8ca1\u5c40\u8209\u8fa6\u5340\u57df\u76e3\u7ba1\u8ad6\u58c7\uff0c\u70ba\u9996\u500b\u7531\u5be9\u8a08\u76e3\u7ba1\u6a5f\u69cb\u4e3b\u8fa6\uff0c\u5c08\u70ba\u6703\u8a08\u5c08\u696d\u7684\u76e3\u7ba1\u6a5f\u69cb\u548c\u53d7\u76e3\u7ba1\u5e02\u5834\u800c\u8a2d\u7684\u8ad6\u58c7\u3002<span style=\"font-size-ignore:13pt;\">\u8ad6\u58c7\u5438\u5f15\u4e86\u8d85\u904e350\u540d\u4f86\u81ea\u570b\u969b\u3001\u5167\u5730\u53ca\u672c\u5730\u7684\u53c3\u8207\u8005\uff0c\u7576\u4e2d\u5305</span><span style=\"font-size-ignore:13pt;\">\u62ec\u6703\u8a08\u53ca\u91d1\u878d\u76e3\u7ba1\u6a5f\u69cb\u3001\u57f7\u6cd5\u6a5f\u69cb\u3001\u56db\u5927\u570b\u969b\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240\u7684\u5168\u7403\u4e3b\u5e2d\u53ca\u526f\u4e3b\u5e2d\u3001\u5c08\u696d</span><span style=\"font-size-ignore:13pt;\">\u7d44\u7e54\u3001\u6703\u8a08\u5c08\u696d\u4eba\u58eb\u3001\u6295\u8cc7\u8005\u4ee5\u53ca\u5546\u696d\u9818\u8896\u3002</span></p>\n<p>\u8ca1\u653f\u53f8\u53f8\u9577\u9673\u8302\u6ce2\u5728\u958b\u5834\u81f4\u8a5e\u4e2d\u8868\u793a\uff0c\u76e3\u7ba1\u672c\u8eab\u4e26\u975e\u6700\u7d42\u7684\u76ee\u6a19\uff0c\u800c\u662f\u4f5c\u70ba\u4fc3\u9032\u6301\u7e8c\u767c\u5c55\u7684\u65b9\u6cd5\uff0c\u70ba\u6240\u6709\u4eba\u5275\u9020\u9577\u9060\u5229\u76ca\u3002\u8207\u672c\u6e2f\u5176\u4ed6\u91d1\u878d\u76e3\u7ba1\u6a5f\u69cb\u4e00\u6a23\uff0c\u6703\u8ca1\u5c40\u80a9\u8ca0\u7740\u96d9\u91cd\u4f7f\u547d\uff0c\u5728\u78ba\u4fdd\u9ad8\u6c34\u5e73\u8ca1\u52d9\u6ed9\u5831\u7684\u540c\u6642\uff0c\u652f\u6301\u548c\u4fc3\u9032\u6703\u8a08\u884c\u696d\u7684\u767c\u5c55\u3002</p>\n<p>\u6703\u8ca1\u5c40\u4e3b\u5e2d\u9ec3\u5929\u7950\u6307\u51fa\uff0c\u6703\u8a08\u5e2b\u548c\u6703\u8a08\u5e2b\u4e8b\u52d9\u6240\u5728\u652f\u6301\u8cc7\u672c\u5e02\u5834\u7a69\u5b9a\u548c\u767c\u5c55\u65b9\u9762\u767c\u63ee\u7740\u95dc\u9375\u800c\u795e\u8056\u7684\u89d2\u8272\uff0c\u901a\u904e\u53ef\u9760\u7684\u4f01\u696d\u6ed9\u5831\u4f86\u4fdd\u969c\u516c\u773e\u5229\u76ca\uff0c\u4e26\u978f\u56fa\u6295\u8cc7\u8005\u4fe1\u5fc3\u3002\u5c55\u671b\u672a\u4f86\uff0c\u671f\u671b\u6240\u6709\u4e3b\u8981\u6301\u4efd\u8005\u5747\u81f4\u529b\u65bc\u6301\u7e8c\u6539\u9032\u5404\u81ea\u7684\u6587\u5316\u548c\u7ba1\u6cbb\u5be6\u8e10\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3942277/%E6%9C%83%E8%B2%A1%E5%B1%80%E8%88%89%E8%BE%A6%E8%AB%96%E5%A3%87%E9%87%8D%E5%BB%BA%E5%85%AC%E7%9C%BE%E5%B0%8D%E6%9C%83%E8%A8%88%E5%8F%8A%E5%AF%A9%E8%A8%88%E5%B0%88%E6%A5%AD%E4%BF%A1%E5%BF%83"}, {"title": "\u9673\u8302\u6ce2:\u8ca1\u653f\u8a08\u5283\u4e3b\u529b\u524a\u958b\u652f \u5c0d\u958b\u6e90\u76f8\u7576\u5fcd\u624b", "description": "<p>\u8ca1\u653f\u53f8\u53f8\u9577\u9673\u8302\u6ce2\u8868\u793a\uff0c\u521d\u6b65\u4f30\u7b97\u672c\u8ca1\u653f\u5e74\u5ea6\u7684\u7d9c\u5408\u8d64\u5b57\u7d041000\u5104\u5143\uff0c\u9ad8\u65bc\u300a\u8ca1\u653f\u9810\u7b97\u6848\u300b\u9810\u8a08\u7684481\u5104\u5143\uff0c\u56e0\u8ce3\u5730\u548c\u88dc\u5730\u50f9\u6536\u5165\u5927\u5e45\u4e0b\u6ed1\uff0c\u62d6\u7d2f\u571f\u5730\u6536\u5165\u8868\u73fe\u3002\u53e6\u5916\uff0c9\u6708\u524d\u6a13\u5e02\u4ea4\u6613\u91cf\u5c11\uff0c\u5f71\u97ff\u76f8\u95dc\u5370\u82b1\u7a05\u6536\u5165\uff1b\u4f01\u696d\u7d93\u71df\u60c5\u6cc1\u4ea6\u4e0d\u53ca\u60f3\u50cf\u4e2d\u597d\uff0c\u4ee4\u5229\u5f97\u7a05\u6536\u5165\u6e1b\u5c11\u3002</p>\n<p>\u9673\u8302\u6ce2\u8868\u793a\uff0c\u7279\u5340\u653f\u5e9c\u7684\u8ca1\u653f\u8a08\u5283\u4e3b\u529b\u5728\u65bc\u524a\u6e1b\u958b\u652f\uff0c\u589e\u52a0\u6536\u5165\u53ea\u662f\u8f14\u52a9\u5f62\u5f0f\uff0c\u5f62\u5bb9\u653f\u5e9c\u5c0d\u65bc\u300c\u958b\u6e90\u300d\u7684\u505a\u6cd5\u76f8\u7576\u5fcd\u624b\uff0c\u76e1\u91cf\u6e1b\u4f4e\u5c0d\u4e00\u822c\u5e02\u6c11\u53ca\u4e2d\u7522\u4eba\u58eb\u7684\u5f71\u97ff\u3002\u7576\u5c40<span style=\"font-size-ignore:13pt;\">\u6b63\u6309\u8a08\u5283\u524a\u6e1b\u958b\u652f\uff0c\u6703\u8207\u4e0d\u540c\u653f\u7b56\u5c40\u6e9d\u901a\uff0c\u6aa2\u8996\u662f\u5426\u6709\u7a7a\u9593\u9032\u4e00\u6b65\u524a\u6e1b\u958b\u652f\uff0c\u7814\u7a76\u5982\u4f55\u52a0\u5927\u529b\u5ea6\u63a8\u9032\u3002\u4f46\u4ed6\u7a31\uff0c\u798f\u5229\u3001\u91ab\u7642\u53ca\u6559\u80b2\u958b\u652f\u90fd\u8207\u6c11\u751f\u76f8\u95dc\uff0c\u9762\u5c0d\u4eba\u53e3\u6025\u901f\u8001\u9f61\u5316\uff0c\u91ab\u7642\u548c\u798f\u5229\u958b\u652f\u589e\u9577\u7684\u78ba\u6703\u6709\u58d3\u529b\u3002</span></p>\n<p>\u653f\u5e9c\u8fd1\u5e74\u589e\u52a0\u767c\u50b5\uff0c\u9673\u8302\u6ce2\u8868\u793a\uff0c\u96c6\u8cc7\u6240\u5f97\u4e3b\u8981\u7528\u4f5c\u57fa\u5efa\u9805\u76ee\u6295\u5165\uff0c\u4f8b\u5982\u5317\u90e8\u90fd\u6703\u5340\u3002\u653f\u5e9c\u4e0d\u5e0c\u671b\u56e0\u70ba\u77ed\u671f\u7d93\u6fdf\u5468\u671f\u9ad8\u4f4e\uff0c\u800c\u5f71\u97ff\u7d93\u6fdf\u5bb9\u91cf\u64f4\u5145\u548c\u9577\u671f\u898f\u5283\u3002</p>\n<p>\u4ed6\u53c8\u8aaa\uff0c\u5373\u4f7f\u7d93\u904e\u8fd1\u5e74\u767c\u50b5\u5f8c\uff0c\u672c\u6e2f\u50b5\u52d9\u4f54\u672c\u5730\u751f\u7522\u7e3d\u503c(GDP)\u6bd4\u91cd\uff0c\u53ea\u6703\u7531\u4eca\u5e743\u6708\u5e95\u6642\u7684\u7d046.5%\uff0c\u589e\u52a0\u5230\u7d0413%\u81f314%\uff0c\u76f8\u5c0d\u5168\u7403\u767c\u9054\u7d93\u6fdf\u9ad4\u4ecd\u5c6c\u8f03\u7a69\u5065\uff0c\u6bcb\u9808\u592a\u6182\u616e\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3942244/%E9%99%B3%E8%8C%82%E6%B3%A2%3A%E8%B2%A1%E6%94%BF%E8%A8%88%E5%8A%83%E4%B8%BB%E5%8A%9B%E5%89%8A%E9%96%8B%E6%94%AF+%E5%B0%8D%E9%96%8B%E6%BA%90%E7%9B%B8%E7%95%B6%E5%BF%8D%E6%89%8B"}, {"title": "\u9673\u8302\u6ce2\u6599\u7f8e\u570b\u6e1b\u606f\u7bc0\u594f\u653e\u6162 \u6216\u6291\u58d3\u672c\u5730\u6d88\u8cbb", "description": "<p>\u8ca1\u653f\u53f8\u53f8\u9577\u9673\u8302\u6ce2\u8868\u793a\uff0c2025\u5e74\u74b0\u7403\u7d93\u6fdf\u4ecd\u7136\u9762\u5c0d\u5f88\u591a\u4e0d\u78ba\u5b9a\u6027\uff0c\u7279\u5225\u662f\u7f8e\u570b\u65b0\u4e00\u5c46\u653f\u5e9c\u7684\u7d93\u6fdf\u653f\u7b56\uff0c\u9999\u6e2f\u4f5c\u70ba\u7d30\u5c0f\u5916\u5411\u578b\u7d93\u6fdf\u9ad4\u96e3\u514d\u6703\u53d7\u5230\u5f71\u97ff\u3002</p>\n<p>\u5728\u7acb\u6cd5\u6703\u8ca1\u7d93\u4e8b\u52d9\u59d4\u54e1\u6703\u6703\u8b70\u4e0a\uff0c\u6709\u8b70\u54e1\u95dc\u6ce8\u7f8e\u570b\u5019\u4efb\u7e3d\u7d71\u7279\u6717\u666e\u672a\u4f86\u7684\u65bd\u653f\u65b9\u5411\u6216\u6703\u5f71\u97ff\u7f8e\u5143\u8d70\u52e2\uff0c\u5f9e\u800c\u5f71\u97ff\u9999\u6e2f\u7d93\u6fdf\u3002\u9673\u8302\u6ce2\u8868\u793a\uff0c\u9810\u671f\u7f8e\u570b\u65b0\u653f\u5e9c\u5c07\u6703\u5be6\u65bd\u64f4\u5f35\u6027\u8ca1\u653f\u653f\u7b56\uff0c\u53ef\u80fd\u6703\u589e\u52a0\u7576\u5730\u901a\u8139\u58d3\u529b\uff0c\u6e1b\u6162\u5229\u7387\u4e0b\u8abf\u6b65\u4f10\u3002\u9664\u4e86\u5f71\u97ff\u5168\u7403\u7d93\u6fdf\u4fe1\u5fc3\u53ca\u589e\u9577\uff0c\u4ea6\u6703\u5f71\u97ff\u9999\u6e2f\u7684\u5229\u7387\u74b0\u5883\u3002\u96a8\u7740\u6e1b\u606f\u7bc0\u594f\u653e\u6162\uff0c\u6e2f\u5143\u504f\u5f37\u7684\u6642\u9593\u6703\u5ef6\u9577\uff0c\u5f71\u97ff\u672c\u5730\u8ca8\u7269\u53ca\u670d\u52d9\u7684\u5438\u5f15\u529b\uff0c\u6291\u58d3\u5e02\u6c11\u53ca\u65c5\u5ba2\u5728\u6e2f\u6d88\u8cbb\u3002</p>\n<p>\u5c0d\u65bc\u806f\u7e6b\u6ed9\u7387\uff0c\u9673\u8302\u6ce2\u91cd\u7533\uff0c\u806f\u7e6b\u6ed9\u7387\u81ea1983\u5e74\u8d77\u5be6\u65bd\uff0c\u96d6\u7136\u904e\u53bb\u5e7e\u5e74\u7d93\u6b77\u9ad8\u9ad8\u4f4e\u4f4e\u7684\u7d93\u6fdf\u5468\u671f\uff0c\u4f46\u806f\u7e6b\u6ed9\u7387\u5236\u5ea6\u4e00\u76f4\u884c\u4e4b\u6709\u6548\uff0c\u4ea6\u6703\u6301\u7e8c\u5be6\u65bd\u3002</p>\n<p>\u7279\u6717\u666e\u63da\u8a00\u5c07\u5c0d\u4e2d\u570b\u3001\u52a0\u62ff\u5927\u53ca\u58a8\u897f\u54e5\u5927\u5e45\u52a0\u5fb5\u95dc\u7a05\uff0c\u9673\u8302\u6ce2\u8a8d\u70ba\uff0c\u9019\u5c07\u5e72\u64fe\u74b0\u7403\u8cbf\u6613\u53ca\u6295\u8cc7\u5f80\u4f86\uff0c\u4e26\u5f15\u767c\u5176\u4ed6\u7d93\u6fdf\u9ad4\u7684\u53cd\u5236\u63aa\u65bd\uff0c\u9999\u6e2f\u51fa\u53e3\u7279\u5225\u662f\u5167\u5730\u8f38\u4f4f\u7f8e\u570b\u7684\u8f49\u53e3\u5c07\u6703\u53d7\u5230\u5f71\u97ff\u3002<span style=\"font-size-ignore:13pt;\">\u4f46\u5167\u5730\u5927\u529b\u63d0\u632f\u7d93\u6fdf\u7684\u63aa\u65bd\uff0c\u5c07\u60e0\u53ca\u9999\u6e2f\u4e0d\u540c\u7d93\u6fdf\u74b0\u7bc0\u3002\u800c\u9999\u6e2f\u8fd1\u5e74\u4ea6\u81f4\u529b\u64f4\u5927\u7d93\u6fdf\u5bb9\u91cf\uff0c\u63d0\u5347\u7af6\u722d\u529b\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u4ed6\u63d0\u5230\uff0c\u7279\u5340\u653f\u5e9c\u5c07\u4e00\u65b9\u9762\u767c\u5c55\u9999\u6e2f\u6210\u70ba\u9ad8\u589e\u503c\u4f9b\u61c9\u93c8\u7269\u6d41\u93c8\u7ba1\u61c9\u4e2d\u5fc3\uff0c\u53e6\u4e00\u65b9\u9762\u9f13\u52f5\u4f01\u696d\u51fa\u6d77\u3001\u51fa\u570b\u3002\u540c\u6642\u4ea6\u81f4\u529b\u958b\u62d3\u6771\u76df\u53ca\u4e2d\u6771\u5e02\u5834\uff0c\u5438\u5f15\u6d77\u5916\u516c\u53f8\u4f86\u9999\u6e2f\u8a2d\u7acb\u5340\u57df\u4ee5\u81f3\u570b\u969b\u7e3d\u90e8\uff0c\u652f\u6301\u5728\u6e2f\u767c\u5c55\u5883\u5916\u696d\u52d9\u767c\u5c55\uff0c\u5438\u5f15\u66f4\u591a\u8cc7\u91d1\u4f86\u6e2f\u3002</span></p>\n<p>\u9673\u8302\u6ce2\u5f37\u8abf\uff0c\u9999\u6e2f\u8981\u5584\u7528\u81ea\u8eab\u512a\u52e2\uff0c\u4ee5\u5be6\u73fe\u7d93\u6fdf\u9ad8\u8cea\u91cf\u53ef\u6301\u7e8c\u767c\u5c55\u3002\u800c\u300a\u65bd\u653f\u5831\u544a\u300b\u63d0\u51fa\u4e00\u7cfb\u5217\u767c\u5c55\u7d93\u6fdf\u63aa\u65bd\uff0c\u4ea6\u70ba\u672c\u5730\u7d93\u6fdf\u6ce8\u5165\u65b0\u52d5\u529b\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3942151/%E9%99%B3%E8%8C%82%E6%B3%A2%E6%96%99%E7%BE%8E%E5%9C%8B%E6%B8%9B%E6%81%AF%E7%AF%80%E5%A5%8F%E6%94%BE%E6%85%A2+%E6%88%96%E6%8A%91%E5%A3%93%E6%9C%AC%E5%9C%B0%E6%B6%88%E8%B2%BB"}, {"title": "\u674e\u5bb6\u8d85:\u63d0\u5347\u9999\u6e2f\u5b78\u8853\u767c\u5c55 \u63a8\u52d5\u5927\u7063\u5340\u6210\u570b\u969b\u5275\u79d1\u6a1e\u7d10", "description": "<p><span style=\"font-size-ignore:13pt;\">\u884c\u653f\u9577\u5b98\u674e\u5bb6\u8d85\u5728\u5927\u5b78\u6821\u9577\u9ad8\u5cf0\u8ad6\u58c7\u4e0a\u81f4\u8a5e\u6642\u8868\u793a\uff0c\u9999\u6e2f\u4f5c\u70ba\u5927\u7063\u5340\u57ce\u5e02\u4e4b\u4e00\uff0c\u672a\u4f86\u5c07\u63d0\u5347\u5b78\u8853\u53ca\u7814\u7a76\u767c\u5c55\u3001\u77e5\u8b58\u8f49\u79fb\u4ee5\u81f3\u5de5\u696d\u548c\u5546\u696d\u5316\u7b49\uff0c\u63a8\u52d5\u5927\u7063\u5340\u767c\u5c55\u6210\u70ba\u570b\u969b\u5275\u65b0\u548c\u79d1\u6280\u6a1e\u7d10\u3002</span></p>\n<p>\u674e\u5bb6\u8d85\u8868\u793a\uff0c\u73fe\u6642\u672c\u6e2f\u67095\u9593\u5927\u5b78\u6392\u540d\u4e16\u754c100\u540d\u4e4b\u5167\uff0c\u66f4\u67093\u9593\u6392\u540d\u4e9e\u6d32\u982d10\u4f4d\uff0c\u53d7\u60e0\u300c\u4e00\u570b\u5169\u5236\u300d\uff0c\u9999\u6e2f\u5f97\u5230\u7956\u570b\u652f\u6301\uff0c\u4f5c\u70ba\u4e9e\u6d32\u570b\u969b\u57ce\u5e02\uff0c\u5438\u5f15\u4f86\u81ea\u903e100\u500b\u570b\u5bb6\u7684\u5b78\u751f\u5230\u6e2f\u5b78\u7fd2\uff0c\u6709\u95dc\u57fa\u790e\u4e0a\uff0c\u9999\u6e2f\u5c07\u767c\u5c55\u6210\u70ba\u570b\u969b\u5c08\u4e0a\u6559\u80b2\u6a1e\u7d10\u3002</p>\n<p>\u4ed6\u53c8\u7a31\uff0c\u65b0\u4e00\u4efd\u300a\u65bd\u653f\u5831\u544a\u300b\u6253\u9020\u300c\u7559\u5b78\u9999\u6e2f\u300d\u54c1\u724c \uff0c\u63a8\u52d5\u672c\u6e2f\u5c08\u4e0a\u9662\u6821\u63d0\u5347\u8207\u5404\u5730\u9662\u6821\u4ea4\u6d41\uff0c\u5438\u5f15\u6771\u76df\u53ca\u5176\u4ed6\u300c\u4e00\u5e36\u4e00\u8def\u300d\u570b\u5bb6\u7684\u5b78\u751f\u4f86\u6e2f\u5347\u5b78\uff0c\u6b64\u5916<span style=\"font-size-ignore:13pt;\">\uff0c\u5317\u90e8\u90fd\u6703\u5340\u5c07\u6703\u5efa\u8a2d\u5927\u5b78\u57ce\uff0c\u653f\u5e9c\u9f13\u52f5\u672c\u6e2f\u7684\u9662\u6821\u767c\u6398\u66f4\u591a\u5177\u5275\u610f\u7684\u8a08\u5283\u53ca\u7814\u7a76\uff0c\u8207\u5167\u5730\u53ca\u6d77\u5916\u5927\u5b78\u4ea4\u6d41\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3942148/%E6%9D%8E%E5%AE%B6%E8%B6%85%3A%E6%8F%90%E5%8D%87%E9%A6%99%E6%B8%AF%E5%AD%B8%E8%A1%93%E7%99%BC%E5%B1%95+%E6%8E%A8%E5%8B%95%E5%A4%A7%E7%81%A3%E5%8D%80%E6%88%90%E5%9C%8B%E9%9A%9B%E5%89%B5%E7%A7%91%E6%A8%9E%E7%B4%90"}, {"title": "\u6eec\u6df1\u80a1\u5e02\u534a\u65e5\u5347\u903e1%", "description": "<p>A\u80a1\u9020\u597d\uff0c\u6eec\u6df1\u80a1\u5e02\u534a\u65e5\u5347\u903e1%\u3002</p>\n<p>\u4e0a\u8b49\u6307\u6578\u6700\u591a\u8dcc3\u9ede\u62160.1%\uff0c\u4f4e\u898b3323\u9ede\uff0c\u96a8\u5f8c\u6709\u8cb7\u76e4\u5438\u7d0d\uff0c\u5927\u5e02\u8f49\u5347\uff0c\u6700\u591a\u534735\u9ede\u62161.05%\uff0c\u9ad8\u898b3361\u9ede\uff0c\u534a\u65e5\u6536\u5e02\u58313360\u9ede\uff0c\u534733\u9ede\u62161.02%\uff0c\u6210\u4ea44462.14\u5104\u5143(\u4eba\u6c11\u5e63\u2027\u4e0b\u540c)\u3002</p>\n<p>\u6df1\u6210\u6307\u6700\u591a\u8dcc28\u9ede\u62160.26%\uff0c\u4f4e\u898b10583\u9ede\u5f8c\u6709\u627f\u58d3\u56de\u7a69\uff0c\u6700\u591a\u5012\u5347154\u9ede\u62161.45%\uff0c\u9ad8\u898b10766\u9ede\uff0c\u534a\u65e5\u6536\u5e02\u583110743\u9ede\uff0c\u5347131\u9ede\u62161.24%\uff0c\u6210\u4ea46809.45\u5104\u5143\u3002</p>\n<p>\u6eec\u6df1300\u6307\u6578\u6536\u58313944\u9ede\uff0c\u534727\u9ede\u62160.7%\uff1b\u5275\u696d\u677f\u6307\u6578\u6536\u58312255\u9ede\uff0c\u534731\u9ede\u62161.41%\u3002</p>\n<p>\u5404\u677f\u584a\u666e\u904d\u8d70\u9ad8\uff0c\u92fc\u9435\u3001\u50b3\u5a92\u5a1b\u6a02\u3001\u6c7d\u8eca\u88fd\u9020\u3001\u623f\u5730\u7522\u80a1\u5347\u903e2%\uff1b\u77f3\u6cb9\u3001\u96fb\u529b\u3001\u6c34\u6ce5\u3001\u5316\u5de5\u3001\u751f\u7269\u88fd\u85e5\u80a1\u5347\u903e1%\uff1b\u6709\u8272\u91d1\u5c6c\u3001\u7164\u70ad\u3001\u91d1\u878d\u80a1\u9760\u7a69\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3942150/%E6%BB%AC%E6%B7%B1%E8%82%A1%E5%B8%82%E5%8D%8A%E6%97%A5%E5%8D%87%E9%80%BE1%25"}, {"title": "\u9280\u6e56\u5929\u5cf0\u9cf3\u51f0\u5c64\u5169\u623f819\u842c\u6613\u4e3b", "description": "<p><span style=\"font-size-ignore:13pt;\">\u99ac\u978d\u5c71\u9280\u6e56\u5929\u5cf07\u5ea7\u9cf3\u51f0\u5c64\u6236\uff0c\u5be6\u7528\u9762\u7a4d564\u65b9\u544e\uff0c2\u623f\u9593\u9694\u3002\u55ae\u4f4d\u65e9\u524d\u4ee5900\u842c\u5143\u653e\u552e\uff0c\u5c4b\u82d1\u540c\u985e\u55ae\u4f4d\u5c11\u6709\u653e\u76e4\uff0c\u7d93\u591a\u756a\u8b70\u50f9\u5f8c\uff1b\u55ae\u4f4d\u7d42\u4ee5819.8\u842c\u5143\u6613\u4e3b\uff0c\u5be6\u7528\u544e\u50f9\u7d0414535\u5143\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u7f8e\u806f\u7269\u696d\u8868\u793a\uff0c</span><span style=\"font-size-ignore:13pt;\">\u539f\u696d\u4e3b2010\u4ee5431.5\u842c\u5143\u8cfc\u5165\u55ae\u4f4d\u53ca\u8eca\u4f4d\uff0c\u6301\u8ca814\u5e74\uff0c\u662f\u6b21\u8f49\u624b\u8cec\u9762\u5347\u503c388.3\u842c\u5143\u6216\u7d0490%\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3942122/%E9%8A%80%E6%B9%96%E5%A4%A9%E5%B3%B0%E9%B3%B3%E5%87%B0%E5%B1%A4%E5%85%A9%E6%88%BF819%E8%90%AC%E6%98%93%E4%B8%BB"}]}