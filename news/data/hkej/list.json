article/3947037/%E4%BA%BA%E8%A1%8C%E9%80%86%E5%9B%9E%E8%B3%BC%E9%99%8D%E8%87%B3373%E5%84%84%E4%BA%BA%E5%B9%A3"}, {"title": "\u4eba\u6c11\u5e63\u4e2d\u9593\u50f9\u534755\u9ede\u5b50", "description": "<p>\u4eba\u6c11\u5e63\u514c\u7f8e\u5143\u4e2d\u9593\u50f9\u58317.1879\uff0c\u8f03\u4e0a\u65e5\u58317.1934\uff0c\u4e0a\u8abf55\u9ede\u5b50\u62160.08%\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3947036/%E4%BA%BA%E6%B0%91%E5%B9%A3%E4%B8%AD%E9%96%93%E5%83%B9%E5%8D%8755%E9%BB%9E%E5%AD%90"}, {"title": "\u8c9d\u7d22\u65af:\u7279\u6717\u666e\u53ef\u52a9\u6e1b\u5c11\u76e3\u7ba1", "description": "<p><span style=\"font-size-ignore:13pt;\">\u96fb\u5546\u5e73\u53f0\u4e9e\u99ac\u905c\u5275\u8fa6\u4eba\u8c9d\u7d22\u65af(Jeff Bezos)\u8868\u793a\uff0c\u6709\u4fe1\u5fc3\u7f8e\u570b\u5019\u4efb\u7e3d\u7d71\u7279\u6717\u666e\u4e0a\u4efb\u5f8c\uff0c\u53ef\u70ba\u5546\u754c\u63d0\u4f9b\u4e00\u500b\u66f4\u53cb\u5584\u7684\u76e3\u7ba1\u74b0\u5883\u3002</span></p>\n<p>\u8c9d\u7d22\u65af\u5728\u51fa\u5e2d\u6d3b\u52d5\u6642\u7a31\uff0c\u5c0d\u65bc\u4e8b\u4ef6\u767c\u5c55\u65b9\u5411\u611f\u5230\u6a02\u89c0\uff0c\u800c\u5982\u679c\u5c0d\u65b9\u6709\u9700\u8981\u7684\u8a71\uff0c\u4ed6\u4e5f\u53ef\u63d0\u4f9b\u5354\u52a9\u3002</p>\n<p>\u5e02\u5834\u666e\u904d\u8a8d\u70ba\uff0c\u5728\u7279\u6717\u666e\u9996\u500b\u7e3d\u7d71\u4efb\u671f\u5167\uff0c\u8c9d\u7d22\u65af\u8207\u4ed6\u7684\u95dc\u4fc2\u76f8\u7576\u7dca\u5f35\u3002\u7279\u6717\u666e\u591a\u6b21\u6279\u8a55\u8c9d\u7d22\u65af\uff0c\u4ed6\u64c1\u6709\u7684\u300a\u83ef\u76db\u9813\u90f5\u5831\u300b\u53ca\u4e9e\u99ac\u905c\u3002</p>\n<p>\u4e0d\u904e\uff0c\u8c9d\u7d22\u65af\u8207\u7279\u6717\u666e\u4eca\u5e74\u7684\u95dc\u4fc2\u8f03\u7de9\u548c\u3002\u7279\u6717\u666e11\u67085\u65e5\u7576\u9078\u5f8c\uff0c\u8c9d\u7d22\u65af\u5411\u4ed6\u5169\u5ea6\u767c\u51fa\u795d\u8cc0\u5e16\u6587\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3947034/%E8%B2%9D%E7%B4%A2%E6%96%AF%3A%E7%89%B9%E6%9C%97%E6%99%AE%E5%8F%AF%E5%8A%A9%E6%B8%9B%E5%B0%91%E7%9B%A3%E7%AE%A1"}, {"title": "\u904b\u8f38\u7f72:\u5927\u6b16\u96a7\u9053\u6e1b\u50f9\u52a9\u5206\u6d41 \u518d\u964d\u6536\u8cbb\u6216\u81f4\u64e0\u585e", "description": "<p>\u5927\u6b16\u96a7\u9053\u6536\u8cbb\u65b9\u6848\u51fa\u7210\uff0c\u79c1\u5bb6\u8eca\u5e73\u65e5\u7e41\u5fd9\u6642\u6bb5\u5efa\u8b70\u6536\u8cbb45\u5143\u3002\u904b\u8f38\u7f72\u52a9\u7406\u7f72\u9577\u6881\u4e16\u8c6a\u5728\u96fb\u53f0\u7bc0\u76ee\u8868\u793a\uff0c\u5efa\u8b70\u6536\u8cbb\u76f8\u8f03\u73fe\u6642\u6536\u8cbb58\u5143\uff0c\u6e1b\u5e45\u5df2\u9054\u523022%\u3002\u5982\u679c\u518d\u5c07\u6536\u8cbb\u8abf\u4f4e\uff0c\u8eca\u6d41\u589e\u52a0\uff0c\u4fbf\u6709\u6a5f\u6703\u51fa\u73fe\u64e0\u585e\u60c5\u6cc1\u3002</p>\n<p>\u6881\u4e16\u8c6a\u6307\u51fa\uff0c\u672a\u4f86\u65b0\u754c\u897f\u5317\u7b49\u5730\u5340\u6703\u6709\u5f88\u591a\u65b0\u767c\u5c55\uff0c\u9810\u6599\u8eca\u6d41\u4e0a\u5347\uff0c\u56e0\u6b64\u9700\u8981\u63a1\u53d6\u79c1\u5bb6\u8eca\u5206\u6642\u6bb5\u6536\u8cbb\uff0c\u5426\u5247\u5c07\u4f86\u6703\u300c\u505a\u5514\u8fd4\u300d\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u4ed6\u53c8\u7a31\uff0c</span>\u6839\u64da\u4f30\u7b97\uff0c\u82e5\u7dad\u6301\u5927\u6b16\u96a7\u9053\u73fe\u6642\u7684\u6536\u8cbb\uff0c\u52302026\u5e74\u4ecd\u6709\u7d0415%\u5bb9\u8eca\u91cf\uff0c\u56e0\u6b64\u5e0c\u671b\u8abf\u6574\u6536\u8cbb\uff0c\u5438\u5f15\u90e8\u5206\u99d5\u99db\u8005\u4f7f\u7528\u5927\u6b16\u96a7\u9053\uff0c\u5354\u52a9\u5206\u6563\u5c6f\u9580\u516c\u8def\u7b49\u7684\u8eca\u6d41\u3002</p>\n<p>\u7acb\u6cd5\u6703\u4ea4\u901a\u4e8b\u52d9\u59d4\u54e1\u6703\u4e3b\u5e2d\u9673\u6052\u944c\u5728\u540c\u4e00\u7bc0\u76ee\u4e2d\u7a31\uff0c\u65b0\u65b9\u6848\u4e0d\u904e\u4e0d\u5931\uff0c\u5e0c\u671b\u5728\u5be6\u65bd\u4e00\u6bb5\u6642\u9593\u5f8c\uff0c\u7576\u5c40\u6703\u518d\u8003\u616e\u662f\u5426\u6709\u7a7a\u9593\u8abf\u6574\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3946994/%E9%81%8B%E8%BC%B8%E7%BD%B2%3A%E5%A4%A7%E6%AC%96%E9%9A%A7%E9%81%93%E6%B8%9B%E5%83%B9%E5%8A%A9%E5%88%86%E6%B5%81+%E5%86%8D%E9%99%8D%E6%94%B6%E8%B2%BB%E6%88%96%E8%87%B4%E6%93%A0%E5%A1%9E"}]}