0c\u52a0\u5f37\u9ad4\u80b2\u65c5\u904a\u7684\u6548\u61c9\uff0c\u5ef6\u9577\u65c5\u5ba2\u5728\u6fb3\u9580\u7684\u9017\u7559\u6642\u9593\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3948485/NBA%E6%93%9A%E5%A0%B1%E8%88%87%E9%87%91%E6%B2%99%E4%B8%AD%E5%9C%8B%E7%B0%BD5%E5%B9%B4%E5%8D%94%E8%AD%B0+%E5%9C%A8%E6%BE%B3%E9%96%80%E8%BE%A6%E5%AD%A3%E5%89%8D%E8%B3%BD"}, {"title": "\u5357\u97d3\u570b\u60c5\u9662\u6b21\u9577:\u5c39\u932b\u6085\u89aa\u53e3\u6307\u793a\u902e\u6355\u570b\u6703\u8b70\u9577\u53ca\u671d\u91ce\u9ee8\u9b41", "description": "<p>\u97d3\u806f\u793e\u5831\u9053\uff0c\u5357\u97d3\u570b\u9632\u90e8\u5ba3\u5e03\uff0c\u9996\u90fd\u9632\u885e\u53f8\u4ee4\u5b98\u3001\u7279\u6230\u53f8\u4ee4\u5b98\u3001\u53cd\u9593\u8adc\u53f8\u4ee4\u5b98\u88ab\u505c\u8077\u3002</p>\n<p>\u6b64\u5916\uff0c\u5357\u97d3\u570b\u60c5\u9662\u6b21\u9577\u6d2a\u9577\u5143\u8868\u793a\uff0c\u7e3d\u7d71\u5c39\u932b\u6085\u672c\u5468\u4e8c\u5ba3\u5e03\u7dca\u6025\u6212\u56b4\u4e4b\u5f8c\uff0c\u66fe\u89aa\u53e3\u6307\u793a\u62d8\u6355\u500b\u5225\u653f\u6cbb\u4eba\u58eb\u3002</p>\n<p>\u64da\u6d2a\u9577\u5143\u900f\u9732\uff0c\u62d8\u6355\u5c0d\u8c61\u5305\u62ec\u570b\u6703\u8b70\u9577\u79b9\u5143\u690d\u3001\u57f7\u653f\u9ee8\u570b\u6c11\u529b\u91cf\u9ee8\u9ee8\u9b41\u97d3\u6771\u52f3\u3001\u5171\u540c\u6c11\u4e3b\u9ee8\u9ee8\u9b41\u674e\u5728\u660e\u3001\u9ee8\u97ad\u6734\u8d0a\u5927\u3001\u9996\u5e2d\u6700\u9ad8\u59d4\u54e1\u91d1\u6c11\u932b\u3001\u570b\u6703\u6cd5\u5236\u53f8\u6cd5\u59d4\u54e1\u6703\u59d4\u54e1\u9577\u912d\u6e05\u4f86\u3001\u7956\u570b\u9769\u65b0\u9ee8\u9ee8\u9b41\u66f9\u570b\uff0c\u4ee5\u53ca\u6642\u4e8b\u540d\u5634\u91d1\u65bc\u4fca\u7b49\u3002</p>\n<p>\u6d2a\u9577\u5143\u53c8\u63d0\u5230\uff0c\u5c39\u932b\u6085\u7576\u6642\u4f86\u96fb\u7a31\u300c\u85c9\u6b64\u6b21\u6a5f\u6703\u5168\u90e8\u6293\u9032\u4f86\u6536\u62fe\u300d\uff0c\u9084\u7a31\u300c\u6211\u6703\u628a\u53cd\u9593\u8adc\u5075\u67e5\u6b0a\u4e0b\u653e\u7d66\u570b\u60c5\u9662\uff0c\u4f60\u5011\u5148\u5411\u570b\u9632\u90e8\u9632\u8adc\u53f8\u4ee4\u90e8\u63d0\u4f9b\u5354\u52a9\uff0c\u8cc7\u91d1\u3001\u4eba\u529b\u7d71\u7d71\u90fd\u8981\u63d0\u4f9b\u300d\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3948487/%E5%8D%97%E9%9F%93%E5%9C%8B%E6%83%85%E9%99%A2%E6%AC%A1%E9%95%B7%3A%E5%B0%B9%E9%8C%AB%E6%82%85%E8%A6%AA%E5%8F%A3%E6%8C%87%E7%A4%BA%E9%80%AE%E6%8D%95%E5%9C%8B%E6%9C%83%E8%AD%B0%E9%95%B7%E5%8F%8A%E6%9C%9D%E9%87%8E%E9%BB%A8%E9%AD%81"}, {"title": "\u65b0\u90fd\u57ce\u5169\u623f\u897f\u5357530\u842c\u6613\u4e3b", "description": "<p>\u5c07\u8ecd\u6fb3\u65b0\u90fd\u57ce1\u671f2\u5ea7\u4f4e\u5c64A\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d420\u65b9\u544e\uff0c2\u623f\u9593\u9694\uff0c\u5ea7\u5411\u897f\u5357\u65b9\uff0c\u5411\u5167\u5712\u666f\uff0c\u6700\u65b0\u4ee5530\u842c\u5143\u6613\u624b\uff0c\u5be6\u7528\u544e\u50f912619\u5143\u3002</p>\n<p>\u4e2d\u539f\u5730\u7522\u8868\u793a\uff0c\u539f\u696d\u4e3b\u65bc2009\u5e743\u6708\u4ee5198\u842c\u5143\u8cfc\u5165\u55ae\u4f4d\uff0c\u6301\u8ca8\u5df215\u5e74\uff0c\u662f\u6b21\u6cbd\u51fa\u55ae\u4f4d\u8cec\u9762\u7372\u5229332\u842c\u5143\uff0c\u55ae\u4f4d\u671f\u5167\u5347\u503c\u903e1.6\u500d\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3948479/%E6%96%B0%E9%83%BD%E5%9F%8E%E5%85%A9%E6%88%BF%E8%A5%BF%E5%8D%97530%E8%90%AC%E6%98%93%E4%B8%BB"}, {"title": "\u60e0\u8b7d\u964d\u842c\u9054\u5546\u7ba1\u548c\u842c\u9054\u9999\u6e2f\u8a55\u7d1a\u81f3C", "description": "<p>\u570b\u969b\u8a55\u7d1a\u6a5f\u69cb\u60e0\u8b7d\u516c\u5e03\uff0c\u5df2\u5c07\u5927\u9023\u842c\u9054\u5546\u696d\u7ba1\u7406\u548c\u842c\u9054\u5546\u696d\u5730\u7522(\u9999\u6e2f)\u7684\u9577\u671f\u5916\u5e63\u767c\u884c\u4eba\u9055\u7d04\u8a55\u7d1a\u7531\u300c<span style=\"font-size-ignore:13pt;\">CC\u300d\u4e0b\u8abf\u81f3\u300cC\u300d\uff0c\u56e0\u842c\u9054\u5546\u7ba1</span><span style=\"font-size-ignore:13pt;\">\u5c0d\u660e\u5e741\u6708\u5230\u671f\u76844\u5104\u7f8e\u5143\u50b5\u5238\u9032\u884c\u5c55\u671f\u3002</span></p>\n<p>\u60e0\u8b7d\u540c\u6642\u5c07\u842c\u9054\u9999\u6e2f\u64d4\u4fdd\u3001\u842c\u9054\u5546\u7ba1\u5b50\u516c\u53f8\u6240\u767c\u884c\u7f8e\u5143\u50b5\u5238\u7684\u8a55\u7d1a\u81ea\u300cCC\u300d\u4e0b\u8abf\u81f3\u300cC\u300d\uff0c\u8a72\u50b5\u5238\u7684\u56de\u6536\u7387\u8a55\u7d1a\u81eaRR4\u4e0b\u8abf\u81f3RR5\u3002\u60e0\u8b7d\u5df2\u5c07\u6240\u6709\u8a55\u7d1a\u79fb\u51fa\u8ca0\u9762\u89c0\u5bdf\u540d\u55ae\u3002</p>\n<p>\u60e0\u8b7d\u6307\u51fa\uff0c\u6b64\u6b21\u8a55\u7d1a\u4e0b\u8abf\u662f\u57fa\u65bc\uff0c\u842c\u9054\u5546\u7ba1\u5ba3\u5e03\uff0c\u516c\u53f8\u5df2\u5c312025\u5e741\u670820\u65e5\u5230\u671f\u76844\u5104\u7f8e\u5143\u50b5\u5238\u5fb5\u6c42\u4f54\u672a\u511f\u672c\u91d1\u7e3d\u984d96.32%\u7684\u5408\u8cc7\u683c\u50b5\u5238\u6301\u6709\u4eba\u7684\u540c\u610f\uff0c\u4ee5\u4fee\u8a02\u50b5\u5238\u689d\u6b3e\uff0c\u4e26\u8c41\u514d\u6f5b\u5728\u9055\u7d04\u4e8b\u4ef6\u3002\u60e0\u8b7d\u8a8d\u70ba\uff0c\u5c0d\u50b5\u5238\u689d\u6b3e\u7684\u64ec\u8b70\u4fee\u8a02\u7b26\u5408\u60e0\u8b7d\u300a\u4f01\u696d\u8a55\u7d1a\u6a19\u6e96\u300b\u5217\u8f09\u7684\u4e0d\u826f\u50b5\u52d9\u4ea4\u63db\u5b9a\u7fa9\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u53bb\u5e748\u6708\uff0c\u56e0\u5728\u5bec\u9650\u671f\u7d50\u675f\u524d\u511f\u4ed82025\u5e741\u670820\u65e5\u5230\u671f\u76844\u5104\u7f8e\u5143\u50b5\u7684\u5229\u606f\uff0c\u60e0\u8b7d\u5ba3\u5e03\u4e0a\u8abf\u842c\u9054\u5546\u7ba1\u548c\u842c\u9054\u9999\u6e2f\u7684\u8a55\u7d1a\uff0c\u5169\u5bb6\u516c\u53f8\u7684\u9577\u671f\u5916\u5e63\u767c\u884c\u4eba\u9055\u7d04\u8a55\u7d1a\u5747\u81ea\u300cC\u300d\u4e0a\u8abf\u81f3\u300cCC\u300d\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3948476/%E6%83%A0%E8%AD%BD%E9%99%8D%E8%90%AC%E9%81%94%E5%95%86%E7%AE%A1%E5%92%8C%E8%90%AC%E9%81%94%E9%A6%99%E6%B8%AF%E8%A9%95%E7%B4%9A%E8%87%B3C"}]}