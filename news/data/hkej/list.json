f0c\u514c\u4ed8\u65e5\u70ba2029\u5e7410\u670818\u65e5\u3002</span></p>\n<p>\u4eba\u884c\u4e0a\u5468\u4e94\u5ba3\u5e03\uff0c\u5373\u65e5\u8d77\u6b63\u5f0f\u555f\u52d5\u8b49\u5238\u3001\u57fa\u91d1\u3001\u4fdd\u96aa\u516c\u53f8\u4e92\u63db\u4fbf\u5229\u64cd\u4f5c\uff1b\u76ee\u524d\u7372\u51c6\u53c3\u8207\u4e92\u63db\u4fbf\u5229\u64cd\u4f5c\u7684\u8b49\u5238\u3001\u57fa\u91d1\u516c\u53f8\u670920\u5bb6\uff0c\u9996\u6279\u7533\u8acb\u984d\u5ea6\u5df2\u8d852000\u5104\u5143\u4eba\u6c11\u5e63\u3002\u592e\u884c\u5c07\u6839\u64da\u53c3\u8207\u6a5f\u69cb\u9700\u6c42\u6b63\u5f0f\u555f\u52d5\u64cd\u4f5c\uff0c\u652f\u6301\u8cc7\u672c\u5e02\u5834\u7a69\u5b9a\u767c\u5c55\u3002</p>\n<p>\u4e2d\u570b\u8b49\u76e3\u6703\u96a8\u5f8c\u8868\u793a\uff0c\u5df2\u7d93\u540c\u610f\u4e2d\u4fe1\u8a3c\u5238\u3001\u4e2d\u91d1\u516c\u53f8\u7b4920\u5bb6\u8b49\u5238\u3001\u57fa\u91d1\u516c\u53f8\u958b\u5c55\u4e92\u63db\u4fbf\u5229\u64cd\u4f5c\uff1b\u8981\u6c42\u76f8\u95dc\u6a5f\u69cb\u52a0\u5f37\u5408\u898f\u98a8\u63a7\u7ba1\u7406\uff0c\u4e3b\u52d5\u914d\u5408\u505a\u597d\u9019\u9805\u696d\u52d9\uff0c\u767c\u63ee\u7dad\u8b77\u5e02\u5834\u7a69\u5b9a\u904b\u884c\u7684\u7a4d\u6975\u4f5c\u7528\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3907495/%E4%BA%BA%E8%A1%8C%E9%A6%96%E6%9C%9F%E4%BA%92%E6%8F%9B%E4%BE%BF%E5%88%A9%E5%A4%AE%E7%A5%A8%E4%BB%8A%E6%97%A5%E4%B8%8A%E5%B8%82+%E5%88%A9%E7%8E%871.8%25"}]}