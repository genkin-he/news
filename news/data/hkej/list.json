7\u4e0d\u6703\u6e1b\u606f\uff0c\u4f46\u56e0\u5176\u5f8c\u516c\u5e03\u7684\u7d93\u6fdf\u6578\u64da\u53cd\u6620\u6b50\u76df\u7d93\u6fdf\u589e\u9577\u53ca\u901a\u8139\u986f\u8457\u653e\u7de9\uff0c\u56e0\u6b64\u5e02\u5834\u6539\u70ba\u9810\u671f\u6e1b\u606f0.25\u5398\u3002</p>\n<p>\u6cb9\u50f9\u56de\u843d\uff0c\u7d10\u7d04\u539f\u6cb9\u671f\u8ca8\u73fe\u6642\u6bcf\u6876\u583170.27\u7f8e\u5143\uff0c\u8dcc0.12\u7f8e\u5143\u62160.17%\uff1b\u502b\u6566\u5e03\u862d\u7279\u671f\u6cb9\u583174.1\u7f8e\u5143\uff0c\u8dcc0.1\u7f8e\u5143\u62160.13%\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3905326/%E8%A7%80%E6%9C%9B%E6%AD%90%E6%B4%B2%E5%A4%AE%E8%A1%8C%E8%AD%B0%E6%81%AF+%E6%AD%90%E8%82%A1%E6%97%A9%E6%AE%B5%E5%80%8B%E5%88%A5%E8%B5%B0"}, {"title": "\u65bd\u653f\u5831\u544a\u4e28\u5730\u76e3\u5c40\u6307\u63aa\u65bd\u6709\u5229\u672c\u6e2f\u6a13\u5e02\u5065\u5eb7\u767c\u5c55", "description": "<p>\u5730\u7522\u4ee3\u7406\u76e3\u7ba1\u5c40(\u5730\u76e3\u5c40)\u6b61\u8fce\u53ca\u5168\u529b\u652f\u6301\u884c\u653f\u9577\u5b98\u5728\u300a\u65bd\u653f\u5831\u544a\u300b\u4e2d\u63a8\u51fa\u591a\u9805\u623f\u5c4b\u53ca\u6a13\u5e02\u7684\u63aa\u65bd\uff0c\u4ee5\u652f\u63f4\u53ca\u7167\u9867\u4e0d\u540c\u793e\u7fa4\u7684\u623f\u5c4b\u9700\u8981\u3002</p>\n<p>\u300a\u65bd\u653f\u5831\u544a\u300b\u6307\u51fa\uff0c\u653f\u5e9c\u63d0\u51fa\u4ee5\u7acb\u6cd5\u65b9\u5f0f\u5236\u8a02\u4f4f\u5b85\u6a13\u5b87\u5206\u9593\u55ae\u4f4d\u7684\u51fa\u79df\u5236\u5ea6\u3001\u8abf\u6574\u516c\u5c4b\u548c\u8cc7\u52a9\u51fa\u552e\u55ae\u4f4d\u7684\u6bd4\u4f8b\u3001\u652f\u6301\u9752\u5e74\u8cfc\u8cb7\u8cc7\u52a9\u51fa\u552e\u55ae\u4f4d\u53ca\u653e\u5bec\u4f4f\u5b85\u7269\u696d\u6309\u63ed\u6210\u6578\u4e0a\u9650\u7b49\u3002</p>\n<p>\u5730\u76e3\u5c40\u4e3b\u5e2d\u856d\u6fa4\u5b87\u6b61\u8fce\u6709\u95dc\u63aa\u65bd\uff0c\u76f8\u4fe1\u9019\u4e9b\u8209\u63aa\u5747\u6709\u5229\u65bc\u672c\u6e2f\u6a13\u5e02\u5065\u5eb7\u767c\u5c55\uff0c\u4e26\u70ba\u5730\u7522\u4ee3\u7406\u884c\u696d\u5e36\u4f86\u5354\u540c\u6548\u61c9\u3002\u4ed6\u8a8d\u70ba\uff0c\u653f\u5e9c\u4ee5\u7acb\u6cd5\u65b9\u5f0f\u5236\u8a02\u4f4f\u5b85\u6a13\u5b87\u5206\u9593\u55ae\u4f4d\u7684\u51fa\u79df\u5236\u5ea6\uff0c\u9577\u9060\u53ef\u9010\u6b65\u6539\u5584\u4f4f\u6236\u7684\u751f\u6d3b\u74b0\u5883\u3002\u5730\u76e3\u5c40\u5c07\u5bc6\u5207\u7559\u610f\u76f8\u95dc\u7acb\u6cd5\u9032\u7a0b\uff0c\u8207\u5404\u6301\u4efd\u8005\u4fdd\u6301\u7dca\u5bc6\u6e9d\u901a\uff0c\u6709\u9700\u8981\u6642\u6703\u9069\u7576\u5730\u512a\u5316\u73fe\u884c\u6709\u95dc\u5730\u7522\u4ee3\u7406\u8655\u7406\u5206\u9593\u55ae\u4f4d\u79df\u8cc3\u7684\u6307\u5f15\uff0c\u4e26\u6703\u52a0\u5f37\u6559\u80b2\u696d\u754c\u7684\u5de5\u4f5c\uff0c\u4ee5\u78ba\u4fdd\u5730\u7522\u4ee3\u7406\u9075\u5f9e\u3002</p>\n<p>\u5730\u76e3\u5c40\u6703\u5168\u529b\u914d\u5408\u300a\u65bd\u653f\u5831\u544a\u300b\u7684\u65b9\u91dd\uff0c\u4e26\u81f4\u529b\u63d0\u5347\u5730\u7522\u4ee3\u7406\u884c\u696d\u7684\u5c08\u696d\u6c34\u5e73\uff0c\u7e7c\u7e8c\u900f\u904e\u5c65\u884c\u898f\u7ba1\u8005\u7684\u89d2\u8272\uff0c\u70ba\u696d\u754c\u8a02\u7acb\u9ad8\u7684\u9053\u5fb7\u6a19\u6e96\u548c\u64cd\u5b88\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3905324/%E6%96%BD%E6%94%BF%E5%A0%B1%E5%91%8A%E4%B8%A8%E5%9C%B0%E7%9B%A3%E5%B1%80%E6%8C%87%E6%8E%AA%E6%96%BD%E6%9C%89%E5%88%A9%E6%9C%AC%E6%B8%AF%E6%A8%93%E5%B8%82%E5%81%A5%E5%BA%B7%E7%99%BC%E5%B1%95"}, {"title": "\u6eec\u6307\u6536\u8dcc1.1% \u5931\u5b883200\u9ede", "description": "<p>\u4f4f\u5efa\u90e8\u7b49\u90e8\u59d4\u8a18\u8005\u6703\u672a\u6709\u592a\u5927\u9a5a\u559c\u6d88\u606f\u516c\u5e03\uff0cA\u80a1\u4e0b\u6ed1\u3002\u4e0a\u8b49\u6307\u6578\u6536\u8dcc1.1%\uff0c\u8dcc\u7a7f3200\u9ede\u3002\u5e02\u5834\u4ea4\u6295\u66a2\u65fa\uff0c\u5169\u5e02\u6210\u4ea4\u5408\u8a08\u589e\u81f31.49\u842c\u5104\u5143(\u4eba\u6c11\u5e63\u2027\u4e0b\u540c) \uff0c\u9023\u7e8c12\u65e5\u8d85\u904e1\u842c\u5104\u5143\u3002</p>\n<p>\u4e0a\u8b49\u6307\u6578\u6700\u591a\u534738\u9ede\u62161.21%\uff0c\u9ad8\u898b3241\u9ede\uff0c\u96a8\u7740\u4f4f\u5efa\u90e8\u767c\u5e03\u6703\u53ec\u958b\uff0c\u5927\u5e02\u5347\u5e45\u986f\u8457\u6536\u7a84\uff0c\u5348\u5f8c\u5012\u8dcc\u4e26\u5931\u5b883200\u9ede\uff0c\u4ee5\u5168\u65e5\u4f4e\u4f4d\u6536\u5e02\uff0c\u6536\u58313169\u9ede\uff0c\u8dcc33\u9ede\u62161.05%\uff0c\u6210\u4ea45573.47\u5104\u5143\u3002</p>\n<p>\u6df1\u6210\u6307\u752b\u958b\u5e02\u91cd\u4e0a1\u842c\u9ede\u95dc\u53e3\uff0c\u6700\u591a\u5347158\u9ede\u62161.59%\uff0c\u9ad8\u898b10123\u9ede\uff0c\u5348\u5f8c\u6709\u6cbd\u58d3\u8f49\u8dcc\uff0c\u6700\u591a\u8dcc77\u9ede\u62160.77%\uff0c\u4f4e\u898b9887\u9ede\uff0c\u5168\u65e5\u6536\u5e02\u58319891\u9ede\uff0c\u8dcc73\u9ede\u62160.74%\uff0c\u6210\u4ea49339.13\u5104\u5143\u3002</p>\n<p>\u6eec\u6df1300\u6307\u6578\u58313788\u9ede\uff0c\u8dcc43\u9ede\u62161.13%\uff1b\u5275\u696d\u677f\u6307\u6578\u58312033\u9ede\uff0c\u8dcc6\u9ede\u62160.32%\u3002</p>\n<p>\u5404\u677f\u584a\u500b\u5225\u767c\u5c55\uff0c\u958b\u767c\u5340\u80a1\u632b\u903e5%\uff1b\u623f\u5730\u7522\u80a1\u8dcc\u903e3%\uff1b\u77f3\u6cb9\u3001\u6709\u8272\u91d1\u5c6c\u3001\u5316\u5de5\u3001\u96fb\u529b\u3001\u7164\u70ad\u3001\u6c34\u6ce5\u3001\u91d1\u878d\u3001\u92fc\u9435\u80a1\u504f\u8edf\uff1b\u6c7d\u8eca\u88fd\u9020\u3001\u50b3\u5a92\u5a1b\u6a02\u80a1\u9760\u7a69\u3002</p>\n<p>\u4f4f\u5efa\u90e8\u90e8\u9577\u502a\u8679\u5728\u570b\u65b0\u8fa6\u65b0\u805e\u767c\u5e03\u6703\u8868\u793a\uff0c\u5e74\u5e95\u524d\u5c07\u300c\u767d\u540d\u55ae\u300d\u9805\u76ee\u4fe1\u8cb8\u898f\u6a21\u589e\u52a0\u52304\u842c\u5104\u5143\uff0c\u8981\u5c07\u6240\u6709\u5408\u683c\u9805\u76ee\u90fd\u722d\u53d6\u7d0d\u5165\u300c\u767d\u540d\u55ae\u300d\uff0c\u53c8\u7a31\u5c07\u901a\u904e\u8ca8\u5e63\u5316\u5b89\u7f6e\u65b9\u5f0f\uff0c\u65b0\u589e\u5be6\u65bd100\u842c\u5957\u57ce\u4e2d\u6751\u6539\u9020\u548c\u5371\u820a\u623f\u6539\u9020\uff0c\u53ea\u8981\u524d\u671f\u5de5\u4f5c\u505a\u5f97\u597d\uff0c\u9084\u53ef\u4ee5\u5728100\u842c\u5957\u57fa\u790e\u4e0a\u7e7c\u7e8c\u52a0\u5927\u652f\u6301\u529b\u5ea6\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3905320/%E6%BB%AC%E6%8C%87%E6%94%B6%E8%B7%8C1.1%25+%E5%A4%B1%E5%AE%883200%E9%BB%9E"}, {"title": "\u4e2d\u5927\u4e0b\u5b78\u5e74\u958b\u8fa63\u500b\u65b0\u5b78\u58eb\u5b78\u4f4d\u8ab2\u7a0b", "description": "<p><span style=\"font-size-ignore:13pt;\">\u9999\u6e2f\u4e2d\u6587\u5927\u5b78\u5c07\u65bc2025/26\u5b78\u5e74\u958b\u8fa63\u500b\u65b0\u672c\u79d1\u8ab2\u7a0b\uff0c\u4ee5\u61c9\u5c0d\u793e\u6703\u5c0d\u591a\u5143\u4eba\u624d\u65e5\u76ca\u589e\u9577\u7684\u9700\u6c42\uff0c\u8a723\u500b\u65b0\u8ab2\u7a0b\u5206\u5225\u70ba\u516c\u5171\u4eba\u6587\u5b78\u6587\u5b78\u58eb\u8ab2\u7a0b\u3001\u4eba\u9ad4\u904b\u52d5\u79d1\u5b78\u8207\u5065\u5eb7\u7814\u7a76\u7406\u5b78\u58eb\u8ab2\u7a0b\uff0c\u4ee5\u53ca\u6750\u6599\u79d1\u5b78\u8207\u5de5\u7a0b\u5b78\u5de5\u7a0b\u5b78\u58eb\u8ab2\u7a0b\u3002</span></p>\n<p>\u4e2d\u5927\u8868\u793a\uff0c\u516c\u5171\u4eba\u6587\u5b78\u6587\u5b78\u58eb\u8ab2\u7a0b\u7d50\u5408\u6587\u5316\u7814\u7a76\u7684\u6279\u5224\u601d\u8003\u8207\u6587\u5316\u7ba1\u7406\u7684\u5be6\u8e10\u77e5\u8b58\uff0c\u5f37\u8abf\u7814\u7a76\u548c\u7406\u8ad6\u7684\u540c\u6642\uff0c\u4e5f\u91cd\u8996\u6587\u5316\u5be6\u8e10\u3001\u77e5\u8b58\u8f49\u79fb\u548c\u516c\u5171\u53c3\u8207\u3002\u8ab2\u7a0b\u65e8\u5728\u57f9\u990a\u65b0\u4e00\u4ee3\u7684\u6587\u5316\u754c\u5c08\u696d\u4eba\u58eb\uff0c\u4fc3\u9032\u66f4\u7f8e\u597d\u7684\u793e\u5340\u5efa\u8a2d\u3002</p>\n<p>\u4eba\u9ad4\u904b\u52d5\u79d1\u5b78\u8207\u5065\u5eb7\u7814\u7a76\u7406\u5b78\u58eb\u8ab2\u7a0b\uff0c\u5247\u70ba\u5b78\u751f\u63d0\u4f9b\u4eba\u9ad4\u904b\u52d5\u79d1\u5b78\u3001\u6559\u7df4\u3001\u904b\u52d5\u5065\u5eb7\u548c\u904b\u52d5\u5eb7\u5fa9\uff0c\u4ee5\u53ca\u79d1\u7814\u7b49\u7bc4\u7587\u7684\u8de8\u5b78\u79d1\u5b78\u7fd2\u9ad4\u9a57\u3002\u8ab2\u7a0b\u63d0\u4f9b\u96d9\u5b78\u4f4d\u9078\u64c7\uff0c\u5b78\u751f\u53ef\u7533\u8acb\u8207\u5317\u4eac\u9ad4\u80b2\u5927\u5b78\u5408\u8fa6\u7684\u96d9\u5b78\u4f4d\u8ab2\u7a0b\uff0c\u5728\u4e2d\u5927\u548c\u5317\u4eac\u9ad4\u80b2\u5927\u5b78\u5404\u4fee\u8b80\u5169\u5e74\uff0c\u7372\u5f97\u5169\u6240\u5b78\u5e9c\u7684\u5b78\u58eb\u5b78\u4f4d\u3002</p>\n<p>\u81f3\u65bc\u7531\u4e2d\u5927\u5de5\u7a0b\u5b78\u9662\u53ca\u7406\u5b78\u9662\u5408\u8fa6\u7684\u6750\u6599\u79d1\u5b78\u8207\u5de5\u7a0b\u5b78\u5de5\u7a0b\u5b78\u58eb\u8ab2\u7a0b\uff0c\u65e8\u5728\u70ba\u5b78\u751f\u63d0\u4f9b\u5148\u9032\u6750\u6599\u53ca\u5176\u5275\u65b0\u61c9\u7528\u7684\u5168\u9762\u6559\u80b2\uff0c\u5167\u5bb9\u6db5\u84cb\u8de8\u5b78\u79d1\u7684\u79d1\u5b78\u77e5\u8b58\u8207\u5de5\u7a0b\u6280\u80fd\u3002\u8ab2\u7a0b\u8a2d\u8a08\u7740\u91cd\u65bc\u6559\u6388\u65b0\u8208\u6750\u6599\u53ca\u5176\u5177\u5099\u7684\u65b0\u529f\u80fd\uff0c\u5305\u62ec\u7d0d\u7c73\u6750\u6599\u3001\u80fd\u6e90\u6750\u6599\u3001\u96fb\u5b50\u6750\u6599\u3001\u667a\u6167\u6750\u6599\u3001\u751f\u7269\u6750\u6599\u7b49\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3905315/%E4%B8%AD%E5%A4%A7%E4%B8%8B%E5%AD%B8%E5%B9%B4%E9%96%8B%E8%BE%A63%E5%80%8B%E6%96%B0%E5%AD%B8%E5%A3%AB%E5%AD%B8%E4%BD%8D%E8%AA%B2%E7%A8%8B"}, {"title": "\u82f1\u570b\u5916\u76f8\u6797\u5fb7\u5049\u5468\u4e94\u8a2a\u83ef\u5169\u5929", "description": "<p>\u4e2d\u570b\u5916\u4ea4\u90e8\u767c\u8a00\u4eba\u6bdb\u5be7\u5ba3\u5e03\uff0c\u61c9\u4e2d\u5171\u4e2d\u592e\u653f\u6cbb\u5c40\u59d4\u54e1\u3001\u5916\u4ea4\u90e8\u9577\u738b\u6bc5\u9080\u8acb\uff0c\u82f1\u570b\u5916\u76f8\u6797\u5fb7\u5049(David Lammy)\u5c07\u65bc10\u670818\u65e5\u81f319\u65e5\u5c0d\u4e2d\u570b\u9032\u884c\u6b63\u5f0f\u8a2a\u554f\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3905319/%E8%8B%B1%E5%9C%8B%E5%A4%96%E7%9B%B8%E6%9E%97%E5%BE%B7%E5%81%89%E5%91%A8%E4%BA%94%E8%A8%AA%E8%8F%AF%E5%85%A9%E5%A4%A9"}]}