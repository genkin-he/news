8B%A2%E9%A0%97%E5%A4%A7"}, {"title": "\u58d3\u529b\u6e2c\u8a66\u904e\u95dc \u7f8e\u570b\u516d\u5927\u9280\u884c\u8abf\u9ad8\u80a1\u606f", "description": "<p>\u7f8e\u570b\u806f\u5132\u5c40\u8f03\u65e9\u6642\u516c\u5e03\uff0c\u53c3\u8207\u8a55\u4f30\u768431\u9593\u5927\u9280\u884c\u5168\u90e8\u90fd\u901a\u904e\u58d3\u529b\u6e2c\u8a66\u5f8c\uff0c\u591a\u9593\u5927\u9280\u884c\u5468\u4e94\u4e00\u5982\u9810\u671f\u8abf\u9ad8\u7b2c\u4e09\u5b63\u80a1\u606f\u3002</p>\n<p>\u6469\u6839\u5927\u901a\u8868\u793a\uff0c\u5f9e\u7b2c\u4e09\u5b63\u8d77\uff0c\u5b63\u5ea6\u80a1\u606f\u75311.15\u7f8e\u5143\uff0c\u589e\u81f31.25\u7f8e\u5143\u3002\u540c\u6642\uff0c\u57287\u67081\u65e5\u958b\u59cb\u65b0\u4e00\u8f2a\u80a1\u4efd\u56de\u8cfc\u8a08\u5283\uff0c\u898f\u6a21\u662f300\u5104\u7f8e\u5143\u3002</p>\n<p>\u7f8e\u570b\u9280\u884c\u7a31\uff0c\u5b63\u5ea6\u80a1\u606f\u753124\u7f8e\u4ed9\u8abf\u9ad8\u70ba26\u7f8e\u4ed9\u3002<span style=\"font-size-ignore:13pt;\">\u82b1\u65d7\u4e5f\u8868\u793a\uff0c\u5b63\u5ea6\u80a1\u606f\u753153\u7f8e\u4ed9\u4e0a\u5347\u81f356\u7f8e\u4ed9\u3002\u6469\u6839\u58eb\u4e39\u5229\u7a31\uff0c\u80a1\u606f\u753185\u7f8e\u4ed9\u589e\u81f392.5\u7f8e\u4ed9\u3002\u9ad8\u76db\u7684\u6d3e\u606f\u4e5f\u75312.75\u7f8e\u5143\uff0c\u589e\u81f33\u7f8e\u5143\u3002\u5bcc\u570b\u9280\u884c\u80a1\u606f\u753135\u7f8e\u4ed9\uff0c\u5347\u81f340\u7f8e\u4ed9\u3002</span></p>\n<p>\u6839\u64da\u6cd5\u4f8b\uff0c\u806f\u5132\u5c40\u58d3\u529b\u6e2c\u8a66\u904e\u95dc\u5f8c\uff0c\u8a72\u7b49\u9280\u884c\u624d\u6709\u6b0a\u6c7a\u5b9a\u8abf\u6574\u6d3e\u606f\u8207\u80a1\u4efd\u56de\u8cfc\u8a08\u5283\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3806089/%E5%A3%93%E5%8A%9B%E6%B8%AC%E8%A9%A6%E9%81%8E%E9%97%9C+%E7%BE%8E%E5%9C%8B%E5%85%AD%E5%A4%A7%E9%8A%80%E8%A1%8C%E8%AA%BF%E9%AB%98%E8%82%A1%E6%81%AF"}, {"title": "\u65e5\u64ec\u8207\u5fb7\u897f\u5728\u4fc4\u9060\u6771\u908a\u754c\u9644\u8fd1\u8ecd\u6f14 \u4fc4\u5f37\u70c8\u6297\u8b70", "description": "<p>\u5c31\u65e5\u672c\u8a08\u5283\u8207\u5fb7\u570b\u548c\u897f\u73ed\u7259\u5728\u4fc4\u7f85\u65af\u908a\u754c\u9644\u8fd1\u9032\u884c\u806f\u5408\u8ecd\u4e8b\u6f14\u7fd2\uff0c\u4fc4\u7f85\u65af\u5411\u65e5\u672c\u99d0\u4fc4\u5927\u4f7f\u9928\u63d0\u51fa\u5f37\u70c8\u6297\u8b70\u3002</p>\n<p>\u6d88\u606f\u7a31\uff0c\u65e5\u672c\u8a08\u5283\u65bc7\u670819\u65e5\u81f325\u65e5\u671f\u9593\uff0c\u5728\u9760\u8fd1\u4fc4\u7f85\u65af\u908a\u5883\u7684\u5317\u6d77\u9053\uff0c\u8207\u5fb7\u570b\u548c\u897f\u73ed\u7259\u8209\u884c\u7cfb\u5217\u806f\u5408\u8ecd\u4e8b\u6f14\u7fd2\u3002</p>\n<p>\u83ab\u65af\u79d1\u7576\u5c40\u8868\u793a\uff0c\u7d55\u4e0d\u5bb9\u8a31\u65e5\u65b9\u5728\u4fc4\u9060\u6771\u5730\u5340\u908a\u754c\u9644\u8fd1\uff0c\u8207\u5340\u57df\u5916\u5317\u7d04\u6210\u54e1\u570b\u5408\u4f5c\u958b\u5c55\u6311\u91c1\u6027\u8ecd\u4e8b\u6d3b\u52d5\uff0c\u8ecd\u4e8b\u6d3b\u52d5\u88ab\u8996\u70ba\u5c0d\u4fc4\u5b89\u5168\u7684\u6f5b\u5728\u5a01\u8105\u3002</p>\n<p>\u4fc4\u7f85\u65af\u5916\u4ea4\u90e8\u5f37\u8abf\uff0c\u65e5\u672c\u9996\u76f8\u5cb8\u7530\u6587\u96c4\u653f\u5e9c\u4e0d\u8ca0\u8cac\u4efb\u7684\u653f\u7b56\uff0c\u9020\u6210\u6771\u5317\u4e9e\u548c\u4e9e\u592a\u5730\u5340\u7dca\u5f35\u5c40\u52e2\u5347\u7d1a\uff0c\u4f7f\u65e5\u672c\u8d70\u4e0a\u5371\u96aa\u9053\u8def\u3002\u4fc4\u65b9\u5c07\u5145\u5206\u63a1\u53d6\u53cd\u5236\u63aa\u65bd\uff0c\u52a0\u5f37\u9632\u79a6\u80fd\u529b\uff0c\u4fdd\u8b77\u4fc4\u7f85\u65af\u4e3b\u6b0a\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3806091/%E6%97%A5%E6%93%AC%E8%88%87%E5%BE%B7%E8%A5%BF%E5%9C%A8%E4%BF%84%E9%81%A0%E6%9D%B1%E9%82%8A%E7%95%8C%E9%99%84%E8%BF%91%E8%BB%8D%E6%BC%94+%E4%BF%84%E5%BC%B7%E7%83%88%E6%8A%97%E8%AD%B0"}, {"title": "\u7f8e\u570b\u901a\u8139\u653e\u7de9 \u7f8e\u6ed9\u4e00\u5ea6\u8dcc0.15%", "description": "<p>\u7f8e\u570b\u95dc\u9375\u901a\u8139\u6578\u64da\u7b26\u5408\u9810\u671f\uff0c\u806f\u5132\u5c40\u6e1b\u606f\u53ef\u80fd\u6027\u5347\u6eab\uff0c\u7f8e\u5143\u6ed9\u50f9\u504f\u8edf\uff0c\u8207\u7f8e\u570b\u50b5\u606f\u6709\u8f03\u5bc6\u5207\u95dc\u9023\u7684\u7f8e\u5143\u514c\u65e5\u5713\u6ed9\u50f9\u5148\u8dcc\u5f8c\u53cd\u5f48\u3002</p>\n<p>\u7f8e\u6ed9\u6307\u6578\u6700\u591a\u8dcc0.15%\uff0c\u4f4e\u898b105.75\u3002\u7f8e\u570b10\u5e74\u671f\u570b\u5eab\u5238\u5b73\u606f\u7387\u6700\u591a\u8f49\u534711.2\u57fa\u9ede\uff0c\u81f34.4\u5398\u3002</p>\n<p>\u7f8e\u5143\u514c\u65e5\u5713\u4e00\u5ea6\u5275\u4e0b38\u5e74\u9ad8\u4f4d\uff0c\u89f8\u53ca161.27\u65e5\u5713\uff0c\u5728\u7f8e\u570b\u500b\u4eba\u6d88\u8cbb\u958b\u652f(PCE)\u6578\u64da\u66dd\u5149\u524d\u4e00\u5ea6\u8f49\u5347\u70ba\u8dcc\uff0c\u5176\u5f8c\u66fe\u53470.31%\uff0c\u9ad8\u898b160.26\u514c\u6bcf\u7f8e\u5143\u30026\u6708\u53ca\u7b2c\u4e8c\u5b63\u7d2f\u8a08\uff0c\u7f8e\u5143\u514c\u65e5\u5713\u5206\u5225\u53471.9%\u82075.9%\u3002</p>\n<p>\u8f03\u65e9\u6642\uff0c\u7f8e\u570b\u516c\u5e03\u76845\u6708PCE\u6307\u6578\u6309\u6708\u7121\u8b8a\u52d5\uff0c\u6309\u5e74\u53472.6%\uff0c\u5747\u7b26\u5408\u5e02\u5834\u9810\u671f\u3002\u53e6\u5916\uff0c\u829d\u52a0\u54e55\u6708\u63a1\u8cfc\u7d93\u7406\u6307\u6578\u4e0a\u5347\u81f347.4\uff0c\u512a\u65bc\u9810\u671f\u30026\u6708\u5bc6\u6b47\u6839\u5dde\u5927\u5b78\u6d88\u8cbb\u8005\u60c5\u7dd2\u6307\u6578\u583168.2\uff0c\u512a\u65bc\u9810\u671f\u3002</p>\n<p>Convera\u5b8f\u89c0\u7b56\u7565\u5e2bBoris Kovacevic\u8868\u793a\uff0c\u5b8f\u89c0\u6578\u64da\u53cd\u6620\u901a\u8139\u5347\u52e2\u653e\u7de9\u53ca\u7d93\u6fdf\u8f49\u5f31\uff0c\u806f\u5132\u5c40\u6e1b\u606f\u63e3\u6e2c\u5347\u6eab\u3002</p>\n<p>PCE\u6578\u64da\u66dd\u5149\u5f8c\uff0c\u5229\u7387\u671f\u8ca8\u6578\u64da\u986f\u793a\uff0c\u4ea4\u6613\u5546\u9810\u6599\u806f\u5132\u5c409\u6708\u6e1b\u606f\u6982\u7387\u5347\u81f367%\uff0c\u8f03\u6578\u64da\u516c\u5e03\u524d\u768465%\u5fae\u5347\uff0c\u6578\u64da\u4e5f\u9810\u8a08\u806f\u5132\u5c40\u4eca\u5e74\u6e1b\u606f1\u6b21\u62162\u6b21\uff0c\u5404\u6e1b0.25\u5398\u3002</p>\n<p>CIBC Private Wealth\u6295\u8cc