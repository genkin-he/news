/listconews/sehk/2024/1209/2024120900858_c.pdf\" target=\"_blank\">\u4e0b\u8f09\u6e2f\u4ea4\u6240\u901a\u544a\u539f\u6587</a>\n</div>\n        ", "link": "https://www2.hkej.com/instantnews/announcement/article/3950159/%E4%B8%98%E9%88%A611%E6%9C%88%E6%94%9D%E5%83%8F%E9%A0%AD%E6%A8%A1%E7%B5%84%E9%8A%B7%E5%94%AE%E5%8D%879.6%25"}, {"title": "\u6d78\u5927\u63a8\u4e2d\u91ab\u6cbb\u7642\u53ca\u8f14\u5c0e\u8a08\u5283 \u52a9\u53d7\u7cbe\u795e\u5065\u5eb7\u554f\u984c\u56f0\u64fe\u4eba\u58eb", "description": "<p><span style=\"font-size-ignore:13pt;\">\u6d78\u6703\u5927\u5b78\u548c\u65b0\u751f\u7cbe\u795e\u5eb7\u5fa9\u6703(\u65b0\u751f\u6703)\u5408\u4f5c\uff0c\u63a8\u51fa\u70ba\u671f3\u5e74\u7684\u300c\u8cfd\u99ac\u6703\u674f\u6797\u300e\u5fc3\u300f\u9593\u8a08\u5283\u300d\uff0c\u70ba\u53d7\u7cbe\u795e\u5065\u5eb7\u554f\u984c\u56f0\u64fe\u4eba\u58eb\u63d0\u4f9b\u4e2d\u91ab\u6cbb\u7642\u65b9\u6848\u3002</span></p>\n<p>\u8a08\u5283\u5c0d\u8c61\u70ba18\u6b72\u81f365\u6b72\u53d7\u5931\u7720\u3001\u7126\u616e\u53ca\u6291\u9b31\u7b49\u554f\u984c\u56f0\u64fe\u4eba\u58eb\uff0c\u76ee\u6a19\u62db\u52df5000\u540d\u6c92\u6709\u670d\u7528\u5b89\u7720\u85e5\u6216\u7d13\u7de9\u60c5\u7dd2\u85e5\u7269\uff0c\u4ea6\u6c92\u6709\u60a3\u6709\u56b4\u91cd\u6162\u6027\u3001\u795e\u7d93\u7cfb\u7d71\u75be\u75c5\u53c3\u52a0\u8005\u3002\u4ed6\u5011\u5c07\u7372\u5f97\u514d\u8cbb\u7684\u300c\u4e09\u5c64\u7d1a\u5206\u6b65\u8b77\u7406\u300d\u4e2d\u91ab\u85e5\u670d\u52d9\uff0c\u5305\u62ec\u8349\u672c\u8336\u6216\u4e2d\u8349\u85e5\u65b9\u5291\u3002\u5982\u679c\u6cbb\u7642\u5f8c\uff0c\u51fa\u73fe\u4e2d\u5ea6\u75c7\u72c0\u7684\u53c3\u52a0\u8005\u60c5\u6cc1\u672a\u898b\u6539\u5584\uff0c\u65b0\u751f\u6703\u5c07\u63d0\u4f9b\u984d\u5916\u8f14\u5c0e\u670d\u52d9\u3002</p>\n<p>\u8a08\u5283\u4ea6\u6703\u70ba100\u540d\u4e2d\u91ab\u5e2b\u548c\u793e\u5de5\u63d0\u4f9b\u8de8\u5c08\u696d\u57f9\u8a13\uff0c\u52a0\u5f37\u4ed6\u5011\u652f\u63f4\u7cbe\u795e\u5065\u5eb7\u554f\u984c\u4eba\u58eb\u7684\u80fd\u529b\uff0c\u4e26\u8a13\u7df4150\u540d\u5fc3\u7406\u5065\u5eb7\u5927\u4f7f\u548c100\u540d\u4e2d\u91ab\u5b78\u751f\u3002</p>\n<p>\u52de\u5de5\u53ca\u798f\u5229\u5c40\u5c40\u9577\u5b6b\u7389\u83e1\u5728\u8a08\u5283\u555f\u52d5\u79ae\u81f4\u8a5e\u8868\u793a\uff0c\u5982\u679c\u6709\u4e86\u4e2d\u91ab\u7684\u5e6b\u5fd9\uff0c\u518d\u52a0\u4e0a\u65b0\u751f\u6703\u5728\u793e\u5340\u5c64\u9762\u63d0\u4f9b\u7684\u652f\u63f4\u670d\u52d9\u7684\u8a71\uff0c\u5e0c\u671b\u53ef\u4ee5\u76e1\u65e9\u5e6b\u52a9\u4e00\u4e9b\u7cbe\u795e\u958b\u59cb\u51fa\u73fe\u56f0\u64fe\u548c\u6709\u56f0\u96e3\u7684\u4eba\u58eb\u3002\u300c\u53ca\u65e9\u4ecb\u5165\u3001\u53ca\u65e9\u6cbb\u7642\u3001\u53ca\u65e9\u5eb7\u5fa9\u300d\uff0c\u9019\u662f\u5e0c\u671b\u898b\u5230\u7684\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3950182/%E6%B5%B8%E5%A4%A7%E6%8E%A8%E4%B8%AD%E9%86%AB%E6%B2%BB%E7%99%82%E5%8F%8A%E8%BC%94%E5%B0%8E%E8%A8%88%E5%8A%83+%E5%8A%A9%E5%8F%97%E7%B2%BE%E7%A5%9E%E5%81%A5%E5%BA%B7%E5%95%8F%E9%A1%8C%E5%9B%B0%E6%93%BE%E4%BA%BA%E5%A3%AB"}, {"title": "\u5408\u548c\u5546\u5834\u4e0b\u5468\u56db\u6b63\u5f0f\u958b\u5e55", "description": "<p>\u5408\u548c\u96c6\u5718\u65d7\u4e0b\u4f4d\u65bc\u7063\u4ed4\u7687\u540e\u5927\u9053\u6771183\u865f\u7684\u5408\u548c\u5546\u5834(Hopewell Mall)\uff0c\u5c07\u65bc\u4e0b\u5468\u56db(19\u65e5)\u6b63\u5f0f\u9686\u91cd\u958b\u5e55\uff0c\u4e26\u65bc\u7576\u5929\u8209\u884c\u76db\u5927\u7684\u958b\u5e55\u5100\u5f0f\u3002</p>\n<p>\u5408\u548c\u5546\u5834\u8868\u793a\uff0c\u5c07\u63a8\u51fa\u4e09\u5927\u6176\u795d\u958b\u5e55\u63a8\u5ee3\u6d3b\u52d5\uff0c\u5305\u62ec\u5408\u548c\u5546\u5834\u806f\u4e58\u65e5\u672c\u8cbf\u6613\u632f\u8208\u6a5f\u69cb(\u9999\u6e2f)\u8209\u8fa6\u7684\u300c\u5408\u548c\u306e\u65e5\u672c\u6587\u5316\u6176\u5178\u300d\u3001\u514d\u8cbb\u6d3e\u767c\u904e\u5343\u676f\u96ea\u7cd5\u53ca\u958b\u5e55\u9023\u74b0\u6d88\u8cbb\u8cde\u96a8\u5373\u5c55\u958b\u3002</p>\n<p>\u5408\u548c\u5546\u5834\u65bc11\u6708\u521d\u8a66\u696d\u5f8c\uff0c\u9678\u7e8c\u6709\u591a\u500b\u54c1\u724c\u9580\u5e97\u9032\u99d0\uff0c\u8207\u5408\u548c\u96c6\u5718\u65d7\u4e0b\u5176\u9918\u7269\u696d\uff0c\u5305\u62ec\u5408\u548c\u4e2d\u5fc3(\u96f6\u552e\u90e8\u5206)\u3001\u80e1\u5fe0\u5927\u5ec8(\u96f6\u552e\u90e8\u5206)\u3001163 QRE\u3001QRE Plaza\u53caGARDENEast(\u96f6\u552e\u90e8\u5206)\uff0c\u7d44\u6210\u5f37\u5927\u7684\u5408\u548c\u5546\u5708(Hopewell Cluster)\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3950125/%E5%90%88%E5%92%8C%E5%95%86%E5%A0%B4%E4%B8%8B%E5%91%A8%E5%9B%9B%E6%AD%A3%E5%BC%8F%E9%96%8B%E5%B9%95"}, {"title": "\u5091\u51fa\u904b\u52d5\u54e1\u9078\u8209\u4eca\u8d77\u63a5\u53d7\u9ad4\u80b2\u7e3d\u6703\u63d0\u540d", "description": "<p>\u300c\u9999\u6e2f\u5091\u51fa\u904b\u52d5\u54e1\u9078\u8209\u300d\u660e\u5e744\u670817\u65e5\u8209\u884c\u9812\u734e\u79ae\uff0c\u4eca\u65e5\u8d77\u81f3\u4e0b\u670810\u65e5\u63a5\u53d7\u9ad4\u80b2\u7e3d\u6703\u63d0\u540d\uff0c\u660e\u5e742\u670810\u65e5\u8d77\u958b\u653e\u7d66\u516c\u773e\u9032\u884c\u7db2\u4e0a\u6295\u7968\uff0c\u70ba\u671f1\u500b\u6708\u3002</p>\n<p>\u6e2f\u5354\u66a8\u5967\u59d4\u6703\u6703\u9577\u970d\u9707\u9706\u8868\u793a\uff0c\u6e2f\u968a\u904b\u52d5\u54e1\u5728\u5df4\u9ece\u5967\u904b\u53d6\u5f97\u4f73\u7e3e\uff0c\u662f\u9577\u5e74\u7d2f\u6708\u5805\u6301\u8a13\u7df4\u7684\u56de\u5831\uff0c\u5e0c\u671b\u5e02\u6c11\u900f\u904e\u5091\u51fa\u904b\u52d5\u54e1\u9078\u8209\u8a8d\u8b58\u66f4\u591a\u904b\u52d5\u54e1\uff0c\u4e26\u795d\u9858\u5404\u904b\u52d5\u54e1\u5728\u5168\u904b\u6703\u5927\u653e\u7570\u5f69\u3002</p>\n<p>\u672c\u5e74\u5ea6\u9078\u8209\u7e7c\u7e8c\u8a2d4\u500b\u7d44\u5225\u734e\u9805\uff0c\u5305\u62ec\u300c\u9999\u6e2f\u5091\u51fa\u7537\u904b\u52d5\u54e1\u300d\u3001\u300c\u9999\u6e2f\u5091\u51fa\u5973\u904b\u52d5\u54e1\u300d\u3001\u300c\u9999\u6e2f\u6700\u4f73\u904b\u52d5\u7d44\u5408\u300d\u53ca\u300c\u9999\u6e2f\u6700\u4f73\u904b\u52d5\u968a\u4f0d\u300d\uff0c\u9ad4\u80b2\u7e3d\u6703\u53ef\u5404\u7d44\u5225\u63d0\u540d1\u540d\u904b\u52d5\u54e1\u62161\u500b\u7d44\u5408\u6216\u968a\u4f0d\u89d2\u9010\u3002</p>\n<p>\u5176\u4e2d\u5091\u51fa\u7537\u5973\u904b\u52d5\u54e1\u5404\u6709\u6700\u591a5\u540d\u5f97\u734e\u8005\uff0c\u7372\u6700\u9ad8\u7968\u6578\u7684\u904b\u52d5\u54e1\uff0c\u6703\u984d\u5916\u7372\u9812\u661f\u4e2d\u4e4b\u661f\u5091\u51fa\u904b\u52d5\u54e1\uff0c\u5176\u99182\u500b\u7d44\u5225\u5247\u5206\u5225\u6703\u9078\u51fa3\u7d44\u53ca1\u968a\u904b\u52d5\u54e1\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3950158/%E5%82%91%E5%87%BA%E9%81%8B%E5%8B%95%E5%93%A1%E9%81%B8%E8%88%89%E4%BB%8A%E8%B5%B7%E6%8E%A5%E5%8F%97%E9%AB%94%E8%82%B2%E7%B8%BD%E6%9C%83%E6%8F%90%E5%90%8D"}, {"title": "\u7063\u4ed4\u8ed2\u5c3c\u8a69\u9053\u5168\u5e62\u62db\u6a19 \u4f30\u503c22\u5104", "description": "<p>\u7b2c\u4e00\u592a\u5e73\u6234\u7dad\u65af(\u9999\u6e2f)\u7372\u59d4\u4efb\u70ba\u7368\u5bb6\u4ee3\u7406\uff0c\u516c\u958b\u62db\u6a19\u51fa\u552e\u7063\u4ed4\u8ed2\u5c3c\u8a69\u9053318\u865f\uff0c\u7e3d\u5efa\u7bc9\u9762\u7a4d\u7d04128656\u65b9\u544e\uff0c\u5730\u76e4\u9762\u7a4d\u7d047651\u65b9\u544e\uff0c\u9023\u547d\u540d\u6b0a\u51fa\u552e\uff0c\u622a\u6a19\u65e5\u671f\u70ba\u660e\u5e743\u670818\u65e5\u4e2d\u534812\u6642\uff1b\u7269\u696d\u4f30\u503c\u70ba22\u5104\u5143\u3002</p>\n<p>\u4e0a\u8ff0\u7269\u696d\u75318\u5c64\u5546\u8216\u53ca16\u5c64\u5beb\u5b57\u6a13\u7d44\u6210\uff0c\u5546\u8216\u6a13\u5c64\u53ca\u5beb\u5b57\u6a13\u6a13\u5c64\u5404\u81ea\u914d\u5099\u96fb\u68af\uff0c\u80fd\u6709\u6548\u5206\u6d41\u4eba\u6f6e\u3002\u6bcf\u5c64\u5efa\u7bc9\u9762\u7a4d\u7d042998\u81f37338\u65b9\u544e\uff0c\u5c64\u9ad8\u90543.35\u81f34.72\u7c73\u3002\u6b64\u5916\uff0c\u7269\u696d\u5916\u7246\u70ba\u5168\u73bb\u7483\u5e55\u7246\uff0c\u9762\u5411\u8ed2\u5c3c\u8a69\u9053\u53ca\u675c\u8001\u8a8c\u9053\u4ea4\u754c\uff0c\u80fd\u5438\u5f15\u4eba\u6d41\u76ee\u5149\uff0c\u5177\u5099\u9ad8\u5ee3\u544a\u50f9\u503c\u3002</p>\n<p>\u7b2c\u4e00\u592a\u5e73\u6234\u7dad\u65af\u6295\u8cc7\u90e8\u9996\u5e2d\u8cc7\u6df1\u8463\u4e8b\u6eab\u6b66\u5fe0\u8868\u793a\uff0c\u662f\u6b21\u51fa\u552e\u7684\u7269\u696d\u6700\u65b0\u4f30\u503c\u70ba22\u5104\u5143\uff0c\u9810\u8a08\u6bcf\u6708\u79df\u91d1\u6536\u5165\u7d04500\u842c\u5143\u3002\u5546\u8216\u6a13\u5c64\u7684\u73fe\u79df\u6236\u5305\u62ec\u591a\u9593\u77e5\u540d\u98df\u5e9c\uff0c\u79df\u91d1\u6536\u5165\u7a69\u5b9a\uff0c\u70ba\u8cb7\u5bb6\u63d0\u4f9b\u5373\u6642\u56de\u5831\u3002\u6b64\u5916\uff0c\u4f4d\u65bc\u8ed2\u5c3c\u8a69\u9053\u9023\u540c\u547d\u540d\u6b0a\u4e00\u540c\u51fa\u552e\u7684\u5546\u696d\u5927\u5ec8\u6975\u70ba\u7f55\u898b\uff0c\u6975\u9069\u5408\u4f5c\u70ba\u5927\u578b\u96c6\u5718\u7e3d\u90e8\u53ca\u9577\u7dda\u6536\u79df\u6295\u8cc7\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3950034/%E7%81%A3%E4%BB%94%E8%BB%92%E5%B0%BC%E8%A9%A9%E9%81%93%E5%85%A8%E5%B9%A2%E6%8B%9B%E6%A8%99+%E4%BC%B0%E5%80%BC22%E5%84%84"}]}