f0c\u5305\u62ec63\u4f19\u50f9\u55ae\u53ca5\u4f19\u62db\u6a19\u55ae\u4f4d\uff0c\u5957\u73fe\u903e3.49\u5104\u5143\u3002</p>\n<p>\u4eca\u65e5\u6210\u4ea4\u55ae\u4f4d\u5305\u62ec\u7b2c\u4e09\u5ea71\u6a13D\u55ae\u4f4d\uff0c\u5169\u623f\u958b\u653e\u5f0f\u5eda\u623f\u8a2d\u8a08\uff0c\u5be6\u7528\u9762\u7a4d496\u65b9\u544e\uff0c\u8a2d\u9577\u65b9\u5f62\u5ba2\u5ef3\u76f4\u9023\u5168\u843d\u5730\u73bb\u7483\u8d9f\u9580\u9732\u53f0\uff0c\u4e0d\u4f46\u53ef\u5f15\u666f\u5165\u5ba4\uff0c\u4ea6\u76f4\u9023128\u544e\u6236\u5916\u82b1\u5712\uff0c\u6210\u4ea4\u50f9\u70ba579.4\u842c\u5143\uff0c\u544e\u50f911681\u5143\u3002</p>\n<p>\u9805\u76ee\u5408\u5171\u552e\u51fa117\u4f19\uff0c\u5957\u73fe\u903e5.74\u5104\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3808845/%E5%87%B1%E5%92%8C%E5%B1%B1%E9%80%A3%E6%B2%BD%E5%85%A9%E4%BC%99+%E5%A5%97%E7%8F%BE%E9%80%BE940%E8%90%AC"}, {"title": "\u52a0\u6c99:\u7576\u5730\u5269\u9918\u91ab\u7642\u6a5f\u69cb48\u5c0f\u6642\u5167\u505c\u6b62\u5de5\u4f5c", "description": "<p><span style=\"font-size-ignore:13pt;\">\u52a0\u6c99\u885e\u751f\u90e8\u9580\u901a\u904e\u5176\u793e\u4ea4\u8cec\u865f\u767c\u8868\u8072\u660e\u7a31\uff0c\u5118\u7ba1\u8a72\u90e8\u9580\u5df2\u63a1\u53d6\u4e86\u56b4\u683c\u7684\u63aa\u65bd\u76e1\u53ef\u80fd\u9577\u6642\u9593\u5730\u4fdd\u5b58\u5269\u9918\u71c3\u6599\uff0c\u4f46\u7531\u65bc\u7dad\u6301\u767c\u96fb\u6a5f\u904b\u884c\u6240\u9700\u7684\u71c3\u6599\u5373\u5c07\u8017\u76e1\uff0c\u52a0\u6c99\u5730\u5e36\u5269\u9918\u7684\u91ab\u9662\u3001\u91ab\u7642\u4e2d\u5fc3\u548c\u6c27\u6c23\u7ad9\u5c07\u572848\u5c0f\u6642\u5167\u505c\u6b62\u5de5\u4f5c\u3002</span></p>\n<p>\u8072\u660e\u547c\u7c72\u6240\u6709\u76f8\u95dc\u7684\u570b\u969b\u7d44\u7e54\u548c\u4eba\u9053\u4e3b\u7fa9\u6a5f\u69cb\u8fc5\u901f\u4ecb\u5165\uff0c\u76e1\u5feb\u70ba\u7576\u5730\u63d0\u4f9b\u71c3\u6599\u548c\u7dad\u8b77\u767c\u96fb\u6a5f\u904b\u884c\u6240\u9700\u7684\u914d\u4ef6\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3808843/%E5%8A%A0%E6%B2%99%3A%E7%95%B6%E5%9C%B0%E5%89%A9%E9%A4%98%E9%86%AB%E7%99%82%E6%A9%9F%E6%A7%8B48%E5%B0%8F%E6%99%82%E5%85%A7%E5%81%9C%E6%AD%A2%E5%B7%A5%E4%BD%9C"}, {"title": "\u76e7\u5bf5\u8302:\u9762\u5c0d\u5404\u7a2e\u6311\u6230\u5fc5\u9808\u7e7c\u7e8c\u8b8a\u9769\u6c42\u9032", "description": "<p>\u91ab\u52d9\u885e\u751f\u5c40\u5c40\u9577\u76e7\u5bf5\u8302\u5728\u793e\u4ea4\u5e73\u53f0\u767c\u88687.1\u611f\u8a00\u6642\u7a31\uff0c\u81ea2022\u5e74\u958b\u59cb\uff0c7\u67081\u65e5\u5c0d\u4ed6\u4f86\u8aaa\u5df2\u8ce6\u4e88\u7279\u5225\u610f\u7fa9\u3002\u7576\u570b\u65d7\u548c\u5340\u65d7\u5f90\u5f90\u5347\u8d77\u3001\u7576\u570b\u6b4c\u6a02\u7ae0\u5639\u4eae\u594f\u8d77\uff0c\u540c\u6642\u4ea6\u63d0\u9192\u4ed6\u5169\u5e74\u524d\u63a5\u53d7\u4eba\u751f\u4e2d\u6700\u5149\u69ae\u4efb\u52d9\u6642\u6240\u7acb\u4e0b\u7684\u4f7f\u547d\u3001\u6240\u80cc\u8ca0\u7684\u8cac\u4efb\u3001\u6240\u627f\u8f09\u884c\u653f\u9577\u5b98\u548c\u570b\u5bb6\u5c0d\u4ed6\u7684\u4fe1\u4efb\u3002</p>\n<p>\u4ed6\u51fa\u4efb\u91ab\u52d9\u885e\u751f\u5c40\u5c40\u9577\u6642\uff0c\u7acb\u4e0b\u4e09\u500b\u91cd\u5927\u4f7f\u547d\ufe30\u7b2c\u4e00\uff0c\u5faa\u8b49\u6297\u75ab\uff0c\u70ba\u9999\u6e2f\u9023\u63a5\u570b\u969b\uff0c\u9023\u901a\u5167\u5730\uff1b\u7b2c\u4e8c\uff0c\u512a\u5316\u91ab\u7642\uff0c\u4ee4\u5e02\u6c11\u75c5\u6709\u826f\u91ab\uff1b\u7b2c\u4e09\uff0c\u5275\u51fa\u9999\u6e2f\uff0c\u5145\u5206\u767c\u63ee\u9999\u6e2f\u5728\u91ab\u7642\u885e\u751f\u5404\u65b9\u9762\u7684\u512a\u52e2\uff0c\u63a8\u52d5\u5927\u7063\u5340\u91ab\u7642\u5275\u65b0\u548c\u878d\u5408\u3002\u4e0a\u4efb\u4e4b\u521d\uff0c\u6297\u64ca\u65b0\u51a0\u75ab\u60c5\u662f\u91ab\u52d9\u885e\u751f\u5c40\u5de5\u4f5c\u91cd\u4e2d\u4e4b\u4e2d\u3002\u672c\u5c46\u653f\u5e9c\u958b\u59cb\u5c07\u5404\u9805\u9632\u75ab\u63aa\u65bd\u9678\u7e8c\u5faa\u8b49\u9b06\u7d81\uff0c\u793e\u6703\u6709\u5e8f\u5730\u5fa9\u5e38\u3002\u53bb\u5e743\u67081\u65e5\u8d77\u5168\u9762\u64a4\u92b7\u53e3\u7f69\u4ee4\u5f8c\uff0c\u793e\u6703\u5168\u9762\u5fa9\u5e38\uff0c\u8207\u5167\u5730\u5be6\u73fe\u5168\u9762\u901a\u95dc\uff0c\u8207\u4e16\u754c\u6062\u5fa9\u5168\u9762\u63a5\u8ecc\u3002</p>\n<p>\u76e7\u5bf5\u8302\u6307\u51fa\uff0c\u6210\u529f\u6297\u64ca\u75ab\u60c5\u5f8c\uff0c\u91ab\u885e\u5c40\u5373\u99ac\u4e0d\u505c\u8e44\u63a8\u9032\u591a\u9805\u91ab\u7642\u885e\u751f\u6539\u9769\u653f\u7b56\uff0c\u5305\u62ec\u5168\u529b\u63a8\u5c55\u57fa\u5c64\u91ab\u7642\u5065\u5eb7\u767c\u5c55\uff1b\u63d0\u5347\u53e3\u8154\u5065\u5eb7\u548c\u7cbe\u795e\u5065\u5eb7\uff1b\u63d0\u51fa10\u9805\u63a7\u7159\u653f\u7b56\u4ee5\u4fdd\u8b77\u4e0b\u4e00\u4ee3\u514d\u53d7\u7159\u5bb3\uff1b\u6301\u7e8c\u6539\u5584\u516c\u71df\u91ab\u7642\u670d\u52d9\uff1b\u589e\u52a0\u91ab\u8b77\u4eba\u624b\u4f9b\u61c9\uff0c\u900f\u904e\u4fee\u4f8b\u5f15\u5165\u975e\u672c\u5730\u57f9\u8a13\u91ab\u8b77\uff1b\u63a8\u52d5\u4e2d\u91ab\u85e5\u767c\u5c55\u7b49\u3002</p>\n<p>\u8207\u6b64\u540c\u6642\uff0c\u91ab\u885e\u5c40\u7a4d\u6975\u767c\u5c55\u9999\u6e2f\u6210\u70ba\u570b\u969b\u91ab\u7642\u5275\u65b0\u6a1e\u7d10\u3002\u904e\u53bb\u4e00\u5e74\uff0c\u70ba\u512a\u5316\u73fe\u884c\u7684\u85e5\u7269\u5be9\u6279\u548c\u8a3b\u518a\u5236\u5ea6\uff0c\u4ee5\u5be6\u8e10\u5efa\u7acb\u300c\u7b2c\u4e00\u5c64\u5be9\u6279\u300d\u85e5\u68b0\u8a3b\u518a\u6a5f\u69cb\u7684\u9577\u9060\u76ee\u6a19\uff0c\u5168\u65b9\u4f4d\u4e3b\u52d5\u51fa\u64ca\uff0c\u5305\u62ec\u6210\u70ba\u300c\u570b\u969b\u91ab\u85e5\u6cd5\u898f\u5354\u8abf\u6703\u8b70\u300d\u89c0\u5bdf\u54e1\u3001\u5efa\u7acb\u300c1+\u300d\u85e5\u7269\u5be9\u6279\u6a5f\u5236\u3001\u6210\u7acb\u300c\u9999\u6e2f\u85e5\u7269\u53ca\u91ab\u7642\u5668\u68b0\u76e3\u7763\u7ba1\u7406\u4e2d\u5fc3\u300d\u7c4c\u5099\u8fa6\u516c\u5ba4\uff0c\u4ee5\u53ca\u63a8\u52d5\u5728\u4eca\u5e74\u5167\u6210\u7acb\u300c\u5927\u7063\u5340\u570b\u969b\u81e8\u5e8a\u8a66\u9a57\u6240\u300d\u3002</p>\n<p>\u5728\u5f37\u5316\u8de8\u5883\u91ab\u7642\u5408\u4f5c\u65b9\u9762\uff0c\u91ab\u885e\u5c40\u5728\u904e\u53bb\u4e00\u5e74\u4ea6\u505a\u4e86\u5927\u91cf\u5de5\u4f5c\uff0c\u4f8b\u5982\u64f4\u5927\u9577\u8005\u91ab\u7642\u5238\u7684\u4f7f\u7528\u9ede\u81f3\u5927\u7063\u53407\u9593\u91ab\u7642\u6a5f\u69cb\u3001\u7a4d\u6975\u63a8\u5c55\u5927\u7063\u5340\u8de8\u5883\u76f4\u901a\u6551\u8b77\u8eca\u670d\u52d9\u3001\u63a8\u52d5\u66f4\u591a\u516c\u7acb\u91ab\u9662\u53c3\u8207\u300a\u570b\u969b\u91ab\u9662\u8a55\u5be9\u8a8d\u8b49\u6a19\u6e96(\u4e2d\u570b)\u300b\u8a8d\u8b49\uff0c\u4ee5\u53ca\u4fc3\u9032\u516c\u7acb\u91ab\u9662\u548c\u5167\u5730\u91ab\u8b77\u4eba\u54e1\u4ea4\u6d41\u7b49\u3002</p>\n<p>\u4ed6\u6307\u51fa\uff0c\u56de\u9867\u904e\u53bb\u5169\u5e74\uff0c\u9999\u6e2f\u91ab\u7642\u885e\u751f\u7531\u9000\u5230\u5b88\u3001\u7531\u5b88\u5230\u653b\u3002\u96a8\u7740\u65b0\u51a0\u75ab\u60c5\u53d7\u63a7\uff0c\u9999\u6e2f\u91ab\u7642\u670d\u52d9\u8e0f\u4e0a\u5fa9\u5e38\uff0c\u751a\u81f3\u300c\u8d85\u5e38\u300d\u4e4b\u8def\u3002\u63a8\u5c55\u7684\u591a\u9805\u91ab\u7642\u885e\u751f\u63aa\u65bd\uff0c\u6b63\u7a69\u6b65\u5411\u524d\u9081\u9032\uff0c\u4ea6\u521d\u898b\u6210\u679c\u3002\u4f46\u9762\u5c0d\u79d1\u6280\u9032\u6b65\u3001\u4eba\u53e3\u8001\u5316\u3001\u4eba\u624d\u6d41\u5931\u7b49\u7a2e\u7a2e\u56b4\u5cfb\u6311\u6230\uff0c\u5fc5\u9808\u7e7c\u7e8c\u8b8a\u9769\u6c42\u9032\uff0c\u624d\u80fd\u4fdd\u969c\u9999\u6e2f\u5e02\u6c11\u7684\u5065\u5eb7\u3002</p>\n<p>\u76e7\u5bf5\u8302\u611f\u6fc0\u884c\u653f\u9577\u5b98\u7684\u5e36\u9818\u548c\u5c0d\u4ed6\u7684\u4fe1\u4efb\uff0c\u4e5f\u611f\u8b1d\u7ba1\u6cbb\u5718\u968a\u7684\u652f\u6301\uff1b\u4ed6\u66f4\u8981\u611f\u8b1d\u5728\u904e\u53bb730\u5929\u4e00\u76f4\u8207\u4ed6\u540c\u884c\u7684\u91ab\u885e\u5c40\u3001\u885e\u751f\u7f72\u548c\u91ab\u7ba1\u5c40\u5718\u968a\uff0c\u6cbf\u9014\u6709\u4ed6\u5011\u7684\u652f\u6301\u548c\u4ed8\u51fa\uff0c\u4ee4\u4ed6\u66f4\u6709\u4fe1\u5fc3\u5e36\u9818\u9999\u6e2f\u91ab\u7642\u5728\u7a69\u56fa\u57fa\u790e\u4e0a\u7e7c\u7e8c\u6301\u7e8c\u767c\u5c55\uff0c\u4ee4\u5e02\u6c11\u7372\u5f97\u66f4\u5927\u5e78\u798f\u611f\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3808842/%E7%9B%A7%E5%AF%B5%E8%8C%82%3A%E9%9D%A2%E5%B0%8D%E5%90%84%E7%A8%AE%E6%8C%91%E6%88%B0%E5%BF%85%E9%A0%88%E7%B9%BC%E7%BA%8C%E8%AE%8A%E9%9D%A9%E6%B1%82%E9%80%B2"}, {"title": "\u904b\u8f38\u7f72\u6599\u660e\u65e5\u6709\u8f03\u591a\u8de8\u5883\u65c5\u5ba2\u4f7f\u7528\u9678\u8def\u53e3\u5cb8\u56de\u6e2f", "description": "<p>\u904b\u8f38\u7f72\u8868\u793a\uff0c\u9810\u6599\u660e\u65e5\u5c07\u6709\u8f03\u591a\u8de8\u5883\u65c5\u5ba2\u4f7f\u7528\u9678\u8def\u53e3\u5cb8\u56de\u6e2f\uff0c\u547c\u7c72\u65c5\u5ba2\u9810\u65e9\u59a5\u5584\u898f\u5283\u884c\u7a0b\uff0c\u9810\u7559\u5145\u88d5\u7684\u4ea4\u901a\u6642\u9593\u3002</p>\n<p>\u7f72\u65b9\u9810\u671f\uff0c\u5728\u8fd4\u6e2f\u9ad8\u5cf0\u6642\u9593\u7684\u516c\u5171\u904b\u8f38\u9700\u6c42\u6703\u8f03\u9ad8\uff0c\u4e58\u5ba2\u5019\u8eca\u6642\u9593\u6703\u8f03\u9577\uff0c\u5df2\u6307\u793a\u516c\u5171\u904b\u8f38\u670d\u52d9\u71df\u8fa6\u5546\u52a0\u5f37\u670d\u52d9\uff0c\u61c9\u4ed8\u4e58\u5ba2\u9700\u6c42\u3002\u904b\u8f38\u7f72\u7684\u7dca\u6025\u4ea4\u901a\u4e8b\u6545\u5354\u8abf\u4e2d\u5fc3\u6703\u7e7c\u7e8c\u76e3\u5bdf\u5404\u9678\u8def\u53e3\u5cb8\u7684\u516c\u5171\u904b\u8f38\u670d\u52d9\u60c5\u6cc1\uff0c\u4e26\u6703\u900f\u904e\u904b\u8f38\u7f72\u6d41\u52d5\u61c9\u7528\u7a0b\u5f0f\u300c\u9999\u6e2f\u51fa\u884c\u6613\u300d\u767c\u653e\u6700\u65b0\u7684\u4ea4\u901a\u6d88\u606f\u3002</p>\n<p>\u7f72\u65b9\u6307\u51fa\uff0c\u5e02\u6c11\u53ef\u900f\u904e\u300c\u9999\u6e2f\u51fa\u884c\u6613\u300d\u67e5\u95b1\u6e2f\u73e0\u6fb3\u5927\u6a4b\u9999\u6e2f\u53e3\u5cb8\u51fa\u5883\u53ca\u5165\u5883\u5ba2\u8eca\u901a\u95dc\u5ee3\u5834\u7684\u4ea4\u901a\u5feb\u62cd\uff0c\u4ee5\u53ca\u4f7f\u7528\u300c\u6e2f\u73e0\u6fb3\u5927\u6a4b\u73e0\u6d77\u53e3\u5cb8\u300d\u6216\u300c\u73e0\u6d77\u767c\u5e03\u300d\u5fae\u4fe1\u516c\u773e\u865f\u5167\u7684\u300c\u5927\u6a4b\u53e3\u5cb8\u5be6\u6642\u901a\u95dc\u300d\u670d\u52d9\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3808841/%E9%81%8B%E8%BC%B8%E7%BD%B2%E6%96%99%E6%98%8E%E6%97%A5%E6%9C%89%E8%BC%83%E5%A4%9A%E8%B7%A8%E5%A2%83%E6%97%85%E5%AE%A2%E4%BD%BF%E7%94%A8%E9%99%B8%E8%B7%AF%E5%8F%A3%E5%B2%B8%E5%9B%9E%E6%B8%AF"}]}