e74\u4ee51300\u842c\u5143\u8cfc\u5165\u4e0a\u8ff0\u55ae\u4f4d\uff0c\u662f\u6b21\u79df\u51fa\u53ef\u4eab2.7\u5398\u79df\u91d1\u56de\u5831\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3942586/%E9%A7%BF%E6%99%AF%E5%9C%92%E4%B8%AD%E5%B1%A4%E4%B8%89%E6%88%BF2.9%E8%90%AC%E6%89%BF%E7%A7%9F"}, {"title": "\u6607\u8588\u9ad8\u5c64\u4e00\u623f\u875520\u842c\u8f49\u624b", "description": "<p><span style=\"font-size-ignore:13pt;\">\u6771\u6d8c\u6607\u858810\u5ea7\u9ad8\u5c64G\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d445\u65b9\u544e\uff0c1\u623f\u9593\u9694\uff1b\u958b\u50f9610\u842c\u5143\uff0c\u6e1b\u50f930\u842c\u5143\uff0c\u4ee5580\u842c\u5143\u6cbd\u51fa\uff0c\u5be6\u7528\u544e\u50f913034\u5143\u3002</span></p>\n<p>\u4e2d\u539f\u5730\u7522\u8868\u793a\uff0c\u8cb7\u5bb6\u70ba\u6771\u6d8c\u696d\u4e3b\uff0c\u898b\u6a13\u50f9\u5df2\u91cd\u8fd4\u4f4e\u4f4d\uff0c\u65bc\u662f\u591a\u8cfc\u4e00\u4f19\u81ea\u7528\uff1b\u7747\u6a13\u7d04\u5169\u661f\u671f\uff0c\u898b\u55ae\u4f4d\u6e1b\u50f9\u5e45\u5ea6\u5438\u5f15\uff0c\u5373\u62cd\u677f\u627f\u63a5\u3002</p>\n<p>\u539f\u696d\u4e3b\u65bc2019\u5e7412\u6708\u4ee5600\u842c\u5143\u8cb7\u5165\u4e0a\u8ff0\u55ae\u4f4d\uff0c\u6301\u8ca85\u5e74\uff0c\u73fe\u6cbd\u51fa\u55ae\u4f4d\u8cec\u9762\u8667\u875520\u842c\u5143\u6216\u7d043.3%</p>\n<h3>\u00a0</h3>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3942564/%E6%98%87%E8%96%88%E9%AB%98%E5%B1%A4%E4%B8%80%E6%88%BF%E8%9D%9520%E8%90%AC%E8%BD%89%E6%89%8B"}, {"title": "\u667a\u5eab:\u5167\u5730\u6fc0\u5149\u96f7\u9054\u50b3\u611f\u5668\u6216\u4f7f\u7f8e\u570b\u9632\u8a2d\u5099\u906d\u9ed1\u5ba2\u653b\u64ca", "description": "<p>\u8def\u900f\u5831\u9053\uff0c\u83ef\u76db\u9813\u667a\u5eab\u7684\u5831\u544a\u7a31\uff0c\u4e2d\u570b\u88fd\u9020\u7684\u6fc0\u5149\u96f7\u9054\u50b3\u611f\u5668\u53ef\u80fd\u4f7f\u7f8e\u570b\u8ecd\u65b9\u5728\u885d\u7a81\u671f\u9593\u906d\u5230\u9ed1\u5ba2\u653b\u64ca\u548c\u7834\u58de\u3002\u5831\u544a\u4e26\u547c\u7c72\u7981\u6b62\u5c07\u9019\u4e9b\u50b3\u611f\u5668\u5b89\u88dd\u5230\u7f8e\u570b\u570b\u9632\u8a2d\u5099\u4e2d\u3002</p>\n<p>\u6fc0\u5149\u96f7\u9054\u50b3\u611f\u5668\u4f7f\u7528\u6fc0\u5149\u751f\u6210\u5468\u908a\u74b0\u5883\u7684\u6578\u5b57\u4e09\u7dad\u5730\u5716\u3002\u96d6\u7136\u5b83\u5011\u6700\u5e38\u7528\u65bc\u6c7d\u8eca\u884c\u696d\u7684\u8f14\u52a9\u99d5\u99db\u7cfb\u7d71\uff0c\u4f46\u4e5f\u7528\u65bc\u6e2f\u53e3\u7b49\u95dc\u9375\u57fa\u790e\u8a2d\u65bd\uff0c\u5e6b\u52a9\u5be6\u73fe\u8d77\u91cd\u6a5f\u7684\u81ea\u52d5\u5316\u3002<span style=\"font-size-ignore:13pt;\">\u7f8e\u570b\u8ecd\u65b9\u4e5f\u5728\u8003\u616e\u5982\u4f55\u5c07\u9019\u9805\u6280\u8853\u61c9\u7528\u65bc\u81ea\u52d5\u99d5\u99db\u8ecd\u7528\u8eca\u8f1b\u3002\u4f46\u4fdd\u885e\u6c11\u4e3b\u57fa\u91d1\u6703(Foundation for Defense of Democracies, FDD)\u5728\u5831\u544a\u4e2d\u8868\u793a\uff0c\u901a\u5e38\u9023\u63a5\u5230\u4e92\u806f\u7db2\u7684\u6fc0\u5149\u96f7\u9054\u50b3\u611f\u5668\u4f7f\u7528\u5148\u9032\u7684\u8655\u7406\u5668\uff0c\u53ef\u4ee5\u96b1\u85cf\u96e3\u4ee5\u6aa2\u6e2c\u7684\u60e1\u610f\u4ee3\u78bc\u6216\u56fa\u4ef6\u5f8c\u9580\u3002</span></p>\n<p>\u8a72\u57fa\u91d1\u6703\u8a8d\u70ba\uff0c\u57fa\u65bc\u885e\u661f\u7684\u6fc0\u5149\u96f7\u9054\u7cfb\u7d71\u9084\u53ef\u7528\u65bc\u5728\u4e0d\u5230\u4e00\u79d2\u6642\u9593\u5167\u5728\u7f8e\u570b\u5927\u7247\u9818\u571f\u4e0a\u89f8\u767c\u6216\u7981\u7528\u6b64\u985e\u50b3\u611f\u5668\u3002<span style=\"font-size-ignore:13pt;\">\u96d6\u7136\u4e2d\u570b\u7684\u6fc0\u5149\u96f7\u9054\u50b3\u611f\u5668\u53ef\u80fd\u66f4\u4fbf\u5b9c\uff0c\u4f46\u7834\u58de\u548c\u76e3\u8996\u7684\u9577\u671f\u6210\u672c\u986f\u7136\u9060\u9060\u8d85\u904e\u7bc0\u7701\u7684\u6210\u672c\u3002</span></p>\n<p>\u8a72\u57fa\u91d1\u6703\u5efa\u8b70\u7f8e\u570b\u8b70\u54e1\u7981\u6b62\u63a1\u8cfc\u4e2d\u570b\u6fc0\u5149\u96f7\u9054\u7528\u65bc\u570b\u9632\u88dd\u5099\uff0c\u4e26\u5efa\u8b70\u7f8e\u570b\u5404\u5dde\u653f\u5e9c\u7981\u6b62\u5728\u95dc\u9375\u57fa\u790e\u8a2d\u65bd\u4e2d\u4f7f\u7528\u4e2d\u570b\u6fc0\u5149\u96f7\u9054\u3002\u8a72\u667a\u5eab\u9084\u5efa\u8b70\u7f8e\u570b\u6c7a\u7b56\u8005\u8207\u5fb7\u570b\u3001\u52a0\u62ff\u5927\u3001\u97d3\u570b\u3001\u4ee5\u8272\u5217\u548c\u65e5\u672c\u7b49\u76df\u570b\u5408\u4f5c\uff0c\u6253\u9020\u4e00\u689d\u66ff\u4ee3\u4e2d\u570b\u6fc0\u5149\u96f7\u9054\u7684\u4f9b\u61c9\u93c8\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3944073/%E6%99%BA%E5%BA%AB%3A%E5%85%A7%E5%9C%B0%E6%BF%80%E5%85%89%E9%9B%B7%E9%81%94%E5%82%B3%E6%84%9F%E5%99%A8%E6%88%96%E4%BD%BF%E7%BE%8E%E5%9C%8B%E9%98%B2%E8%A8%AD%E5%82%99%E9%81%AD%E9%BB%91%E5%AE%A2%E6%94%BB%E6%93%8A"}, {"title": "YOHO WEST\u5169\u623f\u4e0d\u8db3\u4e00\u5e74\u8cfa14.2\u842c\u6cbd", "description": "<p><span style=\"font-size-ignore:13pt;\">\u5929\u6c34\u570dYOHO WEST\u00a02B\u5ea7\u4f4e\u5c64B7\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d415\u65b9\u544e\uff0c2\u623f\u9593\u9694\u3002\u55ae\u4f4d\u539f\u5148\u53eb\u50f9475\u842c\u5143\u653e\u552e\uff0c\u53ca\u5f8c\u6e1b\u50f910\u842c\u5143\uff1b\u7372\u540c\u5340\u5206\u652f\u5bb6\u5ead\u4ee5465\u842c\u5143\u627f\u63a5\uff0c\u5be6\u7528\u544e\u50f911205\u5143\u3002</span></p>\n<p>\u7f8e\u806f\u7269\u696d\u8868\u793a\uff0c\u7531\u65bc\u65b0\u8cb7\u5bb6\u5fc3\u5100\u6a13\u76e4\u4f4d\u65bc\u5e02\u4e2d\u5fc3\u4f4d\u7f6e\uff0c\u4e14\u9130\u8fd1\u5546\u5834\u8eca\u7ad9\uff1b\u52a0\u4e0a\u5bb6\u4eba\u4ea6\u5c45\u65bc\u9644\u8fd1\u65b9\u4fbf\u7167\u9867\uff0c\u6545\u7121\u7747\u6a13\u4e0b\u8cfc\u5165\u7269\u696d\u3002</p>\n<p>\u539f\u696d\u4e3b2023\u5e7412\u6708\u4ee5450.8\u842c\u5143\u8cfc\u5165\u4e0a\u8ff0\u55ae\u4f4d\uff0c\u6301\u8ca8\u4e0d\u8db31\u5e74\u8f49\u624b\uff0c\u8cec\u9762\u7372\u5229\u7d0414.2\u842c\u5143\u6216\u7d043.1%\u3002</p>\n<p>\u00a0</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3942284/YOHO+WEST%E5%85%A9%E6%88%BF%E4%B8%8D%E8%B6%B3%E4%B8%80%E5%B9%B4%E8%B3%BA14.2%E8%90%AC%E6%B2%BD"}]}