com/instantnews/hongkong/article/3909634/%E4%BF%A1%E9%8A%80%E5%9C%8B%E9%9A%9B%3A%E5%B7%B2%E7%8E%87%E5%85%88%E7%82%BA%E7%89%B9%E9%81%B8%E5%80%8B%E4%BA%BA%E5%AE%A2%E6%88%B6%E5%95%9F%E5%8B%95%E6%88%B6%E5%8F%A3%E4%BA%92%E8%81%AF"}, {"title": "\u7ff9\u7fe0\u5cf0\u9ad8\u5c64\u4e09\u623f663\u842c\u6613\u4e3b", "description": "<p>\u5143\u6717\u7ff9\u7fe0\u5cf05\u5ea7\u9ad8\u5c64F\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d667\u65b9\u544e\uff0c3\u623f\u9593\u9694\uff0c\u958b\u50f9700\u842c\u5143\uff0c\u8b70\u50f9\u5f8c\u4ee5663\u842c\u5143\u6210\u4ea4\uff0c\u5be6\u7528\u544e\u50f99940\u5143\u3002</p>\n<p>\u4e2d\u539f\u5730\u7522\u8868\u793a\uff0c\u8cb7\u5bb6\u70ba\u5340\u5167\u5bb6\u5ead\uff0c\u4e00\u76f4\u79df\u6a13\uff0c\u56e0\u70ba\u60f3\u5c0f\u670b\u53cb\u65bc\u56fa\u5b9a\u5c45\u6240\u6210\u9577\uff0c\u6c7a\u5b9a\u81ea\u7f6e\u7269\u696d\u3002</p>\n<p>\u539f\u696d\u4e3b\u65bc2012\u5e749\u6708\u4ee5445\u842c\u5143\u8cb7\u5165\u55ae\u4f4d\uff0c\u6301\u8ca812\u5e74\uff0c\u8cec\u9762\u8cfa218\u842c\u5143\u621649%\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3909447/%E7%BF%B9%E7%BF%A0%E5%B3%B0%E9%AB%98%E5%B1%A4%E4%B8%89%E6%88%BF663%E8%90%AC%E6%98%93%E4%B8%BB"}]}