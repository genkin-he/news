1\u8b66\u544a\u4ee5\u8272\u5217\u4e0d\u8981\u653b\u64ca\u4f0a\u6717\u6838\u8a2d\u65bd", "description": "<p>\u4fc4\u7f85\u65af\u5854\u65af\u793e(Tass)\u5f15\u8ff0\u4fc4\u7f85\u65af\u526f\u5916\u9577\u91cc\u4e9e\u5e03\u79d1\u592b(Sergei Ryabkov)\u8a00\u8ad6\u7a31\uff0c\u4fc4\u7f85\u65af\u8b66\u544a\u4ee5\u8272\u5217\u4e0d\u8981\u5c0d\u4f0a\u6717\u6838\u8a2d\u65bd\u767c\u52d5\u4efb\u4f55\u6253\u64ca\u3002</p>\n<p>\u76ee\u524d\u5c1a\u4e0d\u6e05\u695a\u83ab\u65af\u79d1\u662f\u4ee5\u4f55\u7a2e\u5f62\u5f0f\u767c\u51fa\u9019\u4e00\u8b66\u544a\u3002</p>\n<p>\u5728\u4f0a\u6717\u65bc10\u67081\u65e5\u5c0d\u4ee5\u8272\u5217\u767c\u52d5\u5c0e\u5f48\u8972\u64ca\u5f8c\uff0c\u5916\u754c\u7d1b\u7d1b\u731c\u6e2c\u4ee5\u8272\u5217\u53ef\u80fd\u6703\u6253\u64ca\u4f0a\u6717\u7684\u6838\u8a2d\u65bd\uff0c\u56e0\u70ba\u4ee5\u8272\u5217\u9577\u671f\u4ee5\u4f86\u4e00\u76f4\u5a01\u8105\u8981\u9019\u6a23\u505a\u3002</p>\n<p>\u4ee5\u8272\u5217\u7e3d\u7406\u5167\u5854\u5c3c\u4e9e\u80e1\u7684\u8fa6\u516c\u5ba4\u5468\u4e8c\u5728\u8072\u660e\u4e2d\u8868\u793a\uff0c\u4ee5\u8272\u5217\u6703\u807d\u53d6\u7f8e\u570b\u7684\u610f\u898b\uff0c\u4f46\u5c07\u6839\u64da\u81ea\u5df1\u7684\u570b\u5bb6\u5229\u76ca\u81ea\u884c\u505a\u51fa\u6c7a\u5b9a\u3002</p>\n<p>\u9019\u4efd\u8072\u660e\u9644\u5728\u300a\u83ef\u76db\u9813\u90f5\u5831\u300b\u7684\u4e00\u7bc7\u6587\u7ae0\u4e4b\u5f8c\uff0c\u6587\u7ae0\u4e2d\u8868\u793a\u5167\u5854\u5c3c\u4e9e\u80e1\u5df2\u544a\u77e5\u62dc\u767b\u653f\u5e9c\uff0c\u4ee5\u8272\u5217\u5c07\u6253\u64ca\u4f0a\u6717\u7684\u8ecd\u4e8b\u76ee\u6a19\uff0c\u800c\u975e\u6838\u6216\u77f3\u6cb9\u76ee\u6a19\u3002</p>\n<p>\u4fc4\u7f85\u65af\u570b\u5bb6\u5a92\u9ad4\u5f15\u8ff0\u91cc\u4e9e\u5e03\u79d1\u592b\u7684\u8a71\u8aaa\uff0c\u7121\u8ad6\u8a72\u5730\u5340\u7684\u7dca\u5f35\u5c40\u52e2\u5982\u4f55\uff0c\u83ab\u65af\u79d1\u90fd\u8207\u4f0a\u6717\u4fdd\u6301\u806f\u7e6b\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3905903/%E4%BF%84%E7%BE%85%E6%96%AF%E6%93%9A%E5%A0%B1%E8%AD%A6%E5%91%8A%E4%BB%A5%E8%89%B2%E5%88%97%E4%B8%8D%E8%A6%81%E6%94%BB%E6%93%8A%E4%BC%8A%E6%9C%97%E6%A0%B8%E8%A8%AD%E6%96%BD"}, {"title": "\u7f8e\u570b9\u6708\u96f6\u552e\u92b7\u552e\u589e0.4% \u9ad8\u9810\u671f", "description": "<p>\u7f8e\u570b9\u6708\u96f6\u552e\u92b7\u552e\u6309\u6708\u589e\u52a00.4%\uff0c\u9810\u671f\u70ba\u53470.3%\u3002</p>\n<p>\u671f\u5167\uff0c\u6263\u9664\u6c7d\u8eca\u7684\u96f6\u552e\u92b7\u552e\u6309\u6708\u589e\u52a00.5%\uff0c\u9810\u671f\u70ba\u53470.1%\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3905905/%E7%BE%8E%E5%9C%8B9%E6%9C%88%E9%9B%B6%E5%94%AE%E9%8A%B7%E5%94%AE%E5%A2%9E0.4%25+%E9%AB%98%E9%A0%90%E6%9C%9F"}, {"title": "\u516d\u798f\u96c6\u5718\u7b2c\u4e8c\u5b63\u540c\u5e97\u92b7\u552e\u8dcc35%", "description": "<p>\u516d\u798f\u96c6\u5718(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00590' >00590</a>)\u516c\u5e03\uff0c\u622a\u81f3\u4eca\u5e749\u6708\u5e95\u6b62\uff0c\u7b2c\u4e8c\u5b63\u540c\u5e97\u92b7\u552e\u6309\u5e74\u8dcc35%\uff0c\u6574\u9ad4\u96f6\u552e\u6536\u5165\u8dcc25%\u3002</p>\n<p>\u671f\u5167\uff0c\u6e2f\u6fb3\u5e02\u5834\u7b2c\u4e8c\u5b63\u7684\u6574\u9ad4\u96f6\u552e\u6536\u5165\u6309\u5e74\u9304\u5f9731%\u8dcc\u5e45\uff0c\u540c\u5e97\u92b7\u552e\u8dcc38%\uff1b\u5176\u4e2d\uff0c\u9999\u6e2f\u7684\u540c\u5e97\u92b7\u552e\u6e1b\u5c1136%\uff0c\u6fb3\u9580\u5247\u8dcc42%\u3002</p>\n<p>\u5167\u5730\u5b8f\u89c0\u7d93\u6fdf\u4ecd\u7136\u75b2\u5f31\uff0c\u52a0\u4e0a\u91d1\u50f9\u6301\u7e8c\u7834\u9802\uff0c\u5167\u5730\u5e97\u8216\u5728\u7b2c\u4e8c\u5b63\u7684\u6574\u9ad4\u96f6\u552e\u503c\u6309\u5e74\u8dcc13%\u3002\u5167\u5730\u96f6\u552e\u6536\u5165(\u5305\u542b\u81ea\u71df\u5e97\u53ca\u96fb\u5b50\u5546\u52d9\u696d\u52d9\u7684\u92b7\u552e\u91d1\u984d)\u6309\u5e74\u8dcc\u8fd19%\u3002\u5728\u9ad8\u57fa\u6578\u6548\u61c9\u53ca\u91d1\u50f9\u9ad8\u4f01\u4e0b\uff0c\u5167\u5730\u96fb\u5b50\u5546\u52d9\u696d\u52d9\u7b2c\u4e8c\u5b63\u7684\u92b7\u552e\u984d\u4e0b\u8dcc25%\u3002\u5167\u5730\u81ea\u71df\u5e97\u6574\u9ad4\u540c\u5e97\u92b7\u552e\u8dcc29%\u3002</p>\n<p>\u65bc9\u6708\u5e95\uff0c\u96c6\u5718\u5168\u7403\u5171\u67093408\u9593\u5e97\u8216\uff0c\u65bc\u7b2c\u4e8c\u5b63\u6de8\u6e1b\u5c1176\u9593\u5e97\u8216\u3002\u96c6\u5718\u5168\u7403\u5171\u6709151\u9593\u300c\u516d\u798f\u300d\u81ea\u71df\u5e97\uff0c\u5305\u62ec73\u9593\u8a2d\u65bc\u5167\u5730\u300150\u9593\u8a2d\u65bc\u9999\u6e2f\u300117\u9593\u8a2d\u65bc\u6fb3\u9580\u53ca11\u9593\u8a2d\u65bc\u6d77\u5916\u3002\u65bc\u4e0a\u8ff0\u65e5\u671f\uff0c\u9023\u540c2769\u9593\u5167\u5730\u53ca11\u9593\u6d77\u5916\u54c1\u724c\u5e97\uff0c\u96c6\u5718\u5728\u4e16\u754c\u5404\u5730\u5408\u5171\u8a2d\u67092931\u9593\u300c\u516d\u798f\u300d\u5e97\u8216\u3002</p>\n<p>\u9664\u6b64\u4e4b\u5916\uff0c\u96c6\u5718\u5168\u7403\u5171\u670985\u9593\u300c\u91d1\u81f3\u5c0a\u300d\u81ea\u71df\u5e97\uff0c\u5305\u62ec79\u9593\u8a2d\u65bc\u5167\u5730\u30015\u9593\u8a2d\u65bc\u9999\u6e2f\u53ca1\u9593\u8a2d\u65bc\u6fb3\u9580\u3002</p>\n<p>\u5c55\u671b\u65b9\u9762\uff0c\u5167\u5730\u5e02\u5834(\u5305\u542b\u81ea\u71df\u5e97\u53ca\u54c1\u724c\u5e97)\u53ca\u9999\u6e2f\u5e02\u5834\u7684\u540c\u5e97\u92b7\u552e\u8dcc\u5e45\u81ea9\u6708\u8d77\u958b\u59cb\u6536\u7a84\u3002\u65bc\u672c\u67081\u65e5\u81f314\u65e5\u671f\u9593\uff0c\u96c6\u5718\u6574\u9ad4\u7684\u540c\u5e97\u92b7\u552e\u8868\u73fe\u8f03\u7b2c\u4e8c\u5b63\u56e0\u6b64\u7565\u6709\u6539\u5584\u3002\u77ed\u671f\u91d1\u50f9\u6025\u5347\u96d6\u7136\u6703\u5f71\u97ff\u92b7\u552e\uff0c\u4f46\u6bdb\u5229\u7387\u7684\u63d0\u5347\u5c07\u6709\u52a9\u6e1b\u4f4e\u92b7\u552e\u4e0b\u8dcc\u7684\u5f71\u97ff\u3002</p>\n<p>\u5167\u5730\u653f\u5e9c\u6b63\u7740\u529b\u4fc3\u9032\u5167\u9700\uff0c\u4e26\u63a8\u51fa\u591a\u9805\u653f\u7b56\u6276\u6301\u6a13\u5e02\u53ca\u8cc7\u672c\u5e02\u5834\u3002\u671f\u671b\u5728\u5b8f\u89c0\u7d93\u6fdf\u53ca\u96f6\u552e\u6c23\u6c1b\u6062\u5fa9\u4e0b\uff0c\u96f6\u552e\u696d\u52d9\u5f97\u4ee5\u91cd\u62fe\u5347\u8ecc\uff0c\u96c6\u5718\u56e0\u6b64\u5c0d\u65bc\u4e2d\u9577\u7dda\u696d\u52d9\u524d\u666f\u4ecd\u611f\u6a02\u89c0\uff0c\u672a\u4f86\u4ecd\u5c07\u6703\u64f4\u5c55\u5167\u5730\u5e02\u5834\u3002</p>\n<p>\u96c6\u5718\u770b\u597d\u6d77\u5916\u5e02\u5834\u7684\u9f90\u5927\u767c\u5c55\u6f5b\u529b\uff0c\u5c07\u6295\u653e\u66f4\u591a\u8cc7\u6e90\u7a4d\u6975\u62d3\u5c55\u6d77\u5916\u5e02\u5834\uff0c\u4e26\u8a08\u5283\u65bc\u5e74\u5167\u5728\u6d77\u5916\u5e02\u5834\u6de8\u589e\u9577\u7d0415\u9593\u5e97\u8216\u3002\u5728\u4f4e\u57fa\u6578\u6548\u61c9\u4e0b\uff0c\u96c6\u5718\u671f\u671b\u4e0b\u534a\u8ca1\u5e74\u6709\u8f03\u4f73\u92b7\u552e\u8868\u73fe\u3002</p>   </div>\n<p></p>\n<div class=\"hkej_hkex_notice_dl_btn_2014\">\n<a href=\"https://www1.hkexnews.hk/listedco/listconews/sehk/2024/1017/2024101700974_c.pdf\" target=\"_blank\">\u4e0b\u8f09\u6e2f\u4ea4\u6240\u901a\u544a\u539f\u6587</a>\n</div>\n        ", "link": "https://www2.hkej.com/instantnews/announcement/article/3905896/%E5%85%AD%E7%A6%8F%E9%9B%86%E5%9C%98%E7%AC%AC%E4%BA%8C%E5%AD%A3%E5%90%8C%E5%BA%97%E9%8A%B7%E5%94%AE%E8%B7%8C35%25"}]}