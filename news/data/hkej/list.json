e5\u8cc7\u7387\u6309\u5e74\u53471.5%\u3002</p>\n<p>\u6263\u9664\u4ee5\u7d9c\u5408\u6d88\u8cbb\u7269\u50f9\u6307\u6578\u8a08\u7b97\u7684\u6d88\u8cbb\u7269\u50f9\u8b8a\u52d5\u7684\u56e0\u7d20\u5f8c\uff0c\u7b2c\u4e00\u5b63\u7684\u5c31\u696d\u4eba\u58eb\u5be6\u8cea\u5e73\u5747\u85aa\u91d1\u6309\u5e74\u4e0a\u53471.8%\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3805831/%E6%B8%AF3%E6%9C%88%E5%B9%B3%E5%9D%87%E5%B7%A5%E8%B3%87%E7%8E%87%E5%8D%873.9%25"}, {"title": "\u200b\u653f\u5e9c\u7c72\u4e03\u4e00\u9577\u5468\u672b\u9810\u65e9\u898f\u5283\u7d93\u6e2f\u73e0\u6fb3\u6a4b\u884c\u7a0b", "description": "<p>\u653f\u5e9c\u8868\u793a\uff0c\u4e03\u4e00\u5047\u671f\u9577\u5468\u672b\u671f\u9593\uff0c\u6216\u6703\u6709\u5927\u91cf\u5e02\u6c11\u7d93\u5404\u9678\u8def\u7ba1\u5236\u7ad9\u5f80\u4f86\u5167\u5730\u6216\u6fb3\u9580\uff0c\u904b\u8f38\u7f72\u6703\u5bc6\u5207\u7559\u610f\u5404\u53e3\u5cb8\u7684\u4ea4\u901a\u60c5\u6cc1\uff0c\u5c24\u5176\u52a0\u5f37\u5411\u4f7f\u7528\u6e2f\u73e0\u6fb3\u5927\u6a4b\u4f86\u5f80\u4e09\u5730\u7684\u5e02\u6c11\u767c\u653e\u6700\u65b0\u4ea4\u901a\u6d88\u606f\uff0c\u547c\u7c72\u53ca\u65e9\u898f\u5283\u884c\u7a0b\uff0c\u76e1\u91cf\u9078\u64c7\u932f\u5cf0\u51fa\u884c\u3002</p>\n<p>\u904b\u8f38\u7f72\u5df2\u5728\u5404\u9678\u8def\u7ba1\u5236\u7ad9\u4f5c\u51fa\u76f8\u61c9\u7684\u4ea4\u901a\u53ca\u904b\u8f38\u5b89\u6392\uff0c\u5176\u7dca\u6025\u4e8b\u6545\u4ea4\u901a\u5354\u8abf\u4e2d\u5fc3\u670324\u5c0f\u6642\u76e3\u5bdf\u53e3\u5cb8\u53ca\u4e3b\u8981\u8eca\u7ad9\u7684\u4ea4\u901a\u60c5\u6cc1\uff0c\u9069\u6642\u4f5c\u51fa\u61c9\u5c0d\u63aa\u65bd\uff0c\u4e26\u6703\u900f\u904e\u4e0d\u540c\u6e20\u9053\uff0c\u5305\u62ec\u96fb\u53f0\u5ee3\u64ad\u3001\u904b\u8f38\u7f72\u624b\u6a5f\u61c9\u7528\u7a0b\u5f0f\u300c\u9999\u6e2f\u51fa\u884c\u6613\u300d\u548c\u904b\u8f38\u7f72\u7db2\u9801\u767c\u653e\u6700\u65b0\u4ea4\u901a\u8cc7\u8a0a\u3002</p>\n<p>\u7f72\u65b9\u9810\u8a08\u660e\u65e5\u53ca\u4e0b\u5468\u4e00\u5c07\u5206\u5225\u6709\u8f03\u591a\u8de8\u5883\u8eca\u8f1b\u4f7f\u7528\u5927\u6a4b\u96e2\u6e2f\u53ca\u56de\u6e2f\uff0c\u5c07\u5bc6\u5207\u7559\u610f\u5927\u6a4b\u7684\u904b\u4f5c\uff0c\u5c24\u5176\u5728\u7e41\u5fd9\u6642\u6bb5\u5927\u6a4b\u53e3\u5cb8\u7684\u901a\u95dc\u548c\u4ea4\u901a\u60c5\u6cc1\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3805830/%E2%80%8B%E6%94%BF%E5%BA%9C%E7%B1%B2%E4%B8%83%E4%B8%80%E9%95%B7%E5%91%A8%E6%9C%AB%E9%A0%90%E6%97%A9%E8%A6%8F%E5%8A%83%E7%B6%93%E6%B8%AF%E7%8F%A0%E6%BE%B3%E6%A9%8B%E8%A1%8C%E7%A8%8B"}, {"title": "\u623f\u5c4b\u5c40:\u7c21\u7d04\u516c\u5c4b\u63a55800\u4efd\u7533\u8acb \u60c5\u6cc1\u8e34\u8e8d", "description": "<p>\u7c21\u7d04\u516c\u5c4b\u65bc\u672c\u5468\u4e00(24\u65e5)\u8d77\u958b\u59cb\u63a5\u53d7\u7533\u8acb\uff0c\u622a\u81f3\u4eca\u65e5\u4e0b\u53483\u6642\uff0c\u5df2\u6536\u5230\u7d045800\u4efd\u7533\u8acb\u3002</p>\n<p>\u7f72\u7406\u623f\u5c4b\u5c40\u5c40\u9577\u6234\u5c1a\u8aa0\u8207\u7d0460\u540d\u6709\u610f\u4e86\u89e3\u548c\u7533\u8acb\u5e02\u6c11\u4e0b\u5348\u4e00\u8d77\u53c3\u89c0\u4f4d\u65bc\u725b\u982d\u89d2\u5f69\u8208\u8def\u7684\u6a23\u677f\u55ae\u4f4d\uff0c\u5be6\u5730\u4e86\u89e3\u55ae\u4f4d\u7684\u8a2d\u8a08\u548c\u57fa\u672c\u914d\u5099\uff0c\u4ee5\u53ca\u9805\u76ee\u672a\u4f86\u7684\u914d\u5957\u8a2d\u65bd\u3002</p>\n<p>\u6234\u5c1a\u8aa0\u8868\u793a\uff0c\u7c21\u7d04\u516c\u5c4b\u7533\u8acb\u60c5\u6cc1\u8e34\u8e8d\uff0c\u74b0\u5883\u53ca\u914d\u5957\u5747\u9060\u52dd\u74b0\u5883\u60e1\u52a3\u7684\u4e0d\u9069\u5207\u5c45\u6240\uff0c\u9996\u6279\u5169\u500b\u9805\u76ee\u6db5\u84cb\u5e02\u5340\u53ca\u64f4\u5c55\u5e02\u5340\u65b0\u754c\uff0c\u5404\u6709\u512a\u9ede\u800c\u4e14\u79df\u91d1\u76f8\u5b9c\uff0c\u9f13\u52f5\u6709\u9700\u8981\u4e26\u5408\u8cc7\u683c\u7684\u5e02\u6c11\u628a\u63e1\u6a5f\u6703\uff0c\u76e1\u5feb\u63d0\u51fa\u7533\u8acb\uff0c\u8b93\u81ea\u5df1\u53ca\u5bb6\u4eba\u6709\u6a5f\u6703\u53ef\u4ee5\u6539\u5584\u751f\u6d3b\u74b0\u5883\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3805822/%E6%88%BF%E5%B1%8B%E5%B1%80%3A%E7%B0%A1%E7%B4%84%E5%85%AC%E5%B1%8B%E6%8E%A55800%E4%BB%BD%E7%94%B3%E8%AB%8B+%E6%83%85%E6%B3%81%E8%B8%B4%E8%BA%8D"}, {"title": "\u6d77\u95dc\u78343\u5b97\u5229\u7528\u9060\u6d0b\u8239\u8d70\u79c1\u6848 \u6aa2\u503c1\u5104\u96fb\u5b50\u8ca8\u7269", "description": "<p><span style=\"font-size-ignore:13pt;\">\u6d77\u95dc\u65bc6\u6708\u5c55\u958b\u4ee3\u865f\u300c\u5de8\u6d6a\u300d\u7684\u7279\u5225\u884c\u52d5\uff0c\u5075\u78343\u5b97\u6d89\u5acc\u5229\u7528\u9060\u6d0b\u8239\u8d70\u79c1\u7684\u6848\u4ef6\uff0c\u4e26\u6aa2\u7372\u5927\u6279\u61f7\u7591\u8d70\u79c1\u8ca8\u7269\uff0c\u4f30\u8a08\u5e02\u503c\u5171\u7d041\u5104\u5143\u3002</span></p>\n<p>\u6d77\u95dc\u900f\u904e\u60c5\u5831\u5206\u6790\u53ca\u98a8\u96aa\u8a55\u4f30\uff0c\u767c\u73fe\u4e0d\u6cd5\u5206\u5b50\u610f\u5716\u5229\u7528\u9060\u6d0b\u8239\u8d70\u79c1\u8ca8\u7269\uff0c\u9042\u90e8\u7f72\u7b56\u7565\uff0c\u9396\u5b9a3\u500b\u7531\u9999\u6e2f\u904b\u5f80\u99ac\u4f86\u897f\u4e9e\u7684\u53ef\u7591\u8ca8\u6ac3\u9032\u884c\u67e5\u9a57\u3002</p>\n<p>\u7d93\u6aa2\u67e5\u5f8c\uff0c\u6d77\u95dc\u4eba\u54e1\u5728\u8a723\u500b\u5206\u5225\u5831\u7a31\u8f09\u6709\u92c1\u7247\u3001\u92c1\u5408\u91d1\u53ca\u901a\u8a0a\u914d\u4ef6\u7684\u8ca8\u6ac3\u5167\u6aa2\u7372\u5927\u6279\u61f7\u7591\u8d70\u79c1\u96fb\u5b50\u8ca8\u7269\uff0c\u5305\u62ec\u96fb\u8def\u677f\u3001\u667a\u80fd\u96fb\u8a71\u3001\u5e73\u677f\u96fb\u8166\u53ca\u6c7d\u8eca\u96f6\u4ef6\u3002</p>\n<p>\u7d93\u8ddf\u9032\u8abf\u67e5\u5f8c\uff0c\u6d77\u95dc\u4eba\u54e1\u62d8\u6355\u4e00\u540d\u61f7\u7591\u8207\u4e0a\u8ff0\u5176\u4e2d\u4e00\u5b97\u6848\u4ef6\u6709\u95dc\u768460\u6b72\u7537\u5b50\u3002\u6848\u4ef6\u4ecd\u5728\u8abf\u67e5\u4e2d\uff0c\u8a72\u540d\u88ab\u6355\u7537\u5b50\u73fe\u6b63\u4fdd\u91cb\u5019\u67e5\uff0c\u4e0d\u6392\u9664\u6703\u6709\u66f4\u591a\u4eba\u88ab\u6355\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3805829/%E6%B5%B7%E9%97%9C%E7%A0%B43%E5%AE%97%E5%88%A9%E7%94%A8%E9%81%A0%E6%B4%8B%E8%88%B9%E8%B5%B0%E7%A7%81%E6%A1%88+%E6%AA%A2%E5%80%BC1%E5%84%84%E9%9B%BB%E5%AD%90%E8%B2%A8%E7%89%A9"}]}