ff0c\u4f46\u7f8e\u5143\u514c\u65e5\u5713\u5f37\u52e2\u5728\u4e00\u6bb5\u6642\u9593\u5167\u9810\u6599\u4fdd\u6301\u4e0d\u8b8a\u3002</p>\n<p>\u53e6\u5916\uff0c\u6b50\u7f85\u66fe\u53470.74%\uff0c\u81f31.0767\u7f8e\u5143\u3002\u6cd5\u570b\u6975\u53f3\u7684\u570b\u6c11\u806f\u76df(National Rally)\u5728\u570b\u6c11\u8b70\u6703\u9996\u56de\u5408\u7684\u5f97\u7968\u7387\u4f54\u9996\u4f4d\uff0c\u4f46\u6bd4\u7387\u8f03\u9810\u671f\u4f4e\uff0c\u52a0\u4e0a\u5de6\u6d3e\u53ca\u4e2d\u9593\u6d3e\u63da\u8a00\u5408\u529b\u963b\u6b62\u570b\u6c11\u806f\u76df\u53d6\u5f97\u570b\u6703\u63a7\u5236\u6b0a\uff0c\u5e02\u5834\u5c0d\u6b50\u6d32\u653f\u5c40\u7684\u6182\u616e\u60c5\u7dd2\u8da8\u5411\u7d13\u7de9\uff0c\u5229\u597d\u6b50\u7f85\u6ed9\u50f9\u3002</p>\n<p>\u82f1\u938a\u6ed9\u50f9\u5927\u81f4\u6301\u7a69\uff0c\u58311.2643\u7f8e\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3809492/%E5%9C%93%E6%BB%99%E5%86%8D%E5%89%B538%E5%B9%B4%E6%96%B0%E4%BD%8E+%E6%AD%90%E7%BE%85%E5%91%88%E5%BC%B7"}, {"title": "\u4e2d\u7f8e\u539f\u6cb9\u9700\u6c42\u524d\u666f\u770b\u4fcf \u7d10\u6cb9\u50f9\u683c\u5347\u903e2%", "description": "<p>\u4e2d\u570b\u7d93\u6fdf\u6578\u64da\u8f03\u9810\u671f\u4f73\uff0c\u52a0\u4e0a\u5e02\u5834\u5c0d\u5317\u534a\u7403\u590f\u5b63\u7528\u6cb9\u9700\u6c42\u524d\u666f\u8f49\u8da8\u6a02\u89c0\uff0c\u727d\u52d5\u570b\u969b\u6cb9\u50f9\u5468\u4e00\u9020\u597d\uff0c\u9023\u7e8c\u7b2c\u4e09\u5929\u5275\u4e0b\u5169\u500b\u6708\u65b0\u9ad8\u3002</p>\n<p>\u7d10\u7d04\u671f\u6cb9\u6536\u5e02\u53471.84\u7f8e\u5143\u62162.26%\uff0c\u6bcf\u6876\u583183.38\u7f8e\u5143\uff0c\u5275\u4e0b4\u670826\u65e5\u4ee5\u4f86\u65b0\u9ad8\u3002\u502b\u6566\u5e03\u862d\u7279\u671f\u6cb9\u6536\u5e02\u53471.6\u7f8e\u5143\u62161.88%\uff0c\u6bcf\u6876\u583186.6\u7f8e\u5143\uff0c\u5275\u4e0b4\u670830\u65e5\u4ee5\u4f86\u65b0\u9ad8\u3002</p>\n<p>\u8f03\u65e9\u6642\uff0c\u4e2d\u570b\u516c\u5e03\u76846\u6708\u8ca1\u65b0\u88fd\u9020\u696d\u63a1\u8cfc\u7d93\u7406\u6307\u6578(PMI)\u583151.8\uff0c\u512a\u65bc\u9810\u671f\u768451.5\u3002\u6578\u64da\u8b93\u5e02\u5834\u5c0d\u4e2d\u570b\u7d93\u6fdf\u6709\u8f03\u5f37\u4fe1\u5fc3\uff0c\u539f\u6cb9\u9700\u6c42\u524d\u666f\u8f49\u8da8\u6a02\u89c0\uff0c\u727d\u52d5\u570b\u969b\u6cb9\u50f9\u9020\u597d\u3002</p>\n<p>\u53e6\u5916\uff0c\u5e02\u5834\u61a7\u61ac\u7f8e\u570b\u7528\u6cb9\u9ad8\u5cf0\u671f\u8868\u73fe\u4f73\uff0c\u67f4\u6cb9\u671f\u8ca8\u50f9\u683c\u4e0a\u5347\u81f3\u5341\u5468\u65b0\u9ad8\uff0c\u6c7d\u6cb9\u671f\u8ca8\u50f9\u683c\u4e5f\u6f32\u81f3\u516b\u5468\u9ad8\u4f4d\uff0c\u5c0d\u539f\u6cb9\u50f9\u683c\u4e5f\u6709\u5229\u3002</p>\n<p>\u540c\u6642\uff0c\u591a\u9805\u56e0\u7d20\u4e5f\u5c0d\u6cb9\u50f9\u6709\u5229\u3002\u7f8e\u570b\u5927\u897f\u6d0b\u5340\u6709\u56db\u7d1a\u98b6\u98a8Beryl\u5439\u8972\uff0c\u5e02\u5834\u95dc\u6ce8\u98b6\u98a8\u53ef\u80fd\u5f71\u97ff\u58a8\u897f\u54e5\u7063\u5340\u77f3\u6cb9\u751f\u7522\u53ca\u7149\u6cb9\u5ee0\u3002\u4ee5\u8272\u5217\u7e3d\u7406\u5167\u5854\u5c3c\u4e9e\u80e1\u7a31\u7e7c\u7e8c\u5c0d\u5df4\u52d2\u65af\u5766\u6b66\u88dd\u7d44\u7e54\u54c8\u99ac\u65af\u767c\u52d5\u653b\u64ca\uff0c\u8207\u9ece\u5df4\u5ae9\u771f\u4e3b\u9ee8\u4e5f\u5728\u76f8\u4e92\u653b\u6253\uff0c\u5730\u7de3\u5c40\u52e2\u8da8\u7dca\u5f35\u3002\u6cd5\u570b\u570b\u6c11\u8b70\u6703\u9996\u56de\u5408\u9078\u8209\uff0c\u6975\u53f3\u6d3e\u7372\u52dd\uff0c\u6b50\u6d32\u5c40\u52e2\u6216\u6709\u65b0\u8b8a\u5316\u3002\u7f8e\u5143\u6ed9\u50f9\u504f\u8edf\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3809491/%E4%B8%AD%E7%BE%8E%E5%8E%9F%E6%B2%B9%E9%9C%80%E6%B1%82%E5%89%8D%E6%99%AF%E7%9C%8B%E4%BF%8F+%E7%B4%90%E6%B2%B9%E5%83%B9%E6%A0%BC%E5%8D%87%E9%80%BE2%25"}, {"title": "\u6eab\u65bd:\u901a\u8139\u9808\u56de\u843d \u624d\u652f\u6301\u6b50\u592e\u884c\u4eca\u5e74\u518d\u6e1b\u606f\u5169\u6b21", "description": "<p>\u6b50\u6d32\u592e\u884c\u7ba1\u7406\u59d4\u54e1\u6703\u6210\u54e1\u517c\u6bd4\u5229\u6642\u592e\u884c\u884c\u9577\u6eab\u65bd(Pierre Wunsch)\u8a8d\u70ba\uff0c\u9808\u5b8c\u5168\u4fe1\u670d\u6b50\u7f85\u5340\u901a\u8139\u6703\u56de\u843d\u81f32%\u76ee\u6a19\uff0c\u624d\u6703\u652f\u6301\u6b50\u592e\u884c\u4eca\u5e74\u9032\u4e00\u6b65\u6e1b\u606f\u8d85\u904e\u5169\u6b21\u7684\u6c7a\u7b56\u3002</p>\n<p>\u6b50\u592e\u884c\u4e0a\u6708\u6e1b\u606f0.25\u5398\uff0c\u5e02\u5834\u9810\u671f\u4eca\u5e74\u9084\u6703\u518d\u6e1b\u606f\u5169\u6b21\uff0c\u5404\u6e1b0.25\u5398\u3002\u6eab\u65bd\u8207\u5176\u4ed6\u6b50\u592e\u884c\u7ba1\u7406\u59d4\u54e1\u6703\u6210\u54e1\u6b63\u5728\u8461\u8404\u7259\uff0c\u51fa\u5e2d\u6b50\u592e\u884c\u975c\u4fee\u6703(annual retreat)\u3002</p>\n<p>\u6eab\u65bd\u63a5\u53d7\u5916\u96fb\u8a2a\u554f\u6642\u7a31\uff0c\u6b50\u592e\u884c\u76ee\u524d\u5229\u7387\u6c34\u5e73\u660e\u986f\u5c0d\u7d93\u6fdf\u6709\u8db3\u5920\u7684\u58d3\u6291\u4f5c\u7528\uff0c\u56e0\u6b64\u53ea\u8981\u901a\u8139\u8655\u65bc2%\u81f32.5%\u6c34\u5e73\uff0c\u6b50\u592e\u884c\u4eca\u5e74\u6e1b\u606f\u5169\u6b21\u662f\u8f03\u5408\u7406\u7684\u9810\u671f\u3002\u4e0d\u904e\uff0c\u5018\u82e5\u901a\u8139\u4e00\u76f4\u8655\u65bc2.5%\u9644\u8fd1\uff0c\u8981\u652f\u6301\u6e1b\u606f\u591a\u65bc\u5169\u6b21\u4fbf\u6709\u76f8\u7576\u56f0\u96e3\u3002\u4ed6\u9700\u8981\u660e\u78ba\u8a8d\u5b9a\u901a\u8139\u6703\u75312.5%\u964d\u81f32%\uff0c\u624d\u6703\u652f\u6301\u4eca\u5e74\u6e1b\u606f\u591a\u65bc\u5169\u6b21\u7684\u6c7a\u5b9a\u3002</p>\n<p>\u6eab\u65bd\u56e0\u6b64\u91cd\u8996\u6bcf\u6b21\u8b70\u606f\u524d\u516c\u5e03\u7684\u6700\u65b0\u7d93\u6fdf\u6578\u64da\uff0c\u4ee5\u53ca\u6b50\u592e\u884c\u6bcf\u5b63\u767c\u5e03\u7684\u66f4\u65b0\u9810\u6e2c\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3809489/%E6%BA%AB%E6%96%BD%3A%E9%80%9A%E8%84%B9%E9%A0%88%E5%9B%9E%E8%90%BD+%E6%89%8D%E6%94%AF%E6%8C%81%E6%AD%90%E5%A4%AE%E8%A1%8C%E4%BB%8A%E5%B9%B4%E5%86%8D%E6%B8%9B%E6%81%AF%E5%85%A9%E6%AC%A1"}]}