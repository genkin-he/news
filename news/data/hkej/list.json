\u6708\u4efd\u589e\u52a0\u7d04 900\u5143\uff0c\u4eca\u5e74\u8fc4\u4eca\u589e\u52a0\u7d0432700\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3945634/%E7%A9%8D%E9%87%91%E8%A9%95%E7%B4%9A%3AMPF%E9%A6%9611%E6%9C%88%E4%BA%BA%E5%9D%87%E8%B3%BA2.38%E8%90%AC"}, {"title": "\u570b\u5bb6\u61b2\u6cd5\u65e5 \u6797\u5b9a\u570b:\u61b2\u6cd5\u610f\u8b58\u61c9\u5f9e\u5c0f\u57f9\u990a", "description": "<p>\u4eca\u65e5\u662f\u300c\u570b\u5bb6\u61b2\u6cd5\u65e5\u300d\uff0c\u4fdd\u5b89\u5c40\u5e36\u9818\u8f44\u4e0b\u7d00\u5f8b\u90e8\u968a\u5728\u6d77\u95dc\u5b78\u9662\u8209\u884c\u570b\u5bb6\u61b2\u6cd5\u65e5\u5347\u65d7\u5100\u5f0f\uff0c\u7531\u5f8b\u653f\u53f8\u53f8\u9577\u6797\u5b9a\u570b\u4e3b\u79ae\u3002</p>\n<p>\u6797\u5b9a\u570b\u81f4\u8a5e\u6642\u8868\u793a\uff0c\u300c\u570b\u5bb6\u61b2\u6cd5\u65e5\u300d\u6d3b\u52d5\u7684\u8209\u8fa6\uff0c\u6b63\u6b63\u662f\u5c0d\u300a\u61b2\u6cd5\u300b\u7684\u5ba3\u63da\u53ca\u63a8\u5ee3\uff0c\u4ea6\u662f\u5411\u5927\u773e\u63a8\u5ee3\u6cd5\u6cbb\u610f\u8b58\u5ee3\u6cdb\u6559\u80b2\u7684\u597d\u6a5f\u6703\uff0c\u300a\u61b2\u6cd5\u300b\u610f\u8b58\u61c9\u8a72\u5f9e\u5c0f\u57f9\u990a\uff0c\u56e0\u6b64\u52a0\u6df1\u52a0\u5f37\u5c0d\u9752\u5c11\u5e74\u7684\u300a\u61b2\u6cd5\u300b\u6559\u80b2\u662f\u4e00\u9805\u91cd\u5927\u4f7f\u547d\u3002</p>\n<p>\u6797\u5b9a\u570b\u6307\u51fa\uff0c\u300c\u570b\u5bb6\u61b2\u6cd5\u65e5\u300d\u5df2\u8e0f\u5165\u7b2c\u4e8c\u500b\u5341\u5e74\u3002\u9999\u6e2f\u7684\u61b2\u5236\u79e9\u5e8f\u662f\u4ee5\u300a\u61b2\u6cd5\u300b\u548c\u300a\u57fa\u672c\u6cd5\u300b\u70ba\u57fa\u790e\uff0c\u662f\u9999\u6e2f\u7684\u300c\u6839\u300d\u548c\u300c\u6e90\u300d\u3002\u300a\u61b2\u6cd5\u300b\u70ba\u300c\u4e00\u570b\u5169\u5236\u300d\u63d0\u4f9b\u4e86\u6cd5\u5f8b\u4e0a\u6700\u6839\u672c\u53ca\u5805\u5be6\u7684\u4fdd\u969c\uff0c\u9999\u6e2f\u8981\u5145\u5206\u5229\u7528\u300c\u4e00\u570b\u5169\u5236\u300d\u4e0b\u4eab\u6709\u7684\u6240\u6709\u7368\u7279\u512a\u52e2\uff0c\u7dad\u8b77\u570b\u5bb6\u4e3b\u6b0a\u3001\u5b89\u5168\u548c\u767c\u5c55\u5229\u76ca\uff0c\u4fdd\u6301\u9999\u6e2f\u9577\u671f\u7e41\u69ae\u7a69\u5b9a\u3002</p>\n<p>\u4ed6\u53c8\u7a31\uff0c\u5927\u5bb6\u90fd\u662f\u300a\u61b2\u6cd5\u300b\u7684\u53d7\u76ca\u8005\uff0c\u66f4\u52a0\u61c9\u8a72\u8b39\u8a18\uff0c\u4eab\u53d7\u9019\u4e00\u4efd\u5229\u76ca\u540c\u6642\uff0c\u5fc5\u9808\u8981\u627f\u64d4\u76f8\u95dc\u8cac\u4efb\uff0c\u5c31\u662f\u7576\u597d\u300a\u61b2\u6cd5\u300b\u7684\u5b88\u8b77\u8005\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3945631/%E5%9C%8B%E5%AE%B6%E6%86%B2%E6%B3%95%E6%97%A5+%E6%9E%97%E5%AE%9A%E5%9C%8B%3A%E6%86%B2%E6%B3%95%E6%84%8F%E8%AD%98%E6%87%89%E5%BE%9E%E5%B0%8F%E5%9F%B9%E9%A4%8A"}, {"title": "\u860b\u679c\u50b3\u5370\u5c3c\u6295\u8cc7\u5927\u5e45\u589e\u52a0\u81f378\u5104", "description": "<p>\u860b\u679c\u516c\u53f8(Apple)\u64da\u5831\u5927\u5e45\u589e\u52a0\u5728\u5370\u5c3c\u6295\u8cc7\u7684\u627f\u8afe\uff0c\u50b3\u75311\u5104\u7f8e\u5143\uff0c\u589e\u52a0\u81f310\u5104\u7f8e\u5143(\u7d0478\u5104\u6e2f\u5143)\uff0c\u9810\u8a08\u4e00\u5468\u5167\u5c07\u6536\u5230\u860b\u679c\u66f8\u9762\u627f\u8afe\u3002\u6700\u7d42\u5e0c\u671b\u53ef\u89e3\u9664iPhone 16\u7576\u5730\u92b7\u552e\u7981\u4ee4\u3002</p>\n<p>\u5370\u5c3c\u65bc10\u6708\u963b\u6b62\u860b\u679c\u5728\u7576\u5730\u92b7\u552eiPhone 16\uff0c\u56e0\u5176\u672a\u80fd\u9054\u5230\u667a\u80fd\u96fb\u8a71\u548c\u5e73\u677f\u96fb\u8166\u9808\u670940%\u5728\u7576\u5730\u751f\u7522\u7684\u8981\u6c42\u3002\u860b\u679c\u6700\u521d\u7684\u6295\u8cc7\u627f\u8afe\u70ba1000\u842c\u7f8e\u5143\uff0c\u4e0a\u6708\u64da\u5831\u52a0\u78bc\u81f31\u5104\u7f8e\u5143\uff0c\u6642\u9694\u7d04\u534a\u500b\u6708\uff0c\u518d\u50b3\u51fa\u5927\u5e45\u589e\u52a0\u6295\u8cc7\u627f\u8afe\u81f310\u5104\u7f8e\u5143\u3002</p>\n<p>\u50b3\u5a92\u5f15\u8ff0\u5370\u5c3c\u6295\u8cc7\u90e8\u9577Rosan Roeslani\u8868\u793a\uff0c\u653f\u5e9c\u548c\u860b\u679c\u5df2\u78ba\u5b9a\u9019\u500b\u6578\u5b