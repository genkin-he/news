ad\u62c9\u6703\u9762\uff0c\u5c31\u5171\u540c\u95dc\u6ce8\u7684\u8b70\u984c\u4ea4\u63db\u610f\u898b\u3002</p>\n<p>\u674e\u5bb6\u8d85\u8868\u793a\uff0c\u4e2d\u570b\u9999\u6e2f\u662f\u4e16\u8cbf\u7684\u5275\u59cb\u6210\u54e1\uff0c\u5805\u5b9a\u652f\u6301\u4ee5\u4e16\u8cbf\u70ba\u6838\u5fc3\u3001\u4ee5\u898f\u5247\u70ba\u672c\u7684\u591a\u908a\u8cbf\u6613\u5236\u5ea6\u3002\u4e16\u8cbf\u6210\u54e1\u5728\u53bb\u5e7412\u6708\u7684\u8cbf\u6613\u653f\u7b56\u6aa2\u8a0e\u6703\u8b70\u4e0a\u80af\u5b9a\u4e2d\u570b\u9999\u6e2f\u5728\u63a8\u52d5\u570b\u969b\u8cbf\u6613\u81ea\u7531\u5316\u3001\u63d0\u5347\u4fbf\u5229\u71df\u5546\u63aa\u65bd\uff0c\u4ee5\u53ca\u978f\u56fa\u4e2d\u570b\u9999\u6e2f\u4f5c\u70ba\u570b\u969b\u6295\u8cc7\u53ca\u8cbf\u6613\u6a1e\u7d10\u6240\u4f5c\u51fa\u7684\u52aa\u529b\uff0c\u4ed6\u70ba\u6b64\u611f\u5230\u9f13\u821e\u3002</p>\n<p>\u4ed6\u7e8c\u7a31\uff0c\u9999\u6e2f\u4e00\u76f4\u7a4d\u6975\u722d\u53d6\u76e1\u65e9\u52a0\u5165\u300a\u5340\u57df\u5168\u9762\u7d93\u6fdf\u4f19\u4f34\u95dc\u4fc2\u5354\u5b9a\u300b\uff0c\u4e0a\u500b\u6708\u4ea6\u8207\u79d8\u9b6f\u7c3d\u8a02\u81ea\u7531\u8cbf\u6613\u5354\u5b9a\uff0c\u90fd\u6709\u52a9\u978f\u56fa\u9999\u6e2f\u4f5c\u70ba\u570b\u969b\u57ce\u5e02\u7684\u7368\u7279\u512a\u52e2\uff0c\u540c\u6642\u66f4\u597d\u767c\u63ee\u9999\u6e2f\u5728\u570b\u969b\u8cbf\u6613\u4e2d\u63d0\u4f9b\u9ad8\u589e\u503c\u4f9b\u61c9\u93c8\u7ba1\u7406\u670d\u52d9\u7684\u91cd\u8981\u89d2\u8272\u3002\u4ed6\u8aaa\uff0c\u591a\u908a\u8cbf\u6613\u5236\u5ea6\u662f\u9999\u6e2f\u8cbf\u6613\u653f\u7b56\u7684\u57fa\u77f3\uff0c\u7279\u5340\u653f\u5e9c\u6703\u7e7c\u7e8c\u4ee5\u7c3d\u8a02\u81ea\u7531\u8cbf\u6613\u5354\u5b9a\u7b49\u65b9\u5f0f\uff0c\u64f4\u5c55\u9999\u6e2f\u7684\u5168\u7403\u7d93\u8cbf\u7db2\u7d61\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3948061/%E6%9D%8E%E5%AE%B6%E8%B6%85%E6%99%A4%E4%B8%96%E8%B2%BF%E7%B5%84%E7%B9%94%E7%B8%BD%E5%B9%B9%E4%BA%8B%E4%BC%8A%E7%B6%AD%E6%8B%89"}, {"title": "\u5fb7\u52e4\u4e2d\u570b:\u9ece\u5609\u6069\u7b493\u4eba\u9055\u5408\u540c\u53ca\u53d7\u4fe1\u7fa9\u52d9 \u5df2\u96e2\u4efb", "description": "<p><span style=\"font-size-ignore:13pt;\">\u5fb7\u52e4\u4e2d\u570b\u78ba\u8a8d\uff0c\u9999\u6e2f\u91cd\u7d44\u696d\u52d9\u90e8\u9580\u5f9e\u696d\u4eba\u54e1\u9ece\u5609\u6069\u3001\u7518\u4ef2\u6052\u548c\u9673\u667a\u8070\u7531\u65bc\u9055\u53cd\u5408\u540c\u53ca\u53d7\u4fe1\u7fa9\u52d9\uff0c\u4ee5\u53ca\u5c0d\u516c\u53f8\u7684\u5fe0\u8aa0\u7fa9\u52d9\uff0c\u73fe\u5df2\u96e2\u958b\u516c\u53f8\u3002\u76f8\u95dc\u9055\u898f\u884c\u70ba\u662f\u5728\u516c\u53f8\u5e38\u898f\u6aa2\u8996\u5408\u5925\u4eba\u548c\u54e1\u5de5\u7684\u96e2\u8077\u6d41\u7a0b\u4e2d\u767c\u73fe\u7684\u3002</span></p>\n<p>\u57fa\u65bc\u985e\u4f3c\u539f\u56e0\uff0c\u4e2d\u570b\u5927\u9678\u91cd\u7d44\u696d\u52d9\u90e8\u9580\u7684\u9112\u6587\u6649\u5df2\u88ab\u5f37\u5236\u4f11\u5047\u3002\u516c\u53f8\u5df2\u6c7a\u5b9a\u5c0d\u4e0a\u8ff04\u4eba\u63a1\u53d6\u6cd5\u5f8b\u884c\u52d5\u3002</p>\n<p>\u5fb7\u52e4\u7406\u89e3\u4e26\u5c0a\u91cd\u5408\u5925\u4eba\u5728\u8077\u696d\u751f\u6daf\u4e2d\u53ef\u80fd\u9078\u64c7\u96e2\u958b\u516c\u53f8\u4e26\u53e6\u8b00\u8077\u696d\u767c\u5c55\u7684\u884c\u70ba\u3002\u7136\u800c\uff0c\u516c\u53f8\u5c0d\u8a724\u4eba\u63a1\u53d6\u884c\u52d5\uff0c\u662f\u70ba\u5805\u5b88\u516c\u53f8\u7684\u8077\u8cac\uff0c\u5373\u59cb\u7d42\u7dad\u8b77\u5176\u6838\u5fc3\u50f9\u503c\u89c0\uff0c\u4e26\u78ba\u4fdd\u96e2\u8077\u5408\u5925\u4eba\u5c0a\u91cd\u5c0d\u516c\u53f8\u8ca0\u6709\u7684\u5408\u540c\u53ca\u53d7\u4fe1\u7fa9\u52d9\uff0c\u4ee5\u53ca\u5fe0\u8aa0\u3001\u8aa0\u4fe1\u548c\u554f\u8cac\u7684\u8cac\u4efb\u3002</p>\n<p>\u5fb7\u52e4\u8868\u793a\uff0c\u6b63\u5728\u5b89\u6392\u5176\u4ed6\u5fb7\u52e4\u5408\u5925\u4eba\u8207\u76f8\u95dc\u6301\u4efd\u8005\u5354\u8abf\u4e26\u63a5\u7ba1\u73fe\u6709\u9805\u76ee\uff0c\u4ee5\u7dad\u8b77\u516c\u773e\u5229\u76ca\u4e26\u78ba\u4fdd\u516c\u773e\u4efb\u547d\u7684\u9805\u76ee\u5f97\u4ee5\u9ad8\u6548\u9032\u884c\u3002\u6b64\u5916\uff0c\u516c\u53f8\u4fdd\u7559\u4e86\u4e00\u652f\u5f37\u5927\u4e14\u6709\u80fd\u529b\u7684\u91cd\u7d44\u696d\u52d9\u5718\u968a\uff0c\u53ef\u4ee5\u78ba\u8a8d\u6b64\u4e8b\u4e0d\u6703\u5f71\u97ff\u5176\u5c65\u884c\u5c0d\u5ba2\u6236\u627f\u8afe\u548c\u7e7c\u7e8c\u63d0\u4f9b\u9ad8\u54c1\u8cea\u670d\u52d9\u7684\u80fd\u529b\u3002</p>\n<p>\u8a72\u884c\u6307\u51fa\uff0c\u7531\u65bc\u9019\u5df2\u5c6c\u65bc\u6cd5\u5f8b\u4e8b\u9805\uff0c\u56e0\u6b64\u4e0d\u5b9c\u767c\u8868\u66f4\u591a\u8a55\u8ad6\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3948062/%E5%BE%B7%E5%8B%A4%E4%B8%AD%E5%9C%8B%3A%E9%BB%8E%E5%98%89%E6%81%A9%E7%AD%893%E4%BA%BA%E9%81%95%E5%90%88%E5%90%8C%E5%8F%8A%E5%8F%97%E4%BF%A1%E7%BE%A9%E5%8B%99+%E5%B7%B2%E9%9B%A2%E4%BB%BB"}, {"title": "\u570b\u52d9\u9662:\u9010\u6b65\u7a69\u59a5\u61c9\u7528\u8f14\u52a9\u99d5\u99db\u53ca\u81ea\u52d5\u99d5\u99db", "description": "<p>\u570b\u52d9\u9662\u767c\u5e03\u300a\u95dc\u65bc\u63a8\u9032\u65b0\u578b\u57ce\u5e02\u57fa\u790e\u8a2d\u65bd\u5efa\u8a2d\u6253\u9020\u97cc\u6027\u57ce\u5e02\u7684\u610f\u898b\u300b\u7a31\uff0c\u6df1\u5165\u63a8\u9032\u300c\u7b2c\u4e94\u4ee3\u79fb\u52d5\u901a\u8a0a(5G)+\u8eca\u806f\u7db2\u300d\u767c\u5c55\uff0c\u9010\u6b65\u7a69\u59a5\u63a8\u5ee3\u61c9\u7528\u8f14\u52a9\u99d5\u99db\u3001\u81ea\u52d5\u99d5\u99db\uff1b\u901a\u904e\u5730\u65b9\u653f\u5e9c\u5c08\u9805\u50b5\u5238\u652f\u6301\u7b26\u5408\u689d\u4ef6\u7684\u65b0\u578b\u57ce\u5e02\u57fa\u790e\u8a2d\u65bd\u5efa\u8a2d\u9805\u76ee\u3002</p>\n<p>\u610f\u898b\u7a31\uff0c\u52302027\u5e74\uff0c\u65b0\u578b\u57ce\u5e02\u57fa\u790e\u8a2d\u65bd\u5efa\u8a2d\u53d6\u5f97\u660e\u986f\u9032\u5c55\uff0c\u5c0d\u97cc\u6027\u57ce\u5e02\u5efa\u8a2d\u7684\u652f\u6490\u4f5c\u7528\u4e0d\u65b7\u589e\u5f37\uff1b\u52302030\u5e74\uff0c\u65b0\u578b\u57ce\u5e02\u57fa\u790e\u8a2d\u65bd\u5efa\u8a2d\u53d6\u5f97\u986f\u8457\u6210\u6548\uff0c\u63a8\u52d5\u5efa\u6210\u4e00\u6279\u9ad8\u6c34\u5e73\u97cc\u6027\u57ce\u5e02\uff0c\u57ce\u5e02\u5b89\u5168\u97cc\u6027\u6301\u7e8c\u63d0\u5347\u3002</p>\n<p>\u610f\u898b\u63d0\u5230\uff0c\u8981\u63a2\u7d22\u5efa\u7acb\u65b0\u578b\u57ce\u5e02\u57fa\u790e\u8a2d\u65bd\u5efa\u8a2d\u7684\u904b\u4f5c\u6a5f\u5236\u548c\u5546\u696d\u6a21\u5f0f\u3002\u9f13\u52f5\u91d1\u878d\u6a5f\u69cb\u4ee5\u5e02\u5834\u5316\u65b9\u5f0f\u589e\u52a0\u4e2d\u9577\u671f\u4fe1\u8cb8\u6295\u653e\uff0c\u652f\u6301\u7b26\u5408\u689d\u4ef6\u7684\u9805\u76ee\u767c\u884c\u57fa\u790e\u8a2d\u65bd\u9818\u57df\u4e0d\u52d5\u7522\u6295\u8cc7\u4fe1\u8a17\u57fa\u91d1(REITs)\u3002</p>\n<p>\u6b64\u5916\uff0c\u8981\u52a0\u5f37\u57ce\u5e02\u7269\u6d41\u914d\u9001\u8a2d\u65bd\u7684\u898f\u5283\u3001\u5efa\u8a2d\u3001\u6539\u9020\uff0c\u5efa\u8a2d\u96c6\u7d04\u3001\u9ad8\u6548\u3001\u667a\u6167\u7684\u7da0\u8272\u914d\u9001\u9ad4\u7cfb\uff1b\u52a0\u5feb\u91cd\u9ede\u516c\u5171\u5340\u57df\u548c\u9053\u8def\u8996\u983b\u76e3\u63a7\u7b49\u5b89\u9632\u8a2d\u5099\u667a\u80fd\u5316\u6539\u9020\u7b49\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3948047/%E5%9C%8B%E5%8B%99%E9%99%A2%3A%E9%80%90%E6%AD%A5%E7%A9%A9%E5%A6%A5%E6%87%89%E7%94%A8%E8%BC%94%E5%8A%A9%E9%A7%95%E9%A7%9B%E5%8F%8A%E8%87%AA%E5%8B%95%E9%A7%95%E9%A7%9B"}, {"title": "HashKey\u9996\u5e2d\u904b\u71df\u5b98\u7fc1\u66c9\u5947\u4eca\u5e74\u5e95\u96e2\u4efb", "description": "<p><span style=\"font-size-ignore:13pt;\">HashKey Group\u516c\u5e03\uff0c\u8a72\u516c\u53f8\u9996\u5e2d\u904b\u71df\u5b98\u517cHashKey Exchange\u9996\u5e2d\u57f7\u884c\u5b98\u7fc1\u66c9\u5947\u56e0\u500b\u4eba\u5bb6\u5ead\u539f\u56e0\uff0c\u65bc\u6578\u6708\u524d\u6b63\u5f0f\u5411\u516c\u53f8\u63d0\u51fa\u4e86\u96e2\u8077\u7533\u8acb\u3002\u7d93\u904e\u8207\u7fc1\u66c9\u5947\u7684\u5145\u5206\u6e9d\u901a\uff0c\u516c\u53f8\u5df2\u7d93\u5171\u540c\u5236\u5b9a\u4e86\u5b8c\u5099\u7684\u904e\u6e21\u65b9\u6848\u548c\u4eba\u54e1\u5b89\u6392\u8a08\u5283\u3002\u7fc1\u66c9\u5947\u5c07\u7e7c\u7e8c\u5c65\u8077\u81f3\u4eca\u5e74\u5e95\uff0c\u5354\u52a9\u5b8c\u6210\u6240\u6709\u4ea4\u63a5\u5de5\u4f5c\u3002</span></p>\n<p>\u5728\u7fc1\u66c9\u5947\u7684\u5e36\u9818\u548c\u5718\u968a\u7684\u5171\u540c\u52aa\u529b\u4e0b\uff0cHashKey Exchange\u5df2\u6210\u9577\u70ba\u9999\u6e2f\u6700\u5927\u7684\u6301\u724c\u865b\u64ec\u8cc7\u7522\u4ea4\u6613\u6240\uff0c\u8877\u5fc3\u611f\u8b1d\u4ed6\u5728\u4efb\u8077\u671f\u9593\u70baHashKey Group\u53caHashKey Exchange\u6240\u4f5c\u51fa\u7684\u5353\u8d8a\u8ca2\u737b\u3002</p>\n<p>\u7fc1\u66c9\u5947\u8868\u793a\uff0c\u5728\u904e\u53bb\u7684\u4e00\u5e74\u4e2d\uff0c\u6709\u5e78\u898b\u8b49\u4e26\u53c3\u8207\u4e86HashKey Group\u548cHashKey Exchange\u7684\u767c\u5c55\u8207\u58ef\u5927\u3002\u7531\u65bc\u500b\u4eba\u5bb6\u5ead\u539f\u56e0\uff0c\u4ed6\u5c07\u66ab\u5225HashKey\uff0c\u611f\u8b1d\u516c\u53f8\u3001\u5718\u968a\u4ee5\u53ca\u884c\u696d\u5925\u4f34\u4e00\u76f4\u4ee5\u4f86\u7684\u652f\u6301\u8207\u4fe1\u4efb\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3948029/HashKey%E9%A6%96%E5%B8%AD%E9%81%8B%E7%87%9F%E5%AE%98%E7%BF%81%E6%9B%89%E5%A5%87%E4%BB%8A%E5%B9%B4%E5%BA%95%E9%9B%A2%E4%BB%BB"}]}