8df\u54c1\u5916\uff0c\u9084\u6709\u5bb6\u5c45\u7528\u54c1\u7b49\uff0c\u5176\u4e2d\u5982Knorr\u3001Magnum\u3001Dove\u3001Rexona\u53caCif\u7b4930\u500b\u4e3b\u529b\u54c1\u724c\u3002\u8fd1\u671f\u6b63\u7a4d\u6975\u7cbe\u7c21\u696d\u52d9\uff0c\u7279\u5225\u662f\u5728\u6b50\u6d32\uff0c\u65e9\u524d\u6709\u50b3\u8a08\u5283\u5206\u62c6\u96ea\u7cd5\u696d\u52d9\u65d7\u4e0b\u54c1\u724c\u5305\u62ecBen &amp; Jerry\u53caMagnum\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3943465/%E8%81%AF%E5%90%88%E5%88%A9%E8%8F%AF%E6%93%AC%E5%87%BA%E5%94%AE%E9%83%A8%E5%88%86%E9%A3%9F%E5%93%81%E5%93%81%E7%89%8C"}, {"title": "\u9673\u6d69\u6fc2:\u6b61\u8fce\u5409\u723e\u5409\u65af\u8003\u616e\u9999\u6e2f\u767c\u884c\u4e3b\u6b0a\u50b5\u5238", "description": "<p>\u8ca1\u7d93\u4e8b\u52d9\u53ca\u5eab\u52d9\u5c40\u526f\u5c40\u9577\u9673\u6d69\u6fc2\u8868\u793a\uff0c\u4eca\u5929\u51fa\u5e2d\u5409\u723e\u5409\u65af\u8ca1\u653f\u90e8\u8207\u91d1\u878d\u6a5f\u69cb\u5728\u9999\u6e2f\u806f\u5408\u8209\u8fa6\u7684\u63a8\u5ee3\u7814\u8a0e\u6703\u53ca\u975e\u4ea4\u6613\u8def\u6f14\uff0c\u8207\u5409\u723e\u5409\u65af\u526f\u8ca1\u9577Mr Umutzhan Mominovich Amanbaev\u4ea4\u6d41\uff0c\u4e26\u6b61\u8fce\u5409\u723e\u5409\u65af\u7a4d\u6975\u8003\u616e\u65bc\u9996\u6b21\u5728\u9999\u6e2f\u767c\u884c\u4e3b\u6b0a\u50b5\u5238\u3002</p>\n<p>\u9673\u6d69\u6fc2\u7a31\uff0c\u904e\u53bb\u5341\u5e74\u9593(2013\u5e74\u81f32023\u5e74)\uff0c\u9999\u6e2f\u8207\u300c\u4e00\u5e36\u4e00\u8def\u300d\u7d93\u6fdf\u9ad4\u7684\u5c0d\u5916\u8cbf\u6613\u984d\u589e\u9577\u8fd1\u516d\u6210\uff0c\u5145\u5206\u986f\u793a\u51fa\u300c\u4e00\u5e36\u4e00\u8def\u300d\u5021\u8b70\u5c0d\u4fc3\u9032\u5340\u57df\u5408\u4f5c\u8207\u7d93\u6fdf\u589e\u9577\u7684\u5de8\u5927\u6f5b\u529b\u3002\u5409\u723e\u5409\u65af\u4f5c\u70ba\u300c\u4e00\u5e36\u4e00\u8def\u300d\u5021\u8b70\u7684\u91cd\u8981\u5925\u4f34\uff0c\u540c\u6642\u4e5f\u662f\u9999\u6e2f\u5728\u4e2d\u4e9e\u5730\u5340\u7684\u91cd\u8981\u8cbf\u6613\u5925\u4f34\u3002\u5982\u9019\u6b21\u5728\u6e2f\u767c\u50b5\u8a08\u5283\u5f97\u4ee5\u5be6\u884c\uff0c\u8996\u4e4e\u5e02\u5834\u60c5\u6cc1\uff0c\u5c07\u50be\u5411\u65bc2025\u5e74\u4ee5\u4eba\u6c11\u5e63\u53ca\u7f8e\u5143\u767c\u884c\uff0c\u4e0d\u50c5\u5c07\u70ba\u5169\u5730\u5408\u4f5c\u5beb\u4e0b\u4e86\u65b0\u7bc7\u7ae0\uff0c\u4e5f\u70ba\u5176\u4ed6\u300c\u4e00\u5e36\u4e00\u8def\u300d\u570b\u5bb6\u63d0\u4f9b\u4e86\u5bf6\u8cb4\u7684\u53c3\u8003\u548c\u793a\u7bc4\u3002\u4ed6\u76f8\u4fe1\uff0c\u5409\u723e\u5409\u65af\u8207\u9999\u6e2f\u7684\u5408\u4f5c\u5c07\u70ba\u96d9\u65b9\u7d93\u6fdf\u5e36\u4f86\u8c50\u78a9\u6210\u679c\uff0c\u958b\u5275\u4e92\u5229\u5171\u8d0f\u7684\u65b0\u5c40\u9762\u3002</p>\n<p>\u9673\u6d69\u6fc2\u8868\u793a\uff0c\u8877\u5fc3\u671f\u671b\uff0c\u672a\u4f86\u6703\u6709\u66f4\u591a\u300c\u4e00\u5e36\u4e00\u8def\u300d\u6cbf\u7dda\u570b\u5bb6\u5145\u5206\u5229\u7528\u9999\u6e2f\u570b\u969b\u5316\u3001\u591a\u5143\u5316\u7684\u878d\u8cc7\u5e73\u53f0\u512a\u52e2\uff0c\u9078\u64c7\u5728\u6e2f\u767c\u884c\u5404\u985e\u50b5\u5238\uff0c\u4fc3\u9032\u570b\u969b\u8cc7\u91d1\u8207\u300c\u4e00\u5e36\u4e00\u8def\u300d\u9805\u76ee\u7684\u6709\u6548\u5c0d\u63a5\uff0c\u52a9\u529b\u76f8\u95dc\u9805\u76ee\u66f4\u5feb\u3001\u66f4\u597d\u5730\u843d\u5be6\u8207\u767c\u5c55\u3002\u540c\u6642\uff0c\u9019\u4e5f\u5c07\u9032\u4e00\u6b65\u978f\u56fa\u9999\u6e2f\u4f5c\u70ba\u5168\u7403\u91d1\u878d\u6a1e\u7d10\u7684\u5730\u4f4d\uff0c\u589e\u5f37\u9999\u6e2f\u7684\u6838\u5fc3\u7af6\u722d\u529b\uff0c\u70ba\u9999\u6e2f\u91d1\u878d\u5e02\u5834\u5e36\u4f86\u66f4\u591a\u5275\u65b0\u52d5\u529b\uff0c\u958b\u555f\u66f4\u5ee3\u95ca\u7684\u767c\u5c55\u7a7a\u9593\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3943522/%E9%99%B3%E6%B5%A9%E6%BF%82%3A%E6%AD%A1%E8%BF%8E%E5%90%89%E7%88%BE%E5%90%89%E6%96%AF%E8%80%83%E6%85%AE%E9%A6%99%E6%B8%AF%E7%99%BC%E8%A1%8C%E4%B8%BB%E6%AC%8A%E5%82%B5%E5%88%B8"}, {"title": "\u5730\u7522\u4ee3\u7406\u4eba\u6578\u9023\u8dcc7\u500b\u6708", "description": "<p><span style=\"font-size-ignore:13pt;\">\u64da\u5730\u7522\u4ee3\u7406\u76e3\u7ba1\u5c40\u6700\u65b0\u6578\u64da\uff0c\u622a\u81f311\u6708\u5e95\uff0c\u5168\u6e2f\u6301\u724c\u4ee3\u7406\u4eba\u657838517\u4eba\uff0c\u6309\u6708\u6e1b\u5c11103\u4eba\uff0c\u9023\u8dcc7\u500b\u6708\uff0c\u7d2f\u6e1b656\u4eba\u62161.67%\uff0c\u6309\u5e74\u5247\u6e1b\u5c111230\u4eba\u62163.09%\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u82e5\u5c0d\u6bd42022\u5e742\u6708\u9ad8\u5cf0\u671f\u9304\u5f97\u768442408\u4eba</span><span style=\"font-size-ignore:13pt;\">\uff0c\u81f3\u4eca\u5df2\u6d41\u5931\u591a\u90543891\u4eba</span><span style=\"font-size-ignore:13pt;\">\u62169.18%\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u671f\u5167\uff0c\u5206\u884c\u6578\u76ee\u9304\u5f976751\u9593\uff0c\u6309\u6708\u6e1b\u5c1118\u9593\u3002</span></p>\n<p>\u6301\u6709\u71df\u696d\u54e1\u724c\u7167(\u4fd7\u7a31S\u724c\u6216\u7d30\u724c)\u7684\u4ee3\u7406\u517120646\u4eba\uff0c\u6309\u6708\u6e1b\u5c1162\u4eba\uff1b\u5730\u7522\u4ee3\u7406(\u500b\u4eba)\u724c\u7167(\u4fd7\u7a31E\u724c\u6216\u5927\u724c)\u7684\u6301\u724c\u4eba\u6578\u517117871\u4eba\uff0c\u6309\u6708\u6e1b\u5c1141\u4eba\u3002<span style=\"font-size-ignore:13pt;\">\u00a0</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3943302/%E5%9C%B0%E7%94%A2%E4%BB%A3%E7%90%86%E4%BA%BA%E6%95%B8%E9%80%A3%E8%B7%8C7%E5%80%8B%E6%9C%88"}, {"title": "\u4f55\u6c38\u8ce2:\u4e0d\u5408\u6a19\u6e96\u528f\u623f\u5211\u4e8b\u8cac\u4efb\u91dd\u5c0d\u696d\u4e3b \u4f4f\u5ba2\u6bcb\u9808\u8ca0\u8cac", "description": "<p>\u623f\u5c4b\u5c40\u5c40\u9577\u4f55\u6c38\u8ce2\u5728\u7acb\u6cd5\u6703\u623f\u5c4b\u4e8b\u52d9\u59d4\u54e1\u6703\u5c31\u300c\u7c21\u6a38\u623f\u300d\u898f\u7ba1\u5236\u5ea6\u5efa\u8b70\u65b9\u6848\u767c\u8a00\u6642\u8868\u793a\uff0c\u5efa\u8b70\u7528\u4e00\u500b\u7acb\u6cd5\u7684\u65b9\u5f0f\u53bb\u5236\u5b9a\u4e00\u4e9b\u4f4f\u5b85\u6a13\u5b87\u5206\u9593\u55ae\u4f4d\u7684\u51fa\u79df\u5236\u5ea6\uff0c\u5c07\u4f86\u51fa\u79df\u7684\u5206\u9593\u55ae\u4f4d\u5fc5\u9808\u662f\u5408\u4e4e\u6a19\u6e96\u7684\u300c\u7c21\u6a38\u623f\u300d\u3002\u4e0d\u5408\u6a19\u6e96\u7684\u5206\u9593\u55ae\u4f4d(\u528f\u623f)\u9700\u8981\u6539\u5efa\u6210\u5408\u6a19\u6e96\u7684\u300c\u7c21\u6a38\u623f\u300d\uff0c\u7531\u5c08\u696d\u4eba\u58eb\u78ba\u8a8d\u4e26\u4e14\u7533\u8acb\u4e00\u500b\u8a8d\u8b49\u3002\u82e5\u975e\u5982\u6b64\uff0c\u696d\u4e3b\u7e7c\u7e8c\u5c07\u9019\u4e9b\u55ae\u4f4d\u51fa\u79df\uff0c\u4fbf\u8981\u8ca0\u4e0a\u5211\u4e8b\u7684\u8cac\u4efb\u3002\u5211\u4e8b\u8cac\u4efb\u4e3b\u8981\u662f\u91dd\u5c0d\u696d\u4e3b\u7684\uff0c\u4f4f\u5ba2\u662f\u4e0d\u9700\u8981\u8ca0\u6cd5\u5f8b\u8cac\u4efb\u3002</p>\n<p>\u5979\u6307\u51fa\uff0c\u7576\u5c40\u7531\u4eca\u65e5\u958b\u59cb\u5230\u660e\u5e74\u76842\u670810\u65e5\u6703\u9032\u884c\u4e00\u500b\u6301\u4efd\u8005\u8aee\u8a62\uff0c\u7a0d\u5f8c\u6703\u518d\u56de\u4f86\u7acb\u6cd5\u6703\u623f\u5c4b\u4e8b\u52d9\u59d4\u54e1\u6703\uff0c\u7e3d\u7d50\u6536\u5230\u7684\u610f\u898b\u548c\u4ea4\u4ee3\u6700\u7d42\u7684\u5efa\u8b70\u65b9\u6848\u3002\u8996\u4e4e\u8aee\u8a62\u7684\u7d50\u679c\uff0c\u5c40\u65b9\u6703\u76e1\u5feb\u5411\u7acb\u6cd5\u6703\u63d0\u4ea4\u689d\u4f8b\u8349\u6848\uff0c\u7a4d\u6975\u914d\u5408\u7acb\u6cd5\u6703\u7684\u5be9\u8b70\uff0c\u722d\u53d6\u5728\u660e\u5e74\u5167\u901a\u904e\u6cd5\u4f8b\u3002\u5b8c\u6210\u6cd5\u5f8b\u7a0b\u5e8f\u5f8c\uff0c\u9810\u8a08\u6700\u5feb\u53ef\u4ee5\u5728\u660e\u5e74\u7684\u7b2c\u56db\u5b63\u958b\u59cb\u70ba\u73fe\u5b58\u51fa\u79df\u7684\u5206\u9593\u55ae\u4f4d\u9032\u884c\u767b\u8a18\uff0c\u4e26\u4e14\u540c\u6b65\u63a5\u53d7\u300c\u7c21\u6a38\u623f\u300d\u7684\u8a8d\u8b49\u7533\u8acb\u3002</p>\n<p>\u4f55\u6c38\u8ce2\u900f\u9732\uff0c\u898f\u7ba1\u7684\u5c0d\u8c61\u662f\u4f4f\u5b85\u7528\u9014\u5927\u5ec8\u6216\u7d9c\u5408\u7528\u9014\u5927\u5ec8\u7684\u4f4f\u5b85\u90e8\u5206\u7684\u5206\u9593\u55ae\u4f4d\u3002\u81f3\u65bc\u5de5\u5ec8\u3001\u5546\u5ec8\u6216\u8005\u4e00\u4e9b\u975e\u6cd5\u69cb\u7bc9\u7269\u88cf\u9762\u7684\u300c\u528f\u623f\u300d\uff0c\u672c\u8eab\u662f\u9055\u6cd5\u7684\uff0c\u6709\u73fe\u884c\u7684\u6cd5\u898f\u6216\u8005\u653f\u5e9c\u76f8\u95dc\u7684\u79df\u5951\u53bb\u898f\u7ba1\u3002\u540c\u6a23\uff0c\u5e8a\u4f4d\u662f\u53d7\u300a\u5e8a\u4f4d\u5bd3\u6240\u689d\u4f8b\u300b\u898f\u7ba1\uff0c\u76f8\u95dc\u90e8\u9580\u6703\u7e7c\u7e8c\u6309\u73fe\u884c\u7684\u6cd5\u898f\u9032\u884c\u5de1\u67e5\u548c\u57f7\u7ba1\u3002</p>\n<p>\u767b\u8a18\u5236\u5ea6\u65b9\u9762\uff0c\u7576\u5c40\u5efa\u8b70\u767b\u8a18\u671f\u53ef\u4ee5\u8003\u616e12\u500b\u6708\uff0c\u6216\u8005\u523018\u500b\u6708\uff0c\u800c\u767b\u8a18\u4e86\u7684\u55ae\u4f4d\u53ef\u5728\u767b\u8a18\u671f\u5b8c\u7d50\u5f8c\u7372\u5f97\u4e00\u500b\u5bec\u9650\u671f\uff0c\u5efa\u8b70\u5bec\u9650\u671f\u662f12\u500b\u6708\uff0c\u6216\u8005\u662f\u53bb\u523024\u500b\u6708\uff0c\u5728\u8aee\u8a62\u671f\u9593\u6b61\u8fce\u5927\u5bb6\u7d66\u4e88\u610f\u898b\u3002\u7576\u5c40\u5efa\u8b70\u5bec\u9650\u671f\u4e0d\u8981\u592a\u77ed\uff0c\u56e0\u70ba\u8981\u6709\u5145\u8db3\u7684\u6642\u9593\u8b93\u5927\u5bb6\u53bb\u66f4\u6b63\u6216\u8acb\u5c08\u696d\u4eba\u58eb\u8a8d\u8b49\u7b49\u3002</p>\n<p>\u5979\u6307\u51fa\uff0c\u767b\u8a18\u671f\u53ca\u5bec\u9650\u671f\u7d50\u675f\u5f8c\uff0c\u7576\u5c40\u6703\u56e0\u61c9\u623f\u5c4b\u4f9b\u61c9\u548c\u5be6\u969b\u60c5\u6cc1\uff0c\u6309\u90e8\u5c31\u73ed\uff0c\u6709\u5e8f\u6c7a\u5b9a\u57f7\u6cd5\u7684\u6642\u6a5f\u3002\u53d7\u57f7\u6cd5\u884c\u52d5\u5f71\u97ff\u7684\u4f4f\u6236\uff0c\u6703\u63d0\u4f9b\u9069\u7576\u7684\u642c\u9077\u5354\u52a9\u3002\u5979\u5f37\u8abf\uff0c\u5373\u4f7f\u6709\u4e9b\u4f4f\u6236\u6b63\u8f2a\u5019\u516c\u5c4b\uff0c\u4f46\u4e0d\u6703\u56e0\u57f7\u6cd5\u884c\u52d5\u7372\u5f97\u63d0\u65e9\u7de8\u914d\u516c\u5c4b\u55ae\u4f4d\uff0c\u5426\u5247\u5c0d\u5176\u4ed6\u8f2a\u5019\u516c\u5c4b\u7684\u4eba\u58eb\u4e0d\u516c\u5e73\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3943401/%E4%BD%95%E6%B0%B8%E8%B3%A2%3A%E4%B8%8D%E5%90%88%E6%A8%99%E6%BA%96%E5%8A%8F%E6%88%BF%E5%88%91%E4%BA%8B%E8%B2%AC%E4%BB%BB%E9%87%9D%E5%B0%8D%E6%A5%AD%E4%B8%BB+%E4%BD%8F%E5%AE%A2%E6%AF%8B%E9%A0%88%E8%B2%A0%E8%B2%AC"}]}