d\u70ba5\u5104\u81f35.2\u5104\u7f8e\u5143\uff0c\u6bdb\u5229\u7387\u70ba10%\u81f312%\u3002\u516c\u53f8\u7e7c\u7e8c\u64f4\u514512\u5bf8\u6676\u5713\u7522\u80fd\uff0c\u4e26\u9810\u671f\u7b2c\u4e8c\u5ea7\u6676\u7247\u5ee0\u65bc\u660e\u5e74\u7b2c\u4e00\u5b63\u91cf\u7522\u3002</p>\n<p>\u82b1\u65d7\u8a8d\u70ba\uff0c\u96d6\u7136\u83ef\u8679\u9032\u53d6\u7684\u5b9a\u50f9\u548c\u570b\u5167\u9700\u6c42\u5c07\u80fd\u5920\u652f\u6301\u5176\u7522\u80fd\u5229\u7528\u7387\uff0c\u4f46\u8a72\u884c\u5c0d\u5176\u7372\u5229\u80fd\u529b\u548c\u6bdb\u5229\u7387\u524d\u666f\u6301\u8b39\u614e\u614b\u5ea6\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/stock/article/3844121/%E8%8A%B1%E6%97%97%3A%E5%8D%87%E8%8F%AF%E8%99%B9%E7%9B%AE%E6%A8%99%E5%83%B9%E8%87%B317%E5%85%83+%E7%B6%AD%E6%8C%81%E6%B2%BD%E5%94%AE%E8%A9%95%E7%B4%9A+"}, {"title": "\u5c71\u9802\u5357\u5340\u4e0a\u6708\u8c6a\u5b85\u8cb7\u8ce3\u50f9\u91cf\u9f4a\u5347", "description": "<p><span style=\"font-size-ignore:13pt;\">\u7f8e\u806f\u7269\u696d\u6578\u64da\u986f\u793a\uff0c7\u6708\u6e2f\u5cf6\u5c71\u9802\u5357\u5340\u8c6a\u5b85\u9304\u5f97\u7d0413\u5b97\u8cb7\u8ce3\uff0c\u6d89\u53ca\u91d1\u984d\u7d0431.57\u5104\u5143\uff0c\u6309\u6708\u5206\u5225\u534716\u500d\u53ca9.63\u500d\uff1b\u7576\u4e2d\u6210\u4ea4\u4f5477%\u5c6c\u4e00\u624b\u3002\u91cf\u984d\u4ff1\u589e\uff0c\u4e3b\u8981\u53d7\u60e0\u5e02\u5834\u9304\u5f97\u591a\u5b97\u5927\u984d\u6210\u4ea4\u5e36\u52d5\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">7\u6708\u9304\u5f9710\u5b97\u4e00\u624b\u6210\u4ea4\uff0c\u6d89\u53ca\u91d1\u984d\u7d0430.6\u5104\u5143\u3002\u7576\u4e2d\u5168\u6708\u4ea6\u9304\u5f97\u591a\u5b97\u77da\u76ee\u6210\u4ea4\uff0c\u5305\u62ec\u7a2e\u690d\u9053\u96d9\u865f4\u6d0b\u623f\uff0c\u4ee5\u5171\u7d0411\u5104\u5143\u6210\u4ea4\uff0c\u800c\u5c71\u9802\u905399\u81f3103\u865f\u4ea6\u67093\u9593\u6d0b\u623f\uff0c\u4ee5\u7d048.28\u5104\u5143\u6210\u4ea4\uff0c\u58fd\u81e3\u5c7115\u865f\u4ea6\u5206\u5225\u9304\u5f971\u5b977.17\u5104\u5143\u6210\u4ea4\u53ca1\u5b973.2\u5104\u5143\u6210\u4ea4\u3002\u81f3\u65bcOne Stanley\u4ea6\u9304\u5f971\u5b97\u5206\u5c64\u6236\uff0c\u4ee5\u7d049469\u842c\u5143\u6210\u4ea4\u3002</span></p>\n<p>\u4e8c\u624b\u5e02\u5834\u5168\u6708\u93043\u5b97\u8cb7\u8ce3\uff0c\u6210\u4ea4\u91d1\u984d\u7d049658\u842c\u5143\uff0c\u5206\u5225\u6309\u6708\u6e1b\u7d0440%\u53ca\u7d0467.47%\uff0c\u53cd\u6620\u5168\u6708\u4ee5\u4e00\u624b\u4e3b\u5c0e\u3002\u7531\u65bc7\u6708\u9304\u5f97\u591a\u5b97\u903e\u5104\u5143\u7684\u8d85\u7d1a\u8c6a\u5b85\u6210\u4ea4\u500b\u6848\uff0c\u5e36\u52d5\u6210\u4ea4\u91d1\u984d\u5927\u5e45\u98c6\u5347\u3002</p>\n<p>\u81f3\u65bc7\u6708\u5c71\u9802\u5357\u5340\u79df\u52d9\u5e02\u5834\uff0c\u5168\u6708\u9304\u5f97\u7d0453\u5b97\u79df\u52d9\uff0c\u6d89\u53ca\u6bcf\u6708\u7e3d\u91d1\u984d\u7d04\u70ba611\u842c\u5143\uff0c\u6309\u6708\u5206\u5225\u8f15\u5fae\u4e0b\u8dcc7.02%\u53ca3.79%\uff0c\u5168\u6708\u79df\u52d9\u4ea4\u6295\u8868\u73fe\u5927\u81f4\u76f8\u82e5\u3002\u800c\u6d0b\u623f\u4f549\u5b97\uff0c10\u842c\u5143\u6216\u4ee5\u4e0a\u6708\u79df\u7684\u5927\u984d\u6210\u4ea4\u5247\u4f54\u7d0425\u5b97\uff0c\u82076\u6708\u7d048\u5b97\u53ca18\u5b97\u5247\u5206\u5225\u589e\u52a0\u7d0412.5%\u53ca38.89%\u3002\u6708\u79df\u6700\u9ad8\u7684\u6210\u4ea4\u500b\u6848\u70ba\u67ef\u58eb\u7538\u5c71\u90538\u865f\u4e00\u5e62\u6d0b\u623f\uff0c\u6708\u79df\u91d1\u984d\u7d0450\u842c\u5143\uff0c\u544e\u79df\u7d04\u70ba109\u5143\u3002</p>\n<p>\u7f8e\u806f\u7269\u696d\u5c71\u9802\u5357\u5340\u8c6a\u5b85\u9996\u5e2d\u5340\u57df\u71df\u696d\u8463\u4e8b\u65b9\u5bcc\u7fa9\u8868\u793a\uff0c\u96a8\u7740\u5340\u5167\u6709\u8c6a\u5b85\u65b0\u76e4\u90e8\u7f72\u63a8\u51fa\uff1b\u52a0\u4e0a\u8fd1\u671f\u8c6a\u5b85\u6210\u4ea4\u8868\u73fe\u5411\u597d\uff0c\u800c\u4e14\u79df\u91d1\u4ea6\u898b\u4e00\u5b9a\u652f\u6301\uff0c\u9810\u8a08\u77ed\u671f\u5167\u5c71\u9802\u5357\u5340\u8c6a\u5b85\u8cb7\u8ce3\u53ca\u79df\u52d9\u8868\u73fe\u5c07\u6703\u5411\u597d\u3002</p>\n<p>\u00a0</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3844043/%E5%B1%B1%E9%A0%82%E5%8D%97%E5%8D%80%E4%B8%8A%E6%9C%88%E8%B1%AA%E5%AE%85%E8%B2%B7%E8%B3%A3%E5%83%B9%E9%87%8F%E9%BD%8A%E5%8D%87"}, {"title": "\u97d3\u65b0\u4efb\u99d0\u65e5\u5927\u4f7f:\u69cb\u5efa\u4e0d\u52d5\u6416\u97d3\u65e5\u95dc\u4fc2", "description": "<p><span style=\"font-size-ignore:13pt;\">\u5357\u97d3\u65b0\u4efb\u99d0\u65e5\u672c\u5927\u4f7f\u6734\u5586\u7199\u62b5\u9054\u6771\u4eac\u6642\u8868\u793a\uff0c\u5c07\u69cb\u5efa\u300c\u4e0d\u52d5\u6416\u3001\u4e0d\u5012\u9000\u300d\u7684\u97d3\u65e5\u95dc\u4fc2\u624d\u662f\u81ea\u5df1\u6240\u80a9\u8ca0\u7684\u4f7f\u547d\u3002</span></p>\n<p>\u6734\u5586\u7199\u8868\u793a\uff0c\u5c39\u932b\u6085\u653f\u5e9c\u6210\u7acb\u4ee5\u4f86\uff0c\u97d3\u65e5\u95dc\u4fc2\u57fa\u65bc\u9818\u5c0e\u4eba\u4e92\u4fe1\u8fce\u4f86\u4e86\u65b0\u7684\u8f49\u6369\u9ede\u3002\u660e\u5e74\u662f\u5169\u570b\u90a6\u4ea4\u6b63\u5e38\u531660\u5468\u5e74\uff0c\u5c07\u662f\u63a8\u52d5\u5169\u570b\u95dc\u4fc2\u66f4\u4e0a\u4e00\u5c64\u6a13\u3001\u958b\u95e2\u65b0\u672a\u4f86\u7684\u826f\u6a5f\u3002\u4ed6\u5f37\u8abf\uff0c\u5c07\u63a8\u9032\u8b93\u5169\u570b\u570b\u6c11\u5207\u8eab\u611f\u53d7\u5230\u7684\u5404\u7a2e\u5408\u4f5c\u9805\u76ee\uff0c\u9032\u800c\u63a8\u52d5\u97d3\u65e5\u95dc\u4fc2\u6210\u719f\u767c\u5c55\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3844116/%E9%9F%93%E6%96%B0%E4%BB%BB%E9%A7%90%E6%97%A5%E5%A4%A7%E4%BD%BF%3A%E6%A7%8B%E5%BB%BA%E4%B8%8D%E5%8B%95%E6%90%96%E9%9F%93%E6%97%A5%E9%97%9C%E4%BF%82"}, {"title": "\u745e\u9280\u6599\u5167\u5730\u80a1\u5e02\u4e0b\u884c\u7a7a\u9593\u6709\u9650", "description": "<p>\u745e\u9280\u8868\u793a\uff0c\u5916\u570b\u6295\u8cc7\u8005\u5728\u7b2c\u4e8c\u5b63\u7dad\u6301\u5c0d\u4e2d\u570b\u80a1\u7968\u7684\u6e1b\u6301\u5009\u4f4d\uff0c\u8003\u616e\u5230\u5916\u8cc7\u6a5f\u69cb\u5009\u4f4d\u8f03\u4f4e\u800c\u4fdd\u96aa\u8cc7\u91d1\u6301\u7e8c\u6d41\u5165\uff0c\u9810\u8a08\u5167\u5730\u80a1\u7968\u5e02\u5834\u4e0b\u884c\u7a7a\u9593\u6709\u9650\u3002</p>\n<p>\u8a72\u884c\u4e2d\u570b\u80a1\u7968\u7b56\u7565\u7814\u7a76\u4e3b\u7ba1\u738b\u5b97\u8c6a\u6307\u51fa\uff0c\u5118\u7ba14\u6708\u548c5\u6708\u5e02\u5834\u53cd\u5f48\uff0c\u4f46\u8a72\u884c\u5c0d\u5927\u7d04800\u5bb6\u6d3b\u8e8d\u7684\u5916\u570b\u6a5f\u69cb\u6295\u8cc7\u8005(\u5171\u6301\u6709\u7d041500\u5104\u7f8e\u5143\u7684\u4e2d\u570b\u80a1\u7968)\u7684\u8ffd\u8e64\u986f\u793a\uff0c\u4ed6\u5011\u7684\u6e1b\u6301\u5009\u4f4d\u5728\u6b21\u5b63\u6309\u5b63\u6301\u5e73\uff0c\u70ba\u8ca02.4\u500b\u767e\u5206\u9ede\u3002</p>\n<p>\u7576\u4e2d\uff0c\u7d04190\u96bb\u57fa\u91d1\u6c92\u6709\u6301\u6709\u4efb\u4f55\u4e2d\u570b\u80a1\u7968(\u7ba1\u7406\u898f\u6a21\u70ba2250\u5104\u7f8e\u5143)\uff0c\u670915\u96bb\u6301\u6709\u5c11\u91cf\u4e2d\u570b\u80a1\u7968\u7684\u5168\u7403\u8a17\u7ba1\u57fa\u91d1\u5728\u7b2c\u4e8c\u5b63\u6e05\u5009\uff0c\u670915\u96bb\u65b0\u8208\u5e02\u5834\u6388\u6b0a\u57fa\u91d1\u5118\u7ba1\u57fa\u6e96\u5305\u542b\u4e2d\u570b\u80a1\u7968\uff0c\u537b\u6c92\u6709\u4efb\u4f55\u982d\u5bf8\u3002</p>\n<p>\u5728\u4e92\u806f\u4e92\u901a\u65b9\u9762\uff0c\u8a72\u884c\u6307\u51fa\uff0c\u5317\u5411\u8cc7\u91d1\u7e7c\u7b2c\u4e00\u5b63\u6d41\u516594\u5104\u7f8e\u5143\u5f8c\uff0c\u7b2c\u4e8c\u5b63\u6d41\u51fa42\u5104\u7f8e\u5143\uff0c7\u6708\u9032\u4e00\u6b65\u6d41\u51fa23\u5104\u7f8e\u5143\uff0c\u800c\u5357\u5411\u8cc7\u91d1\u6d41\u5165\u5728\u7b2c\u4e8c\u5b63\u52a0\u5feb\u81f3310\u5104\u7f8e\u5143\u3002\u9451\u65bc\u5b8f\u89c0\u4e0d\u78ba\u5b9a\u6027\uff0c\u6295\u8cc7\u8005\u53ef\u80fd\u6703\u7e7c\u7e8c\u8cb7\u5165\u9632\u5b88\u6027\u548c\u9ad8\u6536\u76ca\u80a1\u7968\u3002</p>\n<p>\u8a72\u884c\u4e26\u7a31\uff0c<span style=\"font-size-ignore:13pt;\">\u7531\u65bc\u9999\u6e2f\u4e0a\u5e02\u516c\u53f8\u63d0\u4f9b1\u500b\u767e\u5206\u9ede\u7684\u984d\u5916\u80a1\u606f\u6536\u76ca\u7387\uff0c\u4ee5\u53ca\u5c0d\u4eba\u6c11\u5e63\u8cb6\u503c\u7684\u64d4\u6182\uff0c\u9810\u8a08\u5357\u5411\u8cc7\u91d1\u6d41\u5165\u5c07\u6703\u7e7c\u7e8c\uff0c\u7279\u5225\u662f\u4f86\u81ea\u4eab\u6709\u80a1\u606f\u7a05\u8c41\u514d\u7684\u4fdd\u96aa\u57fa\u91d1\u3002\u7531\u65bc\u5916\u8cc7\u6a5f\u69cb\u5009\u4f4d\u8f03\u4f4e\uff0c\u4ee5\u53ca\u4fdd\u96aa\u8cc7\u91d1\u6d41\u5165\uff0c\u8a8d\u70ba\u4e2d\u570b\u80a1\u5e02\u4e0b\u884c\u7a7a\u9593\u6709\u9650\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3844106/%E7%91%9E%E9%8A%80%E6%96%99%E5%85%A7%E5%9C%B0%E8%82%A1%E5%B8%82%E4%B8%8B%E8%A1%8C%E7%A9%BA%E9%96%93%E6%9C%89%E9%99%90"}]}