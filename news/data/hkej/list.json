ws/china/article/3951070/%E6%BD%98%E5%8A%9F%E5%8B%9D%E6%99%A4IMF%E7%B8%BD%E5%B9%B9%E4%BA%8B%E7%AD%89+%E5%B0%B1%E7%B6%93%E6%BF%9F%E5%BD%A2%E5%8B%A2%E4%BA%A4%E6%8F%9B%E6%84%8F%E8%A6%8B"}, {"title": "\u5149\u5927\u524d\u8463\u4e8b\u9577\u5510\u96d9\u5be7\u53d7\u8cc4\u903e1400\u842c \u5224\u56da12\u5e74", "description": "<p>\u592e\u8996\u65b0\u805e\u5831\u9053\uff0c\u4e2d\u570b\u5149\u5927\u96c6\u5718\u539f\u9ee8\u59d4\u66f8\u8a18\u3001\u8463\u4e8b\u9577\u5510\u96d9\u5be7\u8caa\u6c61\u3001\u53d7\u8cc4\u4e00\u6848\uff0c\u6cb3\u5317\u7701\u5510\u5c71\u5e02\u4e2d\u7d1a\u4eba\u6c11\u6cd5\u9662\u4eca\u65e5\u516c\u958b\u5ba3\u5224\uff0c\u4ee5\u8caa\u6c61\u7f6a\u5224\u8655\u6709\u671f\u5f92\u52115\u5e74\uff0c\u4e26\u8655\u7f70\u91d120\u842c\u5143(\u4eba\u6c11\u5e63\u2027\u4e0b\u540c)\uff0c\u4ee5\u53d7\u8cc4\u7f6a\u5224\u8655\u6709\u671f\u5f92\u521110\u5e746\u500b\u6708\uff0c\u4e26\u8655\u7f70\u91d1110\u842c\u5143\uff0c\u6c7a\u5b9a\u57f7\u884c\u6709\u671f\u5f92\u521112\u5e74\uff0c\u4e26\u8655\u7f70\u91d1130\u842c\u5143\uff1b\u5c0d\u5510\u96d9\u5be7\u72af\u7f6a\u6240\u5f97\u8ca1\u7269\u53ca\u5b73\u606f\u4f9d\u6cd5\u4e88\u4ee5\u8ffd\u7e73\uff0c\u5206\u5225\u8fd4\u9084\u88ab\u5bb3\u55ae\u4f4d\u6216\u8005\u4e0a\u7e73\u570b\u5eab\u3002</p>\n<p>\u7d93\u5be9\u7406\u67e5\u660e\uff0c2003\u5e744\u6708\uff0c\u5510\u96d9\u5be7\u5229\u7528\u64d4\u4efb\u4e2d\u570b\u4eba\u6c11\u9280\u884c\u9280\u884c\u76e3\u7ba1\u4e00\u53f8\u53f8\u9577\u8077\u52d9\u4e0a\u7684\u4fbf\u5229\uff0c\u5c07\u5176\u4fdd\u7ba1\u3001\u4f7f\u7528\u7684\u50f9\u503c301.5\u842c\u5143\u516c\u5171\u8ca1\u7269\u64da\u70ba\u5df1\u6709\u30022000\u5e74\u81f32017\u5e74\uff0c\u5510\u96d9\u5be7\u5229\u7528\u64d4\u4efb\u4eba\u6c11\u9280\u884c\u9280\u884c\u76e3\u7ba1\u4e00\u53f8\u53f8\u9577\uff0c\u4e2d\u570b\u9280\u884c\u696d\u76e3\u7763\u7ba1\u7406\u59d4\u54e1\u6703\u9ee8\u59d4\u59d4\u54e1\u3001\u526f\u4e3b\u5e2d\uff0c\u4e2d\u570b\u5149\u5927\u96c6\u5718\u80a1\u4efd\u516c\u53f8\u9ee8\u59d4\u66f8\u8a18\u3001\u8463\u4e8b\u9577\uff0c\u4e2d\u570b\u5149\u5927\u9280\u884c\u80a1\u4efd\u6709\u9650\u516c\u53f8\u9ee8\u59d4\u66f8\u8a18\u3001\u8463\u4e8b\u9577\u7b49\u8077\u52d9\u4e0a\u7684\u4fbf\u5229\uff0c\u70ba\u6709\u95dc\u55ae\u4f4d\u548c\u500b\u4eba\u5728\u8077\u52d9\u8abf\u6574\u3001\u8cb8\u6b3e\u7372\u53d6\u7b49\u4e8b\u9805\u4e0a\u63d0\u4f9b\u5e6b\u52a9\uff0c\u975e\u6cd5\u6536\u53d7\u8ca1\u7269\u5171\u8a081102\u842c\u9918\u5143\u3002</p>\n<p>\u6cd5\u9662\u8a8d\u70ba\uff0c\u5510\u96d9\u5be7\u7684\u884c\u70ba\u69cb\u6210\u8caa\u6c61\u7f6a\u3001\u53d7\u8cc4\u7f6a\uff0c\u6578\u984d\u5747\u7279\u5225\u5de8\u5927\uff0c\u61c9\u4f9d\u6cd5\u61f2\u8655\u3002\u9451\u65bc\u5510\u96d9\u5be7\u5230\u6848\u5f8c\u5982\u5be6\u4f9b\u8ff0\u7f6a\u884c\uff0c\u4e3b\u52d5\u4ea4\u4ee3\u8fa6\u6848\u6a5f\u95dc\u5c1a\u672a\u638c\u63e1\u7684\u8caa\u6c61\u4e8b\u5be6\u548c\u90e8\u5206\u53d7\u8cc4\u4e8b\u5be6\uff0c\u6240\u72af\u8caa\u6c61\u7f6a\u69cb\u6210\u81ea\u9996\uff0c\u8a8d\u7f6a\u6094\u7f6a\uff0c\u7a4d\u6975\u9000\u8d13\uff0c\u8d13\u6b3e\u8d13\u7269\u53ca\u5b73\u606f\u5df2\u5168\u90e8\u8ffd\u7e73\uff0c\u5c0d\u5176\u6240\u72af\u8caa\u6c61\u7f6a\u53ef\u6e1b\u8f15\u8655\u7f70\uff0c\u6240\u72af\u53d7\u8cc4\u7f6a\u53ef\u5f9e\u8f15\u8655\u7f70\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3951036/%E5%85%89%E5%A4%A7%E5%89%8D%E8%91%A3%E4%BA%8B%E9%95%B7%E5%94%90%E9%9B%99%E5%AF%A7%E5%8F%97%E8%B3%84%E9%80%BE1400%E8%90%AC+%E5%88%A4%E5%9B%9A12%E5%B9%B4"}, {"title": "11\u6708\u4e2d\u5c0f\u4f01\u6574\u9ad4\u71df\u5546\u6c23\u6c1b\u7565\u70ba\u6e1b\u5f31", "description": "<p>\u653f\u5e9c\u7d71\u8a08\u8655\u516c\u5e03\uff0c11\u6708\u4e2d\u5c0f\u578b\u4f01\u696d\u696d\u52d9\u72c0\u6cc1\u8abf\u67e5\uff0c\u4e2d\u5c0f\u4f01\u696d\u52d9\u6536\u76ca\u7684\u73fe\u6642\u52d5\u5411\u6307\u6578\u753110\u6708\u5728\u6536\u7e2e\u5340\u57df\u768442.3\u4e0b\u8dcc\u81f311\u6708\u768441.9\uff0c\u800c\u672a\u4f86\u4e00\u500b\u6708(\u537312\u6708)\u7684\u696d\u52d9\u6536\u76ca\u5c55\u671b\u52d5\u5411\u6307\uf969\u70ba46.6\u3002</p>\n<p>\u6309\u884c\u696d\u5206\u6790\uff0c\u4e00\u4e9b\u7d71\u8a08\u8abf\u67e5\u6db5\u84cb\u7684\u884c\u696d\u7684\u696d\u52d9\u6536\u76ca\u73fe\u6642\u52d5\u5411\u6307\u6578\u572811\u6708\u6309\u6708\u4e0b\u8dcc\uff0c\u5305\u62ec\u5546\u7528\u670d\u52d9\u696d\u5f9e50\u4e0b\u8dcc\u81f345.9\uff1b\u98f2\u98df\u696d\u5f9e37.4\u4e0b\u8dcc\u81f334.9\uff1b\u96f6\u552e\u696d\u5f9e39.8\u4e0b\u8dcc\u81f337.7\u3002</p>\n<p>\u9032\u51fa\u53e3\u8cbf\u6613\u696d\u65b0\u8a02\u55ae\u7684\u73fe\u6642\u52d5\u5411\u6307\uf969\u5f9e10\u6708\u768444.7\u4e0a\u5347\u81f311\u6708\u768445.1\uff0c\u800c\u672a\u4f86\u4e00\u500b\u6708(\u537312\u6708)\u7684\u65b0\u8a02\u55ae\u5c55\u671b\u52d5\u5411\u6307\uf969\u70ba47.4\u3002</p>\n<p>\u653f\u5e9c\u767c\u8a00\u4eba\u8868\u793a\uff0c11\u6708\u4e2d\u5c0f\u4f01\u7684\u6574\u9ad4\u71df\u5546\u6c23\u6c1b\u53ca\u5176\u5c0d\u672a\u4f86\u4e00\u500b\u6708\u696d\u52d9\u60c5\u6cc1\u7684\u6574\u9ad4\u9810\u671f\u7565\u70ba\u6e1b\u5f31\uff0c\u4f46\u500b\u5225\u884c\u696d\u7684\u60c5\u6cc1\u6709\u6240\u4e0d\u540c\u3002\u6574\u9ad4\u5c31\u696d\u60c5\u6cc1\u7dad\u6301\u5927\u81f4\u5e73\u7a69\u3002</p>\n<p>\u767c\u8a00\u4eba\u88dc\u5145\uff0c\u5168\u7403\u7d93\u6fdf\u4e0d\u660e\u6717\u56e0\u7d20\u589e\u52a0\u548c\u8cbf\u6613\u6469\u64e6\u5347\u6eab\u6703\u70ba\u696d\u52d9\u524d\u666f\u5e36\u4f86\u58d3\u529b\u3002\u4e0d\u904e\uff0c\u4e2d\u592e\u653f\u5e9c\u6700\u8fd1\u63a8\u51fa\u591a\u9805\u63d0\u632f\u5167\u5730\u7d93\u6fdf\u7684\u63aa\u65bd\uff0c\u4ee5\u53ca\u5404\u9805\u60e0\u6e2f\u63aa\u65bd\uff0c\u61c9\u6703\u6709\u5229\u71df\u5546\u6c23\u6c1b\u3002\u653f\u5e9c\u6703\u5bc6\u5207\u76e3\u5bdf\u76f8\u95dc\u60c5\u6cc1\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3951047/11%E6%9C%88%E4%B8%AD%E5%B0%8F%E4%BC%81%E6%95%B4%E9%AB%94%E7%87%9F%E5%95%86%E6%B0%A3%E6%B0%9B%E7%95%A5%E7%82%BA%E6%B8%9B%E5%BC%B1"}]}