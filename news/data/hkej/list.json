b9\u9152\u5e97\u8f49\u4f5c\u9752\u5e74\u5bbf\u820d \u63d0\u4f9b\u6700\u591a160\u5bbf\u4f4d", "description": "<p>\u6c11\u9752\u5c40\u6279\u51fa\u7b2c\u4e94\u500b\u300c\u5c07\u9152\u5e97\u548c\u65c5\u9928\u8f49\u4f5c\u9752\u5e74\u5bbf\u820d\u7528\u9014\u7684\u8cc7\u52a9\u8a08\u5283\u300d\u9805\u76ee\u3002\u9805\u76ee\u4f4d\u65bc\u5bcc\u8c6a\u6771\u65b9\u9152\u5e97\uff0c\u5171\u670980\u500b\u623f\u9593\uff0c\u53ef\u63d0\u4f9b\u6700\u591a160\u500b\u5bbf\u4f4d\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u8a72\u9805\u76ee\u7531\u4ec1\u611b\u5802\u8207\u5bcc\u8c6a\u9152\u5e97\u96c6\u5718\u5408\u4f5c\u63a8\u51fa</span><span style=\"font-size-ignore:13pt;\">\u3002</span><span style=\"font-size-ignore:13pt;\">\u9805\u76ee\u7684\u5176\u4e2d\u4e00\u500b\u7279\u8272\u662f\u900f\u904e\u63d0\u4f9b\u57f9\u8a13\u8ab2\u7a0b\u3001\u4ea4\u6d41\u6d3b\u52d5\u548c\u5be6\u7fd2\u8a08\u5283\uff0c\u52a0\u5f37\u9752\u5e74\u79df\u6236\u5c0d\u570b\u5bb6\u767c\u5c55\u6a5f\u9047\u7684\u4e86\u89e3\uff0c\u4e26\u6703\u8209\u8fa6\u7406\u8ca1\u8ab2\u7a0b\u3001\u8077\u696d\u767c\u5c55\u5de5\u4f5c\u574a\u548c\u5fc3\u7406\u5065\u5eb7\u8b1b\u5ea7\u7b49\u6d3b\u52d5\uff0c\u70ba\u9752\u5e74\u63d0\u4f9b\u4e0d\u540c\u65b9\u9762\u7684\u81ea\u6211\u589e\u503c\u53ca\u652f\u63f4\u670d\u52d9\u3002</span><span style=\"font-size-ignore:13pt;\">\u4ec1\u611b\u5802\u4ea6\u6703\u7d44\u7e54\u9752\u5e74\u670d\u52d9\u968a\uff0c\u9080\u8acb\u9752\u5e74\u5171\u540c\u7b56\u5283\u793e\u5340\u6d3b\u52d5\uff0c\u4e26\u6703\u5b9a\u671f\u5b89\u6392\u4e0d\u540c\u985e\u578b\u7684\u7fa9\u5de5\u670d\u52d9\uff0c\u9f13\u52f5\u4ed6\u5011\u8ca2\u737b\u793e\u6703\uff0c\u5f9e\u800c\u5efa\u7acb\u5c0d\u793e\u6703\u7684\u6b78\u5c6c\u611f\u548c\u8cac\u4efb\u611f\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3909299/%E5%AF%8C%E8%B1%AA%E6%9D%B1%E6%96%B9%E9%85%92%E5%BA%97%E8%BD%89%E4%BD%9C%E9%9D%92%E5%B9%B4%E5%AE%BF%E8%88%8D+%E6%8F%90%E4%BE%9B%E6%9C%80%E5%A4%9A160%E5%AE%BF%E4%BD%8D"}, {"title": "\u8c9d\u840a\u5fb7\u6301\u62fc\u591a\u591a\u80a1\u6b0a\u51fa\u932f \u6301\u80a1\u75319.5%\u4fee\u6b63\u81f32.4%", "description": "<p>\u8c9d\u840a\u5fb7(BlackRock)\u5411\u7f8e\u570b\u8b49\u5238\u4ea4\u6613\u59d4\u54e1\u6703(SEC)\u63d0\u4ea4\u7684\u80a1\u6b0a\u62ab\u9732\u64ec\u4f3c\u51fa\u932f\uff0c\u89f8\u767c\u5167\u5730\u5546\u8cbf\u5e73\u53f0\u62fc\u591a\u591a\u5728\u7f8e\u80a1\u80a1\u50f9\u51fa\u73fe\u5927\u5e45\u6ce2\u52d5\u3002</p>\n<p>\u00a0</p>\n<p>\u8c9d\u840a\u5fb7(BlackRock)\u5411\u7f8e\u570b\u8b49\u5238\u4ea4\u6613\u59d4\u54e1\u6703\u65bc\u5468\u4e00(21\u65e5)\u63d0\u4ea4\u7684\u4ea4\u4ef6\u62ab\u9732\uff0c\u65bc\u7b2c\u4e09\u5b63\u5927\u624b\u589e\u6301\u62fc\u591a\u591a\u81f3\u7d041.32\u5104\u80a1\uff0c\u80a1\u6b0a\u75312.1%\u98c6\u5347\u81f39.5%\uff0c\u4e00\u5ea6\u523a\u6fc0\u62fc\u591a\u591a\u80a1\u50f9\u98c6\u5347\u903e8%\u3002</p>\n<p>\u4e0d\u904e\uff0c\u8c9d\u840a\u5fb7\u65bc\u5468\u4e8c(22\u65e5)\u5411\u7f8e\u570b\u8b49\u5238\u4ea4\u6613\u59d4\u54e1\u6703\u63d0\u4ea4<span style=\"font-size-ignore:13pt;\">\u4fee\u6b63\u6587\u4ef6\uff0c\u6f84\u6e05\u6301\u80a1\u91cf\u50c5\u70ba2.4%\u62163300\u842c\u80a1\uff0c\u5373\u7b2c\u4e09\u5b63\u50c5</span><span style=\"font-size-ignore:13pt;\">\u589e\u6301400\u842c\u80a1\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3909291/%E8%B2%9D%E8%90%8A%E5%BE%B7%E6%8C%81%E6%8B%BC%E5%A4%9A%E5%A4%9A%E8%82%A1%E6%AC%8A%E5%87%BA%E9%8C%AF+%E6%8C%81%E8%82%A1%E7%94%B19.5%25%E4%BF%AE%E6%AD%A3%E8%87%B32.4%25"}]}