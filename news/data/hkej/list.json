\u589e\u52a0\u50f9\u503c\u7d0414\u5104\u5143 \u3002\u76db\u4e8b\u4ee5\u6703\u8b70\u53ca\u5c55\u89bd\u9818\u57df\u7684\u6d3b\u52d5\u5c45\u591a\uff0c\u670938\u9805\uff0c\u4f5434%\u3002\u5176\u6b21\u662f\u6587\u5316\u85dd\u8853\u53ca\u5275\u610f\u6d3b\u52d5\uff0c\u670931\u9805\u3002</span></p>\n<p>\u7d93\u6c11\u806f\u7acb\u6cd5\u6703\u8b70\u54e1\u6797\u5065\u92d2\u63d0\u51fa\u66f8\u9762\u8cea\u8a62\uff0c\u95dc\u6ce8\u76db\u4e8b\u6578\u76ee\u3001\u7d93\u6fdf\u6548\u76ca\u53ca\u5ba3\u50b3\u5de5\u4f5c\u3002\u7f85\u6dd1\u4f69\u66f8\u9762\u56de\u8986\u8868\u793a\uff0c2024\u5e74\u4e0a\u534a\u5e74\u76db\u4e8b\u5e74\u8868\u5171\u6709110\u9805\u76db\u4e8b\uff0c\u4e26\u6307\u7de8\u5236\u76db\u4e8b\u5e74\u8868\u7684\u5176\u4e2d\u4e00\u500b\u4e3b\u8981\u76ee\u7684\u662f\u8b93\u5927\u773e\u548c\u904a\u5ba2\u53ca\u65e9\u77e5\u6089\u6d3b\u52d5\uff0c\u8b93\u65c5\u904a\u696d\u754c \u3001\u9152\u5e97\u696d\u3001\u9910\u98f2\u696d\u53ca\u65e9\u90e8\u7f72\uff0c\u4e26\u8a2d\u8a08\u63a8\u5ee3\u8a08\u5283\u548c\u65c5\u904a\u7522\u54c1 \u3002\u5979\u4ea6\u4ee5\u6e2f\u53f0\u7bc0\u76ee\u300a\u76db\u4e8b\u50b3\u57ce\u300b\u53ca\u65b0\u805e\u8655\u300c\u9999\u6e2f\u54c1\u724c\u300d\u7db2\u9801\u300c\u76db\u4e8b\u4e4b\u90fd\u300d\u5c08\u9805\u70ba\u4f8b\uff0c\u6307\u5df2\u52a0\u5f37\u63a8\u5ee3\u76db\u4e8b\u3002</p>\n<p>\u53e6\u5916\uff0c\u300a\u8ca1\u653f\u9810\u7b97\u6848\u300b\u63d0\u51fa\u9810\u75591\u5104\u5143\uff0c\u4ee5\u52a0\u5f37\u672a\u4f863\u5e74\u76db\u4e8b\u5ba3\u50b3\u5de5\u4f5c\uff0c\u6797\u5065\u92d2\u95dc\u6ce8\u6709\u95dc\u8a73\u60c5\u53ca\u9032\u5c55\u3002\u7f85\u6dd1\u4f69\u8868\u793a\uff0c\u653f\u5e9c\u6703\u5be9\u8996\u548c\u56e0\u61c9\u8b8a\u5316\u53ca\u66f4\u65b0\u7684\u76db\u4e8b\u8209\u8fa6\u8a08\u5283\uff0c\u7528\u597d\u5404\u9805\u8cc7\u6e90\uff0c\u52a0\u5f37\u76db\u4e8b\u5ba3\u50b3\u5de5\u4f5c\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3951825/%E4%BB%8A%E5%B9%B4%E4%B8%8A%E5%8D%8A%E5%B9%B4%E8%BE%A6110%E9%A0%85%E7%9B%9B%E4%BA%8B+%E5%90%B855%E8%90%AC%E6%97%85%E5%AE%A2"}, {"title": "AMD\u8607\u59ff\u8c50\u81ba\u300a\u6642\u4ee3\u300b\u96dc\u8a8c\u5e74\u5ea6CEO", "description": "<p>\u7f8e\u570b\u300a\u6642\u4ee3\u300b(TIME)\u96dc\u8a8c\u8a55\u9078\u8d85\u5fae\u534a\u5c0e\u9ad4(AMD)\u4e3b\u5e2d\u517c\u884c\u653f\u7e3d\u88c1(CEO)\u8607\u59ff\u8c50(Lisa Su)\u70ba\u5e74\u5ea6\u884c\u653f\u7e3d\u88c1\u3002</p>\n<p>\u8607\u59ff\u8c50\u65bc2012\u5e74\u52a0\u5165AMD\uff0c\u51fa\u4efb\u9ad8\u7d1a\u526f\u7e3d\u88c1\u517c\u7e3d\u7d93\u7406\uff0c<span style=\"font-size-ignore:13pt;\">2014\u5e74\u5347\u4efb\u70baCEO\u3002\u5979\u63a5\u7ba1\u9019\u5bb6\u8ca0\u50b5\u7d2f\u7d2f\u4e14\u5df2\u89e3\u50f125%\u54e1\u5de5\u7684\u516c\u53f8\uff0c\u9762\u81e8\u7740\u8271\u96e3\u7684\u8655\u5883\u3002\u5979\u901a\u904e\u63a8\u51fa\u92b3\u9f8d\u8655\u7406\u5668\u548cZen\u6838\u5fc3\u67b6\u69cb\u7b49\u95dc\u9375\u6c7a\u7b56\uff0c\u6210\u529f\u626d\u8f49AMD\u7684\u9839\u52e2\u3002</span></p>\n<p>10\u5e74\u524d\uff0cAMD\u80a1\u50f9\u5f98\u5f8a3\u7f8e\u5143\uff0c\u4eca\u5e74\u80a1\u50f9\u4e00\u5ea6\u6500\u5347\u81f3\u8d85\u903e200\u7f8e\u5143\uff0c\u76ee\u524d\u5247\u56de\u9806\u81f3\u7d04130\u7f8e\u5143\uff0c\u4ecd\u8f03\u8607\u59ff\u8c50\u63a5\u638cAMD\u6642\u66b4\u6f32\u903e40\u500d\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u4eca\u5e749\u6708\uff0c\u5728</span><span style=\"font-size-ignore:13pt;\">\u300a\u6642\u4ee3\u300b\u4eba\u5de5\u667a\u80fd(AI)\u9818\u57df\u767e\u5927\u5f71\u97ff\u529b\u4eba\u7269\u699c\u4e2d\uff0c</span><span style=\"font-size-ignore:13pt;\">\u8607\u59ff\u8c50\u4ea6\u4e0a\u699c\uff0c\u70ba</span><span style=\"font-size-ignore:13pt;\">\u5275\u9020\u8005\u985e\u5225\u7684\u4ee3\u8868\u4eba\u7269\u4e4b\u4e00\uff0c\u5979\u88ab\u8a55\u70ba\u9802\u4f4f\u6700\u5f37\u5c0d\u624b\u8f1d\u9054\u7684\u7af6\u722d\u58d3\u529b\uff0c\u63a8\u52d5\u516c\u53f8\u5728AI\u9818\u57df\u7684\u5275\u65b0\u548c\u62d3\u5c55\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u8607\u59ff\u8c50\u5728\u53f0\u7063\u51fa\u751f\uff0c3\u6b72\u6642\u8209\u5bb6\u79fb\u6c11\u7f8e\u570b\u3002\u5728\u7d10\u7d04\u9577\u5927\u7684\u5979\u5f88\u5c0f\u5c31\u767c\u73fe\u81ea\u5df1\u5c0dSTEM(\u79d1\u5b78\u3001\u6280\u8853\u3001\u5de5\u7a0b\u8207\u6578\u5b78)\u7684\u71b1\u611b\uff0c\u4e26\u9010\u6f38\u5c0d\u5728\u96fb\u8166\u4e0a\u7de8\u5beb\u57fa\u672c\u7a0b\u5f0f\u7740\u8ff7\u3002\u5979\u5728\u9ebb\u7701\u7406\u5de5\u5b78\u9662\u4e3b\u4fee\u96fb\u6a5f\u5de5\u7a0b\u5b78\uff0c\u6700\u7d42\u53d6\u5f97\u535a\u58eb\u5b78\u4f4d\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3951786/AMD%E8%98%87%E5%A7%BF%E8%B1%90%E8%86%BA%E3%80%8A%E6%99%82%E4%BB%A3%E3%80%8B%E9%9B%9C%E8%AA%8C%E5%B9%B4%E5%BA%A6CEO"}, {"title": "\u5c0f\u9d6cP7+\u7d2f\u8a08\u4ea4\u4ed8\u7a81\u78341\u842c\u8f1b", "description": "<p>\u5c0f\u9d6c\u6c7d\u8eca(<a target='_blank' href='https://stock360.hkej.com/quotePlus/09868' >09868</a>)\u5728\u5fae\u535a\u5ba3\u5e03\uff0c\u5c0f\u9d6cP7+\u4e0a\u5e02\u7d2f\u8a08\u4ea4\u4ed8\u7a81\u78341\u842c\u8f1b\u3002</p>\n<p>\u8a72\u516c\u53f8\u6307\u51fa\uff0c\u5c0f\u9d6c\u6c7d\u8ecaCEO\u4f55\u5c0f\u9d6c\u73fe\u8eab\u5ee3\u5dde\u4ea4\u4ed8\u4e2d\u5fc3\uff0c\u7d66\u7b2c1\u842c\u8f1bP7+\u8eca\u4e3b\u9032\u884c\u4ea4\u4ed8\u3002\u4f55\u5c0f\u9d6c\u5728\u73fe\u5834\u900f\u9732\uff0c\u5c0f\u9d6cP7+\u5df2\u5b8c\u6210\u7b2c3\u6b21\u7522\u80fd\u63d0\u5347\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3951816/%E5%B0%8F%E9%B5%ACP7%2B%E7%B4%AF%E8%A8%88%E4%BA%A4%E4%BB%98%E7%AA%81%E7%A0%B41%E8%90%AC%E8%BC%9B"}, {"title": "\u5ed6\u632f\u65b0\u8a2a\u554f\u963f\u806f\u914b\u53ca\u5df4\u6797 \u63a8\u5ee3\u9999\u6e2f\u4f5c\u70ba\u570b\u969b\u822a\u904b\u7269\u6d41\u6a1e\u7d10\u512a\u52e2", "description": "<p><span style=\"font-size-ignore:13pt;\">\u904b\u8f38\u53ca\u7269\u6d41\u5c40\u526f\u5c40\u9577\u5ed6\u632f\u65b0\u7387\u9818\u9999\u6e2f\u6d77\u904b\u6e2f\u53e3\u5c40\u53ca\u9999\u6e2f\u7269\u6d41\u767c\u5c55\u5c40\u6210\u54e1\u3001\u6d77\u4e8b\u8655\u548c\u6295\u8cc7\u63a8\u5ee3\u7f72\u7684\u4ee3\u8868\uff0c\u524d\u5f80\u963f\u806f\u914b\u675c\u62dc\u548c\u963f\u5e03\u624e\u6bd4\uff0c\u4ee5\u53ca\u5df4\u6797\u9032\u884c\u70ba\u671f5\u65e5\u8a2a\u554f\uff0c\u63a8\u5ee3\u9999\u6e2f\u4f5c\u70ba\u570b\u969b\u822a\u904b\u53ca\u7269\u6d41\u6a1e\u7d10\u7684\u512a\u52e2\u548c\u6a5f\u9047\u3002</span></p>\n<p>\u5ed6\u632f\u65b0\u548c\u9999\u6e2f\u6d77\u904b\u6e2f\u53e3\u5c40\u6210\u54e1\uff0c\u7576\u5730\u6642\u9593\u524d\u65e5\u53ca\u6628\u65e5\u5c55\u958b\u675c\u62dc\u548c\u963f\u5e03\u624e\u6bd4\u8a2a\u554f\u884c\u7a0b\uff0c\u4e26\u8207\u591a\u9593\u822a\u904b\u4f01\u696d\u3001\u6e2f\u53e3\u71df\u904b\u5546\u548c\u6d77\u904b\u7d44\u7e54\u7b49\u4ee3\u8868\u6703\u9762\uff0c\u89e3\u8aaa\u9999\u6e2f\u767c\u5c55\u9ad8\u589e\u503c\u6d77\u904b\u670d\u52d9\u3001\u7da0\u8272\u822a\u904b\u548c\u7814\u7a76\u589e\u8a2d\u5927\u5b97\u5546\u54c1\u4ea4\u6613\u7a05\u52d9\u512a\u60e0\u7b49\u63aa\u65bd\u3001\u9999\u6e2f\u8239\u8236\u8a3b\u518a\u8655\u7684\u512a\u5316\u670d\u52d9\uff0c\u4ee5\u53ca\u822a\u904b\u4f01\u696d\u5728\u9999\u6e2f\u8a2d\u7acb\u548c\u64f4\u5c55\u696d\u52d9\u7684\u5546\u6a5f\u3002</p>\n<p>\u4ee3\u8868\u5718\u4ea6\u5411\u7576\u5730\u4ef2\u88c1\u4e2d\u5fc3\u4ee3\u8868\u4ecb\u7d39\u9999\u6e2f\u4f5c\u70ba\u666e\u901a\u6cd5\u53f8\u6cd5\u7ba1\u8f44\u5340\u7684\u7368\u7279\u6027\uff0c\u4ee5\u53ca\u6ce2\u7f85\u7684\u6d77\u570b\u969b\u822a\u904b\u516c\u6703\u8a8d\u53ef\u76844\u500b\u4ef2\u88c1\u5730\u4e4b\u4e00\u7684\u597d\u8655\uff0c\u4fc3\u9032\u96d9\u65b9\u4eba\u624d\u4ea4\u6d41\u548c\u5408\u4f5c\u3002\u5ed6\u632f\u65b0\u548c\u4ee3\u8868\u5718\u4ea6\u62dc\u8a2a\u4e2d\u83ef\u4eba\u6c11\u5171\u548c\u570b\u99d0\u963f\u806f\u914b\u7279\u547d\u5168\u6b0a\u5927\u4f7f\u5f35\u76ca\u660e\uff0c\u5411\u4ed6\u6ed9\u5831\u9999\u6e2f\u6e2f\u53e3\u548c\u6d77\u904b\u696d\u7684\u767c\u5c55\u65b9\u5411\u3002</p>\n<p>\u9999\u6e2f\u7269\u6d41\u767c\u5c55\u5c40\u6210\u54e1\u4eca\u65e5\u52a0\u5165\u4ee3\u8868\u5718\uff0c\u7e7c\u7e8c\u675c\u62dc\u548c\u5df4\u6797\u8a2a\u554f\u884c\u7a0b\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3951797/%E5%BB%96%E6%8C%AF%E6%96%B0%E8%A8%AA%E5%95%8F%E9%98%BF%E8%81%AF%E9%85%8B%E5%8F%8A%E5%B7%B4%E6%9E%97+%E6%8E%A8%E5%BB%A3%E9%A6%99%E6%B8%AF%E4%BD%9C%E7%82%BA%E5%9C%8B%E9%9A%9B%E8%88%AA%E9%81%8B%E7%89%A9%E6%B5%81%E6%A8%9E%E7%B4%90%E5%84%AA%E5%8B%A2"}, {"title": "\u8c9d\u840a\u5fb7:\u5373\u4f7f\u50c5\u6eab\u548c\u6e1b\u606f \u6295\u8cc7\u8005\u4ea6\u5c07\u589e\u80a1\u50b5\u914d\u7f6e", "description": "<p>\u5168\u7403\u6700\u5927\u57fa\u91d1\u516c\u53f8\u8c9d\u840a\u5fb7(BlackRock)\u8ca1\u52d9\u7e3d\u76e3Martin Small\u8868\u793a\uff0c\u5373\u4f7f\u7f8e\u570b\u806f\u5132\u5c40\u53ea\u662f\u300c\u6eab\u548c\u300d\u6e1b\u606f\uff0c\u6295\u8cc7\u8005\u4e5f\u6703\u5c07\u8cc7\u7522\u5f9e\u73fe\u91d1\u8f49\u5411\u589e\u52a0\u80a1\u7968\u548c\u50b5\u5238\u7684\u914d\u7f6e\u3002</p>\n<p>\u96a8\u7740\u7f8e\u570b\u7d93\u6fdf\u8fd1\u6578\u6708\u5728\u501f\u8cb8\u6210\u672c\u9ad8\u4f01\u7684\u60c5\u6cc1\u4e0b\uff0c\u4ecd\u7e7c\u7e8c\u4fdd\u6301\u589e\u9577\u52e2\u982d\uff0c\u5e02\u5834\u5c0d\u806f\u5132\u5c40\u6e1b\u606f\u9810\u671f\u964d\u6eab\u3002Small\u5728\u4e00\u5834\u6703\u8b70\u4e0a\u6307\u51fa\uff0c\u76f8\u4fe1\u5373\u4f7f\u662f\u6eab\u548c\u7684\u6e1b\u606f\uff0c\u4e5f\u6703\u52a9\u9577\u6295\u8cc7\u8005\u975e\u5e38\u5065\u5eb7\u7684\u518d\u5192\u96aa\u884c\u70ba\u3002</p>\n<p>\u4ed6\u7a31\uff0c\u504f\u611b\u73fe\u91d1\u7684\u6295\u8cc7\u8005\u7e3e\u6548\u4e0d\u5982\u6df7\u5408\u80a1\u50b5\u7684\u50b3\u7d71\u6295\u8cc7\u7d44\u5408\uff0c\u9019\u7a2e\u5bb3\u6015\u932f\u904e\u7684\u5fc3\u7406\uff0c\u662f\u5c0e\u81f4\u91cd\u65b0\u5192\u96aa\u7684\u91cd\u8981\u539f\u56e0\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3951801/%E8%B2%9D%E8%90%8A%E5%BE%B7%3A%E5%8D%B3%E4%BD%BF%E5%83%85%E6%BA%AB%E5%92%8C%E6%B8%9B%E6%81%AF+%E6%8A%95%E8%B3%87%E8%80%85%E4%BA%A6%E5%B0%87%E5%A2%9E%E8%82%A1%E5%82%B5%E9%85%8D%E7%BD%AE"}]}