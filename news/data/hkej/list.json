b\u91d1\u78da\u570b\u5bb6\u6df1\u6d77\u8cc7\u6e90\u570b\u969b\u7814\u7a76\u4e2d\u5fc3\u3001\u91d1\u78da\u570b\u5bb6\u7279\u6b8a\u7d93\u6fdf\u5340\u4e2d\u570b\u5408\u4f5c\u4e2d\u5fc3\u3001\u91d1\u78da\u570b\u5bb6\u5de5\u696d\u80fd\u529b\u4e2d\u570b\u4e2d\u5fc3\u3001\u91d1\u78da\u570b\u5bb6\u6578\u5b57\u7523\u696d\u751f\u614b\u5408\u4f5c\u7db2\u7d61\uff0c\u6b61\u8fce\u5404\u65b9\u7a4d\u6975\u53c3\u8207\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3909720/%E7%BF%92%E8%BF%91%E5%B9%B3%3A%E7%B6%AD%E8%AD%B7%E9%AB%98%E6%B0%B4%E5%B9%B3%E9%87%91%E8%9E%8D%E5%AE%89%E5%85%A8+%E5%81%9A%E5%A4%A7%E5%81%9A%E5%BC%B7%E6%96%B0%E9%96%8B%E7%99%BC%E9%8A%80%E8%A1%8C"}, {"title": "\u842c\u5e74\u5de5\u696d\u5927\u5ec8\u5168\u5c64\u610f\u5411\u50f98200\u842c", "description": "<p>\u7b2c\u4e00\u592a\u5e73\u6234\u7dad\u65af\u7372\u59d4\u4efb\u70ba\u7368\u5bb6\u4ee3\u7406\uff0c\u4ee5\u79c1\u4eba\u8981\u7d04\u5f62\u5f0f\u653e\u552e\u6cb9\u5858\u842c\u5e74\u5de5\u696d\u5927\u5ec89\u6a13\u3002\u8a72\u5c64\u6a13\u9762\u7e3d\u6279\u5247\u9762\u7a4d\u7d0422246\u65b9\u544e\uff0c\u7269\u696d\u4ee5\u73fe\u72c0\u9023\u73fe\u6709\u79df\u7d04\u51fa\u552e\uff0c\u79c1\u4eba\u8981\u7d04\u622a\u6b62\u65e5\u671f\u70ba\u4eca\u5e7411\u670828\u65e5\u3002</p>\n<p>\u7b2c\u4e00\u592a\u5e73\u6234\u7dad\u65af\u8cc7\u6df1\u8463\u4e8b\u53ca\u5de5\u696d\u53ca\u4e5d\u9f8d\u5546\u696d\u92b7\u552e\u90e8\u526f\u4e3b\u7ba1\u5468\u6d69\u6587\u8868\u793a\uff0c\u662f\u6b21\u51fa\u552e\u7684\u7269\u696d\u610f\u5411\u50f9\u7d048200\u842c\u5143\uff0c\u96a8\u7740\u8fd1\u671f\u806f\u5132\u5c40\u5ba3\u5e03\u958b\u59cb\u6e1b\u606f\uff1b\u52a0\u4e0a\u653f\u5e9c\u6700\u65b0\u767c\u8868\u7684\u300a\u65bd\u653f\u5831\u544a\u300b\uff0c\u91d1\u7ba1\u5c40\u5c07\u653e\u5bec\u975e\u4f4f\u5b85\u7269\u696d\u7684\u6309\u63ed\u8cb8\u6b3e\u689d\u4ef6\uff0c\u5728\u773e\u591a\u5229\u597d\u689d\u4ef6\u4e0b\uff0c\u76f8\u4fe1\u6b64\u7269\u696d\u7d55\u5c0d\u9069\u5408\u8cb7\u5bb6\u4f5c\u81ea\u7528\u6216\u6295\u8cc7\u7528\u9014\u3002</p>\n<p>\u7269\u696d\u4eab\u6709\u958b\u63da\u666f\u81f4\uff0c\u6a13\u5c64\u9ad8\u5ea6\u7d0411\u544e\uff0c\u6a13\u9762\u8ca0\u91cd\u7d04\u6bcf\u65b9\u544e150\u78c5\u3002\u7269\u696d\u9130\u8fd1\u6709\u591a\u5ea7\u8fd1\u5e74\u843d\u6210\u4f4f\u5b85\u7269\u696d\u53ca\u5927\u578b\u5546\u5834\uff0c\u98f2\u98df\u53ca\u793e\u5340\u914d\u5957\u5b8c\u5584\uff1b\u52a0\u4e0a\u53d7\u60e0\u65bc\u672a\u4f86\u6cb9\u5858\u7063\u9f90\u5927\u7684\u5546\u4f4f\u767c\u5c55\u9805\u76ee\u3002\u9664\u4e86\u8ddd\u96e2\u6cb9\u5858\u6e2f\u9435\u7ad9\u53ea\u97004\u5206\u9418\u6b65\u7a0b\uff0c\u9644\u8fd1\u4ea6\u8a2d\u6709\u6cb9\u5858\u53ca\u9bc9\u9b5a\u9580\u90a8\u5df4\u58eb\u7e3d\u7ad9\uff0c\u4ee5\u53ca\u4e09\u5bb6\u6751\u6e21\u8f2a\u78bc\u982d\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3909579/%E8%90%AC%E5%B9%B4%E5%B7%A5%E6%A5%AD%E5%A4%A7%E5%BB%88%E5%85%A8%E5%B1%A4%E6%84%8F%E5%90%91%E5%83%B98200%E8%90%AC"}, {"title": "\u3010\u65b0\u80a1\u8ffd\u8e64\u3011\u6052\u745e\u91ab\u85e5\u50b3\u8003\u616e\u9999\u6e2f\u7b2c\u4e8c\u4e0a\u5e02", "description": "<p>\u5916\u96fb\u5f15\u8ff0\u77e5\u60c5\u4eba\u58eb\u900f\u9732\uff0c\u6c5f\u8607\u6052<span style=\"font-size-ignore:13pt;\">\u745e\u91ab\u85e5\u6b63\u8003\u616e\u5728\u9999\u6e2f\u9032</span><span style=\"font-size-ignore:13pt;\">\u884c\u7b2c\u4e8c\u4e0a\u5e02\uff0c\u6700\u5feb\u53ef\u80fd\u660e\u5e74\u9032\u884c\u3002</span></p>\n<p>\u77e5\u60c5\u4eba\u58eb\u7a31\uff0c\u8a72\u516c\u53f8\u6b63\u5728\u8207\u9867\u554f\u6a5f\u69cb\u5546\u8a0e\u6f5b\u5728\u7684\u80a1\u7968\u767c\u884c\uff0c\u9019\u53ef\u80fd\u7c4c\u96c6\u81f3\u5c1120\u5104\u7f8e\u5143(\u7d04156\u5104\u6e2f\u5143)\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u77e5\u60c5\u4eba\u58eb\u88dc\u5145\u7a31\uff0c\u4e8b\u9805\u4ecd\u5728\u8003\u616e\u4e4b\u4e2d\uff0c\u878d\u8cc7\u898f\u6a21\u5c07\u53d6\u6c7a\u65bc\u5e02\u5834\u72c0\u6cc1\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u6052\u745e\u91ab\u85e5\u4e0a\u6d77\u4e0a\u5e02\u7684\u80a1\u7968\u4eca\u5e74\u5df2\u4e0a\u6f3212%\uff0c\u5e02\u503c454\u5104\u7f8e\u5143\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3909719/%E3%80%90%E6%96%B0%E8%82%A1%E8%BF%BD%E8%B9%A4%E3%80%91%E6%81%92%E7%91%9E%E9%86%AB%E8%97%A5%E5%82%B3%E8%80%83%E6%85%AE%E9%A6%99%E6%B8%AF%E7%AC%AC%E4%BA%8C%E4%B8%8A%E5%B8%82"}, {"title": "\u5947\u745e\u50b3\u5df2\u6311\u9078\u6295\u884c\u70ba\u6c7d\u8eca\u5b50\u516c\u53f8\u5b89\u6392\u9999\u6e2f\u4e0a\u5e02\u4e8b\u5b9c ", "description": "<p>\u5916\u96fb\u5f15\u8ff0\u77e5\u60c5\u4eba\u58eb\u7a31\uff0c\u5947\u745e\u63a7\u80a1\u96c6\u5718\u5df2\u9078\u64c7\u4e2d\u91d1\u516c\u53f8\u3001\u5ee3\u767c\u8b49\u5238\u548c\u83ef\u6cf0\u570b\u969b\u8ca0\u8cac\u5b89\u6392\u65d7\u4e0b\u6c7d\u8eca\u5b50\u516c\u53f8\u6f5b\u5728\u4e0a\u5e02\u4e8b\u5b9c\u3002</p>\n<p>\u77e5\u60c5\u4eba\u58eb\u7a31\uff0c\u5947\u745e\u6c7d\u8eca\u6700\u65e9\u6216\u660e\u5e74\u5728\u9999\u6e2f\u4e0a\u5e02\u3002\u8a72\u516c\u53f8\u53ef\u80fd\u5c0b\u6c42\u5728IPO\u4e2d\u7372\u5f97\u8d85\u904e1000\u5104\u5143\u4eba\u6c11\u5e63\u7684\u4f30\u503c\u3002</p>\n<p>\u77e5\u60c5\u4eba\u58eb\u88dc\u5145\uff0c\u6709\u95dcIPO\u898f\u6a21\u548c\u6642\u9593\u7b49\u7d30\u7bc0\u4ecd\u53ef\u80fd\u6703\u767c\u751f\u8b8a\u5316\u3002\u4ed6\u5011\u8868\u793a\uff0c\u7a0d\u5f8c\u66f4\u591a\u9280\u884c\u53ef\u80fd\u6703\u52a0\u5165\u5176\u4e2d\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3909680/%E5%A5%87%E7%91%9E%E5%82%B3%E5%B7%B2%E6%8C%91%E9%81%B8%E6%8A%95%E8%A1%8C%E7%82%BA%E6%B1%BD%E8%BB%8A%E5%AD%90%E5%85%AC%E5%8F%B8%E5%AE%89%E6%8E%92%E9%A6%99%E6%B8%AF%E4%B8%8A%E5%B8%82%E4%BA%8B%E5%AE%9C+"}]}