u964d12.5%\u81f370\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/stock/article/3844105/%E9%AB%98%E7%9B%9B%E9%97%9C%E6%B3%A8%E5%BF%AB%E6%89%8B%E9%9B%BB%E5%95%86%E6%94%B6%E5%85%A5%E8%A1%A8%E7%8F%BE+%E9%99%8D%E7%9B%AE%E6%A8%99%E5%83%B9%E8%87%B370%E5%85%83"}, {"title": "\u803f\u723d:\u53cd\u6050\u4e0d\u80fd\u6210\u70ba\u5e72\u6d89\u5225\u570b\u5167\u653f\u85c9\u53e3", "description": "<p>\u4e2d\u570b\u5e38\u99d0\u806f\u5408\u570b\u526f\u4ee3\u8868\u803f\u723d\u5728\u5b89\u7406\u6703\u767c\u8a00\u6642\u8868\u793a\uff0c\u53cd\u6050\u4e0d\u61c9\u6210\u70ba\u5927\u570b\u535a\u5f08\u7684\u5de5\u5177\u3001\u5730\u7de3\u653f\u6cbb\u7684\u7c4c\u78bc\uff0c\u66f4\u4e0d\u80fd\u6210\u70ba\u5e72\u6d89\u5225\u570b\u5167\u653f\u7684\u85c9\u53e3\u3002</p>\n<p>\u803f\u723d\u8868\u793a\uff0c\u9762\u5c0d\u8907\u96dc\u56b4\u5cfb\u7684\u53cd\u6050\u5f62\u52e2\uff0c\u5404\u570b\u8981\u79c9\u6301\u5171\u540c\u5b89\u5168\u7406\u5ff5\uff0c\u6452\u68c4\u610f\u8b58\u5f62\u614b\u504f\u898b\uff0c\u675c\u7d55\u300c\u96d9\u91cd\u6a19\u6e96\u300d\u548c\u9078\u64c7\u6027\u53cd\u6050\uff0c\u5207\u5be6\u5c0a\u91cd\u548c\u4fdd\u969c\u6bcf\u500b\u570b\u5bb6\u7684\u5b89\u5168\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u803f\u723d\u6307\u51fa\uff0c\u55ae\u7d14\u4f9d\u9760\u8ecd\u4e8b\u624b\u6bb5\u96e3\u4ee5\u5fb9\u5e95\u6d88\u6ec5\u6050\u6016\u4e3b\u7fa9\uff0c\u5730\u5340\u570b\u5bb6\u5728\u53cd\u6050\u7684\u540c\u6642\uff0c\u61c9\u91cd\u8996\u6d88\u9664\u8ca7\u56f0\u3001\u63d0\u5347\u6559\u80b2\u3001\u64f4\u5927\u5c31\u696d\u3001\u767c\u5c55\u7d93\u6fdf\uff0c\u570b\u969b\u793e\u6703\u61c9\u52a0\u5927\u767c\u5c55\u63f4\u52a9\uff0c\u652f\u6301\u548c\u5e6b\u52a9\u6709\u95dc\u570b\u5bb6\u89e3\u6c7a\u50b5\u52d9\u3001\u878d\u8cc7\u7b49\u96e3\u984c\uff0c\u63d0\u5347\u793e\u6703\u7d93\u6fdf\u53ef\u6301\u7e8c\u767c\u5c55\u80fd\u529b\u3002</span></p>\n<p>\u803f\u723d\u7a31\uff0c\u4e2d\u65b9\u7279\u5225\u547c\u7c72\u570b\u969b\u793e\u6703\u5171\u540c\u52aa\u529b\uff0c\u63a8\u52d5\u52a0\u6c99\u76e1\u5feb\u5be6\u73fe\u505c\u706b\uff0c\u8b93\u5730\u5340\u7dca\u5f35\u5c40\u52e2\u76e1\u5feb\u964d\u6eab\uff0c\u5168\u529b\u9632\u6b62\u885d\u7a81\u5c0d\u6297\u9032\u4e00\u6b65\u5347\u7d1a\uff0c\u9020\u6210\u66f4\u5927\u707d\u96e3\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3844100/%E8%80%BF%E7%88%BD%3A%E5%8F%8D%E6%81%90%E4%B8%8D%E8%83%BD%E6%88%90%E7%82%BA%E5%B9%B2%E6%B6%89%E5%88%A5%E5%9C%8B%E5%85%A7%E6%94%BF%E8%97%89%E5%8F%A3"}, {"title": "\u6162\u75c5\u5171\u6cbb\u8a08\u5283\u64f4\u85e5\u7269\u540d\u55ae \u5e74\u5ea6\u8abf\u6574\u5171\u4ed8\u984d9\u6708\u8d77\u751f\u6548", "description": "<p><span style=\"font-size-ignore:13pt;\">\u91ab\u52d9\u885e\u751f\u5c40\u516c\u5e03\uff0c\u70ba\u76e1\u65e9\u8b58\u5225\u6709\u7cd6\u5c3f\u75c5\u548c\u9ad8\u8840\u58d3\u98a8\u96aa\u4eba\u58eb\u800c\u8a2d\u7684\u300c\u6162\u6027\u75be\u75c5\u5171\u540c\u6cbb\u7406\u5148\u5c0e\u8a08\u5283\u300d\uff0c\u5f9e\u672c\u6708\u8d77\u589e\u52a0\u5176\u57fa\u672c\u85e5\u7269\u540d\u55ae\u6db5\u84cb\u7684\u85e5\u7269\u9805\u76ee\u81f359\u9805\uff0c\u70ba\u53c3\u52a0\u8a08\u5283\u7684\u5bb6\u5ead\u91ab\u751f\u63d0\u4f9b\u66f4\u591a\u85e5\u7269\u9078\u9805\uff0c\u7167\u9867\u8a08\u5283\u53c3\u52a0\u8005\u4e0d\u540c\u7684\u81e8\u5e8a\u7528\u85e5\u9700\u6c42\u3002</span></p>\n<p>\u300c\u6162\u75c5\u5171\u6cbb\u8a08\u5283\u300d\u8a2d\u6709\u57fa\u672c\u85e5\u7269\u540d\u55ae\uff0c\u6db5\u84cb\u6cbb\u7642\u6162\u6027\u75be\u75c5\u7684\u57fa\u672c\u85e5\u7269\uff0c\u4ee5\u53ca\u6cbb\u7642\u5076\u767c\u6027\u75be\u75c5\u7684\u57fa\u672c\u85e5\u7269\u3002\u5728\u653f\u5e9c\u8cc7\u52a9\u4e0b\uff0c\u7372\u8655\u65b9\u540d\u55ae\u6240\u5217\u85e5\u7269\u7684\u53c3\u52a0\u8005\u6bcb\u9808\u652f\u4ed8\u4efb\u4f55\u85e5\u8cbb\u3002\u5728\u6aa2\u8996\u53c3\u52a0\u8005\u7684\u5be6\u969b\u9700\u6c42\u5f8c\uff0c\u653f\u5e9c\u7531\u672c\u6708\u8d77\u5728\u57fa\u672c\u85e5\u7269\u540d\u55ae\u589e\u6dfb16\u9805\u85e5\u7269\uff0c\u5305\u62ec\u6297\u9ad8\u8840\u58d3\u3001\u8abf\u7bc0\u8840\u8102\u3001\u6297\u751f\u7d20\u548c\u6cbb\u7406\u76f8\u95dc\u5065\u5eb7\u554f\u984c\u7684\u85e5\u7269\u3002\u64f4\u5927\u5f8c\u7684\u540d\u55ae\u7531\u6700\u521d\u768443\u9805\u57fa\u672c\u85e5\u7269\u589e\u81f3\u6db5\u84cb59\u9805\u57fa\u672c\u85e5\u7269\uff0c\u4ee4\u5bb6\u5ead\u91ab\u751f\u6709\u66f4\u5927\u5f48\u6027\uff0c\u56e0\u61c9\u53c3\u52a0\u8005\u7684\u81e8\u5e8a\u9700\u6c42\u8655\u65b9\u85e5\u7269\u3002</p>\n<p>\u6b64\u5916\uff0c\u6309\u65e2\u5b9a\u6a5f\u5236\uff0c\u5bb6\u5ead\u91ab\u751f\u6bcf\u5e74\u5747\u53ef\u8abf\u6574\u5176\u5728\u6cbb\u7642\u968e\u6bb5\u6536\u53d6\u7684\u8a3a\u75c7\u5171\u4ed8\u984d\u3002\u5404\u5bb6\u5ead\u91ab\u751f\u5728\u672c\u5e74\u5ea6\u8abf\u6574\u5f8c\u7684\u8a3a\u75c7\u5171\u4ed8\u984d\u6703\u75319\u67081\u65e5\u8d77\u751f\u6548\u3002</p>\n<p>\u73fe\u6642\u53c3\u8207\u8a08\u5283\u7684718\u500b\u670d\u52d9\u9ede\u4e2d\uff0c672\u500b\u5c07\u7dad\u6301\u5176\u6cbb\u7642\u968e\u6bb5\u7684\u8a3a\u75c7\u5171\u4ed8\u984d\u4e0d\u8b8a\uff0c\u53e6\u67098\u500b\u6703\u4e0b\u8abf\u8a3a\u75c7\u5171\u4ed8\u984d\uff0c\u4e0b\u8abf\u5e45\u5ea6\u753150\u81f3350\u5143\u4e0d\u7b49\uff0c\u800c\u9918\u4e0b\u768438\u500b\u670d\u52d9\u9ede\u5247\u6703\u4e0a\u8abf\u8a3a\u75c7\u5171\u4ed8\u984d\uff0c\u4e0a\u8abf\u5e45\u5ea6\u753120\u81f3250\u5143\u4e0d\u7b49\u3002\u6574\u9ad4\u800c\u8a00\uff0c\u75319\u67081\u65e5\u8d77\uff0c\u8a08\u5283\u4e0b\u6709\u4e09\u5206\u4e4b\u4e8c\u7684\u670d\u52d9\u9ede(473\u500b)\u53ea\u6536\u53d6\u653f\u5e9c\u5efa\u8b70\u7684150\u5143\u6216\u4ee5\u4e0b\u7684\u8a3a\u75c7\u5171\u4ed8\u984d\u3002</p>\n<p>\u91ab\u52d9\u885e\u751f\u5c40\u8868\u793a\uff0c\u8a08\u5283\u63a8\u51fa\u4ee5\u4f86\u53cd\u61c9\u826f\u597d\uff0c\u622a\u81f38\u67087\u65e5\uff0c\u5df2\u6709\u7d045.6\u842c\u540d\u5e02\u6c11\u53c3\u52a0\u3002\u5728\u8d85\u904e3.2\u842c\u540d\u5df2\u5b8c\u6210\u7cd6\u5c3f\u75c5\u53ca\u9ad8\u8840\u58d3\u7be9\u67e5\u7684\u53c3\u52a0\u8005\u4e2d\uff0c\u7d04\u56db\u6210\u88ab\u8a3a\u65b7\u70ba\u8840\u7cd6\u504f\u9ad8\uff0c\u6216\u60a3\u6709\u7cd6\u5c3f\u75c5\u6216\u9ad8\u8840\u58d3\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3844093/%E6%85%A2%E7%97%85%E5%85%B1%E6%B2%BB%E8%A8%88%E5%8A%83%E6%93%B4%E8%97%A5%E7%89%A9%E5%90%8D%E5%96%AE+%E5%B9%B4%E5%BA%A6%E8%AA%BF%E6%95%B4%E5%85%B1%E4%BB%98%E9%A1%8D9%E6%9C%88%E8%B5%B7%E7%94%9F%E6%95%88"}]}