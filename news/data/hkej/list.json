u8981\u5438\u7d0d\u66f4\u591a\u696d\u754c\u7684\u610f\u898b\uff0c\u9032\u4e00\u6b65\u6df1\u5316\u63aa\u65bd\u3002</p>\n<p>\u4ed6\u8868\u793a\uff0c\u300a\u85cd\u5716\u300b\u5f88\u591a\u90e8\u5206\u91cd\u65b0\u64b0\u5beb\uff0c\u6703\u518d\u8207\u6587\u5316\u59d4\u54e1\u6703\u5546\u8a0e\u3002\u6587\u5316\u85dd\u8853\u767c\u5c55\u65b9\u9762\u53ef\u4ee5\u8d70\u5411\u7522\u696d\u5316\uff0c\u53ef\u4ee5\u7528\u5230\u66f4\u591a\u5546\u696d\u53ca\u793e\u6703\u8cc7\u6e90\uff0c\u63a8\u52d5\u85dd\u8853\u767c\u5c55\u3002</p>\n<p>\u81f3\u65bc\u570b\u5bb6\u767c\u5c55\u6210\u5c31\u9928\uff0c\u694a\u6f64\u96c4\u900f\u9732\uff0c\u7d93\u904e\u7d041\u5e74\u6642\u9593\u7814\u7a76\u53ca\u5546\u8a0e\uff0c\u5b89\u6392\u5728\u5317\u90e8\u90fd\u6703\u5340\u5167\u3001\u4e00\u4e9b\u4ea4\u901a\u8f03\u65b9\u4fbf\u7684\u4f4d\u7f6e\uff0c\u6703\u6bd4\u8f03\u5408\u9069\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3907496/%E6%96%BD%E6%94%BF%E5%A0%B1%E5%91%8A%E4%B8%A8%E6%A5%8A%E6%BD%A4%E9%9B%84%3A%E5%95%9F%E5%BE%B7%E9%AB%94%E8%82%B2%E5%9C%92%E8%A6%81%E5%B0%8F%E5%BF%83%E8%99%95%E7%90%86%E4%BA%BA%E6%B5%81%E5%AE%89%E6%8E%92"}, {"title": "\u694a\u6f64\u96c4:\u6703\u89e3\u5256\u8fd1\u65e5\u5169\u96bb\u6b7b\u4ea1\u7334\u5b50\u6aa2\u8996\u6b7b\u56e0", "description": "<p>\u9999\u6e2f\u52d5\u690d\u7269\u516c\u5712\u6628\u65e5\u518d\u6709\u4e00\u96bb\u63a5\u53d7\u9694\u96e2\u89c0\u5bdf\u7684\u677e\u9f20\u7334\u6b7b\u4ea1\uff0c<span style=\"font-size-ignore:13pt;\">\u73fe\u6642\u9084\u6709\u4e00\u96bb\u7334\u5b50\u4ecd\u7136\u63a5\u53d7\u9694\u96e2\u6cbb\u7642\uff0c\u7531\u672c\u670813\u65e5\u81f3\u4eca\u516c\u5712\u517111\u96bb\u7334\u5b50\u6b7b\u4ea1\u3002</span></p>\n<p>\u6587\u5316\u9ad4\u80b2\u53ca\u65c5\u904a\u5c40\u5c40\u9577\u694a\u6f64\u96c4\u5728\u96fb\u53f0\u7bc0\u76ee\u8868\u793a\uff0c\u73fe\u6642\u6b63\u9694\u96e2\u89c0\u5bdf\u7684\u4e00\u96bb\u7334\u5b50\uff0c<span style=\"font-size-ignore:13pt;\">\u8868\u73fe\u8207\u5e73\u65e5\u6709\u9ede\u7570\u5e38\uff0c\u60c5\u6cc1\u6709\u4e9b\u53cd\u8986\uff0c\u6b63\u5728\u63a5\u53d7\u91ab\u7642\u7a0b\u5e8f\u3002</span></p>\n<p>\u694a\u6f64\u96c4\u7a31\uff0c\u672c\u670813\u65e5\u67098\u96bb\u7334\u5b50\u6b7b\u4ea1\uff0c\u7576\u5c40\u7acb\u5373\u63a1\u53d6\u884c\u52d5\uff0c\u9694\u96e2\u5169\u96bb\u7334\u5b50\uff0c\u4e26\u95dc\u9589\u6709\u95dc\u5712\u5340\uff0c\u672c\u670816\u65e5\u518d\u591a\u5169\u96bb\u7334\u5b50\u9700\u8981\u9694\u96e2\u3002\u5230\u8fd1\u5e7e\u65e5\uff0c\u518d\u591a\u5169\u96bb\u7334\u5b50\u6b7b\u4ea1\uff0c\u7576\u5c40\u6703\u9032\u884c\u89e3\u5256\u7b49\uff0c\u4ee5\u6aa2\u8996\u5169\u96bb\u7334\u5b50\u7684\u6b7b\u56e0\u662f\u5426\u611f\u67d3\u985e\u9f3b\u75bd\u3002</p>\n<p>\u4ed6\u53c8\u5e0c\u671b\uff0c\u904e\u4e00\u6bb5\u6642\u9593\u898b\u5230\u7334\u5b50\u60c5\u6cc1\u56de\u5fa9\u6b63\u5e38\u5f8c\uff0c\u6703\u8003\u616e\u91cd\u958b\u6709\u95dc\u5712\u5340\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3907492/%E6%A5%8A%E6%BD%A4%E9%9B%84%3A%E6%9C%83%E8%A7%A3%E5%89%96%E8%BF%91%E6%97%A5%E5%85%A9%E9%9A%BB%E6%AD%BB%E4%BA%A1%E7%8C%B4%E5%AD%90%E6%AA%A2%E8%A6%96%E6%AD%BB%E5%9B%A0"}, {"title": "\u3010\u7570\u52d5\u80a1\u3011\u4e0a\u6d77\u96fb\u6c23\u66fe\u98c625% \u65a531\u5104\u4eba\u5e63\u6ce8\u5165\u6bcd\u4f01\u5de5\u696d\u6a5f\u68b0\u4eba\u696d\u52d9", "description": "<p>\u4e0a\u6d77\u96fb\u6c23(<a target='_blank' href='https://stock360.hkej.com/quotePlus/02727' >02727</a>)\u7372\u6ce8\u5165\u6bcd\u4f01\u5de5\u696d\u6a5f\u68b0\u4eba\u696d\u52d9\uff0c\u80a1\u50f9\u4eca\u65e9\u9ad8\u958b\u8fd1\u4e00\u6210\u534a\u5f8c\uff0c\u66fe\u534725.3%\u58312.28\u5143\uff0c\u6700\u65b0\u4ecd\u5347\u5169\u6210\u583120.3%\u58312.19\u5143\uff0c\u6210\u4ea42.38\u5104\u5143\u3002</p>\n<p>\u96c6\u5718\u4e0a\u5468\u4e94\u516c\u5e03\uff0c\u4ee5\u7d0430.8\u5104\u5143\u4eba\u5e63\u5411\u63a7\u80a1\u80a1\u6771\u96fb\u6c23\u63a7\u80a1\u6536\u8cfc\u6301\u6709\u767c\u90a3\u79d1\u6a5f\u5668\u4eba50%\u80a1\u6b0a\u7684\u5be7\u7b19\u5be6\u696d100%\u80a1\u6b0a\uff0c\u4ea4\u6613\u8cc7\u91d1\u4f86\u81ea\u65bc\u516c\u53f8\u81ea\u6709\u8cc7\u91d1\u548c\u4f75\u8cfc\u8cb8\u6b3e\u3002\u6709\u95dc\u4ea4\u6613\u69cb\u6210\u95dc\u9023\u4ea4\u6613\uff0c\u9808\u80a1\u6771\u6279\u51c6\u3002</p>\n<p>\u516c\u53f8\u6307\uff0c\u5be7\u7b19\u5be6\u696d\u70ba\u5de5\u696d\u6a5f\u5668\u4eba\u76f8\u95dc\u696d\u52d9\u6301\u80a1\u7ba1\u7406\u5e73\u53f0\uff0c\u6301\u6709\u767c\u90a3\u79d1\u6a5f\u5668\u4eba50%\u80a1\u6b0a\u548c\u767c\u90a3\u79d1\u570b\u8cbf25%\u80a1\u6b0a\uff0c\u4e0a\u534a\u5e74\u6309\u6240\u6301\u767c\u90a3\u79d1\u6a5f\u5668\u4eba\u80a1\u6b0a\u7684\u6295\u8cc7\u6536\u76ca\u7d041.78\u5104\u5143\u4eba\u5e63\u3002\u81f3\u65bc\u767c\u90a3\u79d1\u6a5f\u5668\u4eba\u5411\u88fd\u9020\u696d\u7528\u6236\u92b7\u552e\u5de5\u696d\u6a5f\u5668\u4eba\u3001\u667a\u80fd\u6a5f\u68b0\u53ca\u81ea\u52d5\u5316\u6210\u5957\u751f\u7522\u7cfb\u7d71\u7b49\uff0c\u4e0a\u534a\u5e74\u7d14\u52293.56\u5104\u5143\u4eba\u5e63\uff0c\u71df\u696d\u6536\u516530.7\u5104\u5143\u4eba\u5e63\uff0c\u800c\u53bb\u5e74\u7d14\u5229\u7d0410.5\u5104\u5143\u4eba\u5e63\uff0c\u8dcc21%\uff0c\u56e0\u90e8\u5206\u7522\u54c1\u63a1\u53d6\u5177\u5099\u5e02\u5834\u7af6\u722d\u529b\u7684\u5b9a\u50f9\u548c\u5e02\u5834\u958b\u767c\u7b56\u7565\uff0c\u6574\u9ad4\u76c8\u5229\u6c34\u5e73\u8f032022\u5e74\u5ea6\u6709\u6240\u4e0b\u6ed1\u3002</p>\n<p>\u8a72\u96c6\u5718\u6307\uff0c\u9644\u5c6c\u81ea\u52d5\u5316\u96c6\u5718\u5c07\u65bc\u6536\u8cfc\u5f8c\u5728\u5e02\u5834\u958b\u62d3\u3001\u7522\u54c1\u7814\u767c\u7b49\u8207\u767c\u90a3\u79d1\u6a5f\u5668\u4eba\u9032\u4e00\u6b65\u5354\u540c\uff0c\u800c\u5be7\u7b19\u5be6\u696d\u4e0a\u534a\u5e74\u6de8\u5229\u70ba1.63\u5104\u5143\u4eba\u5e63\uff0c\u4f54\u8a72\u96c6\u5718\u540c\u671f\u6de8\u5229\u6f64\u6bd4\u4f8b27.08%\uff0c\u63d0\u5347\u76c8\u5229\u6c34\u5e73\u3002\u81f3\u65bc\u6536\u8cfc\u4ea4\u6613\u8cc7\u91d1\u4f86\u81ea\u65bc\u81ea\u6709\u8cc7\u91d1\u548c\u4f75\u8cfc\u8cb8\u6b3e\uff0c\u4e0d\u4f7f\u7528\u52df\u96c6\u8cc7\u91d1\u3002</p>\n<p><span