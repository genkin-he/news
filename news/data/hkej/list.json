u589e\u503c\u7b56\u7565\u3002\u898f\u6a21\u8f03\u5c0f\u7684\u8cc7\u7522\u4e5f\u7372\u5f97\u9752\u775e\uff0c\u56e0\u70ba\u51fa\u552e\u7d66\u8f03\u5927\u7684\u6295\u8cc7\u8005\u6bd4\u8f03\u5bb9\u6613\uff0c\u4e26\u4e14\u4e26\u4e0d\u9019\u9ebc\u4f9d\u8cf4IPO\u5e02\u5834\u3002\u9ad8\u76db\u4e5f\u770b\u5230\u8ca1\u5bcc\u7ba1\u7406\u6a5f\u69cb\u548c\u9ad8\u6de8\u503c\u500b\u4eba\u6295\u8cc7\u8005\u900f\u904e\u534a\u6d41\u52d5\u7d50\u69cb\u5c0d\u4e2d\u7aef\u5e02\u5834\u57fa\u790e\u8a2d\u65bd\u6295\u8cc7\u7d44\u5408\u589e\u52a0\u914d\u7f6e\u3002</p>\n<p>\u8abf\u67e5\u986f\u793a\uff0c\u5168\u7403\u79c1\u52df\u4fe1\u8cb8\u914d\u7f6e\u4e0d\u65b7\u589e\u52a0\u3002\u5728\u4e9e\u592a\u5730\u5340\uff0c\u4e5f\u770b\u5230\u6a5f\u69cb\u6295\u8cc7\u8005\u5c07\u5176\u79c1\u52df\u4fe1\u8cb8\u914d\u7f6e\u591a\u5143\u5316\u7684\u8da8\u52e2\u3002\u6295\u8cc7\u8005\u4e0d\u518d\u53ea\u5c08\u6ce8\u65bc\u76f4\u63a5\u8cb8\u6b3e\uff0c\u800c\u662f\u64f4\u5927\u5c0b\u627e\u5728\u79c1\u52df\u6295\u8cc7\u7b49\u7d1a\u4fe1\u8cb8\u3001\u8cc7\u7522\u878d\u8cc7\u3001\u53ef\u6301\u7e8c\u4fe1\u8cb8\u548c\u6df7\u5408\u89e3\u6c7a\u65b9\u6848\u7684\u6a5f\u9047\u3002\u4ed6\u5011\u4e5f\u6b63\u5728\u8861\u91cf\u5176\u516c\u958b\u548c\u79c1\u52df\u5e02\u5834\u914d\u7f6e\u7684\u4fe1\u7528\u98a8\u96aa\uff0c\u4ee5\u6c7a\u5b9a\u9069\u7576\u7684\u975e\u6d41\u52d5\u6027\u7a0b\u5ea6\u3002</p>\n<p>\u96d6\u7136\u8abf\u67e5\u986f\u793a\u7f8e\u6d32\u7684\u6709\u9650\u5408\u5925\u4eba\u5c0d\u79c1\u52df\u80a1\u6b0a\u8d85\u914d\uff0c\u4f46\u4e9e\u592a\u5730\u534048%\u7684\u53d7\u8a2a\u8005\u8a8d\u70ba\u4ed6\u5011\u7684\u914d\u7f6e\u4e0d\u8db3\u3002\u4e9e\u592a\u5340\u6295\u8cc7\u8005\u8868\u73fe\u4e86\u589e\u52a0\u6295\u8cc7\u7684\u5f37\u70c8\u610f\u9858\uff0c\u7279\u5225\u662f\u900f\u904e\u5171\u540c\u6295\u8cc7\u6216\u4e8c\u7d1a\u5e02\u5834\u3002</p>\n<p>\u53ef\u6301\u7e8c\u6027\u6295\u8cc7\u662f\u4e9e\u592a\u5730\u5340\u7684\u91cd\u8981\u7126\u9ede\uff0c44%\u7684\u4e9e\u592a\u5340\u53d7\u8a2a\u8005\u4f9d\u9760\u8ca1\u52d9\u548c\u5229\u76ca\u76f8\u95dc\u8005\u6307\u6a19\u7684\u7d50\u5408\u4f86\u8861\u91cf\u4ed6\u5011\u7684\u76ee\u6a19\u3002\u4e9e\u592a\u5340\u5e02\u5834\u57fa\u672c\u4e0a\u5df2\u7d93\u6b77\u4e86\u5021\u5c0e\u53ef\u6301\u7e8c\u6027\u6295\u8cc7\u597d\u8655\u7684\u968e\u6bb5\uff0c\u8abf\u67e5\u986f\u793a\u53ea\u670915%\u7684\u4e9e\u592a\u5340\u53d7\u8a2a\u8005\u6c92\u6709\u53ef\u6301\u7e8c\u6027\u6295\u8cc7\u76ee\u6a19\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3907933/%E9%AB%98%E7%9B%9B%3A%E4%BA%9E%E6%B4%B2%E7%A7%81%E5%8B%9F%E5%B8%82%E5%A0%B4%E6%A8%82%E8%A7%80%E5%80%A9%E7%B7%92%E5%8D%87%E6%BA%AB"}]}