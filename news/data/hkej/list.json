cc7\u300d\u5747\u53ef\u7372\u5f97\u8c41\u514d\u7684\u8cc7\u683c\uff0c\u7a81\u986f\u8b49\u66f8\u5168\u9762\u7b26\u5408\u91d1\u7ba1\u5c40\u7684\u80fd\u529b\u6a19\u6e96\u3002</p>\n<p>CFA\u5354\u6703\u7b56\u7565\u5408\u4f5c\u5925\u4f34\u9ad8\u7d1a\u7e3d\u76e3\u674e\u65e5\u660c\u8868\u793a\uff0c\u300c\u6c23\u5019\u98a8\u96aa\u3001\u4f30\u503c\u8207\u6295\u8cc7\u8b49\u66f8\u300d\u7372\u5f97\u91d1\u7ba1\u5c40\u300c\u7da0\u8272\u548c\u53ef\u6301\u7e8c\u91d1\u878d\u5c08\u696d\u8cc7\u6b77\u67b6\u69cb\u300d\u7684\u8a8d\u53ef\uff0c\u986f\u793a\u5354\u6703\u81f4\u529b\u63a8\u52d5\u5353\u8d8a\u7684\u53ef\u6301\u7e8c\u91d1\u878d\u6559\u80b2\u3001\u4e26\u652f\u6301\u91d1\u878d\u884c\u696d\u9081\u5411\u53ef\u6301\u7e8c\u767c\u5c55\u7684\u6c7a\u5fc3\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3952508/CFA%E5%8D%94%E6%9C%83%E6%B0%A3%E5%80%99%E9%A2%A8%E9%9A%AA%E3%80%81%E4%BC%B0%E5%80%BC%E8%88%87%E6%8A%95%E8%B3%87%E8%AD%89%E6%9B%B8%E7%8D%B2%E9%87%91%E7%AE%A1%E5%B1%80%E5%B0%88%E6%A5%AD%E8%B3%87%E6%AD%B7%E6%9E%B6%E6%A7%8B%E8%AA%8D%E8%AD%89"}, {"title": "\u8a31\u6b63\u5b87\u6664\u5370\u5c3c\u91d1\u878d\u5b98\u54e1\u548c\u696d\u754c\u9818\u8896 \u52a0\u5f37\u5169\u5730\u5408\u4f5c", "description": "<p>\u8ca1\u7d93\u4e8b\u52d9\u53ca\u5eab\u52d9\u5c40\u5c40\u9577\u8a31\u6b63\u5b87\u4eca\u65e5\u5728\u5370\u5c3c\u96c5\u52a0\u9054\u5c55\u958b\u8a2a\u554f\u884c\u7a0b\uff0c\u8207\u7576\u5730\u91d1\u878d\u5b98\u54e1\u548c\u696d\u754c\u9818\u8896\u6703\u9762\uff0c\u52a0\u5f37\u9999\u6e2f\u8207\u5370\u5c3c\u7684\u91d1\u878d\u5408\u4f5c\u3002</p>\n<p>\u5728\u8207\u5370\u5c3c\u570b\u6709\u4f01\u696d\u90e8\u526f\u90e8\u9577Dony Oskaria\u6703\u9762\u6642\uff0c\u8a31\u6b63\u5b87\u5411\u4ed6\u4ecb\u7d39\u65b0\u4e00\u4efd\u300a\u65bd\u653f\u5831\u544a\u300b\u4e2d\u591a\u9805\u6709\u95dc\u767c\u6398\u65b0\u589e\u9577\u9ede\u53ca\u6df1\u5316\u8207\u6771\u76df\u5730\u5340\u806f\u7e6b\u7684\u63aa\u65bd\u3002\u8a31\u6b63\u5b87\u9f13\u52f5\u5370\u5c3c\u7684\u570b\u6709\u4f01\u696d\u53ca\u512a\u8cea\u5275\u65b0\u578b\u4f01\u696d\u5584\u7528\u9999\u6e2f\u570b\u969b\u5316\u7684\u878d\u8cc7\u5e73\u53f0\u58ef\u5927\u548c\u767c\u5c55\u696d\u52d9\u3002</p>\n<p>\u8a31\u6b63\u5b87\u4ea6\u5230\u8a2a\u5370\u5c3c\u8b49\u5238\u4ea4\u6613\u6240\uff0c\u8207\u4ea4\u6613\u6240\u7e3d\u7d93\u7406Iman Rachman\u6703\u9762\u3002\u5370\u5c3c\u8b49\u5238\u4ea4\u6613\u6240\u81ea\u53bb\u5e7411\u6708\u8d77\u7372\u7d0d\u5165\u6e2f\u4ea4\u6240(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00388' >00388</a>)\u7684\u8a8d\u53ef\u8b49\u5238\u4ea4\u6613\u6240\u5217\u8868\u3002\u8a31\u6b63\u5b87\u7279\u5225\u63d0\u5230\uff0c\u5728\u6e2f\u4ea4\u6240\u4e0a\u5dff\u7684\u516c\u53f8\u6700\u8fd1\u7e3d\u5dff\u503c\u9054\u7d0435\u842c\u5104\u5143\uff0c\u4f4d\u5217\u5168\u7403\u7b2c\u4e03\u3001\u4e9e\u6d32\u7b2c\u56db\u3002\u8a31\u6b63\u5b87\u9f13\u52f5\u5728\u5370\u5c3c\u8b49\u5238\u4ea4\u6613\u6240\u4e3b\u677f\u5e02\u5834\u4e0a\u5e02\u7684\u5370\u5c3c\u516c\u53f8\u4f86\u6e2f\u5c0b\u6c42\u7b2c\u4e8c\u4e0a\u5e02\uff0c\u900f\u904e\u9999\u6e2f\u84ec\u52c3\u7684\u80a1\u7968\u5e02\u5834\u806f\u7e6b\u5340\u5167\u548c\u5168\u7403\u7684\u6295\u8cc7\u8005\u3002\u4e8c\u4eba\u9084\u8ac7\u53ca\u7da0\u8272\u91d1\u878d\u3002</p>\n<p>\u8a31\u6b63\u5b87\u4ea6\u8207\u5370\u5ea6\u5c3c\u897f\u4e9e\u4e2d\u83ef\u7e3d\u5546\u6703\u7e3d\u4e3b\u5e2d\u5f35\u9326\u96c4\u3001\u4ee5\u53ca\u5370\u5c3c\u50f1\u4e3b\u5354\u6703\u4e3b\u5e2dShinta Widjaja Kamdani\u6703\u9762\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3952505/%E8%A8%B1%E6%AD%A3%E5%AE%87%E6%99%A4%E5%8D%B0%E5%B0%BC%E9%87%91%E8%9E%8D%E5%AE%98%E5%93%A1%E5%92%8C%E6%A5%AD%E7%95%8C%E9%A0%98%E8%A2%96+%E5%8A%A0%E5%BC%B7%E5%85%A9%E5%9C%B0%E5%90%88%E4%BD%9C"}]}