f0c\u9ece\u667a\u82f1\u7a31\u662f\uff0c\u4f46\u6709\u4e9b\u539f\u5247\u56e0\u70ba\u300a\u570b\u5b89\u6cd5\u300b\u800c\u7121\u6cd5\u5be6\u884c\u3002\u81f3\u65bc\u300c\u6709\u8207\u570b\u5b89\u4ea4\u624b\u7d93\u9a57\u540c\u4e8b\u300d\u662f\u8ab0\uff0c\u9ece\u667a\u82f1\u7a31\u4e0d\u8a18\u5f97\uff0c\u4ea6\u4e0d\u77e5\u9053\u570b\u5b89\u7576\u6642\u6709\u5426\u63a5\u89f8\u300a\u860b\u679c\u300b\u54e1\u5de5\u3002</p>\n<p>\u8faf\u65b9\u53c8\u554f\u9ece\u667a\u82f1\u6709\u5426\u5728\u300a\u570b\u5b89\u6cd5\u300b\u5f8c\u522a\u9664\u4efb\u4f55\u96fb\u90f5\u3001Signal\u3001WhatsApp\u8a0a\u606f\u3002\u9ece\u667a\u82f1\u7a31\u6c92\u6709\uff0c\u56e0\u70ba\u4e0d\u89ba\u5f97\u81ea\u5df1\u505a\u4e86\u9055\u6cd5\u4e8b\u60c5\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3952220/%E9%BB%8E%E6%99%BA%E8%8B%B1%E7%A8%B1%E5%88%B6%E8%A3%81%E5%B1%AC%E6%AD%A3%E7%BE%A9%E5%8F%8A%E6%9C%89%E6%95%88+%E6%83%9F%E5%90%A6%E8%AA%8D%E9%BC%93%E5%8B%B5"}, {"title": "\u7164\u6c23\u9023\u7e8c\u5169\u5e74\u7372\u9999\u6e2f\u7fa9\u5de5\u734e\u2014\u5091\u51fa\u4f01\u696d\u734e", "description": "<p>\u4e2d\u83ef\u7164\u6c23(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00003' >00003</a>)\u9023\u7e8c\u5169\u5e74\u7372\u7531\u6c11\u653f\u53ca\u9752\u5e74\u4e8b\u52d9\u5c40\u8207\u7fa9\u52d9\u5de5\u4f5c\u767c\u5c55\u5c40\u5408\u8fa6\u7684\u300c\u9999\u6e2f\u7fa9\u5de5\u734e\u2014\u5091\u51fa\u4f01\u696d\u734e\u3002</p>\n<p>\u7164\u6c23\u53bb\u5e74\u8209\u8fa8\u591a\u9805\u5275\u65b0\u7fa9\u5de5\u6d3b\u52d5\uff0c\u5305\u62ec\u5925\u62cd\u6a02\u9f61\u793e\u4f01\u5408\u8fa6\u300c\u6d41\u52d5\u4e94\u611f\u5927\u8336\u6a13\u300d\u6d3b\u52d5\uff0c\u628a\u9662\u820d\u5e03\u7f6e\u6210\u61f7\u820a\u8336\u6a13\uff0c\u7fa9\u5de5\u5316\u8eab\u8336\u6a13\u4f19\u8a18\uff0c\u8b93\u6709\u541e\u56a5\u56f0\u96e3\u7684\u9577\u8005\u91cd\u62fe\u98f2\u8336\u6a02\u8da3\u3002\u53e6\u63a8\u51fa\u300c\u7164\u6c23\u7da0\u706b\u7130\u80fd\u6e90\u79d1\u5b78\u5bb6\u57f9\u80b2\u8a08\u5283\u300d\uff0c\u5230\u6821\u8b1b\u89e3\u672a\u4f86\u80fd\u6e90\u3001\u6c23\u5019\u8b8a\u5316\u3001\u79d1\u6280\u8207\u5275\u65b0\u53ca\u71c3\u6c23\u5b89\u5168\u7b49\u77e5\u8b58\uff0c\u63a8\u52d5\u74b0\u4fdd\u6559\u80b2\u7b49\u3002</p>\n<p>\u4eca\u5e74\u662f\u7164\u6c23\u6eab\u99a8\u7fa9\u5de5\u968a\u6210\u7acb25\u5468\u5e74\uff0c\u96c6\u5718\u74b0\u5883\u3001\u793e\u6703\u53ca\u7ba1\u6cbb\u7e3d\u76e3/\u96c6\u5718\u4f01\u696d\u4e8b\u52d9\u7e3d\u76e3\u674e\u5065\u660e\u6307\uff0c\u9664\u6301\u7e8c\u8209\u8fa6\u4e00\u4e9b\u5982\u63a2\u8a2a\u9001\u6696\u7b49\u50b3\u7d71\u7fa9\u5de5\u6d3b\u52d5\uff0c\u4ea6\u95dc\u6ce8\u793e\u6703\u4e0a\u88ab\u5ffd\u7565\u793e\u7fa4\uff0c\u5982\u65bc\u7aef\u5348\u7bc0\u8209\u8fa6\u5305\u7cc9\u6d3b\u52d5\uff0c\u7531\u7fa9\u5de5\u968a\u966a\u4f34\u300c\u7559\u6e2f\u9577\u8005\u300d\u4e00\u8d77\u5305\u7cc9\uff0c\u4fc3\u9032\u4ed6\u5011\u7684\u5e78\u798f\u611f\uff1b\u53c8\u8209\u8fa6\u8996\u969c\u4eba\u58eb\u70f9\u98ea\u6bd4\u8cfd\uff0c\u8b93\u4ed6\u5011\u767c\u63ee\u5eda\u85dd\u7b49\u3002\u70ba\u6176\u795d\u7fa9\u5de5\u968a\u6210\u7acb25\u5468\u5e74\uff0c\u7279\u5225\u9080\u8acb200\u4f4d\u9577\u8005\u53ca\u5176\u7167\u9867\u8005\u53c3\u8207\u300c\u6d41\u52d5\u4e94\u611f\u5927\u8336\u6a13\u300d\u6d3b\u52d5\u3002</p>\n<p>\u7164\u6c23\u6e29\u99a8\u7fa9\u5de5\u968a\u7e3d\u53d7\u60e0\u4eba\u6b21\u5df2\u8d85\u904e850\u842c\uff0c\u670d\u52d9\u7e3d\u6642\u6578\u903e100\u842c\u5c0f\u6642\uff0c\u4eca\u5e74\u5171\u9001\u51fa\u8d85\u904e32\u842c\u500b\u611b\u5fc3\u6708\u9905\uff0c\u903e150\u9593\u6148\u5584\u6a5f\u69cb\u53ca\u5718\u9ad4\u53d7\u60e0\uff0c\u300c\u6148\u5584\u8fb2\u8015\u6a02\u300d\u6d3b\u52d5\u4eca\u5e74\u4ea6\u5df2\u9001\u51fa\u8d85\u904e4000\u65a4\u8fb2\u4f5c\u7269\u4e88\u6148\u5584\u6a5f\u69cb\uff0c\u7d04\u67098000\u4eba\u53d7\u60e0\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3952214/%E7%85%A4%E6%B0%A3%E9%80%A3%E7%BA%8C%E5%85%A9%E5%B9%B4%E7%8D%B2%E9%A6%99%E6%B8%AF%E7%BE%A9%E5%B7%A5%E7%8D%8E%