ad8\u6548\u3001\u554f\u8cac\u958b\u660e\uff1b\u4ea6\u8b9a\u63da\u516c\u7f72\u5728\u570b\u969b\u7533\u8a34\u5c08\u54e1\u5354\u6703\u548c\u4e9e\u6d32\u7533\u8a34\u5c08\u54e1\u5354\u6703\u7b49\u6a5f\u69cb\u7a4d\u6975\u53c3\u8207\u570b\u969b\u4e8b\u52d9\uff0c\u65bc\u4e16\u754c\u821e\u53f0\u4e0a\u8aaa\u597d\u9999\u6e2f\u5728\uff62\u4e00\u570b\u5169\u5236\uff63\u4e0b\u7684\u597d\u6545\u4e8b\u3002</p>\n<p>\u516c\u7f72\u6210\u7acb35\u5468\u5e74\u6176\u795d\u5927\u6703\u7372\u5f97\u71b1\u70c8\u652f\u6301\uff0c\u8fd1230\u540d\u5609\u8cd3\u8e34\u8e8d\u51fa\u5e2d\u6176\u795d\u6d3b\u52d5\uff0c\u7576\u4e2d\u9664\u4e86\u7d04140\u540d\u4f86\u81ea\u516d\u5927\u6d32\u7d0440\u500b\u570b\u5bb6\u53ca\u5730\u5340\u7684\u7533\u8a34\u5c08\u54e1\u3001\u9ad8\u5c64\u96a8\u54e1\u548c\u570b\u969b\u7d44\u7e54\u7684\u9ad8\u5c64\u4ee3\u8868\u7b49\u6d77\u5916\u53ca\u5167\u5730\u53c3\u52a0\u8005\u5916\uff0c\u4ea6\u5305\u62ec\u591a\u540d\u884c\u653f\u6703\u8b70\u6210\u54e1\u3001\u7acb\u6cd5\u6703\u8b70\u54e1\u3001\u9ad8\u7d1a\u653f\u5e9c\u5b98\u54e1\u3001\u5546\u6703\u4e3b\u5e2d\u3001\u672c\u5730\u5c08\u696d\u548c\u5b78\u8853\u754c\u4eba\u58eb\u7b49\u3002</p>\n<p>\u5728\u9ad8\u5cf0\u8ad6\u58c7\u66a8\u516c\u7f72\u6210\u7acb35\u5468\u5e74\u6176\u795d\u5927\u6703\u7fcc\u65e5\uff0c\u660e\u5929\u6d77\u5916\u5609\u8cd3\u5c07\u53c3\u8207\u7531\u516c\u7f72\u5b89\u6392\u7684\u4e00\u7cfb\u5217\u7cbe\u5f69\u6587\u5316\u89c0\u5149\u6d3b\u52d5\uff0c\u5305\u62ec\u53c3\u89c0\u7acb\u6cd5\u6703\u53ca\u5c55\u57ce\u9928\u3001\u904a\u89bd\u9999\u6e2f\u5730\u8cea\u516c\u5712\u3001\u4e2d\u74b0\u534a\u5c71\u65b0\u820a\u57ce\u5340\u6f2b\u6b65\u3001\u8a60\u6625\u62f3\u935b\u934a\u9ad4\u9a57\u3001\u9999\u6e2f\u96fb\u8eca\u89c0\u5149\u4e4b\u65c5\u4ee5\u53ca\u7e7d\u7d1b\u8cfd\u99ac\u591c\uff0c\u85c9\u6b64\u89aa\u8eab\u9ad4\u9a57\u548c\u611f\u53d7\u9999\u6e2f\u9019\u9846\u6771\u65b9\u4e4b\u73e0\u7684\u7368\u7279\u9b45\u529b\uff0c\u4ee5\u53ca\u52d5\u611f\u4e4b\u90fd\u7684\u8d85\u51e1\u6d3b\u529b\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3945388/%E6%9D%8E%E5%AE%B6%E8%B6%85%3A%E7%94%B3%E8%A8%B4%E5%B0%88%E5%93%A1%E5%85%AC%E7%BD%B2%E6%96%BC%E4%B8%96%E7%95%8C%E8%88%9E%E5%8F%B0%E8%AA%AA%E5%A5%BD%E9%A6%99%E6%B8%AF%E5%9C%A8%E4%B8%80%E5%9C%8B%E5%85%A9%E5%88%B6%E4%B8%8B%E5%A5%BD%E6%95%85%E4%BA%8B"}, {"title": "\u653f\u5e9c\u8207\u4e2d\u570b\u79d1\u5354\u7c3d\u5408\u4f5c\u6846\u67b6\u5354\u8b70", "description": "<p>\u7279\u5340\u653f\u5e9c\u8207\u4e2d\u570b\u79d1\u5b78\u6280\u8853\u5354\u6703\u7c3d\u7f72\u300a\u95dc\u65bc\u652f\u6301\u9999\u6e2f\u6253\u9020\u570b\u969b\u9ad8\u7aef\u79d1\u6280\u4eba\u624d\u96c6\u805a\u9ad8\u5730 \u5171\u540c\u670d\u52d9\u9ad8\u6c34\u5e73\u79d1\u6280\u81ea\u7acb\u81ea\u5f37\u7684\u5408\u4f5c\u6846\u67b6\u5354\u8b70\u300b\u3002<span style=\"font-size-ignore:13pt;\">\u884c\u653f\u9577\u5b98\u674e\u5bb6\u8d85\u8868\u793a\uff0c</span><span style=\"font-size-ignore:13pt;\">\u300a\u5354\u8b70\u300b</span><span style=\"font-size-ignore:13pt;\">\u6709\u52a9\u52a0\u5f37\u5169\u5730\u79d1\u7814\u5b78\u8853\u5718\u9ad4\u4ea4\u6d41\u3001\u79d1\u6280\u4eba\u624d\u57f9\u990a\u3001\u63a8\u52d5\u79d1\u6280\u666e\u53ca\u3001\u4fc3\u9032\u5927\u7063\u5340\u7684\u79d1\u6280\u878d\u5408\u767c\u5c55\u7b49\u4e0d\u540c\u9818\u57df\u7684\u5408\u4f5c\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u4ed6\u7a31\uff0c\u7279\u5340\u653f\u5e9c\u6703\u7e7c\u7e8c\u767c\u63ee\u597d\u9999\u6e2f\u4f5c\u70ba\u300c\u8d85\u7d1a\u806f\u7e6b\u4eba\u300d\u548c\u300c\u8d85\u7d1a\u589e\u503c\u4eba\u300d\u7684\u91cd\u8981\u89d2\u8272\uff0c\u8207\u4e2d\u570b\u79d1\u5354\u6301\u7e8c\u6df1\u5316\u5408\u4f5c\uff0c\u6253\u9020\u9999\u6e2f\u6210\u70ba\u570b\u969b\u5275\u65b0\u79d1\u6280\u4e2d\u5fc3\u548c\u570b\u969b\u9ad8\u7aef\u4eba\u624d\u96c6\u805a\u9ad8\u5730\uff0c\u670d\u52d9\u570b\u5bb6\u5be6\u73fe\u9ad8\u6c34\u5e73\u79d1\u6280\u81ea\u7acb\u81ea\u5f37\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u5275\u65b0\u79d1\u6280\u53ca\u5de5\u696d\u5c40\u5c40\u9577\u5b6b\u6771\u4eca\u65e5\u8207\u4e2d\u570b\u79d1\u5354\u4e3b\u5e2d\u842c\u92fc\u53ca\u4e2d\u570b\u79d1\u5354\u4ee3\u8868\u6703\u9762\uff0c\u5c31\u5169\u5730\u5275\u79d1\u6700\u65b0\u767c\u5c55\u53ca\u5408\u4f5c\u6a5f\u9047\uff0c\u9032\u884c\u4ea4\u6d41\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3945374/%E6%94%BF%E5%BA%9C%E8%88%87%E4%B8%AD%E5%9C%8B%E7%A7%91%E5%8D%94%E7%B0%BD%E5%90%88%E4%BD%9C%E6%A1%86%E6%9E%B6%E5%8D%94%E8%AD%B0"}, {"title": "\u4e2d\u5c0f\u4f01\u6771\u4e3b\u5443\u903e380\u842c\u767e\u5206\u767e\u64d4\u4fdd\u7279\u60e0\u8cb8\u6b3e \u5224\u56da38\u500b\u6708", "description": "<p>\u5ec9\u653f\u516c\u7f72\u843d\u6848\u8d77\u8a34\u4e00\u540d\u4e2d\u5c0f\u4f01\u6771\u4e3b\uff0c\u8a87\u5927\u7533\u5831\u516c\u53f8\u50f1\u54e1\u4eba\u6578\u53ca\u85aa\u916c\u958b\u652f\uff0c\u8a50\u9a19\u4e00\u9593\u9280\u884c\u6279\u51fa\u300c\u767e\u5206\u767e\u64d4\u4fdd\u7279\u60e0\u8cb8\u6b3e\u300d\u903e380\u842c\u5143\u3002\u88ab\u544a\u4eca\u65e5\u5728\u5340\u57df\u6cd5\u9662\u88ab\u5224\u5165\u734438\u500b\u6708\u3002</p>\n<p>45\u6b72\u7684\u99ae\u9326\u8f1d\u70ba\u9f8d\u904b\u6c7d\u8eca\u6771\u4e3b\uff0c\u65e9\u524d\u627f\u8a8d\u4e00\u9805\u6b3a\u8a50\u7f6a\uff0c\u9055\u53cd\u300a\u76dc\u7aca\u7f6a\u689d\u4f8b\u300b\u7b2c16A(1)\u689d\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u6cd5\u5b98\u8b1d\u6c88\u667a\u6167\u5224\u5211\u6642\u6307\u6848\u4ef6\u6027\u8cea\u56b4\u91cd\uff0c\u65a5\u8cac\u88ab\u544a\u6709\u9810\u8b00\u5730\u72af\u6848\uff0c\u8a50\u9a19\u91d1\u984d\u9f90\u5927\uff0c\u5982\u88ab\u544a\u7684\u884c\u70ba\u6c92\u6709\u88ab\u63ed\u767c\uff0c\u5176\u8a50\u9a19\u6703\u6301\u7e8c\u3002</span></p>\n<p>\u6cd5\u5b98\u53c8\u6307\u88ab\u544a\u88ab\u5b9a\u7f6a\u5224\u76e3\u5be6\u5c6c\u548e\u7531\u81ea\u53d6\u3002\u6cd5\u5ead\u4ee5\u76e3\u798145\u500b\u6708\u70ba\u91cf\u5211\u8d77\u9ede\uff0c\u88ab\u544a\u5728\u6848\u4ef6\u958b\u5be9\u5f8c\u624d\u627f\u8a8d\u63a7\u7f6a\uff0c\u53ea\u80fd\u628a\u5211\u671f\u6263\u6e1b15%\uff0c\u8003\u616e\u5176\u4ed6\u6c42\u60c5\u56e0\u7d20\u5f8c\uff0c\u6700\u7d42\u5224\u521138\u500b\u6708\u3002</p>\n<p>\u5ec9\u7f72\u65e9\u524d\u63a5\u7372\u8caa\u6c61\u6295\u8a34\uff0c\u7d93\u8abf\u67e5\u5f8c\u63ed\u767c\u4e0a\u8ff0\u8a50\u9a19\u300c\u767e\u5206\u767e\u64d4\u4fdd\u7279\u60e0\u8cb8\u6b3e\u300d\u7684\u9055\u6cd5\u884c\u70ba\uff0c\u5206\u6848\u8d77\u8a346\u540d\u4e2d\u5c0f\u4f01\u6771\u4e3b\uff0c\u6d89\u53ca\u8a50\u9a19\u91d1\u984d\u5171\u7d041900\u842c\u5143\u30026\u540d\u88ab\u544a\u4e2d\u9664\u99ae\u9326\u8f1d\u5916\uff0c\u4e8c\u4eba\u5df2\u8a8d\u7f6a\uff0c\u65e9\u524d\u5206\u5225\u88ab\u5224\u56da24\u500b\u6708\u53ca22\u500b\u6708\u3002\u53e6\u59163\u540d\u88ab\u544a\u7684\u6848\u4ef6\uff0c\u5206\u5225\u65bc\u660e\u5e742\u6708\u81f35\u6708\u9032\u884c\u7b54\u8faf\u3001\u5be9\u8a0a\u53ca\u88c1\u6c7a\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3945363/%E4%B8%AD%E5%B0%8F%E4%BC%81%E6%9D%B1%E4%B8%BB%E5%91%83%E9%80%BE380%E8%90%AC%E7%99%BE%E5%88%86%E7%99%BE%E6%93%94%E4%BF%9D%E7%89%B9%E6%83%A0%E8%B2%B8%E6%AC%BE+%E5%88%A4%E5%9B%9A38%E5%80%8B%E6%9C%88"}, {"title": "\u7b2c\u4e00\u592a\u5e73\u64ec\u5206\u62c6Maynilad\u83f2\u5f8b\u8cd3\u4e0a\u5e02", "description": "<p>\u7b2c\u4e00\u592a\u5e73(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00142' >00142</a>)\u516c\u5e03\uff0c\u6b63\u8003\u616e\u53ef\u80fd\u5206\u62c6\u83f2\u5f8b\u8cd3\u806f\u865f\u516c\u53f8Maynilad Water Services, Inc.\u4e4b\u80a1\u4efd\uff0c\u65bc\u83f2\u5f8b\u8cd3\u8b49\u5238\u4ea4\u6613\u6240\u7368\u7acb\u4e0a\u5e02\u3002</p>\n<p>Maynilad\u65bc\u5927\u99ac\u5c3c\u62c9\u5730\u5340\u300c\u897f\u90e8\u300d\u5f9e\u4e8b\u63d0\u4f9b\u8f38\u6c34\u53ca\u6c61\u6c34\u8655\u7406\u670d\u52d9\uff0c\u8a72\u5730\u5340\u6db5\u84cb\u99ac\u5c3c\u62c9\u5927\u90fd\u670311\u500b\u57ce\u5e02\u4ee5\u53caCavite\u77013\u500b\u57ce\u5e02\u53ca3\u500b\u76f4\u8f44\u5e02\u3002</p>   </div>\n<p></p>\n<div class=\"hkej_hkex_notic