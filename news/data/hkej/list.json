\u6a5f\u9047", "description": "<p>\u653f\u52d9\u53f8\u53f8\u9577\u9673\u570b\u57fa\u4eca\u65e5\u51fa\u5e2d\u300c\u4e00\u5e36\u4e00\u8def\u300d\u9752\u5e74\u767c\u5c55\u9ad8\u5cf0\u8ad6\u58c7\u81f4\u8a5e\u6642\u8868\u793a\uff0c\u96a8\u7740\u300c\u4e00\u5e36\u4e00\u8def\u300d\u5021\u8b70\u9032\u5165\u4e0b\u4e00\u500b\u91d1\u8272\u5341\u5e74\uff0c\u9999\u6e2f\u6703\u7e7c\u7e8c\u64d4\u7576\u597d\u300c\u4e00\u5e36\u4e00\u8def\u300d\u529f\u80fd\u5e73\u53f0\u7684\u89d2\u8272\uff0c\u81f4\u529b\u767c\u63ee\u300c\u8d85\u7d1a\u806f\u7e6b\u4eba\u300d\u548c\u300c\u8d85\u7d1a\u589e\u503c\u4eba\u300d\u7684\u4f5c\u7528\u3002</p>\n<p>\u9673\u570b\u57fa\u5f37\u8abf\uff0c\u9752\u5e74\u662f\u793e\u6703\u7684\u672a\u4f86\u3001\u5e0c\u671b\u548c\u68df\u6a11\uff0c\u4e5f\u662f\u63a8\u52d5\u300c\u4e00\u5e36\u4e00\u8def\u300d\u5021\u8b70\u53ef\u6301\u7e8c\u767c\u5c55\u7684\u751f\u529b\u8ecd\uff0c<span style=\"font-size-ignore:13pt;\">\u70ba\u9f13\u52f5\u9752\u5e74\u4eba\u878d\u5165\u570b\u5bb6\u767c\u5c55\u5927\u5c40\uff0c\u628a\u63e1\u300c\u4e00\u5e36\u4e00\u8def\u300d\u5021\u8b70\u6240\u5e36\u4f86\u7684\u9f90\u5927\u6a5f\u9047\uff0c\u7576\u5c40\u6301\u7e8c\u63a8\u5c55\u591a\u500b\u8207\u300c\u4e00\u5e36\u4e00\u8def\u300d\u570b\u5bb6\u548c\u5730\u5340\u76f8\u95dc\u7684\u9752\u5e74\u5be6\u7fd2\u548c\u4ea4\u6d41\u8a08\u5283\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u4ed6\u6307\u51fa\uff0c\u57282024\u81f325\u5e74\u5ea6\uff0c\u6c11\u653f\u53ca\u9752\u5e74\u4e8b\u52d9\u5c40\u7684\u5404\u9805\u76f8\u95dc\u5be6\u7fd2\u548c\u4ea4\u6d41\u8a08\u5283\u5408\u5171\u63d0\u4f9b\u7d041800\u500b\u540d\u984d\uff0c\u6db5\u84cb\u591a\u500b\u300c\u4e00\u5e36\u4e00\u8def\u300d\u570b\u5bb6\u548c\u5730\u5340\uff0c\u9f13\u52f5\u9752\u5e74\u4eba\u300c\u884c\u842c\u91cc\u8def\u300d\uff0c\u89aa\u8eab\u9ad4\u9a57\u548c\u4e86\u89e3\u5b83\u5011\u7684\u6b77\u53f2\u3001\u6587\u5316\u548c\u6700\u65b0\u767c\u5c55\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u5c55\u671b\u672a\u4f86\uff0c\u9673\u570b\u57fa\u8868\u793a\uff0c\u9999\u6e2f\u5c07\u7e7c\u7e8c\u767c\u63ee\u300c\u4e00\u5e36\u4e00\u8def\u300d\u529f\u80fd\u5e73\u53f0\u7684\u91cd\u8981\u89d2\u8272\uff0c\u81f4\u529b\u901a\u904e\u9999\u6e2f\u7684\u512a\u52e2\uff0c\u505a\u597d\u958b\u653e\u578b\u7d93\u6fdf\u9ad4\u5236\u7684\u63a8\u52d5\u8005\u3001\u65b0\u8cea\u751f\u7522\u529b\u548c\u65b0\u8208\u9818\u57df\u5408\u4f5c\u7684\u958b\u62d3\u8005\uff0c\u4ee5\u53ca\u8207\u300c\u4e00\u5e36\u4e00\u8def\u300d\u570b\u5bb6\u6c11\u5fc3\u76f8\u901a\u7684\u4fc3\u9032\u8005\uff0c\u70ba\u300c\u4e00\u5e36\u4e00\u8def\u300d\u9752\u5e74\u5e36\u4f86\u66f4\u5927\u767c\u5c55\u6a5f\u9047\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3942121/%E9%99%B3%E5%9C%8B%E5%9F%BA%3A%E9%BC%93%E5%8B%B5%E9%9D%92%E5%B9%B4%E6%8A%8A%E6%8F%A1%E4%B8%80%E5%B8%B6%E4%B8%80%E8%B7%AF%E5%80%A1%E8%AD%B0%E9%BE%90%E5%A4%A7%E6%A9%9F%E9%81%87"}, {"title": "11\u6708\u4eac\u6eec\u571f\u5730\u51fa\u8b93\u91d1\u5747\u903e300\u5104\u4eba\u6c11\u5e63", "description": "<p>\u4e2d\u6307\u7814\u7a76\u9662\u6578\u64da\u986f\u793a\uff0c<span style=\"font-size-ignore:13pt;\">11\u6708\u76e3\u6e2c\u57ce\u5e02\u7e3d\u9ad4\u4f9b\u6c42\u6309\u5e74\u4e0b\u964d\uff0c\u63a8\u51fa\u91cf\u6309\u5e74\u964d\u8fd1\u4e00\u6210\uff0c\u6574\u9ad4\u6210\u4ea4\u65b9\u9762\u91cf\u8dcc\u50f9\u6f32\uff0c\u4e00\u7dda\u57ce\u5e02\u6210\u4ea4\u91cf\u964d\u8fd1\u4e8c\u6210\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u51fa\u8b93\u91d1\u7e3d\u984d\u6309\u5e74\u589e\u903e\u4e00\u6210\uff0c\u4e0a\u6d77\u652c\u91d1\u903e317\u5104\u9818\u8dd1\uff0c\u5317\u4eac\u4ee5308\u5104\u5c45\u7b2c\u4e8c\u3002\u9577\u4e09\u89d2\u5730\u5340\u5b85\u5730\u5bc6\u96c6\u5165\u5e02\uff0c\u4f54\u64da\u51fa\u8b93\u91d1\u7e3d\u984d\u699c\u55ae11\u5e2d\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">11\u6708\uff0c30\u57ce\u65b0\u623f\u6210\u4ea4\u9762\u7a4d\u6309\u6708\u589e\u957712.4%\uff0c\u6309\u5e74\u589e\u957720.6%\uff1b20\u57ce\u4e8c\u624b\u623f\u6210\u4ea4\u5957\u6578\u6309\u6708\u589e\u957711.7%\uff0c\u6309\u5e74\u589e\u957726.3%\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3942119/11%E6%9C%88%E4%BA%AC%E6%BB%AC%E5%9C%9F%E5%9C%B0%E5%87%BA%E8%AE%93%E9%87%91%E5%9D%87%E9%80%BE300%E5%84%84%E4%BA%BA%E6%B0%91%E5%B9%A3"}, {"title": "\u912d\u96c1\u96c4:\u7279\u5340\u653f\u5e9c\u5805\u5b88\u5927\u5b78\u5b89\u5168\u7a69\u5b9a\u5e95\u7dda", "description": "<p>\u4e2d\u806f\u8fa6\u4e3b\u4efb\u912d\u96c1\u96c4\u5728\u5927\u5b78\u6821\u9577\u9ad8\u5cf0\u8ad6\u58c7\u4e0a\u81f4\u8a5e\u6642\u8868\u793a\uff0c\u4eca\u5e749\u6708\u570b\u5bb6\u4e3b\u5e2d\u7fd2\u8fd1\u5e73\u51fa\u5e2d\u5168\u570b\u6559\u80b2\u5927\u6703\u6642\u4e26\u767c\u8868\u91cd\u8981\u8b1b\u8a71\uff0c\u5c0d\u5efa\u8a2d\u6559\u80b2\u5f37\u570b\u4f5c\u51fa\u4e00\u7cfb\u5217\u7684\u65b0\u90e8\u7f72\uff0c\u5728\u9019\u6a23\u80cc\u666f\u4e0b\uff0c\u9999\u6e2f\u8209\u8fa6\u4eca\u6b21\u7684\u8ad6\u58c7\u53ef\u8b02\u6070\u9022\u5176\u6642\u3002</p>\n<p>\u912d\u96c1\u96c4\u5206\u4eab\u4e09\u9ede\u8a8d\u8b58\uff0c\u7b2c\u4e00\u662f\u300c\u5805\u6301\u7acb\u5fb7\u6a39\u4eba\u7684\u6839\u672c\u5b97\u65e8\uff0c\u767c\u63ee\u9ad8\u6548\u529b\u91cf\uff0c\u5171\u80b2\u5929\u4e0b\u82f1\u624d\u300d\u3002\u4ed6\u6307\u51fa\uff0c\u7576\u524d\u4e16\u754c\u9762\u81e8\u767e\u5e74\u672a\u6709\u4e4b\u5927\u8b8a\u5c40\uff0c\u4e0d\u65b7\u63d0\u5347\u9752\u5e74\u5b78\u751f\u7684\u683c\u5c40\u3001\u8996\u91ce\u3001\u4eba\u6587\u7cbe\u795e\u548c\u5b78\u8853\u7d20\u990a\u5341\u5206\u91cd\u8981\uff0c\u5e0c\u671b\u80fd\u9032\u4e00\u6b65\u51dd\u805a\u4e16\u754c\u77e5\u540d\u9ad8\u6821\uff0c\u4ee5\u7acb\u5fb7\u6a39\u4eba\u7684\u5171\u8b58\u642d\u5efa\u5168\u7403\u7684\u4eba\u624d\u57f9\u990a\u5e73\u53f0\uff0c\u5171\u540c\u57f9\u990a\u5fb7\u624d\u517c\u5099\u3001\u6709\u4e16\u754c\u773c\u5149\u3001\u81ea\u529b\u69cb\u5efa\u4eba\u985e\u547d\u904b\u5171\u540c\u9ad4\u7684\u9ad8\u7d20\u8cea\u4eba\u624d\u3002</p>\n<p>\u7b2c\u4e8c\u9ede\u8a8d\u8b58\u662f\u300c\u5805\u6301\u5927\u5b78\u570b\u969b\u5316\u7684\u91cd\u8981\u65b9\u5411\uff0c\u69cb\u5efa\u4e92\u806f\u4e92\u901a\u7684\u570b\u969b\u9ad8\u7b49\u6559\u80b2\u5408\u4f5c\u7db2\u7d61\u3002\u300d\u912d\u96c1\u96c4\u7a31\uff0c\u9999\u6e2f\u56de\u6b78\u7956\u570b\u4ee5\u4f86\uff0c\u7279\u5340\u653f\u5e9c\u5728\u4e2d\u592e\u7684\u652f\u6301\u4e0b\u5805\u5b88\u5927\u5b78\u5b89\u5168\u7a69\u5b9a\u7684\u5e95\u7dda\uff0c\u5805\u5b9a\u4e0d\u79fb\u7dad\u8b77\u5927\u5b78\u81ea\u4e3b\u548c\u5b78\u8853\u81ea\u7531\uff0c\u652f\u6301\u5927\u5b78\u958b\u5c55\u5ee3\u6cdb\u7684\u570b\u969b\u5408\u4f5c\uff0c\u63a8\u52d5\u9999\u6e2f\u5404\u5927\u5b78\u5be6\u73fe\u5feb\u901f\u767c\u5c55\uff0c\u6e2f\u5927\u7b495\u6240\u9ad8\u6821\u9023\u7e8c\u591a\u5e74\u4f4d\u5c45\u4e16\u754c\u767e\u5f37\uff0c\u570b\u969b\u5316\u7279\u8272\u5341\u5206\u7a81\u51fa\uff0c\u9999\u6e2f\u4ea6\u6210\u70ba\u9023\u7e8c6\u5e74\u64c1\u6709\u5168\u7403\u6700\u591a\u53ca\u6700\u570b\u969b\u5316\u5927\u5b78\u7684\u57ce\u5e02\u3002</p>\n<p>\u81f3\u65bc\u7b2c\u4e09\u9ede\u8a8d\u8b58\u662f\u300c\u5805\u6301\u9020\u798f\u793e\u6703\u7684\u5d07\u9ad8\u4f7f\u547d\uff0c\u70ba\u4eba\u985e\u6587\u660e\u9032\u6b65\u8ca2\u737b\u5927\u5b78\u667a\u6167\u548c\u64d4\u7576\u3002\u300d\u4ed6\u8868\u793a\uff0c\u7576\u4eca\u4e16\u754c\u5927\u5b78\u6108\u4f86\u6108\u6210\u70ba\u627f\u8f09\u793e\u6703\u671f\u5f85\u548c\u5ef6\u7e8c\u4eba\u985e\u6587\u660e\u7684\u91cd\u8981\u8cc7\u6e90\uff0c<span style=\"font-size-ignore:13pt;\">\u8a8d\u70ba\u8981\u79c9\u6301\u958b\u653e\u7406\u5ff5\u548c\u5275\u65b0\u7cbe\u795e\uff0c\u5728\u95dc\u9375\u9818\u57df\u52a0\u5f37\u570b\u969b\u79d1\u5b78\u7814\u7a76\u5408\u4f5c\uff0c\u8b93\u5148\u9032\u6280\u8853\u8de8\u8d8a\u570b\u754c\u969c\u7919\uff0c\u70ba\u89e3\u6c7a\u4eba\u985e\u793e\u6703\u7684\u91cd\u5927\u79d1\u5b78\u96e3\u984c\u548c\u793e\u6703\u554f\u984c\uff0c\u505a\u51fa\u5927\u5b78\u61c9\u6709\u7684\u8ca2\u737b\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3942093/%E9%84%AD%E9%9B%81%E9%9B%84%3A%E7%89%B9%E5%8D%80%E6%94%BF%E5%BA%9C%E5%A0%85%E5%AE%88%E5%A4%A7%E5%AD%B8%E5%AE%89%E5%85%A8%E7%A9%A9%E5%AE%9A%E5%BA%95%E7%B7%9A"}, {"title": "\u76e7\u5bf5\u8302\u4eca\u5348\u7387\u5718\u8d74\u4eac\u51fa\u5e2d\u4e16\u754c\u50b3\u7d71\u91ab\u85e5\u5927\u6703", "description": "<p>\u91ab\u52d9\u885e\u751f\u5c40\u5c40\u9577\u76e7\u5bf5\u8302\u4eca\u65e5\u4e0b\u5348\u7387\u9818\u4ee3\u8868\u5718\u5230\u5317\u4eac\u51fa\u5e2d\u660e\u65e5\u8d77\u4e00\u9023\u5169\u65e5\u8209\u884c\u76842024\u4e16\u754c\u50b3\u7d71\u91ab\u85e5\u5927\u6703\uff0c\u8207\u4f86\u81ea\u4e16\u754c\u5404\u5730\u7684\u9ad8\u7d1a\u885e\u751f\u5b98\u54e1\u548c\u50b3\u7d71\u91ab\u5b78\u9818\u57df\u7684\u5c08\u5bb6\u548c\u5b78\u8005\u5c31\u50b3\u7d71\u91ab\u85e5\u7684\u50b3\u627f\u548c\u5275\u65b0\uff0c\u4ee5\u53ca\u4fc3\u9032\u50b3\u7d71\u91ab\u5b78\u878d\u5165\u91ab\u7642\u885e\u751f\u670d\u52d9\u9ad4\u7cfb\u7b49\u8b70\u984c\u9032\u884c\u6df1\u5165\u8a0e\u8ad6\u548c\u4ea4\u6d41\u3002</p>\n<p>\u76e7\u5bf5\u8302\u5c07\u51fa\u5e2d\u653f\u5e9c\u8ad6\u58c7\uff0c\u4e26\u6703\u767c\u8868\u4e3b\u984c\u5831\u544a\uff0c\u5411\u4f86\u81ea\u4e16\u754c\u5404\u5730\u7684\u8207\u6703\u8005\u4ecb\u7d39\u9999\u6e2f\u5728\u4fc3\u9032\u4e2d\u91ab\u85e5\u767c\u5c55\u7684\u6210\u5c31\u53ca\u63a8\u52d5\u4e2d\u91ab\u85e5\u570b\u969b\u5316\u7684\u7b56\u7565\u65b9\u5411\u3002</p>\n<p>\u9999\u6e2f\u4ee3\u8868\u5718\u6210\u54e1\u5305\u62ec\u885e\u751f\u7f72\u7f72\u9577\u6797\u6587\u5065\u3001\u91ab\u885e\u5c40\u4e2d\u91ab\u85e5\u767c\u5c55\u5c08\u54e1\u937e\u5fd7\u8c6a\u3001\u885e\u751f\u7f72\u52a9\u7406\u7f72\u9577\u4e2d\u91ab\u85e5\u65b9\u6d69\u6f84\u3001\u885e\u751f\u7f72\u63a7\u7159\u9152\u8fa6\u516c\u5ba4\u4e3b\u4efb\u5c01\u87a2\u3001\u91ab\u7ba1\u5c40\u4e3b\u5e2d\u8303\u9d3b\u9f61\u3001\u91ab\u7ba1\u5c40\u884c\u653f\u7e3d\u88c1\u9ad8\u62d4\u965e\uff0c\u4ee5\u53ca\u5176\u4ed6\u91ab\u885e\u5c40\u3001\u885e\u751f\u7f72\u548c\u91ab\u7ba1\u5c40\u4eba\u54e1\u3002