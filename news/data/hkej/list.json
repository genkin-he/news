{"data": [{"title": "\u65e5\u672c10\u6708\u57fa\u672c\u5de5\u8cc7\u589e\u5e45\u527532\u5e74\u9ad8", "description": "<p><span style=\"font-size-ignore:13pt;\">\u65e5\u672c\u653f\u5e9c\u516c\u5e03\u7684\u6578\u64da\u986f\u793a\uff0c\u65e5\u672c\u57fa\u672c\u5de5\u8cc710\u6708\u589e\u901f\u527532\u5e74\u4f86\u65b0\u9ad8\uff0c\u70ba\u592e\u884c\u672c\u6708\u52a0\u606f\u524d\u666f\u63d0\u4f9b\u7d71\u8a08\u6578\u64da\u9762\u7684\u652f\u6301\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u539a\u751f\u52de\u52d5\u7701\u7684\u6578\u64da\u986f\u793a\uff0c10\u6708\u57fa\u672c\u5de5\u8cc7\u53472.7%\uff0c\u5275\u4e0b1992\u5e7411\u6708\u4ee5\u4f86\u7684\u6700\u5feb\u5347\u5e45\u3002</span><span style=\"font-size-ignore:13pt;\">\u4f5c\u70ba\u8861\u91cf\u4f01\u696d\u5be6\u529b\u6307\u6a19\u7684\u52a0\u73ed\u5de5\u8cc7\u572810\u6708\u4e0a\u6f321.4%\uff0c9\u6708\u4fee\u6b63\u70ba\u4e0b\u964d0.9%\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">10\u6708\u7d93\u901a\u8139\u8abf\u6574\u5f8c\u7684\u5be6\u969b\u5de5\u8cc7\u8f03\u4e0a\u5e74\u540c\u671f\u6301\u5e73\uff0c9\u6708\u548c8\u6708\u5206\u5225\u4fee\u6b63\u70ba\u4e0b\u964d0.4%\u548c0.8%\u3002</span></p>\n<p>\u65e5\u672c\u592e\u884c\u9d3f\u6d3e\u5be9\u8b70\u59d4\u54e1\u4e2d\u6751\u8c4a\u660e\u5468\u56db\u8868\u793a\uff0c\u592e\u884c\u5728\u8003\u616e\u662f\u5426\u5728\u672c\u6708\u52a0\u606f\u6642\uff0c\u5fc5\u9808\u4ed4\u7d30\u5be9\u67e5\u5404\u7a2e\u7d93\u6fdf\u6307\u6a19\uff0c\u5305\u62ec\u5de5\u8cc7\u548c\u4f01\u696d\u666f\u6c23\u6307\u6a19\u3002</p>\n<p>\u5e02\u5834\u5c0d\u65e5\u672c\u592e\u884c\u4e0b\u6b21\u52a0\u606f\u662f\u572812\u6708\u62161\u6708\u7684\u770b\u6cd5\u4ecd\u7136\u5b58\u5728\u5206\u6b67\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3948430/%E6%97%A5%E6%9C%AC10%E6%9C%88%E5%9F%BA%E6%9C%AC%E5%B7%A5%E8%B3%87%E5%A2%9E%E5%B9%85%E5%89%B532%E5%B9%B4%E9%AB%98"}, {"title": "\u83ef\u723e\u8857\u5927\u884c\u6599\u4e2d\u570b\u660e\u5e74\u6e1b\u606f\u5e45\u5ea6\u6216\u5341\u5e74\u4f86\u6700\u5927", "description": "<p>\u83ef\u723e\u8857\u5927\u884c\u9810\u8a08\u4e2d\u570b\u4eba\u6c11\u9280\u884c\u660e\u5e74\u5c07\u9032\u884c10\u5e74\u4f86\u6700\u5927\u5e45\u5ea6\u7684\u964d\u606f\uff0c\u6c7a\u7b56\u8005\u5c07\u52a0\u5927\u529b\u5ea6\u63d0\u632f\u7d93\u6fdf\u589e\u9577\u4e26\u61c9\u5c0d\u901a\u7e2e\u58d3\u529b\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u5f6d\u535a\u5f15\u8ff0\u9ad8\u76db\u548c\u6469\u6839\u58eb\u4e39\u5229\u7b49\u6a5f\u69cb\u9810\u6e2c\uff0c\u4e2d\u570b\u592e\u884c2025\u5e74\u5c07\u628a\u4e3b\u8981\u653f\u7b56\u5229\u7387\u4e0b</span><span style=\"font-size-ignore:13pt;\">\u8abf40\u500b\u57fa\u9ede\uff0c\u9019\u5c07\u662f2015\u5e74\u4ee5\u4f86\u6700\u5927\u964d\u5e45\uff0c\u5c46\u66427\u5929\u671f\u9006\u56de</span><span style=\"font-size-ignore:13pt;\">\u8cfc\u5229\u7387\u5c07\u4e0b\u8abf\u81f31.1\u5398\u3002\u5f6d\u535a\u6700\u8fd1\u8abf\u67e5\u4e2d\u7684\u9810\u671f\u4e2d\u503c\u70ba\u4e0b\u8abf30\u500b\u57fa\u9ede\u3002</span></p>\n<p>\u96d6\u7136\u9019\u5e45\u5ea6\u76f8\u6bd4\u591a\u6578\u5176\u4ed6\u4e3b\u8981\u7d93\u6fdf\u9ad4\u592e\u884c\u7684\u901a\u5e38\u64cd\u4f5c\u8981\u4f4e\u5f88\u591a\uff0c\u4f46\u4e2d\u570b\u592e\u884c\u6709\u7406\u7531\u4fdd\u6301\u8b39\u614e\u3002\u964d\u4f4e\u5229\u7387\u5c07\u4ee4\u5546\u696d\u9280\u884c\u672c\u5df2\u8655\u65bc\u7d00\u9304\u4f4e\u9ede\u7684\u6de8\u606f\u5dee\u627f\u58d3\uff0c\u5728\u623f\u5730\u7522\u6301\u7e8c\u4f4e\u8ff7\u7684\u60c5\u6cc1\u4e0b\uff0c\u9280\u884c\u8499\u53d7\u640d\u5931\u7684\u7de9\u885d\u7a7a\u9593\u5c07\u66f4\u5c0f\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u5831\u9053\u5f15\u8ff0\u9ad8\u76db\u9996\u5e2d\u4e2d\u570b\u7d93\u6fdf\u5b78\u5bb6Hui Shan\u8868\u793a\uff0c\u8ca1\u653f\u523a\u6fc0\u5728\u660e\u5e74\u63d0\u632f\u9700\u6c42\u4e0a\u5c07\u9700\u8981</span><span style=\"font-size-ignore:13pt;\">\u767c\u63ee\u91cd\u8981\u4f5c\u7528\uff0c\u4e0d\u904e\u4e5f\u9700\u8981\u66f4\u4f4e\u7684\u5229\u7387\u3002\u5979\u8868\u793a\uff0c\u70ba\u4e86\u62b5\u79a6\u570b\u5167\u9700\u6c42\u75b2\u8edf</span><span style=\"font-size-ignore:13pt;\">\u548c\u7f8e\u570b\u53ef\u80fd\u52a0\u5fb5\u95dc\u7a05\u6240\u5e36\u4f86\u7684\u589e\u9577\u5f37\u963b\u529b\uff0c\u6709\u5fc5\u8981\u5927\u5e45\u653e\u5bec\u5b8f\u89c0\u653f\u7b56\uff0c\u5305</span><span style=\"font-size-ignore:13pt;\">\u62ec\u8ca8\u5e63\u5bec\u9b06\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u964d\u606f\u9810\u671f\u8868\u660e\uff0c\u4e2d\u570b\u7684\u4f4e\u5229\u7387\u74b0\u5883\u53ef\u80fd\u6703\u6301\u7e8c\uff0c\u9019\u4e00\u8da8\u52e2\u6700\u8fd1\u6210\u70ba\u50b5\u5238\u5e02</span><span style=\"font-size-ignore:13pt;\">\u5834\u95dc\u6ce8\u7684\u7126\u9ede\u300210\u5e74\u671f\u570b\u50b5\u6b96\u5229\u7387\u672c\u5468\u8dcc\u78342%\uff0c\u70ba\u6709\u7d00\u9304\u4ee5\u4f86\u9996\u6b21\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3948426/%E8%8F%AF%E7%88%BE%E8%A1%97%E5%A4%A7%E8%A1%8C%E6%96%99%E4%B8%AD%E5%9C%8B%E6%98%8E%E5%B9%B4%E6%B8%9B%E6%81%AF%E5%B9%85%E5%BA%A6%E6%88%96%E5%8D%81%E5%B9%B4%E4%BE%86%E6%9C%80%E5%A4%A7"}, {"title": "\u8449\u5289:\u554f\u8cac\u5236\u4e0b\u6709\u5c40\u9577\u88ab\u64a4\u63db\u662f\u6b63\u5e38", "description": "<p><span style=\"font-size-ignore:13pt;\">\u570b\u52d9\u9662\u514d\u53bb\u6797\u4e16\u96c4\u53ca\u694a\u6f64\u96c4\u7684\u8077\u52d9\uff0c\u7531\u9673\u7f8e\u5bf6\u548c\u7f85\u6dd1\u4f69\u5206\u5225\u63a5\u4efb\u904b\u8f38\u53ca\u7269\u6d41\u5c40\u5c40\u9577\uff0c\u4ee5\u53ca\u6587\u5316\u9ad4\u80b2\u53ca\u65c5\u904a\u5c40\u5c40\u9577\u3002</span></p>\n<p>\u884c\u653f\u6703\u8b70\u53ec\u96c6\u4eba\u8449\u5289\u6dd1\u5100\u5728\u96fb\u53f0\u7bc0\u76ee\u8868\u793a\uff0c\u5728\u554f\u8cac\u5236\u4e0b\uff0c\u6709\u5c40\u9577\u88ab\u64a4\u63db\u662f\u6b63\u5e38\uff0c\u88ab\u514d\u8077\u7684\u5169\u4f4d\u5c40\u9577\u4e26\u975e\u505a\u5f97\u5f88\u4e0d\u7406\u60f3\uff0c\u800c\u662f\u7279\u9996\u770b\u5230\u672a\u4f86\u5de5\u4f5c\u6311\u6230\u66f4\u5927\u3002</p>\n<p>\u8449\u5289\u6dd1\u5100\u6307\u51fa\uff0c\u694a\u6f64\u96c4\u4efb\u5167\u89aa\u81ea\u53bb\u5df4\u9ece\u5967\u904b\uff0c\u4ea6\u6709\u56db\u5468\u8003\u5bdf\u65c5\u904a\u4e8b\u52d9\uff0c\u300c\u5514\u53ef\u4ee5\u8a71\u4f62\u7121\u505a\u5622\u300d\u3002\u81f3\u65bc\u6797\u4e16\u96c4\uff0c\u8449\u5289\u6dd1\u5100\u6307\u4ed6\u4efb\u5167\u8868\u73fe\u4e2d\u898f\u4e2d\u77e9\uff0c\u5c24\u5176\u662f\u300c\u4e09\u96a7\u5206\u6d41\u300d\uff0c\u7d05\u96a7\u66a2\u901a\u4e86\uff0c\u99d5\u99db\u4eba\u58eb\u4ea6\u7bc0\u7701\u91d1\u9322\u3002</p>\n<p>\u8449\u5289\u6dd1\u5100\u53c8\u8b9a\u63da\u5169\u4f4d\u5973\u5c40\u9577\u662f\u9069\u7576\u4eba\u9078\uff0c<span style=\"font-size-ignore:13pt;\">\u90f5\u8f2a\u78bc\u982d\u4e4b\u524d\u591a\u6b21\u300c\u7529\u8f46\u300d\u6975\u4e0d\u7406\u60f3\uff0c\u672c\u6e2f\u9700\u8981\u5438\u5f15\u66f4\u591a\u9ad8\u7aef\u53ca\u904e\u591c\u65c5\u5ba2\uff0c\u52a0\u4e0a\u555f\u5fb7\u9ad4\u80b2\u5712\u5c07\u555f\u7528\uff0c\u7f85\u6dd1\u4f69\u66fe\u505a\u904e\u65c5\u904a\u53ca\u904b\u8f38\u65b9\u9762\u7684\u5de5\u4f5c\uff0c\u500b\u6027\u5927\u81bd\u53ca\u5275\u65b0\uff0c\u6709\u80fd\u529b\u61c9\u4ed8\u672a\u4f86\u7684\u91cd\u8981\u5de5\u4f5c\u3002</span></p>\n<p>\u81f3\u65bc\u9673\u7f8e\u5bf6\uff0c\u8449\u5289\u6dd1\u5100\u6307\u5979\u4e4b\u524d\u662f\u904b\u6d41\u5c40\u5e38\u4efb\u79d8\u66f8\u9577\uff0c\u4e00\u76f4\u8ddf\u9032\u653f\u7b56\u5c40\u7684\u76f8\u95dc\u5de5\u4f5c\uff0c\u719f\u6089\u904b\u8f38\u4e8b\u52d9\uff0c\u672a\u4f86\u6311\u6230\u66f4\u5927\uff0c\u5305\u62ec\u8981\u8655\u7406\u4f4e\u7a7a\u7d93\u6fdf\uff0c\u96a8\u7740\u4e09\u8dd1\u7cfb\u7d71\u555f\u7528\uff0c\u5982\u4f55\u7dad\u6301\u7a7a\u904b\u4e16\u754c\u6392\u540d\u7b2c\u4e00\u5f88\u91cd\u8981\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3948404/%E8%91%89%E5%8A%89%3A%E5%95%8F%E8%B2%AC%E5%88%B6%E4%B8%8B%E6%9C%89%E5%B1%80%E9%95%B7%E8%A2%AB%E6%92%A4%E6%8F%9B%E6%98%AF%E6%AD%A3%E5%B8%B8"}, {"title": "\u5eb7\u6587\u7f72\u5925\u6d77\u6d0b\u516c\u5712\u63a8\u65b0\u512a\u60e0", "description": "<p>\u5eb7\u6587\u7f72\u8207\u9999\u6e2f\u6d77\u6d0b\u516c\u5712\u5408\u4f5c\u63a8\u51fa\u65b0\u512a\u60e0\uff0c\u5373\u65e5\u81f32026\u5e748\u670831\u65e5\uff0c\u6d77\u6d0b\u516c\u5712\u5168\u5e74\u6703\u7c4d\u6301\u6709\u4eba\u8cfc\u8cb7\u535a\u7269\u9928\u901a\u884c\u8b49\uff0c\u53ef\u4eab\u4e5d\u6298\u512a\u60e0\uff0c\u800c\u535a\u7269\u9928\u901a\u884c\u8b49\u6301\u6709\u4eba\u8cfc\u8cb7\u6d77\u6d0b\u516c\u5712\u5168\u5e74\u6703\u7c4d\uff0c\u4ea6\u53ef\u7372\u4e5d\u6298\u3002</p>\n<p>\u53e6\u5916\uff0c\u7531\u4e0b\u5468\u56db(12\u65e5)\u8d77\uff0c\u535a\u7269\u9928\u901a\u884c\u8b49\u6301\u6709\u4eba\u65bc\u57ce\u5e02\u552e\u7968\u7db2\u552e\u7968\u8655\u8cfc\u8cb7\u9999\u6e2f\u821e\u8e48\u5718\u6f14\u51fa\u6b63\u50f9\u9580\u7968\uff0c\u53ca\u65bc\u6f14\u51fa\u671f\u9593\u5728\u8868\u6f14\u5834\u5730\u8cfc\u8cb7\u9999\u6e2f\u821e\u8e48\u5718\u7bc0\u76ee\u5468\u908a\u5546\u54c1\u6642\uff0c\u5747\u53ef\u4eab\u6709\u4e5d\u6298\u512a\u60e0\u3002</p>\n<p>\u5e02\u6c11\u53ef\u65bc7\u9593\u5eb7\u6587\u7f72\u6307\u5b9a\u535a\u7269\u9928\u8cfc\u8cb7\u5be6\u9ad4\u535a\u7269\u9928\u901a\u884c\u8b49\uff0c\u6216\u900f\u904e\u57ce\u5e02\u552e\u7968\u7db2\u6216\u6d41\u52d5\u61c9\u7528\u7a0b\u5f0f\uff0c\u8cfc\u8cb7\u96fb\u5b50\u535a\u7269\u9928\u901a\u884c\u8b49\u3002\u5bb6\u5ead\u901a\u884c\u8b49\u7684\u5168\u5e74\u7968\u50f9\u70ba100\u5143\u3001\u500b\u4eba\u901a\u884c\u8b49\u7684\u5168\u5e74\u7968\u50f9\u70ba50\u5143\u3001\u9069\u7528\u65bc\u5168\u65e5\u5236\u5b78\u751f\u3001\u6b98\u75be\u4eba\u58eb\u300160\u6b72\u6216\u4ee5\u4e0a\u9ad8\u9f61\u4eba\u58eb\u7684\u512a\u60e0\u901a\u884c\u8b49\uff0c\u5168\u5e74\u7968\u50f9\u70ba25\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3948411/%E5%BA%B7%E6%96%87%E7%BD%B2%E5%A4%A5%E6%B5%B7%E6%B4%8B%E5%85%AC%E5%9C%92%E6%8E%A8%E6%96%B0%E5%84%AA%E6%83%A0"}, {"title": "\u57fa\u5efa\u96f6\u552e\u50b5\u4e28\u4eca\u65e5\u4e0b\u53482\u6642\u622a\u6b62\u8a8d\u8cfc", "description": "<p>\u653f\u5e9c\u767c\u884c\u57fa\u790e\u5efa\u8a2d\u96f6\u552e\u50b5\u5238\uff0c\u4eca\u65e5\u4e0b\u53482\u6642\u622a\u6b62\u8a8d\u8cfc\u3002</p>\n<p>\u653f\u5e9c\u767c\u884c\u7684\u57fa\u5efa\u96f6\u552e\u50b5\uff0c\u76ee\u6a19\u767c\u884c\u984d\u70ba200\u5104\u5143\uff0c\u6703\u8996\u4e4e\u8a8d\u8cfc\u53cd\u61c9\uff0c\u53ef\u52a0\u78bc\u81f3\u6700\u591a250\u5104\u5143\u3002<span style=\"font-size-ignore:13pt;\">\u6bcf\u624b1\u842c\u5143\uff0c\u5e74\u671f\u70ba3\u5e74\uff0c\u6bcf\u534a\u5e74\u6d3e\u606f\u4e00\u6b21\uff0c\u606f\u7387\u8207\u672c\u5730\u901a\u8139\u639b\u920e\uff0c\u4e26\u4fdd\u8b49\u4e0d\u6703\u5c11\u65bc3.5\u5398\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u57fa\u790e\u96f6\u552e\u50b5\u5238\u5c07\u65bc12\u670817\u65e5\u767c\u884c\uff0c\u4e26\u65bc12\u670818\u65e5\u5728\u9999\u6e2f\u806f\u5408\u4ea4\u6613\u6240\u4e0a\u5e02\uff0c\u4e26\u53ef\u5728\u4e8c\u624b\u5e02\u5834\u9032\u884c\u8cb7\u8ce3\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u70ba\u4e86\u8b93\u66f4\u591a\u5e02\u6c11\u53ef\u4ee5\u53c3\u8207\u8a08\u5283\uff0c\u662f\u6b21\u767c\u884c\u7684\u6700\u9ad8\u914d\u767c\u91d1\u984d\u8a2d\u5b9a\u70ba\u6bcf\u4f4d\u6295\u8cc7\u8005100\u842c\u5143\uff0c\u5373\u6bcf\u4f4d\u6295\u8cc7\u8005\u6700\u591a\u53ea\u80fd\u7372\u914d\u767c100\u624b\u50b5\u5238\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u672c\u6279\u50b5\u5238\u4e43\u57fa\u790e\u5efa\u8a2d\u50b5\u5238\u8a08\u5283\u4e0b\u7684\u96f6\u552e\u90e8\u5206\u3002\u767c\u50b5\u6240\u5f97\u8cc7\u91d1\u5c07\u64a5\u5165\u57fa\u672c\u5de5\u7a0b\u5132\u5099\u57fa\u91d1\uff0c\u6309\u8a08\u5283\u6846\u67b6\u4f5c\u57fa\u5efa\u9805\u76ee\u6295\u8cc7\u3002\u653f\u5e9c\u6703\u6bcf\u5e74\u516c\u5e03\u52df\u5f97\u8cc7\u91d1\u7684\u5206\u914d\u60c5\u6cc1\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3948397/%E5%9F%BA%E5%BB%BA%E9%9B%B6%E5%94%AE%E5%82%B5%E4%B8%A8%E4%BB%8A%E6%97%A5%E4%B8%8B%E5%8D%882%E6%99%82%E6%88%AA%E6%AD%A2%E8%AA%8D%E8%B3%BC"}, {"title": "\u672c\u5468\u8cfd\u99ac\u76db\u4e8b\u6709\u6d77\u5916\u99ac\u8ff7\u7d44\u5718\u4f86\u6e2f \u6599\u4eba\u5747\u6d88\u8cbb5\u81f310\u842c", "description": "<p>\u300a\u65bd\u653f\u5831\u544a\u300b\u63d0\u51fa\u63a8\u52d5\u8cfd\u99ac\u65c5\u904a\uff0c\u99ac\u6703\u672c\u5468\u8209\u8fa6\u5169\u5834\u570b\u969b\u8cfd\u4e8b\uff0c\u6709\u6d77\u5916\u65c5\u884c\u793e\u5b89\u6392\u6d77\u5916\u99ac\u8ff7\u4f86\u6e2f\u89c0\u8cfd\uff0c\u7a31\u5718\u53cb\u8a2a\u6e2f\u671f\u9593\u4eba\u5747\u6d88\u8cbb\u984d\u9ad8\u90545\u81f310\u842c\u5143\uff0c\u6709\u4eba\u55ae\u65e5\u5927\u624b\u7b46\u82b1\u8cbb50\u842c\u5143\u8cfc\u8cb7\u73e0\u5bf6\uff0c\u66f4\u6709\u5718\u53cb\u6703\u8d81\u6a5f\u4f86\u9999\u6e2f\u5c0b\u627e\u5546\u6a5f\u3002</p>\n<p>\u4e00\u884c80\u4eba\u7684\u6fb3\u6d32\u65c5\u884c\u5718\u5468\u4e09(4\u65e5)\u9060\u9053\u5230\u8dd1\u99ac\u5730\u5165\u5834\u6367\u5834\u3002\u8ca0\u8cac\u7b56\u5283\u5e36\u968a\u7684\u65c5\u884c\u793e\u8ca0\u8cac\u4eba\u8868\u793a\uff0c\u9999\u6e2f\u570b\u969b\u8cfd\u4e8b\u6709\u5438\u5f15\u529b\u3002\u6240\u5c6c\u7684\u65c5\u884c\u793e<span style=\"font-size-ignore:13pt;\">\u65e9\u572814\u5e74\u524d\u5df2\u7c4c\u8fa6\u8cfd\u99ac\u65c5\u884c\u5718\u4f86\u6e2f\uff0c\u898f\u6a21\u7531\u6700\u521d\u6bcf\u57187\u4eba\uff0c\u767c\u5c55\u81f3\u4eca\u5e7480\u4eba\u3002\u4ed6\u5f62\u5bb9\uff0c\u9999\u6e2f\u8cfd\u99ac\u662f\u4e16\u754c\u4e0a\u6700\u597d\u7684\u8cfd\u4e8b\u4e4b\u4e00\uff0c\u65c5\u5ba2\u9664\u4e86\u4f86\u89c0\u8cfd\uff0c\u4ea6\u6703\u6d88\u8cbb\uff0c\u4e0d\u5c11\u4eba\u90fd\u8a8d\u70ba\u4f86\u6e2f\u89c0\u770b\u8cfd\u99ac\u7684\u6027\u50f9\u6bd4\u9ad8\u3002</span></p>\n<p>\u8ca0\u8cac\u4eba\u6307\u51fa\uff0c\u4eca\u6b21\u76847\u59296\u591c\u8cfd\u99ac\u65c5\u884c\u5718\uff0c80\u540d\u5718\u53cb\u4e3b\u8981\u4f86\u81ea\u58a8\u723e\u672c\u548c\u6089\u5c3c\uff0c\u5728\u6e2f\u9017\u7559\u671f\u9593\u6703\u5165\u4f4f\u4e94\u661f\u7d1a\u9152\u5e97\uff0c\u4f4f\u5bbf\u9023\u9910\u98f2\u7b49\u7684\u6d88\u984d\u7e3d\u984d\u5df2\u9ad8\u9054200\u591a\u842c\u5143\uff0c\u52a0\u4e0a\u81e8\u8fd1\u8056\u8a95\uff0c\u4e0d\u5c11\u65c5\u5ba2\u7684\u6d88\u8cbb\u610f\u6b32\u8f03\u65fa\u76db\u3002</p>\n<p>\u4ed6\u53c8\u7a31\uff0c\u53c3\u52a0\u9019\u985e\u8cfd\u99ac\u65c5\u884c\u5718\u7684\u5ba2\u4eba\u4e0d\u5c11\u90fd\u662f\u751f\u610f\u4eba\uff0c\u9664\u4e86\u89c0\u770b\u8cfd\u99ac\uff0c\u4ed6\u5011\u4ea6\u6703\u85c9\u6a5f\u5c0b\u627e\u5546\u696d\u5408\u4f5c\u6a5f\u6703\uff0c\u4ee5\u62d3\u5c55\u696d\u52d9\uff0c\u76f8\u4fe1\u80fd\u70ba\u9999\u6e2f\u5e36\u4f86\u5f88\u591a\u6f5b\u5728\u5546\u6a5f\u3002<span style=\"font-size-ignore:13pt;\">\u4e0b\u4e00\u5718\u6703\u5728\u660e\u5e744\u6708\u4f86\u6e2f\u53c3\u8207\u8cfd\u99ac\u76db\u4e8b\uff0c\u4e5f\u6703\u8003\u616e\u5e36\u65c5\u5ba2\u5230\u5927\u7063\u5340\u65c5\u904a\u3002</span></p>\n<p>\u6c99\u7530\u99ac\u5834\u5468\u65e5(8\u65e5)\u5c07\u4e0a\u6f144\u5834\u570b\u969b\u4e00\u7d1a\u8cfd\uff0c\u7e3d\u734e\u91d1\u9ad8\u90541.2\u5104\u5143\uff0c\u662f\u4e16\u754c\u99ac\u58c7\u5e74\u7d42\u76db\u4e8b\u3002\u800c\u5728\u525b\u904e\u53bb\u7684\u5468\u4e09\uff0c\u8dd1\u99ac\u5730\u99ac\u5834\u8209\u884c\u300c\u570b\u969b\u9a0e\u5e2b\u9326\u6a19\u8cfd\u300d\uff0c\u5168\u665a\u5171\u903e2.1\u842c\u4eba\u6b21\u5165\u5834\uff0c\u6295\u6ce8\u984d\u905414.45\u5104\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3948395/%E6%9C%AC%E5%91%A8%E8%B3%BD%E9%A6%AC%E7%9B%9B%E4%BA%8B%E6%9C%89%E6%B5%B7%E5%A4%96%E9%A6%AC%E8%BF%B7%E7%B5%84%E5%9C%98%E4%BE%86%E6%B8%AF+%E6%96%99%E4%BA%BA%E5%9D%87%E6%B6%88%E8%B2%BB5%E8%87%B310%E8%90%AC"}, {"title": "\u660e\u665a\u8f49\u6dbc\u5468\u65e5\u964d\u81f316\u5ea6 \u65b0\u754c\u518d\u4f4e\u5169\u4e09\u5ea6", "description": "<p>\u5929\u6587\u53f0\u8868\u793a\uff0c\u6771\u5317\u5b63\u5019\u98a8\u6b63\u5f71\u97ff\u83ef\u5357\uff0c\u5c55\u671b\u672a\u4f86\u5169\u4e09\u65e5\u90e8\u5206\u6642\u9593\u6709\u967d\u5149\uff0c\u660e\u665a\u8f49\u6dbc\uff0c\u661f\u671f\u65e5\u53ca\u661f\u671f\u4e00\u5e02\u5340\u6700\u4f4e\u6c23\u6eab\u964d\u81f3\u7d0416\u300117\u5ea6\uff0c\u65b0\u754c\u518d\u4f4e\u5169\u4e09\u5ea6\uff0c\u4e0b\u5468\u4e2d\u671f\u6c23\u6eab\u7a0d\u70ba\u56de\u5347\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3948398/%E6%98%8E%E6%99%9A%E8%BD%89%E6%B6%BC%E5%91%A8%E6%97%A5%E9%99%8D%E8%87%B316%E5%BA%A6+%E6%96%B0%E7%95%8C%E5%86%8D%E4%BD%8E%E5%85%A9%E4%B8%89%E5%BA%A6"}, {"title": "\u5357\u97d3\u53cd\u5c0d\u9ee8\u8b70\u54e1\u7a31\u63a5\u5831\u6216\u518d\u6b21\u6212\u56b4", "description": "<p>\u64da\u97d3\u806f\u793e\u5831\u9053\uff0c\u5357\u97d3\u4e3b\u8981\u53cd\u5c0d\u9ee8\u6c11\u4e3b\u9ee8\u7a31\uff0c\u5728\u6536\u5230\u591a\u4efd\u6709\u95dc\u518d\u6b21\u5ba3\u5e03\u6212\u56b4\u4ee4\u7684\u5831\u544a\u5f8c\uff0c\u8a72\u9ee8\u8b70\u54e1\u5df2\u9032\u5165\u5f85\u547d\u72c0\u614b\u3002</p>\n<p>\u64da\u5831\uff0c\u6c11\u4e3b\u9ee8\u9084\u5c07\u65bc\u5468\u4e94\u4e0a\u5348\u53ec\u958b\u7dca\u6025\u6703\u8b70\u3002</p>\n<p>\u5357\u97d3\u7e3d\u7d71\u5c39\u932b\u6085\u5468\u4e8c\u6df1\u591c\u7a81\u7136\u9812\u5e03\u7dca\u6025\u6212\u56b4\u4ee4\uff0c6\u5c0f\u6642\u5f8c\u5ba3\u5e03\u89e3\u9664\uff0c\u4e8b\u4ef6\u6301\u7e8c\u767c\u9175\uff0c\u5f15\u767c\u5168\u570b\u591a\u5730\u793a\u5a01\uff0c\u8981\u6c42\u5c39\u932b\u6085\u4e0b\u53f0\u3002</p>\n<p>\u7576\u5730\u4e00\u9805\u6c11\u8abf\u65bc\u672c\u67083\u65e5\u81f35\u65e5\u8a2a\u554f1001\u540d\u9078\u6c11\uff0c\u7d50\u679c\u986f\u793a\uff0c<span style=\"font-size-ignore:13pt;\">\u5c39\u932b\u6085\u65bd\u653f\u597d\u8a55\u7387\u70ba16%\uff0c\u8f03\u4e0a\u5468\u4e0b\u964d3\u500b\u767e\u5206\u9ede\uff0c\u5275\u5176\u57f7\u653f\u7684\u65b0\u4f4e\uff1b\u5dee\u8a55\u738775%\uff0c\u5247\u5275\u65b0\u9ad8\u3002</span><span style=\"font-size-ignore:13pt;\">\u82e5\u4ee5\u5c39\u932b\u6085\u767c\u5e03\u7dca\u6025\u6212\u56b4\u4e4b\u5f8c\u76844\u65e5\u81f35\u65e5\u7d71\u8a08\u70ba\u6e96\uff0c\u5176\u597d\u8a55\u7387\u66f4\u8dcc\u81f313%\uff0c\u5dee\u8a55\u7387\u5347\u81f380%\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3948382/%E5%8D%97%E9%9F%93%E5%8F%8D%E5%B0%8D%E9%BB%A8%E8%AD%B0%E5%93%A1%E7%A8%B1%E6%8E%A5%E5%A0%B1%E6%88%96%E5%86%8D%E6%AC%A1%E6%88%92%E5%9A%B4"}, {"title": "\u6eec\u6df1\u80a1\u5e02\u534a\u65e5\u5347\u903e1% \u5275\u696d\u677f\u6f32\u903e2%", "description": "<p>\u5e02\u5834\u61a7\u61ac\u5167\u5730\u4e0b\u5468\u53ec\u958b\u4e2d\u592e\u7d93\u6fdf\u5de5\u4f5c\u6703\u8b70\u6703\u5e36\u4f86\u597d\u6d88\u606f\uff0cA\u80a1\u4e0a\u63da\u3002\u4e0a\u8b49\u6307\u6578\u534a\u65e5\u5347\u903e1%\uff0c\u91cd\u4e0a3400\u9ede\u95dc\u53e3\uff0c\u5275\u696d\u677f\u66f4\u6f32\u903e2%\u3002</p>\n<p>\u4e0a\u8b49\u6307\u6578\u6700\u591a\u8dcc4\u9ede\u62160.14%\uff0c\u4f4e\u898b3364\u9ede\uff0c\u96a8\u5f8c\u6709\u8cb7\u76e4\u6e67\u73fe\uff0c\u5927\u5e02\u56de\u5347\uff0c\u6700\u5012\u591a\u534749\u9ede\u62161.47%\uff0c\u9ad8\u898b3418\u9ede\uff0c\u534a\u65e5\u6536\u5e02\u58313410\u9ede\uff0c\u534741\u9ede\u62161.23%\uff0c\u6210\u4ea44380.43\u5104\u5143(\u4eba\u6c11\u5e63\u2027\u4e0b\u540c)\u3002</p>\n<p>\u6df1\u6210\u6307\u6700\u591a\u8dcc15\u9ede\u62160.15%\uff0c\u4f4e\u898b10618\u9ede\u5f8c\u5598\u5b9a\u56de\u7a69\uff0c\u6700\u591a\u5347225\u9ede\u62162.12%\uff0c\u9ad8\u898b10860\u9ede\uff0c\u534a\u65e5\u6536\u5e02\u583110825\u9ede\uff0c\u5347190\u9ede\u62161.79%\uff0c\u6210\u4ea47111.97\u5104\u5143\u3002</p>\n<p>\u6eec\u6df1300\u6307\u6578\u6536\u58313983\u9ede\uff0c\u534761\u9ede\u62161.57%\uff1b\u5275\u696d\u677f\u6307\u6578\u6536\u58312276\u9ede\uff0c\u534755\u9ede\u62162.49%\u3002</p>\n<p>\u5404\u677f\u584a\u666e\u904d\u9020\u597d\uff0c\u50b3\u5a92\u5a1b\u6a02\u5347\u903e3%\uff1b\u91d1\u878d\u80a1\u5347\u903e2%\uff1b\u92fc\u9435\u3001\u6c34\u6ce5\u3001\u5316\u5de5\u3001\u623f\u5730\u7522\u80a1\u5347\u903e1%\uff1b\u7164\u70ad\u3001\u6709\u8272\u91d1\u5c6c\u3001\u96fb\u529b\u3001\u77f3\u6cb9\u3001\u6c7d\u8eca\u88fd\u9020\u80a1\u9760\u7a69\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3948393/%E6%BB%AC%E6%B7%B1%E8%82%A1%E5%B8%82%E5%8D%8A%E6%97%A5%E5%8D%87%E9%80%BE1%25+%E5%89%B5%E6%A5%AD%E6%9D%BF%E6%BC%B2%E9%80%BE2%25"}, {"title": "\u6d77\u95dc\u6253\u64ca\u8de8\u5883\u8f49\u904b\u5192\u724c\u8ca8 \u6aa2\u503c1100\u842c\u8ca8\u62d83\u4eba", "description": "<p><span style=\"font-size-ignore:13pt;\">\u9999\u6e2f\u6d77\u95dc\u8207\u5167\u5730\u53ca\u6fb3\u9580\u4e09\u5730\u6d77\u95dc\u63a1\u53d6\u806f\u5408\u57f7\u6cd5\u884c\u52d5\uff0c\u52a0\u5f37\u6aa2\u67e5\u5f9e\u4e09\u5730\u8f49\u53e3\u5f80\u5317\u7f8e\u3001\u6b50\u6d32\u3001\u975e\u6d32\u3001\u5357\u7f8e\u3001\u6771\u5357\u4e9e\u3001\u300c\u4e00\u5e36\u4e00\u8def\u300d\u6cbf\u7dda\u570b\u5bb6\u548c\u5730\u5340\u7684\u8ca8\u7269\uff0c\u4ee5\u904f\u6b62\u8de8\u5883\u53ca\u8f49\u53e3\u7684\u5192\u724c\u8ca8\u7269\u6d3b\u52d5\u3002</span></p>\n<p>\u884c\u52d5\u4e2d\uff0c\u9999\u6e2f\u6d77\u95dc\u5075\u783426\u5b97\u6848\u4ef6\uff0c\u6aa2\u7372\u5171\u7d043.6\u842c\u4ef6\u61f7\u7591\u5192\u724c\u8ca8\u7269\uff0c\u5305\u62ec\u96fb\u8a71\u914d\u4ef6\u3001\u624b\u8868\u3001\u7403\u8863\u548c\u624b\u888b\uff0c\u4f30\u8a08\u5e02\u503c\u5171\u7d041100\u842c\u5143\uff0c\u62d8\u63553\u540d\u5e74\u9f61\u4ecb\u4e4e27\u6b72\u81f358\u6b72\u7684\u7537\u8ca8\u8eca\u53f8\u6a5f\uff0c<span style=\"font-size-ignore:13pt;\">\u73fe\u6b63\u4fdd\u91cb\u5019\u67e5\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3948387/%E6%B5%B7%E9%97%9C%E6%89%93%E6%93%8A%E8%B7%A8%E5%A2%83%E8%BD%89%E9%81%8B%E5%86%92%E7%89%8C%E8%B2%A8+%E6%AA%A2%E5%80%BC1100%E8%90%AC%E8%B2%A8%E6%8B%983%E4%BA%BA"}]}