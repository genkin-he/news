6\u3002\u6c11\u5efa\u806f\u7acb\u6cd5\u6703\u8b70\u54e1\u674e\u4e16\u69ae\u8868\u793a\u5c0d\u4e8b\u4ef6\u611f\u5230\u9707\u9a5a\uff0c\u5411\u53d7\u5bb3\u8005\u53ca\u5176\u5bb6\u4eba\u9001\u4e0a\u6df1\u5207\u6170\u554f\u3002\u4ed6\u95dc\u6ce8\u5321\u667a\u6703\u4e8b\u9694\u5169\u500b\u6708\u624d\u516c\u5e03\u4e8b\u4ef6\u7684\u539f\u56e0\uff0c\u8a8d\u70ba\u6a5f\u69cb\u7684\u8655\u7406\u65b9\u5f0f\u8207\u793e\u6703\u671f\u671b\u6709\u843d\u5dee\uff0c\u4ed6\u53c8\u63d0\u5230\u73fe\u6642\u6027\u7f6a\u884c\u5b9a\u7f6a\u7d00\u9304\u53ea\u80fd\u67e5\u6838\u5230\u6700\u8fd1\u4e09\u5e74\u7684\u5b9a\u7f6a\uff0c\u671f\u671b\u653f\u5e9c\u8207\u696d\u754c\u7814\u7a76\u6309\u7f6a\u884c\u56b4\u91cd\u7a0b\u5ea6\u5ef6\u9577\u7d00\u9304\u5e74\u671f\u3002</span></p>\n<p>\u5321\u667a\u6703\u6628\u65e5\u8868\u793a\uff0c\u4eca\u5e748\u6708\u63a5\u7372\u5b78\u54e1\u5bb6\u9577\u67e5\u8a62\u5f8c\u7ffb\u67e5\u9589\u8def\u96fb\u8996\uff0c\u767c\u73fe\u4e00\u540d20\u6b72\u7537\u9662\u53cb\u53ca\u4e00\u540d21\u6b72\u5973\u9662\u53cb\u61f7\u7591\u66fe\u88ab\u300c\u50b7\u5bb3\u300d\uff0c\u53c8\u7a31\u8a72\u54e1\u5de5\u56e0\u9055\u53cd\u54e1\u5de5\u884c\u70ba\u5b88\u5247\uff0c\u5df2\u88ab\u5373\u6642\u89e3\u50f1\u3002</p>\n<p>\u674e\u4e16\u69ae\u8868\u793a\uff0c\u7559\u610f\u5230\u4e8b\u4ef6\u65bc8\u6708\u767c\u751f\uff0c\u60df\u5321\u667a\u6703\u76f4\u81f3\u6628\u65e5\u624d\u767c\u8072\u660e\u516c\u5e03\u4e8b\u4ef6\uff0c\u5766\u8a00\u5c0d\u6a5f\u69cb\u7684\u8655\u7406\u65b9\u6cd5\u6709\u671f\u671b\u843d\u5dee\uff0c\u8a8d\u70ba\u5927\u773e\u6709\u77e5\u60c5\u6b0a\uff0c\u8cea\u7591\u5321\u667a\u6703\u4e8b\u767c\u5169\u500b\u6708\u624d\u5c0d\u5916\u516c\u5e03\uff0c\u5c0d\u670d\u52d9\u4f7f\u7528\u8005\u9020\u6210\u4e0d\u516c\uff0c\u4fc3\u8acb\u793e\u7f72\u53ca\u5321\u667a\u6703\u89e3\u91cb\u5ef6\u9072\u5169\u500b\u6708\u516c\u5e03\u4e8b\u4ef6\u7684\u539f\u56e0\u3002\u4ed6\u53c8\u671f\u671b\u793e\u6703\u798f\u5229\u7f72\u53ca\u5321\u667a\u6703\u5b8c\u6210\u8abf\u67e5\u5f8c\uff0c\u5230\u7acb\u6cd5\u6703\u798f\u5229\u4e8b\u52d9\u59d4\u54e1\u6703\u4ea4\u4ee3\u4e8b\u4ef6\uff0c\u5171\u540c\u6aa2\u8996\u6a5f\u69cb\u63d0\u4f9b\u670d\u52d9\u671f\u9593\u662f\u5426\u6709\u6f0f\u6d1e\u3002</p>\n<p>\u53e6\u5916\uff0c\u674e\u4e16\u69ae\u7559\u610f\u5230\u73fe\u6642\u6027\u7f6a\u884c\u5b9a\u7f6a\u7d00\u9304\u53ea\u80fd\u67e5\u5230\u6700\u8fd1\u4e09\u5e74\u7684\u72af\u7f6a\u7d00\u9304\uff0c\u5efa\u8b70\u653f\u5e9c\u8207\u696d\u754c\u5546\u8a0e\uff0c\u7814\u7a76\u5ef6\u9577\u7d00\u9304\u5e74\u671f\uff0c\u300c\u500b\u4eba\u8a8d\u70ba\uff0c\u5982\u679c\u500b\u6848\u56b4\u91cd\u3001\u88ab\u5b9a\u7f6a\u5605\u8a71\uff0c\u61c9\u8a72\u653e\u55ba\u7d00\u9304\u5230\uff0c\u56e0\u70ba\u5766\u767d\u8b1b\uff0c\u90fd\u597d\u96e3\u6709\u6a5f\u69cb\u6216\u8005\u5e02\u6c11\u6703\u518d\u76f8\u4fe1\u72af\u904e\u5481\u56b4\u91cd\u7f6a\u884c\u5605\u4eba\u300d\uff0c\u5efa\u8b70\u6309\u72af\u7f6a\u56b4\u91cd\u7a0b\u5ea6\u76f8\u61c9\u5ef6\u9577\u7d00\u9304\u5e74\u671f\u3002</p>\n<p>\u674e\u4e16\u69ae\u4fc3\u8acb\u653f\u5e9c\u53ca\u90e8\u9580\u91cd\u65b0\u6aa2\u8996\u76e3\u7763\u60c5\u6cc1\uff0c\u5c07\u6f5b\u5728\u98a8\u96aa\u6e1b\u70ba\u96f6\uff0c\u76f8\u4fe1\u7acb\u6cd5\u6703\u8b70\u54e1\u53ca\u696d\u754c\u9858\u610f\u5171\u540c\u60f3\u8fa6\u6cd5\uff0c\u5835\u585e\u6f0f\u6d1e\uff0c\u4ee5\u53ca\u6539\u5584\u76f8\u95dc\u60c5\u6cc1\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3910281/%E5%8C%A1%E6%99%BA%E6%9C%83%E8%81%B7%E5%93%A1%E6%80%A7%E4%BE%B5%E5%85%A9%E5%AD%B8%E5%93%A1+%E6%9D%8E%E4%B8%96%E6%A6%AE%E8%B3%AA%E7%96%91%E8%99%95%E7%90%86%E6%89%8B%E6%B3%95%E8%88%87%E7%A4%BE%E6%9C%83%E6%9C%9F%E6%9C%9B%E6%9C%89%E8%90%BD%E5%B7%AE"}, {"title": "\u8b70\u54e1\u95dc\u6ce8\u4eba\u624d\u8a08\u5283\u6f0f\u6d1e \u9ed1\u4e2d\u4ecb\u62db\u652c\u5347\u5b78\u79fb\u6c11", "description": "<p><span style=\"font-size-ignore:13pt;\">\u7acb\u6cd5\u6703\u8faf\u8ad6\u300c\u8ddf\u9032\u65b0\u4f86\u6e2f\u4eba\u624d\u878d\u5165\u9999\u6e2f\u63aa\u65bd\u300d\u8b70\u6848\u671f\u9593\uff0c\u591a\u540d\u8b70\u54e1\u95dc\u6ce8\u672c\u6e2f\u5f15\u5165\u4eba\u624d\u8a08\u5283\u51fa\u73fe\u6f0f\u6d1e\u3002\u8b70\u54e1\u9673\u6708\u660e\u8868\u793a\uff0c\u7559\u610f\u5230\u6709\u4eba\u53cd\u6620\uff0c\u6709\u6295\u6a5f\u5206\u5b50\u3001\u9ed1\u4e2d\u4ecb\u5229\u7528\u672c\u6e2f\u4eba\u624d\u8a08\u5283\u62db\u652c\u751f\u610f\uff0c\u5438\u5f15\u6709\u610f\u8b93\u5b50\u5973\u5728\u6e2f\u5347\u8b80\u5927\u5b78\u7684\u5167\u5730\u7236\u6bcd\uff0c\u5354\u52a9\u4ed6\u5011\u7533\u8acb\u300c\u9ad8\u624d\u901a\u300d\u7b49\u4eba\u624d\u8a08\u5283\uff0c\u4ee4\u8a72\u4e9b\u4e26\u975e\u4ee5\u5728\u6e2f\u5c31\u696d\u70ba\u76ee\u6a19\u7684\u5167\u5730\u4eba\u7684\u5bb6\u5c6c\uff0c\u8207\u672c\u5730\u5b78\u751f\u4e00\u540c\u7af6\u722d\u8cc7\u52a9\u5927\u5b78\u5b78\u984d\uff0c\u589e\u52a0\u672c\u5730\u5b78\u751f\u7684\u8ca0\u64d4\u3002\u4ed6\u4fc3\u8acb\u653f\u5e9c\u8ddf\u9032\u76f8\u95dc\u8ca0\u9762\u8072\u97f3\uff0c\u91cb\u9664\u516c\u773e\u7591\u616e\u3002</span></p>\n<p>\u9673\u6708\u660e\u8868\u793a\uff0c\u9451\u65bc\u8fd1\u671f\u672c\u6e2f\u51fa\u73fe\u5047\u5b78\u6b77\u4e2d\u4ecb\u7b49\u554f\u984c\uff0c\u5c0e\u81f4\u4eba\u624d\u8a08\u5283\u53d7\u5230\u6279\u8a55\uff0c\u4ed6\u95dc\u6ce8\u653f\u5e9c\u5728\u76e3\u7ba1\u65b9\u9762\u7684\u5de5\u4f5c\uff0c\u4fc3\u8acb\u653f\u5e9c\u7e7c\u7e8c\u6253\u64ca\u5047\u5b78\u6b77\uff0c\u5835\u585e\u6e90\u982d\uff0c\u4e26\u5728\u6279\u6838\u4eba\u624d\u4f86\u6e2f\u7533\u8acb\u6642\uff0c\u6aa2\u67e5\u76f8\u95dc\u5b78\u6b77\u8cc7\u6599\u7684\u771f\u5be6\u6027\u3002\u53e6\u5916\uff0c\u5979\u53c8\u8868\u793a\uff0c\u7559\u610f\u5230\u6709\u95dc\u6ce8\u5718\u9ad4\uff0c\u8cea\u7591\u6709\u6295\u6a5f\u5206\u5b50\uff0c\u5229\u7528\u4eba\u624d\u8a08\u5283\u62db\u652c\u751f\u610f\uff0c\u5438\u5f15\u4e26\u7121\u610f\u6b32\u5728\u6e2f\u5de5\u4f5c\u7684\u5167\u5730\u7236\u6bcd\u7533\u8acb\u4eba\u624d\u8a08\u5283\uff0c\u5f9e\u800c\u4ee4\u5176\u672a\u6210\u5e74\u5bb6\u5c6c\uff0c\u53ef\u4ee5\u8003\u53d6\u672c\u5730\u5927\u5b78\u8cc7\u52a9\u5b78\u984d\uff0c\u589e\u52a0\u672c\u6e2f\u5b78\u751f\u7684\u7af6\u722d\u548c\u8ca0\u64d4\u3002</p>\n<p>\u9673\u6708\u660e\u6307\u51fa\uff0c\u672c\u6e2f\u5404\u9662\u6821\uff0c\u6bcf\u5e74\u5927\u7d04\u53ea\u67091.5\u842c\u6559\u8cc7\u6703\u8cc7\u52a9\u5b78\u4f4d\uff0c\u800c\u900f\u904e\u4eba\u624d\u8a08\u5283\u4f86\u6e2f\u4eba\u58eb\u5e36\u540c\u7684\u5b50\u5973\u5927\u7d04\u67093\u842c\u4eba\uff0c\u4e5d\u6210\u70ba14\u6b72\u4ee5\u4e0b\uff0c\u7406\u8ad6\u4e0a\u4eba\u624d\u8a08\u5283\u4e0d\u6703\u589e\u52a0\u8cc7\u52a9\u5b78\u984d\u7af6\u722d\u60c5\u6cc1\uff0c\u4f46\u8a8d\u70ba\u653f\u5e9c\u4e0d\u59a8\u95dc\u6ce8\uff0c\u5982\u679c\u5b78\u751f\u79fb\u6c11\u5831\u8003DSE\u4eba\u6578\u4e0a\u5347\uff0c\u4ee4\u7af6\u722d\u5927\u5e45\u589e\u52a0\uff0c\u5c31\u61c9\u8a72\u8003\u616e\u8cc7\u52a9\u5b78\u984d\u662f\u5426\u6709\u5411\u4e0a\u8abf\u6574\u7684\u7a7a\u9593\u3002\u4ed6\u7e8c\u6307\uff0c\u82e5\u76f8\u95dc\u6307\u63a7\u4e0d\u6210\u7acb\uff0c\u70ba\u4fdd\u969c\u4eba\u624d\u8a08\u5283\u8072\u8b7d\uff0c\u653f\u5e9c\u5fc5\u9808\u8ddf\u9032\u8655\u7406\u8ca0\u9762\u8072\u97f3\uff0c\u5229\u7528\u771f\u5be6\u6578\u5b57\u91cb\u9664\u516c\u773e\u7591\u616e\u3002</p>\n<p>\u9999\u6e2f\u65b0\u65b9\u5411\u8b70\u54e1\u5f35\u6b23\u5b87\u8868\u793a\uff0c\u4efb\u4f55\u8a08\u5283\u90fd\u7e3d\u6703\u6709\u4eba\u5c0b\u6c42\u7a7a\u9593\uff0c\u5c07\u81ea\u5df1\u7684\u5229\u76ca\u6700\u5927\u5316\uff0c\u4e0d\u61c9\u8a72\u56e0\u70ba\u4eba\u624d\u8a08\u5283\u6709\u6f0f\u6d1e\u800c\u5426\u8a8d\u8a08\u5283\u6210\u529f\u4e4b\u8655\uff0c\u5c0d\u65bc\u5047\u5b78\u6b77\u4e2d\u4ecb\uff0c\u653f\u5e9c\u4ea6\u6709\u5805\u6c7a\u56de\u61c9\uff0c\u6d88\u9664\u793e\u6703\u9867\u616e\u3002\u53e6\u5916\uff0c\u4ed6\u627f\u8a8d\uff0c\u81ea\u5df1\u4e5f\u6709\u6536\u5230\u672c\u5730\u5bb6\u9577\u53cd\u6620\u6709\u4eba\u5229\u7528\u4eba\u624d\u8a08\u5283\u5b89\u6392\u5b50\u5973\u5347\u5b78\uff1b\u64da\u4ed6\u6240\u77e5\uff0c\u76ee\u524d\u60c5\u6cc1\u5c0d\u672c\u5730\u5b78\u984d\u885d\u64ca\u4e26\u4e0d\u5927\uff0c\u4f46\u8b49\u660e\u300c\u689d\u8def\u884c\u5f97\u901a\u300d\uff0c\u5018\u82e5\u76f8\u95dc\u500b\u6848\u4e0a\u5347\u5230\u5e7e\u5343\u500b\uff0c\u5c31\u6703\u592a\u9072\uff0c\u4ed6\u4fc3\u8acb\u653f\u5e9c\u76e1\u5feb\u8655\u7406\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3910283/%E8%AD%B0%E5%93%A1%E9%97%9C%E6%B3%A8%E4%BA%BA%E6%89%8D%E8%A8%88%E5%8A%83%E6%BC%8F%E6%B4%9E+%E9%BB%91%E4%B8%AD%E4%BB%8B%E6%8B%9B%E6%94%AC%E5%8D%87%E5%AD%B8%E7%A7%BB%E6%B0%91"}]}