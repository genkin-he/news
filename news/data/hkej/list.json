.hkej.com/instantnews/stock/article/3951726/%E3%80%90%E7%95%B0%E5%8B%95%E8%82%A1%E3%80%91%E9%AB%98%E9%91%AB%E9%9B%B6%E5%94%AE%E6%8F%9214%25%E5%BE%8C%E5%96%98%E7%A9%A9+%E6%89%AD%E8%99%A7%E6%88%90%E5%8A%9F%E5%AE%A3%E6%B4%BE%E4%B8%AD%E6%9C%9F%E6%81%AF17%E4%BB%99"}, {"title": "\u7f8e\u570b\u50b3\u8003\u616e\u5c0d\u4fc4\u7f85\u65af\u77f3\u6cb9\u5be6\u65bd\u65b0\u5236\u88c1", "description": "<p>\u5916\u96fb\u5831\u9053\uff0c\u7f8e\u570b\u62dc\u767b\u653f\u5e9c\u6b63\u8003\u616e\u5c0d\u4fc4\u7f85\u65af\u7684\u77f3\u6cb9\u8cbf\u6613\u5be6\u65bd\u66f4\u56b4\u53b2\u7684\u65b0\u5236\u88c1\uff0c\u4ee5\u5728\u5019\u4efb\u7e3d\u7d71\u7279\u6717\u666e\u4e0a\u53f0\u524d\u524a\u5f31\u4fc4\u7f85\u65af\u7e3d\u7d71\u666e\u4eac\u3002</p>\n<p>\u5831\u9053\u5f15\u8ff0\u6d88\u606f\u4eba\u58eb\u7a31\uff0c\u65b0\u63aa\u65bd\u7684\u7d30\u7bc0\u5c1a\u672a\u6700\u7d42\u78ba\u5b9a\uff0c\u4f46\u7e3d\u7d71\u62dc\u767b\u7684\u5718\u968a\u6b63\u8003\u616e\u53ef\u80fd\u91dd\u5c0d\u4fc4\u7f85\u65af\u90e8\u5206\u77f3\u6cb9\u51fa\u53e3\u7684\u9650\u5236\u63aa\u65bd\u3002\u83ef\u5e9c\u9084\u8003\u616e\u91dd\u5c0d\u4fc4\u7f85\u65af\u7528\u65bc\u904b\u8f38\u77f3\u6cb9\u7684\u6cb9\u8f2a\u5be6\u65bd\u65b0\u5236\u88c1\uff0c\u5c0d\u5f71\u5b50\u8239\u968a\u7684\u65b0\u9650\u5236\u53ef\u80fd\u6703\u5728\u672a\u4f86\u5e7e\u5468\u5167\u516c\u5e03\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3951734/%E7%BE%8E%E5%9C%8B%E5%82%B3%E8%80%83%E6%85%AE%E5%B0%8D%E4%BF%84%E7%BE%85%E6%96%AF%E7%9F%B3%E6%B2%B9%E5%AF%A6%E6%96%BD%E6%96%B0%E5%88%B6%E8%A3%81"}, {"title": "\u5bb6\u9577\u6295\u8a34\u672a\u80fd\u8d16\u56de\u6f22\u9f0e\u66f8\u9662\u5efa\u6821\u50b5\u5238 \u8b66\u65b9\u63a511\u4eba\u5831\u6848\u6d89\u6b3e580\u842c", "description": "<p>\u6e2f\u5cf6\u5357\u5340\u9ec3\u7af9\u5751\u79c1\u7acb\u5b78\u6821\u6f22\u9f0e\u66f8\u9662\u6709\u5bb6\u9577\u6295\u8a34\uff0c\u6307\u5b50\u5973\u9000\u5b782\u5e74\u5f8c\uff0c\u4ecd\u672a\u80fd\u8d16\u56de\u65e9\u524d\u8cfc\u8cb7\u5efa\u6821\u50b5\u5238\u768460\u842c\u5143\u6b3e\u9805\uff0c\u5df2\u5831\u8b66\u6c42\u52a9\u3002\u7acb\u6cd5\u6703\u8b70\u54e1\u6881\u7199\u63a5\u7372\u81f3\u5c1150\u591a\u540d\u5bb6\u9577\u6c42\u52a9\uff0c\u4f30\u8a08\u6d89\u53ca\u8d85\u904e3000\u842c\u5143\u3002</p>\n<p>\u8b66\u65b9\u8868\u793a\uff0c\u4e0a\u670815\u81f318\u65e5\u63a5\u737211\u540d\u5e02\u6c11\u5831\u6848\uff0c\u6307\u4ed6\u5011\u7684\u5b50\u5973\u5165\u8b80\u9ec3\u7af9\u5751\u9053\u4e00\u5b78\u6821\u6642\u8cfc\u5165\u5b78\u6821\u50b5\u5238\uff0c\u6d89\u6b3e\u5408\u5171\u7d04580\u842c\u5143\uff0c\u4f46\u5b50\u5973\u9000\u5b78\u5f8c\u672a\u7372\u9000\u9084\u76f8\u95dc\u6b3e\u9805\uff0c\u61f7\u7591\u53d7\u9a19\uff0c\u65bc\u662f\u5831\u6848\u3002\u8b66\u65b9\u7d93\u521d\u6b65\u8abf\u67e5\uff0c\u6848\u4ef6\u5217\u4f5c\u300c\u6c42\u8b66\u8abf\u67e5\u300d\uff0c\u4ea4\u7531\u897f\u5340\u8b66\u5340\u91cd\u6848\u7d44\u8ddf\u9032\uff0c\u66ab\u6642\u672a\u6709\u4eba\u88ab\u6355\u3002</p>\n<p>\u6559\u80b2\u5c40\u8868\u793a\uff0c\u4e00\u76f4\u56b4\u8085\u8ddf\u9032\u8a72\u6821\u7684\u7ba1\u7406\u53ca\u8ca1\u52d9\u60c5\u6cc1\uff0c\u9664\u4e86\u7763\u4fc3\u5b78\u6821\u5236\u5b9a\u53ca\u56e0\u61c9\u60c5\u6cc1\u66f4\u65b0\u5176\u7dca\u6025\u61c9\u8b8a\u8a08\u5283\uff0c\u4ea6\u8981\u6c42\u5b78\u6821\u66ab\u505c\u6536\u53d6\u5efa\u6821\u50b5\u5238\uff0c\u4ee5\u53ca\u5411\u6559\u80b2\u5c40\u6e05\u695a\u4ea4\u4ee3\u672a\u4f86\u7684\u767c\u5c55\u8def\u5411\u3002\u6559\u80b2\u5c40\u6703\u7e7c\u7e8c\u76e3\u5bdf\u5b78\u6821\u7684\u71df\u904b\u60c5\u6cc1\uff0c\u8207\u76f8\u95dc\u6301\u4efd\u8005\u4fdd\u6301\u7dca\u5bc6\u806f\u7e6b\uff0c\u4fdd\u969c\u5b78\u751f\u7684\u798f\u7949\u3002</p>\n<p>\u6839\u64da\u6f22\u9f0e\u66f8\u9662\u7db2\u7ad9\uff0c\u5efa\u6821\u50b5\u5238\u9762\u984d\u70ba60\u842c\u5143\uff0c\u9700\u65bc\u5165\u5b78\u8a3b\u518a\u524d\u4e00\u6b21\u6027\u7e73\u7d0d\uff0c\u6bcf\u5b78\u5e74\u6263\u6e1b\u5b78\u8cbb4.5\u842c\u5143\uff0c\u96e2\u6821\u5b78\u751f\u53ef\u7533\u8acb\u9000\u9084\u6263\u6e1b\u5f8c\u5269\u9918\u90e8\u5206\u3002\u5b78\u6821\u7531\u6148\u5584\u6a5f\u69cb\u76ca\u5229\u6a02\u751f\u6559\u80b2\u57fa\u91d1\u57282017\u5e74\u5275\u8fa6\uff0c\u63d0\u4f9b\u5c0f\u5b78\u3001\u4e2d\u5b78\u53ca\u5927\u5b78\u9810\u79d1\u8ab2\u7a0b\uff0c\u5b78\u8cbb\u6bcf\u5e74\u5206\u522519.8\u842c\u5143\u300120.8\u842c\u5143\u53ca21.8\u842c\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3951725/%E5%AE%B6%E9%95%B7%E6%8A%95%E8%A8%B4%E6%9C%AA%E8%83%BD%E8%B4%96%E5%9B%9E%E6%BC%A2%E9%BC%8E%E6%9B%B8%E9%99%A2%E5%BB%BA%E6%A0%A1%E5%82%B5%E5%88%B8+%E8%AD%A6%E6%96%B9%E6%8E%A511%E4%BA%BA%E5%A0%B1%E6%A1%88%E6%B6%89%E6%AC%BE580%E8%90%AC"}, {"title": "\u5357\u97d3\u570b\u6703\u8b70\u9577\u6c7a\u5b9a\u5c31\u6212\u56b4\u4e8b\u4ef6\u958b\u5c55\u570b\u653f\u8abf\u67e5", "description": "<p>\u97d3\u806f\u793e\u5831\u9053\uff0c\u5357\u97d3\u570b\u6703\u8b70\u9577\u79b9\u5143\u690d\u4eca\u65e5\u8868\u793a\uff0c\u570b\u6703\u5c07\u91dd\u5c0d\u7e3d\u7d71\u5c39\u932b\u6085\u5ba3\u5e03\u7dca\u6025\u6212\u56b4\u4e8b\u4ef6\u958b\u5c55\u570b\u653f\u8abf\u67e5\u3002</p>\n<p>\u64da\u6089\uff0c\u6b64\u6b21\u8abf\u67e5\u7531\u79b9\u5143\u690d\u884c\u4f7f\u8b70\u9577\u8077\u6b0a\u767c\u8d77\uff0c\u800c\u975e\u570b\u6703\u9ee8\u5718\u63d0\u51fa\u76f8\u95dc\u8981\u6c42\u3002\u570b\u6703\u4e00\u540d\u8ca0\u8cac\u4eba\u7a31\uff0c\u7531\u65bc\u6b64\u6b21\u4e8b\u614b\u56b4\u91cd\uff0c\u570b\u6703\u5c07\u76e1\u5feb\u8655\u7406\u6212\u56b4\u570b\u653f\u8abf\u67e5\u8a08\u5283\u66f8\u3002</p>\n<p>\u6b64\u5916\uff0c\u64da\u592e\u8996\u65b0\u805e\u5831\u9053\uff0c\u5357\u97d3\u6aa2\u65b9\u5c0d\u7279\u6230\u90e8\u968a\u53f8\u4ee4\u90e8\u9032\u884c\u6263\u62bc\u641c\u67e5\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3951732/%E5%8D%97%E9%9F%93%E5%9C%8B%E6%9C%83%E8%AD%B0%E9%95%B7%E6%B1%BA%E5%AE%9A%E5%B0%B1%E6%88%92%E5%9A%B4%E4%BA%8B%E4%BB%B6%E9%96%8B%E5%B1%95%E5%9C%8B%E6%94%BF%E8%AA%BF%E6%9F%A5"}, {"title": "\u4e2d\u570b\u8db3\u5354\u88c1\u5224\u7ba