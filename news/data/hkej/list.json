fe\u5927\u5e45\u6ce2\u52d5\u3002</p>\n<p>\u00a0</p>\n<p>\u8c9d\u840a\u5fb7(BlackRock)\u5411\u7f8e\u570b\u8b49\u5238\u4ea4\u6613\u59d4\u54e1\u6703\u65bc\u5468\u4e00(21\u65e5)\u63d0\u4ea4\u7684\u4ea4\u4ef6\u62ab\u9732\uff0c\u65bc\u7b2c\u4e09\u5b63\u5927\u624b\u589e\u6301\u62fc\u591a\u591a\u81f3\u7d041.32\u5104\u80a1\uff0c\u80a1\u6b0a\u75312.1%\u98c6\u5347\u81f39.5%\uff0c\u4e00\u5ea6\u523a\u6fc0\u62fc\u591a\u591a\u80a1\u50f9\u98c6\u5347\u903e8%\u3002</p>\n<p>\u4e0d\u904e\uff0c\u8c9d\u840a\u5fb7\u65bc\u5468\u4e8c(22\u65e5)\u5411\u7f8e\u570b\u8b49\u5238\u4ea4\u6613\u59d4\u54e1\u6703\u63d0\u4ea4<span style=\"font-size-ignore:13pt;\">\u4fee\u6b63\u6587\u4ef6\uff0c\u6f84\u6e05\u6301\u80a1\u91cf\u50c5\u70ba2.4%\u62163300\u842c\u80a1\uff0c\u5373\u7b2c\u4e09\u5b63\u50c5</span><span style=\"font-size-ignore:13pt;\">\u589e\u6301400\u842c\u80a1\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3909291/%E8%B2%9D%E8%90%8A%E5%BE%B7%E6%8C%81%E6%8B%BC%E5%A4%9A%E5%A4%9A%E8%82%A1%E6%AC%8A%E5%87%BA%E9%8C%AF+%E6%8C%81%E8%82%A1%E7%94%B19.5%25%E4%BF%AE%E6%AD%A3%E8%87%B32.4%25"}, {"title": "\u66fe\u5049\u96c4\u5bd3\u6240\u9047\u7aca \u9127\u70b3\u5f37:\u6751\u5c4b\u7206\u7aca\u6848\u589e\u8b66\u52a0\u7dca\u5de1\u908f", "description": "<p><span style=\"font-size-ignore:13pt;\">\u8b66\u52d9\u8655\u524d\u8655\u9577\u66fe\u5049\u96c4\u5728\u5927\u57d4\u5eb7\u6a02\u5712\u7684\u4f4f\u6240\u5468\u65e5(20\u65e5)\u665a\u4e0a\u906d\u7206\u7aca\uff0c\u521d\u6b65\u4e86\u89e3\u81f3\u5c11\u640d\u5931\u7d0410\u842c\u5143\u8ca1\u7269\u3002</span></p>\n<p>\u4fdd\u5b89\u5c40\u5c40\u9577\u9127\u70b3\u5f37\u5728\u96fb\u53f0\u7bc0\u76ee\u56de\u61c9\u6642\u8868\u793a\uff0c\u4eca\u5e74\u99968\u500b\u6708\u6574\u9ad4\u7f6a\u6848\u589e\u52a07.2%\uff0c\u7206\u7aca\u6848\u4ea6\u6709\u4e0a\u5347\uff0c\u5347\u5e45\u4e3b\u8981\u56e0\u70ba\u6751\u5c4b\u7206\u7aca\u6848\uff0c\u8b66\u65b9\u6703\u52a0\u7dca\u5de1\u908f\u3002\u4ed6\u53c8\u7a31\uff0c\u52a0\u88dd\u9589\u8def\u96fb\u8996\u6709\u6548\u9632\u6b62\u7f6a\u6848\uff0c2025\u5e74\u524d\u6703\u5b8c\u6210\u5b89\u88dd2000\u7d44\u9589\u8def\u96fb\u8996\uff0c\u672a\u4f86\u8a08\u5283\u6bcf\u5e74\u52a0\u88dd2000\u81f32500\u7d44\u3002</p>\n<p>\u9127\u70b3\u5f37\u5f37\u8abf\uff0c\u7576\u5c40\u975e\u5e38\u6ce8\u91cd\u79c1\u96b1\uff0c\u6703\u5728\u516c\u773e\u5730\u65b9\u5b89\u88dd\uff0c\u4e0d\u6703\u5f71\u5230\u79c1\u4eba\u5730\u65b9\uff0c\u73fe\u5834\u4ea6\u6703\u6709\u544a\u793a\u3002</p>\n<p>\u5728\u53e3\u5cb8\u65b9\u9762\uff0c\u9127\u70b3\u5f37\u6307\u660e\u5e74\u843d\u6210\u7684\u6c99\u982d\u89d2\u91cd\u5efa\u53e3\u5cb8\u6703\u4ee5\u8de8\u6cb3\u5efa\u6210\u65b9\u5f0f\uff0c\u5c07\u6703\u63a1\u7528\u5408\u4f5c\u67e5\u9a57\u3001\u4e00\u6b21\u653e\u884c\uff0c\u84ee\u5858/\u9999\u5712\u570d\u53e3\u5cb8\u7531\u65bc\u9762\u7a4d\u8f03\u5927\uff0c\u6b63\u8207\u5167\u5730\u90e8\u9580\u7814\u7a76\u662f\u5426\u53ef\u4ee5\u63a1\u7528\u76f8\u95dc\u6a21\u5f0f\u3002</p>\n<p>\u9127\u70b3\u5f37\u53c8\u63d0\u5230\uff0c\u4eca\u5e74\u5e95\u524d\u6703\u5728\u4e2d\u82f1\u8857\u8a2d\u7acb\u6aa2\u67e5\u7ad9\u5f15\u5165\u4eba\u9762\u8b58\u5225\u79d1\u6280\uff0c\u5e0c\u671b\u628a\u6709\u95dc\u6280\u8853\u65e5\u5f8c\u61c9\u7528\u5728\u95dc\u53e3\uff0c\u5982\u6cb3\u5957\u5340\uff0c\u4ee5\u65b9\u4fbf\u76f8\u95dc\u5e02\u6c11\u9032\u51fa\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3909293/%E6%9B%BE%E5%81%89%E9%9B%84%E5%AF%93%E6%89%80%E9%81%87%E7%AB%8A+%E9%84%A7%E7%82%B3%E5%BC%B7%3A%E6%9D%91%E5%B1%8B%E7%88%86%E7%AB%8A%E6%A1%88%E5%A2%9E%E8%AD%A6%E5%8A%A0%E7%B7%8A%E5%B7%A1%E9%82%8F"}, {"title": "\u7d10\u6642:\u82e5\u8cc0\u9326\u9e97\u7576\u9078 \u6234\u8499\u8003\u616e\u5165\u95a3", "description": "<p>\u300a\u7d10\u7d04\u6642\u5831\u300b\u5f15\u8ff0\u6d88\u606f\u4eba\u58eb\u6307\uff0c<span style=\"font-size-ignore:13pt;\">\u82e5\u7f8e\u570b\u526f\u7e3d\u7d71\u517c\u6c11\u4e3b\u9ee8\u7e3d\u7d71\u5019\u9078\u4eba\u8cc0\u9326\u9e97</span><span style=\"font-size-ignore:13pt;\">\u8d0f\u5f97\u7f8e\u570b\u7e3d\u7d71\u5927\u9078\uff0c\u6469\u6839\u5927\u901a\u884c\u653f\u7e3d\u88c1\u6234\u8499(Jamie Dimon)\u5c07\u8003\u616e\u5165\u95a3\uff0c\u53ef\u80fd\u64d4\u4efb\u8ca1\u653f\u90e8\u9577\uff0c\u4e26\u7a31\u4ed6</span><span style=\"font-size-ignore:13pt;\">\u6c92\u6709\u516c\u958b\u8868\u660e\u7acb\u5834\u662f\u56e0\u70ba\u64d4\u5fc3\u842c\u4e00\u5171\u548c\u9ee8\u5019\u9078\u4eba\u7279\u6717\u666e\u52dd\u51fa\uff0c\u81ea\u5df1\u6703\u906d\u5230\u5831\u5fa9\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u9577\u4e45\u4ee5\u4f86\uff0c</span><span style=\"font-size-ignore:13pt;\">\u6234\u8499</span><span style=\"font-size-ignore:13pt;\">\u4e00\u76f4\u662f\u7f8e\u570b\u7d93\u6fdf\u653f\u7b56\u9ad8\u5c64\u8077\u4f4d\u7684\u71b1\u9580\u4eba\u9078\u3002\u4ed6</span><span style=\"font-size-ignore:13pt;\">\u5c0d\u7d93\u6fdf\u548c\u653f\u7b56\u8b70\u984c\u4ea6\u76f4\u8a00\u4e0d\u8af1\uff0c\u7d93\u5e38\u7a31\u980c\u7f8e\u570b\u7684\u512a\u7570\u6027\u3002\u4ed6\u66fe\u5c0d\u5206\u6790\u5e2b\u8868\u793a\uff0c\u4ed6\u662f\u7f8e\u570b\u611b\u570b\u8005\uff0c\u570b\u5bb6\u6bd4\u5176\u516c\u53f8\u66f4\u52a0\u91cd\u8981\u3002</span></p>\n<p>\u64da\u5831\uff0c\u6234\u8499\u79c1\u4e0b\u660e\u78ba\u8868\u614b\u652f\u6301\u8cc0\u9326\u9e97\uff0c\u82e5\u8cc0\u9326\u9e97\u8d0f\u5f97\u5927\u9078\uff0c\u4ed6\u9858\u610f\u52a0\u5165\u5176\u653f\u5e9c\uff0c\u53ef\u80fd\u6703\u64d4\u4efb\u8ca1\u9577\u4e00\u8077\u3002</p>\n<p>\u7136\u800c\uff0c\u5728\u672c\u6708\u7a0d\u65e9\u6469\u901a\u7684\u8ca1\u5831\u5f8c\u96fb\u8a71\u6703\u8b70\u4e0a\uff0c\u6234\u8499\u8868\u793a\uff0c\u53d7\u9080\u64d4\u4efb\u653f\u5e9c\u8077\u52d9\u7684\u53ef\u80fd\u6027\u5e7e\u4e4e\u70ba\u96f6\uff0c\u4f46<span style=\"font-size-ignore:13pt;\">\u4fdd\u7559\u91cd\u65b0\u8003\u616e\u7684\u6b0a\u5229\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3909284/%E7%B4%90%E6%99%82%3A%E8%8B%A5%E8%B3%80%E9%8C%A6%E9%BA%97%E7%95%B6%E9%81%B8+%E6%88%B4%E8%92%99%E8%80%83%E6%85%AE%E5%85%A5%E9%96%A3"}, {"title": "ARM\u64da\u5831\u5c07\u53d6\u6d88\u5c0d\u9ad8\u901a\u6676\u7247\u8a2d\u8a08\u8a31\u53ef", "description": "<p>\u5916\u96fb\u5f15\u8ff0\u4e00\u4ef6\u6587\u4ef6\u5831\u9053\uff0c\u82f1\u570b\u6676\u7247\u8a2d\u8a08\u5546ARM\u8a08\u5283\u53d6\u6d88\u4e00\u9805\u67b6\u69cb\u8a31\u53ef\u5354\u8b70\uff0c\u8a72\u5354\u8b70\u5141\u8a31\u9577\u671f\u5408\u4f5c\u5925\u4f34\u9ad8\u901a(Qualcomm)\u4f7f\u7528ARM\u7684\u77e5\u8b58\u7522\u6b0a\u4f86\u8a2d\u8a08\u6676\u7247\u3002</p>\n<p>\u6587\u4ef6\u986f\u793a\uff0cARM\u5df2\u63d0\u524d60\u5929\u901a\u77e5\u9ad8\u901a\u8981\u53d6\u6d88\u8a31\u53ef\u5354\u8b70\u3002</p>\n<p>\u5831\u9053\u6307\uff0cARM\u6b64\u8209\u53ef\u80fd\u6703\u64fe\u4e82\u667a\u80fd\u624b\u6a5f\u548c\u500b\u4eba\u96fb\u8166\u5e02\u5834\uff0c\u6253\u4e82\u5169\u9593\u516c\u53f8\u7684\u8ca1\u52d9\u548c\u904b\u71df\u3002\u5982\u679c\u843d\u5be6\u53d6\u6d88\u8a31\u53ef\u5354\u8b70\uff0c\u9ad8\u901a\u53ef\u80fd\u4e0d\u5f97\u4e0d\u505c\u6b62\u92b7\u552e\u5728\u5176\u7d04390\u5104\u7f8e\u5143\u6536\u5165\u4e2d\u4f54\u5f88\u5927\u4e00\u90e8\u5206\u7684\u7522\u54c1\uff0c\u5426\u5247\u5c07\u9762\u81e8\u5de8\u984d\u7d22\u511f\u3002</p>\n<p>ARM\u65e9\u65bc2022\u5e74\u958b\u59cb\u5df2\u8d77\u8a34\u9ad8\u901a\u9055\u53cd\u5408\u540c\u548c\u5546\u6a19\u4fb5\u6b0a\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3909295/ARM%E6%93%9A%E5%A0%B1%E5%B0%87%E5%8F%96%E6%B6%88%E5%B0%8D%E9%AB%98%E9%80%9A%E6%99%B6%E7%89%87%E8%A8%AD%E8%A8%88%E8%A8%B1%E5%8F%AF"}]}