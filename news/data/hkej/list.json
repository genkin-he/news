e6\u4e00\u5957\u903e\u842c\u65b9\u544e\u5927\u5b85\u70ba1\u865f\u5c4b\uff0c\u5be6\u7528\u9762\u7a4d11660\u65b9\u544e\uff0c\u96c6\u5718\u5c07\u7e7c\u7e8c\u63a1\u53d6\u60dc\u552e\u7b56\u7565\u6309\u6b65\u63a8\u51fa\u5e02\u5834\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u694a\u653f\u9f8d\u7e8c\u6307\uff0c</span><span style=\"font-size-ignore:13pt;\">2\u865f\u6d0b\u623f\u6210\u4ea4\u50f9\u5275\u4eca\u5e74\u6e2f\u5cf6\u5168\u65b0\u6d0b\u623f\u65b0\u9ad8\uff0c\u8b49\u660e\u5e02\u5834\u5c0d\u77dc\u7f55\u7684\u4f4f\u5b85\u7269\u696d\u9700\u6c42\u6bb7\u5207\u3002\u6628\u65e5\u65b0\u4e00\u4efd\u300a\u65bd\u653f\u5831\u544a\u300b\u653e\u5bec\u300c\u65b0\u8cc7\u672c\u6295\u8cc7\u8005\u5165\u5883\u8a08\u5283\u300d\u5bb9\u8a31\u6295\u8cc75000\u842c\u5143\u6216\u4ee5\u4e0a\u7684\u4f4f\u5b85\u7269\u696d\uff0c\u8a72\u63aa\u65bd\u76f4\u63a5\u5c0d\u8c6a\u5b85\u7269\u696d\u5e02\u5834\u8d77\u5897\u503c\u7684\u4f5c\u7528\uff0c\u4e26\u9f13\u52f5\u6d77\u5916\u5c08\u624d\u6295\u8cc7\u9999\u6e2f\u8c6a\u5b85\u7269\u696d\uff0c\u512a\u8cea\u7269\u696d\u7684\u9020\u50f9\u7e7c\u7e8c\u7a69\u6b65\u4e0a\u63da\uff0c\u6a13\u5e02\u53ca\u6a13\u50f9\u4ea6\u6703\u91cd\u62fe\u6b63\u8ecc\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u73fe\u6642\u58fd\u81e3\u5c7115\u865f\u5171\u6cbd\u51fa7\u5e62\u6d0b\u623f\uff0c\u5957\u73fe\u8fd139\u5104\u5143\uff1b\u96c6\u5718\u5e74\u521d\u81f3\u4eca\u7d2f\u6cbd178\u4f19\uff0c\u5957\u73fe\u7e3d\u984d\u903e41\u5104\u5143\u3002<br /></span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3905284/%E5%A3%BD%E8%87%A3%E5%B1%B115%E8%99%9F2%E8%99%9F%E5%B1%8B8.45%E5%84%84%E6%B2%BD+%E5%89%B5%E4%BB%8A%E5%B9%B4%E6%B8%AF%E5%B3%B6%E5%85%A8%E6%96%B0%E6%B4%8B%E6%88%BF%E6%96%B0%E9%AB%98"}, {"title": "\u65bd\u653f\u5831\u544a\u4e28\u6e2f\u6fb3\u8fa6:\u7c21\u6a38\u623f\u6709\u5e8f\u89e3\u6c7a\u528f\u623f\u554f\u984c \u7372\u5e02\u6c11\u5145\u5206\u80af\u5b9a", "description": "<p><span style=\"font-size-ignore:13pt;\">\u570b\u52d9\u9662\u6e2f\u6fb3\u8fa6\u767c\u8868\u7f72\u540d\u300c\u6e2f\u6fb3\u5e73\u300d\u7684\u6587\u7ae0\uff0c\u6307\u884c\u653f\u9577\u5b98\u674e\u5bb6\u8d85\u767c\u8868\u4efb\u5167\u7b2c\u4e09\u4efd\u300a\u65bd\u653f\u5831\u544a\u300b\uff0c\u9999\u6e2f\u793e\u6703\u548c\u570b\u969b\u793e\u6703\u9ad8\u5ea6\u95dc\u6ce8\u4e26\u7a4d\u6975\u8a55\u8ad6\uff0c\u5f9e\u5831\u544a\u7684\u8c50\u5bcc\u5167\u5bb9\u548c\u5404\u65b9\u9762\u7684\u71b1\u70c8\u53cd\u61c9\u4e2d\uff0c\u53ef\u4ee5\u611f\u53d7\u5230\u7279\u5340\u653f\u5e9c\u92b3\u610f\u6539\u9769\u3001\u596e\u767c\u9032\u53d6\u3001\u9020\u798f\u6c11\u773e\u7684\u5805\u5b9a\u4fe1\u5ff5\u548c\u5805\u5be6\u884c\u52d5\u3002</span></p>\n<p>\u6587\u7ae0\u6307\u51fa\uff0c\u674e\u5bb6\u8d85\u5728\u53c3\u9078\u884c\u653f\u9577\u5b98\u6642\u5c31\u660e\u78ba\u63d0\u51fa\u300c\u5fc5\u9808\u6709\u8b8a\u9769\u7cbe\u795e\u300d\uff0c\u5c31\u4efb\u5f8c\u5e36\u9818\u65b0\u4e00\u5c46\u7279\u5340\u653f\u5e9c\u624e\u5be6\u63a8\u9032\u5404\u9805\u6539\u9769\uff0c\u6b64\u6b21\u300a\u65bd\u653f\u5831\u544a\u300b\u66f4\u9bae\u660e\u63d0\u51fa\u8981\u300c\u4e0d\u65b7\u6c42\u9032\u3001\u81ea\u6211\u9769\u65b0\u300d\uff0c\u300c\u8b58\u8b8a\u3001\u6c42\u8b8a\uff0c\u5b88\u6b63\u5275\u65b0\uff0c\u9748\u6d3b\u61c9\u5c0d\u6311\u6230\u548c\u6a5f\u9047\u300d\uff0c\u9084\u7cfb\u7d71\u95e1\u8ff0\u5176\u6539\u9769\u7406\u5ff5\uff0c\u63d0\u51fa\u6ce8\u91cd\u7cfb\u7d71\u89c0\u5ff5\u3002</p>\n<p>\u6e2f\u6fb3\u8fa6\u8a8d\u70ba\uff0c\u9019\u4efd\u300a\u65bd\u653f\u5831\u544a\u300b\u7e7c\u7e8c\u805a\u7126\u9020\u5730\u5efa\u5c4b\u3001\u4ea4\u901a\u904b\u8f38\u3001\u91ab\u7642\u885e\u751f\u3001\u6276\u8ca7\u52a9\u5f31\u3001\u9752\u5e74\u767c\u5c55\u3001\u52de\u5de5\u652f\u63f4\u7b49\u6c11\u751f\u6182\u96e3\u554f\u984c\u63d0\u51fa\u8a31\u591a\u5207\u5be6\u6709\u529b\u7684\u8209\u63aa\uff0c\u7279\u5225\u662f\u5c0d\u65bc\u5e02\u6c11\u5ee3\u6cdb\u95dc\u6ce8\u7684\u623f\u5c4b\u554f\u984c\uff0c\u300c\u7c21\u6a38\u623f\u300d\u7a69\u5b9a\u6709\u5e8f\u89e3\u6c7a\u300c\u528f\u623f\u300d\u9019\u500b\u8001\u5927\u96e3\u554f\u984c\uff0c\u5f97\u5230\u5e02\u6c11\u5145\u5206\u80af\u5b9a\u3002</p>\n<p>\u6587\u7ae0\u7a31\uff0c\u9999\u6e2f\u793e\u6703\u666e\u904d\u8a8d\u70ba\u300a\u65bd\u653f\u5831\u544a\u300b\u4ee5\u5b8f\u89c0\u8996\u91ce\u5be9\u8996\u5168\u5c40\uff0c\u5c0d\u9999\u6e2f\u672a\u4f86\u767c\u5c55\u7684\u8b00\u7bc7\u5e03\u5c40\u65b9\u5411\u660e\u78ba\u3001\u8def\u5f91\u6e05\u6670\u3001\u8209\u63aa\u5230\u4f4d\uff0c\u91dd\u5c0d\u6027\u3001\u96c6\u6210\u6027\u3001\u524d\u77bb\u6027\u5f37\uff0c\u8207\u904e\u53bb\u5169\u4efd\u300a\u65bd\u653f\u5831\u544a\u300b\u6240\u63d0\u653f\u7b56\u8209\u63aa\u9023\u8cab\u4e92\u88dc\uff0c\u70ba\u4e0d\u65b7\u589e\u5f37\u9999\u6e2f\u767c\u5c55\u52d5\u80fd\u63d0\u4f9b\u4e86\u91cd\u8981\u6307\u5f15\u548c\u9075\u5faa\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u6587\u7ae0\u63d0\u5230\uff0c\u8a31\u591a\u4eba\u58eb\u90fd\u8868\u793a\u300a\u65bd\u653f\u5831\u544a\u300b\u5728\u6c11\u751f\u75db\u9ede\u96e3\u9ede\u554f\u984c\u4e0a\u4f5c\u51fa\u8a31\u591a\u7a81\u7834\uff0c\u6709\u300c\u5fc3\u300d\u66f4\u6709\u300c\u884c\u300d\uff0c\u9ad4\u73fe\u51fa\u674e\u5bb6\u8d85\u548c\u65b0\u4e00\u5c46\u7279\u5340\u653f\u5e9c\u4ee5\u6c11\u70ba\u672c\u7684\u771f\u646f\u60c5\u61f7\u548c\u4e8b\u4e0d\u907f\u96e3\u7684\u8cac\u4efb\u64d4\u7576\uff0c\u6c11\u8abf\u986f\u793a\u903e\u4e03\u6210\u5e02\u6c11\u5c0d\u65bd\u653f\u5831\u544a\u611f\u5230\u6eff\u610f\u3002</span></p>\n<p>\u6e2f\u6fb3\u8fa6\u76f8\u4fe1\uff0c\u9999\u6e2f\u793e\u6703\u5404\u754c\u5718\u7d50\u4e00\u81f4\uff0c\u4ee5\u5be6\u969b\u884c\u52d5\u5168\u529b\u652f\u6301\u7279\u5340\u653f\u5e9c\u4f9d\u6cd5\u65bd\u653f\uff0c\u300c\u9f4a\u6539\u9769\u540c\u767c\u5c55 \u60e0\u6c11\u751f\u5efa\u672a\u4f86\u300d\uff0c\u7f8e\u597d\u9858\u666f\u5fc5\u5c07\u8b8a\u70ba\u8f1d\u714c\u73fe\u5be6\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3905280/%E6%96%BD%E6%94%BF%E5%A0%B1%E5%91%8A%E4%B8%A8%E6%B8%AF%E6%BE%B3%E8%BE%A6%3A%E7%B0%A1%E6%A8%B8%E6%88%BF%E6%9C%89%E5%BA%8F%E8%A7%A3%E6%B1%BA%E5%8A%8F%E6%88%BF%E5%95%8F%E9%A1%8C+%E7%8D%B2%E5%B8%82%E6%B0%91%E5%85%85%E5%88%86%E8%82%AF%E5%AE%9A"}, {"title": "\u6797\u5b9a\u570b:\u9999\u6e2f\u666e\u901a\u6cd5\u5236\u5ea6\u9808\u8207\u5167\u5730\u6cd5\u5236\u6709\u9069\u7576\u806f\u7e6b", "description": "<p>\u5f8b\u653f\u53f8\u53f8\u9577\u6797\u5b9a\u570b\u51fa\u5e2d\u6709\u95dc\u9999\u6e2f\u548c\u5167\u5730\u76f8\u4e92\u6cd5\u5f8b\u5354\u52a9\u7684\u8b1b\u5ea7\u6642\u8868\u793a\uff0c<span style=\"font-size-ignore:13pt;\">\u9999\u6e2f\u6cd5\u5f8b\u5236\u5ea6\u904b\u4f5c\u4e0d\u55ae\u6b62\u670d\u52d9\u9999\u6e2f\uff0c\u800c\u662f\u6574\u500b\u570b\u5bb6\u7684\u5229\u76ca\uff0c\u5169\u5957\u5236\u5ea6\u4e4b\u9593\u5fc5\u9808\u6709\u9069\u7576\u806f\u7e6b\uff0c\u5728\u6c11\u4e8b\u53ca\u5546\u4e8b\u6cd5\u4e8b\u5b9c\u4e0a\uff0c\u5167\u5730\u8207\u9999\u6e2f\u6cd5\u5f8b\u5236\u5ea6\u806f\u7e6b\u5efa\u7acb\u5728\u4e0d\u540c\u53f8\u6cd5\u76f8\u4e92\u5354\u5b9a\u4e0a\u3002</span></p>\n<p>\u6797\u5b9a\u570b\u7a31\uff0c\u653f\u5e9c\u5728\u65e9\u524d\u7c3d\u8a02\u7684CEPA\u7b2c\u4e8c\u4efd\u8cbf\u6613\u5354\u8b70\uff0c\u589e\u52a0\u4e86\u5167\u5730\u548c\u9999\u6e2f\u7684\u8de8\u5883\u4ef2\u88c1\u6a5f\u6703\uff0c\u904e\u5f80\u5167\u5730\u6cd5\u5f8b\u5c0d\u7576\u4e8b\u4eba\u7684\u9078\u64c7\u6709\u8f03\u591a\u9650\u5236\uff0c\u5354\u8b70\u63a8\u52d5\u5be6\u884c\u300c\u6e2f\u8cc7\u6e2f\u4ef2\u88c1\u300d\uff0c\u5728\u5927\u7063\u5340\u71df\u904b\u7684\u9999\u6e2f\u4f01\u696d\uff0c\u65e5\u5f8c\u6709\u6b0a\u9078\u64c7\u5728\u9999\u6e2f\u89e3\u6c7a\u6cd5\u5f8b\u7cfe\u7d1b\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3905285/%E6%9E%97%E5%AE%9A%E5%9C%8B%3A%E9%A6%99%E6%B8%AF%E6%99%AE%E9%80%9A%E6%B3%95%E5%88%B6%E5%BA%A6%E9%A0%88%E8%88%87%E5%85%A7%E5%9C%B0%E6%B3%95%E5%88%B6%E6%9C%89%E9%81%A9%E7%95%B6%E8%81%AF%E7%B9%AB"}, {"title": "\u5916\u5a92:\u4f4f\u5efa\u90e8\u8a18\u62db\u4e4f\u5927\u7206\u70b8\u5f0f\u523a\u6fc0 \u5e02\u5834\u96e3\u514d\u5931\u671b\u6216\u5c0d\u77ed\u671f\u6548\u679c\u5b58\u7591", "description": "<p>\u4f4f\u5efa\u90e8\u3001\u4eba\u6c11\u9280\u884c\u7b49\u90e8\u9580\u4eca\u65e9\u8209\u884c\u767c\u5e03\u6703\uff0c\u5ba3\u5e03\u589e\u52a0\u623f\u5730\u7522\u300c\u767d\u540d\u55ae\u300d\u9805\u76ee\u4fe1\u8cb8\u3001\u57ce\u4e2d\u6751\u6539\u9020\u8ca8\u5e63\u5316\u5b89\u7f6e\u7b49\u8209\u63aa\u3002\u5916\u96fb\u5831\u9053\uff0c\u8a18\u62db\u4ee4\u61a7\u61ac\u66f4\u591a\u91cd\u78c5\u7a69\u6a13\u5e02\u51fa\u53f0\u7684\u6295\u8cc7\u8005\u96e3\u514d\u5931\u671b\u3002</p>\n<p>\u5831\u9053\u6307\u51fa\uff0c\u96d6\u7136\u5305\u62ec\u4eba\u884c\u526f\u884c\u9577\u9676\u73b2\u5728\u5167\u7684\u5b98\u54e1\u5728\u767c\u5e03\u6703\u8868\u793a\uff0c\u6b63\u6293\u7dca\u7814\u7a76\u5141\u8a31\u653f\u7b56\u6027\u9280\u884c\u3001\u5546\u696d\u9280\u884c\u5411\u6709\u689d\u4ef6\u7684\u4f01\u696d\u767c\u653e\u8cb8\u6b3e\uff0c\u6536\u8cfc\u623f\u4f01\u5b58\u91cf\u571f\u5730\uff0c\u4f46\u9664\u4e86\u627f\u8afe\u6293\u7dca\u63a8\u52d5\u653f\u7b56\u76e1\u5feb\u843d\u5730\uff0c\u767c\u5e03\u6703\u672a\u5c31\u5b58\u91cf\u623f\u548c\u571f\u5730\u6536\u8cfc\u7b49\u7d66\u51fa\u5177\u9ad4\u91d1\u984d\u548c\u6642\u9593\u8868\u7b49\u589e\u91cf\u8a0a\u606f\u3002</p>\n<p>Union Bancaire Privee\u8463\u4e8b\u7e3d\u7d93\u7406Vey-Sern Ling\u8868\u793a\uff0c\u80a1\u7968\u6295\u8cc7\u8005\u6b63\u5728\u5c0b\u627e\u91cd\u78c5\u6578\u5b57\u4f86\u63a8\u52d5\u80a1\u5e02\u9032\u4e00\u6b65\u4e0a\u6f32\uff0c\u800c\u653f\u5e9c\u66f4\u5c08\u6ce8\u65bc\u63a8\u52d5\u7d93\u6fdf\u548c\u623f\u5730\u7522\u5e02\u5834\u4f01\u7a69\uff0c\u53ea\u8981\u9810\u671f\u5b58\u5728\u5982\u6b64\u5927\u7684\u932f\u914d\uff0c\u6240\u6709\u65b0\u805e\u767c\u5e03\u6703\u90fd\u5c07\u4e0d\u53ef\u907f\u514d\u5730\u4ee4\u4eba\u5931\u671b\u3002</p>\n<p>\u6771\u65b9\u532f\u7406\u7d93\u6fdf\u5b78\u5bb6\u6cbb\u66c9\u4f73\u8868\u793a\uff0c\u7e3d\u9ad4\u800c\u8a00\u9019\u4e9b\u63aa\u65bd\u662f\u6709\u5e6b\u52a9\uff0c\u96d6\u7136\u5e02\u5834\u53ef\u80fd\u671f\u5f85\u4e00\u4e9b\u5927\u7206\u70b8\u5f0f\u7684\u523a\u6fc0\u63aa\u65bd\u4f86\u63a8\u52d5\u623f\u5730\u7522\u5e02\u5834\u77ed\u671f\u4f01\u7a69\u3002\u9451\u65bc\u5df2\u5ba3\u5e03\u7684\u63aa\u65bd\u770b\u8d77\u4f86\u4ecd\u76f8\u7576\u6eab\u548c\uff0c\u5e02\u5834\u53ef\u80fd\u5c0d\u77ed\u671f\u6548\u679c\u4fdd\u6301\u61f7\u7591\u614b\u5ea6\u3002</p>\n<p>\u4e0a\u6d77\u6613\u5c45\u623f\u5730\u7522\u7814\u7a76\u9662\u526f\u9662\u9577\u56b4\u8e8d\u9032\u5247\u8a8d\u70ba\uff0c5\u90e8\u59d4\u806f\u5408\u53ec\u958b\u623f\u5730\u7522\u65b9\u9762\u7684\u767c\u5e03\u6703\u975e\u5e38\u7f55\u898b\uff0c\u5145\u5206\u8aaa\u660e\u623f\u5730\u7522\u7d44\u5408\u62f3\u5927\u529b\u51fa\u64ca\uff0c\u5176\u5c0d\u65bc\u7b2c\u56db\u5b63\u548c\u5f8c\u7e8c\u623f\u5730\u7522\u6b62\u8dcc\u56de\u7a69\u5c07\u767c\u63ee\u91cd\u8981\u7684\u4f5c\u7528\u3002<span style=\"font-size-ignore:13pt;\">\u6b64\u6b21\u653f\u7b56\u6700\u91cd\u78c5\u7684\u8868\u8ff0\u662f\uff0c\u57ce\u4e2d\u6751\u6982\u5ff5\u518d\u6b21\u51fa\u73fe\u3002\u56e0\u70ba\u57282014\u5e74\u623f\u5730\u7522\u7a69\u767c\u5c55\u7684\u904e\u7a0b\u4e2d\uff0c\u7576\u6642\u68da\u6539\u5de5\u4f5c\u6210\u70ba\u6a13\u5e02\u5feb\u901f\u8d70\u51fa\u4f4e\u8ff7\u884c\u60c5\u7684\u91cd\u8981\u5de5\u5177\u3002\u7e3d\u9ad4\u4e0a\u5c0d\u65bc\u66f4\u597d\u66f4\u5feb\u89e3\u6c7a\u5b89\u5c45\u5de5\u4f5c\u548c\u66f4\u597d\u6d88\u5316\u5eab\u5b58\u623f\u6e90\u7b49\uff0c\u5177\u6709\u7a4d\u6975\u4f5c\u7528\u3002</span></p>\n<p>\u4f4f\u5efa\u90e8\u90e8\u9577\u502a\u8679\u8868\u793a\uff0c\u5e74\u5e95\u524d\u5c07\u300c\u767d\u540d\u55ae\u300d\u9805\u76ee\u4fe1\u8cb8\u898f\u6a21\u589e\u52a0\u52304\u842c\u5104\u5143\u4eba\u6c11\u5e63\uff0c\u8981\u5c07\u6240\u6709\u5408\u683c\u9805\u76ee\u90fd\u722d\u53d6\u7d0d\u5165\u300c\u767d\u540d\u55ae\u300d\uff0c\u53c8\u7a31\u5c07\u901a\u904e\u8ca8\u5e63\u5316\u5b89\u7f6e\u65b9\u5f0f\uff0c\u65b0\u589e\u5be6\u65bd100\u842c\u5957\u57ce\u4e2d\u6751\u6539\u9020\u548c\u5371\u820a\u623f\u6539\u9020\uff0c\u53ea\u8981\u524d\u671f\u5de5\u4f5c\u505a\u5f97\u597d\uff0c\u9084\u53ef\u4ee5\u5728100\u842c\u5957\u57fa\u790e\u4e0a\u7e7c\u7e8c\u52a0\u5927\u652f\u6301\u529b\u5ea6\u3002</p>\n<p>\u4e2d\u6e2f\u80a1\u5e02\u5730\u7522\u677f\u584a\u4eca\u65e9\u4e0b\u6ed1\uff0c\u5728\u4f4f\u5efa\u90e8\u65b0\u805e\u767c\u5e03\u6703\u9032\u884c\u671f\u9593\uff0c\u8dcc\u5e45\u986f\u8457\u64f4\u5927\uff0c\u5c07\u4e0a\u65e5\u4e58\u7740\u8209\u884c\u8a18\u8005\u6703\u6d88\u606f\u6240\u7092\u4e0a\u7684\u5347\u5e45\u4e00\u5ea6\u6089\u6578\u56de\u5410\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3905274/%E5%A4%96%E5%AA%92%3A%E4%BD%8F%E5%BB%BA%E9%83%A8%E8%A8%98%E6%8B%9B%E4%B9%8F%E5%A4%A7%E7%88%86%E7%82%B8%E5%BC%8F%E5%88%BA%E6%BF%80+%E5%B8%82%E5%A0%B4%E9%9B%A3%E5%85%8D%E5%A4%B1%E6%9C%9B%E6%88%96%E5%B0%8D%E7%9F%AD%E6%9C%9F%E6%95%88%E6%9E%9C%E5%AD%98%E7%96%91"}, {"title": "\u65bd\u653f\u5831\u544a\u4e28\u674e\u5bb6\u8d85:\u6709\u9650\u8cc7\u6e90\u4e0b\u63d0\u5347\u516c\u71df\u91ab\u7642\u6548\u76ca \u7814\u8de8\u5c08\u79d1\u7d71\u7c4c\u5e73\u53f0", "description": "<p>\u300a\u65bd\u653f\u5831\u544a\u300b\u7b54\u554f\u6703\u65e9\u4e0a\u5728\u7acb\u6cd5\u6703\u8209\u884c\u3002\u672c\u8eab\u662f\u793e\u5de5\u7684\u300cA4\u806f\u76df\u300d\u8b70\u54e1\u6797\u7d20\u851a\u95dc\u6ce8\uff0c<span style=\"font-size-ignore:13pt;\">\u5831\u544a\u4e2d\u63d0\u51fa\u8a2d\u7acb\u8de8\u5c08\u79d1\u7d9c\u5408\u9580\u8a3a\u7684\u76f8\u95dc\u5b89\u6392\u3002</span></p>\n<p>\u884c\u653f\u9577\u5b98\u674e\u5bb6\u8d85\u8868\u793a\uff0c\u653f\u5e9c\u6bcf\u5e74\u5728\u91ab\u7642\u652f\u51fa\u975e\u5e38\u9f90\u5927\uff0c\u91ab\u7642\u662f\u653f\u5e9c\u958b\u652f\u6295\u5165\u7684\u524d\u4e09\u4f4d\uff0c\u7d04\u4f5420%\uff0c<span style=\"font-size-ignore:13pt;\">\u5728\u6709\u9650\u8cc7\u6e90\u4e0b\u9700\u8981\u63d0\u5347\u516c\u71df\u670d\u52d9\u7684\u6548\u76ca\u3002</span></p>\n<p>\u674e\u5bb6\u8d85\u6307\u51fa\uff0c\u8de8\u5c08\u79d1\u7d71\u7c4c\u662f\u6307\u540c\u4e00\u500b\u75c5\u4eba\u53ef\u80fd\u9700\u8981\u770b\u6ccc\u5c3f\u79d1\u3001\u5fc3\u81df\u79d1\u7b49\uff0c\u5982\u6709\u5c08\u79d1\u53ef\u4ee5\u7167\u9867\u5176\u4ed6\u5c08\u79d1\u754c\u5225\uff0c\u75c5\u4eba\u53ea\u9700\u8981\u770b\u4e00\u500b\u5c08\u79d1\u4fbf\u53ef\uff0c\u63aa\u65bd\u9700\u8981\u8a2d\u7acb\u4e00\u500b\u5e73\u53f0\uff0c\u70ba\u75c5\u4eba\u4f5c\u51fa\u7d71\u6574\uff0c\u505a\u5230\u8de8\u5c08\u79d1\u7d71\u7c4c\uff0c<span style=\"font-size-ignore:13pt;\">\u91ab\u885e\u5c40\u5c07\u5728\u8a18\u8005\u6703\u6216\u7acb\u6cd5\u6703\u4ea4\u4ee3\u6280\u8853\u6027\u554f\u984c\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u4ed6\u53c8\u63d0\u5230\uff0c\u9664\u8de8\u5c08\u79d1\u7d9c\u5408\u9580\u8a3a\u7684\u65b0\u6a5f\u5236\uff0c\u8981\u512a\u5316\u91ab\u7642\u670d\u52d9\uff0c\u91ab\u9662\u4ea6\u9700\u8981\u64f4\u5bb9\uff0c\u5982\u8b93\u516c\u79c1\u71df\u91ab\u9662\u5408\u4f5c\u66f4\u66a2\u9806\uff0c\u4ee5\u53ca\u8b93\u5e02\u6c11\u66f4\u4fbf\u5229\u5730\u4f7f\u7528\u7b26\u5408\u6a19\u6e96\u7684\u5927\u7063\u5340\u91ab\u7642\u670d\u52d9\u3002</span></p>\n<p>\u5de5\u806f\u6703\u8b70\u54e1\u5433\u79cb\u5317\u8868\u793a\uff0c\u672c\u6e2f\u52de\u52d5\u4eba\u53e3\u6709\u6e1b\u5c11\u548c\u8001\u5316\u8da8\u52e2\uff0c\u95dc\u6ce8\u5831\u544a\u63d0\u51fa\u52a0\u5927\u57f9\u8a13\u529b\u5ea6\u3001\u9f13\u52f5\u975e\u672c\u5730\u7562\u696d\u751f\u7559\u6e2f\u7b49\u63aa\u65bd\uff0c\u5c0d\u7de9\u89e3\u52de\u52d5\u529b\u7d50\u69cb\u554f\u984c\u7684\u4f5c\u7528\u3002</p>\n<p>\u674e\u5bb6\u8d85\u7a31\uff0c\u5e74\u9752\u52de\u52d5\u529b\u4e0b\u964d\u662f\u672c\u6e2f\u6574\u9ad4\u4eba\u53e3\u8001\u5316\u7684\u73fe\u8c61\uff0c\u8f38\u5165\u52de\u5de5\u662f\u91dd\u5c0d\u77ed\u671f\u554f\u984c\uff0c\u9577\u9060\u4e00\u5b9a\u672c\u5730\u52de\u5de5\u512a\u5148\uff0c\u4eca\u6b21\u653f\u7b56\u91cd\u9ede\u662f\u6539\u9769\u50f1\u54e1\u518d\u57f9\u8a13\u5c40\uff0c\u4e26\u63a8\u51fa\u5169\u500b\u5730\u65b9\u8b93\u6709\u7d93\u9a57\u52de\u5de5\u5718\u968a\u4f5c\u5de5\u696d\u57f9\u8a13\u3002</p>\n<p>\u4ed6\u8a8d\u70ba\uff0c\u57f9\u8a13\u8981\u9081\u5411\u5168\u6c11\u5316\uff0c15\u6b72\u6216\u4ee5\u4e0a\u5e02\u6c11\u5c31\u53ef\u53c3\u8207\uff0c\u4e26\u4ee5\u6280\u8853\u70ba\u672c\uff0c\u56e0\u6709\u6280\u80fd\u7684\u4eba\u66f4\u5bb9\u6613\u8f49\u8b8a\u5de5\u4f5c\u3002</p>\n<p>\u9078\u59d4\u6703\u8b70\u54e1\u4f55\u656c\u5eb7\u95dc\u6ce8\uff0c\u672a\u4f86\u6709\u4f55\u5c0d\u7b56\u8655\u7406\u9ad4\u80b2\u57fa\u672c\u8a2d\u65bd\u5efa\u8a2d\u548c\u5834\u5730\u5206\u914d\u3002<span style=\"font-size-ignore:13pt;\">\u674e\u5bb6\u8d85\u8868\u793a\uff0c\u53bb\u5e74\u548c\u4eca\u5e74\u7684\u300a\u65bd\u653f\u5831\u544a\u300b\u9808\u5ef6\u7e8c\u6027\u4e00\u8d77\u770b\uff0c\u5728\u5834\u5730\u63d0\u4f9b\u65b9\u9762\uff0c\u5df2\u7f85\u5217\u6574\u500b\u8a08\u5283\uff0c\u7576\u5c40\u6295\u653e\u5728\u9ad4\u80b2\u65b9\u9762\u7684\u8cc7\u6e90\u5f88\u591a\uff0c\u4f46\u66f4\u91cd\u8996\u662f\u5426\u9054\u5230\u6700\u597d\u6548\u679c\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u6c11\u5efa\u806f\u8b70\u54e1\u984f\u6c76\u7fbd\u8868\u793a\uff0c\u6709\u9ad8\u624d\u53cd\u6620\u5f9e\u5167\u5730\u8de8\u5883\u6ed9\u6b3e\u3001\u4f86\u6e2f\u6295\u8cc7\u7f6e\u696d\u6709\u9650\u5236\uff0c\u95dc\u6ce8\u6703\u5426\u7c21\u5316\u8cc7\u91d1\u5f80\u4f86\u7a0b\u5e8f\u3002</span><span style=\"font-size-ignore:13pt;\">\u674e\u5bb6\u8d85\u8868\u793a\uff0c\u653f\u5e9c\u5341\u5206\u91cd\u8996\u7559\u4eba\u624d\uff0c\u5169\u5c46\u300a\u65bd\u653f\u5831\u544a\u300b\u90fd\u5e0c\u671b\u8b93\u4eba\u624d\u843d\u5730\u751f\u6839\uff0c\u8de8\u5883\u6ed9\u6b3e\u65b9\u9762\u662f\u52aa\u529b\u7684\u65b9\u5411\uff0c\u4f46\u6d89\u53ca\u4e0d\u540c\u56e0\u7d20\uff0c\u76f8\u4fe1\u653f\u5e9c\u5167\u90e8\u548c\u6709\u95dc\u55ae\u4f4d\u90fd\u9700\u8981\u7814\u7a76\u3002</span></p>\n<p>\u4e5d\u9f8d\u4e2d\u8b70\u54e1\u694a\u6c38\u6770\u6307\u51fa\uff0c\u300a\u65bd\u653f\u5831\u544a\u300b\u4e0d\u5c11\u653f\u7b56\u5c0d\u555f\u5fb7\u5927\u6709\u88e8\u76ca\uff0c\u4f46\u4e0d\u5c11\u554f\u984c\u9808\u8de8\u90e8\u9580\u8655\u7406\uff0c\u95dc\u6ce8\u6703\u5426\u6210\u7acb\u300c\u555f\u5fb7\u8fa6\u300d\u7d71\u7c4c\u76f8\u95dc\u5de5\u4f5c\u3002<span style=\"font-size-ignore:13pt;\">\u674e\u5bb6\u8d85\u6307\u51fa\uff0c\u555f\u5fb7\u9ad4\u80b2\u5712\u662f\u91cd\u8981\u5de5\u7a0b\uff0c\u6545\u8981\u6c42\u653f\u52d9\u53f8\u53f8\u9577\u505a\u8a72\u5c08\u8cac\u5c0f\u7d44\u7d44\u9577\uff0c\u78ba\u4fdd\u5de5\u7a0b\u53ca\u5176\u4ed6\u914d\u5957\u80fd\u904b\u4f5c\u9806\u66a2\uff0c\u8b93\u555f\u5fb7\u9ad4\u80b2\u5712\u767c\u63ee\u61c9\u6709\u4f5c\u7528\u3001\u6210\u9999\u6e2f\u65b0\u5750\u6a19\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3905271/%E6%96%BD%E6%94%BF%E5%A0%B1%E5%91%8A%E4%B8%A8%E6%9D%8E%E5%AE%B6%E8%B6%85%3A%E6%9C%89%E9%99%90%E8%B3%87%E6%BA%90%E4%B8%8B%E6%8F%90%E5%8D%87%E5%85%AC%E7%87%9F%E9%86%AB%E7%99%82%E6%95%88%E7%9B%8A+%E7%A0%94%E8%B7%A8%E5%B0%88%E7%A7%91%E7%B5%B1%E7%B1%8C%E5%B9%B3%E5%8F%B0"}]}