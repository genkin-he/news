u7b2c\u4e03\u5341\u516b\u5c46\u806f\u5927\u9084\u5c07\u8fb2\u66c6\u65b0\u5e74\u78ba\u5b9a\u70ba\u806f\u5408\u570b\u7684\u5047\u65e5\u3002</p>\n<p>\u4ed6\u8aaa\uff0c\u4e2d\u65b9\u6b61\u8fce\u5404\u570b\u670b\u53cb\u5230\u4e2d\u570b\u4f86\u9ad4\u9a57\u8c50\u5bcc\u591a\u5f69\u7684\u6625\u7bc0\u6587\u5316\uff0c\u4e5f\u771f\u8aa0\u5e0c\u671b\u5404\u570b\u4eba\u6c11\u4e00\u8d77\u6b61\u5ea6\u6625\u7bc0\u6642\u523b\uff0c\u5206\u4eab\u6625\u7bc0\u5feb\u6a02\u3002</p>\n<p>\u806f\u5408\u570b\u6559\u79d1\u6587\u7d44\u7e54\u4fdd\u8b77\u975e\u7269\u8cea\u6587\u5316\u907a\u7522\u653f\u5e9c\u9593\u59d4\u54e1\u6703\u6628\u65e5\u901a\u904e\u8a55\u5be9\uff0c\u6c7a\u5b9a\u5c07\u300c\u6625\u7bc0\u2014\u4e2d\u570b\u4eba\u6176\u795d\u50b3\u7d71\u65b0\u5e74\u7684\u793e\u6703\u5be6\u8e10\u300d\u5217\u5165\u4eba\u985e\u975e\u7269\u8cea\u6587\u5316\u907a\u7522\u4ee3\u8868\u4f5c\u540d\u9304\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3947262/%E6%98%A5%E7%AF%80%E7%94%B3%E9%81%BA%E6%88%90%E5%8A%9F+%E5%A4%96%E4%BA%A4%E9%83%A8%3A%E6%98%A5%E7%AF%80%E6%97%A2%E6%98%AF%E4%B8%AD%E5%9C%8B%E7%9A%84%E4%B9%9F%E6%98%AF%E4%B8%96%E7%95%8C%E7%9A%84"}, {"title": "BBC\u7c72\u897f\u65b9\u570b\u5bb6\u505c\u7528\u65b0\u7586\u756a\u8304 \u5916\u4ea4\u90e8:\u4e0d\u5b58\u5728\u5f37\u8feb\u52de\u52d5", "description": "<p><span style=\"font-size-ignore:13pt;\">\u82f1\u570b\u5ee3\u64ad\u516c\u53f8(BBC)\u767c\u5e03\u6240\u8b02\u63ed\u79d8\u65b0\u7586\u756a\u8304\u6d89\u53ca\u300c\u5f37\u8feb\u52de\u52d5\u300d\u7684\u8996\u983b\uff0c\u547c\u7c72\u897f\u65b9\u570b\u5bb6\u505c\u6b62\u4f7f\u7528\u65b0\u7586\u756a\u8304\u539f\u6599\u6216\u6210\u54c1\u3002</span></p>\n<p>\u4e2d\u570b\u5916\u4ea4\u90e8\u767c\u8a00\u4eba\u6797\u528d\u5728\u4f8b\u884c\u8a18\u8005\u6703\u8868\u793a\uff0c\u4e2d\u65b9\u591a\u6b21\u5f37\u8abf\uff0c\u65b0\u7586\u4e0d\u5b58\u5728\u300c\u5f37\u8feb\u52de\u52d5\u300d\uff0c\u4e2d\u570b\u653f\u5e9c\u4e5f\u59cb\u7d42\u5805\u6c7a\u53cd\u5c0d\u4e26\u56b4\u53b2\u6253\u64ca\u5f37\u8feb\u52de\u52d5\u3002\u65b0\u7586\u756a\u8304\u548c\u65b0\u7586\u68c9\u82b1\u4e00\u6a23\uff0c\u90fd\u662f\u4eab\u8b7d\u4e16\u754c\u3001\u5bb6\u55bb\u6236\u66c9\u7684\u512a\u8cea\u7522\u54c1\uff0c\u5f9e\u7a2e\u690d\u5230\u63a1\u6536\u5df2\u57fa\u672c\u5be6\u73fe\u6a5f\u68b0\u5316\uff0c\u6a5f\u63a1\u7387\u5206\u5225\u8d85\u904e90%\u548c85%\uff0c\u53c8\u4f55\u8ac7\u300c\u5f37\u8feb\u52de\u52d5\u300d\u5462\uff1f</p>\n<p>\u4ed6\u7e8c\u7a31\uff0c\u65b0\u805e\u7684\u751f\u547d\u5728\u65bc\u771f\u5be6\uff0c\u4e0d\u9020\u8b20\u50b3\u8b20\u3001\u4e0d\u504f\u807d\u504f\u4fe1\u662f\u65b0\u805e\u8077\u696d\u9053\u5fb7\u7684\u8d77\u78bc\u8981\u6c42\uff0c\u4e5f\u662f\u516c\u6b63\u5ba2\u89c0\u5a92\u9ad4\u7684\u57fa\u672c\u7d20\u990a\u3002\u5728\u9019\u500b\u8abf\u67e5\u5831\u544a\u548c\u8996\u983b\u4e2d\uff0c\u6240\u8b02\u7684\u300c\u8b49\u64da\u300d\u5f88\u591a\u90fd\u51a0\u4ee5\u300c\u8072\u7a31\u300d\u3001\u300c\u611f\u53d7\u300d\u9019\u6a23\u7684\u4e3b\u89c0\u81c6\u65b7\uff0c\u5728\u672a\u7d93\u6838\u5be6\u7684\u60c5\u6cc1\u4e0b\u5148\u5165\u70ba\u4e3b\u3001\u65b7\u7ae0\u53d6\u7fa9\uff0c\u5984\u8a00\u65b0\u7586\u756a\u8304\u63a1\u6536\u884c\u696d\u5b58\u5728\u300c\u5f37\u8feb\u52de\u52d5\u300d\u3002\u6709\u95dc\u8a18\u8005\u5927\u8cbb\u5468\u7ae0\u82b1\u5e7e\u500b\u6708\u6642\u9593\u7814\u7a76\u5341\u5e7e\u7a2e\u756a\u8304\u91ac\u3001\u537b\u4e0d\u9858\u82b1\u4e00\u79d2\u9418\u4e86\u89e3\u65b0\u7586\u7684\u771f\u76f8\uff0c\u9019\u662f\u5178\u578b\u7684\u96d9\u6a19\u504f\u898b\u3002</p>\n<p>\u6797\u528d\u6307\u51fa\uff0c\u5e0c\u671b\u6709\u95dc\u65b9\u9762\u8a8d\u6e05\u300c\u5f37\u8feb\u52de\u52d5\u300d\u8b0a\u8a00\u80cc\u5f8c\u7684\u96aa\u60e1\u7528\u5fc3\uff0c\u4e5f\u6b61\u8fce\u5927\u5bb6\u591a\u5230\u65b0\u7586\u8d70\u8d70\u770b\u770b\uff0c\u5be6\u5730\u54c1\u5617\u65b0\u7586\u7684\u756a\u8304\uff0c\u9ad4\u9a57\u65b0\u7586\u7684\u751f\u6d3b\uff0c\u611f\u77e5\u771f\u5be6\u7684\u65b0\u7586\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3947260/BBC%E7%B1%B2%E8%A5%BF%E6%96%B9%E5%9C%8B%E5%AE%B6%E5%81%9C%E7%94%A8%E6%96%B0%E7%96%86%E7%95%AA%E8%8C%84+%E5%A4%96%E4%BA%A4%E9%83%A8%3A%E4%B8%8D%E5%AD%98%E5%9C%A8%E5%BC%B7%E8%BF%AB%E5%8B%9E%E5%8B%95"}, {"title": "\u8ca1\u5eab\u5c40:\u65b0\u6295\u8cc7\u79fb\u6c11\u8a08\u5283\u63a5\u903e700\u7533\u8acb \u6599\u6295\u8cc7\u984d\u903e210\u5104", "description": "<p><span style=\"font-size-ignore:13pt;\">\u8ca1\u7d93\u4e8b\u52d9\u53ca\u5eab\u52d9\u5c40\u8868\u793a\uff0c\u4eca\u5e743\u6708\u555f\u52d5\u7684\u300c\u65b0\u8cc7\u672c\u6295\u8cc7\u8005\u5165\u5883\u8a08\u5283\u300d(CIES)\uff0c\u622a\u81f3\u4e0a\u6708\u5e95\uff0c\u63a5\u7372\u8d85\u904e700\u5b97\u7533\u8acb\uff0c\u9810\u8a08\u53ef\u70ba\u9999\u6e2f\u5e36\u4f86\u7684\u6295\u8cc7\u984d\u5c07\u903e210\u5104\u5143\u3002</span></p>\n<p>\u8ca1\u7d93\u4e8b\u52d9\u53ca\u5eab\u52d9\u5c40\u526f\u5c40\u9577\u9673\u6d69\u6fc2\u5728\u7acb\u6cd5\u6703\u6703\u8b70\u8868\u793a\uff0c\u6b63\u4e0d\u65b7\u52a0\u5f37\u8207\u300c\u4e00\u5e36\u4e00\u8def\u300d\u7d93\u6fdf\u9ad4\u7684\u9023\u7e6b\uff0c\u7a4d\u6975\u5c0b\u6c42\u65b0\u6295\u8cc7\u548c\u8cc7\u91d1\u4f86\u6e90\uff0c\u5305\u62ec\u63a8\u52d5\u4ea4\u6613\u6240\u8cb7\u8ce3\u57fa\u91d1\u5728\u9999\u6e2f\u53ca\u6c99\u7279\u963f\u62c9\u4f2f\u5e02\u5834\u639b\u724c\u4e0a\u5e02\uff0c\u4fc3\u9032\u5169\u5730\u96d9\u5411\u8cc7\u91d1\u878d\u901a\uff1b\u4ea6\u6703\u7e7c\u7e8c\u8207\u5167\u5730\u76e3\u7ba1\u6a5f\u69cb\u7a4d\u6975\u7814\u7a76\u548c\u63a8\u52d5\u4e92\u806f\u4e92\u901a\u64f4\u5bb9\u589e\u91cf\u3001\u63d0\u5347\u96e2\u5cb8\u4eba\u6c11\u5e63\u7684\u6295\u8cc7\u529f\u80fd\uff0c\u5305\u62ec\u5c07\u4eba\u6c11\u5e63\u80a1\u7968\u4ea4\u6613\u6ac3\u53f0\u7d0d\u5165\u300c\u6e2f\u80a1\u901a\u300d\u3001\u63a8\u52d5\u5927\u5b97\u4ea4\u6613\u7d0d\u5165\u4e92\u806f\u4e92\u901a\u6a5f\u5236\u7b49\uff0c\u63a8\u52d5\u4eba\u6c11\u5e63\u570b\u969b\u5316\u3002</p>\n<p>\u4ed6\u7a31\uff0c\u5c07\u65bc\u6708\u5167\u6210\u7acb\u5de5\u4f5c\u5c0f\u7d44\uff0c\u63a8\u884c\u5efa\u7acb\u570b\u969b\u9ec3\u91d1\u4ea4\u6613\u4e2d\u5fc3\u7684\u5de5\u4f5c\uff0c\u5305\u62ec\u5f37\u5316\u4ea4\u6613\u6a5f\u5236\u53ca\u76f8\u95dc\u898f\u7ba1\u6846\u67b6\u3001\u63a8\u52d5\u524d\u6cbf\u91d1\u878d\u79d1\u6280\u61c9\u7528\uff0c\u4ee5\u53ca\u8207\u5167\u5730\u63a2\u8a0e\u5c07\u9ec3\u91d1\u7522\u54c1\u7d0d\u5165\u4e92\u806f\u4e92\u901a\u7b49\u3002</p>\n<p>\u53e6\u5916\uff0c\u622a\u81f310\u6708\uff0c\u9999\u6e2f\u6709\u8d85\u904e1100\u9593\u91d1\u878d\u79d1\u6280\u516c\u53f8\uff0c\u6309\u5e74\u589e\u9577\u7d0415%\u3002\u9673\u6d69\u6fc2\u8868\u793a\uff0c\u672a\u4f86\u6703\u6301\u7e8c\u63a8\u52d5\u592e\u884c\u6578\u78bc\u8ca8\u5e63\u3001\u79fb\u52d5\u652f\u4ed8\u3001\u6578\u5b57\u9280\u884c\u3001\u865b\u64ec\u8cc7\u7522\u4ea4\u6613\u7b49\u79d1\u6280\u61c9\u7528\uff0c\u4fc3\u9032\u9999\u6e2f\u7a69\u5b9a\u5e63\u4ee5\u81f3web3\u751f\u614b\u5708\u53ef\u6301\u7e8c\u767c\u5c55\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3947253/%E8%B2%A1%E5%BA%AB%E5%B1%80%3A%E6%96%B0%E6%8A%95%E8%B3%87%E7%A7%BB%E6%B0%91%E8%A8%88%E5%8A%83%E6%8E%A5%E9%80%BE700%E7%94%B3%E8%AB%8B+%E6%96%99%E6%8A%95%E8%B3%87%E9%A1%8D%E9%80%BE210%E5%84%84"}, {"title": "\u5eb7\u6021\u82b1\u5712\u4e09\u623f\u6a13\u666f728\u842c\u6210\u4ea4", "description": "<p><span style=\"font-size-ignore:13pt;\">\u9c02\u9b5a\u6d8c</span><span style=\"font-size-ignore:13pt;\">\u5eb7\u6021\u82b1\u5712R\u5ea7\u4e2d\u4f4e\u5c6412\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d616\u65b9\u544e\uff0c3\u623f\u9593\u9694\uff0c\u671b\u6a13\u666f\uff0c\u6700\u65b0\u4ee5728\u842c\u5143\u6210\u4ea4\uff0c\u5be6\u7528\u544e\u50f911818\u5143\u3002</span></p>\n<p>\u4e2d\u539f\u5730\u7522\u8868\u793a\uff0c\u65b0\u8cb7\u5bb6\u70ba\u540c\u5340\u7528\u5bb6\uff0c\u5fc3\u5100\u55ae\u4f4d\u5c6c\u300c\u4e0b\u5eb7\u300d\uff0c\u51fa\u5165\u4fbf\u5229\uff0c\u4e14\u9593\u9694\u5be6\u7528\uff0c\u50f9\u683c\u5408\u9069\u9042\u6c7a\u5b9a\u5165\u5e02\u81ea\u7528\u3002</p>\n<p>\u64da\u4e86\u89e3\uff0c\u539f\u696d\u4e3b\u5247\u65bc1996\u5e74\u4ee5407\u842c\u5143\u8cfc\u5165\u4e0a\u8ff0\u55ae\u4f4d\uff0c\u6301\u8ca828\u5e74\uff0c\u662f\u6b21\u6cbd\u51fa\u8cec\u9762\u7372\u5229321\u842c\u5143\uff0c\u7269\u696d\u5347\u503c\u7d0479%\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3947185/%E5%BA%B7%E6%80%A1%E8%8A%B1%E5%9C%92%E4%B8%89%E6%88%BF%E6%A8%93%E6%99%AF728%E8%90%AC%E6%88%90%E4%BA%A4"}, {"title": "\u524d\u6d77\u7cb5\u6e2f\u6fb3\u53f0\u9752\u5e74\u5275\u65b0\u5275\u696d\u8cfd\u516c\u5e03\u512a\u52dd\u9805\u76ee", "description": "<p>\u70ba\u57f9\u80b2\u5275\u65b0\u5275\u696d\u4eba\u624d\uff0c\u63a8\u52d5\u9752\u5e74\u5728\u5927\u7063\u5340\u5be6\u73fe\u5275\u696d\u5922\u60f3\uff0c\u300c\u524d\u6d77\u7cb5\u6e2f\u6fb3\u53f0\u9752\u5e74\u5275\u65b0\u5275\u696d\u5927\u8cfd2024\u300d(\u9999\u6e2f\u8cfd\u5340)\u9812\u734e\u79ae\u4eca\u5929\u8209\u884c\uff0c\u516c\u5e0312\u500b\u5f97\u734e\u9805\u76ee\uff0c\u5176\u4e2d\u91d1\u734e\u6700\u9ad8\u53ef\u73728\u842c\u5143\u4eba\u6c11\u5e63\u734e\u91d1\u53ca\u843d\u6236\u524d\u6d77\u5b75\u5316\u3002</p>\n<p>\u6bd4\u8cfd\u5206\u70ba\u4f01\u696d\u6210\u9577\u7d44\u53ca\u521d\u5275\u5718\u968a\u7d44\uff0c\u5408\u5171\u6536\u5230534\u4eba\u7684249\u4efd\u7533\u8acb\u3002\u7d93\u904e\u5169\u8f2a\u7be9\u9078\uff0c\u7372\u734e\u5718\u968a\u6db5\u84cb\u591a\u500b\u5275\u65b0\u79d1\u6280\u7bc4\u7587\uff0c\u5305\u62ec\u4eba\u5de5\u667a\u80fd\u3001\u751f\u7269\u79d1\u6280\u3001\u65b0\u80fd\u6e90\u79d1\u6280\u3001\u5148\u9032\u88fd\u9020\u7b49\u3002</p>\n<p>\u4f01\u696d\u6210\u9577\u7d44\u91d1\u734e\u662f\u53ef\u53ef\u897f\u91cc\u79d1\u6280\u6709\u9650\u516c\u53f8\uff0c\u5718\u968a\u6210\u54e1\u7814\u767c\u9ad8\u6548\u80fd\u5149\u5b50\u82af\u7247\uff0c\u5177\u5099\u901f\u7387\u9ad8\u3001\u80fd\u8017\u4f4e\u7b49\u512a\u52e2\uff0c\u70baAI\u30016G\u53ca\u591a\u500b\u7522\u696d\u63d0\u4f9b\u6280\u8853\u652f\u6301\u3002\u521d\u5275\u5718\u968a\u7d44\u91d1\u734e\u662f\u64c1\u62b1\u6642\u4ee3\uff0c\u5275\u9a45\u672a\u4f86\u2014\u4e00\u8afe\u74e6\u79d1\u6280\uff0c\u5718\u968a\u6210\u54e1\u671f\u671b\u63a8\u51fa\u901a\u7528\u578b\u667a\u80fd\u5e95\u76e4\uff0c\u5177\u5099\u7121\u7dda\u5145\u96fb\u3001L4\u5168\u81ea\u52d5\u99d5\u99db\u548c\u8a9e\u97f3\u4ea4\u4e92\u529f\u80fd\uff0c\u63d0\u5347\u50b3\u7d71\u884c\u696d\u667a\u80fd\u6c34\u5e73\u53ca\u9748\u6d3b\u6027\u3002</p>\n<p>\u9999\u6e2f\u9752\u5e74\u5354\u6703\u7e3d\u5e79\u4e8b\u5f90\u5c0f\u66fc\u8868\u793a\uff0c\u4e0a\u5c46\u7684\u512a\u79c0\u9805\u76ee\u5df2\u9806\u5229\u5728\u524d\u6d77\u5c55\u958b\u5275\u696d\u65c5\u7a0b\uff0c\u5bc4\u8a9e\u53c3\u8cfd\u9752\u5e74\u6293\u7dca\u9752\u5354\u8207\u524d\u6d77\u6df1\u6e2f\u9752\u5e74\u5922\u5de5\u5834\u63d0\u4f9b\u7684\u5168\u65b9\u4f4d\u652f\u63f4\u53ca\u8cc7\u6e90\uff0c\u5728\u5927\u7063\u5340\u5be6\u8e10\u5275\u696d\u5922\uff0c\u70ba\u570b\u5bb6\u767c\u5c55\u4f5c\u51fa\u8ca2\u737b\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3947252/%E5%89%8D%E6%B5%B7%E7%B2%B5%E6%B8%AF%E6%BE%B3%E5%8F%B0%E9%9D%92%E5%B9%B4%E5%89%B5%E6%96%B0%E5%89%B5%E6%A5%AD%E8%B3%BD%E5%85%AC%E5%B8%83%E5%84%AA%E5%8B%9D%E9%A0%85%E7%9B%AE"}, {"title": "\u7f8e\u518d\u5c0d\u83ef\u534a\u5c0e\u9ad4\u5be6\u65bd\u7ba1\u5236 \u4e2d\u65b9\u5c07\u63a1\u63aa\u65bd\u7dad\u8b77\u6b0a\u76ca", "description": "<p>\u88ab\u554f\u53ca\u7f8e\u570b\u5c0d\u83ef\u534a\u5c0e\u9ad4\u5be6\u65bd\u51fa\u53e3\u7ba1\u5236\u63aa\u65bd\uff0c\u591a\u500b\u884c\u696d\u5354\u6703\u547c\u7c72\u8b39\u614e\u63a1\u8cfc\u7f8e\u570b\u6676\u7247\u4e00\u4e8b\uff0c\u5546\u52d9\u90e8\u767c\u8a00\u4eba\u56de\u61c9\u7a31\uff0c\u4e2d\u65b9\u5c07\u63a1\u53d6\u5fc5\u8981\u63aa\u65bd\uff0c\u5805\u6c7a\u7dad\u8b77\u81ea\u8eab\u6b63\u7576\u6b0a\u76ca\u3002</p>\n<p>\u767c\u8a00\u4eba\u6307\u51fa\uff0c<span style=\"font-size-ignore:13pt;\">\u7f8e\u65b9\u4e0d\u65b7\u6cdb\u5316\u570b\u5bb6\u5b89\u5168\u6982\u5ff5\uff0c\u6feb\u7528\u51fa\u53e3\u7ba1\u5236\u63aa\u65bd\uff0c\u5be6\u65bd\u55ae\u908a\u9738\u51cc\u884c\u5f91\u300212\u67082\u65e5\u518d\u6b21\u767c\u5e03\u5c0d\u83ef\u534a\u5c0e\u9ad4\u51fa\u53e3\u7ba1\u5236\u63aa\u65bd\uff0c\u5c0d\u65bc\u534a\u5c0e\u9ad4\u9818\u57df\u6b63\u5e38\u8cbf\u6613\u5f80\u4f86\u5e36\u4f86\u6975\u5927\u4e0d\u78ba\u5b9a\u6027\uff0c\u5c0d\u5168\u7403\u7522\u696d\u93c8\u4f9b\u61c9\u93c8\u7a69\u5b9a\u69cb\u6210\u4e86\u5a01\u8105\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3947249/%E7%BE%8E%E5%86%8D%E5%B0%8D%E8%8F%AF%E5%8D%8A%E5%B0%8E%E9%AB%94%E5%AF%A6%E6%96%BD%E7%AE%A1%E5%88%B6+%E4%B8%AD%E6%96%B9%E5%B0%87%E6%8E%A1%E6%8E%AA%E6%96%BD%E7%B6%AD%E8%AD%B7%E6%AC%8A%E7%9B%8A"}]}