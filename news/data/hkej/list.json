u7528100+\u9078\u80a1\u689d\u4ef6\u7be9\u9078\u503c\u535a\u80a1\uff01</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/stock/article/3949741/%E3%80%90%E7%95%B0%E5%8B%95%E8%82%A1%E3%80%91%E5%BC%98%E6%B5%A9%E5%A4%A7%E5%8D%871.6%E5%80%8D%E5%BE%8C%E5%8D%87%E5%B9%85%E5%89%8A%E9%80%BE%E5%8D%8A+%E6%8E%A7%E8%82%A1%E6%AC%8A%E6%98%93%E6%89%8B"}, {"title": "\u653f\u5e9c\u64ec\u898f\u5b9a\u7684\u58eb\u9808\u5b89\u88dd\u651d\u9304\u7cfb\u7d71\u53ca\u63d0\u4f9b\u96fb\u5b50\u652f\u4ed8", "description": "<p><span style=\"font-size-ignore:13pt;\">\u904b\u8f38\u53ca\u7269\u6d41\u5c40\u5411\u7acb\u6cd5\u6703\u63d0\u4ea4\u6587\u4ef6\uff0c\u6307\u8a08\u5283\u5728\u672a\u4f86\u6578\u6708\u64ec\u5b9a\u76f8\u95dc\u7684\u6cd5\u4f8b\u4fee\u8a02\u689d\u6587\uff0c\u4ee5\u898f\u5b9a\u6240\u6709\u7684\u58eb\u5fc5\u9808\u5b89\u88dd\u8eca\u5ec2\u651d\u9304\u6a5f\u3001\u884c\u8eca\u8a18\u9304\u5100\u53ca\u5168\u7403\u885e\u661f\u5c0e\u822a\u7cfb\u7d71(\u7d71\u7a31\u651d\u9304\u7cfb\u7d71)\uff0c\u4ee5\u53ca\u6240\u6709\u7684\u58eb\u53f8\u6a5f\u5fc5\u9808\u63d0\u4f9b\u96fb\u5b50\u652f\u4ed8\u65b9\u5f0f\uff0c\u6703\u722d\u53d6\u65bc2025\u5e74\u7b2c\u4e8c\u5b63\u5411\u7acb\u6cd5\u6703\u63d0\u4ea4\u6cd5\u4f8b\u4fee\u8a02\u5efa\u8b70\u3002</span></p>\n<p>\u6587\u4ef6\u6307\u51fa\uff0c\u5728\u7684\u58eb\u4e0a\u5b89\u88dd\u651d\u9304\u7cfb\u7d71\u6709\u52a9\u963b\u5687\u548c\u6253\u64ca\u7684\u58eb\u53f8\u6a5f\u7684\u4e0d\u7576\u884c\u70ba\u3001\u63d0\u5347\u7684\u58eb\u99d5\u99db\u5b89\u5168\uff0c\u4ee5\u53ca\u5728\u7684\u58eb\u53f8\u6a5f\u548c\u4e58\u5ba2\u51fa\u73fe\u722d\u62d7\u6642\u4fdd\u969c\u96d9\u65b9\u6b0a\u76ca\uff0c\u9019\u4e9b\u90fd\u6709\u5229\u65bc\u63d0\u5347\u7684\u58eb\u670d\u52d9\u8cea\u7d20\u548c\u6574\u9ad4\u5f62\u8c61\u3002</p>\n<p>\u6587\u4ef6\u63d0\u5230\uff0c\u9664\u4e86\u8981\u6c42\u6240\u6709\u7684\u58eb\u5fc5\u9808\u5b89\u88dd\u651d\u9304\u7cfb\u7d71\u5916\uff0c\u904b\u8f38\u7f72\u6703\u8058\u7528\u670d\u52d9\u627f\u8fa6\u5546\u67b6\u8a2d\u548c\u7dad\u8b77\u4e2d\u592e\u5e73\u53f0\u3002\u4e2d\u592e\u5e73\u53f0\u9700\u8981\u517c\u5bb9\u5404\u500b\u7372\u904b\u8f38\u7f72\u5be9\u6279\u7684\u88dd\u7f6e\u6240\u4e0a\u50b3\u7684\u5f71\u97f3\u8a18\u9304\u548c\u6578\u64da\uff0c\u653f\u5e9c\u5efa\u8b70\u651d\u9304\u7cfb\u7d71\u6240\u6536\u96c6\u5230\u7684\u5f71\u97f3\u8a18\u9304\u548c\u6578\u64da\uff0c\u9808\u88ab\u52a0\u5bc6\u4e26\u5132\u5b58\u5728\u8eca\u5167\u7684\u5132\u5b58\u88dd\u7f6e\u4e2d\u4e0d\u5c11\u65bc30\u5929\uff0c\u4f46\u6bcb\u9808\u4e0a\u50b3\u4e2d\u592e\u5e73\u53f0\u3002</p>\n<p>\u800c\u5728\u6709\u9700\u8981\u6642\uff0c\u4f8b\u5982\u6709\u4e58\u5ba2\u6295\u8a34\u53f8\u6a5f\u884c\u70ba\u4e0d\u7576\u6216\u767c\u751f\u4ea4\u901a\u610f\u5916\uff0c\u7372\u6388\u6b0a\u4eba\u54e1\u53ef\u900f\u904e\u9060\u7aef\u64f7\u53d6\u7684\u65b9\u5f0f\uff0c\u5c07\u5132\u5b58\u65bc\u8eca\u5ec2\u88dd\u7f6e\u7684\u6709\u95dc\u5f71\u97f3\u8a18\u9304\u548c\u6578\u64da\uff0c\u4e0a\u50b3\u81f3\u653f\u5e9c\u8a2d\u7f6e\u7684\u4e2d\u592e\u5e73\u53f0\uff0c\u4e26\u5132\u5b58\u65bc\u653f\u5e9c\u96f2\u7aef\uff0c\u8b93\u8b66\u65b9\u6216\u904b\u8f38\u7f72\u4f5c\u8ddf\u9032\u8abf\u67e5\u3002</p>\n<p>\u653f\u5e9c\u8a08\u5283\u65bc2025\u5e74\u5e95\u843d\u5be6\u96fb\u5b50\u652f\u4ed8\u65b9\u5f0f\u5efa\u8b70\u3002\u81f3\u65bc\u651d\u9304\u7cfb\u7d71\u5efa\u8b70\u65b9\u9762\uff0c\u904b\u8f38\u7f72\u8a08\u5283\u65bc\u660e\u5e74\u4e2d\u63a5\u53d7\u5408\u898f\u683c\u7684\u651d\u9304\u7cfb\u7d71\u63d0\u51fa\u5be9\u6279\u7533\u8acb\uff0c\u4ee5\u53ca\u62db\u8058\u627f\u8fa6\u5546\u67b6\u8a2d\u4e2d\u592e\u5e73\u53f0\uff0c\u653f\u5e9c\u7a4d\u6975\u8207\u696d\u754c\u651c\u624b\u722d\u53d6\u65bc2025\u5e74\u5e95\u81f32026\u5e74\u4e2d\u9678\u7e8c\u5b89\u88dd\u651d\u9304\u7cfb\u7d71\uff0c\u4e26\u65bc2026\u5e74\u5167\u5b8c\u6210\u5b89\u88dd\uff0c\u5c46\u6642\u5c07\u5be6\u65bd\u6709\u95dc\u6cd5\u4f8b\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3949730/%E6%94%BF%E5%BA%9C%E6%93%AC%E8%A6%8F%E5%AE%9A%E7%9A%84%E5%A3%AB%E9%A0%88%E5%AE%89%E8%A3%9D%E6%94%9D%E9%8C%84%E7%B3%BB%E7%B5%B1%E5%8F%8A%E6%8F%90%E4%BE%9B%E9%9B%BB%E5%AD%90%E6%94%AF%E4%BB%98"}, {"title": "\u73e0\u6d77\u9999\u6d32\u5340\u6b63\u526f\u5340\u9577\u70ba35\u6b7b\u6158\u6848\u8acb\u8fad", "description": "<p>\u73e0\u6d77\u5e02\u9999\u6d32\u5340\u9ad4\u80b2\u4e2d\u5fc3\u4e0a\u6708\u767c\u751f\u7537\u5b50\u7121\u5dee\u5225\u99d5\u8eca\u649e\u4eba\uff0c\u81f435\u55aa\u751f43\u50b7\u6158\u6848\u3002</p>\n<p>\u73e0\u6d77\u5e02\u9999\u6d32\u5340\u7b2c10\u5c46\u4eba\u5927\u5e38\u59d4\u6703\u53ec\u958b\u7b2c35\u6b21\u6703\u8b70\uff0c\u6c7a\u5b9a\u63a5\u53d7\u5289\u9f4a\u82f1\u8fad\u53bb\u9999\u6d32\u5340\u5340\u9577\u8077\u52d9\u8acb\u6c42\uff0c\u63a5\u53d7\u4ed8\u8f1d\u8fad\u53bb\u526f\u5340\u9577\u8077\u52d9\u7684\u8acb\u6c42\u3002</p>\n<p>\u6703\u8b70\u7d93\u904e\u5be9\u8b70\u8868\u6c7a\uff0c\u901a\u904e\u6709\u95dc\u4eba\u4e8b\u4efb\u514d\uff0c\u4efb\u547d\u5f35\u6703\u6d0b\u70ba\u526f\u5340\u9577\uff0c\u5f35\u6703\u6d0b\u4ee3\u7406\u5340\u9577\u8077\u52d9\u3002</p>\n<p>\u6b64\u5916\uff0c\u73e0\u6d77\u5e02\u4eba\u5927\u5e38\u59d4\u6703\u6703\u8b70\u65e9\u524d\u6c7a\u5b9a\uff0c\u63a5\u53d7\u9ec3\u5fd7\u8c6a\u8fad\u53bb\u73e0\u6d77\u5e02\u5e02\u9577\u8077\u52d9\u7684\u8acb\u6c42\uff0c\u63a5\u53d7\u8b1d\u4ec1\u601d\u8fad\u53bb\u526f\u5e02\u9577\u8077\u52d9\uff1b\u6c7a\u5b9a\u514d\u53bb\u8b1d\u4ec1\u601d\u7684\u516c\u5b89\u5c40\u5c40\u9577\u8077\u52d9\u3002</p>\n<p>\u6703\u8b70\u540c\u6642\u6c7a\u5b9a\uff0c\u4efb\u547d\u5433\u6fa4\u6850\u70ba\u526f\u5e02\u9577\uff0c\u6c7a\u5b9a\u4ed6\u70ba\u4ee3\u7406\u5e02\u9577\uff1b\u4e26\u6c7a\u5b9a\u4efb\u547d\u55ac\u96f7\u70ba\u526f\u5e02\u9577\u53ca\u516c\u5b89\u5c40\u5c40\u9577\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3949731/%E7%8F%A0%E6%B5%B7%E9%A6%99%E6%B4%B2%E5%8D%80%E6%AD%A3%E5%89%AF%E5%8D%80%E9%95%B7%E7%82%BA35%E6%AD%BB%E6%85%98%E6%A1%88%E8%AB%8B%E8%BE%AD"}, {"title": "\u7f6e\u63db\u5b58\u91cf\u96b1\u6027\u50b5\u52d9\u5730\u65b9\u50b5\u64da\u58