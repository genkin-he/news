9\u696d\u3001\u540d\u724c\u624b\u888b\u53ca\u624b\u9336\u7b49\u3002</p>\n<p>\u64da\u5831\u9053\uff0c\u73fe\u5e7438\u6b72\u7684\u8c9d\u6771\u4e39\uff0c\u5176\u540d\u4e0b\u5305\u62ec\u6301\u6709\u502b\u6566\u5169\u9805\u7269\u696d\u3001\u65e5\u672c\u5317\u6d77\u9053\u5169\u5e45\u571f\u5730\u53ca\u5728\u6cf0\u570b\u7b49\u591a\u7269\u696d\u53ca\u571f\u5730\u5408\u5171\u7e3d\u503c8.93\u5104\u6cf0\u9296\u3001217\u500b\u624b\u888b\u50f9\u503c200\u842c\u7f8e\u5143\uff0c\u53ca\u6700\u5c1175\u96bb\u540d\u8cb4\u624b\u9336\uff0c\u7e3d\u503c500\u842c\u7f8e\u5143\uff1b\u9084\u67099\u96bbBearbrick\u6a21\u578b\uff0c\u6d89\u8cc7190\u842c\u6cf0\u9296\u7b49\u3002\u53e6\u5916\uff0c\u5979\u5171\u6301\u6709\u7d04727\u842c\u6cf0\u9296\u73fe\u91d1\u53ca10.8\u5104\u6cf0\u9296\u9280\u884c\u5b58\u6b3e\uff0c\u4ea6\u6709\u6295\u8cc7\u57fa\u91d1\u53ca\u80a1\u7968\uff0c\u4e26\u6301\u6709\u7684\u8c6a\u83ef\u6c7d\u8eca\u5982Bentley\u53caRolls-Royce Phantom\u7b49\u7d04\u503c6677\u842c\u6cf0\u9296\u7b49\u3002</p>\n<p>\u8c9d\u6771\u4e39\u904e\u53bb\u4e00\u5e74\u7e3d\u6536\u5165\u7d042.65\u5104\u6cf0\u9296\uff0c\u5176\u4e2d\u5305\u62ec\u7e3d\u7406\u85aa\u8cc7340\u842c\u6cf0\u9296\u3001\u80a1\u606f\u6536\u51652.59\u5104\u6cf0\u9296\uff0c\u4ee5\u53ca\u4f86\u81ea\u5b58\u6b3e\u5229\u606f\u8207\u79df\u91d1\u5206\u5225\u6709200\u842c\u53ca89\u842c\u6cf0\u9296\u3002\u81f3\u65bc\u4e00\u5e74\u652f\u51fa\u7d045772\u842c\u6cf0\u9296\u3002</p>\n<p>\u8c9d\u6771\u4e39\u662f\u6cf0\u570b\u524d\u7e3d\u7406\u4ed6\u4fe1(Thaksin Shinawatra)\u6700\u5c0f\u7684\u5973\u5152\uff0c\u4ea6\u662f\u6cf0\u570b\u6b77\u4f86\u6700\u5e74\u8f15\u7684\u7e3d\u7406\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3970298/%E6%B3%B0%E5%9C%8B%E7%B8%BD%E7%90%86%E8%B2%9D%E6%9D%B1%E4%B8%B9%E8%B3%87%E7%94%A2%E9%80%BE31%E5%84%84+%E6%8C%81%E5%80%AB%E6%95%A6%E5%85%A9%E7%89%A9%E6%A5%AD%E5%8F%8A%E5%90%8D%E9%8C%B6%E6%89%8B%E8%A2%8B%E7%AD%89", "pub_date": "2025-01-03 18:10:33", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u4e2d\u539f\u63a8\u50b2\u83ef\u7f6e\u696d\u6309\u63ed\u512a\u60e0 \u6309\u606f\u4f4e\u81f3H+1.3%", "description": "<p>\u5354\u6210\u884c\u7b72\u7b95\u7063\u6771\u5927\u8857\u50b2\u83ef\uff0c\u9810\u8a08\u5728\u8fb2\u66c6\u65b0\u5e74\u524d\u958b\u552e\u3002\u4e2d\u539f\u5730\u7522\u53ca\u4e2d\u539f\u6309\u63ed\u914d\u5408\u9805\u76ee\u6700\u65b0\u73fe\u6a13\u63a8\u552e\u5b89\u6392\uff0c\u7279\u5225\u70ba\u8a72\u76e4\u8cb7\u5bb6\u63d0\u4f9b\u5168\u65b0\u6309\u63ed\u512a\u60e0\u8f49\u4ecb\uff0c\u6309\u606f\u4f4e\u81f3H+1.3%\u3002</p>\n<p>\u4e2d\u539f\u6309\u63ed\u8463\u4e8b\u7e3d\u7d93\u7406\u738b\u7f8e\u9cf3\u516c\u5e03\uff0c\u662f\u6b21\u7279\u5225\u70ba\u50b2\u83ef\u8cb7\u5bb6\u63a8\u51fa\u50b2\u83ef\u7f6e\u696d\u6309\u63ed\u512a\u60e0\uff0c\u51e1\u7d93\u4e2d\u539f\u6309\u63ed\u8f49\u4ecb\u5747\u53ef\u7533\u8acb\u662f\u6b21\u512a\u60e0\uff0c\u5168\u671f\u6309\u606f\u4f4e\u81f3H+1.3%\uff0c\u5c01\u9802\u606f\u7387\u4f4e\u81f3P-2%(P:5.5%)\uff0c\u57fa\u65bc\u53bb\u5e74\u672c\u6e2f\u9280\u884c\u4e09\u5ea6\u6e1bP\uff0c\u5be6\u969b\u6309\u606f\u73fe\u4f4e\u81f33.5%\uff0c\u8a08\u5283\u8a2d\u6709\u7279\u9ad8\u73fe\u91d1\u56de\u8d08\u9ad8\u9054\u8cb8\u6b3e\u984d1%\uff0c\u4e26\u7279\u8a2dMortgage\u2013Link\u9ad8\u5b58\u606f\u6236\u53e3\uff0c\u5b58\u606f\u8207\u6309\u606f\u4e00\u81f4\u73fe\u70ba3.5%\uff0c\u5584\u7528\u9ad8\u5b58\u606f\u6236\u53e3\u4ee5\u5b58\u606f\u56de\u5831\u62b5\u6d88\u6309\u606f\u652f\u51fa\uff0c\u6709\u6548\u964d\u4f4e\u6de8\u6309\u606f\u3002\u5ba2\u6236\u53ef\u900f\u904e\u6309\u4fdd\u627f\u9020\u9ad8\u9054\u4e5d\u6210\u6309\u63ed\uff0c\u50b2\u83ef\u6700\u65b0\u50f9\u55ae\u5165\u5834\u55ae\u4f4d5\u6a13C\u5ba4\u70ba\u4f8b\uff0c\u6298\u5be6\u552e\u50f9335.1\u842c\u5143\uff0c\u5373\u9996\u671f\u4f4e\u81f333\u842c\u591a\u5143\u4fbf\u53ef\u4e0a\u8eca\u3002</p>\n<p>\u4e2d\u539f\u5730\u7522\u4f55\u5049\u5f37\u8868\u793a\uff0c\u50b2\u83ef\u5468\u908a\u914d\u5957\u9f4a\u5168\uff0c\u4ea4\u901a\u4fbf\u5229\uff0c\u800c\u4e14\u9805\u76ee\u73fe\u5df2\u5c46\u73fe\u6a13\uff0c\u8cb7\u5bb6\u77ed\u671f\u5167\u5373\u53ef\u5165\u4f4f\uff0c\u76f8\u4fe1\u5c0d\u525b\u9700\u5ba2\u6975\u5177\u5438\u5f15\u529b\u3002\u800c\u6e2f\u5cf6\u5340\u79df\u8cc3\u5e02\u5834\u5411\u4f86\u6709\u4fdd\u8b49\uff0c\u6599\u9805\u76ee\u5e73\u5747\u544e\u79df\u53ef\u905465\u5143\uff0c\u82e5\u4ee5studio\u6236\u578b\u70ba\u4f8b\uff0c\u55ae\u4f4d\u9644\u9001\u5168\u5c4b\u50a2\u4fec\uff0c\u544e\u79df\u53ef\u905475\u5143\uff0c\u79df\u91d1\u56de\u5831\u53ef\u90545\u5398\uff0c\u56de\u5831\u6709\u4fdd\u8b49\uff0c\u70ba\u6295\u8cc7\u6536\u79df\u597d\u9078\u64c7\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3970284/%E4%B8%AD%E5%8E%9F%E6%8E%A8%E5%82%B2%E8%8F%AF%E7%BD%AE%E6%A5%AD%E6%8C%89%E6%8F%AD%E5%84%AA%E6%83%A0+%E6%8C%89%E6%81%AF%E4%BD%8E%E8%87%B3H%2B1.3%25", "pub_date": "2025-01-03 18:05:34", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u6e2f\u73e0\u6fb3\u5927\u6a4b\u534a\u99ac\u5468\u65e5\u958b\u8dd1 \u5927\u6703:\u6d41\u52d5\u5ec1\u6240\u500d\u589e", "description": "<p><span style=\"font-size-ignore:13pt;\">\u6e2f\u73e0\u6fb3\u5927\u6a4b\u9999\u6e2f\u6bb5\u534a\u99ac\u62c9\u677e\u5c07\u65bc\u5468\u65e5\u8209\u884c\uff0c\u4f86\u81ea\u5168\u74038000\u540d\u8dd1\u624b\u53c3\u52a0\u3002\u8cfd\u4e8b\u5206\u70ba\u6311\u6230\u7d44\u548c\u975e\u6311\u6230\u7d44\uff0c\u6311\u6230\u7d44\u8dd1\u624b\u6700\u65e9\u8d77\u6b65\uff0c\u6642\u9593\u70ba\u65e9\u4e0a7\u664215\u5206\u3002\u6311\u6230\u7d44\u7e3d\u734e\u91d1\u70ba8.08\u842c\u7f8e\u5143(\u7d0463\u842c\u6e2f\u5143)\u3002\u81f3\u65bc\u672c\u5730\u8dd1\u624b\u7e3d\u734e\u91d1\u70ba6\u842c\u6e2f\u5143\uff0c\u53c3\u8cfd\u7d44\u5225\u4ea6\u64f4\u95ca\u81f370\u6b72\u4ee5\u4e0a\u4eba\u58eb\u3002</span></p>\n<p>\u6e2f\u73e0\u6fb3\u5927\u6a4b\u9999\u6e2f\u6bb5\u534a\u99ac\u62c9\u677e\u8cfd\u4e8b\u7c4c\u59d4\u6703\u4e3b\u5e2d\u694a\u4e16\u6a21\u8868\u793a\uff0c\u8cfd\u9053\u8d77\u9ede\u70ba\u6e2f\u73e0\u6fb3\u5927\u6a4b\u9999\u6e2f\u9023\u63a5\u8def\uff0c\u53c3\u8cfd\u8005\u6cbf\u73e0\u6d77\u65b9\u5411\u8dd1\uff0c\u5230\u5dee\u4e0d\u591a\u7cb5\u6e2f\u5206\u754c\u7dda\u8abf\u982d\uff0c\u6cbf\u8def\u67096\u500b\u6c34\u7ad9\uff0c\u90e8\u5206\u6703\u63d0\u4f9b\u904b\u52d5\u98f2\u6599\uff0c\u73fe\u5834\u4ea6\u6703\u6d3e\u767c\u9999\u8549\u3002\u9451\u65bc\u53bb\u5e74\u6709\u8dd1\u624b\u63d0\u51fa\u6d41\u52d5\u5ec1\u6240\u4e0d\u8db3\uff0c\u4eca\u5e74\u8d77\u9ede\u3001\u7d42\u9ede\u5171\u670970\u500b\u6d41\u52d5\u5ec1\u6240\uff0c\u6574\u500b\u8cfd\u9053\u6709130\u500b\u6d41\u52d5\u5ec1\u6240\uff0c\u6578\u91cf\u6bd4\u53bb\u5e74\u500d\u589e\uff0c\u627f\u5efa\u5546\u4ea6\u6703\u5728\u5c01\u8def\u671f\u9593\u5728\u6a4b\u4e0a\u7684\u63a5\u99c1\u4f4d\u92ea\u9632\u6ed1\u8edf\u588a\uff0c\u6e1b\u5c11\u610f\u5916\u767c\u751f\u3002</p>\n<p>\u6bd4\u8cfd\u7576\u65e5\u6e2f\u9435\u5c07\u5b89\u63923\u73ed\u6a5f\u5834\u5feb\u7dda\u7279\u5225\u5217\u8eca\uff0c\u5206\u5225\u63d0\u65e9\u65bc\u6e05\u66685\u664215\u5206\u30015\u664225\u5206\u548c5\u664235\u5206\uff0c\u63a5\u8f09\u8dd1\u624b\u5230\u4e9e\u6d32\u570b\u969b\u535a\u89bd\u9928\u96c6\u5408\u3001\u6838\u5be6\u8eab\u4efd\u4e26\u5b89\u6aa2\uff0c\u6234\u4e0a\u624b\u5e36\u624d\u53ef\u767b\u4e0a\u5927\u6703\u6307\u5b9a\u8eca\u8f1b\u5230\u8d77\u9ede\u6bd4\u8cfd\u3002</p>\n<p>\u8b66\u65b9\u8868\u793a\uff0c\u7531\u660e\u65e5\u8d77\u4ecb\u4e4e\u6e2f\u73e0\u6fb3\u5927\u6a4b\u9999\u6e2f\u53e3\u5cb8\u8207\u7cb5\u6e2f\u5206\u754c\u7dda\u7684\u6e2f\u73e0\u6fb3\u5927\u6a4b\u9999\u6e2f\u9023\u63a5\u8def\uff0c\u5206\u968e\u6bb5\u5be6\u65bd\u81e8\u6642\u4ea4\u901a\u5b89\u6392\u3002\u9996\u968e\u6bb5\u5728\u660e\u65e5\u4e0b\u53484\u6642\u81f3\u665a\u4e0a11\u6642\uff0c\u6e2f\u73e0\u6fb3\u5927\u6a4b\u9999\u6e2f\u9023\u63a5\u8def\u5f80\u9999\u6e2f\u65b9\u5411\u7684\u5de6\u7dda\u53ca\u4e2d\u7dda\u5c07\u6703\u5c01\u9589\uff0c\u56de\u6e2f\u8eca\u8f1b\u53ea\u80fd\u4f7f\u7528\u53f3\u7dda\u524d\u5f80\u6e2f\u73e0\u6fb3\u9999\u6e2f\u53e3\u5cb8\u6216\u901a\u95dc\u5ee3\u5834\u3002</p>\n<p>\u7b2c\u4e8c\u968e\u6bb5\u5c01\u8def\u7531\u660e\u665a11\u6642\u958b\u59cb\uff0c\u6e2f\u73e0\u6fb3\u5927\u6a4b\u5f80\u73e0\u6d77\u53ca\u6fb3\u9580\u65b9\u5411\u5c07\u6703\u5168\u7dda\u5c01\u9589\uff0c\u5be6\u65bd\u55ae\u6a4b\u96d9\u7a0b\u81e8\u6642\u4ea4\u901a\u63aa\u65bd\uff0c\u96e2\u6e2f\u8eca\u8f1b\u5c07\u6539\u9053\u5230\u5c0d\u9762\u7684\u884c\u8eca\u7dda\u524d\u5f80\u73e0\u6d77\u6216\u6fb3\u9580\uff0c\u76f4\u81f3\u5468\u65e5\u4e0b\u5348\u7d042\u6642\u89e3\u5c01\uff0c\u800c\u6e2f\u73e0\u6fb3\u5927\u6a4b\u9999\u6e2f\u9023\u63a5\u8def\u5f80\u9999\u6e2f\u65b9\u5411\u65bc\u4e0b\u5348\u7d044\u6642\u534a\u5168\u7dda\u89e3\u5c01\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3970272/%E6%B8%AF%E7%8F%A0%E6%BE%B3%E5%A4%A7%E6%A9%8B%E5%8D%8A%E9%A6%AC%E5%91%A8%E6%97%A5%E9%96%8B%E8%B7%91+%E5%A4%A7%E6%9C%83%3A%E6%B5%81%E5%8B%95%E5%BB%81%E6%89%80%E5%80%8D%E5%A2%9E", "pub_date": "2025-01-03 18:00:44", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u5bb6\u5ead\u8ffd\u50f9\u81f3850\u842c\u8cfc\u6717\u9038\u5cef\u4e09\u623f", "description": "<p><span style=\"font-size-ignore:13pt;\">\u8343\u7063\u6717\u9038\u5cef6\u5ea7\u4e2d\u5c64A\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d929\u65b9\u544e\uff0c3\u623f\u5957\u623f\u9593\u9694\uff0c\u671b\u5e02\u666f\u3002\u539f\u696d\u4e3b\u53bb\u5e74\u4ee51090\u842c\u5143\u653e\u76e4\uff0c\u6700\u65b0\u53eb\u50f9930\u842c\uff0c\u8fd1\u65e5\u7372\u8cb7\u5bb6\u5782\u9752\uff0c\u9084\u50f9800\u842c\u5143\u6d3d\u8cfc\uff0c\u696d\u4e3b\u898b\u8cb7\u5bb6\u6709\u8aa0\u610f\uff0c\u80af\u6e1b\u81f3850\u842c\u5143\uff1b\u6700\u5f8c\u8cb7\u5bb6\u8ffd\u50f950\u842c\u5143\u627f\u63a5\uff0c\u5be6\u7528\u544e\u50f99150\u5143\u3002</span></p>\n<p>\u4e2d\u539f\u5730\u7522\u8868\u793a\uff0c\u65b0\u8cb7\u5bb6\u70ba\u5bb6\u5ead\uff0c\u898b\u606f\u53e3\u56de\u843d\u8d81\u6a5f\u63db\u6a13\uff0c\u65e5\u524d\u8ce3\u51fa\u820a\u5c45\uff0c\u5fc3\u5100\u55ae\u4f4d\u666f\u81f4\u6021\u4eba\uff1b\u52a0\u4e0a\u95ca\u843d\u5be6\u7528\uff0c\u96a8\u5373\u8cb7\u5165\u4f5c\u65b0\u5c45\u3002</p>\n<p>\u539f\u696d\u4e3b\u5247\u65bc2004\u5e744\u6708\u4ee5460\u842c\u5143\u8cfc\u5165\u4e0a\u8ff0\u55ae\u4f4d\uff0c\u7d2f\u6e1b240\u842c\u5143\u621622%\u6cbd\u51fa\uff1b\u8cec\u9762\u7372\u5229390\u842c\u5143\uff0c\u7269\u696d\u572820\u5e74\u9593\u5347\u503c\u7d0485%\u3002</p>\n<p>\u00a0</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3969695/%E5%AE%B6%E5%BA%AD%E8%BF%BD%E5%83%B9%E8%87%B3850%E8%90%AC%E8%B3%BC%E6%9C%97%E9%80%B8%E5%B3%AF%E4%B8%89%E6%88%BF", "pub_date": "2025-01-03 18:00:43", "source": "hkej", "kind": 1, "language": "zh-HK"}]}