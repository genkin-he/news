5408\u8a08\uff0c\u5408\u7d04\u7269\u696d\u92b7\u552e1988.48\u5104\u5143\uff0c\u6309\u5e74\u8dcc16.8%\u3002\u76f8\u61c9\u7684\u7d2f\u8a08\u92b7\u552e\u9762\u7a4d\u7d04763.04\u842c\u5e73\u65b9\u7c73\uff0c\u6309\u5e74\u4e0b\u964d26.1%\u3002</p>\n<p>\u622a\u81f39\u6708\u5e95\uff0c\u9304\u5f97\u5df2\u8a8d\u8cfc\u7269\u696d\u92b7\u552e152.97\u5104\u5143\uff0c\u9810\u671f\u5f80\u5f8c\u6578\u6708\u5c07\u8f49\u5316\u70ba\u5408\u7d04\u92b7\u552e\u3002</p>\n<p>\u4e2d\u6d77\u59169\u6708\u5728\u6df1\u5733\u3001\u6d77\u53e3\u3001\u9577\u6625\u548c\u77f3\u5bb6\u838a\u5408\u5171\u6536\u8cfc4\u5e45\u5730\uff0c\u6b0a\u76ca\u5efa\u7bc9\u9762\u7a4d\u8fd148.44\u842c\u5e73\u65b9\u7c73\uff0c\u96c6\u5718\u5c31\u76f8\u95dc\u571f\u5730\u6536\u8cfc\u7684\u6b0a\u76ca\u571f\u5730\u51fa\u8b93\u91d1\u7d0440.57\u5104\u5143\u3002</p>   </div>\n<p></p>\n<div class=\"hkej_hkex_notice_dl_btn_2014\">\n<a href=\"https://www1.hkexnews.hk/listedco/listconews/sehk/2024/1010/2024101000418_c.pdf\" target=\"_blank\">\u4e0b\u8f09\u6e2f\u4ea4\u6240\u901a\u544a\u539f\u6587</a>\n</div>\n        ", "link": "https://www2.hkej.com/instantnews/announcement/article/3900945/%E4%B8%AD%E6%B5%B7%E5%A4%969%E6%9C%88%E7%89%A9%E6%A5%AD%E9%8A%B7%E5%94%AE%E9%A1%8D%E8%B7%8C33%25"}, {"title": "\u5546\u52d9\u90e8\u8207\u6fb3\u9580\u7c3d\u7f72CEPA\u4fee\u8a02\u670d\u52d9\u8cbf\u6613\u5354\u8b70", "description": "<p>\u4e2d\u570b\u5546\u52d9\u90e8\u570b\u969b\u8cbf\u6613\u8ac7\u5224\u526f\u4ee3\u8868\u674e\u8a60\u7b91\u8207\u6fb3\u9580\u7d93\u6fdf\u8ca1\u653f\u53f8\u53f8\u9577\u674e\u5049\u8fb2\uff0c\u5728\u6fb3\u9580\u5171\u540c\u7c3d\u7f72\u300a\u95dc\u65bc\u4fee\u8a02\u300a\u5167\u5730\u8207\u6fb3\u9580\u95dc\u65bc\u5efa\u7acb\u66f4\u7dca\u5bc6\u7d93\u8cbf\u95dc\u4fc2\u7684\u5b89\u6392\u300b(CEPA)\u670d\u52d9\u8cbf\u6613\u5354\u8b70\u7684\u5354\u8b70\u4e8c\u300b\u3002\u300a\u5354\u8b70\u4e8c\u300b\u81ea\u7c3d\u7f72\u4e4b\u65e5\u8d77\u751f\u6548\uff0c\u4e26\u5c07\u65bc\u660e\u5e743\u67081\u65e5\u8d77\u6b63\u5f0f\u5be6\u65bd\u3002</p>\n<p>\u6b64\u6b21\u4fee\u8a02\u662f\u8cab\u5fb9\u843d\u5be6\u9ee8\u7684\u4e8c\u5341\u5927\u548c\u4e8c\u5341\u5c46\u4e8c\u4e2d\u3001\u4e09\u4e2d\u5168\u6703\u7cbe\u795e\uff0c\u5065\u5168\u6fb3\u9580\u5728\u570b\u5bb6\u5c0d\u5916\u958b\u653e\u4e2d\u66f4\u597d\u767c\u63ee\u4f5c\u7528\u6a5f\u5236\u7684\u91cd\u8981\u8209\u63aa\u3002\u9019\u4e5f\u662f\u7e7c2019\u5e74\u9996\u6b21\u4fee\u8a02\u5f8c\uff0c\u5c0d\u300aCEPA\u670d\u52d9\u8cbf\u6613\u5354\u5b9a\u300b\u7684\u518d\u6b21\u4fee\u8a02\uff0c\u5c07\u9032\u4e00\u6b65\u6df1\u5316\u5169\u5730\u7d93\u8cbf\u4ea4\u6d41\u5408\u4f5c\uff0c\u70ba\u6fb3\u9580\u7d93\u6fdf\u9069\u5ea6\u591a\u5143\u767c\u5c55\u63d0\u4f9b\u6709\u529b\u652f\u6490\uff0c\u652f\u6301\u6fb3\u9580\u767c\u5c55\u7d93\u6fdf\u3001\u6539\u5584\u6c11\u751f\uff0c\u66f4\u597d\u878d\u5165\u570b\u5bb6\u767c\u5c55\u5927\u5c40\u3002</p>\n<p>\u6b64\u6b21\u4fee\u8a02\u7d50\u5408\u4e86\u6fb3\u9580\u7d93\u6fdf\u793e\u6703\u767c\u5c55\u9700\u8981\u548c\u696d\u754c\u7684\u8a34\u6c42\uff0c\u5728\u91d1\u878d\u3001\u96fb\u8a0a\u3001\u5efa\u7bc9\u3001\u65c5\u904a\u7b49\u9818\u57df\uff0c\u9032\u4e00\u6b65\u964d\u4f4e\u6216\u53d6\u6d88\u5c0d\u6fb3\u9580\u670d\u52d9\u63d0\u4f9b\u8005\u7684\u51c6\u5165\u9580\u6abb\uff0c\u4fbf\u5229\u5176\u5728\u5167\u5730\u5c31\u696d\u57f7\u696d\uff1b\u90e8\u5206\u958b\u653e\u63aa\u65bd\u5c07\u5728\u5927\u7063\u5340\u7387\u5148\u5be6\u65bd\uff0c\u9032\u4e00\u6b65\u63a8\u9032\u7cb5\u6e2f\u6fb3\u5927\u7063\u5340\u6a5f\u5236\u5c0d\u63a5\u3001\u898f\u5247\u929c\u63a5\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3900944/%E5%95%86%E5%8B%99%E9%83%A8%E8%88%87%E6%BE%B3%E9%96%80%E7%B0%BD%E7%BD%B2CEPA%E4%BF%AE%E8%A8%82%E6%9C%8D%E5%8B%99%E8%B2%BF%E6%98%93%E5%8D%94%E8%AD%B0"}, {"title": "\u5e0c\u723e\u9813\u4e2d\u5fc3\u9ad8\u5c64\u4e09\u623f\u7d2f\u6e1b130\u842c\u6cbd", "description": "<p>\u6c99\u7530\u5e0c\u723e\u9813\u4e2d\u5fc3C\u5ea7\u9ad8\u5c6408\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d475\u65b9\u544e\uff0c3\u623f\u9593\u9694\uff0c\u958b\u50f9\u7d04690\u842c\u5143\uff0c\u5176\u5f8c\u6e1b\u81f3620\u842c\u5143\uff0c\u65e5\u524d\u8b70\u50f9\u5f8c\u4ee5560\u842c\u5143\u7372\u627f\u63a5\uff0c\u7d2f\u6e1b130\u842c\u5143\uff0c\u5be6\u7528\u544e\u50f911789\u5143\u3002</p>\n<p>\u4e2d\u539f\u5730\u7522\u8868\u793a\uff0c\u65b0\u8cb7\u5bb6\u70ba\u7528\u5bb6\uff0c\u898b\u5c4b\u82d1\u4ea4\u901a\u65b9\u4fbf\uff0c\u539f\u696d\u4e3b\u63d0\u4f9b\u5408\u7406\u8b70\u50f9\u7a7a\u9593\uff0c\u5373\u627f\u63a5\u55ae\u4f4d\u81ea\u7528\u3002</p>\n<p>\u64da\u4e86\u89e3\uff0c\u539f\u696d\u4e3b\u65bc1997\u5e74\u4ee5\u7d04267\u842c\u5143\u8cfc\u5165\u55ae\u4f4d\uff0c\u6301\u8ca827\u5e74\uff0c\u662f\u6b21\u6613\u624b\u8cec\u9762\u7372\u5229293\u842c\u5143\uff0c\u55ae\u4f4d\u671f\u5167\u5347\u503c\u7d041.1\u500d\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3900785/%E5%B8%8C%E7%88%BE%E9%A0%93%E4%B8%AD%E5%BF%83%E9%AB%98%E5%B1%A4%E4%B8%89%E6%88%BF%E7%B4%AF%E6%B8%9B130%E8%90%AC%E6%B2%BD"}, {"title": "\u5167\u5730\u660e\u8d77\u8abf\u9ad8\u6210\u54c1\u6cb9\u50f9\u683c", "description": "<p>\u767c\u6539\u59d4\u8868\u793a\uff0c\u6839\u64da\u8fd1\u671f\u570b\u969b\u5e02\u5834\u6cb9\u50f9\u8b8a\u5316\u60c5\u6cc1\uff0c\u6309\u7167\u73fe\u884c\u6210\u54c1\u6cb9\u50f9\u683c\u5f62\u6210\u6a5f\u5236\uff0c\u81ea\u660e\u65e5\u51cc\u6668\u96f6\u6642\u8d77\uff0c\u570b\u5167\u6c7d\u3001\u67f4\u6cb9\u50f9\u683c\u6bcf\u5678\u5206\u5225\u4e0a\u6f32140\u5143(\u4eba\u6c11\u5e63\u2027\u4e0b\u540c)\u548c135\u5143\u3002</p>\n<p>\u767c\u6539\u59d4\u7a31\uff0c\u4e2d\u77f3\u6cb9\u3001\u4e2d\u77f3\u5316\u3001\u4e2d\u6d77\u6cb9\u4e09\u5927\u516c\u53f8\u53ca\u5176\u4ed6\u539f\u6cb9\u52a0\u5de5\u4f01\u696d\uff0c\u8981\u7d44\u7e54\u597d\u6210\u54c1\u6cb9\u751f\u7522\u548c\u8abf\u904b\uff0c\u78ba\u4fdd\u5e02\u5834\u7a69\u5b9a\u4f9b\u61c9\uff0c\u56b4\u683c\u57f7\u884c\u570b\u5bb6\u50f9\u683c\u653f\u7b56\u3002\u5404\u5730\u76f8\u95dc\u90e8\u9580\u8981\u52a0\u5927\u5e02\u5834\u76e3\u7763\u6aa2\u67e5\u529b