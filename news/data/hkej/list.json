5c07\u70ba634\u9593\uff0c\u7e3d\u8a08\u96c6\u5718\u65d7\u4e0b\u5404\u4e8b\u696d\u5206\u90e8\u9580\u5e97\u7e3d\u6578\u5c07\u9054\u52303698\u9593\u3002</p>   </div>\n<p></p>\n<div class=\"hkej_hkex_notice_dl_btn_2014\">\n<a href=\"https://www.fastretailing.com/tc/ir/library/pdf/tanshin202408_4q_tc.pdf\" target=\"_blank\">\u4e0b\u8f09\u6e2f\u4ea4\u6240\u901a\u544a\u539f\u6587</a>\n</div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3900760/%E8%BF%85%E9%8A%B7%E5%85%A8%E5%B9%B4%E5%A4%9A%E8%B3%BA25.6%25"}, {"title": "\u65e5\u80a1\u6536\u5347102\u9ede \u5169\u9023\u5347", "description": "<p>\u7f8e\u80a1\u9694\u665a\u4e0a\u5347\uff0c\u5176\u4e2d\u6a19\u6307\u8207\u9053\u6307\u9f4a\u5275\u6536\u5e02\u7d00\u9304\u9ad8\u4f4d\uff0c\u4e9e\u592a\u5340\u80a1\u5e02\u8ddf\u96a8\u8d70\u9ad8\u3002</p>\n<p>\u65e5\u672c\u80a1\u5e02\u9023\u5347\u5169\u65e5\uff0c\u65e5\u7d93\u5e73\u5747\u6307\u6578\u9ad8\u958b297\u9ede\uff0c\u96a8\u5f8c\u7dad\u6301\u5347\u52e2\uff0c\u6700\u591a\u5347338\u9ede\u62160.86%\uff0c\u9ad8\u898b39616\u9ede\uff0c\u5168\u65e5\u6536\u5e02\u583139380\u9ede\uff0c\u5347102\u9ede\u62160.26%\u3002</p>\n<p>\u5357\u97d3\u80a1\u5e02\u5fa9\u5e02\u9760\u7a69\uff0c\u97d3\u570b\u9996\u723e\u7d9c\u5408\u6307\u6578\u6536\u58312599\u9ede\uff0c\u53474\u9ede\u62160.19%\u3002</p>\n<p>\u6fb3\u6d32\u80a1\u5e02\u4e0a\u5347\uff0c\u6fb3\u6d32\u666e\u901a\u80a1\u6307\u6578\u6536\u58318498\u9ede\uff0c\u534741\u9ede\u62160.5%\u3002</p>\n<p>\u53f0\u7063\u4eca\u65e5\u5047\u671f\uff0c\u91d1\u878d\u5e02\u5834\u4f11\u5e02\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3900765/%E6%97%A5%E8%82%A1%E6%94%B6%E5%8D%87102%E9%BB%9E+%E5%85%A9%E9%80%A3%E5%8D%87"}, {"title": "\u6fb3\u6d32\u7e3d\u7406:\u4e2d\u570b\u5e74\u5e95\u524d\u6062\u5fa9\u9032\u53e3\u6fb3\u6d32\u9f8d\u8766", "description": "<p>\u4e2d\u570b\u570b\u52d9\u9662\u7e3d\u7406\u674e\u5f37\u5728\u842c\u8c61\u51fa\u5e2d\u6771\u4e9e\u5408\u4f5c\u9818\u5c0e\u4eba\u7cfb\u5217\u6703\u8b70\u671f\u9593\uff0c\u6703\u898b\u6fb3\u6d32\u7e3d\u7406\u963f\u723e\u5df4\u5167\u585e(Anthony Albanese)\u3002\u963f\u723e\u5df4\u5167\u585e\u6703\u5f8c\u8868\u793a\uff0c\u8207\u674e\u5f37\u5c31\u5e74\u5e95\u524d\u5168\u9762\u6062\u5fa9\u9f8d\u8766\u8cbf\u6613\u7684\u6642\u9593\u8868\u9054\u6210\u5171\u8b58\uff0c\u4e2d\u570b\u5c07\u5728\u5e74\u5e95\u524d\u6062\u5fa9\u9032\u53e3\u6fb3\u6d32\u9f8d\u8766\u3002</p>\n<p>\u65b0\u83ef\u793e\u5f15\u8ff0\u674e\u5f37\u7a31\uff0c\u76ee\u524d\u4e2d\u6fb3\u95dc\u4fc2\u7e3d\u9ad4\u7e7c\u7e8c\u5411\u597d\u767c\u5c55\uff0c\u5169\u570b\u5404\u9818\u57df\u5c0d\u8a71\u5408\u4f5c\u7a69\u6b65\u63a8\u9032\uff0c\u5730\u65b9\u548c\u4eba\u6587\u4ea4\u6d41\u66f4\u52a0\u6d3b\u8e8d\u3002\u4e2d\u65b9\u9858\u540c\u6fb3\u65b9\u9032\u4e00\u6b65\u52a0\u5f37\u76f8\u4e92\u7406\u89e3\uff0c\u6301\u7e8c\u651c\u624b\u524d\u884c\uff0c\u6253\u9020\u66f4\u52a0\u6210\u719f\u7a69\u5b9a\u3001\u66f4\u52a0\u5bcc\u6709\u6210\u679c\u7684\u4e2d\u6fb3\u5168\u9762\u6230\u7565\u5925\u4f34\u95dc\u4fc2\uff0c\u66f4\u597d\u9020\u798f\u5169\u570b\u4eba\u6c11\uff0c\u70ba\u5730\u5340\u548c\u4e16\u754c\u548c\u5e73\u7a69\u5b9a\u767c\u5c55\u4f5c\u51fa\u66f4\u5927\u8ca2\u737b\u3002</p>\n<p>\u674e\u5f37\u6307\u51fa\uff0c\u4e2d\u6fb3\u95dc\u4fc2\u7684\u672c\u8cea\u662f\u4e92\u5229\u5171\u8d0f\u3002\u4e2d\u65b9\u9858\u540c\u6fb3\u65b9\u66f4\u591a\u5206\u4eab\u767c\u5c55\u6a5f\u9047\uff0c\u7e7c\u7e8c\u52a0\u5f37\u5b8f\u89c0\u7d93\u6fdf\u653f\u7b56\u4ea4\u6d41\uff0c\u62d3\u5c55\u8cbf\u6613\u6295\u8cc7\u3001\u7da0\u8272\u767c\u5c55\u3001\u79d1\u6280\u5275\u65b0\u7b49\u9818\u57df\u5408\u4f5c\uff0c\u70ba\u5169\u570b\u5171\u540c\u767c\u5c55\u589e\u6dfb\u66f4\u591a\u52d5\u529b\u3002\u4e2d\u65b9\u6b61\u8fce\u66f4\u591a\u6fb3\u6d32\u4f01\u696d\u4f86\u4e2d\u570b\u6295\u8cc7\u8208\u696d\uff0c\u4e5f\u5e0c\u671b\u6fb3\u65b9\u80fd\u70ba\u4e2d\u570b\u4f01\u696d\u8d74\u6fb3\u6295\u8cc7\u7d93\u71df\uff0c\u63d0\u4f9b\u516c\u5e73\u3001\u5b89\u5168\u3001\u975e\u6b67\u8996\u3001\u53ef\u9810\u671f\u7684\u71df\u5546\u74b0\u5883\u3002\u96d9\u65b9\u8981\u64f4\u5927\u4eba\u6587\u4ea4\u6d41\u548c\u4eba\u54e1\u5f80\u4f86\uff0c\u592f\u5be6\u5169\u570b\u95dc\u4fc2\u7684\u53cb\u597d\u57fa\u790e\u3002\u4e00\u500b\u548c\u5e73\u3001\u7a69\u5b9a\u3001\u7e41\u69ae\u7684\u4e9e\u592a\u7b26\u5408\u4e2d\u6fb3\u4ee5\u53ca\u5730\u5340\u5404\u570b\u7684\u5171\u540c\u5229\u76ca\uff0c\u4e2d\u65b9\u9858\u540c\u6fb3\u65b9\u4e00\u9053\u52aa\u529b\uff0c\u4ee5\u5be6\u969b\u884c\u52d5\u7dad\u8b77\u4e9e\u592a\u5730\u5340\u7684\u548c\u5e73\u7a69\u5b9a\u3002</p>\n<p>\u963f\u723e\u5df4\u5167\u585e\u8868\u793a\uff0c\u6fb3\u4e2d\u95dc\u4fc2\u7576\u524d\u767c\u5c55\u52e2\u982d\u7a4d\u6975\u7a69\u5b9a\uff0c\u5916\u4ea4\u3001\u7d93\u6fdf\u7b49\u9818\u57df\u5c0d\u8a71\u5bc6\u96c6\u958b\u5c55\u3002\u6fb3\u65b9\u9858\u540c\u4e2d\u65b9\u9032\u4e00\u6b65\u52a0\u5f37\u9ad8\u5c64\u53ca\u5404\u7d1a\u5225\u5c0d\u8a71\u5408\u4f5c\uff0c\u672c\u7740\u76f8\u4e92\u5c0a\u91cd\u7684\u7cbe\u795e\u5766\u8aa0\u6e9d\u901a\uff0c\u6df1\u5316\u7d93\u8cbf\u3001\u7da0\u8272\u7d93\u6fdf\u3001\u6e05\u6f54\u80fd\u6e90\u3001\u6c23\u5019\u8b8a\u5316\u3001\u4eba\u6587\u7b49\u9818\u57df\u5408\u4f5c\uff0c\u63a8\u52d5\u5169\u570b\u95dc\u4fc2\u6301\u7e8c\u5411\u597d\u767c\u5c55\u3002\u6fb3\u65b9\u5805\u6301\u300c\u4e00\u500b\u4e2d\u570b\u300d\u653f\u7b56\u3002\u6fb3\u65b9\u9858\u540c\u4e2d\u65b9\u5728\u591a\u908a\u9818\u57df\u52a0\u5f37\u5354\u8abf\uff0c\u5171\u540c\u7dad\u8b77\u5730\u5340\u548c\u4e16\u754c\u548c\u5e73\u3001\u7a69\u5b9a\u8207\u7e41\u69ae\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3900762/%E6%BE%B3%E6%B4%B2%E7%B8%BD%E7%90%86%3A%E4%B8%AD%E5%9C%8B%E5%B9%B4%E5%BA%95%E5%89%8D%E6%81%A2%E5%BE%A9%E9%80%B2%E5%8F%A3%E6%BE%B3%E6%B4%B2%E9%BE%8D%E8%9D%A6"}, {"title": "\u5bcc\u885b\u59d4\u4efb\u96f7\u97dc\u6f64\u70ba\u96c6\u5718\u7b56\u7565\u7e3d\u76e3", "description": "<p>\u5bcc\u885b\u96c6\u5718\u5ba3\u5e03\u59d4\u4efb\u96f7\u97dc\u6f64(Peter Reynolds)\u70ba\u96c6\u5718\u7b56\u7565\u7e3d\u76e3\uff0c\u81ea\u4eca\u5e7411\u67081\u65e5\u751f\u6548\u3002</p>\n<p>\u96f7\u97dc\u6f64\u66fe\u65bc\u570b\u969b\u7ba1\u7406\u8aee\u8a62\u516c\u53f8\u5967\u7def\u8aee\u8a62\u64d4\u4efb\u8463\u4e8b\u5408\u5925\u4eba\u3001\u4e9e\u592a\u5340\u7522\u696d\u8ca0\u8cac\u4eba\u548c\u5927\u4e2d\u83ef\u4e3b\u7ba1\u3002\u96f7\u97dc\u6f64\u5c07\u6210\u70ba\u96c6\u5718\u57f7\u884c\u59d4\u54e1\u6703\u6210\u54e1\uff0c\u76f4\u63a5\u5411\u5bcc\u885b\u96c6\u5718\u884c\u653f\u7e3d\u88c1\u9ec3\u6e05\u98a8\u6ed9\u5831\u3002</p>\n<p>\u9ec3\u6e05\u98a8\u7a31\uff0c\u975e\u5e38\u6b61\u8fce\u96f7\u97dc\u6f64\u7684\u52a0\u5165\uff0c\u4ed6\u5c07\u5e36\u9818\u96c6\u5718\u4e0b\u4e00\u968e\u6bb5\u7684\u7b56\u7565\u898f\u5283\u548c\u767c\u5c55\uff0c\u4ee5\u53ca\u5e36\u9818\u96c6\u5718\u5728\u696d\u754c\u4e2d\u7a81\u570d\u800c\u51fa\u3002\u96f7\u97dc\u6f64<span style=\"font-size-ignore:13pt;\">\u7684\u7d93\u9a57\u548c\u898b\u89e3\u5c07\u6709\u5229\u96c6\u5718\u7e7c\u7e8c\u64f4\u5c55\u696d\u52d9\u3001\u5728\u5bcc\u885b10\u500b\u5e02\u5834\u4e2d\u6301\u7e8c\u722d\u53d6\u884c\u696d\u9818\u5c0e\u5730\u4f4d\uff0c\u53ca\u5be6\u73fe\u53ef\u6301\u7e8c\u76c8\u5229\u3002</span><span style=\"font-size-ignore:13pt;\"><br /></span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u96f7\u97dc\u6f64\u8868\u793a\uff0c\u5bcc\u885b\u7684\u898f\u6a21\u5728\u904e\u53bb11\u5e74\u9593\u8fc5\u901f\u64f4\u5927\uff0c\u5176\u5718\u968a\u6210\u529f\u70ba\u4e9e\u6d32\u6578\u4ee5\u767e\u842c\u4eba\u63d0\u4f9b\u7c21\u55ae\u3001\u4fbf\u5229\u800c\u4e14\u76f8\u5b9c\u5be6\u60e0\u7684\u4fdd\u96aa\u670d\u52d9\u3002\u96a8\u7740\u4e9e\u6d32\u7684\u4e2d\u7522\u968e\u7d1a\u6301\u7e8c\u589e\u9577\uff0c\u73fe\u5728\u6b63\u662f\u4e00\u500b\u7d55\u4f73\u6642\u6a5f\u52a0\u5165\u5bcc\u885b\uff0c\u70ba\u5927\u773e\u5275\u9020\u4fdd\u96aa\u65b0\u9ad4\u9a57\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3900764/%E5%AF%8C%E8%A1%9B%E5%A7%94%E4%BB%BB%E9%9B%B7%E9%9F%9C%E6%BD%A4%E7%82%BA%E9%9B%86%E5%9C%98%E7%AD%96%E7%95%A5%E7%B8%BD%E7%9B%A3"}, {"title": "\u5357\u97d3:\u5317\u97d3\u5272\u88c2\u5169\u5730\u5c6c\u53cd\u6c11\u65cf\u884c\u70ba", "description": "<p>\u5317\u97d3\u6628\u5929\u5ba3\u5e03\u5373\u65e5\u8d77\u6c38\u4e45\u5207\u65b7\u63a5\u58e4\u5357\u97d3\u7684\u908a\u5883\uff0c\u6307\u6b64\u8209\u662f\u56de\u61c9\u5357\u97d3\u8ecd\u4e8b\u6f14\u7fd2\uff0c\u6e96\u5099\u9032\u884c\u9632\u79a6\u8a2d\u65bd\u5f37\u5316\u52a0\u56fa\u5de5\u7a0b\u3002</p>\n<p>\u5357\u97d3\u7d71\u4e00\u90e8\u4eca\u65e5\u5c0d\u6b64\u4e88\u4ee5\u5f37\u70c8\u8b74\u8cac\uff0c\u7a31\u671d\u65b9\u6b64\u8209\u8f9c\u8ca0\u97d3\u671d\u5169\u5730\u6c11\u773e\u7684\u671f\u671b\uff0c\u662f\u53cd\u7d71\u4e00\u3001\u53cd\u6c11\u65cf\u884c\u70ba\u3002</p>\n<p>\u7d71\u4e00\u90e8\u5f37\u8abf\uff0c\u653f\u5e9c\u5c07\u7acb\u8db3\u65bc\u5357\u97d3\u300a\u61b2\u6cd5\u300b\u548c\u300c\u516b\u4e00\u4e94\u7d71\u4e00\u6230\u7565\u300d\u63d0\u51fa\u7684\u81ea\u7531\u6c11\u4e3b\u57fa\u672c\u79e9\u5e8f\uff0c\u5805\u5b9a\u4e0d\u79fb\u5730\u63a8\u9032\u548c\u5e73\u7d71\u4e00\u4e8b\u696d\u3002</p>\n<p>\u5c31\u5317\u97d3\u53ea\u5411\u7f8e\u8ecd\u901a\u5831\u975e\u8ecd\u4e8b\u5340\u5167\u7684\u65bd\u5de5\u8a08\u5283\uff0c\u800c\u672a\u53e6\u884c\u901a\u5831\u97d3\u65b9\u3002\u7d71\u4e00\u90e8\u63a8\u6e2c\u671d\u65b9\u6b63\u5728\u63a8\u884c\u97d3\u671d\u300c\u6575\u5c0d\u570b\u300d\u65b9\u91dd\uff0c\u6216\u56e0\u6b64\u907f\u514d\u8207\u97d3\u65b9\u63a5\u89f8\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3900763/%E5%8D%97%E9%9F%93%3A%E5%8C%97%E9%9F%93%E5%89%B2%E8%A3%82%E5%85%A9%E5%9C%B0%E5%B1%AC%E5%8F%8D%E6%B0%91%E6%97%8F%E8%A1%8C%E7%82%BA"}]}