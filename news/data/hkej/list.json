1a\u9152\u5e97\u3002</p>\n<p>\u9152\u5e97\u63d0\u4f9b1000\u9593\u5ba2\u623f\u3001\u8d85\u904e7\u842c\u65b9\u544e\u7684\u7121\u67f1\u5f0f\u6703\u8b70\u53ca\u5c55\u89bd\u7a7a\u9593\uff0c\u66f4\u5177\u5099\u9910\u98f2\u548c\u4f11\u61a9\u8a2d\u65bd\uff0c\u4ee5\u53ca\u64c1\u6709\u8d85\u904e400\u500b\u505c\u8eca\u4f4d\u3002</p>\n<p>\u5408\u548c\u9152\u5e97\u63a8\u51fa\u300c\u9152\u5e97\u958b\u5e55\u7cbe\u5f69\u5ba2\u623f\u79ae\u9047\u300d\uff0c\u5373\u65e5\u8d77\u53ef\u4eab75\u6298\u512a\u60e0\uff0c\u623f\u50f91538\u5143\u8d77\uff0c\u512a\u60e0\u671f\u81f3\u660e\u5e742\u670828\u65e5\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3947526/%E5%90%88%E5%92%8C%E9%85%92%E5%BA%97%E4%B8%8B%E5%91%A8%E4%BA%8C%E8%A9%A6%E6%A5%AD"}, {"title": "\u9038\u5cef\u4e2d\u5c64\u958b\u653e\u62361.09\u842c\u79df\u51fa", "description": "<p>\u7c89\u5dba\u9038\u5cef3\u5ea7\u4e2d\u5c64F\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d326\u65b9\u544e\uff0c\u958b\u653e\u5f0f\u9593\u9694\uff0c\u671b\u6e05\u975c\u5167\u5712\u666f\uff0c\u6700\u521d\u53eb\u79df1.25\u842c\u5143\uff0c\u696d\u4e3b\u898b\u79df\u5ba2\u5feb\u8d77\u79df\uff0c\u9042\u4ee51.09\u842c\u5143\u79df\u51fa\uff0c\u5be6\u7528\u544e\u79df33\u5143\u3002</p>\n<p>\u4e2d\u539f\u5730\u7522\u8868\u793a\uff0c\u696d\u4e3b\u65bc2016\u5e748\u6708\u4ee5345.8\u842c\u5143\u8cb7\u5165\u55ae\u4f4d\uff0c\u6301\u8ca88\u5e74\u591a\uff0c\u662f\u6b21\u51fa\u79df\u53ef\u4eab\u79df\u91d1\u56de\u58313.8\u5398\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3947246/%E9%80%B8%E5%B3%AF%E4%B8%AD%E5%B1%A4%E9%96%8B%E6%94%BE%E6%88%B61.09%E8%90%AC%E7%A7%9F%E5%87%BA"}, {"title": "\u6771\u4e9e\u9280\u884c\u59d4\u7562\u660e\u5f37\u4efb\u526f\u884c\u653f\u7e3d\u88c1", "description": "<p>\u6771\u4e9e\u9280\u884c(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00023' >00023</a>)\u516c\u5e03\uff0c\u7562\u660e\u5f37\u7372\u59d4\u4efb\u70ba\u96c6\u5718\u526f\u884c\u653f\u7e3d\u88c1\uff0c\u4e3b\u8981\u8ca0\u8cac\u7ba1\u7406\u96c6\u5718\u7684\u5168\u8cc7\u9644\u5c6c\u516c\u53f8\u6771\u4e9e\u9280\u884c(\u4e2d\u570b)\u6709\u9650\u516c\u53f8\uff0c\u5373\u65e5\u8d77\u751f\u6548\u3002</p>\n<p>\u7562\u660e\u5f37\u64c1\u670927\u5e74\u9280\u884c\u696d\u7684\u5c08\u696d\u7d93\u9a57\u3002\u5728\u52a0\u5165\u96c6\u5718\u524d\uff0c\u4ed6<span style=\"font-size-ignore:13pt;\">\u66fe\u5728\u4e2d\u570b\u5167\u5730\u3001\u9999\u6e2f</span><span style=\"font-size-ignore:13pt;\">\u53ca\u6d77\u5916\u7684\u91d1\u878d\u6a5f\u69cb\u64d4\u4efb\u591a\u500b\u9ad8\u5c64\u7ba1\u7406\u8077\u4f4d\u3002</span></p>\n<p>\u00a0</p>   </div>\n<p></p>\n<div class=\"hkej_hkex_notice_dl_btn_2014\">\n<a href=\"https://www1.hkexnews.hk/listedco/listconews/sehk/2024/1205/2024120500533_c.pdf\" target=\"_blank\">\u4e0b\u8f09\u6e2f\u4ea4\u6240\u901a\u544a\u539f\u6587</a>\n</div>\n        ", "link": "https://www2.hkej.com/instantnews/announcement/article/3947389/%E6%9D%B1%E4%BA%9E%E9%8A%80%E8%A1%8C%E5%A7%94%E7%95%A2%E6%98%8E%E5%BC%B7%E4%BB%BB%E5%89%AF%E8%A1%8C%E6%94%BF%E7%B8%BD%E8%A3%81"}, {"title": "\u6109\u666f\u65b0\u57ce\u4e2d\u5c64\u4e09\u623f\u7d2f\u6e1b182\u842c\u6613\u624b", "description": "<p><span style=\"font-size-ignore:13pt;\">\u8343\u7063\u6109\u666f\u65b0\u57ce10\u5ea7\u4e2d\u5c64E\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d581\u65b9\u544e\uff0c3\u623f\u8a2d\u8a08\uff0c9\u500b\u6708\u524d\u4ee5800\u842c\u5143\u653e\u552e\uff0c\u81f3\u8fd1\u6708\u56e0\u61c9\u5e02\u6cc1\u5c07\u53eb\u50f9\u56de\u843d\u81f3650\u842c\u5143\uff0c\u8b70\u50f9\u5f8c\u4ee5618\u842c\u5143\u552e\u51fa\uff0c\u7d2f\u6e1b182\u842c\u5143\uff0c\u5be6\u7528\u544e\u50f9\u7d0410637\u5143\u3002</span></p>\n<p>\u7f8e\u806f\u7269\u696d\u8868\u793a\uff0c\u8cb7\u5bb6\u70ba\u4e0a\u8eca\u4eba\u58eb\uff0c\u56e0\u70ba\u9810\u7b97\u4e0d\u591a\uff0c\u6700\u521d\u65bc\u6109\u666f\u65b0\u57ce\u7269\u82722\u623f\u55ae\u4f4d\uff0c\u4f46\u6709\u898b\u539f\u696d\u4e3b\u53eb\u50f9\u82072\u623f\u76f8\u82e5\uff0c\u6545\u5230\u55ae\u4f4d\u7747\u6a13\u6bd4\u8f03\uff0c\u6700\u7d42\u6210\u529f\u8cfc\u5f97\u55ae\u4f4d\u3002</p>\n<p>\u539f\u696d\u4e3b\u65bc1999\u5e74\u65bc\u4e00\u624b\u5e02\u5834\u4ee5230.1\u842c\u5143\u8cfc\u5165\u55ae\u4f4d\uff0c\u6301\u8ca825\u5e74\uff0c\u73fe\u8f49\u624b\u8cec\u9762\u7372\u5229387.9\u842c\u5143\uff0c\u7269\u696d\u5347\u503c\u7d041.7\u500d\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3947191/%E6%84%89%E6%99%AF%E6%96%B0%E5%9F%8E%E4%B8%AD%E5%B1%A4%E4%B8%89%E6%88%BF%E7%B4%AF%E6%B8%9B182%E8%90%AC%E6%98%93%E6%89%8B"}, {"title": "\u5442\u5fd7\u548c\u4e2d\u5348\u8fad\u9748\u51fa\u6baf 4\u540d\u6e2f\u6fb3\u524d\u7279\u9996\u7b49\u6276\u9748", "description": "<p>\u5609\u83ef\u96c6\u5718\u5275\u8fa6\u4eba\u517c\u4e3b\u5e2d\u5442\u5fd7\u548c<span style=\"font-size-ignore:13pt;\">\u65bc\u4eca\u65e5\u4e2d\u534812\u6642\u5728\u9999\u6e2f\u6baf\u5100\u9928\u8fad\u9748\u51fa\u6baf\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u55aa\u79ae\u6276\u9748\u4eba\u58eb\u70ba\u5168\u570b\u653f\u5354\u526f\u4e3b\u5e2d\u3001\u6fb3\u9580\u524d\u884c\u653f\u9577\u5b98\u4f55\u539a\u93f5\u3001\u653f\u52d9\u53f8\u53f8\u9577\u9673\u570b\u57fa\u3001\u6fb3\u9580\u7d93\u6fdf\u8ca1\u653f\u53f8\u53f8\u9577\u674e\u5049\u8fb2\u3001\u524d\u884c\u653f\u9577\u5b98\u66fe\u852d\u6b0a\u3001\u6fb3\u9580\u524d\u884c\u653f\u9577\u5b98\u5d14\u4e16\u5b89\u3001\u524d\u884c\u653f\u9577\u5b98\u6797\u912d\u6708\u5a25\u3001\u4e2d\u806f\u8fa6\u526f\u4e3b\u4efb\u5c39\u5b97\u83ef\u3001\u6fb3\u9580\u4e2d\u806f\u8fa6\u526f\u4e3b\u4efb\u9ec3\u67f3\u6b0a\u3001\u8449\u6a39\u6797\u53ca\u99ae\u5bb6\u5f6c\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u516c\u796d\u65bc\u4e0a\u53489\u6642\u8209\u884c\uff0c\u4f86\u81ea\u4e2d\u570b\u5167\u5730\u3001\u9999\u6e2f\u3001\u6fb3\u9580\u5404\u754c\u8d85\u904e80\u500b\u5718\u9ad4\u5230\u73fe\u5834\u81f4\u796d\u3002\u6b64\u5916\uff0c\u903e\u6578\u5343\u540d\u653f\u5546\u540d\u4eba\u53ca\u5e02\u6c11\u524d\u4f86\u81f4\u796d\uff0c\u9023\u540c\u65e9\u524d\u65bc\u6fb3\u9580\u9280\u6cb3\u570b\u969b\u6703\u8b70\u4e2d\u5fc3\u8a2d\u7f6e\u7684\u60bc\u5ff5\u5340\uff0c\u5df2\u6709\u903e\u842c\u4eba\u516c\u958b\u60bc\u5ff5\u5442\u5fd7\u548c\uff0c\u8868\u9054\u5c0d\u4ed6\u7684\u656c\u610f\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3947277/%E5%91%82%E5%BF%97%E5%92%8C%E4%B8%AD%E5%8D%88%E8%BE%AD%E9%9D%88%E5%87%BA%E6%AE%AF+4%E5%90%8D%E6%B8%AF%E6%BE%B3%E5%89%8D%E7%89%B9%E9%A6%96%E7%AD%89%E6%89%B6%E9%9D%88"}, {"title": "\u9999\u6e2f\u7f6e\u5730\u50b3\u8003\u616e\u51fa\u552e\u65b0\u52a0\u5761\u5b50\u4f01MCL\u5730\u7522", "description": "<p>\u5916\u96fb\u5f15\u8ff0\u6d88\u606f\u4eba\u58eb\u6307\uff0c\u9999\u6e2f\u7f6e\u5730\u6b63\u8003\u616e\u51fa\u552e\u65d7\u4e0b\u7e3d\u90e8\u4f4d\u65bc\u65b0\u52a0\u5761\u7684MCL\u5730\u7522\u3002</p>\n<p>\u6d88\u606f\u7a31\uff0c\u9999\u6e2f\u7f6e\u5730\u6b63\u5c0b\u6c42\u4ee5\u9ad8\u65bcMCL\u5730\u7522\u8cec\u9762\u503c11\u5104\u65b0\u52a0\u5761\u5143(\u7d0463.83\u5104\u6e2f\u5143)\u7684\u6ea2\u50f9\uff0c\u525d\u96e2MCL\u5730\u7522\u3002\u9999\u6e2f\u7f6e\u5730\u6b63\u8207\u6f5b\u5728\u7684\u8ca1\u52d9\u9867\u554f\u6d3d\u8ac7\u5e6b\u52a9\u7c4c\u5099\u4ea4\u6613\u7684\u4e8b\u5b9c\u3002</p>\n<p>\u6d88\u606f\u4eba\u58eb\u8868\u793a\uff0c\u6709\u95dc\u5546\u8b70\u6b63\u5728\u9032\u884c\u4e2d\uff0c\u9999\u6e2f\u7f6e\u5730\u4ecd\u53ef\u80fd\u9078\u64c7\u4fdd\u7559MCL\u5730\u7522\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3947484/%E9%A6%99%E6%B8%AF%E7%BD%AE%E5%9C%B0%E5%82%B3%E8%80%83%E6%85%AE%E5%87%BA%E5%94%AE%E6%96%B0%E5%8A%A0%E5%9D%A1%E5%AD%90%E4%BC%81MCL%E5%9C%B0%E7%94%A2"}]}