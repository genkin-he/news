0\u5feb\u57f9\u80b2\u767c\u5c55\u5149\u82af<span style=\"font-size-ignore:13pt;\">\u7247\u7522\u696d\uff0c\u529b\u722d\u52302030\u5e74\u53d6\u5f9710\u9805\u4ee5\u4e0a\u5149\u82af</span><span style=\"font-size-ignore:13pt;\">\u7247\u9818\u57df\u95dc\u9375\u6838\u5fc3\u6280\u8853\u7a81\u7834\uff0c\u6253\u902010\u500b\u4ee5\u4e0a\u300c\u62f3\u982d\u300d\u7522\u54c1\uff0c\u57f9\u80b210\u5bb6\u4ee5\u4e0a\u5177\u6709\u570b\u969b\u7af6\u722d\u529b\u7684\u4e00\u6d41\u9818\u8ecd\u4f01\u696d\uff0c\u5efa\u8a2d10\u500b\u5de6\u53f3\u570b\u5bb6\u548c\u7701\u7d1a\u5275\u65b0\u5e73\u53f0\uff0c\u57f9\u80b2\u5f62\u6210\u65b0\u7684\u5343\u5104\u7d1a\u7522\u696d\u96c6\u7fa4\uff0c\u5efa\u8a2d\u6210\u70ba\u5177\u6709\u5168\u7403\u5f71\u97ff\u529b\u7684\u5149\u82af</span><span style=\"font-size-ignore:13pt;\">\u7247\u7522\u696d\u5275\u65b0\u9ad8\u5730\u3002</span></p>\n<p>\u65b9\u6848\u63d0\u5230\uff0c\u7701\u91cd\u9ede\u9818\u57df\u7814\u767c\u8a08\u5283\u652f\u6301\u5149\u82af<span style=\"font-size-ignore:13pt;\">\u7247\u6280\u8853\u653b\u95dc\u3002\u52a0\u5927\u5c0d\u9ad8\u901f\u5149\u901a\u8a0a\u82af</span><span style=\"font-size-ignore:13pt;\">\u7247\u3001\u9ad8\u6027\u80fd\u5149\u50b3\u611f\u82af</span><span style=\"font-size-ignore:13pt;\">\u7247\u3001\u901a\u611f\u878d\u5408\u82af</span><span style=\"font-size-ignore:13pt;\">\u7247\u3001\u8584\u819c\u922e\u9178\u92f0\u6750\u6599\u3001\u78f7\u5316\u92a6\u896f\u5e95\u6750\u6599\u3001\u6709\u6a5f\u534a\u5c0e\u9ad4\u6750\u6599\u3001\u7845\u5149\u96c6\u6210\u6280\u8853\u3001\u67d4\u6027\u96c6\u6210\u6280\u8853\u3001\u78ca\u6676\u751f\u9577\u548c\u5916\u5ef6\u5de5\u85dd\u3001\u6838\u5fc3\u534a\u5c0e\u9ad4\u8a2d\u5099\u7b49\u65b9\u5411\u7684\u7814\u767c\u6295\u5165\u529b\u5ea6\uff0c\u7740\u529b\u89e3\u6c7a\u7522\u696d\u93c8\u4f9b\u61c9\u93c8\u7684\u300c\u5361\u9ede\u300d\u300c\u5835\u9ede\u300d\u554f\u984c\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3907689/%E5%BB%A3%E6%9D%B1%3A%E6%8E%A8%E5%8B%95%E5%88%BB%E8%9D%95%E6%A9%9F%E7%AD%89%E5%85%89%E8%8A%AF%E7%89%87%E9%97%9C%E9%8D%B5%E8%A3%9D%E5%82%99%E7%A0%94%E7%99%BC%E5%92%8C%E5%9C%8B%E7%94%A2%E5%8C%96%E6%9B%BF%E4%BB%A3"}, {"title": "\u6052\u5b89\u6a19\u6e96\u4eba\u58fd\u6599\u5167\u5730\u6709\u66f4\u591a\u589e\u91cf\u653f\u7b56\u63a8\u51fa", "description": "<p>\u6052\u5b89\u6a19\u6e96\u4eba\u58fd(\u4e9e\u6d32)\u767c\u5e032024\u5e74\u7b2c\u56db\u5b63\u5b8f\u89c0\u7d93\u6fdf\u89c0\u9ede\u5206\u6790\uff0c\u7f8e\u570b\u806f\u5132\u5c40\u6b63\u5f0f\u958b\u555f\u964d\u606f\u5468\u671f\uff0c\u7f8e\u570b\u7d93\u6fdf\u8edf\u7740\u9678\u53ef\u80fd\u6027\u589e\u52a0\uff0c\u540c\u6642\u96a8\u7740\u5e02\u5834\u9810\u671f\u806f\u5132\u5c40\u5c07\u9032\u4e00\u6b65\u6e1b\u606f\uff0c\u8cc7\u91d1\u6d41\u5411\u90e8\u5206\u65b0\u8208\u5e02\u5834\uff0c\u626d\u8f49\u5e74\u521d\u81f3\u4eca\u767c\u9054\u7d93\u6fdf\u9ad4\u80a1\u7968\u5e02\u5834\u6574\u9ad4\u8dd1\u8d0f\u767c\u5c55\u4e2d\u7d93\u6fdf\u9ad4\u7684\u60c5\u6cc1\u3002</p>\n<p>\u6052\u5b89\u6a19\u6e96\u4eba\u58fd\u4e9e\u6d32\u9996\u5e2d\u6295\u8cc7\u7e3d\u76e3\u5f35\u5f18\u8868\u793a\uff0c\u5167\u5730\u65b9\u9762\uff0c\u4e2d\u570b\u653f\u5e9c\u81ea9\u6708\u4e0b\u65ec\u958b\u59cb\u63a8\u51fa\u4e00\u7c43\u5b50\u523a\u6fc0\u653f\u7b56\uff0c\u5305\u62ec\u964d\u6e96\u3001\u964d\u606f\u3001\u964d\u5b58\u91cf\u623f\u8cb8\u5229\u7387\u3001\u964d\u9996\u4ed8\u6bd4\u4f8b\u3001\u8a2d\u7acb\u65b0\u7684\u8ca8\u5e63\u653f\u7b56\u5de5\u5177\u652f\u6301\u80a1\u5e02\u7b49\uff0c\u6307\u5411\u4e09\u500b\u76ee\u6a19\uff1a\u7a69\u589e\u9577\u3001\u7a69\u623f\u50f9\u3001\u7a69\u80a1\u5e02\uff0c\u5f8c\u7e8c\u9810\u8a08\u9084\u5c07\u6709\u66f4\u591a\u589e\u91cf\u653f\u7b56\u9678\u7e8c\u63a8\u51fa\uff0c\u63a8\u52d5\u5b8f\u89c0\u57fa\u672c\u9762\u5411\u4e0a\u3002</p>\n<p>\u56e0\u61c9\u7f8e\u570b\u53ca\u4e2d\u570b\u6700\u65b0\u7684\u8ca8\u5e63\u653f\u7b56\uff0c\u8a72\u516c\u53f8\u70ba\u4e86\u8b93\u5ba2\u6236\u6709\u66f4\u5168\u9762\u8cc7\u7522\u914d\u7f6e\u5b89\u6392\uff0c\u5728\u65d7\u4e0b\u6295\u8cc7\u76f8\u9023\u4fdd\u96aa\u65b0\u589e12\u9805\u73fe\u91d1\u80a1\u606f\u5206\u6d3e\u6295\u8cc7\u9078\u64c7\uff0c\u8986\u84cb\u80a1\u7968\u53ca\u50b5\u5238\u7b49\u5e02\u5834\uff0c\u4ee4\u6295\u8cc7\u9078\u64c7\u7e3d\u6578\u76ee\u589e\u52a0\u81f3\u8d85\u904e310\u9805\uff0c\u6210\u70ba\u9999\u6e2f\u6295\u9023\u96aa\u5e02\u5834\u4e0a\u63d0\u4f9b\u6700\u591a\u6295\u8cc7\u9078\u64c7\u7684\u4fdd\u96aa\u516c\u53f8\uff0c\u53e6\u4ea6\u65b0\u589e2\u5bb6\u57fa\u91d1\u516c\u53f8\u4f5c\u70ba\u5408\u4f5c\u5925\u4f34\uff0c\u4ee4\u6295\u8cc7\u9078\u64c7\u53ca\u57fa\u91d1\u516c\u53f8\u6578\u76ee\u5747\u662f\u5168\u6e2f\u6700\u591a\u7684\u4fdd\u96aa\u516c\u53f8\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3907863/%E6%81%92%E5%AE%89%E6%A8%99%E6%BA%96%E4%BA%BA%E5%A3%BD%E6%96%99%E5%85%A7%E5%9C%B0%E6%9C%89%E6%9B%B4%E5%A4%9A%E5%A2%9E%E9%87%8F%E6%94%BF%E7%AD%96%E6%8E%A8%E5%87%BA"}]}