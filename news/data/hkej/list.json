le/3946201/%E7%99%BE%E5%BA%A6%E6%8E%A8%E5%8D%87%E7%B4%9A%E7%89%88Apollo%E9%96%8B%E6%94%BE%E5%B9%B3%E5%8F%B010.0"}, {"title": "\u4fe1\u5229\u570b\u969b11\u6708\u71df\u696d\u984d\u8dcc1.1%", "description": "<p>\u4fe1\u5229\u570b\u969b(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00732' >00732</a>)\u516c\u5e03\uff0c11\u6708\u7d9c\u5408\u71df\u696d\u6de8\u984d\u7d0415.01\u5104\u5143\uff0c\u6309\u5e74\u6e1b\u5c11\u7d041.1%\u3002</p>\n<p>\u4eca\u5e74\u999611\u500b\u6708\uff0c\u96c6\u5718\u7d9c\u5408\u71df\u696d\u6de8\u984d\u7d04162.63\u5104\u5143\uff0c\u6309\u5e74\u589e\u52a0\u7d0416%\u3002</p>   </div>\n<p></p>\n<div class=\"hkej_hkex_notice_dl_btn_2014\">\n<a href=\"https://www1.hkexnews.hk/listedco/listconews/sehk/2024/1204/2024120401010_c.pdf\" target=\"_blank\">\u4e0b\u8f09\u6e2f\u4ea4\u6240\u901a\u544a\u539f\u6587</a>\n</div>\n        ", "link": "https://www2.hkej.com/instantnews/announcement/article/3946230/%E4%BF%A1%E5%88%A9%E5%9C%8B%E9%9A%9B11%E6%9C%88%E7%87%9F%E6%A5%AD%E9%A1%8D%E8%B7%8C1.1%25"}, {"title": "\u6ed9\u8c50\u53ca\u4e2d\u9280\u6b61\u8fce\u91d1\u7ba1\u5c40\u63a8\u4e00\u6b21\u6027\u6a13\u82b1\u6309\u63ed\u5b89\u6392", "description": "<p>\u91d1\u7ba1\u5c40\u5411\u9280\u884c\u767c\u51fa\u6307\u5f15\uff0c\u63a8\u51fa\u4e00\u6b21\u6027\u7279\u5225\u5b89\u6392\uff0c\u5bb9\u8a31\u653e\u5bec\u6700\u9ad8\u6309\u63ed\u8cb8\u6b3e\u6210\u6578\u548c\u300c\u4f9b\u6b3e\u8207\u5165\u606f\u6bd4\u7387\u300d\u4e0a\u9650\u7684\u76e3\u7ba1\u8981\u6c42\u3002<span style=\"font-size-ignore:13pt;\">\u6ed9\u8c50\u767c\u8a00\u4eba\u8868\u793a\uff0c\u6ed9\u8c50\u5168\u529b\u652f\u6301\u76f8\u95dc\u7279\u5225\u5b89\u6392\uff0c\u70ba\u8cb7\u5bb6\u5728\u7269\u696d\u5e02\u5834\u8f49\u8b8a\u4e0b\u63d0\u4f9b\u66f4\u5927\u5f48\u6027\u3002\u4f5c\u70ba\u9999\u6e2f\u9818\u5148\u7684\u6309\u63ed\u670d\u52d9\u9280\u884c\uff0c\u6ed9\u8c50\u4e00\u76f4\u81f4\u529b\u70ba\u4e0d\u540c\u5ba2\u6236\u63d0\u4f9b\u6240\u9700\u6309\u63ed\u8a08\u5283\u3002</span></p>\n<p>\u4e2d\u9280\u9999\u6e2f\u500b\u91d1\u7522\u54c1\u7e3d\u7d93\u7406\u5468\u570b\u660c\u8868\u793a\uff0c\u4e2d\u9280\u9999\u6e2f\u6b61\u8fce\u53ca\u652f\u6301\u91d1\u7ba1\u5c40\u4eca\u5929\u5ba3\u5e03\u7684\u4e00\u6b21\u6027\u7279\u5225\u6309\u63ed\u5b89\u6392\uff0c\u653e\u5bec\u65bc\u6307\u5b9a\u671f\u9593\u4ee5\u5efa\u7bc9\u671f\u4ed8\u6b3e\u8cfc\u5165\u6a13\u82b1\u4f4f\u5b85\u7269\u696d\u7528\u5bb6\u7684\u6309\u63ed\u7533\u8acb\u6210\u6578\u53ca\u4f9b\u6b3e\u6bd4\u7387\uff0c\u4ee5\u7de9\u89e3\u5176\u7533\u8acb\u6309\u63ed\u6642\uff0c\u56e0\u7269\u696d\u4f30\u50f9\u4f4e\u65bc\u6210\u4ea4\u50f9\u800c\u6240\u9762\u5c0d\u7684\u8cc7\u91d1\u5468\u8f49\u58d3\u529b\u3002\u8a72<span style=\"font-size-ignore:13pt;\">\u884c\u6703\u7e7c\u7e8c\u5168\u529b\u914d\u5408\u76e3\u7ba1\u6a5f\u69cb\u7684\u653f\u7b56\uff0c\u4ee5\u6eff\u8db3\u5e02\u6c11\u5927\u773e\u7f6e\u696d\u7684\u9700\u6c42\u3002</span></p>\n<p>\u00a0</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3946184/%E6%BB%99%E8%B1%90%E5%8F%8A%E4%B8%AD%E9%8A%80%E6%AD%A1%E8%BF%8E%E9%87%91%E7%AE%A1%E5%B1%80%E6%8E%A8%E4%B8%80%E6%AC%A1%E6%80%A7%E6%A8%93%E8%8A%B1%E6%8C%89%E6%8F%AD%E5%AE%89%E6%8E%92"}, {"title": "\u8588\u9cf4\u63a8\u65b0\u4ed8\u6b3e\u8a08\u5283 \u516c\u5c4b\u8cb7\u5bb6\u4eab30%\u6298\u6263", "description": "<p>\u5b8f\u5b89\u5730\u7522(<a target='_blank' href='https://stock360.hkej.com/quotePlus/01243' >01243</a>)\u9ec3\u5927\u4ed9\u9cf4\u9cf3\u885728\u865f\u91cd\u5efa\u9805\u76ee\u8588\u9cf4\uff0c\u4eca\u65e5\u66f4\u65b0\u50f9\u55ae\u53ca\u540c\u6642\u63a8\u51fa\u300c\u5bcc\u6236\u7f6e\u5176\u5c4b\u4ed8\u6b3e\u8a08\u5283\u300d\uff0c\u5438\u5f15\u73fe\u6709\u516c\u5c4b\u4f4f\u6236\u5165\u5e02\u3002</p>\n<p>\u5b8f\u5b89\u5730\u7522\u57f7\u884c\u8463\u4e8b\u7a0b\u5fb7\u97fb\u8868\u793a\uff0c\u8588\u9cf4\u81ea\u63a8\u552e\u81f3\u4eca\u5df2\u9304150\u5b97\u6210\u4ea4\uff0c\u5957\u73fe\u903e7.2\u5104\u5143\uff1b\u7576\u4e2d78\u5b97\u6210\u4ea4\u9078\u7528\u300c\u7f6e\u696d\u968e\u68af\u5171\u4eab\u4ed8\u6b3e\u8a08\u5283\u300d\uff0c\u5373\u8cb7\u65b9\u70ba\u300c\u7279\u9078\u516c\u5c4b\u8cb7\u5bb6\u300d\u3001\u300c2023\u5e74\u8cc7\u52a9\u51fa\u552e\u623f\u5c4b\u7533\u8acb\u8005\u300d\u6216\u300c\u5e02\u5340\u66f4\u65b0\u4f4f\u6236\u300d\uff0c\u4f54\u5168\u76e4\u6210\u4ea4\u8d85\u904e50%\u3002\u96a8\u7740\u9805\u76ee\u63a5\u8fd1\u9810\u8a08\u95dc\u9375\u65e5\u671f\u53ca\u66f4\u7a4d\u6975\u56de\u61c9\u623f\u5c4b\u9700\u6c42\uff0c\u73fe\u66f4\u65b0\u50f9\u55ae\u53ca\u540c\u6642\u63a8\u51fa\u5168\u65b0\u4ed8\u6b3e\u8a08\u5283\u2500\u2500\u300c\u5bcc\u6236\u7f6e\u5176\u5c4b\u4ed8\u6b3e\u8a08\u5283\u300d\u3002</p>\n<p>\u5b8f\u5b89\u5730\u7522\u71df\u696d\u53ca\u5e02\u52d9\u52a9\u7406\u7e3d\u7d93\u7406\u9673\u6c38\u76df\u88dc\u5145\uff0c\u300c\u5bcc\u6236\u7f6e\u5176\u5c4b\u4ed8\u6b3e\u8a08\u5283\u300d\u662f\u56de\u61c9\u653f\u5e9c\u516c\u5c4b\u4f4f\u6236\u8cc7\u52a9\u653f\u7b56\u53ca\u7dad\u8b77\u516c\u5c4b\u8cc7\u6e90\u7684\u5408\u7406\u5206\u914d\u653f\u7b56(\u5373\u5bcc\u6236\u653f\u7b56)\u7684\u5168\u65b0\u6982\u5ff5\u4ed8\u6b3e\u8a08\u5283\uff0c\u8cb7\u5bb6\u5982\u9078\u7528\u6709\u95dc\u4ed8\u6b3e\u8a08\u5283\uff0c\u53ef\u4eab\u7167\u552e\u50f9\u6e1b27%\uff1b\u9023\u540c\u300c\u5f9e\u50f9\u5370\u82b1\u7a05\u300d3%\u6298\u6263\uff0c\u5408\u5171\u53ef\u4eab\u7167\u552e\u50f9\u6e1b30%\u6298\u6263\u512a\u60e0\u3002</p>\n<p>\u9673\u6c38\u76df\u7e8c\u6307\uff0c\u5982\u8cb7\u5bb6\u70ba\u300c\u7279\u9078\u5bcc\u6236\u8cb7\u5bb6\u300d\uff0c\u66f4\u53ef\u984d\u5916\u7372\u5f976.8\u842c\u5143\u7279\u6075\u642c\u9077\u73fe\u91d1\u6d25\u8cbc\u3002\u4e0a\u8ff0\u5168\u65b0\u4ed8\u6b3e\u8a08\u5283\u53ca\u7279\u6075\u642c\u9077\u73fe\u91d1\u6d25\u8cbc\uff0c\u671f\u671b\u53ef\u4ee4\u5bcc\u6236\u653f\u7b56\u4e0b\u4f4f\u6236\u5c45\u4f4f\u9700\u6c42\u5f97\u4ee5\u6eff\u8db3\uff0c\u540c\u6642\u5229\u7528\u79c1\u4eba\u767c\u5c55\u9805\u76ee\u4f9b\u61c9\u60e0\u53ca\u516c\u71df\u623f\u5c4b\u6d41\u8f49\u653f\u7b56\u4e2d\u4e0d\u540c\u6301\u4efd\u8005\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3946160/%E8%96%88%E9%B3%B4%E6%8E%A8%E6%96%B0%E4%BB%98%E6%AC%BE%E8%A8%88%E5%8A%83+%E5%85%AC%E5%B1%8B%E8%B2%B7%E5%AE%B6%E4%BA%AB30%25%E6%8A%98%E6%89%A3"}, {"title": "\u9752\u6021\u82b1\u5712\u9ad8\u5c64\u4e09\u623f\u4f5c\u50f9560\u842c", "description": "<p>\u9752\u8863\u9752\u6021\u82b1\u57126\u5ea7\u9ad8\u5c64C\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d\u7d04547\u65b9\u544e\uff0c3\u623f1\u5957\u623f\u9593\u9694\uff0c\u671b\u5712\u666f\uff0c\u4ee5560\u842c\u5143\u6210\u4ea4\uff0c\u5be6\u7528\u544e\u50f9\u7d0410238\u5143\u3002</p>\n<p>\u5229\u5609\u95a3\u5730\u7522\u8868\u793a\uff0c\u539f\u696d\u4e3b\u65bc2015\u5e74\u4ee5\u7d04490\u842c\u5143\u8cb7\u5165\u55ae\u4f4d\uff0c\u6301\u8ca8\u81f3\u4eca\u8f49\u624b\uff0c\u8cec\u9762\u7372\u5229\u7d0470\u842c\u5143\u621614%\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3945901/%E9%9D%92%E6%80%A1%E8%8A%B1%E5%9C%92%E9%AB%98%E5%B1%A4%E4%B8%89%E6%88%BF%E4%BD%9C%E5%83%B9560%E8%90%AC"}, {"title": "\u512a\u624d\u66f8\u9662\u5c0f\u5b78\u524d\u6821\u9577\u6d89\u632a\u7528\u5343\u842c\u5143 \u4e0a\u5ead\u524d\u58ae\u6a13\u4ea1", "description": "<p>\u76f4\u8cc7\u540d\u6821\u512a\u624d(\u694a\u6bb7\u6709\u5a23)\u66f8\u9662\u5c0f\u5b78\u90e8\u524d\u6821\u9577\u8076\u654f\u6d89\u632a\u7528\u5b78\u6821\u903e\u5343\u842c\u5143\u6b3e\u9805\uff0c\u539f\u5b9a\u4eca\u65e9\u5728\u89c0\u5858\u88c1\u5224\u6cd5\u9662\u63d0\u5802\uff0c\u8faf\u65b9\u5ead\u4e0a\u900f\u9732\u88ab\u544a\u7dca\u6025\u9001\u9662\uff0c\u6436\u6551\u5f8c\u4e0d\u6cbb\u3002</p>\n<p>\u73fe\u5834\u662f\u8475\u6d8c\u9e97\u7464\u90a8\u5bcc\u7464\u6a13\uff0c\u8b66\u65b9\u65e9\u4e0a\u8fd19\u6642\u63a5\u5831\uff0c\u767c\u73fe46\u6b72\u7537\u6b7b\u8005\u5012\u81e5\u5728\u5929\u4e95\u4f4d\u7f6e\u660f\u8ff7\uff0c\u9001\u5f80\u746a\u5609\u70c8\u91ab\u9662\u6436\u6551\uff0c\u60dc\u6700\u7d42\u4e0d\u6cbb\uff0c\u8b66\u65b9\u65bc\u73fe\u5834\u6709\u6aa2\u7372\u907a\u66f8\uff0c\u521d\u6b65\u8abf\u67e5\u76f8\u4fe1\u4e8b\u4e3b\u5728\u8d70\u5eca\u58ae\u4e0b\u3002</p>\n<p>\u8b66\u65b92021\u5e745\u6708\u63a5\u7372\u5b78\u6821\u5831\u6848\uff0c\u61f7\u7591\u6709\u8077\u54e1\u4ee5\u865b\u5047\u7406\u7531\u6279\u51fa\u53ca\u63d0\u53d6\u7d041060\u842c\u5143\uff0c\u8abf\u67e5\u5f8c\u62d8\u6355\u8076\u654f\u3002</p>\n<p>\u8076\u654f2004\u5e74\u52a0\u5165\u512a\u624d\u66f8\u9662\uff0c\u66fe\u4efb\u6559\u4e2d\u6587\u3001\u5e38\u8b58\u3001\u666e\u901a\u8a71\u548c\u4e2d\u53f2\uff0c2020\u5e749\u6708\u8d77\u51fa\u4efb\u5c0f\u5b78\u90e8\u6821\u9577\uff0c2021\u5e745\u6708\u7a81\u7136\u8fad\u8077\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3945950/%E5%84%AA%E6%89%8D%E6%9B%B8%E9%99%A2%E5%B0%8F%E5%AD%B8%E5%89%8D%E6%A0%A1%E9%95%B7%E6%B6%89%E6%8C%AA%E7%94%A8%E5%8D%83%E8%90%AC%E5%85%83+%E4%B8%8A%E5%BA%AD%E5%89%8D%E5%A2%AE%E6%A8%93%E4%BA%A1"}]}