7121\u4eba\u6a5f\u8972\u64ca\u5167\u5854\u5c3c\u4e9e\u80e1\u5728\u51f1\u6492\u5229\u4e9e(Caesarea)\u7684\u4f4f\u6240\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u8072\u660e\u7a31\uff0c\u8972\u64ca\u767c\u751f\u6642\u5167\u5854\u5c3c\u4e9e\u80e1\u548c\u4ed6\u7684\u59bb\u5b50\u4e26\u4e0d\u5728\u51f1\u6492\u5229\u4e9e\uff0c\u653b\u64ca\u4e26\u672a\u9020\u6210\u4eba\u54e1\u50b7\u4ea1\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3907129/%E5%85%A7%E5%A1%94%E5%B0%BC%E4%BA%9E%E8%83%A1%E4%BD%8F%E5%AE%85%E9%81%AD%E7%84%A1%E4%BA%BA%E6%A9%9F%E6%94%BB%E6%93%8A"}, {"title": "\u7fd2\u8fd1\u5e73\u8996\u5bdf\u706b\u7bad\u8ecd\u4e26\u807d\u53d6\u5de5\u4f5c\u6ed9\u5831", "description": "<p><span style=\"font-size-ignore:13pt;\">\u4e2d\u5171\u4e2d\u592e\u7e3d\u66f8\u8a18\u3001\u570b\u5bb6\u4e3b\u5e2d\u3001\u4e2d\u592e\u8ecd\u59d4\u4e3b\u5e2d\u7fd2\u8fd1\u5e73\u65e5\u524d</span><span style=\"font-size-ignore:13pt;\">\u8996\u5bdf\u706b\u7bad\u8ecd\uff0c\u4e26\u807d\u53d6\u5de5\u4f5c\u6ed9\u5831\u3002</span></p>\n<p>\u00a0</p>\n<p><span style=\"font-size-ignore:13pt;\">\u4ed6</span><span style=\"font-size-ignore:13pt;\">\u5f37\u8abf\uff0c\u8981\u6df1\u5165\u8cab\u5fb9\u65b0\u6642\u4ee3\u5f37\u8ecd\u601d\u60f3\uff0c\u8cab\u5fb9\u65b0\u6642\u4ee3\u8ecd\u4e8b\u6230\u7565\u65b9\u91dd\uff0c\u5805\u6301\u653f\u6cbb\u5f15\u9818\uff0c\u5f37\u5316\u4f7f\u547d\u64d4\u7576\uff0c\u63a8\u9032\u90e8\u968a\u5efa\u8a2d\u9ad8\u8cea\u91cf\u767c\u5c55\uff0c\u63d0\u5347\u6230\u7565\u5a01\u61fe\u548c\u5be6\u6230\u80fd\u529b\uff0c\u5805\u6c7a\u5b8c\u6210\u9ee8\u548c\u4eba\u6c11\u8ce6\u4e88\u7684\u5404\u9805\u4efb\u52d9\u3002</span></p>\n<p>\u7fd2\u8fd1\u5e73\u7a31\uff0c\u8981\u5805\u6301\u9ee8\u5c0d\u8ecd\u968a\u7d55\u5c0d\u9818\u5c0e\uff0c\u78ba\u4fdd\u90e8\u968a\u4efb\u4f55\u6642\u5019\u3001\u4efb\u4f55\u60c5\u6cc1\u4e0b\uff0c\u90fd\u5805\u6c7a\u807d\u5f9e\u9ee8\u4e2d\u592e\u548c\u4e2d\u592e\u8ecd\u59d4\u6307\u63ee\u3002\u8981\u56b4\u683c\u843d\u5be6\u6c11\u4e3b\u96c6\u4e2d\u5236\uff0c\u56b4\u8085\u9ee8\u5167\u653f\u6cbb\u751f\u6d3b\uff0c\u56b4\u8085\u67e5\u8655\u5b98\u5175\u8eab\u908a\u7684\u8150\u6557\u554f\u984c\u548c\u4e0d\u6b63\u4e4b\u98a8\u3002</p>\n<p>\u7fd2\u8fd1\u5e73\u7e8c\u7a31\uff0c\u8981\u5f37\u5316\u6182\u60a3\u610f\u8b58\u3001\u5371\u6a5f\u610f\u8b58\u3001\u6253\u4ed7\u610f\u8b58\uff0c\u5168\u9762\u52a0\u5f37\u7df4\u5175\u5099\u6230\uff0c\u628a\u90e8\u968a\u4f5c\u6230\u80fd\u529b\u641e\u624e\u5be6\uff0c\u6709\u529b\u7dad\u8b77\u570b\u5bb6\u6230\u7565\u5b89\u5168\u548c\u6838\u5fc3\u5229\u76ca\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3907128/%E7%BF%92%E8%BF%91%E5%B9%B3%E8%A6%96%E5%AF%9F%E7%81%AB%E7%AE%AD%E8%BB%8D%E4%B8%A6%E8%81%BD%E5%8F%96%E5%B7%A5%E4%BD%9C%E6%BB%99%E5%A0%B1"}, {"title": "\u7da0\u8272\u548c\u5e73\u6536\u96c6\u5169\u6cb3\u5cb8\u903e3000\u4ef6\u5783\u573e 97%\u70ba\u5851\u81a0", "description": "<p>\u7da0\u8272\u548c\u5e73<span style=\"font-size-ignore:13pt;\">\u8abf\u67e5\u986f\u793a\uff0c\u5f9e\u672c\u5730\u5169\u689d\u5177\u91cd\u8981\u751f\u614b\u50f9\u503c\u6cb3\u5cb8\u6536\u96c6\u76843000\u591a\u4ef6\u5783\u573e\u4e2d\uff0c\u767c\u73fe\u670997%\u70ba\u5851\u81a0\u3002\u98df\u54c1\u3001\u7269\u6d41\u3001\u98f2\u54c1\u53ca\u5373\u68c4\u9910\u51774\u5927\u985e\u5305\u88dd\u5783\u573e\u4f54\u4e03\u6210\u3002</span></p>\n<p>\u7da0\u8272\u548c\u5e73\u8868\u793a\uff0c\u653f\u5e9c\u5074\u91cd\u64a5\u6b3e\u4e88\u672b\u7aef\u56de\u6536\u3001\u8208\u5efa\u711a\u5316\u7210\u7b49\uff0c\u898f\u7ba1\u4f01\u696d\u751f\u7522\u5373\u68c4\u81a0\u7684\u9032\u5c55\u7de9\u6162\uff0c\u8b8a\u76f8\u4ee4\u793e\u6703\u627f\u64d4\u7684\u9ad8\u6602\u5ee2\u7269\u8655\u7f6e\u8cbb\u53ca\u74b0\u5883\u6210\u672c\u3002</p>\n<p>\u7da0\u8272\u548c\u5e73\u7a31\u6307\u51fa\uff0c\u672c\u6e2f\u6709\u8cac\u4efb\u652f\u6301\u53ca\u63a8\u52d5\u300a\u5168\u7403\u5851\u81a0\u516c\u7d04\u300b\uff0c\u5236\u5b9a\u6e1b\u5851\u76ee\u6a19\uff0c\u540c\u6642\u63a8\u52d5\u4f01\u696d\u7531\u5373\u68c4\u8f49\u578b\u91cd\u7528\u53ca\u7121\u5305\u88dd\u7684\u92b7\u552e\u6a21\u5f0f\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3907127/%E7%B6%A0%E8%89%B2%E5%92%8C%E5%B9%B3%E6%94%B6%E9%9B%86%E5%85%A9%E6%B2%B3%E5%B2%B8%E9%80%BE3000%E4%BB%B6%E5%9E%83%E5%9C%BE+97%25%E7%82%BA%E5%A1%91%E8%86%A0"}, {"title": "\u5b8f\u9054\u5de5\u696d\u4e2d\u5fc3\u76f8\u9130\u55ae\u4f4d\u53eb\u50f94500\u842c", "description": "<p>\u5229\u5609\u95a3(\u5de5\u5546\u8216)\u5730\u7522\u8868\u793a\uff0c\u8475\u6d8c\u5b8f\u9054\u5de5\u696d\u4e2d\u5fc3\u76f8\u9130\u55ae\u4f4d\uff0c\u5efa\u7bc9\u9762\u7a4d\u5408\u5171\u7d0415151\u65b9\u544e\uff0c\u696d\u4e3b\u610f\u5411\u552e\u50f94500\u842c\u5143\uff0c\u544e\u50f9\u7d042970\u5143\uff0c\u53e6\u6709\u8ca8\u8eca\u4f4d\u51fa\u552e\u3002</p>\n<p>\u8a72\u884c\u6307\u51fa\uff0c\u4e0a\u8ff0\u7269\u696d\u73fe\u4f5c\u98df\u7269\u5de5\u5834\u53ca\u8ca8\u5009\uff0c\u53ef\u4ee5\u73fe\u72c0\u5f62\u5f0f\u4ea4\u5409\u4ea4\u6613\u6216\u539f\u696d\u4e3b\u53ef\u552e\u5f8c\u79df\u56de\u3002\u7269\u696d\u63d0\u4f9b400A\u4e09\u76f8\u96fb\u53ca\u7164\u6c23\uff0c\u55ae\u4f4d\u5167\u8a2d\u6709\u51cd\u623f\u53ca\u5c11\u90e8\u5206\u9762\u7a4d\u4f5c\u70ba\u5beb\u5b57\u6a13\uff0c\u7531\u65bc\u55ae\u4f4d\u9644\u88dd\u4fee\u53ca\u9023\u724c\u7167\uff0c\u65b0\u8cb7\u5bb6\u53ef\u5373\u8cb7\u5373\u7528\uff0c\u540c\u6642\u4ea6\u53ef\u6e1b\u7701\u88dd\u4fee\u6642\u9593\u548c\u6210\u672c\u3002</p>\n<p>\u5b8f\u9054\u5de5\u696d\u4e2d\u5fc3\u8a2d\u6709\u8ca8\u53f0\uff0c\u53ef\u516540\u544e\u8ca8\u6ac3\u8eca\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3906295/%E5%AE%8F%E9%81%94%E5%B7%A5%E6%A5%AD%E4%B8%AD%E5%BF%83%E7%9B%B8%E9%84%B0%E5%96%AE%E4%BD%8D%E5%8F%AB%E5%83%B94500%E8%90%AC"}]}