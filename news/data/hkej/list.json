/%E7%91%9C%E4%B8%801C%E6%9C%9F%E6%8C%87%E6%98%8E%E5%96%AE%E4%BD%8D%E7%8D%B2%E9%A1%8D%E5%A4%961%25%E6%8A%98%E6%89%A3"}, {"title": "\u8584\u74dc\u74dc\u767c\u6587\u7a31\u7236\u89aa\u7121\u653f\u6cbb\u91ce\u5fc3", "description": "<p>\u91cd\u6176\u524d\u5e02\u59d4\u66f8\u8a18\u8584\u7199\u4f86\u4e4b\u5b50\u8584\u74dc\u74dc\u8fd1\u65e5\u5728\u53f0\u7063\u8209\u884c\u5a5a\u79ae\u800c\u518d\u5ea6\u6210\u70ba\u50b3\u5a92\u7126\u9ede\uff0c\u4ed6\u8868\u793a\uff0c\u56e0\u65b0\u5a5a\u53c8\u88ab\u7ffb\u820a\u8cec\u800c\u611f\u5230\u56f0\u60d1\uff0c\u4e26\u5f37\u8abf\u300c\u8584\u7fd2\u5169\u5bb6\u4e0d\u66fe\u6709\u904e\u7bc0......\u7236\u89aa\u5f9e\u672a\u5984\u60f3\u8207\u5176\u722d\u92d2\u300d\u3002</p>\n<p>\u8584\u74dc\u74dc\u5728\u793e\u4ea4\u5e73\u53f0X\u5e16\u6587\u7a31\uff0c\u4ed6\u5e0c\u671b\u4fdd\u6301\u4f4e\u8abf\uff0c\u4f46\u9019\u5e7e\u5468\u88ab\u6301\u7e8c\u7092\u4f5c\uff0c\u4ed6\u505a\u500b\u7c21\u7565\u7b54\u8986\uff0c\u5148\u6307\u7576\u5e74\u8aaa\u4ed6\u958b\u6cd5\u62c9\u5229\u7684\u5831\u9053\u662f\u4e00\u6d3e\u80e1\u8a00\u3001\u53c8\u6f84\u6e05\u5f9e\u672a\u88ab\u725b\u6d25\u5927\u5b78\u300c\u9000\u5b78\u300d\uff0c2009\u5e74\u4f11\u5b78\u662f\u56e0\u70ba\u6bcd\u89aa\u75c5\u5371\u800c\u56de\u570b\u966a\u5979\u3002\u4ed6\u4e5f\u5426\u8a8d\u6709\u4e0d\u7fa9\u4e4b\u8ca1\uff0c\u7a31\u300c\u7576\u5e74\u5e7e\u767e\u4eba\u7684\u8abf\u67e5\u7d44\uff0c\u5e7e\u7d93\u5468\u6298\uff0c\u76e4\u8a08\u6211\u7236\u6bcd\u5e7e\u5341\u5e74\u6b77\u7a0b\uff0c\u4e5f\u6c92\u627e\u5230\u9019\u53e3\u4e2d\u7684\u4e0a\u5104\u5bb6\u7522\u3002\u300d</p>\n<p>\u8ac7\u53ca\u7236\u89aa\u8584\u7199\u4f86\uff0c\u8584\u74dc\u74dc\u5f62\u5bb9\u8584\u7199\u4f86\u300c\u4ed6\u4e00\u5411\u55ae\u7d14\u8a8d\u70ba\uff0c\u53ea\u8981\u57cb\u982d\u82e6\u5e79\uff0c\u5c08\u6ce8\u6c11\u751f\u548c\u7d93\u6fdf\uff0c\u5c31\u7b97\u662f\u597d\u9818\u5c0e\u3002\u300d\u3001\u300c\u4ed6\u4e0d\u5584\u4e00\u5c0d\u4e00\u7684\u6e9d\u901a\uff0c\u5ffd\u7565\u4e86\u4eba\u4e4b\u5e38\u60c5\u3002\u300d</p>\n<p>\u8584\u74dc\u74dc\u5728\u6587\u4e2d\u7a31\uff0c\u8584\u7fd2\u5169\u5bb6\u4e0d\u66fe\u6709\u904e\u7bc0\u3002\u300c\u6211\u7236\u89aa\u5f9e\u672a\u5984\u60f3\u8207\u5176\u722d\u92d2\uff0c\u4e26\u65e9\u8868\u614b\u6703\u5168\u529b\u52a9\u70ba\u3002\u6211\u7236\u6bcd\u5165\u7344\u4e5f\u8207\u4ed6\u7121\u95dc\uff0c\u4f46\u4e0d\u65b7\u6709\u4eba\u6311\u64a5\u96e2\u9593\uff0c\u9084\u6709\u90a3\u4e9b\u4e0d\u77e5\u60c5\u7684\u4eba\uff0c\u81ea\u5831\u596e\u52c7\uff0c\u778e\u63e3\u6469\u4e0a\u7d1a\u5fc3\u601d\u3002\u300d</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3947186/%E8%96%84%E7%93%9C%E7%93%9C%E7%99%BC%E6%96%87%E7%A8%B1%E7%88%B6%E8%A6%AA%E7%84%A1%E6%94%BF%E6%B2%BB%E9%87%8E%E5%BF%83"}, {"title": "\u512a\u8863\u5eab\u7a31\u4e0d\u7528\u65b0\u7586\u68c9 \u65b0\u7586\u68c9\u82b1\u5354\u6703:\u5805\u6c7a\u4e0d\u80fd\u63a5\u53d7", "description": "<p>\u512a\u8863\u5eab(UNIQLO)\u6bcd\u516c\u53f8\u8fc5\u92b7\u96c6\u5718\u5275\u8fa6\u4eba\u517c\u8463\u4e8b\u9577\u67f3\u4e95\u6b63\u8fd1\u65e5\u8868\u793a\uff0c\u512a\u8863\u5eab\u4e0d\u4f7f\u7528\u4f86\u81ea\u4e2d\u570b\u65b0\u7586\u5730\u5340\u7684\u68c9\u82b1\u3002\u65b0\u7586\u68c9\u82b1\u5354\u6703\u767c\u8868\u8072\u660e\u7a31\uff0c\u5c0d\u6b64\u5805\u6c7a\u4e0d\u80fd\u63a5\u53d7\u3002</p>\n<p>\u5354\u6703\u6307\u51fa\uff0c\u65b0\u7586\u6c23\u5019\u7368\u7279\u3001\u5730\u7406\u4f4d\u7f6e\u512a\u8d8a\uff0c\u70ba\u68c9\u82b1\u7684\u751f\u9577\u63d0\u4f9b\u4e86\u5f97\u5929\u7368\u539a\u7684\u81ea\u7136\u689d\u4ef6\uff0c\u65b0\u7586\u5730\u5340\u7684\u68c9\u82b1\u662f\u4e16\u754c\u4e0a\u6700\u597d\u7684\u68c9\u82b1\u4e4b\u4e00\u3002\u65b0\u7586\u68c9\u82b1\u662f\u4e2d\u570b\u7d21\u7e54\u696d\u7684\u91cd\u8981\u539f\u6599\uff0c\u662f\u9023\u63a5\u6771\u897f\u65b9\u5e02\u5834\u7684\u6a4b\u6a11\u3002\u65b0\u7586\u7684\u68c9\u82b1\u54c1\u8cea\u4e0a\u4e58\uff0c\u65b0\u7586\u7684\u4eba\u6c11\u52e4\u52de\u6a38\u5be6\u3002\u65b0\u7586\u68c9\u4e0d\u50c5\u7d66\u4e2d\u570b\u548c\u4e16\u754c\u63d0\u4f9b\u4e86\u5927\u91cf\u512a\u8cea\u7d21\u7e54\u539f\u6599\uff0c\u4e5f\u5e36\u52d5\u4e86\u7576\u5730\u7d93\u6fdf\u7684\u767c\u5c55\u3001\u7d66\u7576\u5730\u5c45\u6c11\u63d0\u4f9b\u4e86\u5c31\u696d\u6a5f\u6703\uff0c\u65b0\u7586\u8a31\u591a\u5bb6\u5ead\u5c31\u6b64\u64fa\u812b\u4e86\u8ca7\u56f0\uff0c\u8d70\u5411\u5bcc\u88d5\u3002</p>\n<p>\u8072\u660e\u7a31\uff0c\u96a8\u7740\u300c\u4e00\u5e36\u4e00\u8def\u300d\u7684\u5be6\u65bd\uff0c\u65b0\u7586\u68c9\u4ee5\u512a\u826f\u7684\u54c1\u8cea\u6210\u70ba\u9023\u63a5\u4e16\u754c\u7684\u91cd\u8981\u5546\u54c1\u3002\u7136\u800c\uff0c\u7f8e\u570b\u537b\u6253\u7740\u300c\u4eba\u6b0a\u300d\u7684\u5e4c\u5b50\uff0c\u983b\u983b\u9020\u8b20\u65b0\u7586\u68c9\uff0c\u4f01\u5716\u525d\u596a\u65b0\u7586\u5404\u65cf\u7fa4\u773e\u901a\u904e\u8f9b\u52e4\u52de\u52d5\u548c\u5c31\u696d\u6539\u5584\u751f\u6d3b\u7684\u6b0a\u5229\uff0c\u4ee5\u6240\u8b02\u300c\u5f37\u8feb\u52de\u52d5\u300d\u7b49\u7121\u7aef\u7406\u7531\uff0c\u62b9\u9ed1\u3001\u62b5\u5236\u65b0\u7586\u68c9\u82b1\u53ca\u68c9\u88fd\u54c1\uff0c\u5c0d\u6b64\uff0c\u5354\u6703\u5805\u6c7a\u4e0d\u7b54\u61c9\u3002</p>\n<p>\u5354\u6703\u547c\u7c72\uff0c\u570b\u969b\u793e\u6703\u548c\u7d21\u7e54\u670d\u88dd\u4f01\u696d\u672c\u7740\u5c0a\u91cd\u5ba2\u89c0\u4e8b\u5be6\u7684\u539f\u5247\uff0c\u5c0d\u4e00\u5207\u53cd\u7586\u7684\u8a00\u8ad6\u53ca\u884c\u70ba\u4fdd\u6301\u9ad8\u5ea6\u7684\u7406\u6027\u5206\u6790\u8207\u9078\u64c7\u3002\u671f\u5f85\u512a\u8863\u5eab\u7b49\u570b\u969b\u54c1\u724c\u80fd\u5920\u5c0d\u65b0\u7586\u68c9\u7d66\u8207\u5145\u5206\u7684\u5c0a\u91cd\u8207\u4fe1\u4efb\uff0c\u6062\u5fa9\u4f7f\u7528\u65b0\u7586\u68c9\u82b1\uff0c\u7dad\u8b77\u5168\u7403\u68c9\u7d21\u7e54\u7522\u696d\u7684\u5065\u5eb7\u7a69\u5b9a\u767c\u5c55\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3947201/%E5%84%AA%E8%A1%A3%E5%BA%AB%E7%A8%B1%E4%B8%8D%E7%94%A8%E6%96%B0%E7%96%86%E6%A3%89+%E6%96%B0%E7%96%86%E6%A3%89%E8%8A%B1%E5%8D%94%E6%9C%83%3A%E5%A0%85%E6%B1%BA%E4%B8%8D%E8%83%BD%E6%8E%A5%E5%8F%97"}, {"title": "\u6eec\u6307\u6536\u53474\u9ede A\u80a1\u6210\u4ea4\u7e2e", "description": "<p>\u5167\u5730\u80a1\u5e02\u500b\u5225\u767c\u5c55\uff0c\u4e0a\u8b49\u6307\u6578\u6536\u53474\u9ede\u3002\u5169\u5e02\u6210\u4ea4\u5408\u8a08\u7e2e\u6e1b\u8fd1\u4e00\u6210\u81f31.5\u842c\u5104\u5143(\u4eba\u6c11\u5e63\u2027\u4e0b\u540c)\u3002</p>\n<p>\u4e0a\u8b49\u6307\u6578\u5148\u8dcc\u5f8c\u5347\uff0c\u6700\u591a\u8dcc11\u9ede\u62160.34%\uff0c\u4f4e\u898b3353\u9ede\u5f8c\u6709\u8cb7\u76e4\u5438\u7d0d\uff0c\u5927\u5e02\u56de\u5347\uff0c\u6700\u591a\u5012\u534712\u9ede\u62160.37%\uff0c\u9ad8\u898b3377\u9ede\uff0c\u5168\u65e5\u6536\u5e02\u58313368\u9ede\uff0c\u53474\u9ede\u62160.12%\uff0c\u6210\u4ea45655.51\u5104\u5143\u3002</p>\n<p>\u6df1\u6210\u6307\u6700\u591a\u8dcc38\u9ede\u62160.37%\uff0c\u4f4e\u898b10565\u9ede\u5f8c\u5598\u5b9a\u56de\u7a69\uff0c\u6700\u591a\u534770\u9ede\u62160.67%\uff0c\u9ad8\u898b10674\u9ede\uff0c\u5168\u65e5\u6536\u5e02\u583110634\u9ede\uff0c\u534730\u9ede\u62160.29%\uff0c\u6210\u4ea49330.69\u5104\u5143\u3002</p>\n<p>\u6eec\u6df1300\u6307\u6578\u58313921\u9ede\uff0c\u8dcc8\u9ede\u62160.23%\uff1b\u5275\u696d\u677f\u6307\u6578\u58312221\u9ede\uff0c\u53478\u9ede\u62160.36%\u3002</p>\n<p>\u5404\u677f\u584a\u500b\u5225\u767c\u5c55\uff0c\u50b3\u5a92\u5a1b\u6a02\u80a1\u5347\u903e3%\uff1b\u6c7d\u8eca\u88fd\u9020\u3001\u623f\u5730\u7522\u3001\u92fc\u9435\u80a1\u5347\u903e1%\uff1b\u96fb\u529b\u3001\u6c34\u6ce5\u3001\u5316\u5de5\u3001\u91d1\u878d\u3001\u77f3\u6cb9\u3001\u7164\u70ad\u80a1\u9760\u7a69\uff1b\u9020\u7d19\u80a1\u8dcc\u903e1%\uff1b\u91c0\u9152\u3001\u751f\u7269\u88fd\u85e5\u80a1\u504f\u8edf\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3947227/%E6%BB%AC%E6%8C%87%E6%94%B6%E5%8D%874%E9%BB%9E+A%E8%82%A1%E6%88%90%E4%BA%A4%E7%B8%AE"}, {"title": "\u9673\u570b\u57fa:\u9673\u7f8e\u5bf6\u548c\u7f85\u6dd1\u4f69\u505a\u4e8b\u7a4d\u6975 \u6709\u9b44\u529b\u6709\u64d4\u7576", "description": "<p>\u4e2d\u592e\u4eba\u6c11\u653f\u5e9c\u6839\u64da\u884c\u653f\u9577\u5b98\u7684\u63d0\u540d\u548c\u5efa\u8b70\uff0c\u4efb\u547d\u9673\u7f8e\u5bf6\u51fa\u4efb\u904b\u8f38\u53ca\u7269\u6d41\u5c40\u5c40\u9577\u3001\u7f85\u6dd1\u4f69\u51fa\u4efb\u6587\u5316\u9ad4\u80b2\u53ca\u65c5\u904a\u5c40\u5c40\u9577\uff1b\u540c\u6642\u514d\u53bb\u6797\u4e16\u96c4\u548c\u694a\u6f64\u96c4\u7684\u8077\u52d9\u3002</p>\n<p>\u653f\u52d9\u53f8\u53f8\u9577\u9673\u570b\u57fa\u5728\u793e\u4ea4\u5e73\u53f0\u8868\u793a\uff0c\u9673\u7f8e\u5bf6\u548c\u7f85\u6dd1\u4f69\u90fd\u662f\u8cc7\u6df1\u653f\u52d9\u4e3b\u4efb\uff0c\u505a\u4e8b\u7a4d\u6975\u4e3b\u52d5\u3001\u6709\u9b44\u529b\u3001\u6709\u64d4\u7576\u3002\u73fe\u5c46\u653f\u5e9c\u4ecd\u6709\u5169\u5e74\u534a\u4efb\u671f\uff0c\u76f8\u4fe1\u4e8c\u4eba\u6703\u66f4\u6709\u62fc\u52c1\u5730\u5e36\u9818\u5718\u968a\u524d\u884c\uff0c\u4ee4\u5169\u500b\u5c40\u7684\u5de5\u4f5c\u66f4\u4e0a\u4e00\u5c64\u6a13\uff0c\u66f4\u6709\u529b\u843d\u5be6\u884c\u653f\u9577\u5b98\u7684\u65bd\u653f\u7406\u5ff5\u3002\u6574\u500b\u554f\u8cac\u5718\u968a\u6703\u5718\u7d50\u4e00\u81f4\uff0c\u7e7c\u7e8c\u7aed\u529b\u670d\u52d9\u9999\u6e2f\u5e02\u6c11\u3002</p>\n<p>\u4ed6\u53c8\u611f\u8b1d\u6797\u4e16\u96c4\u548c\u694a\u6f64\u96c4\u591a\u5e74\u4f86\u5728\u7279\u5340\u653f\u5e9c\u8ca2\u737b\u826f\u591a\uff0c\u4efb\u5167\u76e1\u5fc3\u76e1\u529b\u670d\u52d9\u793e\u6703\uff0c\u795d\u9858\u4ed6\u5011\u96e2\u4efb\u5f8c\u4e8b\u4e8b\u9806\u5229\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3947230/%E9%99%B3%E5%9C%8B%E5%9F%BA%3A%E9%99%B3%E7%BE%8E%E5%AF%B6%E5%92%8C%E7%BE%85%E6%B7%91%E4%BD%A9%E5%81%9A%E4%BA%8B%E7%A9%8D%E6%A5%B5+%E6%9C%89%E9%AD%84%E5%8A%9B%E6%9C%89%E6%93%94%E7%95%B6"}]}