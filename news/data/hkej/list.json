u671b\u653f\u5e9c\u5c07\u4f86\u80fd\u5c07\u6709\u95dc\u5927\u5ec8\u7d0d\u5165\u8a55\u5206\u6e96\u5247\u5167\uff0c\u4ee5\u91d0\u5b9a\u4ee3\u8fa6\u5de5\u7a0b\u5148\u5f8c\u6b21\u5e8f\u3002</p>\n<p>A4\u806f\u76df\u6881\u6587\u5ee3\u8868\u793a\uff0c\u6d88\u9632\u8655\u65e9\u524d\u5411\u76ee\u6a19\u6a13\u5b87\u767c\u51fa36\u842c\u5f35\u300c\u6307\u793a\u300d\uff0c\u53ea\u6709\u56db\u6210\u9075\u8fa6\uff0c\u8a8d\u70ba\u7531\u653f\u5e9c\u4ee3\u8fa6\u80fd\u6e1b\u4f4e\u820a\u6a13\u7684\u6d88\u9632\u5b89\u5168\u96b1\u60a3\uff0c\u4f46\u95dc\u6ce8\u653f\u5e9c\u5411\u76f8\u95dc\u696d\u4e3b\u5fb5\u6536\u5169\u6210\u9644\u52a0\u8cbb\uff0c\u5c0d\u5e74\u9577\u53ca\u7d93\u6fdf\u6709\u56f0\u96e3\u7684\u696d\u4e3b\u9020\u6210\u58d3\u529b\uff0c\u5efa\u8b70\u653f\u5e9c\u8c41\u514d\u7279\u6b8a\u60c5\u6cc1\u3002</p>\n<p>\u52de\u806f\u6797\u632f\u6607\u6307\u51fa\uff0c\u904e\u53bb\u591a\u5b97\u706b\u8b66\u986f\u793a\u6709\u95dc\u6d88\u9632\u98a8\u96aa\u554f\u984c\u4e0d\u80fd\u518d\u62d6\uff0c\u5305\u62ec\u4eca\u5e744\u6708\u4f50\u6566\u9053\u83ef\u8c50\u5927\u5ec8\u5927\u706b\u4e8b\u4ef6\uff0c\u820a\u6a13\u5c45\u6c11\u9762\u5c0d\u706b\u8b66\u98a8\u96aa\uff0c\u9700\u8981\u76e1\u5feb\u4fee\u4f8b\u3002</p>\n<p>\u7d93\u6c11\u806f\u76e7\u5049\u570b\u64d4\u5fc3\u5de5\u7a0b\u50f9\u683c\u6703\u56e0\u4f9b\u4e0d\u61c9\u6c42\u88ab\u63a8\u9ad8\uff0c\u696d\u8005\u6703\u5426\u56e0\u672a\u80fd\u8058\u7528\u5408\u9069\u627f\u8fa6\u5546\uff0c\u800c\u88ab\u6307\u4e0d\u9075\u5f9e\u6307\u793a\u8981\u7f70\u6b3e\uff0c\u5e0c\u671b\u653f\u5e9c\u52a0\u5f37\u89e3\u8aaa\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u5de5\u806f\u6703\u9127\u5bb6\u5f6a\u8868\u793a\uff0c\u73fe\u6642\u4e0d\u5c11\u820a\u6a13\u696d\u4e3b\u6015\u592a\u591a\u6cd5\u5f8b\u8cac\u4efb\u300c\u4e0a\u8eab\u300d\u800c\u4e0d\u9858\u7d44\u7e54\u6cd5\u5718\uff0c\u4fee\u4f8b\u5f8c\u82e5\u52a0\u5f37\u76f8\u95dc\u6cd5\u5f8b\u8cac\u4efb\uff0c\u6216\u6703\u5687\u6015\u66f4\u591a\u696d\u4e3b\u64d4\u4efb\u5927\u5ec8\u6cd5\u5718\u7684\u7fa9\u52d9\u5de5\u4f5c\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3952179/%E7%AB%8B%E6%B3%95%E6%9C%83%E9%80%9A%E9%81%8E%E6%94%B9%E5%96%84%E8%88%8A%E6%A8%93%E6%B6%88%E9%98%B2%E5%AE%89%E5%85%A8%E4%BF%AE%E4%BE%8B"}, {"title": "\u6df1\u5733\u5de5\u5730\u8def\u9762\u574d\u584c13\u4eba\u5931\u7e31 \u570b\u52d9\u9662\u639b\u724c\u7763\u8fa6", "description": "<p>\u6df1\u5733\u5e02\u5bf6\u5b89\u5340\u6df1\u6c5f\u9435\u8def\u65bd\u5de5\u5730\u76e4\uff0c\u4e0a\u5468\u4e09(4\u65e5)\u665a\u767c\u751f\u8def\u9677\uff0c\u5c0e\u81f413\u540d\u5de5\u4eba\u5931\u7e31\uff0c\u81f3\u4eca\u4ecd\u4e0b\u843d\u4e0d\u660e\u3002\u570b\u52d9\u9662\u5b89\u5168\u751f\u7522\u59d4\u54e1\u6703\u6c7a\u5b9a\u5c0d\u8a72\u5b97\u91cd\u5927\u4e8b\u6545\u67e5\u8655\u5be6\u884c\u639b\u724c\u7763\u8fa6\u3002</p>\n<p>\u64da\u61c9\u6025\u7ba1\u7406\u90e8\u7db2\u7ad9\u6d88\u606f\u7a31\uff0c\u5ee3\u6771\u7701\u9808\u8fc5\u901f\u67e5\u660e\u4e8b\u6545\u539f\u56e0\uff0c\u56b4\u683c\u6309\u4e8b\u6545\u8abf\u67e5\u898f\u5b9a\u8981\u6c42\u7814\u7a76\u63d0\u51fa\u8655\u7406\u610f\u898b\u3002\u4e8b\u6545\u7d50\u6848\u524d\uff0c\u8981\u5c07\u4e8b\u6545\u8abf\u67e5\u5831\u544a\u5831\u570b\u52d9\u9662\u5b89\u59d4\u6703\u8fa6\u516c\u5ba4\u5be9\u6838\u540c\u610f\u5f8c\uff0c\u7531\u5ee3\u6771\u7701\u8ca0\u8cac\u6279\u8986\u7d50\u6848\u4e26\u5411\u793e\u6703\u516c\u5e03\u3002</p>\n<p>\u7d50\u6848\u5f8c\uff0c\u4e8b\u6545\u8abf\u67e5\u5831\u544a\u548c\u4e8b\u6545\u8655\u7406\u6c7a\u5b9a\u843d\u5be6\u60c5\u6cc1\u8981\u53ca\u6642\u5831\u5b89\u59d4\u6703\u8fa6\u516c\u5ba4\u5099\u6848\u3002</p>\n<p>\u4e8b\u767c\u65bc\u672c\u67084\u65e5\u665a\u4e0a11\u6642\u8a31\uff0c\u4f4d\u65bc\u5bf6\u5b89\u5340\u822a\u57ce\u8857\u9053\u6d32\u77f3\u8def\u7684\u6df1\u6c5f\u9435\u8def5\u6a19\u6bb5\u65bd\u5de5\u73fe\u5834\u7a81\u767c\u5730\u9762\u574d\u584c\uff0c13\u540d\u73fe\u5834\u5de5\u4f5c\u4eba\u54e1\u5931\u7e31\u3002</p>\n<p>\u516c\u958b\u8cc7\u6599\u986f\u793a\uff0c\u6df1\u6c5f\u9435\u8def\u662f\u5ee3\u6771\u6df1\u5733\u5e02\u81f3\u6c5f\u9580\u5e02\u7684\u9ad8\u901f\u9435\u8def\uff0c\u6b63\u7dda\u5168\u9577116\u516c\u91cc\uff0c\u8a2d\u8a08\u6642\u901f250\u516c\u91cc\uff0c\u9014\u7d93\u6df1\u5733\u3001\u5ee3\u5dde\u3001\u6771\u839e\u3001\u4e2d\u5c71\u3001\u6c5f\u95805\u500b\u5730\u5e02\uff0c\u662f\u5168\u570b\u300c\u516b\u7e31\u516b\u6a6b\u300d\u9ad8\u901f\u9435\u8def\u7db2\u4e3b\u901a\u9053\u4e4b\u4e00\uff0c\u6cbf\u6d77\u901a\u9053\u7684\u91cd\u8981\u7d44\u6210\u90e8\u5206\u3002</p>\n<p>\u6df1\u6c5f\u9435\u8def\u65bc2020\u5e747\u67082\u65e5\u958b\u5de5\u5efa\u8a2d\u5148\u884c\u6bb5\u5de5\u7a0b\u73e0\u6c5f\u53e3\u96a7\u9053\uff0c\u65bc2022\u5e7410\u67089\u65e5\u6b63\u5f0f\u958b\u5de5\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3952129/%E6%B7%B1%E5%9C%B3%E5%B7%A5%E5%9C%B0%E8%B7%AF%E9%9D%A2%E5%9D%8D%E5%A1%8C13%E4%BA%BA%E5%A4%B1%E7%B8%B1+%E5%9C%8B%E5%8B%99%E9%99%A2%E6%8E%9B%E7%89%8C%E7%9D%A3%E8%BE%A6"}, {"title": "\u4e2d\u570b\u592a\u4fdd\u999611\u6708\u4fdd\u8cbb\u6536\u5165\u589e4.3%", "description": "<p>\u4e2d\u570b\u592a\u4fdd(<a target='_blank' href='https://stock360.hkej.com/quotePlus/02601' >02601</a>)\u516c\u5e03\uff0c\u4eca\u5e74\u999611\u500b\u6708\u65d7\u4e0b\u592a\u5e73\u6d0b\u4eba\u58fd\u4fdd\u96aa\u53ca\u592a\u5e73\u6d0b\u8ca1\u7522\u4fdd\u96aa\u539f\u4fdd\u96aa\u696d\u52d9\u6536\u5165\u5408\u51714158.75\u5104\u5143(\u4eba\u6c11\u5e63\u2027\u4e0b\u540c)\uff0c\u6309\u5e74\u4e0a\u53474.3%\u3002</p>\n<p>\u671f\u5167\uff0c\u592a\u5e73\u6d0b\u4eba\u58fd\u4fdd\u96aa\u7d2f\u8a08\u539f\u4fdd\u96aa\u4fdd\u8cbb\u6536\u51652288.42\u5104\u5143\uff0c\u6309\u5e74\u589e\u95772.2%\uff1b\u592a\u5e73\u6d0b\u8ca1\u7522\u4fdd\u96aa\u7d2f\u8a08\u539f\u4fdd\u96aa\u4fdd\u8cbb\u6536\u51651870.33\u5104\u5143\uff0c\u589e\u95777%\u3002</p>   </div>\n<p></p>\n<div class=\"hkej_hkex_notice_dl_btn_2014\">\n<a href=\"https://www1.hkexnews.hk/listedco/listconews/sehk/2024/1211/2024121100665_c.pdf\" target=\"_blank\">\u4e0b\u8f09\u6e2f\u4ea4\u6