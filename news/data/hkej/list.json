5e0c\u671b\u7f8e\u65b9\u540c\u4e2d\u65b9\u76f8\u5411\u800c\u884c\u3002</span></p>\n<p>\u738b\u6bc5\u6307\u51fa\uff0c\u96d9\u65b9\u8981\u5805\u6301\u6e9d\u901a\u5c0d\u8a71\u300c\u4e0d\u6389\u7dda\u300d\uff1b\u5c0d\u8a71\u53ef\u80fd\u7121\u6cd5\u89e3\u6c7a\u6240\u6709\u554f\u984c\uff0c\u4f46\u6709\u52a9\u65bc\u589e\u9032\u4e86\u89e3\uff0c\u907f\u514d\u8aa4\u5224\uff0c\u63a8\u9032\u5408\u4f5c\u3002</p>\n<p>\u4ed6\u9084\u8868\u793a\uff0c\u4e2d\u65b9\u5c07\u7e7c\u7e8c\u70ba\u5169\u570b\u4eba\u54e1\u5f80\u4f86\u63d0\u4f9b\u652f\u6301\u4fbf\u5229\uff0c\u6b61\u8fce\u66f4\u591a\u7f8e\u570b\u5404\u754c\u4eba\u58eb\u4f86\u83ef\u8a2a\u554f\u4ea4\u6d41\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3945223/%E7%8E%8B%E6%AF%85%3A%E5%8F%8D%E5%B0%8D%E7%BE%8E%E5%9C%8B%E5%B0%8D%E5%8F%B0%E8%BB%8D%E5%94%AE%E5%92%8C%E6%93%B4%E5%A4%A7%E5%96%AE%E9%82%8A%E5%88%B6%E8%A3%81"}]}