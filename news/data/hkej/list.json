c\u5c55\u9805\u76ee\u6703\u6240\u90e8\u5206\u8a2d\u65bd\uff0c\u5305\u62ec\u7d0418\u7c73\u5ba4\u5916\u6e38\u6cf3\u6c60\u3001\u5ba4\u5916\u5152\u7ae5\u904a\u6a02\u5834\u53ca\u6709\u6a5f\u8015\u4f5c\u5340\u7b49\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3949850/%E9%80%A3%E6%96%B9I%E6%8E%A86%E4%BC%99%E9%A0%82%E5%B1%A4%E5%8F%8A%E8%A4%87%E5%BC%8F%E7%89%B9%E8%89%B2%E6%88%B6"}, {"title": "\u6717\u5929\u5cf0\u63d0\u4f9b594\u4f19 \u8fb2\u66c6\u65b0\u5e74\u524d\u767c\u552e", "description": "<p>\u5609\u91cc\u5efa\u8a2d(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00683' >00683</a>)\u65d7\u4e0b\u5143\u6717\u5341\u516b\u9109\u8def39\u865f\u4f4f\u5b85\u9805\u76ee\u547d\u540d\u70ba\u6717\u5929\u5cf0\uff0c\u63d0\u4f9b594\u4f19\uff0c\u4e3b\u62531\u623f\u53ca2\u623f\u6236\uff0c\u722d\u53d6\u8fb2\u66c6\u65b0\u5e74\u524d\u958b\u552e\u3002</p>\n<p>\u5609\u91cc\u767c\u5c55\u8463\u4e8b\u53ca\u9999\u6e2f\u5340\u7e3d\u7d93\u7406\u6e6f\u8000\u5b97\u8868\u793a\uff0c\u6717\u5929\u5cf0\u722d\u53d6\u8fb2\u66c6\u65b0\u5e74\u524d\u958b\u552e\uff0c\u50f9\u9322\u53c3\u8003\u540c\u5340\u5176\u4ed6\u9805\u76ee\u53ca\u9435\u8def\u6cbf\u7dda\u9805\u76ee\u3002</p>\n<p>\u6717\u5929\u5cf0\u7531\u5169\u5ea7\u4f4f\u5b85\u5927\u6a13\u7d44\u6210\uff0c\u63d0\u4f9b594\u4f19\uff0c\u5be6\u7528\u9762\u7a4d245\u81f3851\u65b9\u544e\uff0c\u6a19\u6e96\u6236\u9593\u96941\u623f\u81f33\u623f\u6236\uff0c\u903e\u4e5d\u6210\u55ae\u4f4d\u5c6c\u65bc1\u623f\u53ca2\u623f\u6236\uff1b\u9805\u76ee\u9810\u8a08\u5165\u4f19\u65e5\u671f\u70ba2025\u5e7412\u6708\u5e95\uff0c\u6a13\u82b1\u671f\u7d0412\u500b\u6708\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3949852/%E6%9C%97%E5%A4%A9%E5%B3%B0%E6%8F%90%E4%BE%9B594%E4%BC%99+%E8%BE%B2%E6%9B%86%E6%96%B0%E5%B9%B4%E5%89%8D%E7%99%BC%E5%94%AE"}, {"title": "\u7af6\u59d4\u6703:\u9999\u6e2f\u5de5\u5546\u6e05\u6f54\u670d\u52d9\u5c31\u5408\u8b00\u6848\u7f70\u6b3e1096\u842c", "description": "<p>\u7af6\u722d\u4e8b\u52d9\u59d4\u54e1\u6703\u5ba3\u5e03\uff0c\u5728\u4e00\u5b97\u6e05\u6f54\u670d\u52d9\u5408\u8b00\u6848\u4ef6\u7684\u8a34\u8a1f\u4e2d\uff0c\u88ab\u5217\u70ba\u7b54\u8faf\u4eba\u7684\u9999\u6e2f\u5de5\u5546\u6e05\u6f54\u670d\u52d9\u6709\u9650\u516c\u53f8\u627f\u8a8d\u6cd5\u5f8b\u8cac\u4efb\uff0c\u4e26\u540c\u610f\u652f\u4ed81096\u842c\u5143\u7f70\u6b3e\u3002</p>\n<p>\u7af6\u59d4\u6703\u65bc2021\u5e7412\u670814\u65e5\u5165\u7a1f\u7af6\u722d\u4e8b\u52d9\u5be9\u88c1\u8655\uff0c\u5411\u9999\u6e2f\u5de5\u5546\u53ca\u6c11\u9806\u6e05\u6f54\u6709\u9650\u516c\u53f8\uff0c\u4ee5\u53ca\u51763\u540d\u8463\u4e8b\u9673\u660e\u73e0\u3001\u912d\u696d\u91d7\u53ca\u912d\u5b78\u6b0a\u5c55\u958b\u8a34\u8a1f\u3002\u6848\u4ef6\u6e90\u65bc\u7af6\u59d4\u6703\u63a5\u7372\u7684\u4e00\u5b97\u6295\u8a34\uff0c\u6295\u8a34\u4eba\u5305\u62ec\u5728\u516c\u5171\u5c4b\u90a8\u5de5\u4f5c\u7684\u6578\u540d\u6e05\u6f54\u5de5\u4eba\uff0c\u6307\u5305\u62ec\u9999\u6e2f\u5de5\u5546\u53ca\u6c11\u9806\u5728\u5167\u7684\u6e05\u6f54\u670d\u52d9\u627f\u8fa6\u5546\uff0c\u5728\u7af6\u6295\u9999\u6e2f\u623f\u59d4\u6703\u7684\u6e05\u6f54\u670d\u52d9\u5408\u7d04\u6642\uff0c\u5f9e\u4e8b\u5408\u8b00\u884c\u70ba\uff0c\u7af6\u59d4\u6703\u5728\u6536\u5230\u6295\u8a34\u5f8c\u5c55\u958b\u8abf\u67e5\u3002\u9999\u6e2f\u5de5\u5546\u9023\u540c\u5169\u540d\u8463\u4e8b\u9673\u660e\u73e0\u53ca\u912d\u696d\u91d7\uff0c\u5df2\u65bc\u672c\u67086\u65e5\u7c3d\u7f72\u540c\u610f\u4e8b\u5be6\u9673\u8ff0\u66f8\uff0c\u5c31\u6848\u4ef6\u9054\u6210\u548c\u89e3\u3002</p>\n<p>\u6839\u64da\u9673\u8ff0\u66f8\uff0c\u9999\u6e2f\u5de5\u5546\u627f\u8a8d\u81f3\u5c11\u57282016\u5e745\u6708\u81f32018\u5e748\u6708\u671f\u9593\uff0c\u5c31\u63d0\u4ea4\u4e88\u623f\u59d4\u6703\u768417\u4efd\u6a19\u66f8\u4ea4\u63db\u5546\u696d\u654f\u611f\u8cc7\u6599\uff0c\u69cb\u6210\u5408\u8b00\u5b9a\u50f9\uff0c\u9055\u53cd\u300a\u7af6\u722d\u689d\u4f8b\u300b\u7684\u300c\u7b2c\u4e00\u884c\u70ba\u5b88\u5247\u300d\uff0c\u4e26\u9858\u610f\u627f\u64d4\u6cd5\u5f8b\u8cac\u4efb\u3002\u6709\u95dc\u7684\u62db\u6a19\u9805\u76ee\u6d89\u53ca\u5728\u623f\u59d4\u6703\u6240\u7ba1\u7406\u7684\u516c\u5171\u5c4b\u90a8\u53ca\u5176\u4ed6\u5927\u5ec8\u63d0\u4f9b\u6e05\u6f54\u670d\u52d9\uff0c\u5408\u7d04\u7e3d\u984d\u7d041.8\u5104\u5143\u3002</p>\n<p>\u5c31\u6b64\uff0c\u7af6\u59d4\u6703\u5df2\u5411\u5be9\u88c1\u8655\u7533\u8acb\u591a\u9805\u547d\u4ee4\uff0c\u5305\u62ec\u5ba3\u5e03\u9999\u6e2f\u5de5\u5546\u9055\u53cd\u7b2c\u4e00\u884c\u70ba\u5b88\u5247\uff0c\u4ee5\u53ca\u9673\u660e\u73e0\u548c\u912d\u696d\u91d7\u727d\u6d89\u5165\u9055\u53cd\u8a72\u5b88\u5247\uff1b\u9999\u6e2f\u5de5\u5546\u9808\u652f\u4ed81096\u842c\u6e2f\u5143\u7f70\u6b3e\uff1b\u9673\u660e\u73e0\u53ca\u912d\u696d\u91d7\u9808\u5404\u81ea\u652f\u4ed81\u842c\u5143\u7f70\u6b3e\uff1b\u5411\u9673\u660e\u73e0\u53ca\u912d\u696d\u91d7\u767c\u51fa\u53d6\u6d88\u8463\u4e8b\u8cc7\u683c\u4ee4\uff0c\u70ba\u671f24\u500b\u6708\uff1b\u53ca\u5411\u6709\u95dc\u7b54\u8faf\u4eba\u6536\u53d6\u7af6\u59d4\u6703\u7684\u8abf\u67e5\u8cbb\u7528\u53ca\u8a1f\u8cbb\u3002</p>\n<p>\u81f3\u65bc\u6c11\u9806\u53ca\u5176\u8463\u4e8b\u912d\u5b78\u6b0a\uff0c\u4ed6\u5011\u5df2\u65bc\u4eca\u5e741\u670830\u65e5\u627f\u8a8d\u6cd5\u5f8b\u8cac\u4efb\uff0c\u5be9\u88c1\u8655\u5728\u5176\u5f8c\u7684\u8046\u8a0a\u5df2\u767c\u51fa\u547d\u4ee4\uff0c\u5305\u62ec\u5ba3\u5e03\u6c11\u9806\u9055\u53cd\u7b2c\u4e00\u884c\u70ba\u5b88\u5247\uff1b\u53ca\u5ba3\u5e03\u912d\u5b78\u6b0a\u727d\u6d89\u5165\u9055\u53cd\u7b2c\u4e00\u884c\u70ba\u5b88\u5247\u3002\u5c31\u7af6\u59d4\u6703\u91dd\u5c0d\u6c11\u9806\u53ca\u912d\u5b78\u6b0a\u6240\u5c0b\u6c42\u7684\u5176\u4ed6\u547d\u4ee4\uff0c\u5305\u62ec\u5efa\u8b70\u7f70\u6b3e\u53ca\u53d6\u6d88\u8463\u4e8b\u8cc7\u683c\u4ee4\uff0c\u5982\u96d9\u65b9\u672a\u80fd\u9054\u6210\u548c\u89e3\uff0c\u5247\u6703\u7531\u5be9\u88c1\u8655\u53e6\u884c\u8046\u8a0a\u4f5c\u6c7a\u5b9a\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3949849/%E7%AB%B6%E5%A7%94%E6%9C%83%3A%E9%A6%99%E6%B8%AF%E5%B7%A5%E5%95%86%E6%B8%85%E6%BD%94%E6%9C%8D%E5%8B%99%E5%B0%B1%E5%90%88%E8%AC%80%E6%A1%88%E7%BD%B0%E6%AC%BE1096%E8%90%AC"}, {"title": "\u5916\u4ea4\u90e8:\u4e0d\u8a55\u8ad6\u5357\u97d3\u5167\u653f \u5c0d\u5169\u570b\u95dc\u4fc2\u7acb\u5834\u4e00\u8cab", "description": "<p>\u5357\u97d3\u5c40\u52e2\u6301\u7e8c\u52d5\u76ea\u3002\u4e2d\u570b\u5916\u4ea4\u90e8\u767c\u8a00\u4eba\u6bdb\u5be7\u5728\u4f8b\u884c\u8a18\u8005\u6703\u4e0a\u56de\u4e2d\u97d3\u95dc\u4fc2\u5f71\u97ff\u6642\u8868\u793a\uff0c\u5c0d\u5357\u97d3\u5167\u653f\u4e0d\u4f5c\u8a55\u8ad6\uff0c\u5c0d\u65bc\u4e2d\u97d3\u95dc\u4fc2\u4e2d\u65b9\u7684\u7acb\u5834\u662f\u4e00\u8cab\u7684\u3002</p>\n<p>\u5c31\u53f0\u7063\u9632\u52d9\u90e8\u9580\u8868\u793a\uff0c\u5728\u53f0\u7063\u9644\u8fd1\u6d77\u57df\u767c\u73fe\u4e86\u5927\u9678\u8ecd\u8266\u548c\u6d77\u8b66\u8239\uff0c\u4e26\u6307\u89e3\u653e\u8ecd\u5df2\u7d93\u9650\u5236\u4e86\u5927\u9678\u6cbf\u6d77\u7684\u90e8\u5206\u7a7a\u57df\u3002</p>\n<p>\u6bdb\u5be7\u6307\u51fa\uff0c\u53f0\u7063\u662f\u4e2d\u570b\u9818\u571f\u4e0d\u53ef\u5206\u5272\u7684\u4e00\u90e8\u5206\uff0c\u53f0\u7063\u554f\u984c\u662f\u4e2d\u570b\u5167\u653f\uff0c\u4e2d\u65b9\u5c07\u5805\u5b9a\u7dad\u8b77\u570b\u5bb6\u4e3b\u6b0a\u548c\u9818\u571f\u5b8c\u6574\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3949846/%E5%A4%96%E4%BA%A4%E9%83%A8%3A%E4%B8%8D%E8%A9%95%E8%AB%96%E5%8D%97%E9%9F%93%E5%85%A7%E6%94%BF+%E5%B0%8D%E5%85%A9%E5%9C%8B%E9%97%9C%E4%BF%82%E7%AB%8B%E5%A0%B4%E4%B8%80%E8%B2%AB"}, {"title": "\u745e\u9280:\u95dc\u7a05\u548c\u5730\u7de3\u653f\u6cbb\u98a8\u96aa\u660e\u5e74\u6216\u64fe\u4e82\u5e02\u5834", "description": "<p>\u745e\u9280(UBS)\u884c\u653f\u7e3d\u88c1\u5b89\u601d\u6770(Sergio Ermotti)\u63a5\u53d7\u5916\u96fb\u63a1\u8a2a\u6642\u8868\u793a\uff0c\u5373\u5c07\u4e0a\u5834\u7684\u7279\u6717\u666e\u653f\u5e9c\u53ef\u80fd\u63d0\u9ad8\u5c0d\u8cbf\u6613\u5925\u4f34\u7684\u95dc\u7a05\uff0c\u52a0\u4e0a\u5168\u7403\u5404\u5730\u7684\u885d\u7a81\uff0c\u53ef\u80fd\u6703\u589e\u52a0\u660e\u5e74\u91d1\u878d\u5e02\u5834\u9762\u81e8\u7684\u98a8\u96aa\u3002</p>\n<p>\u5b89\u601d\u6770\u6307\u51fa\uff0c\u5730\u7de3\u653f\u6cbb\u4e8b\u4ef6\u7684\u52a0\u901f\uff0c\u52a0\u4e0a\u5b8f\u89c0\u7d93\u6fdf\u65b9\u9762\u7684\u5347\u7d1a\uff0c\u5305\u62ec\u95dc\u7a05\u3001\u4fdd\u8b77\u4e3b\u7fa9\u7b49\uff0c\u9019\u7d55\u5c0d\u662f\u5fc5\u9808\u95dc\u6ce8\u7684\u554f\u984c\u3002\u76ee\u524d\u4f9d\u7136\u5f88\u4e0d\u78ba\u5b9a\uff0c\u76f8\u4fe1\u5c07\u770b\u5230\u5e02\u5834\u5927\u5e45\u6ce2\u52d5\u3002</p>\n<p>\u5b89\u601d\u6770\u5efa\u8b70\u5ba2\u6236\u5728\u76ee\u524d\u74b0\u5883\u4e0b\u505a\u597d\u591a\u5143\u5316\u6295\u8cc7\uff0c\u53c8\u8a8d\u70ba\u96d6\u7136\u7d93\u6fdf\u548c\u653f\u6cbb\u524d\u666f\u5b58\u5728\u4e0d\u78ba\u5b9a\u6027\uff0c\u4f46\u6d88\u8cbb\u8005\u548c\u7d93\u6fdf\u4ecd\u7136\u5177\u6709\u97cc\u6027\u3002\u8fd1\u671f\u7684\u5730\u7de3\u653f\u6cbb\u4e8b\u4ef6\u4e26\u6c92\u6709\u771f\u6b63\u5728\u91d1\u878d\u5e02\u5834\u5f15\u767c\u4efb\u4f55\u9023\u9396\u4e8b\u4ef6\u548c\u5f8c\u679c\uff0c\u9019\u4ee4\u4ed6\u611f\u5230\u6b23\u6170\u548c\u9a5a\u8a1d\u3002\u901a\u8139\u4f3c\u4e4e\u66ab\u6642\u53d7\u5230\u63a7\u5236\uff0c\u800c\u7f8e\u570b\u653e\u9b06\u76e3\u7ba1\u7684\u524d\u666f\u53ef\u80fd\u6703\u4fc3\u9032\u4f75\u8cfc\u6d3b\u52d5\uff0c\u9019\u6216\u8a31\u5c0d\u5e02\u5834\u548c\u7d93\u6fdf\u6709\u5229\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3949847/%E7%91%9E%E9%8A%80%3A%E9%97%9C%E7%A8%85%E5%92%8C%E5%9C%B0%E7%B7%A3%E6%94%BF%E6%B2%BB%E9%A2%A8%E9%9A%AA%E6%98%8E%E5%B9%B4%E6%88%96%E6%93%BE%E4%BA%82%E5%B8%82%E5%A0%B4"}]}