15\u7f70\u6b3e30%\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3959610/%E6%9C%83%E8%B2%A1%E5%B1%80%E8%AD%B4%E8%B2%AC%E7%AB%8B%E4%BF%A1%E5%BE%B7%E8%B1%AA%E5%8F%8A%E5%85%A9%E9%A0%85%E7%9B%AE%E5%90%88%E5%A4%A5%E4%BA%BA%E9%81%95%E8%A6%8F+%E7%BD%B0%E6%AC%BE145%E8%90%AC+", "pub_date": "2024-12-20 18:01:09", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u98df\u5b89\u4e2d\u5fc3:\u5f9e\u81b3\u98df\u651d\u5165\u4e9e\u786b\u9178\u9e7d\u5c0d\u5065\u5eb7\u69cb\u6210\u5f71\u97ff\u6a5f\u6703\u4e0d\u5927", "description": "<p><span style=\"font-size-ignore:13pt;\">\u98df\u5b89\u4e2d\u5fc3\u516c\u5e03\u9999\u6e2f\u7b2c\u4e8c\u6b21\u7e3d\u81b3\u98df\u7814\u7a76\u7684\u9996\u4efd\u5831\u544a\uff0c\u5c31\u98df\u7269\u4e2d\u4e9e\u786b\u9178\u9e7d\u7684\u542b\u91cf\u53ca\u76f8\u95dc\u7684\u81b3\u98df\u651d\u5165\u91cf\u9032\u884c\u7814\u7a76\u3002\u7d50\u679c\u986f\u793a\uff0c\u9999\u6e2f\u5e02\u6c11\u6bcf\u65e5\u5f9e\u81b3\u98df\u651d\u5165\u4e9e\u786b\u9178\u9e7d\u7684\u4efd\u91cf\uff0c\u9060\u4f4e\u65bc\u6bcf\u65e5\u53ef\u651d\u5165\u91cf\uff0c\u5c0d\u5065\u5eb7\u69cb\u6210\u5f71\u97ff\u7684\u6a5f\u6703\u4e0d\u5927\u3002</span></p>\n<p>\u7814\u7a76\u7531\u53bb\u5e742\u6708\u958b\u59cb\u9032\u884c\uff0c\u5408\u5171\u6536\u96c6\u8d85\u904e2200\u500b\u98df\u7269\u6a23\u672c\uff0c\u6db5\u84cb\u8d85\u904e180\u7a2e\u98df\u7269\u3002\u98df\u7269\u6a23\u672c\u7d93\u8655\u7406\u6210\u53ef\u98df\u7528\u72c0\u614b\u5f8c\uff0c\u5408\u4f75\u6210\u70ba\u8d85\u904e370\u500b\u6df7\u5408\u6a23\u672c\u4f5c\u5316\u9a57\u5206\u6790\uff0c\u6aa2\u6e2c\u591a\u500b\u7d44\u5225\u7684\u5316\u5b78\u7269\u8cea\uff0c\u5305\u62ec\u98df\u7269\u6dfb\u52a0\u5291\u3001\u91d1\u5c6c\u6c61\u67d3\u7269\u3001\u9709\u83cc\u6bd2\u7d20\u3001\u6301\u4e45\u6027\u6709\u6a5f\u6c61\u67d3\u7269\u3001\u9664\u5bb3\u5291\u6b98\u9918\uff0c\u4ee5\u53ca\u7d93\u52a0\u5de5\u7522\u751f\u7684\u6c61\u67d3\u7269\u7b49\u3002</p>\n<p>\u9019\u6b21\u7814\u7a76\u5171\u6aa2\u6e2c185\u7a2e\u98df\u7269\u7684\u4e9e\u786b\u9178\u9e7d\u542b\u91cf\uff0c\u5176\u4e2d\u53ea\u670917\u7a2e\u3001\u7d049%\u6aa2\u51fa\u4e9e\u786b\u9178\u9e7d\u3002\u4e7e\u679c\u7684\u4e9e\u786b\u9178\u9e7d\u5e73\u5747\u6fc3\u5ea6\u6700\u9ad8(\u6bcf\u516c\u65a4240\u6beb\u514b)\uff0c\u5176\u6b21\u662f\u8611\u83c7\u3001\u7d05\u53ca\u767d\u9152\u548c\u9183\u88fd\u852c\u83dc\uff0c\u5e73\u5747\u6fc3\u5ea6\u70ba\u6bcf\u516c\u65a420\u81f330\u6beb\u514b\u3002\u5176\u9918\u6aa2\u51fa\u4e9e\u786b\u9178\u9e7d\u7684\u98df\u7269\uff0c\u5e73\u5747\u6fc3\u5ea6\u70ba\u6bcf\u516c\u65a410\u6beb\u514b\u6216\u4ee5\u4e0b\u3002</p>\n<p>\u5831\u544a\u6240\u6307\u7684\u4e9e\u786b\u9178\u9e7d\u5305\u62ec\u4e8c\u6c27\u5316\u786b\uff0c\u662f\u4e00\u7d44\u5177\u5099\u591a\u7a2e\u529f\u80fd\u7684\u98df\u7269\u6dfb\u52a0\u5291\uff0c\u7279\u5225\u7528\u4f5c\u9632\u8150\u5291\u548c\u6297\u6c27\u5316\u5291\u3002</p>\n<p>\u4e2d\u5fc3\u767c\u4eba\u8a00\u4eba\u8868\u793a\uff0c\u73fe\u6709\u8b49\u64da\u986f\u793a\u4e9e\u786b\u9178\u9e7d\u7684\u6025\u6027\u6bd2\u6027\u4f4e\u3002\u7136\u800c\uff0c\u5728\u5be6\u9a57\u52d5\u7269\u9577\u671f\u904e\u91cf\u651d\u5165\u4e9e\u786b\u9178\u9e7d\u53ef\u5f15\u81f4\u80c3\u90e8\u53d7\u523a\u6fc0\u548c\u5f71\u97ff\u4e2d\u6a1e\u795e\u7d93\u7cfb\u7d71\u3002\u5c0d\u4e9e\u786b\u9178\u9e7d\u6709\u904e\u654f\u53cd\u61c9\u7684\u4eba\u58eb\uff0c\u651d\u5165\u5f8c\u53ef\u80fd\u6703\u5f15\u8d77\u652f\u6c23\u7ba1\u6536\u7e2e\u6216\u5176\u4ed6\u4e0d\u826f\u53cd\u61c9\u3002\u6839\u64da\u806f\u5408\u570b\u7ce7\u98df\u53ca\u8fb2\u696d\u7d44\u7e54/\u4e16\u754c\u885e\u751f\u7d44\u7e54\u98df\u54c1\u6dfb\u52a0\u5291\u806f\u5408\u5c08\u5bb6\u59d4\u54e1\u6703\u8a02\u5b9a\u7684\u5065\u5eb7\u53c3\u8003\u503c\uff0c\u4e9e\u786b\u9178\u9e7d\u7684\u6bcf\u65e5\u53ef\u651d\u5165\u91cf\u70ba\u6bcf\u516c\u65a4\u9ad4\u91cd0\u81f30.7\u6beb\u514b\u3002</p>\n<p>\u767c\u8a00\u4eba\u63d0\u9192\u5e02\u6c11\u61c9\u4fdd\u6301\u5747\u8861\u98f2\u98df\uff0c\u907f\u514d\u56e0\u504f\u98df\u67d0\u5e7e\u985e\u98df\u7269\u800c\u651d\u5165\u904e\u91cf\u4e9e\u786b\u9178\u9e7d\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3959690/%E9%A3%9F%E5%AE%89%E4%B8%AD%E5%BF%83%3A%E5%BE%9E%E8%86%B3%E9%A3%9F%E6%94%9D%E5%85%A5%E4%BA%9E%E7%A1%AB%E9%85%B8%E9%B9%BD%E5%B0%8D%E5%81%A5%E5%BA%B7%E6%A7%8B%E6%88%90%E5%BD%B1%E9%9F%BF%E6%A9%9F%E6%9C%83%E4%B8%8D%E5%A4%A7", "pub_date": "2024-12-20 18:01:09", "source": "hkej", "kind": 1, "language": "zh-HK"}]}