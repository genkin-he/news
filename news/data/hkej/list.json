3606' >03606</a>)\u53d7\u60e0\u5e02\u4f54\u7387\u63d0\u5347\uff0c\u4e0a\u8abf\u76ee\u6a19\u50f913.7%\u81f366\u5143\u3002</p>\n<p>\u5831\u544a\u6307\u51fa\uff0c\u798f\u8000\u9996\u4e09\u5b63\u591a\u8cfa53.5%\uff0c\u96d6\u7136\u6d77\u5916\u5e02\u5834\u8868\u73fe\u75b2\u5f31\uff0c\u4f46\u53d7\u60e0\u5e02\u4f54\u7387\u63d0\u9ad8\uff0c\u52a0\u4e0a\u6c7d\u8eca\u73bb\u7483\u5e73\u5747\u552e\u50f9\u53479%\uff0c\u5e36\u6308\u96c6\u5718\u4e0a\u5b63\u696d\u7e3e\u8868\u73fe\u5f37\u52c1\u3002</p>\n<p>\u57fa\u65bc\u76ee\u524d\u6700\u65b0\u696d\u52d9\u60c5\u6cc1\uff0c\u745e\u9280\u5c07\u798f\u8000\u73bb\u7483\u4eca\u660e\u5169\u5e74\u6de8\u5229\u6f64\u6e2c\u53477%\u548c12%\uff0c\u91cd\u7533\u300c\u8cb7\u5165\u300d\u8a55\u7d1a\uff0c\u76ee\u6a19\u50f9\u753158\u5143\uff0c\u534713.7%\u81f366\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/stock/article/3906256/%E7%91%9E%E9%8A%80%3A%E7%A6%8F%E8%80%80%E7%8E%BB%E7%92%83%E5%B8%82%E4%BD%94%E7%8E%87%E5%A2%9E+%E5%8D%87%E7%9B%AE%E6%A8%99%E5%83%B9%E8%87%B366%E5%85%83"}, {"title": "\u9673\u8302\u6ce2\u8d74\u79d8\u9b6f\u51fa\u5e2dAPEC\u8ca1\u9577\u6703\u8b70 \u4e0b\u5468\u8f49\u5f80\u7d10\u7d04\u8a2a\u554f", "description": "<p><span style=\"font-size-ignore:13pt;\">\u8ca1\u653f\u53f8\u53f8\u9577\u9673\u8302\u6ce2\u4eca\u665a\u555f\u7a0b\u524d\u5f80\u79d8\u9b6f\uff0c\u51fa\u5e2d\u5728\u5229\u99ac\u8209\u884c\u7684\u4e9e\u592a\u5340\u7d93\u6fdf\u5408\u4f5c\u7d44\u7e54(</span><span style=\"font-size-ignore:13pt;\">APEC)</span><span style=\"font-size-ignore:13pt;\">\u8ca1\u653f\u90e8\u9577\u6703\u8b70\u548c\u76f8\u95dc\u6d3b\u52d5\uff0c\u671f\u9593\u6703\u8207\u5176\u4ed6\u7d93\u6fdf\u9ad4\u7684\u5b98\u54e1\u8209\u884c\u96d9\u908a\u6703\u8ac7\uff0c\u4e26\u51fa\u5e2dAPEC\u5546\u8cbf\u8aee\u8a62\u7406\u4e8b\u6703\u7684\u5348\u9910\u6703\uff0c\u8207\u5404\u5730\u5de5\u5546\u754c\u4eba\u58eb\u6703\u9762\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u4eca\u5e74\u7684\u8ca1\u653f\u90e8\u9577\u6703\u8b70\u4ee5\u300c\u53ef\u6301\u7e8c\u3001\u6578\u5b57\u5316\u3001\u5177\u97cc\u6027\u7684\u4e9e\u592a\u7d93\u5408\u7d44\u7e54\u300d\u70ba\u4e3b\u984c\uff0c\u5c31\u5168\u7403\u7d93\u6fdf\u548c\u91d1\u878d\u767c\u5c55\u60c5\u6cc1\u3001\u63a8\u52d5\u7da0\u8272\u548c\u53ef\u6301\u7e8c\u767c\u5c55\u3001\u91d1\u878d\u652f\u6301\u61c9\u5c0d\u6c23\u5019\u8b8a\u5316\u3001\u4ee5\u53ca\u6578\u5b57\u5316\u548c\u666e\u60e0\u91d1\u878d\u767c\u5c55\u7b49\u8b70\u984c\u9032\u884c\u63a2\u8a0e\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u9673\u8302\u6ce2\u5c07\u65bc10\u670822\u65e5\u81f324\u65e5\u8f49\u5f80\u7f8e\u570b\u7d10\u7d04\u8a2a\u554f\uff0c</span><span style=\"font-size-ignore:13pt;\">\u671f\u9593\u51fa\u5e2d\u7531\u5f6d\u535a\u4e3b\u8fa6\u7684\u5f6d\u535a\u5168\u7403\u76e3\u7ba1\u8ad6\u58c7\u4e26\u767c\u8868\u4e3b\u65e8\u6f14\u8b1b\uff0c\u4e5f\u6703\u51fa\u5e2d\u591a\u5834\u65e9\u9910\u6703\u548c\u5348\u9910\u6703\uff0c\u4e26\u6703\u8207\u7f8e\u570b\u653f\u5546\u548c\u91d1\u878d\u754c\u4eba\u58eb\u6703\u9762\u4ea4\u6d41\uff0c\u63a8\u5ee3\u9999\u6e2f\u7684\u512a\u52e2\u548c\u6a5f\u9047\uff0c\u4e26\u6703\u5230\u8a2a\u7576\u5730\u7684\u4f01\u696d\u3002</span></p>\n<p>\u9673\u8302\u6ce2\u5c07\u65bc\u4e0b\u5468\u4e94(25\u65e5)\u508d\u665a\u8fd4\u62b5\u9999\u6e2f\uff0c\u96e2\u6e2f\u671f\u9593\u7531\u526f\u53f8\u9577\u9ec3\u5049\u7db8\u7f72\u7406\u8077\u52d9\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3906251/%E9%99%B3%E8%8C%82%E6%B3%A2%E8%B5%B4%E7%A7%98%E9%AD%AF%E5%87%BA%E5%B8%ADAPEC%E8%B2%A1%E9%95%B7%E6%9C%83%E8%AD%B0+%E4%B8%8B%E5%91%A8%E8%BD%89%E5%BE%80%E7%B4%90%E7%B4%84%E8%A8%AA%E5%95%8F"}, {"title": "\u4eba\u884c\u63a8\u4e92\u63db\u4fbf\u5229 \u4e2d\u4fe1\u8a3c\u5238\u64ec\u7533100\u5104\u984d\u5ea6 \u4e2d\u91d1\u7a4d\u53c3\u8207", "description": "<p>\u4e2d\u570b\u4eba\u6c11\u9280\u884c\u5373\u65e5\u8d77\u6b63\u5f0f\u555f\u52d5\u8b49\u5238\u3001\u57fa\u91d1\u3001\u4fdd\u96aa\u516c\u53f8\u4e92\u63db\u4fbf\u5229(SFISF)\u64cd\u4f5c\u3002\u76ee\u524d\u7372\u51c6\u53c3\u8207\u4e92\u63db\u4fbf\u5229\u64cd\u4f5c\u7684\u8b49\u5238\u3001\u57fa\u91d1\u516c\u53f8\u670920\u5bb6\uff0c\u9996\u6279\u7533\u8acb\u984d\u5ea6\u5df2\u8d852000\u5104\u5143(\u4eba\u6c11\u5e63\u2027\u4e0b\u540c)\u3002\u64da\u5167\u5730\u5a92\u9ad4\u6307\uff0c\u5305\u62ec\u4e2d\u91d1(<a target='_blank' href='https://stock360.hkej.com/quotePlus/03908' >03908</a>)\u3001\u4e2d\u4fe1\u8a3c\u5238(<a target='_blank' href='https://stock360.hkej.com/quotePlus/06030' >06030</a>)\u3001\u6613\u65b9\u9054\u57fa\u91d1\u53ca\u83ef\u590f\u57fa\u91d1\u7b49\u7372\u6279\u53c3\u8207\u4e92\u63db\u4fbf\u5229\u64cd\u4f5c\uff0c\u800c\u4e2d\u4fe1\u8a3c\u5238\u4e0a\u5831\u984d\u5ea6\u7d04100\u5104\u5143\u3002</p>\n<p>\u4e2d\u91d1\u6307\uff0c\u7a4d\u6975\u7533\u8acb\u53c3\u8207\u4e92\u63db\u4fbf\u5229\u696d\u52d9\u64cd\u4f5c\uff0c\u800c\u5c0d\u8b49\u5238\u3001\u57fa\u91d1\u3001\u4fdd\u96aa\u516c\u53f8\u4e92\u63db\u4fbf\u5229\u696d\u52d9\u662f\u4eba\u884c\u9996\u6b21\u63a8\u51fa\u7684\u8cc7\u672c\u5e02\u5834\u91cd\u5927\u5275\u65b0\u5de5\u5177\uff0c\u5c0d\u65bc\u8cc7\u672c\u5e02\u5834\u9577\u9060\u7a69\u5b9a\u767c\u5c55\u5177\u6709\u91cd\u8981\u610f\u7fa9\u3002\u4e2d\u91d1\u4f5c\u70ba\u516c\u958b\u5e02\u5834\u4e00\u7d1a\u4ea4\u6613\u5546\uff0c\u5df2\u6536\u5230\u300a\u95dc\u65bc\u505a\u597d\u8b49\u5238\u3001\u57fa\u91d1\u3001\u4fdd\u96aa\u516c\u53f8\u4e92\u63db\u4fbf\u5229(SFISF)\u76f8\u95dc\u5de5\u4f5c\u7684\u901a\u77e5\u300b\uff0c\u5c07\u5805\u6c7a\u843d\u5be6\u90e8\u7f72\uff0c\u8fc5\u901f\u505a\u597d\u5404\u9805\u4fdd\u969c\u5de5\u4f5c\uff0c\u7a4d\u6975\u7533\u8acb\u53c3\u8207\u9996\u6279\u4e92\u63db\u4fbf\u5229\u696d\u52d9\u64cd\u4f5c\u3002</p>\n<p>\u83ef\u6cf0\u8b49\u5238\u7814\u7a76\u6240\u6240\u9577\u5f35\u7e7c\u5f37\u8a8d\u70ba\uff0c\u4e92\u63db\u4fbf\u5229\u5de5\u5177\u5927\u6982\u7387\u5c07\u9069\u7528\u65bc\u81ea\u6709\u8cc7\u91d1\u800c\u975e\u7522\u54c1\u6236\uff0c\u5c0d\u65bc\u5238\u5546\u800c\u8a00\u5373\u9069\u7528\u65bc\u81ea\u71df\u76e4\uff0c\u4e92\u63db\u4fbf\u5229\u5168\u9762\u63a8\u5ee3\u5f8c\uff0c\u5238\u5546\u81ea\u71df\u53ef\u4e92\u63db\u7684\u8cc7\u7522\u898f\u6a21\u53ef\u80fd\u9054\u52304000\u5104\u5143\u81f35000\u5104\u5143\u5de6\u53f3\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3906253/%E4%BA%BA%E8%A1%8C%E6%8E%A8%E4%BA%92%E6%8F%9B%E4%BE%BF%E5%88%A9+%E4%B8%AD%E4%BF%A1%E8%A8%BC%E5%88%B8%E6%93%AC%E7%94%B3100%E5%84%84%E9%A1%8D%E5%BA%A6+%E4%B8%AD%E9%87%91%E7%A9%8D%E5%8F%83%E8%88%87"}]}