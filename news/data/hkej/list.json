709\u671b\u9032\u5165\u653f\u7b56\u6548\u679c\u514c\u73fe\u671f\u300210\u6708\u5f9e\u300c\u9280\u5341\u300d\u6709\u671b\u8b8a\u6210\u300c\u91d1\u5341\u300d\u3002\u572810\u6708\u4e0a\u534a\u6708\uff0c\u6838\u5fc3\u57ce\u5e02\u65b0\u623f\u548c\u4e8c\u624b\u623f\u5e02\u5834\u6d3b\u8e8d\u5ea6\u90fd\u51fa\u73fe\u660e\u986f\u56de\u5347\uff0c\u6a13\u50f9\u4ea6\u51fa\u73fe\u4f01\u7a69\u5fa9\u7526\u3002</p>\n<p>\u6a19\u666e\u5168\u7403\u8868\u793a\uff0c\u96a8\u7740\u9ad8\u7dda\u57ce\u5e02\u7684\u623f\u50f9\u548c\u7e3d\u92b7\u552e\u91cf\u7a69\u5b9a\uff0c\u4e2d\u570b\u7684\u623f\u5730\u7522\u92b7\u552e\u53ef\u80fd\u5728\u660e\u5e74\u4e0b\u534a\u5e74\u8da8\u65bc\u7a69\u5b9a\u3002\u9019\u5c07\u53d6\u6c7a\u65bc\u653f\u5e9c\u5c0d\u958b\u767c\u5546\u878d\u8cc7\u7684\u6301\u7e8c\u652f\u6301\u53ca\u53bb\u5eab\u5b58\u7684\u52aa\u529b\u3002\u4f30\u8a08\u4eca\u5e74\u5168\u570b\u623f\u5730\u7522\u92b7\u552e\u5c07\u4e0b\u964d\u81f3\u7d048.5\u842c\u5104\u5143(\u4eba\u6c11\u5e63\u2027\u4e0b\u540c)\u81f39\u842c\u5104\u5143\uff0c\u660e\u5e74\u53ef\u80fd\u6703\u9032\u4e00\u6b65\u4e0b\u964d\u81f38\u842c\u5104\u81f38.5\u842c\u5104\u5143\u3002</p>\n<p>\u4e2d\u592e\u653f\u6cbb\u5c409\u670826\u65e5\u6703\u8b70\u5f37\u8abf\u8981\u4fc3\u9032\u623f\u5730\u7522\u5e02\u5834\u6b62\u8dcc\u56de\u7a69\u3002\u4eba\u884c\u3001\u8ca1\u653f\u90e8\u7b49\u591a\u500b\u90e8\u59d4\u8fd1\u4e00\u500b\u6708\u4f86\u53ec\u958b\u591a\u5834\u767c\u5e03\u6703\uff0c\u63d0\u51fa\u591a\u9805\u589e\u91cf\u653f\u7b56\u3002\u4f4f\u5efa\u90e8\u7b495\u90e8\u9580\u6628\u65e5\u5ba3\u5e03\uff0c\u300c\u767d\u540d\u55ae\u300d\u9805\u76ee\u7684\u4fe1\u8cb8\u898f\u6a21\u5e74\u5e95\u589e\u52a0\u81f34\u842c\u5104\u5143\uff0c\u901a\u904e\u8ca8\u5e63\u5316\u5b89\u7f6e\u65b9\u5f0f\u65b0\u589e\u5be6\u65bd100\u842c\u5957\u57ce\u4e2d\u6751\u6539\u9020\u548c\u5371\u820a\u623f\u6539\u9020\u3002</p>\n<p>\u91ce\u6751\u8b49\u5238\u7a31\uff0c\u9019\u4e9b\u63aa\u65bd\u4e0d\u8db3\u4ee5\u5b8c\u5168\u963b\u6b62\u623f\u5730\u7522\u884c\u696d\u4e0b\u6ed1\uff0c\u4f46\u300c\u767d\u540d\u55ae\u300d\u8a08\u5283\u7684\u5927\u5e45\u64f4\u5f35\u8868\u660e\uff0c\u5317\u4eac\u6b63\u52a0\u5927\u52aa\u529b\u78ba\u4fdd\u9810\u552e\u623f\u5c4b\u7684\u4ea4\u4ed8\uff0c\u9019\u662f\u91cd\u5efa\u8cfc\u623f\u8005\u4fe1\u5fc3\u548c\u632f\u8208\u623f\u5730\u7522\u5e02\u5834\u7684\u95dc\u9375\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u4f4f\u5efa\u90e8\u90e8\u9577\u502a\u8679\u6628\u65e5\u8868\u793a\uff0c\u4e2d\u570b\u623f\u5730\u7522\u5728\u7cfb\u5217\u653f\u7b56\u4f5c\u7528\u4e0b\uff0c\u7d93\u904e3\u5e74\u7684\u8abf\u6574\uff0c\u5e02\u5834\u5df2\u7d93\u958b\u59cb\u7bc9\u5e95\uff0c10\u6708\u4efd\u7684\u76f8\u95dc\u6578\u64da\u6703\u662f\u4e00\u500b\u7a4d\u6975\u6a02\u89c0\u7684\u7d50\u679c\uff0c\u5c0d\u623f\u5730\u7522\u5e02\u5834\u6b62\u8dcc\u56de\u7a69\u5145\u6eff\u4fe1\u5fc3\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3906312/%E5%88%86%E6%9E%90%3A%E4%B8%AD%E5%9C%8B%E6%A8%93%E5%B8%82%E6%AD%A5%E5%85%A5%E6%94%BF%E7%AD%96%E5%85%8C%E7%8F%BE%E6%9C%9F+%E6%9C%89%E6%9C%9B%E6%AD%A2%E8%B7%8C%E5%9B%9E%E7%A9%A9"}, {"title": "\u5609\u6e56\u5c71\u838a\u4e09\u623f\u5411\u5317488\u842c\u6613\u624b", "description": "<p>\u5929\u6c34\u570d\u5609\u6e56\u5c71\u838a\u7fe0\u6e56\u5c456\u5ea7\u4f4e\u5c64B\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d633\u65b9\u544e\uff0c3\u623f\u5957\u623f\u9593\u9694\uff0c\u5411\u5317\uff0c\u671b\u8857\u666f\u70ba\u4e3b\uff0c\u53eb\u50f9500\u5143\uff0c\u6e1b\u50f912\u842c\u5143\uff0c\u4ee5488\u842c\u5143\u4ea4\u5409\u6613\u624b\uff0c\u5be6\u7528\u544e\u50f97709\u5143\u3002</p>\n<p>\u4e2d\u539f\u5730\u7522\u8868\u793a\uff0c\u539f\u696d\u4e3b\u65bc2013\u5e742\u6708\u4ee5265\u842c\u5143\u8cb7\u4eba\u55ae\u4f4d\uff0c\u6301\u8ca811\u5e74\uff0c\u8cec\u9762\u7372\u5229223\u842c\u5143\u621684%\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3906279/%E5%98%89%E6%B9%96%E5%B1%B1%E8%8E%8A%E4%B8%89%E6%88%BF%E5%90%91%E5%8C%97488%E8%90%AC%E6%98%93%E6%89%8B"}, {"title": "\u672c\u6e2f\u5931\u696d\u7387\u7dad\u63013%", "description": "<p>\u653f\u5e9c\u7d71\u8a08\u8655\u516c\u5e03\uff0c\u672c\u6e2f\u4eca\u5e747\u6708\u81f39\u6708\u7d93\u5b63\u7bc0\u6027\u8abf\u6574\u7684\u5931\u696d\u7387\u7dad\u63013%\uff1b\u5c31\u696d\u4e0d\u8db3\u7387\u7dad\u6301\u65bc1.2%\u3002</p>\n<p>\u82076\u6708\u81f38\u6708\u6bd4\u8f03\uff0c\u57287\u6708\u81f39\u6708\u671f\u9593\uff0c\u5404\u884c\u696d\u7684\u5931\u696d\u7387(\u4e0d\u7d93\u5b63\u7bc0\u6027\u8abf\u6574)\u53ca\u5c31\u696d\u4e0d\u8db3\u7387\u8b8a\u52d5\u4e0d\u4e00\uff0c\u4f46\u5e45\u5ea6\u666e\u904d\u4e0d\u5927\u3002</p>\n<p>\u7e3d\u5c31\u696d\u4eba\u6578371.02\u842c\u4eba\uff0c<span style=\"font-size-ignore:13pt;\">\u589e\u52a0\u7d041700\u4eba\uff1b\u7e3d\u52de\u52d5\u4eba\u53e3\u70ba383.01\u842c\u4eba\uff0c\u8207\u4e0a\u671f\u5927\u81f4\u76f8\u82e5\u3002</span><span style=\"font-size-ignore:13pt;\">\u5931\u696d\u4eba\u6578(\u4e0d\u7d93\u5b63\u7bc0\u6027\u8abf\u6574)\u6e1b\u5c11\u7d042400\u4eba\uff0c\u81f3</span><span style=\"font-size-ignore:13pt;\">11.99\u842c\u4eba\uff1b\u5c31\u696d\u4e0d\u8db3\u4eba\u6578\u6e1b\u5c11\u7d041500\u4eba\uff0c\u81f3</span><span style=\"font-size-ignore:13pt;\">4.6\u842c\u4eba\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u52de\u5de5\u53ca\u798f\u5229\u5c40\u5c40\u9577\u5b6b\u7389\u83e1\u8868\u793a\uff0c\u5c55\u671b\u5c07\u4f86\uff0c\u96a8\u7740\u7d93\u6fdf\u6301\u7e8c\u589e\u9577\uff0c\u6574\u9ad4\u52de\u5de5\u5e02\u5834\u5728\u77ed\u671f\u5167\u61c9\u6703\u7dad\u6301\u504f\u7dca\uff0c\u5118\u7ba1\u5404\u500b\u884c\u696d\u7684\u5c31\u696d\u60c5\u6cc1\u6216\u6703\u56e0\u5176\u696d\u52d9\u8868\u73fe\u800c\u6709\u6240\u4e0d\u540c\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3906369/%E6%9C%AC%E6%B8%AF%E5%A4%B1%E6%A5%AD%E7%8E%87%E7%B6%AD%E6%8C%813%25"}, {"title": "\u6e23\u6253:\u7e8c\u5168\u529b\u652f\u63f4\u4e2d\u5c0f\u4f01\u5ba2\u6236\u878d\u8cc7\u9700\u6c42", "description": "<p>\u6e23\u6253\u9999\u6e2f\u6b61\u8fce\u91d1\u7ba1\u5c40\u806f\u540c\u9280\u884c\u63a8\u51fa\u591a\u9805\u652f\u6301\u4e2d\u5c0f\u4f01\u696d\u63aa\u65bd\uff0c\u76f8\u4fe1\u9019\u4e9b\u63aa\u65bd\u5c0d\u9280\u884c\u652f\u63f4\u4e2d\u5c0f\u4f01\u501f\u6b3e\u9700\u8981\u6709\u7a4d\u6975\u4f5c\u7528\uff0c\u5e36\u4f86\u8cc7\u91d1\u53ca\u4fe1\u8cb8\u7522\u54c1\u4e0a\u7684\u652f\u6301\uff0c\u8b93\u5b83\u5011\u5728\u5145\u6eff\u6311\u6230\u7684\u74b0\u5883\u4e0b\u80fd\u6301\u7e8c\u767c\u5c55\u3002</p>\n<p>\u6e23\u6253\u9999\u6e2f\u4e2d\u5c0f\u4f01\u696d\u9280\u884c\u4e3b\u7ba1\u8463\u7f8e\u6021\u8868\u793a\uff0c\u6e23\u6253\u4f5c\u70ba\u4e2d\u5c0f\u4f01\u696d\u5925\u4f34\uff0c\u6703\u7e7c\u7e8c\u5168\u529b\u652f\u63f4\u4e2d\u5c0f\u4f01\u5ba2\u6236\u65bc\u7d93\u6fdf\u5fa9\u7526\u53ca\u8f49\u578b\u8def\u4e0a\u7684\u878d\u8cc7\u9700\u6c42\uff0c\u91dd\u5c0d\u5be6\u969b\u60c5\u6cc1\uff0c\u63d0\u4f9b\u9748\u6d3b\u7684\u9084\u6b3e\u9078\u9805\uff0c\u5982\u9084\u606f\u4e0d\u9084\u672c\u6216\u90e8\u5206\u9084\u6b3e\u7684\u7279\u5225\u5b89\u6392\u3002</p>\n<p>\u8463\u7f8e\u6021\u6307\u51fa\uff0c\u8a72\u884c\u4ea6\u6709\u4e0d\u540c\u63aa\u65bd\u5354\u52a9\u4e2d\u5c0f\u4f01\u8f49\u578b\uff0c\u5305\u62ec\u63a8\u51fa\u96fb\u5b50\u5546\u8cbf\u878d\u8cc7\u65b9\u6848\u3001\u512a\u5316\u6578\u78bc\u5e73\u53f0\u52a0\u5feb\u8cb8\u6b3e\u6279\u6838\u53ca\u5229\u7528\u5546\u696d\u6578\u64da\u4fbf\u5229\u878d\u8cc7\u3002\u8a72\u884c\u6703\u7e7c\u7e8c\u958b\u767c\u66f4\u591a\u65b9\u6848\u5354\u52a9\u4e2d\u5c0f\u4f01\u6578\u78bc\u53ca\u7da0\u8272\u8f49\u578b\u3002\u540c\u6642\uff0c\u6703\u7e7c\u7e8c\u7a4d\u6975\u8207\u793e\u6703\u5404\u754c\u4fdd\u6301\u6e9d\u901a\uff0c\u807d\u53d6\u610f\u898b\uff0c\u5354\u52a9\u4e2d\u5c0f\u4f01\u61c9\u5c0d\u76ee\u524d\u7684\u6311\u6230\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3906313/%E6%B8%A3%E6%89%93%3A%E7%BA%8C%E5%85%A8%E5%8A%9B%E6%94%AF%E6%8F%B4%E4%B8%AD%E5%B0%8F%E4%BC%81%E5%AE%A2%E6%88%B6%E8%9E%8D%E8%B3%87%E9%9C%80%E6%B1%82"}]}