0d\u672c\u5730\u7537\u5b50\u6b63\u6e96\u5099\u53c3\u8207\u4e09\u5408\u6703\u7d2e\u8077\u5100\u5f0f\uff0c\u8b66\u65b9\u4ee5\u300c\u53c3\u52a0\u4e09\u5408\u6703\u793e\u5718\u7684\u96c6\u6703\u300d\u7f6a\u62d8\u6355\u4ed6\u5011\uff0c\u76ee\u524d\u88ab\u6263\u7559\u8abf\u67e5\u3002</span></p>\n<p>\u8b66\u65b9\u8868\u793a\uff0c9\u540d\u88ab\u6355\u4eba\u5e74\u9f61\u4ecb\u4e4e30\u81f375\u6b72\uff0c\u76f8\u4fe1\u5176\u4e2d3\u4eba\u70ba\u9ed1\u5e6b\u9ad8\u5c64\uff0c\u53e6\u59166\u4eba\u70ba\u540c\u4e00\u6d3e\u7cfb\u6210\u54e1\u3002\u8b66\u65b9\u65bc\u55ae\u4f4d\u6aa2\u7372\u4e00\u6279\u61f7\u7591\u7528\u65bc\u4e09\u5408\u6703\u7d2e\u8077\u5100\u5f0f\u7684\u7269\u54c1\uff0c\u5305\u62ec\u4e00\u652f\u7d05\u8272\u68cd\u30018\u500b\u895f\u82b1\u3001\u4e00\u500b\u4f7f\u7528\u904e\u7684\u5316\u5bf6\u76e4\uff0c\u4ee5\u53ca\u5169\u5f35\u5206\u5225\u5beb\u67096\u540d\u88ab\u6355\u4eba\u58eb\u4e2d\u6587\u5168\u540d\u7684\u767d\u7d19\u53ca\u9ec3\u7d19\u3002</p>\n<p>\u53e6\u5916\uff0c\u8b66\u65b9\u5728\u5176\u4e2d\u4e00\u540d\u88ab\u6355\u4eba\u58eb\u8eab\u4e0a\u6aa2\u7372\u4e00\u5f35\u5beb\u6709\u61f7\u7591\u4e09\u5408\u6703\u6212\u689d\u548c\u8a93\u8a5e\u7684\u767d\u7d19\uff0c\u4ea6\u5728\u53e6\u4e00\u540d\u88ab\u6355\u4eba\u58eb\u8eab\u4e0a\u6aa2\u7372\u4e00\u5c01\u88dd\u67096000\u5143\u73fe\u91d1\u7684\u5229\u662f\u3002</p>\n<p>9\u540d\u88ab\u6355\u4eba\u4e2d\uff0c2\u4eba\u7121\u696d\u30012\u4eba\u9000\u4f11\u30011\u540d\u5831\u7a31\u5546\u4eba\uff0c\u5176\u9918\u88ab\u6355\u4eba\u5206\u5225\u4efb\u8077\u5730\u76e4\u5de5\u4eba\u3001\u9ebb\u96c0\u9928\u8077\u54e1\u548c\u9001\u8ca8\u5de5\u4eba\uff1b\u81f3\u65bc\u6d89\u6848\u55ae\u4f4d\u7531\u5176\u4e2d\u4e00\u540d\u88ab\u6355\u4eba\u8a3b\u518a\u7684\u516c\u53f8\u5730\u5740\uff0c\u76f8\u4fe1\u6709\u71df\u904b\u6b63\u7576\u751f\u610f\u3002</p>\n<p>\u8b66\u65b9\u5f37\u8abf\u6703\u7e7c\u7e8c\u6253\u64ca\u4e09\u5408\u6703\u6d3b\u52d5\uff0c\u6839\u64da\u9999\u6e2f\u6cd5\u4f8b\u7b2c151\u7ae0\u7b2c20\u689d\uff0c\u4efb\u4f55\u4eba\u53c3\u52a0\u4e09\u5408\u6703\u793e\u5718\u96c6\u6703\uff0c\u4e00\u7d93\u5b9a\u7f6a\uff0c\u6700\u9ad8\u53ef\u865525\u842c\u5143\u7f70\u6b3e\u53ca\u76e3\u79817\u5e74\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3805998/9%E7%94%B7%E6%B6%89%E5%8F%83%E8%88%87%E4%B8%89%E5%90%88%E6%9C%83%E7%B4%AE%E8%81%B7%E5%84%80%E5%BC%8F%E8%A2%AB%E6%8D%95"}, {"title": "\u7fd2\u8fd1\u5e73\u8207\u79d8\u9b6f\u7e3d\u7d71\u6703\u8ac7 \u78ba\u4fdd\u9322\u51f1\u6e2f\u5982\u671f\u5efa\u6210", "description": "<p>\u64da\u592e\u8996\u5831\u9053\uff0c\u4e2d\u570b\u570b\u5bb6\u4e3b\u5e2d\u7fd2\u8fd1\u5e73\u5728\u5317\u4eac\u8207\u79d8\u9b6f\u7e3d\u7d71\u535a\u76e7\u963f\u7279(Dina Boluarte)\u8209\u884c\u6703\u8ac7\uff0c\u7fd2\u8fd1\u5e73\u7a31\uff0c\u96d9\u65b9\u8981\u5171\u540c\u52aa\u529b\u78ba\u4fdd\u9322\u51f1\u6e2f(Chancay Port)\u5982\u671f\u5efa\u6210\uff0c\u6210\u70ba\u4e2d\u570b\u548c\u62c9\u4e01\u7f8e\u6d32\u4e4b\u9593\u7684\u9678\u6d77\u65b0\u901a\u9053\uff0c\u4f7f\u300c\u9322\u51f1\u5230\u4e0a\u6d77\u300d\u4fc3\u9032\u4e2d\u79d8\u5171\u540c\u767c\u5c55\u3002</p>\n<p>\u7fd2\u8fd1\u5e73\u8868\u793a\uff0c\u4e2d\u570b\u5c07\u7d71\u7c4c\u63a8\u9032\u7926\u7522\u3001\u80fd\u6e90\u3001\u88fd\u9020\u696d\u3001\u8fb2\u696d\u7b49\u9818\u57df\u548c\u79d8\u9b6f\u7684\u5408\u4f5c\uff0c\u62d3\u5c55\u65b0\u80fd\u6e90\u3001\u6578\u5b57\u7d93\u6fdf\u3001\u4eba\u5de5\u667a\u80fd\u3001\u6578\u5b57\u91ab\u7642\u7b49\u65b0\u8208\u9818\u57df\u5408\u4f5c\uff0c\u6b61\u8fce\u66f4\u591a\u79d8\u9b6f\u512a\u8cea\u7522\u54c1\u9032\u5165\u4e2d\u570b\u5e02\u5834\u3002</p>\n<p>\u4e2d\u65b9\u9ad8\u5ea6\u91cd\u8996\u4e2d\u62c9\u95dc\u4fc2\u767c\u5c55\uff0c\u9858\u540c\u79d8\u9b6f\u7b49\u62c9\u7f8e\u548c\u52a0\u52d2\u6bd4\u570b\u5bb6\u4e00\u9053\u52aa\u529b\uff0c\u4fc3\u9032\u4e2d\u62c9\u6574\u9ad4\u5408\u4f5c\uff0c\u5171\u5efa\u4e2d\u62c9\u547d\u904b\u5171\u540c\u9ad4\u3002</p>\n<p>\u5169\u570b\u5ba3\u5e03\u5be6\u8cea\u6027\u5b8c\u6210\u81ea\u7531\u8cbf\u6613\u5354\u5b9a\u5347\u7d1a\u8ac7\