e\u64ec\u90e8\u7f72\u7015\u6d77\u4f5c\u6230\u5718 \u570b\u9632\u90e8:\u4eba\u82e5\u72af\u6211 \u6211\u5fc5\u72af\u4eba", "description": "<p>\u7f8e\u570b\u6d77\u8ecd\u9678\u6230\u968a\u53f8\u4ee4\u7a31\uff0c\u672a\u4f86\u6578\u5e74\u5167\u5c07\u5728\u95dc\u5cf6\u90e8\u7f72\u5c0f\u898f\u6a21\u4e14\u5177\u5099\u5feb\u901f\u53cd\u61c9\u80fd\u529b\u7684\u300c\u7015\u6d77\u4f5c\u6230\u5718\u300d\uff0c\u4ee5\u5c0d\u6297\u4f86\u81ea\u4e2d\u570b\u7684\u653b\u64ca\uff0c\u4e26\u4fdd\u8b77\u65e5\u672c\u53ca\u83f2\u5f8b\u8cd3\u7b49\u76df\u53cb\u3002</p>\n<p>\u4e2d\u570b\u570b\u9632\u90e8\u65b0\u805e\u767c\u8a00\u4eba\u5433\u8b19\u56de\u61c9\u7a31\uff0c\u7f8e\u65b9\u4ee5\u83ab\u9808\u6709\u7684\u5a01\u8105\u70ba\u85c9\u53e3\uff0c\u6301\u7e8c\u63a8\u9032\u4e9e\u592a\u524d\u6cbf\u8ecd\u4e8b\u90e8\u7f72\uff0c\u6311\u52d5\u5c0d\u7acb\u5c0d\u6297\uff0c\u63a8\u9ad8\u7dca\u5f35\u5c40\u52e2\uff0c\u4e2d\u65b9\u5c0d\u6b64\u5805\u6c7a\u53cd\u5c0d\u3002</p>\n<p>\u5433\u8b19\u5f37\u8abf\uff0c\u4e2d\u570b\u4eba\u4e0d\u60f9\u4e8b\u4f46\u4e5f\u4e0d\u6015\u4e8b\uff0c\u5f9e\u4f86\u662f\u300c\u4eba\u4e0d\u72af\u6211\uff0c\u6211\u4e0d\u72af\u4eba\uff0c\u4eba\u82e5\u72af\u6211\uff0c\u6211\u5fc5\u72af\u4eba\u300d\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3804555/%E7%BE%8E%E6%93%AC%E9%83%A8%E7%BD%B2%E7%80%95%E6%B5%B7%E4%BD%9C%E6%88%B0%E5%9C%98+%E5%9C%8B%E9%98%B2%E9%83%A8%3A%E4%BA%BA%E8%8B%A5%E7%8A%AF%E6%88%91+%E6%88%91%E5%BF%85%E7%8A%AF%E4%BA%BA"}, {"title": "\u65e5\u51fa\u5eb7\u57ce\u4e09\u623f\u5712\u666f\u8667\u640d184\u842c\u8f49\u624b", "description": "<p><span style=\"font-size-ignore:13pt;\">\u5c07\u8ecd\u6fb3\u65e5\u51fa\u5eb7\u57ce\u9818\u5cef7\u5ea7\u6975\u4f4e\u5c64\u55ae\u4f4d\uff0c\u5be6\u7528\u9762\u7a4d673\u65b9\u544e\uff0c3\u623f\u5957\u623f\u9593\u9694\uff0c\u5411\u6771\u671b\u5167\u5712\u666f\uff0c\u539f\u696d\u4e3b\u4ee5\u7d04720\u842c\u5143\u5c07\u55ae\u4f4d\u653e\u76e4\uff0c\u7d043\u500b\u6708\u5f8c\u7372\u5916\u5340\u4eba\u58eb\u6d3d\u8a62\uff0c\u96d9\u65b9\u7d93\u8b70\u50f9\u5f8c\u6e1b\u50f9\u7d0474\u842c\u5143\uff0c\u4ee5\u7d04646\u842c\u5143\u6210\u4ea4\uff0c\u5be6\u7528\u544e\u50f9\u7d049599\u5143\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u64da\u6089\uff0c\u65b0\u8cb7\u5bb6\u70ba\u9996\u7f6e\u4eba\u58eb\uff0c\u5fc3\u5100\u55ae\u4f4d\u9593\u9694\u5be6\u7528\uff0c\u6545\u7747\u6a131\u6b21\u5f8c\u5373\u6c7a\u5b9a\u627f\u63a5\u7269\u696d\u3002</span></p>\n<p>\u9999\u6e2f\u7f6e\u696d\u8868\u793a\uff0c\u539f\u696d\u4e3b\u65bc2019\u5e747\u6708\u4ee5\u7d04830\u842c\u5143\u8cfc\u5165\u4e0a\u8ff0\u55ae\u4f4d\uff0c\u6301\u8ca85\u5e74\uff0c\u662f\u6b21\u8f49\u624b\u8cec\u9762\u8667\u640d\u7d04184\u842c\u5143\u621622%\u3002</p>\n<p>\u00a0</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3804360/%E6%97%A5%E5%87%BA%E5%BA%B7%E5%9F%8E%E4%B8%89%E6%88%BF%E5%9C%92%E6%99%AF%E8%99%A7%E6%90%8D184%E8%90%AC%E8%BD%89%E6%89%8B"}, {"title": "\u5167\u5730\u5c08\u624d1.68\u842c\u79df\u661f\u51f1\uff0e\u5824\u5cb8\u4e00\u623f", "description": "<p>\u706b\u70ad\u661f\u51f1\uff0e\u5824\u5cb85\u5ea7\u4e2d\u5c64E\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d348\u65b9\u544e\uff0c1\u623f\u9593\u9694\uff0c\u958b\u50f9\u7d041.73\u842c\u5143\uff0c\u65e5\u524d\u8b70\u50f9\u5f8c\u4ee51.68\u842c\u5143\u79df\u51fa\uff0c\u5be6\u7528\u544e\u79df48.3\u5143\u3002</p>\n<p>\u4e2d\u539f\u5730\u7522\u8868\u793a\uff0c\u65b0\u79df\u5ba2\u70ba\u5167\u5730\u5c08\u624d\uff0c\u898b\u5c4b\u82d1\u4ea4\u901a\u4fbf\u5229\uff0c\u65b9\u4fbf\u4e0a\u73ed\uff1b\u52a0\u4e0a\u74b0\u5883\u8212\u9069\uff0c\u55ae\u4f4d\u50f9\u9322\u5408\u7406\uff0c\u5373\u6c7a\u5b9a\u79df\u5165\u55ae\u4f4d\u81ea\u4f4f\u3002</p>\n<p>\u64da\u4e86\u89e3\uff0c\u696d\u4e3b\u65bc2021\u5e74\u4ee5732\u842c\u5143\u8cfc\u5165\u55ae\u4f4d\uff0c\u662f\u6b21\u79df\u51fa\u55ae\u4f4d\u53ef\u4eab\u7d042.8\u5398\u79df\u91d1\u56de\u5831\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3804415/%E5%85%A7%E5%9C%B0%E5%B0%88%E6%89%8D1.68%E8%90%AC%E7%A7%9F%E6%98%9F%E5%87%B1%EF%BC%8E%E5%A0%A4%E5%B2%B8%E4%B8%80%E6%88%BF"}, {"title": "ONE STANLEY\u63a8\u5169\u6d0b\u623f\u4e0b\u5468\u4e8c\u8d77\u62db\u6a19", "description": "<p>\u5efa\u705d\u5730\u7522\u8d64\u67f1\u9ec3\u9ebb\u89d2\u9053\u8c6a\u5b85\u9805\u76eeONE STANLEY\uff0c\u9996\u5ea6\u63a8\u51fa\u5169\u5e62\u4f4d\u65bc\u6700\u524d\u6392\u7684\u81e8\u6d77\u7687\u724c\u7368\u7acb\u6d0b\u623f\u62db\u6a19\u767c\u552e\uff0c\u7531\u4e0b\u5468\u4e8c(7\u67082\u65e5)\u8d77\u62db\u6a19\u3002</p>\n<p>\u62db\u6a19\u767c\u552e\u7684\u6d0b\u623f\u70ba2\u865f\u6d0b\u623f\u53ca5\u865f\u6d0b\u623f\uff0c\u5747\u70ba4\u623f4\u5957\u9593\u9694\uff0c\u5be6\u7528\u9762\u7a4d\u5206\u5225\u70ba4732\u53ca4693\u65b9\u544e\uff0c\u8a72\u6b3e\u9593\u9694\u50c5\u8a2d6\u5e62\u3002</p>\n<p>\u5efa\u705d\u5730\u7522\u96c6\u5718\u6295\u8cc7\u53ca\u92b7\u552e\u90e8\u8463\u4e8b\u912d\u667a\u8363\u8868\u793a\uff0c\u9805\u76ee\u81f3\u4eca\u7d2f\u552e11\u4f19\uff0c\u7e3d\u6210\u4ea4\u91d1\u984d\u903e9.56\u5104\u5143\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3804508/ONE+STANLEY%E6%8E%A8%E5%85%A9%E6%B4%8B%E6%88%BF%E4%B8%8B%E5%91%A8%E4%BA%8C%E8%B5%B7%E6%8B%9B%E6%A8%99"}, {"title": "\u65bd\u7f85\u5fb7\u6295\u8cc7\u5c0d\u74b0\u7403\u80a1\u5e02\u6301\u6a02\u89c0\u614b\u5ea6", "description": "<p>\u65bd\u7f85\u5fb7\u6295\u8cc7\u767c\u88682024\u5e74\u4e0b\u534a\u5e74\u7684\u6295\u8cc7\u524d\u77bb\uff0c\u5c0d\u74b0\u7403\u80a1\u5e02\u6301\u6a02\u89c0\u614b\u5ea6\u3002</p>\n<p>\u7531\u65bc\u5404\u570b\u592e\u884c\u8ca8\u5e63\u653f\u7b56\u51fa\u73fe\u5206\u6b67\uff0c\u9ad8\u5229\u7387\u74b0\u5883\u5f88\u53ef\u80fd\u6703\u6bd4\u9810\u671f\u7dad\u6301\u66f4\u9577\u6642\u9593\uff0c\u70ba\u6295\u8cc7\u8005\u5e36\u4f86\u4e0d\u78ba\u5b9a\u56e0\u7d20\u3002\u5118\u7ba1\u5982\u6b64\uff0c\u65bd\u7f85\u5fb7\u6295\u8cc7\u76f8\u4fe12024\u5e74\u9918\u4e0b\u6642\u9593\u5167\u74b0\u7403\u7d93\u6fdf\u5c07\u6703\u6301\u7e8c\u589e\u9577\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u5728\u57fa\u672c\u9762\u7a69\u5065\uff0c\u5c24\u5176\u662f\u9810\u671f\u4f01\u696d\u76c8\u5229\u524d\u666f\u6539\u5584\u7684\u80cc\u666f\u4e0b\uff0c\u5c0d\u74b0\u7403\u80a1\u5e02\u524d\u666f\u6301\u6a02\u89c0\u614b\u5ea6\u3002\u5728\u82f1\u570b\u3001\u7f8e\u570b\u3001\u65e5\u672c\u548c\u65b0\u8208\u5e02\u5834\u7b49\u5730\u5340\uff0c\u9810\u671f\u6709\u4e94\u5206\u4e4b\u4e00\u7684\u4f01\u696d\u6709\u671b\u5be6\u73fe20%\u4ee5\u4e0a\u7684\u76c8\u5229\u589e\u9577\uff0c\u53cd\u6620\u4f01\u696d\u76c8\u5229\u6b63\u5728\u6301\u7e8c\u6539\u5584\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u5728\u9810\u671f\u4f01\u696d\u76c8\u5229\u589e\u9577\u5f37\u52c1\u548c\u8cc7\u91d1\u6d41\u52d5\u6027\u5145\u8db3\u7684\u74b0\u5883\u4e0b\uff0c\u65bd\u7f85\u5fb7\u6295\u8cc7\u770b\u597d\u4eca\u5e74\u4e0b\u534a\u5e74\u7684\u4e9e\u6d32\u6295\u8cc7\u5e02\u5834\u3002\u65bd\u7f85\u5fb7\u6295\u8cc7\u4e9e\u6d32\u5340\u591a\u5143\u5316\u8cc7\u7522\u6295\u8cc7\u4e3b\u7ba1\u8fd1\u85e4\u656c\u5b50(Keiko Kondo)\u8868\u793a\uff0c\u9810\u671f2024\u5e74\u548c2025\u5e74\u4e9e\u6d32\u5c07\u6703\u5be6\u73fe\u5f37\u52c1\u7684\u7d93\u6fdf\u589e\u9577\u3002\u74b0\u7403\u88fd\u9020\u696d\u5468\u671f\u52a0\u901f\u3001\u5de5\u696d\u751f\u7522\u5f37\u52c1\u3001\u80fd\u6e90\u8f49\u578b\u4ee5\u53ca\u65b0\u7d93\u6fdf\u9818\u57df\u7684\u767c\u5c55\uff0c\u5c07\u5e36\u52d5\u4e2d\u570b\u7d93\u6fdf\u767c\u5c55\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u8fd1\u85e4\u656c\u5b50\u7a31\uff0c\u7f8e\u570b\u8ca8\u5e63\u653f\u7b56\u4ecd\u7136\u662f\u4e9e\u6d32\u5e02\u5834\u7684\u4e3b\u8981\u9a45\u52d5\u529b\u3002\u5f9e\u6b77\u53f2\u6578\u64da\u4f86\u770b\uff0c\u7576\u7f8e\u570b\u5229\u7387\u898b\u9802\u6216\u4fdd\u6301\u7a69\u5b9a\u6642\uff0c\u5f80\u5f80\u6709\u5229\u4e9e\u6d32\u80a1\u5e02\u8868\u73fe\u3002\u8207\u5df2\u767c\u5c55\u5e02\u5834\u76f8\u6bd4\uff0c\u4e9e\u6d32\u80a1\u5e02\u4ecd\u88ab\u4f4e\u4f30\uff0c\u5728\u4f01\u696d\u76c8\u5229\u6b63\u6301\u7e8c\u589e\u9577\u7684\u80cc\u666f\u4e0b\uff0c\u4e9e\u6d32\u80a1\u7968\u4f30\u503c\u6709\u671b\u8fce\u982d\u8d95\u4e0a\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u8fd1\u85e4\u656c\u5b50\u8868\u793a\uff0c\u4eca\u5e74\u4e0b\u534a\u5e74\uff0c\u770b\u597d\u4e09\u5927\u4e9e\u6d32\u6295\u8cc7\u4e3b\u984c\uff0c\u5305\u62ec\u4eba\u5de5\u667a\u80fd\u53ca\u4f01\u696d\u7ba1\u6cbb\u3002\u6b64\u5916\uff0c\u6295\u8cc7\u8005\u4ea6\u4e0d\u5bb9\u5ffd\u8996\u5370\u5ea6\u7684\u589e\u9577\u6f5b\u529b\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3804510/%E6%96%BD%E7%BE%85%E5%BE%B7%E6%8A%95%E8%B3%87%E5%B0%8D%E7%92%B0%E7%90%83%E8%82%A1%E5%B8%82%E6%8C%81%E6%A8%82%E8%A7%80%E6%85%8B%E5%BA%A6"}, {"title": "\u570b\u5bb6\u822a\u5929\u5c40:\u5ae6\u5a256\u865f\u4efb\u52d9\u518d\u5275\u4e2d\u570b\u822a\u5929\u4e16\u754c\u7d00\u9304", "description": "<p><span style=\"font-size-ignore:13pt;\">\u570b\u65b0\u8fa6\u8209\u884c\u65b0\u805e\u767c\u5e03\u6703\uff0c\u4ecb\u7d39\u63a2\u6708\u5de5\u7a0b\u5ae6\u5a256\u865f\u4efb\u52d9\u6709\u95dc\u72c0\u6cc1\uff0c\u570b\u5bb6\u822a\u5929\u5c40\u526f\u5c40\u9577\u535e\u5fd7\u525b\u5728\u6703\u4e0a\u8868\u793a\uff0c\u5ae6\u5a256\u865f\u8fd4\u56de\u5668\u524d\u65e5\u4e0b\u5348\u7d042\u6642\uff0c\u651c\u5e36\u4eba\u985e\u9996\u4efd\u6708\u7403\u80cc\u9762\u6a23\u672c\uff0c\u7cbe\u6e96\u7740\u9678\u5728\u5167\u8499\u53e4\u56db\u5b50\u738b\u65d7\uff0c\u4efb\u52d9\u53d6\u5f97\u5713\u6eff\u6210\u529f\u3002</span></p>\n<p>\u535e\u5fd7\u525b\u6307\u51fa\uff0c\u9019\u6b21\u5ae6\u5a256\u865f\u9078\u64c7\u7740\u9678\u5728\u6708\u7403\u80cc\u9762\u5357\u6975-\u827e\u7279\u80af\u76c6\u5730\u6771\u5317\u90e8\u963f\u6ce2\u7f85\u649e\u64ca\u5751\u908a\u7de3\uff0c\u9019\u662f\u6708\u7403\u4e0a\u5df2\u77e5\u6700\u5927\u3001\u6700\u6df1\u3001\u6700\u53e4\u8001\u7684\u649e\u64ca\u5751\u3002\u79d1\u5b78\u5bb6\u5c0d\u5f9e\u6b64\u8655\u947d\u53d6\u548c\u8868\u53d6\u7684\u6708\u7403\u6a23\u672c\u958b\u5c55\u7814\u7a76\uff0c\u6709\u671b\u767c\u73fe\u66f4\u591a\u592a\u967d\u7cfb\u548c\u6708\u7403\u6f14\u8b8a\u7b49\u91cd\u5927\u79d1\u5b78\u5967\u79d8\u3002</p>\n<p>\u535e\u5fd7\u525b\u53c8\u6307\u51fa\uff0c\u5ae6\u5a256\u865f\u4efb\u52d9\u662f\u4e2d\u570b\u822a\u5929\u53f2\u4e0a\u8fc4\u4eca\u70ba\u6b62\u6280\u8853\u6c34\u5e73\u6700\u9ad8\u7684\u6708\u7403\u63a2\u6e2c\u4efb\u52d9\uff0c\u5be6\u73fe\u4e86\u300c\u4e09\u5927\u6280\u8853\u7a81\u7834\u300d\u548c\u300c\u4e00\u9805\u4e16\u754c\u7b2c\u4e00\u300d\u3002\u5373\u7a81\u7834\u4e86\u6708\u7403\u9006\u884c\u8ecc\u9053\u8a2d\u8a08\u8207\u63a7\u5236\u6280\u8853\u3001\u6708\u80cc\u667a\u80fd\u63a1\u6a23\u6280\u8853\u3001\u6708\u80cc\u8d77\u98db\u4e0a\u5347\u6280\u8853\uff0c\u5be6\u73fe\u4e86\u4e16\u754c\u9996\u6b21\u6708\u7403\u80cc\u9762\u81ea\u52d5\u63a1\u6a23\u8fd4\u56de\uff0c\u518d\u6b21\u5275\u9020\u4e86\u4e2d\u570b\u822a\u5929\u7684\u4e16\u754c\u7d00\u9304\u3002</p>\n<p>\u535e\u5fd7\u525b\u4ea6\u7a31\uff0c\u4e2d\u5916\u79d1\u5b78\u5bb6\u4f7f\u7528\u4e2d\u570b\u63a2\u6708\u6578\u64da\uff0c\u5df2\u767c\u88681900\u591a\u7bc7\u8ad6\u6587\uff0c\u5f9e\u5ae6\u5a255\u865f\u6708\u7403\u6a23\u672c\u4e2d\uff0c\u4e2d\u570b\u79d1\u5b78\u5bb6\u767c\u73fe\u6708\u7403\u7b2c6\u7a2e\u65b0\u7926\u7269\uff0c\u4e26\u547d\u540d\u70ba\u300c\u5ae6\u5a25\u77f3\u300d\uff1b\u7814\u7a76\u8b49\u660e\u6708\u7403\u572819.6\u5104\u5e74\u524d\uff0c\u4ecd\u5b58\u5728\u5ca9\u6f3f\u6d3b\u52d5\uff0c\u4ee4\u76ee\u524d\u5df2\u77e5\u6708\u7403\u5730\u8cea\u58fd\u547d\u5ef6\u9577\u4e8610\u5104\u5e74\uff0c\u6708\u7403\u6a23\u672c\u9032\u5165\u300c\u5ae6\u5a25\u6642\u4ee3\u300d\uff0c\u6975\u5927\u8c50\u5bcc\u4e86\u4eba\u985e\u5c0d\u6708\u7403\u4e43\u81f3\u5b87\u5b99\u7684\u8a8d\u77e5\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3804509/%E5%9C%8B%E5%AE%B6%E8%88%AA%E5%A4%A9%E5%B1%80%3A%E5%AB%A6%E5%A8%A56%E8%99%9F%E4%BB%BB%E5%8B%99%E5%86%8D%E5%89%B5%E4%B8%AD%E5%9C%8B%E8%88%AA%E5%A4%A9%E4%B8%96%E7%95%8C%E7%B4%80%E9%8C%84"}]}