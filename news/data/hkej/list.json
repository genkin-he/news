0c\u539f\u696d\u4e3b\u65bc2022\u5e74\u4ee5\u7d04878\u842c\u5143\u8cfc\u5165\u4e0a\u8ff0\u55ae\u4f4d\uff0c\u6301\u8ca82\u5e74\uff1b\u73fe\u8f49\u624b\u8cec\u9762\u8667\u8755173\u842c\u5143\uff0c\u7269\u696d\u8cb6\u503c\u7d0419.7%\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3970437/%E5%98%89%E5%85%86%E8%BB%92%E4%B8%89%E6%88%BF%E9%80%A3%E5%A4%A9%E5%8F%B0%E8%9D%95173%E8%90%AC%E8%BD%89%E6%89%8B", "pub_date": "2025-01-03 19:20:33", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u5c6f\u9580\u5bf6\u7530\u90a8\u8b00\u6bba\u6848 44\u6b72\u5973\u5b50\u6d89\u8aa4\u5c0e\u8b66\u52d9\u4eba\u54e1\u88ab\u6355", "description": "<p><span style=\"font-size-ignore:13pt;\">\u8b66\u65b9\u6b63\u8abf\u67e5\u6628\u65e5\u5728\u5c6f\u9580\u767c\u751f\u7684\u4e00\u5b97\u8b00\u6bba\u6848\uff0c\u6848\u4e2d\u4e00\u540d\u7537\u5b50\u6b7b\u4ea1\u3002</span></p>\n<p>\u8b66\u65b9\u8868\u793a\uff0c\u6628\u665a10\u664212\u5206\u63a5\u7372\u5831\u6848\uff0c\u6307\u4e00\u540d\u7537\u5b50\u660f\u8ff7\u5012\u5367\u5728\u5bf6\u7530\u90a8\u4e03\u5ea7\u5c0d\u958b\u3002\u4eba\u54e1\u8d95\u8d74\u73fe\u5834\uff0c\u767c\u73fe\u8a72\u540d33\u6b72\u7537\u5b50\u80cc\u90e8\u6709\u50b7\u3002\u4ed6\u660f\u8ff7\u88ab\u9001\u5f80\u5c6f\u9580\u91ab\u9662\u6cbb\u7406\uff0c\u65bc\u665a\u4e0a11\u664255\u5206\u88ab\u8b49\u5be6\u6b7b\u4ea1\u3002</p>\n<p>\u521d\u6b65\u8abf\u67e5\u986f\u793a\uff0c\u6b7b\u8005\u61f7\u7591\u66fe\u88ab\u4e00\u540d\u7537\u5b50\u4ee5\u5229\u5668\u8972\u64ca\uff0c\u6d89\u6848\u7537\u5b50\u4e8b\u5f8c\u9003\u53bb\u3002\u4eba\u54e1\u7d93\u521d\u6b65\u8abf\u67e5\u5f8c\uff0c\u4eca\u65e5\u5728\u9752\u5c71\u5340\u62d8\u6355\u4e00\u540d44\u6b72\u5973\u5b50\uff0c\u5979\u6d89\u5acc\u5728\u5354\u52a9\u8abf\u67e5\u671f\u9593\u8aa4\u5c0e\u8b66\u52d9\u4eba\u54e1\uff0c\u6b63\u88ab\u6263\u7559\u8abf\u67e5\u3002</p>\n<p>\u8b66\u65b9\u7a0d\u5f8c\u5c07\u5b89\u6392\u70ba\u6b7b\u8005\u9032\u884c\u9a57\u5c4d\uff0c\u4ee5\u78ba\u5b9a\u5176\u6b7b\u56e0\u3002<span style=\"font-size-ignore:13pt;\">\u5c6f\u9580\u8b66\u5340\u91cd\u6848\u7d44\u6b63\u7a4d\u6975\u8abf\u67e5\u6848\u4ef6\u3002</span></p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3970438/%E5%B1%AF%E9%96%80%E5%AF%B6%E7%94%B0%E9%82%A8%E8%AC%80%E6%AE%BA%E6%A1%88+44%E6%AD%B2%E5%A5%B3%E5%AD%90%E6%B6%89%E8%AA%A4%E5%B0%8E%E8%AD%A6%E5%8B%99%E4%BA%BA%E5%93%A1%E8%A2%AB%E6%8D%95", "pub_date": "2025-01-03 19:10:33", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u524d\u300a\u6587\u532f\u5831\u300b\u7e3d\u7de8\u7372\u8058\u653f\u52d9\u53f8\u53f8\u9577\u9ad8\u7d1a\u7279\u52a9 \u5408\u7d04\u671f\u4e00\u5e74", "description": "<p><span style=\"font-size-ignore:13pt;\">\u524d\u300a\u6587\u532f\u5831\u300b\u7e3d\u7de8\u8f2f\u5433\u660e\u52a0\u5165\u653f\u5e9c\uff0c\u51fa\u4efb\u653f\u52d9\u53f8\u53f8\u9577\u9ad8\u7d1a\u7279\u5225\u52a9\u7406\uff0c</span><span style=\"font-size-ignore:13pt;\">\u96b8\u5c6c\u653f\u52d9\u53f8\u53f8\u9577\u79c1\u4eba\u8fa6\u516c\u5ba4\u3002</span></p>\n<p>\u64da\u4e86\u89e3\uff0c\u5433\u660e\u66fe\u4efb\u65b0\u83ef\u793e\u8a18\u8005\uff0c\u5f8c\u4f86\u79fb\u5c45\u9999\u6e2f\uff0c\u52a0\u5165\u300a\u6587\u532f\u5831\u300b\u4efb\u9ad8\u5c64\u7d0420\u5e74\uff0c\u6578\u500b\u6708\u524d\u5378\u4efb\u7e3d\u7de8\u8f2f\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u653f\u52d9\u53f8\u53f8\u9577\u79c1\u4eba\u8fa6\u516c\u5ba4\u56de\u8986\u7a31\uff0c</span><span style=\"font-size-ignore:13pt;\">\u878d\u5165\u570b\u5bb6\u767c\u5c55\u5927\u5c40\u662f\u9999\u6e2f\u672a\u4f86\u767c\u5c55\u65b0\u8def\u5411\u3001\u65b0\u7a7a\u9593\u3001\u65b0\u52d5\u529b\u7684\u95dc\u9375\u6240\u5728\uff0c\u6709\u95dc\u5de5\u4f5c\u523b\u4e0d\u5bb9\u7de9\u3002\u9762\u5c0d\u570b\u5bb6\u65b0\u767c\u5c55\u683c\u5c40\u4ee5\u53ca\u570b\u969b\u7af6\u722d\u52a0\u5287\uff0c\u9999\u6e2f\u5fc5\u9808\u52a0\u5f37\u516b\u5927\u4e2d\u5fc3\u5730\u4f4d\uff0c\u52a0\u5feb\u6253\u9020\u570b\u969b\u9ad8\u7aef\u4eba\u624d\u96c6\u805a\u9ad8\u5730\uff0c\u4e26\u7a4d\u6975\u53c3\u8207\u7cb5\u6e2f\u6fb3\u5927\u7063\u5340\u5efa\u8a2d\uff0c\u5be6\u73fe\u9999\u6e2f\u548c\u570b\u5bb6\u7684\u66f4\u597d\u767c\u5c55\u3002</span></p>\n<p><span style=\"font-size-ignore:13pt;\">\u8fa6\u516c\u5ba4\u6307\u51fa\uff0c</span><span style=\"font-size-ignore:13pt;\">\u5728\u4e0a\u8ff0\u80cc\u666f\u4e0b\uff0c\u958b\u8a2d\u4e86\u4e00\u500b\u70ba\u671f\u4e00\u5e74\u7684\u77ed\u671f\u5408\u7d04\u975e\u516c\u52d9\u54e1\u8077\u4f4d\uff0c\u4ee5\u5354\u52a9\u653f\u52d9\u53f8\u53f8\u9577\u9032\u884c\u5167\u5730\u653f\u7b56\u7814\u7a76\u5de5\u4f5c\uff0c\u4ee5\u53ca\u5c31\u5982\u4f55\u52a0\u5feb\u63a8\u52d5\u9999\u6e2f\u878d\u5165\u570b\u5bb6\u767c\u5c55\u5927\u5c40\u5411\u653f\u52d9\u53f8\u53f8\u9577\u63d0\u4f9b\u610f\u898b\u548c\u5efa\u8b70\u3002</span></p>\n<p>\u8fa6\u516c\u5ba4\u7a31\uff0c\u5433\u660e\u64c1\u6709\u8d85\u904e40\u5e74\u7684\u5167\u5730\u548c\u9999\u6e2f\u50b3\u5a92\u5de5\u4f5c\u7d93\u9a57\uff0c\u4f5c\u70ba\u5c08\u9580\u5f9e\u4e8b\u5167\u5730\u4e8b\u52d9\u7684\u50b3\u5a92\u5de5\u4f5c\u8005\uff0c\u5c0d\u5167\u5730\u548c\u9999\u6e2f\u7684\u653f\u7b56\u5747\u6709\u6df1\u523b\u7406\u89e3\u3002\u57fa\u65bc\u4ed6\u7684\u80cc\u666f\u548c\u5c08\u696d\u5c65\u6b77\uff0c\u5433\u660e\u662f\u9019\u500b\u8077\u4f4d\u6700\u5408\u9069\u7684\u4eba\u9078\uff0c\u80fd\u5373\u6642\u5c65\u884c\u76f8\u95dc\u8077\u8cac\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3970403/%E5%89%8D%E3%80%8A%E6%96%87%E5%8C%AF%E5%A0%B1%E3%80%8B%E7%B8%BD%E7%B7%A8%E7%8D%B2%E8%81%98%E6%94%BF%E5%8B%99%E5%8F%B8%E5%8F%B8%E9%95%B7%E9%AB%98%E7%B4%9A%E7%89%B9%E5%8A%A9+%E5%90%88%E7%B4%84%E6%9C%9F%E4%B8%80%E5%B9%B4", "pub_date": "2025-01-03 19:10:32", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u5167\u5730\u516c\u52d9\u54e1\u50b3\u52a0\u85aa \u77ed\u671f\u6599\u70ba\u7d93\u6fdf\u6ce8\u5165\u6700\u591a1560\u5104", "description": "<p>\u5916\u96fb\u65e5\u524d\u5831\u9053\uff0c\u4e2d\u570b\u903e\u767e\u842c\u540d\u516c\u52d9\u54e1\u5c07\u7372\u5927\u5e45\u52a0\u85aa\uff0c\u85c9\u6b64\u671f\u671b\u53ef\u523a\u6fc0\u5c45\u6c11\u6d88\u8cbb\uff0c\u70ba\u7d93\u6fdf\u589e\u9577\u63d0\u4f9b\u4e00\u5b9a\u652f\u6301\u3002\u5916\u96fb\u4f30\u7b97\uff0c\u82e5\u5168\u570b\u7d044800\u842c\u540d\u516c\u52d9\u54e1\u90fd\u53d7\u60e0\u662f\u6b21\u52a0\u85aa\uff0c\u77ed\u671f\u5167\u5c07\u70ba\u7d93\u6fdf\u6ce8\u5165\u7d04120\u5104\u81f3200\u5104\u7f8e\u5143(\u7d04936\u5104\u81f31560\u5104\u6e2f\u5143)\u3002</p>\n<p>\u5831\u9053\u6307\u51fa\uff0c\u5167\u5730\u4e0a\u4e00\u6b21\u516c\u5e03\u516c\u52d9\u54e1\u52a0\u85aa\u57282015\u5e74\uff0c\u7576\u6642\u52a0\u5e45\u7d0430%\u3002\u81f3\u65bc\u4eca\u6b21\u50b3\u6708\u85aa\u5e73\u5747\u4e0a\u8abf\u7d04500\u5143\u4eba\u6c11\u5e63\uff0c\u521d\u7d1a\u54e1\u5de5\u5247\u52a0\u85aa\u7d04300\u5143\u4eba\u6c11\u5e63\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3970436/%E5%85%A7%E5%9C%B0%E5%85%AC%E5%8B%99%E5%93%A1%E5%82%B3%E5%8A%A0%E8%96%AA+%E7%9F%AD%E6%9C%9F%E6%96%99%E7%82%BA%E7%B6%93%E6%BF%9F%E6%B3%A8%E5%85%A5%E6%9C%80%E5%A4%9A1560%E5%84%84", "pub_date": "2025-01-03 19:05:31", "source": "hkej", "kind": 1, "language": "zh-HK"}]}