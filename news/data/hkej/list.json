d\u7f8e\u885d\u7a81\u5c07\u662f\u5927\u707d\u96e3\u3002\u5982\u679c\u5169\u570b\u505a\u5925\u4f34\u3001\u505a\u670b\u53cb\uff0c\u6c42\u540c\u5b58\u7570\u3001\u5f7c\u6b64\u6210\u5c31\uff0c\u4e2d\u7f8e\u95dc\u4fc2\u5c31\u80fd\u5920\u5f97\u5230\u9577\u8db3\u767c\u5c55\u3002\u5982\u679c\u628a\u5c0d\u65b9\u7576\u5c0d\u624b\u3001\u7576\u6575\u4eba\uff0c\u60e1\u6027\u7af6\u722d\u3001\u4e92\u76f8\u50b7\u5bb3\uff0c\u4e2d\u7f8e\u95dc\u4fc2\u5c31\u6703\u906d\u9047\u6ce2\u6298\u751a\u81f3\u5012\u9000\u3002</p>\n<p>\u4ed6\u7e8c\u7a31\uff0c\u4e2d\u7f8e\u95dc\u4fc2\u4e92\u5229\u5171\u8d0f\u7684\u672c\u8cea\u662f\u78ba\u5b9a\u7684\u3002\u96d9\u65b9\u61c9\u767c\u63ee\u4e92\u88dc\u512a\u52e2\u505a\u5927\u5408\u4f5c\u86cb\u7cd5\uff0c\u8b93\u5404\u81ea\u7684\u6210\u529f\u6210\u70ba\u5f7c\u6b64\u7684\u6a5f\u9047\u800c\u975e\u6311\u6230\uff0c\u8b93\u96d9\u65b9\u7684\u767c\u5c55\u6210\u70ba\u5f7c\u6b64\u7684\u52a9\u529b\u800c\u975e\u963b\u529b\u3002</p>\n<p>\u8b1d\u92d2\u8aaa\uff0c\u4e2d\u7f8e\u662f\u5169\u500b\u5927\u570b\uff0c\u96e3\u514d\u6709\u4e9b\u77db\u76fe\u5206\u6b67\uff0c\u4f46\u4e0d\u80fd\u640d\u5bb3\u5f7c\u6b64\u6838\u5fc3\u5229\u76ca\uff0c\u66f4\u4e0d\u80fd\u641e\u885d\u7a81\u5c0d\u6297\u3002\u95dc\u7a05\u6230\u3001\u8cbf\u6613\u6230\u3001\u79d1\u6280\u6230\u9055\u80cc\u6b77\u53f2\u6f6e\u6d41\u548c\u7d93\u6fdf\u898f\u5f8b\uff0c\u4e0d\u6703\u6709\u8d0f\u5bb6\uff0c\u5408\u4f5c\u624d\u662f\u4e2d\u7f8e\u6700\u597d\u7684\u3001\u552f\u4e00\u7684\u9078\u64c7\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3959354/%E8%AC%9D%E9%8B%92%E7%B1%B2%E7%BE%8E%E5%B7%A5%E5%95%86%E7%95%8C%E4%B8%8D%E6%87%BC%E5%AF%92%E8%9F%AC%E6%95%88%E6%87%89+%E7%82%BA%E4%B8%AD%E7%BE%8E%E9%97%9C%E4%BF%82%E6%B3%A8%E5%85%A5%E6%9B%B4%E5%A4%9A%E7%A2%BA%E5%AE%9A%E6%80%A7", "pub_date": "2024-12-20 15:40:37", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u5167\u5730\u5f37\u5316\u9996\u5e2d\u7d93\u6fdf\u5b78\u5bb6\u81ea\u5f8b\u7ba1\u7406 \u4e0d\u7576\u8a00\u884c\u53ef\u88ab\u89e3\u8058", "description": "<p>\u5167\u5730\u5b98\u65b9\u5a92\u9ad4\u300a\u4e2d\u570b\u8b49\u5238\u5831\u300b\u5831\u9053\uff0c\u4e2d\u570b\u8b49\u5238\u696d\u5354\u6703\u8fd1\u65e5\u5728\u696d\u5167\u767c\u5e03\u901a\u77e5\uff0c\u8981\u6c42\u9032\u4e00\u6b65\u5f37\u5316\u9996\u5e2d\u7d93\u6fdf\u5b78\u5bb6\u81ea\u5f8b\u7ba1\u7406\uff0c\u9996\u5e2d\u7d93\u6fdf\u5b78\u5bb6\u5728\u4e00\u5b9a\u671f\u9650\u5167\u591a\u6b21\u56e0\u5176\u500b\u4eba\u4e0d\u7576\u8a00\u884c\u5f15\u767c\u8072\u8b7d\u98a8\u96aa\u4e8b\u4ef6\uff0c\u6216\u7522\u751f\u56b4\u91cd\u4e0d\u826f\u5f71\u97ff\u7684\uff0c\u516c\u53f8\u61c9\u5f9e\u91cd\u8655\u7406\u76f4\u81f3\u89e3\u8058\u3002</p>\n<p>\u901a\u77e5\u7a31\uff0c\u516c\u53f8\u61c9\u52a0\u5f37\u9996\u5e2d\u7d93\u6fdf\u5b78\u5bb6\u5c0d\u5916\u767c\u8868\u610f\u898b\u4e8b\u524d\u5be9\u6838\u3002\u9996\u5e2d\u7d93\u6fdf\u5b78\u5bb6\u53c3\u52a0\u5404\u985e\u6703\u8b70\u3001\u6d3b\u52d5\uff0c\u5c0d\u5916\u767c\u8868\u7814\u7a76\u89c0\u9ede\u3001\u8a55\u8ad6\u610f\u898b\u7684\uff0c\u61c9\u9032\u884c\u4e8b\u524d\u5831\u5099\u3002\u672a\u7d93\u6279\u51c6\uff0c\u4e0d\u5f97\u79c1\u81ea\u53c3\u52a0\u5404\u985e\u6703\u8b70\u3001\u6d3b\u52d5\uff0c\u4e0d\u5f97\u64c5\u81ea\u5c0d\u5916\u767c\u8868\u7814\u7a76\u89c0\u9ede\u3001\u8a55\u8ad6\u610f\u898b\u3002\u4e0d\u5f97\u4ee5\u4efb\u4f55\u5f62\u5f0f\u4f7f\u7528\u6216\u6d29\u9732\u5404\u985e\u4fdd\u5bc6\u8a0a\u606f\u53ca\u672a\u516c\u958b\u8a0a\u606f\uff0c\u4e0d\u5f97\u7de8\u9020\u3001\u50b3\u64ad\u865b\u5047\u3001\u4e0d\u5be6\u3001\u8aa4\u5c0e\u6027\u8a0a\u606f\u3002</p>\n<p>\u8ca1\u806f\u793e\u65e9\u524d\u5f15\u8ff0\u6d88\u606f\u5831\u9053\uff0c\u4e2d\u570b\u591a\u5730\u8b49\u76e3\u5c40\u8fd1\u65e5\u9678\u7e8c\u5c0d\u5238\u5546\u7b49\u63d0\u51fa\u76e3\u7ba1\u8981\u6c42\uff0c\u65e8\u5728\u52a0\u5f37\u5c0d\u516c\u958b\u8a00\u8ad6\u7684\u7ba1\u7406\uff0c\u5c24\u5176\u662f\u9996\u5e2d\u7d93\u6fdf\u5b78\u5bb6\u3001\u5238\u5546\u5206\u6790\u5e2b\u3001\u57fa\u91d1\u7d93\u7406\u7b49\u5f9e\u696d\u4eba\u54e1\u5c0d\u5916\u767c\u8072\u7684\u7ba1\u7406\u5de5\u4f5c\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3959339/%E5%85%A7%E5%9C%B0%E5%BC%B7%E5%8C%96%E9%A6%96%E5%B8%AD%E7%B6%93%E6%BF%9F%E5%AD%B8%E5%AE%B6%E8%87%AA%E5%BE%8B%E7%AE%A1%E7%90%86+%E4%B8%8D%E7%95%B6%E8%A8%80%E8%A1%8C%E5%8F%AF%E8%A2%AB%E8%A7%A3%E8%81%98", "pub_date": "2024-12-20 15:30:53", "source": "hkej", "kind": 1, "language": "zh-HK"}, {"title": "\u6620\u65e5\u7063\u4e2d\u5c64\u6236\u544e\u79df\u5275\u8343\u7063\u65b0\u9ad8", "description": "<p>\u8343\u7063\u6620\u65e5\u70633\u5ea7\u4e2d\u5c64B\u5ba4\uff0c\u5be6\u7528\u9762\u7a4d216\u65b9\u544e\uff0c\u4ee51.55\u842c\u5143\u653e\u79df\uff0c\u4ee51.53\u842c\u5143\u627f\u63a5\uff0c\u5be6\u7528\u544e\u79df\u7d0471\u5143\uff0c\u5275\u5340\u5167\u544e\u79df\u65b0\u9ad8\u3002</p>\n<p>\u7f8e\u806f\u7269\u696d\u8868\u793a\uff0c\u696d\u4e3b2024\u5e748\u6708\u4ee5400\u842c\u5143\u8cfc\u5165\u55ae\u4f4d\uff0c\u6301\u8ca8\u50c54\u500b\u6708\uff0c\u4ee5\u662f\u6b21\u79df\u91d1\u8a08\u7b97\uff0c\u79df\u91d1\u56de\u5831\u8fd14.6\u5398\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3959349/%E6%98%A0%E6%97%A5%E7%81%A3%E4%B8%AD%E5%B1%A4%E6%88%B6%E5%91%8E%E7%A7%9F%E5%89%B5%E8%8D%83%E7%81%A3%E6%96%B0%E9%AB%98", "pub_date": "2024-12-20 15:30:53", "source": "hkej", "kind": 1, "language": "zh-HK"}]}