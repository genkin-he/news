\u91cb\uff0c\u512a\u5316\u4e3b\u8981\u70ba\u5169\u65b9\u9762\uff0c\u76ee\u524d\u4eba\u6c11\u5e63\u5373\u6642\u652f\u4ed8\u7d50\u7b97\u591c\u9593\u8de8\u5883\u670d\u52d9\u70ba\u665a\u4e0a8\u6642\u81f3\u65e9\u4e0a8\u6642\uff0c\u5e0c\u671b\u53ef\u4ee5\u5ef6\u9577\u670d\u52d9\u6642\u9593\uff1b\u6b64\u5916\u4ea6\u5e0c\u671b\u63d0\u5347\u6548\u7387\uff0c\u9054\u5230\u5373\u6642\u8de8\u5883\u652f\u4ed8\u3002</p>\n<p>\u300a\u65bd\u653f\u5831\u544a\u300b\u4ea6\u5ba3\u5e03\uff0c\u5c07\u63d0\u5347\u56fa\u5b9a\u6536\u76ca\u5e02\u5834\u7684\u57fa\u5efa\uff0c\u4f8b\u5982\u70ba\u4eba\u6c11\u5e63\u8a08\u50f9\u7684\u56de\u8cfc\u4ea4\u6613\u5efa\u7acb\u4e2d\u592e\u6e05\u7b97\u7cfb\u7d71\u3002\u6d88\u606f\u4eba\u58eb\u89e3\u91cb\uff0c\u6b64\u53ef\u4ee4\u5728\u6e2f\u767c\u884c\u7684\u570b\u50b5\u6210\u70ba\u62b5\u62bc\u54c1\uff0c\u63d0\u5347\u570b\u969b\u6295\u8cc7\u8005\u5c0d\u570b\u50b5\u7684\u8208\u8da3\uff0c\u4e26\u6709\u52a9\u4eba\u6c11\u5e63\u570b\u969b\u5316\u3002</p>\n<p>\u53e6\u5916\uff0c\u653f\u5e9c\u4ea6\u6703\u7a4d\u6975\u8207\u5167\u5730\u5546\u8a0e\u70ba\u50b5\u5238\u901a(\u5357\u5411\u901a)\u64f4\u5bb9\uff0c\u5305\u62ec\u64f4\u5927\u5408\u8cc7\u683c\u5883\u5167\u6295\u8cc7\u8005\u7bc4\u570d\uff0c\u4f8b\u5982\u7d0d\u5165\u8b49\u5238\u3001\u4fdd\u96aa\u7b49\u975e\u9280\u884c\u91d1\u878d\u6a5f\u69cb\u3002\u6d88\u606f\u4eba\u58eb\u8868\u793a\uff0c\u91d1\u7ba1\u5c40\u8207\u4eba\u6c11\u9280\u884c\u6b63\u5728\u5546\u8a0e\uff0c\u66ab\u672a\u6709\u6642\u9593\u8868\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3904433/%E6%96%BD%E6%94%BF%E5%A0%B1%E5%91%8A%E4%B8%A8%E6%B6%88%E6%81%AF%E4%BA%BA%E5%A3%AB%3A%E5%86%80%E5%B9%B4%E5%BA%95%E5%89%8D%E8%90%BD%E5%AF%A6%E4%BA%BA%E6%B0%91%E5%B9%A3%E5%8D%B3%E6%99%82%E6%94%AF%E4%BB%98%E7%B5%90%E7%AE%97%E7%B3%BB%E7%B5%B1%E5%84%AA%E5%8C%96%E6%8E%AA%E6%96%BD"}, {"title": "\u65bd\u653f\u5831\u544a\u4e28\u8a31\u6b63\u5b87:\u8ca1\u5eab\u5c40\u6703\u5805\u6301\u5b88\u6b63\u5275\u65b0", "description": "<p><span style=\"font-size-ignore:13pt;\">\u884c\u653f\u9577\u5b98\u674e\u5bb6\u8d85\u4eca\u65e5\u767c\u8868\u4efb\u5167\u7b2c\u4e09\u4efd\u300a\u65bd\u653f\u5831\u544a\u300b\u3002\u8ca1\u7d93\u4e8b\u52d9\u53ca\u5eab\u52d9\u5c40\u5c40\u9577\u8a31\u6b63\u5b87\u5728\u793e\u4ea4\u5a92\u9ad4\u5e16\u6587\uff0c\u6307\u8ca1\u5eab\u5c40\u6703\u5805\u6301\u5b88\u6b63\u5275\u65b0\uff0c\u5728\u56fa\u6709\u6839\u57fa\u4e0a\u6c42\u65b0\u3001\u6c42\u9032\u3002</span></p>\n<p>\u8a31\u6b63\u5b87\u6307\u51fa\uff0c\u5177\u9ad4\u7684\u5de5\u4f5c\u5305\u62ec\u6301\u7e8c\u6df1\u5316\u300c\u4e92\u806f\u4e92\u901a\u300d\u3001\u4fc3\u9032\u4eba\u6c11\u5e63\u570b\u969b\u5316\u3001\u5f37\u5316\u570b\u969b\u98a8\u96aa\u7ba1\u7406\u4e2d\u5fc3\u548c\u570b\u969b\u8cc7\u7522\u53ca\u8ca1\u5bcc\u4e2d\u5fc3\uff0c\u7a4d\u6975\u62d3\u5c55\u65b0\u589e\u9577\u9ede\uff0c\u85c9\u7740\u300c\u4e00\u570b\u5169\u5236\u300d\u7684\u7368\u7279\u512a\u52e2\uff0c\u6293\u7dca\u570b\u5bb6\u767c\u5c55\u7684\u9f90\u5927\u6a5f\u9047\uff0c\u767c\u63ee\u300c\u8d85\u7d1a\u806f\u7e6b\u4eba\u300d\u548c\u300c\u8d85\u7d1a\u589e\u503c\u4eba\u300d\u7684\u89d2\u8272\uff0c\u978f\u56fa\u63d0\u5347\u9999\u6e2f\u570b\u969b\u91d1\u878d\u4e2d\u5fc3\u7684\u5730\u4f4d\uff0c\u63a8\u52d5\u9999\u6e2f\u300c\u7531\u6cbb\u53ca\u8208\u300d\u3002</p>\n<p>\u4ed6\u7a31\uff0c\u4f5c\u70ba\u554f\u8cac\u5718\u968a\u4e00\u54e1\uff0c\u5145\u5206\u611f\u53d7\u5230\u5831\u544a\u5167\u5bb9\u7684\u91cd\u91cf\uff0c\u65e2\u76db\u8f09\u570b\u5bb6\u4ea4\u4ed8\u7684\u91cd\u6258\u548c\u5dff\u6c11\u5c0d\u672a\u4f86\u7684\u671f\u76fc\uff0c\u4ea6\u5c55\u73fe\u4e86\u7576\u5c40\u7a69\u4e2d\u6c42\u8b8a\u3001\u6539\u9769\u60e0\u6c11\u7684\u64d4\u7576\uff1b\u653f\u5e9c\u92b3\u610f\u9769\u65b0\uff0c\u76ee\u6a19\u6e05\u6670\u660e\u78ba\uff0c\u5c31\u662f\u8981\u8b93\u5e02\u6c11\u751f\u6d3b\u5f97\u66f4\u7f8e\u597d\u3001\u66f4\u5e78\u798f\u3002\u5728\u884c\u653f\u9577\u5b98\u5e36\u9818\u4e0b\uff0c\u6703\u52d9\u5be6\u6709\u5e8f\u63a8\u9032\u5404\u9805\u5de5\u4f5c\uff0c\u5168\u529b\u4fc3\u9032\u8cc7\u672c\u5dff\u5834\u9ad8\u8cea\u91cf\u767c\u5c55\uff0c\u8b93\u5e02\u6c11\u611f\u53d7\u3001\u5206\u4eab\u6539\u9769\u5e36\u4f86\u7684\u7d05\u5229\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3904363/%E6%96%BD%E6%94%BF%E5%A0%B1%E5%91%8A%E4%B8%A8%E8%A8%B1%E6%AD%A3%E5%AE%87%3A%E8%B2%A1%E5%BA%AB%E5%B1%80%E6%9C%83%E5%A0%85%E6%8C%81%E5%AE%88%E6%AD%A3%E5%89%B5%E6%96%B0"}, {"title": "\u65bd\u653f\u5831\u544a\u4e28\u65c5\u767c\u5c40:\u5168\u529b\u914d\u5408\u63a8\u52d5\u65c5\u904a\u696d\u767c\u5c55\u63aa\u65bd", "description": "<p>\u65c5\u767c\u5c40\u4e3b\u5e2d\u5f6d\u8000\u4f73\u8868\u793a\uff0c\u6b61\u8fce\u65b0\u4e00\u4efd\u300a\u65bd\u653f\u5831\u544a\u300b\u63d0\u51fa\u591a\u9805\u63a8\u52d5\u65c5\u904a\u696d\u767c\u5c55\u7684\u63aa\u65bd\uff0c\u65c5\u767c\u5c40\u5c07\u5168\u529b\u914d\u5408\u76f8\u95dc\u5efa\u8b70\uff0c\u57f9\u80b2\u548c\u62d3\u5c55\u5177\u672c\u6e2f\u548c\u570b\u969b\u7279\u8272\u7684\u65c5\u904a\u9805\u76ee\uff0c\u4ee5\u53ca\u958b\u62d3\u591a\u5143\u5316\u7684\u5ba2\u6e90\u5e02\u5834\u7b49\uff0c\u9032\u4e00\u6b65\u63d0\u5347\u9999\u6e2f\u65c5\u904a\u696d\u7684\u7af6\u722d\u529b\u3002</p>\n<p>\u5f6d\u8000\u4f73\u8868\u793a\uff0c\u65c5\u767c\u5c40\u5c07\u7a4d\u6975\u914d\u5408\u6587\u5316\u9ad4\u80b2\u53ca\u65c5\u904a\u5c40\u4eca\u5e74\u5167\u516c\u5e03\u7684\u300a\u9999\u6e2f\u65c5\u904a\u696d\u767c\u5c55\u85cd\u57162.0\u300b\uff0c\u4ee5\u63a8\u52d5\u6587\u5316\u3001\u9ad4\u80b2\u3001\u751f\u614b\u53ca\u76db\u4e8b\u7b49\u70ba\u91cd\u9ede\u65b9\u5411\u3002\u7576\u4e2d\uff0c\u6703\u52a0\u5927\u9762\u5411\u672c\u5730\u548c\u5916\u5730\u65c5\u5ba2\uff0c\u767c\u5c55\u548c\u63a8\u5ee3\u66f4\u591a\u5177\u9999\u6e2f\u7279\u8272\u7684\u65c5\u904a\u9805\u76ee\u3002</p>\n<p>\u5c0d\u65bc\u300a\u65bd\u653f\u5831\u544a\u300b\u63d0\u51fa\u524a\u6e1b\u70c8\u9152\u7a05\uff0c\u5f6d\u8000\u4f73\u7a31\uff0c\u9019\u6709\u52a9\u9032\u4e00\u6b65\u8c50\u5bcc\u9999\u6e2f\u7684\u7f8e\u98df\u548c\u9910\u98f2\u9078\u64c7\uff0c\u4fc3\u9032\u65c5\u904a\u548c\u9ad8\u7aef\u9910\u98f2\u6d88\u8cbb\uff0c\u978f\u56fa\u9999\u6e2f\u300c\u7f8e\u98df\u4e4b\u90fd\u300d\u7684\u5730\u4f4d\u3002\u65c5\u767c\u5c40\u4ea6\u5c07\u5236\u8a02\u5168\u6e2f18\u5340\u7f8e\u98df\u6307\u5357\u3002</p>\n<p>\u5f6d\u8000\u4f73\u7e8c\u7a31\uff0c\u300a\u65bd\u653f\u5831\u544a\u300b\u63d0\u51fa\u591a\u500b\u958b\u62d3\u5ba2\u6e90\u7684\u63aa\u65bd\u3002\u5728\u958b\u62d3\u4e2d\u6771\u548c\u6771\u76df\u65c5\u5ba2\u5ba2\u6e90\u65b9\u9762\uff0c\u65c5\u767c\u5c40\u5df2\u4e00\u76f4\u63a8\u52d5\u9999\u6e2f\u6210\u70ba\u300c\u7a46\u65af\u6797\u53cb\u597d\u300d\u7684\u65c5\u904a\u76ee\u7684\u5730\uff0c\u9f13\u52f5\u548c\u5354\u52a9\u9910\u98f2\u3001\u9152\u5e97\u548c\u666f\u9ede\u7b49\u589e\u8a2d\u7a46\u65af\u6797\u53cb\u5584\u8a2d\u65bd\uff0c\u4e26\u5df2\u52a0\u5f37\u5728\u4e2d\u6771\u548c\u6771\u76df\u5e02\u5834\u7684\u5ba3\u50b3\u5de5\u4f5c\uff0c\u958b\u62d3\u65b0\u5ba2\u6e90\u3002\u300a\u65bd\u653f\u5831\u544a\u300b\u63d0\u53ca\u7279\u5340\u653f\u5e9c\u5df2\u5411\u4e2d\u592e\u653f\u5e9c\u63d0\u51fa\u6062\u5fa9\u6df1\u5733\u300c\u4e00\u7c3d\u591a\u884c\u300d\u500b\u4eba\u904a\u7c3d\u6ce8\u53ca\u64f4\u5927\u300c\u4e00\u5468\u4e00\u884c\u300d\u500b\u4eba\u904a\u7c3d\u6ce8\u653f\u7b56\u8a66\u9ede\u57ce\u5e02\u7bc4\u570d\u7b49\uff0c\u9019\u6709\u52a9\u4fbf\u5229\u76f8\u95dc\u65c5\u5ba2\u8a2a\u6e2f\uff0c\u9032\u4e00\u6b65\u63d0\u5347\u9999\u6e2f\u65c5\u904a\u696d\u7684\u7af6\u722d\u529b\u3002</p>\n<p>\u53e6\u5916\uff0c\u65c5\u767c\u5c40\u5c07\u7e7c\u7e8c\u914d\u5408\u300c\u76db\u4e8b\u7d71\u7c4c\u5354\u8abf\u7d44\u300d\uff0c\u627f\u64d4\u5927\u578b\u76db\u4e8b\u300c\u7b2c\u4e00\u7ad9\u806f\u7d61\u7a97\u53e3\u300d\u7684\u89d2\u8272\uff1b\u652f\u6301\u653f\u5e9c\u6253\u9020\u555f\u5fb7\u9ad4\u80b2\u5712\u6210\u70ba\u76db\u4e8b\u5730\u6a19\uff0c\u5e36\u52d5\u65c5\u904a\u696d\u548c\u76db\u4e8b\u7d93\u6fdf\u7684\u767c\u5c55\uff1b\u4ee5\u53ca\u52a0\u5f37\u5168\u7403\u5ba3\u50b3\uff0c\u5c07\u897f\u4e5d\u6587\u5316\u5340\u6253\u9020\u6210\u70ba\u65c5\u5ba2\u5fc5\u5230\u7684\u6587\u5275\u65c5\u904a\u5730\u6a19\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3904357/%E6%96%BD%E6%94%BF%E5%A0%B1%E5%91%8A%E4%B8%A8%E6%97%85%E7%99%BC%E5%B1%80%3A%E5%85%A8%E5%8A%9B%E9%85%8D%E5%90%88%E6%8E%A8%E5%8B%95%E6%97%85%E9%81%8A%E6%A5%AD%E7%99%BC%E5%B1%95%E6%8E%AA%E6%96%BD"}]}