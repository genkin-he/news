f\u958b\u652f\u7e3d\u984d\u70ba1.16\u842c\u5104\u7f8e\u5143\uff0c\u9996\u5ea6\u7a81\u78341\u842c\u5104\u7f8e\u5143\u9580\u6abb\uff1b\u6263\u9664\u5229\u606f\u6536\u5165\u5f8c\uff0c\u6de8\u5229\u606f\u958b\u652f\u70ba8820\u5104\u7f8e\u5143\uff0c\u662f\u958b\u652f\u4e2d\u7684\u7b2c\u4e09\u5927\u985e\u5225\uff0c\u50c5\u5c11\u904e\u793e\u6703\u798f\u5229\u53ca\u5065\u8b77\u958b\u652f\u3002</p>\n<p>\u8ca1\u653f\u90e8\u5b98\u54e1\u7a31\uff0c\u4e0a\u5e74\u5ea6\u7f8e\u570b\u570b\u50b5\u5e73\u5747\u5229\u7387\u70ba3.32\u5398\uff0c\u524d\u4e00\u5e74\u5ea6\u70ba2.97\u5398\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3907097/%E7%BE%8E%E5%9C%8B2024%E5%B9%B4%E5%BA%A6%E8%B2%A1%E8%B5%A4%E9%80%BE1.8%E8%90%AC%E5%84%84+%E6%AD%B7%E4%BE%86%E7%AC%AC%E4%B8%89%E9%AB%98"}, {"title": "\u73fe\u8ca8\u91d1\u50f9\u7834\u9802 \u5347\u8d8a2722\u7f8e\u5143", "description": "<p>\u5df4\u52d2\u65af\u5766\u6b66\u88dd\u7d44\u7e54\u54c8\u99ac\u65af\u9818\u8896\u88ab\u6bba\u5f8c\uff0c\u4e2d\u6771\u5c40\u52e2\u8b8a\u5316\u96e3\u6e2c\uff0c\u52a0\u4e0a\u7f8e\u570b\u7e3d\u7d71\u9078\u60c5\u7dca\u6e4a\uff0c\u907f\u96aa\u60c5\u7dd2\u5347\u6eab\uff0c\u73fe\u8ca8\u91d1\u50f9\u53d7\u60e0\u4e26\u9996\u5ea6\u7a81\u7834\u6bcf\u76ce\u65af2700\u7f8e\u5143\u95dc\uff0c\u518d\u5275\u4e0b\u7d00\u9304\u65b0\u9ad8\uff0c\u4e5f\u662f\u4eca\u5e74\u4ee5\u4f86\u7b2c33\u6b21\u5275\u65b0\u9ad8\u3002</p>\n<p><span style=\"font-size-ignore:13pt;\">\u73fe\u8ca8\u91d1\u6700\u9ad8\u898b\u6bcf\u76ce\u65af2722.03\u7f8e\u5143\uff0c\u5347\u5e45\u9054\u52301.07%\uff0c\u6536\u5e02\u58312721.68\u7f8e\u5143\uff0c\u4ecd\u53471.06%\uff0c</span><span style=\"font-size-ignore:13pt;\">\u672c\u5468\u7d2f\u8a08\u5347\u903e2%\u3002</span><span style=\"font-size-ignore:13pt;\">\u9280\u50f9\u6700\u591a\u53476.8%\uff0c\u5275\u4e0b2012\u5e74\u4ee5\u4f86\u6700\u9ad8\u3002\u7d10\u7d04\u671f\u91d1\u6536\u5e02\u534722.5\u7f8e\u5143\uff0c\u6bcf\u76ce\u65af\u58312730\u7f8e\u5143\u3002</span></p>\n<p>\u00a0</p>\n<p>\u54c8\u99ac\u65af\u9818\u8896\u8f9b\u74e6\u723e\u5468\u56db\u88ab\u4ee5\u8272\u5217\u8ecd\u968a\u6bba\u6b7b\u5f8c\uff0c\u7f8e\u570b\u7e3d\u7d71\u62dc\u767b\u8a8d\u70ba\uff0c\u52a0\u6c99\u6230\u4e8b\u9054\u6210\u548c\u89e3\u7684\u5e0c\u671b\u4e0a\u5347\u3002\u4e0d\u904e\uff0c\u54c8\u99ac\u65af\u6b66\u88dd\u6d3e\u7cfb\u54c8\u6851\u65c5\u5f37\u8abf\u4e0d\u6703\u9000\u7e2e\u3002\u4e2d\u6771\u5c40\u52e2\u4e0d\u78ba\u5b9a\u4ee4\u91d1\u50f9\u53d7\u60e0\u3002</p>\n<p>\u540c\u6642\uff0c\u7f8e\u570b11\u6708\u7e3d\u7d71\u9078\u60c5\u7dca\u6e4a\u4e5f\u5229\u597d\u91d1\u50f9\u3002\u5e02\u5834\u4eba\u58ebChristopher Wong\u8a8d\u70ba\uff0c\u6709\u6295\u6a5f\u8005\u62bc\u6ce8\u5171\u548c\u9ee8\u7e3d\u7d71\u5019\u9078\u4eba\u3001\u524d\u7e3d\u7d71\u7279\u6717\u666e\u7372\u52dd\uff0c\u56e0\u6b64\u589e\u6301\u9ec3\u91d1\u597d\u5009\u3002</p>\n<p>\u7f8e\u6ed9\u6307\u6578\u4e00\u5ea6\u8dcc0.35%\uff0c\u4e5f\u5229\u597d\u91d1\u50f9\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3907096/%E7%8F%BE%E8%B2%A8%E9%87%91%E5%83%B9%E7%A0%B4%E9%A0%82+%E5%8D%87%E8%B6%8A2722%E7%BE%8E%E5%85%83"}, {"title": "\u7f8e\u6cd5\u5b98\u66ab\u7de9\u8c37\u6b4cPlay Store\u6539\u9769\u4ee4", "description": "<p>\u7f8e\u570b\u6cd5\u5b98\u540c\u610f\u66ab\u7de9\u8981\u6c42\u8c37\u6b4c\u4fee\u8a02Play Store\u64cd\u4f5c\u6a21\u5f0f\u7684\u6307\u4ee4\uff0c\u76f4\u81f3\u4e0a\u8a34\u5ead\u5c0d\u8c37\u6b4c\u5c31\u53cd\u58df\u65b7\u8a34\u8a1f\u7684\u4e0a\u8a34\u4f5c\u51fa\u88c1\u6c7a\u70ba\u6b62\u3002</p>\n<p>\u4e09\u85e9\u5e02\u5730\u65b9\u6cd5\u9662\u6cd5\u5b98James Donato\u5468\u4e94\u540c\u610f\u8c37\u6b4c\u63d0\u51fa\u7684\u8a34\u6c42\uff0c\u6279\u51c6\u4e86\u66ab\u7de9\u57f7\u884c\u4ed6\u5728\u5169\u5468\u524d\u4e0b\u9054\u3001\u6709\u95dc\u8c37\u6b4c\u9808\u65bc11\u67081\u65e5\u524d\u3001\u6309\u7167\u5224\u6c7a\u66f8\u4fee\u8a02Play Store\u64cd\u4f5c\u6a21\u5f0f\u7684\u547d\u4ee4\u3002</p>\n<p>\u8c37\u6b4c\u5df2\u5c31\u76f8\u95dc\u88c1\u6c7a\u5411\u7b2c\u4e5d\u5de1\u8ff4\u4e0a\u8a34\u6cd5\u9662\u63d0\u51fa\u4e0a\u8a34\uff0c\u8981\u6c42Donato\u9812\u4ee4\u66ab\u7de9\u57f7\u884c\u6307\u4ee4\u3002</p>\n<p>Donato\u8a8d\u70ba\uff0c\u4e0d\u8a8d\u70ba\u4e0a\u8a34\u6cd5\u9662\u6703\u63a8\u7ffb\u4ed6\u7684\u88c1\u6c7a\uff0c\u4f46\u540c\u610f\u61c9\u7d66\u4e88\u4e0a\u8a34\u6cd5\u9662\u4f5c\u6c7a\u5b9a\u3002</p>\n<p>\u8c37\u6b4c\u6b61\u8fceDonato\u7684\u6700\u65b0\u6c7a\u5b9a\u3002\u6700\u521d\u5165\u7a1f\u6307\u63a7\u8c37\u6b4c\u7684Epic\u62d2\u8a55\u6709\u95dc\u6d88\u606f\u3002</p>\n<p>\u5916\u754c\u4f30\u8a08\uff0c\u4e0a\u8a34\u6cd5\u9662\u53ef\u80fd\u9808\u82b1\u4e00\u5e74\u6216\u66f4\u9577\u6642\u9593\uff0c\u624d\u80fd\u5c31\u6709\u95dc\u4e0a\u8a34\u4f5c\u6c7a\u5b9a\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3907095/%E7%BE%8E%E6%B3%95%E5%AE%98%E6%9A%AB%E7%B7%A9%E8%B0%B7%E6%AD%8CPlay+Store%E6%94%B9%E9%9D%A9%E4%BB%A4"}, {"title": "\u7d10\u6cb9\u50f9\u683c\u6536\u5e02\u8dcc2.05% \u672c\u5468\u903e\u632b8%", "description": "<p>\u4ee5\u8272\u5217\u6bba\u6b7b\u5df4\u52d2\u65af\u5766\u6b66\u88dd\u7d44\u7e54\u54c8\u99ac\u65af\u9818\u8896\u5f8c\uff0c\u4ea4\u6613\u5546\u89c0\u671b\u4e2d\u6771\u5c40\u52e2\u8b8a\u5316\uff0c\u540c\u6642\u770b\u6de1\u4e2d\u570b\u7d93\u6fdf\u524d\u666f\u3002\u570b\u969b\u6cb9\u50f9\u5468\u4e94\u504f\u8edf\uff0c\u672c\u5468\u8dcc\u5e45\u5275\u4e0b\u5169\u500b\u6708\u4ee5\u4f86\u6700\u5927\u3002</p>\n<p>\u7d10\u7d04\u671f\u6cb9\u6536\u5e02\u8dcc1.45\u7f8e\u5143\u62162.05%\uff0c\u6bcf\u6876\u583169.22\u7f8e\u5143\uff0c\u672c\u5468\u7d2f\u8a08\u632b8.4%\uff0c\u662f9\u67082\u65e5\u4ee5\u4f86\u6700\u5927\u55ae\u5468\u8dcc\u5e45\u3002\u502b\u6566\u5e03\u862d\u7279\u671f\u6cb9\u6536\u5e02\u8dcc1.39\u7f8e\u5143\u62161.87%\uff0c\u6bcf\u6876\u583173.06\u7f8e\u5143\uff0c\u672c\u5468\u7d2f\u8a08\u632b6.9%\u3002</p>\n<p>Again Capital\u5408\u5925\u4ebaJohn Kilduff\u8868\u793a\uff0c\u4e2d\u570b\u516c\u5e03\u7684\u7b2c\u4e09\u5b63\u7d93\u6fdf\u589e\u95774.6%\uff0c\u5e02\u5834\u64d4\u5fc3\u5317\u4eac\u653f\u5e9c\u7121\u529b\u89e3\u6c7a\u7d93\u6fdf\u56f0\u5883\uff0c\u539f\u6cb9\u9700\u6c42\u4ea6\u51fa\u73fe\u75b2\u614b\uff0c\u570b\u969b\u6cb9\u50f9\u56e0\u6b64\u53d7\u58d3\u3002\u540c\u6642\uff0c\u4e2d\u570b\u96fb\u52d5\u8eca\u92b7\u552e\u826f\u597d\uff0c\u4e5f\u9593\u63a5\u5c0d\u6cb9\u50f9\u4e0d\u5229\u3002</p>\n<p>\u54c8\u99ac\u65af\u9818\u8896\u8f9b\u74e6\u723e\u88ab\u6bba\u5f8c\uff0c\u7f8e\u570b\u7e3d\u7d71\u62dc\u767b\u8a8d\u70ba\uff0c\u52a0\u6c99\u6230\u4e8b\u6709\u671b\u505c\u6b62\u3002Kilduff\u6307\u51fa\uff0c\u6230\u722d\u6ea2\u50f9\u6536\u7e2e\uff0c\u4ee4\u5230\u6cb9\u50f9\u8f03\u5f31\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3907094/%E7%B4%90%E6%B2%B9%E5%83%B9%E6%A0%BC%E6%94%B6%E5%B8%82%E8%B7%8C2.05%25+%E6%9C%AC%E5%91%A8%E9%80%BE%E6%8C%AB8%25"}]}