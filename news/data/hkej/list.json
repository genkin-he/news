5c0d\u7e3d\u7d71\u5c39\u932b\u6085\u7684\u5f48\u52be\u6848\uff0c\u5c07\u65bc\u5468\u56db(12\u65e5)\u5448\u5831\u81f3\u570b\u6703\u5168\u9ad4\u6703\u8b70\uff0c\u4e26\u65bc\u5468\u516d(14\u65e5)\u8868\u6c7a\u3002</p>\n<p>\u5171\u540c\u6c11\u4e3b\u9ee8\u570b\u6703\u767c\u8a00\u4eba\u59dc\u7531\u6968\u8868\u793a\uff0c\u6c11\u4e3b\u9ee8\u9084\u5c07\u5728\u5468\u4e8c(10\u65e5)\u8209\u884c\u7684\u570b\u6703\u5168\u9ad4\u6703\u8b70\u4e0a\uff0c\u5c31\u4e0a\u5468\u7dca\u6025\u6212\u56b4\u4e8b\u4ef6\uff0c\u53e6\u884c\u5f48\u52be\u6cd5\u52d9\u90e8\u9577\u6734\u6027\u8f09\u548c\u8b66\u5bdf\u5ef3\u5ef3\u9577\u8d99\u5fd7\u6d69\uff0c\u4e26\u5728\u5468\u56db\u8209\u884c\u7684\u570b\u6703\u81e8\u6642\u6703\u8b70\u9996\u6b21\u5168\u6703\u4e0a\uff0c\u8868\u6c7a\u8a72\u5f48\u52be\u6848\u3002</p>\n<p>\u53e6\u5916\uff0c\u6c11\u4e3b\u9ee8\u5c07\u65bc\u4eca\u65e5\u767c\u8d77\u67e5\u660e\u6212\u56b4\u4e8b\u4ef6\u771f\u76f8\u7684\u300c\u5167\u4e82\u7368\u6aa2\u6cd5\u300d\uff0c\u548c\u91dd\u5c0d\u7b2c\u4e00\u592b\u4eba\u7684\u300c\u91d1\u5efa\u5e0c\u7368\u6aa2\u6cd5\u300d\u3002\u59dc\u7531\u6968\u8868\u793a\uff0c\u82e5\u9019\u5169\u9805\u6cd5\u6848\u80fd\u7372\u5f97\u5feb\u901f\u8655\u7406\uff0c\u53ef\u4ee5\u5728\u5468\u56db\u7684\u5168\u9ad4\u6703\u8b70\u4e0a\u8868\u6c7a\u3002</p>\n<p>\u5357\u97d3\u570b\u6703\u4e0a\u5468\u516d(7\u65e5)\u8868\u6c7a\u5f48\u52be\u7e3d\u7d71\u5c39\u932b\u6085\u52d5\u8b70\uff0c\u56e0\u57f7\u653f\u570b\u6c11\u529b\u91cf\u9ee8\u5927\u90e8\u5206\u8b70\u54e1\u96e2\u5834\u676f\u845b\uff0c\u4ee4\u6295\u8d0a\u6210\u7968\u672a\u80fd\u901a\u904e\u4e09\u5206\u4e4b\u4e8c\u7684\u9580\u6abb\u3002\u57f7\u653f\u9ee8\u570b\u6c11\u529b\u91cf\u9ee8\u5ba3\u5e03\uff0c\u5c39\u932b\u6085\u653e\u68c4\u57f7\u638c\u5305\u62ec\u5916\u4ea4\u7b49\u570b\u653f\uff0c\u6539\u7531\u7e3d\u7406\u97d3\u5fb7\u6d19\u8207\u8a72\u9ee8\u5354\u5546\u8655\u7406\uff0c\u4ee5\u4fbf\u8b93\u5c39\u932b\u6085\u6709\u5e8f\u63d0\u65e9\u4e0b\u53f0\u3002</p>\n<p>\u5171\u540c\u6c11\u4e3b\u9ee8\u5176\u5f8c\u5f37\u8abf\