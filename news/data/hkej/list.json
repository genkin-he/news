07\u6578\u958b\u5e02\u58313416\u9ede\uff0c\u8dcc6\u9ede\u62160.19%\uff1b\u73fe\u58313429\u9ede\uff0c\u53477\u9ede\u62160.21%\u3002</p>\n<p>\u6df1\u6210\u6307\u958b\u5e02\u583110781\u9ede\uff0c\u8dcc31\u9ede\u62160.29%\uff1b\u73fe\u583110826\u9ede\uff0c\u534714\u9ede\u62160.13%\u3002</p>\n<p>\u6eec\u6df1300\u6307\u6578\u958b\u5e02\u58313988\u9ede\uff0c\u8dcc7\u9ede\u62160.19%\uff1b\u73fe\u58313998\u9ede\uff0c\u53472\u9ede\u62160.07%\u3002</p>\n<p>\u5275\u696d\u677f\u6307\u6578\u958b\u5e02\u58312260\u9ede\uff0c\u8dcc3\u9ede\u62160.15%\uff1b\u73fe\u58312265\u9ede\uff0c\u53471\u9ede\u62160.07%\u3002</p>\n<p>\u5404\u677f\u584a\u500b\u5225\u767c\u5c55\uff0c\u50b3\u5a92\u5a1b\u6a02\u80a1\u5347\u8fd11%\uff1b\u92fc\u9435\u3001\u623f\u5730\u7522\u3001\u5316\u5de5\u3001\u6709\u8272\u91d1\u5c6c\u3001\u7164\u70ad\u3001\u6c34\u6ce5\u3001\u96fb\u529b\u3001\u6c7d\u8eca\u88fd\u9020\u80a1\u9760\u7a69\uff1b\u77f3\u6cb9\u3001\u91d1\u878d\u80a1\u504f\u8edf\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/china/article/3951696/A%E8%82%A1%E9%96%8B%E5%B8%82%E5%88%9D%E6%AE%B5%E9%9D%A0%E7%A9%A9+%E8%A7%80%E6%9C%9B%E4%B8%AD%E5%A4%AE%E7%B6%93%E6%BF%9F%E5%B7%A5%E4%BD%9C%E6%9C%83%E8%AD%B0"}, {"title": "\u62dc\u767b\u50b3\u7981\u65e5\u672c\u88fd\u9435\u6536\u8cfc\u7f8e\u570b\u92fc\u9435", "description": "<p><span style=\"font-size-ignore:13pt;\">\u5916\u96fb\u5831\u9053\uff0c\u7f8e\u570b\u7e3d\u7d71\u62dc\u767b\u653f\u5e9c\u5c07\u6b63\u5f0f\u963b\u6b62\u65e5\u672c\u88fd\u9435(Nippon Steel)\u6536\u8cfc\u7f8e\u570b\u92fc\u9435(U.S. Steel)\u7684\u4ea4\u6613\u3002\u6d88\u606f\u66dd\u5149\u5f8c\uff0c\u7f8e\u92fc\u80a1\u50f9\u6700\u591a\u4e0b\u6ed122%\uff0c\u6536\u5e02\u8dcc9.7%\u3002</span></p>\n<p>\u5831\u9053\u5f15\u8ff0\u6d88\u606f\u4eba\u58eb\u7a31\uff0c\u62dc\u767b\u5c07\u4ee5\u570b\u5bb6\u5b89\u5168\u70ba\u7531\uff0c\u7981\u6b62\u5169\u9593\u7e7c\u7e8c\u9032\u884c\u8a72\u5b97\u6d89\u53ca\u8cc7\u91d1141\u5104\u7f8e\u5143\u7684\u4ea4\u6613\u3002</p>\n<p>\u6839\u64da\u96d9\u65b9\u6709\u95dc\u4ea4\u6613\u689d\u6b3e\uff0c\u4ea4\u6613\u9808\u5f97\u5230\u7f8e\u570b\u8ca1\u653f\u90e8\u65d7\u4e0b\u5916\u570b\u6295\u8cc7\u59d4\u54e1\u6703(CFIUS)\u6279\u51c6\u3002\u9664\u975e\u5ef6\u671f\uff0cCFIUS\u6700\u9072\u65bc12\u670822\u65e5\u9808\u6b63\u5f0f\u5c31\u7533\u8acb\u4f5c\u51fa\u6c7a\u5b9a\uff0c\u800c\u62dc\u767b\u662f\u6700\u7d42\u6c7a\u5b9a\u8005\u3002</p>\n<p>\u6d88\u606f\u4eba\u58eb\u6307\u51fa\uff0c\u81f3\u5c11\u4e00\u540dCFIUS\u6210\u54e1\u8a8d\u70ba\uff0c\u4ea4\u6613\u5b58\u5728\u570b\u5b89\u98a8\u96aa\uff0c\u4e26\u5efa\u8b70\u62dc\u767b\u5426\u6c7a\u6709\u95dc\u7533\u8acb\u3002\u66ab\u6642\u4e0d\u6e05\u695aCFIUS\u5728\u516c\u5e03\u6c7a\u5b9a\u6642\u6703\u4f5c\u51fa\u7684\u89e3\u91cb\u3002</p>\n<p>\u62dc\u767b\u53ca\u7f8e\u570b\u5019\u4efb\u7e3d\u7d71\u7279\u6717\u666e\u5747\u65e9\u5df2\u8868\u660e\uff0c\u4e0d\u652f\u6301\u76f8\u95dc\u4ea4\u6613\u3002\u767d\u5bae\u767c\u8a00\u4eba\u56de\u61c9\u7a31\uff0c\u62dc\u767b\u7acb\u5834\u5f88\u660e\u78ba\uff0c\u4fbf\u662f\u5e0c\u671b\u7f8e\u92fc\u662f\u5728\u7f8e\u570b\u4eba\u624b\u4e0a\u3002</p>\n<p>\u7f8e\u92fc\u767c\u8a00\u4eba\u56de\u61c9\u7a31\uff0c\u5e0c\u671b\u653f\u5e9c\u6279\u51c6\u76f8\u95dc\u4ea4\u6613\u3002\u65e5\u672c\u88fd\u9435\u767c\u8868\u8072\u660e\uff0c\u8a8d\u70ba\u4ea4\u6613\u53d7\u5230\u653f\u6cbb\u5f71\u97ff\u611f\u5230\u4e0d\u5408\u9069\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/international/article/3951701/%E6%8B%9C%E7%99%BB%E5%82%B3%E7%A6%81%E6%97%A5%E6%9C%AC%E8%A3%BD%E9%90%B5%E6%94%B6%E8%B3%BC%E7%BE%8E%E5%9C%8B%E9%8B%BC%E9%90%B5"}, {"title": "\u3010\u7570\u52d5\u80a1\u3011\u5546\u6e6f\u5b88\u914d\u80a1\u50f9 \u73fe\u632b\u8fd12% ", "description": "<p>\u5546\u6e6f(<a target='_blank' href='https://stock360.hkej.com/quotePlus/00020' >00020</a>)\u6298\u8b936%\u914d\u80a1\uff0c\u80a1\u50f9\u4eca\u65e9\u9006\u5e02\u4e0b\u8dcc\uff0c\u4e00\u5ea6\u4f4e\u898b1.54\u5143\uff0c\u8dcc3.8%\uff0c\u65b0\u90201.57\u5143\uff0c\u4ecd\u964d1.9%\uff0c\u6210\