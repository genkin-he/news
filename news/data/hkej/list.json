0.001\u5398\uff0c20\u842c\u81f3100\u842c\u5143\u70ba0.275\u5398\uff0c100\u842c\u81f3500\u842c\u5143\u70ba0.325\u5398\uff0c500\u842c\u5143\u6216\u4ee5\u4e0a\u70ba0.5\u5398\uff0c\u7f8e\u5143\u57fa\u672c\u5132\u84c4\u5b58\u6b3e\u5e74\u5229\u7387\u70ba0.001\u5398\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3906298/%E5%AE%9A%E5%AD%98%E5%88%A9%E7%8E%87%E4%B8%A8%E6%98%9F%E5%B1%95e%24aver%E7%BE%8E%E5%85%83%E6%B4%BB%E6%9C%9F%E6%81%AF%E8%A6%8B4.8%E5%8E%98+%E6%B8%AF%E5%85%83%E4%BA%A6%E6%9C%894%E5%8E%98"}, {"title": "\u65bd\u653f\u5831\u544a\uff5c\u5353\u6c38\u8208:\u672c\u6e2f\u65c5\u904a\u8cc7\u6e90\u8c50\u5bcc \u9808\u63a8\u9673\u51fa\u65b0\u5438\u5ba2\u7559\u5ba2", "description": "<p>\u65b0\u4e00\u4efd\u300a\u65bd\u653f\u5831\u544a\u300b\u63d0\u51fa\u6210\u7acb\u300c\u767c\u5c55\u65c5\u904a\u71b1\u9ede\u5de5\u4f5c\u7d44\u300d\u53ca\u300c\u4fc3\u9032\u9280\u9aee\u7d93\u6fdf\u5de5\u4f5c\u7d44\u300d\uff0c\u7531\u653f\u52d9\u53f8\u526f\u53f8\u9577\u5353\u6c38\u8208\u51fa\u4efb\u7d44\u9577\u3002</p>\n<p>\u5353\u6c38\u8208\u5728\u8a18\u8005\u6703\u8868\u793a\uff0c\u300c\u767c\u5c55\u65c5\u904a\u71b1\u9ede\u5de5\u4f5c\u7d44\u300d\u8ca0\u8cac\u7763\u5c0e\u53ca\u7d71\u7c4c\u8de8\u90e8\u9580\u5354\u4f5c\u9805\u76ee\uff0c\u6587\u5316\u9ad4\u80b2\u53ca\u65c5\u904a\u5c40\u5c40\u9577\u694a\u6f64\u96c4\u51fa\u4efb\u526f\u7d44\u9577\uff0c\u5f37\u8abf\u672c\u6e2f\u65c5\u904a\u8cc7\u6e90\u8c50\u5bcc\uff0c\u4f46\u8981\u63a8\u9673\u51fa\u65b0\uff0c\u624d\u53ef\u5438\u65b0\u5ba2\u3001\u7559\u820a\u5ba2\u3002</p>\n<p>\u5c31\u5de5\u4f5c\u7d44\u8207\u6587\u9ad4\u65c5\u5c40\u7684\u5206\u5de5\uff0c\u5353\u6c38\u8208\u6307\u5de5\u4f5c\u7d44\u7531\u53f8\u9577\u9818\u5c0e\uff0c\u80fd\u63d0\u901f\u63d0\u6548\uff0c\u5168\u76e4\u5be9\u8996\uff0c\u5feb\u901f\u4f5c\u51fa\u6c7a\u5b9a\uff0c\u63d0\u51fa\u65b0\u65b9\u6cd5\uff0c\u6548\u679c\u6703\u66f4\u597d\uff0c\u76f8\u95dc\u5de5\u4f5c\u7d44\u6703\u5728\u5e74\u5e95\u524d\u958b\u5c55\u5de5\u4f5c\uff0c\u9810\u8a08\u660e\u5e74\u4e0a\u534a\u5e74\u7d71\u7c4c\u76f8\u95dc\u653f\u7b56\u5c40\u7684\u91cd\u9ede\u5de5\u4f5c\u3002</p>\n<p>\u81f3\u65bc\u300c\u4fc3\u9032\u9280\u9aee\u7d93\u6fdf\u5de5\u4f5c\u7d44\u300d\uff0c\u5353\u6c38\u8208\u6307\u540c\u6a23\u6703\u5728\u5e74\u5e95\u524d\u958b\u7b2c\u4e00\u6b21\u6703\uff0c\u660e\u5e74\u4e0a\u534a\u5e74\u5236\u8a02\u63a8\u9032\u9805\u76ee\u63aa\u65bd\u4ee5\u53ca\u5177\u9ad4\u5de5\u4f5c\u8a08\u5283\u3002</p>\n<p>\u5546\u52d9\u53ca\u7d93\u6fdf\u767c\u5c55\u5c40\u5c40\u9577\u4e18\u61c9\u6a3a\u8868\u793a\uff0c\u300c\u4fc3\u9032\u9280\u9aee\u7d93\u6fdf\u5de5\u4f5c\u7d44\u300d\u5c07\u5728\u5e7e\u65b9\u9762\u63a8\u51fa\u63aa\u65bd\uff0c\u5305\u62ec\u4fc3\u9032\u9577\u8005\u6d88\u8cbb\uff0c\u52a0\u5165\u9280\u9aee\u5143\u7d20\uff1b\u63a8\u52d5\u6a02\u9f61\u7522\u696d\uff1b\u63a8\u5ee3\u9280\u8272\u8ca1\u52d9\uff0c\u63a8\u5ee3\u9000\u4f11\u7406\u8ca1\u7522\u54c1\u53ca\u6295\u8cc7\u6559\u80b2\uff1b\u9280\u8272\u751f\u7522\u529b\uff0c\u91cb\u653e\u9577\u8005\u751f\u7522\u529b\u3002</p>\n<p>\u4e18\u61c9\u6a3a\u6307\u51fa\uff0c\u6309\u4eba\u53e3\u6bd4\u4f8b\u63a8\u7b97\uff0c\u52302046\u5e74\uff0c\u6bcf3\u540d\u6e2f\u4eba\u6703\u67091\u4eba\u662f\u9577\u8005\uff0c\u9577\u8005\u5c07\u662f\u9f90\u5927\u7684\u6d88\u8cbb\u7fa4\uff0c\u5de5\u4f5c\u7d44\u5e74\u5e95\u6703\u5354\u8abf\u5404\u653f\u7b56\u7684\u5de5\u4f5c\u8a08\u5283\uff0c\u5b9a\u671f\u6aa2\u8996\u9032\u5ea6\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/current/article/3906506/%E6%96%BD%E6%94%BF%E5%A0%B1%E5%91%8A%EF%BD%9C%E5%8D%93%E6%B0%B8%E8%88%88%3A%E6%9C%AC%E6%B8%AF%E6%97%85%E9%81%8A%E8%B3%87%E6%BA%90%E8%B1%90%E5%AF%8C+%E9%A0%88%E6%8E%A8%E9%99%B3%E5%87%BA%E6%96%B0%E5%90%B8%E5%AE%A2%E7%95%99%E5%AE%A2"}, {"title": "PayMe\u9280\u806f\u865b\u64ec\u5361\u5169\u6210\u6d3b\u8e8d\u7528\u6236\u5df2\u555f\u7528 \u4e3b\u8981\u5167\u5730\u65e5\u672c\u6d88\u8cbb", "description": "<p>PayMe by HSBC\u8868\u793a\uff0c\u9280\u806f\u865b\u64ec\u5361\u63a8\u51fa\u50c5\u5169\u500b\u6708\uff0c\u5df2\u7372\u4e94\u5206\u4e00\u6d3b\u8e8d\u7528\u6236\u555f\u7528\u65b0\u5361\uff0c\u4e26\u5f97\u4ee5\u6210\u529f\u62d3\u5c55\u81f3\u5305\u62ec\u5167\u5730\u7b49\u5168\u740346\u500b\u5e02\u5834\u3002\u73fe\u6642PayMe\u5df2\u8986\u84cb\u5168\u7403\u8d85\u904e3800\u842c\u9593\u5546\u6236\uff0c\u865b\u64ec\u5361\u5ba2\u6236\u4e3b\u8981\u6d88\u8cbb\u5e02\u5834\u5305\u62ec\u5167\u5730\u3001\u97d3\u570b\u53ca\u65e5\u672c\u3002</p>\n<p>\u6ed9\u8c50PayMe\u4e3b\u7ba1\u937e\u67cf\u5fb7(Brad Jones)\u4eca\u65e5\u548c\u9280\u806f\u570b\u969b\u5171\u540c\u8209\u8fa6\u6176\u795d\u6d3b\u52d5\uff0c\u4e26\u6307PayMe\u548c\u9280\u806f\u570b\u969b\u5408\u4f5c\uff0c\u6b63\u9ad4\u73fe\u81f4\u529b\u5be6\u8e10\u74b0\u7403\u9280\u884c\u670d\u52d9\u627f\u8afe\u3002\u9019\u6b21\u91cc\u7a0b\u7891\u5c07\u9f13\u52f5\u5c07\u5728\u9999\u6e2f\u53ca\u5168\u7403\u5404\u5730\u7121\u73fe\u91d1\u652f\u4ed8\u767c\u5c55\u52a0\u901f\u4e0b\uff0c\u7e7c\u7e8c\u70ba\u7528\u6236\u5e36\u4f86\u7121\u7e2b\u4fbf\u6377\u7684\u652f\u4ed8\u9ad4\u9a57\u3002</p>\n<p>\u9280\u806f\u570b\u969b\u9996\u5e2d\u57f7\u884c\u5b98\u517c\u526f\u8463\u4e8b\u9577\u738b\u7acb\u65b0\u6307\u51fa\uff0c\u6b64\u6b21\u767c\u5e03\u4e0d\u50c5\u6a19\u8a8c\u96d9\u65b9\u5408\u4f5c\u4e2d\u4e00\u500b\u91cc\u7a0b\u7891\uff0c\u4e5f\u5c55\u793a\u6578\u78bc\u652f\u4ed8\u9818\u57df\u5275\u65b0\u548c\u4e92\u806f\u4e92\u901a\u7684\u529b\u91cf\u3002\u9280\u806f\u8207PayMe\u7684\u5408\u4f5c\u8b49\u660e\u96d9\u8d0f\u5925\u4f34\u95dc\u4fc2\uff0c\u85c9\u5f7c\u6b64\u512a\u52e2\u5275\u9020\u50f9\u503c\u4e26\u64f4\u5927\u96d9\u65b9\u5e02\u5834\u7bc4\u570d\u3002</p>\n<p>\u53e6\u5916\uff0c\u70ba\u56de\u994b\u7528\u6236\uff0cPayMe\u5c07\u984d\u5916\u52a0\u78bc\u5ba2\u6236\u56de\u8d08\u734e\u8cde\uff0c\u4e26\u5ef6\u9577\u6d3b\u52d5\u63a8\u5ee3\u671f\u81f3\u4eca\u5e7412\u670831\u65e5\u3002\u5373\u65e5\u8d77\u81f3\u5e74\u5e95\uff0c\u4f7f\u7528\u9280\u806f\u865b\u64ec\u5361\u5728\u5167\u5730\u6d88\u8cbb\u6eff88\u5143\u4eba\u6c11\u5e63\u6216\u4ee5\u4e0a\uff0c\u6bcf\u7b46\u4ea4\u6613\u53ef\u73728\u6e2f\u5143\u56de\u8d08\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/hongkong/article/3906504/PayMe%E9%8A%80%E8%81%AF%E8%99%9B%E6%93%AC%E5%8D%A1%E5%85%A9%E6%88%90%E6%B4%BB%E8%BA%8D%E7%94%A8%E6%88%B6%E5%B7%B2%E5%95%9F%E7%94%A8+%E4%B8%BB%E8%A6%81%E5%85%A7%E5%9C%B0%E6%97%A5%E6%9C%AC%E6%B6%88%E8%B2%BB"}, {"title": "\u73fe\u5d07\u5c71\u55ae\u865f\u8eca\u4f4d190\u842c\u6210\u4ea4", "description": "<p>\u9ec3\u5927\u4ed9\u73fe\u5d07\u5c714\u6a13\u55ae\u865f\u8eca\u4f4d\uff0c\u6210\u4ea4\u50f9190\u842c\u5143\u3002</p>\n<p>\u5229\u5609\u95a3\u5730\u7522\u8868\u793a\uff0c\u65b0\u8cb7\u5bb6\u56e0\u6709\u81ea\u7528\u9700\u8981\uff0c\u4ee5\u53ca\u8a8d\u70ba\u8eca\u4f4d\u6709\u50f9\u6709\u5e02\uff0c\u800c\u653e\u76e4\u8eca\u4f4d\u4f4d\u7f6e\u65b9\u4fbf\u51fa\u5165\uff1b\u52a0\u4e0a\u539f\u696d\u4e3b\u958b\u50f9\u5408\u7406\uff0c\u6700\u5f8c\u843d\u5be6\u4ee5190\u842c\u5143\u6210\u4ea4\u3002</p>\n<p>\u64da\u6089\uff0c\u539f\u696d\u4e3b\u65bc2017\u5e74\u4ee5\u7d04185\u842c\u5143\u8cfc\u5165\u8eca\u4f4d\uff0c\u6301\u8ca8\u81f3\u4eca\u8f49\u624b\uff0c\u8cec\u9762\u8cfa5\u842c\u5143\u62162.7%\u3002</p>   </div>\n        ", "link": "https://www2.hkej.com/instantnews/property/article/3906294/%E7%8F%BE%E5%B4%87%E5%B1%B1%E5%96%AE%E8%99%9F%E8%BB%8A%E4%BD%8D190%E8%90%AC%E6%88%90%E4%BA%A4"}]}