0/0x0/100/none/6ebb6d0889efbbcfbe03fe7d38803455/2025-02/8_0_3.jpeg\" typeof=\"foaf:Image\" width=\"100%\"/>\n</div>\n</div>\n<div class=\"media-library-item__attributes\">\n<div class=\"media-library-item__name\">\n        大埔運頭塘邨男子墮平台亡 同日同位置37歲婦墜樓不治  二人疑為夫妻。黎志偉攝\n      </div>\n</div>\n</article>\n<article class=\"align-center\">\n<div class=\"media-library-item__preview js-media-library-item-preview\">\n<div class=\"field field--name-thumbnail field--type-image field--label-hidden field__item\" data-quickedit-field-id=\"media/4091860/thumbnail/zh-hant/media_library\"> <img alt=\"黎志偉攝\" class=\"image-style-medium\" src=\"https://image.hkhl.hk/f/1024p0/0x0/100/none/3d7f0a4413684a4935cd0a8cef18cdf5/2025-02/Screenshot_2025-02-19_at_5_37_10_PM.png\" typeof=\"foaf:Image\" width=\"100%\"/>\n</div>\n</div>\n<div class=\"media-library-item__attributes\">\n<div class=\"media-library-item__name\">\n        黎志偉攝\n      </div>\n</div>\n</article>\n<article class=\"align-center\">\n<div class=\"media-library-item__preview js-media-library-item-preview\">\n<div class=\"field field--name-thumbnail field--type-image field--label-hidden field__item\" data-quickedit-field-id=\"media/4091861/thumbnail/zh-hant/media_library\"> <img class=\"image-style-medium\" src=\"https://image.hkhl.hk/f/1024p0/0x0/100/none/c13209cbaafd3fea9f05d79a90a5e13d/2025-02/17_2.jpeg\" typeof=\"foaf:Image\" width=\"100%\"/>\n</div>\n</div>\n<div class=\"media-library-item__attributes\">\n<div class=\"media-library-item__name\">\n</div>\n</div>\n</article>\n<article class=\"align-center\">\n<div class=\"media-library-item__preview js-media-library-item-preview\">\n<div class=\"field field--name-thumbnail field--type-image field--label-hidden field__item\" data-quickedit-field-id=\"media/4091862/thumbnail/zh-hant/media_library\"> <img class=\"image-style-medium\" src=\"https://image.hkhl.hk/f/1024p0/0x0/100/none/263b388d925c50105768474308c452f9/2025-02/3_28.jpeg\" typeof=\"foaf:Image\" width=\"100%\"/>\n</div>\n</div>\n<div class=\"media-library-item__attributes\">\n<div class=\"media-library-item__name\">\n</div>\n</div>\n</article>\n</p>\n<p>男子墮樓位置遺下一灘鮮血，旁邊有一灘已封乾的血迹，正在女子倒斃的位置。\n\n</p>\n<p>周三（19日）凌晨零時許，女子跌落大廈簷篷後昏迷不醒，消防及救護員接報趕至現場，攀上簷篷為女事主進行檢查，惟證實她當場不治。\n\n</p>\n<p>據悉，懷疑女事主墮樓時，壓中大廈外牆的喉管，懷疑有氣體洩漏，消防及工程人員立即協助將氣喉大掣關上，並進行檢查及維修。\n\n</p>\n<p>警方接手調查，初步相信女死者生前有情緒病記錄。\n\n</p>\n<p> \n\n\n\n</p>\n<div class=\"in-article-banner\">\n<div class=\"mx-auto web\" data-slot=\"inarticlebanner,2,1\" id=\"inarticlebanner2\"></div>\n<div class=\"mx-auto mweb\" data-slot=\"inarticlebanner,2,2\" id=\"inarticlebanner2-MWeb\"></div>\n</div>\n</div>",
