ld-id=\"media/4186232/thumbnail/zh-hant/media_library\"> <img alt=\"政府指行政長官從未作出相關言論，忠告市民提防受騙。資料圖片\" class=\"image-style-medium\" src=\"https://image.hkhl.hk/f/1024p0/0x0/100/none/6ce137b71462d14ea10a8e7f06637cef/2025-04/DNSA0517TAMAR001.jpg\" typeof=\"foaf:Image\" width=\"100%\"/>\n</div>\n</div>\n<div class=\"media-library-item__attributes\">\n<div class=\"media-library-item__name\">\n        政府指行政長官從未作出相關言論，忠告市民提防受騙。資料圖片\n      </div>\n</div>\n</article>\n</p>\n<div class=\"in-article-banner\">\n<div class=\"mx-auto web\" data-slot=\"inarticlebanner,2,1\" id=\"inarticlebanner2\"></div>\n<div class=\"mx-auto mweb\" data-slot=\"inarticlebanner,2,2\" id=\"inarticlebanner2-MWeb\"></div>\n</div>\n</div>",
