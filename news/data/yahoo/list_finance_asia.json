            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"214\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/bOtWAQ7rvmBIJ6hAiNCD2A--/YXBwaWQ9aGlnaGxhbmRlcjt3PTcwNTtoPTM5Nw--/https://media.zenfs.com/ko/cnyes_hk_559/d4d59484fb843d974b6e63fc5389719b\" width=\"380\"/></div></figure></div>",
            "link": "https://hk.news.yahoo.com/%E7%BE%8E%E4%BC%8A%E8%A1%9D%E7%AA%81%E6%81%90%E6%95%B8%E6%97%A5%E5%85%A7%E5%86%8D%E7%88%86%E7%99%BC-%E5%B7%9D%E6%99%AE%E7%B7%8A%E6%80%A5%E5%8F%AC%E9%96%8B%E7%99%BD%E5%AE%AE%E6%88%B0%E6%83%85%E5%AE%A4%E6%9C%83%E8%AD%B0-%E8%8D%B7%E5%A7%86%E8%8C%B2%E6%B5%B7%E5%B3%BD%E5%8D%B1%E6%A9%9F%E5%8D%87%E6%BA%AB-060008046.html",
