            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit\"><img alt=\"\" class=\"rounded-lg\" height=\"214\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/JkKzUcrLgRKq.LdvTqomdQ--/YXBwaWQ9aGlnaGxhbmRlcjt3PTcwNTtoPTM5Nw--/https://media.zenfs.com/zh-tw/cnyes_hk_559/d89ec956a5cc38da20689cb67a59a963\" width=\"380\"/></div></figure></div>",
