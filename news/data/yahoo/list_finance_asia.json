            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"214\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/nBip2aMB1S8YZL7oU986lA--/YXBwaWQ9aGlnaGxhbmRlcjt3PTcwNTtoPTM5Nw--/https://media.zenfs.com/ko/cnyes_hk_559/cc33c9b7428ecdd674602e1a3dea1225\" width=\"380\"/></div></figure></div>",
            "link": "https://hk.news.yahoo.com/%E5%85%A8%E5%9C%8B%E9%9B%BB%E5%8F%97%E5%85%A7%E9%9C%80%E7%96%B2%E5%BC%B1%E5%BD%B1%E9%9F%BF%E4%B8%8A%E5%8D%8A%E5%B9%B4%E7%87%9F%E9%81%8B%E4%BF%9D%E5%AE%88%E7%9C%8B%E5%BE%85-%E7%9C%8B%E5%A5%BD%E7%AF%80%E8%83%BD%E8%A3%9C%E5%8A%A9%E6%9C%AB%E7%8F%AD%E8%BB%8A%E6%8B%89%E5%8B%95%E5%AE%B6%E9%9B%BB%E8%B2%B7%E6%B0%A3-090202901.html",
