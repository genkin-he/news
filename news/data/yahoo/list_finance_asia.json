            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit\"><img alt=\"\" class=\"rounded-lg\" height=\"214\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/CkxN0BujFqtu1TmfOyhKVA--/YXBwaWQ9aGlnaGxhbmRlcjt3PTcwNTtoPTM5Nw--/https://media.zenfs.com/ko/cnyes_hk_559/120c8fda2409f517d526ccd1bb62299e\" width=\"380\"/></div></figure></div>",
