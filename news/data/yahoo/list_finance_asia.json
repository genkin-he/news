            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"541\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/U0MbNkCf1lOFjmb1yLojLQ--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTU0MQ--/https://media.zenfs.com/ko/28hse_com_210/c738f7bde140a16752a3955359f29329\" width=\"960\"/></div></figure></div>",
