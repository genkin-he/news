            "language": "zh-HK"
        },
        {
            "title": "海偉IPO入場費2885元",
            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit\"><img alt=\"海偉IPO入場費2885元\" class=\"rounded-lg\" height=\"900\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/DWR16AR3f4yWh4NnD4fhcw--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTkwMDtjZj13ZWJw/https://s.yimg.com/os/creatr-uploaded-images/2025-11/36adc830-c674-11f0-bdf8-9bea0207a413\" width=\"960\"/><figcaption class=\"text-px14 text-dolphin mt-2 wrap-anywhere\" style=\"max-width:960px\">海偉IPO入場費2885元</figcaption></div></figure></div>",
            "link": "https://hk.news.yahoo.com/%E6%B5%B7%E5%81%89ipo%E5%85%A5%E5%A0%B4%E8%B2%BB2885%E5%85%83-180900135.html",
