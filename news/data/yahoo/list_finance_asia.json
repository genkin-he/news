            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"720\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/fMTyNw02pu5MyPorwjTJIA--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTcyMA--/https://media.zenfs.com/vi/28hse_com_210/41874e18b454b72f69513de163f1bbfe\" width=\"960\"/></div></figure></div>",
