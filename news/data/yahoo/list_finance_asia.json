            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"540\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/7rBhYksW9DtP_Rv17.xQmw--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTU0MA--/https://media.zenfs.com/ko/28hse_com_210/4dafae3d4b4cd55e4badba3d06bfa25a\" width=\"960\"/></div></figure></div>",
