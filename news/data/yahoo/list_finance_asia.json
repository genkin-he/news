            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"540\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/PXB5Ab9Cs_H6j.b3uyCnQA--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTU0MA--/https://media.zenfs.com/ko/28hse_com_210/2448c5e669b454cc825005defa3b602f\" width=\"960\"/></div></figure></div>",
