            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"214\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/GzY30hrh2d2EyS6U3QKVHQ--/YXBwaWQ9aGlnaGxhbmRlcjt3PTcwNTtoPTM5Nw--/https://media.zenfs.com/ko/cnyes_hk_559/7f05fe2f7a560f57f30928c484468fa8\" width=\"380\"/></div></figure></div>",
