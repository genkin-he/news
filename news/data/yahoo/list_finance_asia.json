            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"280\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/Sfq.YlIMSwj18Z_WeUT9wg--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTUzOA--/https://media.zenfs.com/ko/the_bamboo_works_186/6321bc3bbeb6aa5d8191c80954944dd7\" width=\"500\"/></div></figure></div>",
