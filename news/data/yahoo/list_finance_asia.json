        {
            "title": "Visa攜MaiCoin集團策略合作 加速台灣數位資產接軌國際支付",
            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"214\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/nHaCZqey2w8piNn2oCon1A--/YXBwaWQ9aGlnaGxhbmRlcjt3PTcwNTtoPTM5Nw--/https://media.zenfs.com/ko/cnyes_hk_559/a55e623e018ed0fdb896d9cdd39d3009\" width=\"380\"/></div></figure></div>",
            "link": "https://hk.news.yahoo.com/visa%E6%94%9Cmaicoin%E9%9B%86%E5%9C%98%E7%AD%96%E7%95%A5%E5%90%88%E4%BD%9C-%E5%8A%A0%E9%80%9F%E5%8F%B0%E7%81%A3%E6%95%B8%E4%BD%8D%E8%B3%87%E7%94%A2%E6%8E%A5%E8%BB%8C%E5%9C%8B%E9%9A%9B%E6%94%AF%E4%BB%98-154150280.html",
