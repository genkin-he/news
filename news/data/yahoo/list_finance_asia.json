e\uff0c\u534776\u9ede\uff0c\u5347\u5e450.33%\u3002 \u53f0\u80a1\u672c\u661f\u671f4\u65e5\u5e02\uff0c\u7d2f\u8a08\u8dcc\u7d041.6%\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E5%8F%B0%E8%82%A1%E9%AB%98%E6%94%B60-3-%E6%9C%AC%E5%91%A8%E8%B7%8C%E7%B4%841-6-063611248.html", "pub_date": "2025-01-03 14:51:00", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u6052\u6307\u4e0b\u5348\u521d\u6bb5\u5347\u5e45\u6536\u7a84", "description": "<div class=\"caas-body\"><p>\u6e2f\u80a1\u4e0b\u5348\u521d\u6bb5\u5347\u5e45\u6536\u7a84\u3002 \u6052\u6307\u8f03\u65e9\u6642\u583119725\u9ede\uff0c\u5347101\u9ede\uff0c\u5347\u5e450.52%\u3002 \u79d1\u6280\u6307\u6578\u58314394\u9ede\uff0c\u534737\u9ede\uff0c\u5347\u5e450.85%\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E6%81%92%E6%8C%87%E4%B8%8B%E5%8D%88%E5%88%9D%E6%AE%B5%E5%8D%87%E5%B9%85%E6%94%B6%E7%AA%84-051020551.html", "pub_date": "2025-01-03 13:31:00", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u97d3\u80a1\u9ad8\u6536\u8fd11.8%\u3000\u672c\u5468\u7d2f\u53471.5%", "description": "<div class=\"caas-body\"><p>\u5357\u97d3\u80a1\u5e02\u7d50\u675f\u9023\u7e8c5\u500b\u4ea4\u6613\u65e5\u7684\u8dcc\u52e2\uff0c\u9996\u723e\u7d9c\u5408\u6307\u6578\u6536\u5e02\u58312441\u9ede\uff0c\u534742\u9ede\uff0c\u5347\u5e451.79%\u3002 \u97d3\u80a1\u672c\u54683\u65e5\u5e02\uff0c\u7d2f\u8a08\u4e0a\u53471.5%\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E9%9F%93%E8%82%A1%E9%AB%98%E6%94%B6%E8%BF%911-8-%E6%9C%AC%E5%91%A8%E7%B4%AF%E5%8D%871-5-065307169.html", "pub_date": "2025-01-03 15:11:01", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u4e00\u5468\u5e02\u5834\u56de\u9867\uff1aA\u80a1\u6158\u6de1\u958b\u5e74\u8868\u73fe\uff1b\u7f8e\u570b\u7d93\u6fdf\u9a5a\u4eba\u97cc\u6027\uff1b\u97d3\u61b2\u653f\u5371\u6a5f\u52a0\u6df1", "description": "<div class=\"caas-body\"><p>\u3010\u5f6d\u535a\u3011-- \u4e2d\u570b\u7d93\u6fdf\u5fa9\u7526\u4e4b\u8def\u4ecd\u5d0e\u5d87\u4e0d\u5e73\uff0c12\u6708\u670d\u52d9\u696d\u4ee5\u4e5d\u500b\u6708\u4f86\u6700\u5feb\u6b65\u4f10\u64f4\u5f35\uff0c\u4f46\u88fd\u9020\u696d\u56de\u6696\u52e2\u982d\u653e\u7de9\u3002\u767e\u5f37\u623f\u4f01\u92b7\u552e\u6b62\u8dcc\uff0c\u53cd\u6620\u653f\u7b56\u7d44\u5408\u62f3\u5f8c\u6a13\u5e02\u521d\u9732\u4f01\u7a69\u8de1\u8c61\u3002\u570b\u5bb6\u4e3b\u5e2d\u7fd2\u8fd1\u5e73\u7a312024\u5e74GDP\u9810\u8a08\u6210\u9577\u4e865%\u5de6\u53f3\uff0c\u540c\u6642\u627f\u8a8d\u7d93\u6fdf\u9762\u81e8\u5916\u90e8\u4e0d\u78ba\u5b9a\u6027\u548c\u65b0\u820a\u52d5\u80fd\u8f49\u63db\u7b49\u65b0\u60c5\u6cc1\u3002\u7531\u65bc\u5e74\u672b\u964d\u6e96\u9810\u671f\u843d\u7a7a\uff0c\u52a0\u4e0a\u64c5\u6253\u95dc\u7a05\u724c\u7684\u5ddd\u666e\u5373\u5c07\u91cd\u8fd4\u767d\u5bae\uff0cA\u80a1\u5728\u65b0\u5e74\u9996\u500b\u4ea4\u6613\u65e5\u5275\u4e0b\u4e5d\u5e74\u4f86\u6700\u5dee\u958b\u5e74\u8868\u73fe\uff0c\u5e02\u5834\u6025\u76fc\u653f\u7b56\u652f\u6301\u52a0\u78bc\u3002</p><p>\u5118\u7ba1\u4e00\u5ea6\u9762\u81e8\u5927\u9078\u4e0d\u78ba\u5b9a\u6027\u3001\u52de\u52d5\u529b\u5e02\u5834\u964d\u6eab\u7b49\u8af8\u591a\u6311\u6230\uff0c\u4f462024\u5e74\u7f8e\u570b\u7d93\u6fdf\u986f\u73fe\u51fa\u4e86\u9a5a\u4eba\u97cc\u6027\uff0c\u7f8e\u80a1\u725b\u5e02\u518d\u7e8c\u50b3\u5947\uff0c\u6a19\u666e500\u6307\u6578\u5168\u5e74\u4e0a\u6f3223%\u3002\u65b0\u4e00\u5e74\u806f\u5132\u6703\u6295\u7968\u59d4\u54e1\u5c07\u6709\u65b0\u9663\u5bb9\uff0c\u6210\u54e1\u8b8a\u5316\u52e2\u5c07\u5e36\u4f86\u65b0\u8996\u89d2\u548c\u7acb\u5834\u50be\u5411\uff0c\u653f\u7b56\u8d70\u5411\u6216\u751f\u8b8a\u3002\u6b50\u6d32\u592e\u884c\u7e3d\u88c1\u62c9\u52a0\u5fb7\u7a31\u6b50\u5143\u5340\u5be6\u73fe\u901a\u81a8\u76ee\u6a19\u5df2\u6307\u65e5\u53ef\u5f85\uff0c\u6709\u7ba1\u59d4\u8a8d\u70ba\u5229\u7387\u5230\u79cb\u5b63\u5c07\u964d\u81f32%\u9644\u8fd1\u3002</p><p>\u5168\u7403\u8cbf\u6613\u7dca\u5f35\u5c40\u52e2\u52a0\u5287\u4e4b\u969b\uff0c\u4e2d\u570b\u8a08\u756b\u9650\u5236\u96fb\u6c60\u7d44\u4ef6\u548c\u95dc\u9375\u91d1\u5c6c\u76f8\u95dc\u6280\u8853\u51fa\u53e3\u3002\u62dc\u767b\u653f\u5e9c\u8003\u616e\u5728\u7f8e\u5c01\u6bba\u4e2d\u570b\u7121\u4eba\u6a5f\uff0c\u4e0d\u904e\u6700\u7d42\u6c7a\u5b9a\u6b0a\u5c07\u843d\u5728\u5ddd\u666e\u624b\u4e2d\u3002\u65b0\u5e74\u4f0a\u59cb\u7f8e\u570b\u767c\u751f\u7684\u6c7d\u8eca\u885d\u649e\u4eba\u7fa4\u548c\u7206\u70b8\u4e8b\u4ef6\u628a\u570b\u5bb6\u5b89\u5168\u548c\u6050\u6016\u4e3b\u7fa9\u554f\u984c\u63a8\u5230\u98a8\u53e3\u6d6a\u5c16\u3002\u97d3\u570b\u653f\u58c7\u98a8\u6ce2\u6301\u7e8c\uff0c\u7576\u5730\u6cd5\u9662\u5411\u4e00\u518d\u7121\u8996\u50b3\u559a\u7684\u5c39\u932b\u6085\u767c\u51fa\u902e\u6355\u4ee4\uff0c\u8abf\u67e5\u4eba\u54e1\u5468\u4e94\u8a66\u5716\u9032\u5165\u7e3d\u7d71\u5b98\u902e\u6355\u5c39\u932b\u6085\uff0c\u906d\u5b89\u4fdd\u5718\u968a\u548c\u6297\u8b70\u8005\u963b\u6493\u3002</p><p>\u71b1\u9580\u5716\u8868</p><p>\u770b\u5716\u8ad6\u5e02\uff1a\u4e2d\u570b10\u5e74\u570b\u50b5\u82077\u5929\u56de\u8cfc\u5229\u7387\u7f55\u898b\u5012\u639b \u535a\u5f08\u5347\u7d1a\u6599\u6ce2\u52d5\u98a8\u96aa\u5347</p><p>\u80a1\u5e02\u56de\u9867</p><p>\u4e2d\u570bA\u80a1\u5275\u4e0b2016\u5e74\u4f86\u6700\u5dee\u958b\u5e74\u8868\u73fe \u907f\u96aa\u5347\u6eab\u5e02\u5834\u518d\u805a\u7126\u5ddd\u666e\u95dc\u7a05\u98a8\u96aa</p><p>\u4e2d\u570b\u80a1\u5e02\u57282025\u5e74\u7684\u7b2c\u4e00\u500b\u4ea4\u6613\u65e5\u907f\u96aa\u60c5\u7dd2\u8513\u5ef6\uff0c\u4e3b\u8981\u80a1\u6307\u91cd\u632b\uff0c\u5176\u4e2d\u6eec\u6df1300\u6307\u6578\u5275\u4e0b2016\u5e74\u4f86\u6700\u5dee\u958b\u5e74\u8868\u73fe\u3002</p><p>\u6469\u6839\u58eb\u4e39\u5229\uff1a\u5927\u578b\u79d1\u6280\u80a1\u7684\u7d71\u6cbb\u5730\u4f4d\u57282025\u5e74\u9762\u81e8\u5371\u96aa</p><p>\u6469\u6839\u58eb\u4e39\u5229\u8a8d\u70ba\uff0c\u96a8\u8457\u5229\u6f64\u6210\u9577\u653e\u7de9\uff0c\u70ba\u6a19\u666e500\u6307\u6578\u53bb\u5e7423%\u7684\u6f32\u5e45\u505a\u51fa\u4e00\u534a\u4ee5\u4e0a\u8ca2\u737b\u7684\u79d1\u6280\u5de8\u982d\u53ef\u80fd\u5f88\u96e3\u57282025\u5e74\u4e3b\u5c0e\u5e02\u5834\u3002</p><div class=\"caas-da\"><div id=\"sda-INARTICLE\"></div></div><p>\u53d7\u8cbf\u6613\u548c\u653f\u6cbb\u64d4\u6182\u5f71\u97ff \u6b50\u6d32\u80a1\u5e02\u5168\u5e74\u6f32\u5e45\u9060\u4e0d\u53ca\u7f8e\u80a1</p><p>\u82f1\u570b\u548c\u6cd5\u570b\u80a1\u5e02\u5728\u6e05\u6de1\u4ea4\u6295\u4e2d\u4e0a\u6f32\uff0c\u5e36\u9818\u6b50\u6d32\u57fa\u6e96\u80a1\u6307\u4ee5\u6eab\u548c\u6f32\u5e45\u70ba2024\u5e74\u6536\u5b98\u3002\u5f6d\u535a\u532f\u7de8\u7684\u6578\u64da\u986f\u793a\uff0c\u6b50\u6d32\u80a1\u5e022024\u5e74\u5168\u5e74\u4e0a\u6f326%\u5de6\u53f3\uff0c\u9060\u4f4e\u65bc\u8a72\u6307\u6578\u81ea1998\u5e74\u63a8\u51fa\u4ee5\u4f86\u6bcf\u9022\u4e0a\u6f32\u5e74\u4efd16%\u7684\u5e73\u5747\u6f32\u5e45\u3002</p><p>\u5168\u7403\u50b5\u5e02</p><p>\u501f\u52a9\u8cb7\u65b7\u5f0f\u9006\u56de\u8cfc\u548c\u570b\u50b5\u8cb7\u8ce3 \u4e2d\u570b\u592e\u884c\u5e74\u672b\u52a0\u78bc\u6295\u653e\u6d41\u52d5\u6027</p><p>\u4e2d\u570b\u592e\u884c12\u6708\u6295\u653e\u4e861.7\u842c\u5104\u5143\u4eba\u6c11\u5e63\uff082,330\u5104\u7f8e\u5143\uff09\u73fe\u91d1\uff0c\u5728\u5e74\u672b\u52a0\u5927\u4e86\u5c0d\u7d93\u6fdf\u548c\u91d1\u878d\u5e02\u5834\u7684\u6d41\u52d5\u6027\u652f\u6301\u3002</p><p>\u7f8e\u570b\u570b\u50b52024\u5e74\u5c0f\u5e45\u4e0a\u6f32 \u56e0\u806f\u5132\u6703\u555f\u52d5\u964d\u606f</p><p>\u7f8e\u570b\u570b\u50b5\u5e02\u5834\u57282024\u5e74\u7d50\u675f\u6642\u5c0f\u5e45\u4e0a\u6f32\uff0c\u56e0\u901a\u81a8\u5728\u4e00\u5b63\u5ea6\u5f8c\u6062\u5fa9\u5c0f\u5e45\u8d70\u4f4e\uff0c\u800c\u4e14\u806f\u5132\u6703\u4e09\u6b21\u964d\u606f\u3002</p><ul class=\"caas-list caas-list-bullet\"><li><p>\u7f8e\u570b\u570b\u50b5\u8d8a\u767c\u8d8a\u591a \u4e00\u7d1a\u4ea4\u6613\u5546\u537b\u4e0d\u518d\u4ee4\u4eba\u8277\u7fa1</p></li></ul><p>\u6fb3\u9580\u50b5\u5238\u767c\u884c\u898f\u6a21\u5927\u589e \u5411\u535a\u5f69\u696d\u4e4b\u5916\u9818\u57df\u591a\u5143\u767c\u5c55</p><p>\u6fb3\u95802024\u5e74\u50b5\u5238\u767c\u884c\u898f\u6a21\u5275\u7d00\u9304\u65b0\u9ad8\u3002\u4f5c\u70ba\u5168\u7403\u6700\u5927\u7684\u535a\u5f69\u4e2d\u5fc3\uff0c\u6fb3\u9580\u5728\u52aa\u529b\u591a\u5143\u5316\u767c\u5c55\u7d93\u6fdf\uff0c\u5c07\u81ea\u5df1\u6253\u9020\u70ba\u4e2d\u8cc7\u4f01\u696d\u7684\u53c8\u4e00\u878d\u8cc7\u4e2d\u5fc3\u3002</p><p>\u5168\u7403\u532f\u5e02</p><p>\u4eba\u6c11\u5e63\u5c0d\u4e00\u7c43\u5b50\u5347\u81f3\u903e\u5169\u5e74\u6700\u9ad8\u6c34\u5e73 \u5f37\u52e2\u8868\u73fe\u6216\u62d6\u7d2f\u51fa\u53e3\u7af6\u722d\u529b</p><p>\u4e2d\u570b\u5c0d\u5728\u5cb8\u4eba\u6c11\u5e63\u7684\u5f37\u529b\u652f\u6490\uff0c\u6b63\u5c0e\u81f4\u4eba\u6c11\u5e63\u514c\u4e00\u7c43\u5b50\u8ca8\u5e63\u986f\u8457\u8d70\u9ad8\u7684\u526f\u4f5c\u7528\uff0c\u5728\u7dad\u7a69\u5c0d\u7f8e\u5143\u532f\u50f9\u7684\u540c\u6642\uff0c\u53ef\u80fd\u885d\u64ca\u8207\u5176\u4ed6\u8cbf\u6613\u570b\u5bb6\u7684\u51fa\u53e3\u7af6\u722d\u529b\u3002</p><ul class=\"caas-list caas-list-bullet\"><li><p>\u6e2f\u5143\u5347\u81f32021\u5e74\u4ee5\u4f86\u6700\u5f37\u6c34\u5e73 \u9694\u591cHibor\u672c\u5468\u5275\u6b77\u53f2\u6700\u9ad8</p></li></ul><p>\u6b50\u5143\u514c\u7f8e\u5143\u8dcc\u81f32022\u5e7411\u6708\u4ee5\u4f86\u4f4e\u9ede \u53d7\u5236\u65bc\u7d93\u6fdf\u548c\u5229\u7387\u524d\u666f</p><p>\u53d7\u5236\u65bc\u5c0d\u6b50\u6d32\u7d93\u6fdf\u53ca\u5176\u8207\u7f8e\u570b\u8ca8\u5e63\u653f\u7b56\u5206\u5316\u7684\u64d4\u6182\uff0c\u6b50\u5143\u514c\u7f8e\u5143\u5468\u56db\u8dcc\u81f3\u903e\u5169\u5e74\u4f4e\u9ede\uff0c\u82f1\u938a\u5247\u89f8\u53ca8\u500b\u6708\u6700\u4f4e\u6c34\u5e73\u3002</p><p>\u5df4\u897f\u592e\u884c\u518d\u6b21\u51fa\u624b\u5e72\u9810 \u70ba\u5168\u7403\u8868\u73fe\u6700\u5dee\u7684\u8ca8\u5e63\u63d0\u4f9b\u652f\u6490</p><p>\u96a8\u8457\u5df4\u897f\u7e3d\u7d71\u76e7\u62c9\u89e3\u6c7a\u9810\u7b97\u8d64\u5b57\u81a8\u8139\u554f\u984c\u7684\u627f\u8afe\u9762\u81e8\u7684\u61f7\u7591\u65e5\u589e\uff0c\u5df4\u897f\u8cc7\u7522\u5168\u5e74\u8868\u73fe\u6599\u843d\u5f8c\u65bc\u6240\u6709\u4e3b\u8981\u540c\u985e\uff0c\u96f7\u4e9e\u723e\u9081\u54112020\u5e74\u75ab\u60c5\u885d\u64ca\u4ee5\u4f86\u6700\u5927\u8dcc\u5e45\u3002</p><p>\u516c\u53f8\u6d88\u606f</p><p>\u963f\u91cc\u5df4\u5df4\u8207\u9ad8\u946b\u96f6\u552e\u5206\u624b \u80a1\u6b0a\u4f5c\u50f9123\u5104\u6e2f\u5143\u51fa\u552e\u7d66\u5fb7\u5f18\u8cc7\u672c</p><p>\u963f\u91cc\u5df4\u5df4\u540c\u610f\u5c07\u6240\u6301\u9ad8\u946b\u96f6\u552e\u80a1\u4efd\u51fa\u552e\u7d66\u79c1\u52df\u80a1\u6b0a\u516c\u53f8\u5fb7\u5f18\u8cc7\u672c\uff0c\u6298\u50f9\u8ce3\u51fa\u53c8\u4e00\u9805\u5099\u53d7\u77da\u76ee\u7684\u5be6\u9ad4\u5546\u696d\u8cc7\u7522\uff0c\u4ee5\u4fbf\u66f4\u597d\u5c08\u6ce8\u65bc\u6838\u5fc3\u7dda\u4e0a\u696d\u52d9\u3002</p><ul class=\"caas-list caas-list-bullet\"><li><p>\u5468\u5927\u798f\u5275\u5efa\u64da\u6089\u5546\u8ac7\u51fa\u552e\u50f9\u503c20\u5104\u7f8e\u5143\u7684\u4e2d\u570b\u6536\u8cbb\u516c\u8def\u8cc7\u7522</p></li></ul><p>\u6bd4\u4e9e\u8fea12\u6708\u92b7\u91cf\u5275\u7d00\u9304\u65b0\u9ad8 \u8207\u7279\u65af\u62c9\u5dee\u8ddd\u9032\u4e00\u6b65\u7e2e\u5c0f</p><p>\u5e74\u672b\u696d\u7e3e\u5927\u589e\u63a8\u52d5\u6bd4\u4e9e\u8fea2024\u5168\u5e74\u4e58\u7528\u8eca\u92b7\u91cf\u9054\u5230425\u842c\u8f1b\uff0c\u9032\u4e00\u6b65\u7e2e\u5c0f\u4e86\u8207\u7279\u65af\u62c9\u7684\u5dee\u8ddd\u3002\u53d7\u88dc\u8cbc\u548c\u5411\u8cb7\u5bb6\u63d0\u4f9b\u984d\u5916\u512a\u60e0\u7684\u523a\u6fc0\uff0c12\u6708\u6bd4\u4e9e\u8fea\u6708\u92b7\u91cf\u9054\u5230\u5275\u7d00\u9304\u6c34\u5e73\u3002</p><ul class=\"caas-list caas-list-bullet\"><li><p>\u7279\u65af\u62c9\u96fb\u52d5\u8eca\u5168\u5e74\u92b7\u91cf\u5341\u591a\u5e74\u4f86\u9996\u6b21\u540c\u6bd4\u4e0b\u964d</p></li></ul><p>\u83ef\u76db\u9813\u90f5\u5831\u7a31\u62dc\u767b\u6c7a\u5b9a\u963b\u6b62\u65e5\u672c\u88fd\u9435\u6536\u8cfc\u7f8e\u570b\u92fc\u9435\u516c\u53f8</p><p>\u64da\u300a\u83ef\u76db\u9813\u90f5\u5831\u300b\u5831\u5c0e\uff0c\u7f8e\u570b\u7e3d\u7d71\u55ac\u00b7\u62dc\u767b\u5df2\u6c7a\u5b9a\u963b\u6b62\u65e5\u672c\u88fd\u9435\u6536\u8cfc\u7f8e\u570b\u92fc\u9435\u516c\u53f8\u3002\u8a72\u5831\u5f15\u8ff0\u5169\u540d\u653f\u5e9c\u5b98\u54e1\u7684\u8a71\u8aaa\uff0c\u767d\u5bae\u8a08\u756b\u6700\u5feb\u5728\u5468\u4e94\u5ba3\u5e03\u7d50\u8ad6\u3002</p><p>\u5927\u5b97\u5546\u54c1</p><p>\u5118\u7ba1\u806f\u5132\u6703\u964d\u606f \u6295\u8cc7\u8005\u4ecd\u9023\u7e8c\u7b2c\u56db\u5e74\u62cb\u552e\u9ec3\u91d1ETF</p><p>\u5118\u7ba1\u91d1\u50f9\u5c62\u5275\u65b0\u9ad8\u3001\u806f\u5132\u6703\u958b\u59cb\u653e\u9b06\u8ca8\u5e63\u653f\u7b56\uff0c\u6295\u8cc7\u80052024\u5e74\u9023\u7e8c\u7b2c\u56db\u5e74\u62cb\u552e\u9ec3\u91d1\u652f\u6301\u4ea4\u6613\u6240\u4ea4\u6613\u57fa\u91d1\u3002</p><p>\u904e\u5883\u5354\u8b70\u5230\u671f\u672a\u7e8c \u4fc4\u7f85\u65af\u505c\u6b62\u7d93\u70cf\u514b\u862d\u5411\u6b50\u8f38\u9001\u5929\u7136\u6c23</p><p>\u7531\u65bc\u57fa\u8f14\u62d2\u7d55\u653e\u884c\uff0c\u4fc4\u7f85\u65af\u5929\u7136\u6c23\u7d93\u70cf\u514b\u862d\u8f38\u5f80\u6b50\u6d32\u7684\u901a\u9053\u88ab\u95dc\u9589\uff0c\u4e94\u5341\u5e74\u6b77\u53f2\u5c31\u6b64\u756b\u4e0a\u53e5\u865f\u3002\u5728\u95dc\u9375\u7684\u5929\u7136\u6c23\u904e\u5883\u904b\u8f38\u5354\u8b70\u5230\u671f\u5f8c\uff0c\u4fc4\u70cf\u96d9\u65b9\u8b49\u5be6\u5df2\u7d93\u66ab\u505c\u8f38\u6c23\u3002\u6b50\u6d32\u5929\u7136\u6c23\u50f9\u683c\u96a8\u5f8c\u6500\u5347\u3002</p><ul class=\"caas-list caas-list-bullet\"><li><p>\u62dc\u767b\u64da\u6089\u5c07\u4e0b\u4ee4\u7981\u6b62\u5728\u90e8\u5206\u6d77\u57df\u65b0\u589e\u6cb9\u6c23\u947d\u63a2</p></li></ul><p>\u65b0\u5e74\u4f0a\u59cb\u9285\u50f9\u57289\u500b\u6708\u4f4e\u9ede\u9644\u8fd1\u6301\u7a69 \u95dc\u6ce8\u4e2d\u570b\u7d93\u6fdf</p><div class=\"caas-readmore caas-readmore-collapse\"><button class=\"link caas-button collapse-button\" data-ylk=\"elm:readmore;slk:Story continues\">\u7e7c\u7e8c\u95b1\u8b80</button></div><p>\u4eca\u5e74\u7b2c\u4e00\u500b\u4ea4\u6613\u65e5\u9285\u50f9\u57289\u500b\u6708\u4f4e\u9ede\u9644\u8fd1\u4f01\u7a69\u3002\u4e2d\u570b\u80a1\u5e02\u627f\u58d3\u4e4b\u969b\uff0c\u6295\u8cc7\u8005\u5728\u6b0a\u8861\u4e2d\u570b\u653f\u5e9c2025\u5e74\u5be6\u884c\u984d\u5916\u523a\u6fc0\u63aa\u65bd\u7684\u7a7a\u9593\u3002</p><p>\u5206\u6790\u8a55\u8ad6\u7cbe\u9078</p><p>2024\u5e74\u5875\u57c3\u843d\u5b9a \u4e00\u842c\u7f8e\u5143\u6295\u5230\u54ea\u4e9b\u8cc7\u7522\u8868\u73fe\u51fa\u773e\uff1f</p><p>\u6b50\u6d32\u548c\u4e2d\u6771\u6230\u4e8b\u7dbf\u5ef6\u4e0d\u7d55\uff0c\u5168\u7403\u653f\u6cbb\u52d5\u76ea\u4e0d\u5b89\uff0c\u7f8e\u570b\u7d93\u6fdf\u6216\u9677\u5165\u8870\u9000\u4ee4\u4eba\u64d4\u6182\uff0c2024\u5e74\u7a2e\u7a2e\u98a8\u96aa\u56f0\u64fe\u8457\u5e02\u5834\uff0c\u4f46\u6700\u7d42\u6562\u65bc\u5192\u96aa\u7684\u6295\u8cc7\u8005\u7372\u5f97\u56de\u5831\u3002</p><p>\u99ac\u65af\u514b\u3001\u624e\u514b\u4f2f\u683c\u9818\u929c \u5168\u7403\u5bcc\u8c6a500\u5f372024\u5e74\u8ca1\u5bcc\u7e3d\u984d\u7a81\u783410\u842c\u5104\u7f8e\u5143</p><p>\u5168\u7403\u6700\u5bcc\u6709\u7684500\u4eba\u57282024\u5e74\u66f4\u9032\u4e00\u6b65\uff0c\u5728\u99ac\u65af\u514b\u3001\u624e\u514b\u4f2f\u683c\u548c\u9ec3\u4ec1\u52f3\u7684\u5e36\u9818\u4e0b\uff0c\u9019\u7fa4\u5104\u842c\u5bcc\u7fc1\u9081\u5411\u4e00\u500b\u65b0\u7684\u91cc\u7a0b\u7891\uff1a\u7e3d\u8cc7\u7522\u6de8\u503c\u9054\u523010\u842c\u5104\u7f8e\u5143\u3002</p><p>\u7a7a\u96e3\u983b\u767c \u53bb\u5e74\u822a\u7a7a\u696d\u4e8b\u6545\u81f4\u6b7b\u4eba\u6578\u52752018\u5e74\u4ee5\u4f86\u65b0\u9ad8</p><p>2024\u5e74\u5e95\u963f\u585e\u62dc\u7586\u822a\u7a7a\u4e00\u67b6\u98db\u6a5f\u589c\u6bc0\u5f8c\uff0c\u97d3\u570b\u6fdf\u5dde\u822a\u7a7a\u5ba2\u6a5f\u53c8\u767c\u751f\u56b4\u91cd\u7a7a\u96e3\uff0c\u5546\u696d\u822a\u7a7a\u696d\u906d\u9047\u4e862018\u5e74\u4ee5\u4f86\u81f4\u6b7b\u4eba\u6578\u6700\u591a\u7684\u4e00\u5e74\u3002</p><p>\u672a\u4f86\u4e00\u5468\u91cd\u8981\u7d93\u6fdf\u6578\u64da\u53ca\u4e8b\u4ef6\u4e00\u89bd</p><p>\u4e2d\u570b\u5c07\u516c\u4f4812\u6708CPI\u3001PPI\u3001\u5916\u5132\u7b49\u6578\u64da\u3002\u806f\u5132\u6703\u5c07\u767c\u5e0312\u6708\u653f\u7b56\u6703\u8b70\u7d00\u8981\uff0c\u91cd\u78c5\u7f8e\u570b\u975e\u8fb2\u5c31\u696d\u5831\u544a\u4e5f\u5c07\u51fa\u7210\u3002\u6b50\u5143\u5340\u5c07\u516c\u4f48CPI\u3001\u6d88\u8cbb\u8005\u4fe1\u5fc3\u7b49\u6578\u64da\u3002</p><p>1\u67089\u65e5\u7f8e\u570b\u5c07\u70ba\u524d\u7e3d\u7d71\u5409\u7c73\u00b7\u5361\u7279\u8209\u884c\u570b\u846c\uff0c\u7576\u65e5\u7f8e\u570b\u80a1\u5e02\u4f11\u5e02\uff0c\u50b5\u5e02\u5c07\u63d0\u524d\u6536\u76e4\u3002</p><p>More stories like this are available on <a class=\"link\" data-ylk=\"slk:bloomberg.com;elm:context_link;itc:0;sec:content-canvas\" href=\"https://www.bloomberg.com\" rel=\"nofollow noopener\" target=\"_blank\">bloomberg.com</a></p><p>\u00a92025 Bloomberg L.P.</p></div>", "link": "https://hk.news.yahoo.com/%E5%91%A8%E5%B8%82%E5%A0%B4%E5%9B%9E%E9%A1%A7-a%E8%82%A1%E6%85%98%E6%B7%A1%E9%96%8B%E5%B9%B4%E8%A1%A8%E7%8F%BE-%E7%BE%8E%E5%9C%8B%E7%B6%93%E6%BF%9F%E9%A9%9A%E4%BA%BA%E9%9F%8C%E6%80%A7-%E9%9F%93%E6%86%B2%E6%94%BF%E5%8D%B1%E6%A9%9F%E5%8A%A0%E6%B7%B1-064252601.html", "pub_date": "2025-01-03 15:11:03", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}]}