            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"540\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/71_sK1hEJIJVGScsm9GEZw--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTU0MA--/https://media.zenfs.com/vi/28hse_com_210/cbd6c7e521101550ba4bed7c0f083945\" width=\"960\"/></div></figure></div>",
