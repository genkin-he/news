            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"280\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/bN8xXkS1ZxFbJ9._xqvVMw--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTUzOA--/https://media.zenfs.com/en/the_bamboo_works_186/4a4c8215e56eea9bc89d82aa4cb11338\" width=\"500\"/></div></figure></div>",
