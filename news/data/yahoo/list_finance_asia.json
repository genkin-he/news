        {
            "title": "永久離港提走強積金額量「雙降」",
            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit\"><img alt=\"永久離港提走強積金額量「雙降」\" class=\"rounded-lg\" height=\"639\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/4M.wVmIu.5gDzS.TNu2IMg--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTYzOQ--/https://s.yimg.com/os/creatr-uploaded-images/2022-02/c46624b0-9383-11ec-bfbf-24244092ceb2\" width=\"960\"/><figcaption class=\"text-px14 text-dolphin mt-2 wrap-anywhere\" style=\"max-width:960px\">永久離港提走強積金額量「雙降」</figcaption></div></figure></div>",
            "link": "https://hk.news.yahoo.com/%E6%B0%B8%E4%B9%85%E9%9B%A2%E6%B8%AF%E6%8F%90%E8%B5%B0%E5%BC%B7%E7%A9%8D%E9%87%91%E9%A1%8D%E9%87%8F-%E9%9B%99%E9%99%8D-181000804.html",
