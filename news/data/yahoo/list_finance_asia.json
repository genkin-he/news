            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"610\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/Z5kM0soBPsPoHx.rGZXgjg--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTYxMA--/https://media.zenfs.com/ko/28hse_com_210/205918b2d615614c572f302d3f452d15\" width=\"960\"/></div></figure></div>",
