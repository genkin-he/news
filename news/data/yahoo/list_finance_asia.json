            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"540\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/1NMGnKYjgQfuNIic1sohNg--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTU0MA--/https://media.zenfs.com/ko/28hse_com_210/0526a9e230cf9b94540cb9140c4b12d5\" width=\"960\"/></div></figure></div>",
