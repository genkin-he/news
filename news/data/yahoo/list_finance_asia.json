{"data": [{"title": "\u7f85\u6dd1\u4f69\uff1a\u53bb\u5e74\u8a2a\u6e2f\u65c5\u5ba2\u8fd14500\u842c\u4eba\u6b21\u8f03\u524d\u5e74\u534731%\u7b26\u5408\u9810\u671f", "description": "<div class=\"caas-body\"><p>\u6587\u5316\u9ad4\u80b2\u53ca\u65c5\u904a\u5c40\u5c40\u9577<a class=\"link\" data-i13n=\"sec:content-canvas;subsec:anchor_text;elm:context_link\" data-ylk=\"slk:\u7f85\u6dd1\u4f69;sec:content-canvas;subsec:anchor_text;elm:context_link;itc:0\" href=\"https://hk.finance.yahoo.com/tag/\u7f85\u6dd1\u4f69\">\u7f85\u6dd1\u4f69</a>\u8868\u793a\uff0c\u53bb\u5e74\u5168\u5e74\u8a2a\u6e2f\u65c5\u5ba2\u6578\u5b57\u63a5\u8fd14500\u842c\u4eba\u6b21\uff0c\u8f032023\u5e74\u4e0a\u534731%\uff0c\u6578\u5b57\u7b26\u5408\u9810\u671f\uff0c\u7576\u4e2d\u5167\u5730\u65c5\u5ba2\u6309\u5e74\u5347\u5e45\u7d0427%\uff0c\u975e\u5167\u5730\u65c5\u5ba2\u66f4\u6309\u5e74\u4e0a\u5347\u7d0444%\u3002 \u7f85\u6dd1\u4f69\u5728\u793e\u4ea4\u7db2\u9801\u8aaa\uff0c\u81ea\u6df1\u5733\u300c\u4e00\u7c3d\u591a\u884c\u300d\u500b\u4eba\u904a\u7c3d\u6ce8\u6062\u5fa9\u5f8c\uff0c\u5167\u5730\u8a2a\u6e2f\u4eba\u6578\u4e0d\u65b7\u6500\u5347\uff0c\u55ae\u8a08\u4e0a\u6708\u8a2a\u6e2f\u65c5\u5ba2\u6709426\u842c\u4eba\u6b21\uff0c\u5167\u5730\u65c5\u5ba2\u8d85\u904e310\u842c\u4eba\u6b21\uff0c\u5e73\u5747\u6bcf\u65e5\u8d85\u904e10\u842c\u4eba\u6b21\uff0c\u8f0311\u6708\u5e73\u5747\u6bcf\u65e5\u4eba\u6b21\u9ad817%\uff0c\u5468\u672b\u5e73\u5747\u6bcf\u65e5\u66f4\u905413\u842c2\u5343\u4eba\u6b21\uff0c\u8f0311\u6708\u540c\u6642\u671f\u5e73\u5747\u9ad817%\uff1b\u975e\u5167\u5730\u65c5\u5ba2\u6578\u5b57\u4ea6\u5275\u5168\u9762\u901a\u95dc\u5f8c\u7684\u55ae\u6708\u65b0\u9ad8\uff0c\u8d85\u904e115 \u842c\u4eba\u6b21\uff0c\u6309\u5e74\u5347\u5e45\u7d0418%\u3002\u5979\u8aaa\u53d7\u65c5\u904a\u696d\u5e36\u52d5\uff0c12\u6708\u6574\u9ad4\u5e02\u9762\u4eba\u6d41\u66a2\u65fa\u3002 \u7f85\u6dd1\u4f69\u63d0\u5230\uff0c\u525b\u904e\u53bb\u7684\u9664\u5915\u53ca\u5143\u65e6\uff0c\u5169\u5929\u5171\u9304\u5f97\u7d0429\u842c2000\u65c5\u5ba2\u4eba\u6b21\uff0c\u8f03\u53bb\u5e74\u540c\u671f\u4f4e\u7d04\u4e00\u6210\uff0c\u5979\u8a8d\u7232\u4eca\u5e74\u9664\u5915\u4e26\u975e\u5167\u5730\u5047\u671f\uff0c\u8207\u53bb\u5e74\u4e0d\u540c\uff0c\u4e0d\u80fd\u76f4\u63a5\u6bd4\u8f03\uff0c\u4f46\u5169\u65e5\u5e73\u5747\u55ae\u65e5\u65c5\u5ba2\u4eba\u6b21\u9304\u5f9714\u842c6\u5343\uff0c\u8056\u8a95\u65b0\u5e74\u7bc0\u65e5\u671f\u9593\u65e5\u5747\u65c5\u5ba2\u4eba\u6578\u9054\u523013\u842c9\u5343\u4eba\u6b21\uff0c\u5206\u4f48\u8f03\u53bb\u5e74\u5e73\u5747\uff0c\u76f8\u4fe1\u662f\u7531\u65bc\u6df1\u5733\u300c\u4e00\u7c3d\u591a\u884c\u300d\u91cd\u555f\uff0c\u65c5\u5ba2\u4e0d\u5fc5\u96c6\u4e2d\u5728\u300c\u7d05\u65e5\u300d\u8a2a\u6e2f\u6709\u95dc\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E7%BE%85%E6%B7%91%E4%BD%A9-%E5%8E%BB%E5%B9%B4%E8%A8%AA%E6%B8%AF%E6%97%85%E5%AE%A2%E8%BF%914500%E8%90%AC%E4%BA%BA%E6%AC%A1%E8%BC%83%E5%89%8D%E5%B9%B4%E5%8D%8731-%E7%AC%A6%E5%90%88%E9%A0%90%E6%9C%9F-140829399.html", "pub_date": "2025-01-03 22:31:05", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u4f55\u6c38\u8ce2\u7a31\u50b3\u7d71\u516c\u5c4b\u7c21\u7d04\u516c\u5c4b\u8207\u904e\u6e21\u623f\u5c4b\u6709\u52a9\u89e3\u6c7a\u528f\u623f\u554f\u984c", "description": "<div class=\"caas-body\"><p>\u623f\u5c4b\u5c40\u9577<a class=\"link\" data-i13n=\"sec:content-canvas;subsec:anchor_text;elm:context_link\" data-ylk=\"slk:\u4f55\u6c38\u8ce2;sec:content-canvas;subsec:anchor_text;elm:context_link;itc:0\" href=\"https://hk.finance.yahoo.com/tag/\u4f55\u6c38\u8ce2\">\u4f55\u6c38\u8ce2</a>\u8aaa\uff0c\u7576\u5c40\u6b63\u5c31\u7c21\u6a38\u623f\u898f\u7ba1\u7684\u5efa\u8b70\u65b9\u6848\u9032\u884c\u6301\u4efd\u8005\u8aee\u8a62\uff0c\u5979\u5f37\u8abf\u50b3\u7d71\u516c\u5c4b\u3001\u7d043\u842c\u500b\u7c21\u7d04\u516c\u5c4b\u55ae\u4f4d\uff0c\u4ee5\u53ca\u8d85\u904e2\u842c\u500b\u904e\u6e21\u623f\u5c4b\u55ae\u4f4d\uff0c\u662f\u653f\u5e9c\u89e3\u6c7a\u300c\u528f\u623f\u300d\u554f\u984c\u7684\u5e95\u6c23\uff0c\u6703\u8abf\u914d\u4e26\u5584\u7528\u597d\u9019\u4e9b\u5bf6\u8cb4\u793e\u6703\u8cc7\u6e90\uff0c\u843d\u5be6\u597d\u6709\u95dc\u5de5\u4f5c\u3002 \u4f55\u6c38\u8ce2\u5728\u793e\u4ea4\u7db2\u9801\u8868\u793a\uff0c\u526f\u5c40\u9577\u6234\u5c1a\u8aa0\u5728\u9664\u5915\u7576\u65e5\uff0c\u8207\u7acb\u6cd5\u6703\u8b70\u54e1\u53ca20\u591a\u500b\u71df\u904b\u904e\u6e21\u623f\u5c4b\u9805\u76ee\u7684\u975e\u653f\u5e9c\u7d44\u7e54\u4ee3\u8868\u6703\u9762\uff0c\u4e86\u89e3\u4ed6\u5011\u5c0d\u7c21\u6a38\u623f\u898f\u7ba1\u7684\u5efa\u8b70\u53ca\u9032\u884c\u4ea4\u6d41\u3002 \u4f55\u6c38\u8ce2\u8aaa\uff0c\u975e\u653f\u5e9c\u7d44\u7e54\u4ee3\u8868\u90fd\u8a8d\u540c\u653f\u5e9c\u89e3\u6c7a\u300c\u528f\u623f\u300d\u554f\u984c\u7684\u6c7a\u5fc3\u8207\u65b9\u5411\uff0c\u5e0c\u671b\u53ef\u4ee5\u5e6b\u52a9\u5230\u6709\u9700\u8981\u5e02\u6c11\u64fa\u812b\u60e1\u52a3\u5c45\u6240\uff0c\u671f\u671b\u904e\u6e21\u623f\u5c4b\u53ef\u4ee5\u767c\u63ee\u7a4d\u6975\u4f5c\u7528\uff0c\u914d\u5408\u7c21\u6a38\u623f\u898f\u7ba1\u7684\u843d\u5be6\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E4%BD%95%E6%B0%B8%E8%B3%A2%E7%A8%B1%E5%82%B3%E7%B5%B1%E5%85%AC%E5%B1%8B%E7%B0%A1%E7%B4%84%E5%85%AC%E5%B1%8B%E8%88%87%E9%81%8E%E6%B8%A1%E6%88%BF%E5%B1%8B%E6%9C%89%E5%8A%A9%E8%A7%A3%E6%B1%BA%E5%8A%8F%E6%88%BF%E5%95%8F%E9%A1%8C-131615687.html", "pub_date": "2025-01-03 21:31:21", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u672c\u6e2f\u66ab\u505c\u5f9e\u6ce2\u862d\u5357\u97d3\u7f8e\u570b\u53ca\u52a0\u62ff\u5927\u90e8\u5206\u5730\u5340\u9032\u53e3\u79bd\u985e\u7522\u54c1", "description": "<div class=\"caas-body\"><p>\u98df\u7269\u5b89\u5168\u4e2d\u5fc3\u5ba3\u5e03\uff0c\u56e0\u61c9\u6ce2\u862d\u7378\u91ab\u6aa2\u67e5\u7e3d\u7f72\u548c\u4e16\u754c\u52d5\u7269\u885e\u751f\u7d44\u7e54\u5206\u5225\u901a\u5831\uff0c\u6307\u6ce2\u862d\u90e8\u5206\u5730\u5340\u7206\u767c\u9ad8\u81f4\u75c5\u6027\u79bd\u6d41\u611f\uff0c\u4ee5\u53ca\u5357\u97d3\u3001\u7f8e\u570b\u548c\u52a0\u62ff\u5927\u90e8\u5206\u5730\u5340\u7206\u767c\u9ad8\u81f4\u75c5\u6027H5N1\u79bd\u6d41\u611f\uff0c\u4e2d\u5fc3\u5373\u6642\u6307\u793a\u696d\u754c\u66ab\u505c\u5f9e\u6709\u95dc\u5730\u5340\u9032\u53e3\u79bd\u8089\u53ca\u79bd\u985e\u7522\u54c1\u5305\u62ec\u79bd\u86cb\uff0c\u4ee5\u4fdd\u969c\u672c\u6e2f\u516c\u773e\u5065\u5eb7\u3002 \u6709\u95dc\u5730\u5340\u70ba\u6ce2\u862d\u74e6\u723e\u7c73\u4e9e\u2014\u99ac\u7956\u91cc\u7701\u3001\u5357\u97d3\u4eac\u757f\u9053\u3001\u5fe0\u6e05\u5357\u9053\u9752\u967d\u90e1\u3001\u7f8e\u570b\u4fc4\u4ea5\u4fc4\u5dde\u3001\u52a0\u62ff\u5927\u5b89\u5927\u7565\u7701\u3002\u6839\u64da\u653f\u5e9c\u7d71\u8a08\u8655\u7684\u8cc7\u6599\uff0c\u672c\u6e2f\u53bb\u5e74\u99969\u500b\u6708\u5f9e\u6ce2\u862d\u9032\u53e3\u7d043480\u516c\u5678\u51b7\u85cf\u79bd\u8089\u3001\u5f9e\u5357\u97d3\u9032\u53e3\u7d0420\u516c\u5678\u51b0\u9bae\u548c\u51b7\u85cf\u79bd\u8089\u53ca\u7d041552\u842c\u96bb\u79bd\u86cb\u3001\u5f9e\u7f8e\u570b\u9032\u53e3\u7d0463470\u516c\u5678\u51b0\u9bae\u548c\u51b7\u85cf\u79bd\u8089\u53ca\u7d041720\u842c\u96bb\u79bd\u86cb\uff0c\u4ee5\u53ca\u5f9e\u52a0\u62ff\u5927\u9032\u53e3\u7d04370\u516c\u5678\u51b7\u85cf\u79bd\u8089\u3002 \u767c\u8a00\u4eba\u8aaa\uff0c\u5df2\u5c31\u4e8b\u4ef6\u806f\u7d61\u6ce2\u862d\u3001\u5357\u97d3\u3001\u7f8e\u570b\u548c\u52a0\u62ff\u5927\u7576\u5c40\uff0c\u4e26\u6703\u7e7c\u7e8c\u5bc6\u5207\u7559\u610f\u4e16\u754c\u52d5\u7269\u885e\u751f\u7d44\u7e54\u53ca\u6709\u95dc\u7576\u5c40\u767c\u51fa\u95dc\u65bc\u7206\u767c\u79bd\u6d41\u611f\u7684\u6d88\u606f\uff0c\u56e0\u61c9\u7576\u5730\u75ab\u60c5\u767c\u5c55\uff0c\u63a1\u53d6\u9069\u7576\u884c\u52d5\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E6%9C%AC%E6%B8%AF%E6%9A%AB%E5%81%9C%E5%BE%9E%E6%B3%A2%E8%98%AD%E5%8D%97%E9%9F%93%E7%BE%8E%E5%9C%8B%E5%8F%8A%E5%8A%A0%E6%8B%BF%E5%A4%A7%E9%83%A8%E5%88%86%E5%9C%B0%E5%8D%80%E9%80%B2%E5%8F%A3%E7%A6%BD%E9%A1%9E%E7%94%A2%E5%93%81-140303382.html", "pub_date": "2025-01-03 22:31:07", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u4e09\u540d\u5167\u5730\u7537\u5b50\u6d89\u672c\u6e2f\u6c34\u57df\u975e\u6cd5\u6355\u9b5a\u3000\u660e\u65e5\u63d0\u5802", "description": "<div class=\"caas-body\"><p>\u6f01\u8b77\u7f72\u8d77\u8a34\u4e09\u540d\u5167\u5730\u7537\u5b50\uff0c\u4ed6\u5011\u6d89\u5acc\u5728\u5206\u6d41\u897f\u7063\u5c0d\u958b\u6c34\u57df\u4ee5\u5ef6\u7e69\u91e3\u65b9\u5f0f\u975e\u6cd5\u6355\u9b5a\uff0c\u4e09\u4eba\u88ab\u843d\u6848\u6aa2\u63a7\uff0c\u660e\u65e5\u5728\u4e5d\u9f8d\u57ce\u88c1\u5224\u6cd5\u9662\u63d0\u5802\u3002 \u6f01\u8b77\u7f72\u4eba\u54e1\u6628\u65e5\u5728\u6709\u95dc\u6c34\u57df\uff0c\u767c\u73fe\u4e00\u8258\u5167\u5730\u8239\u96bb\u61f7\u7591\u4ee5\u5ef6\u7e69\u91e3\u65b9\u5f0f\u975e\u6cd5\u6355\u9b5a\uff0c\u540c\u65e5\u4e0b\u5348\u7d04\u56db\u6642\u534a\u622a\u505c\u6709\u95dc\u8239\u96bb\u9032\u884c\u8abf\u67e5\uff0c\u5728\u8239\u4e0a\u6aa2\u8d70\u4e00\u6279\u6355\u9b5a\u5de5\u5177\u3002 \u7f72\u65b9\u91cd\u7533\uff0c\u4efb\u4f55\u4eba\u58eb\u5728\u672c\u6e2f\u6c34\u57df\u4f7f\u7528\u8239\u96bb\u6355\u9b5a\u6642\uff0c\u5fc5\u9808\u5df2\u6839\u64da\u300a\u689d\u4f8b\u300b\u767b\u8a18\uff0c\u975e\u672c\u5730\u6f01\u8239\uff0c\u4e0d\u8ad6\u4f7f\u7528\u4f55\u7a2e\u6f01\u5177\u5747\u4e0d\u53ef\u5728\u672c\u6e2f\u6c34\u57df\u5167\u6355\u9b5a\uff0c\u9055\u8005\u4e00\u7d93\u5b9a\u7f6a\uff0c\u6700\u9ad8\u53ef\u88ab\u5224\u7f70\u6b3e\u5341\u842c\u5143\u53ca\u76e3\u7981\u516d\u500b\u6708\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E4%B8%89%E5%90%8D%E5%85%A7%E5%9C%B0%E7%94%B7%E5%AD%90%E6%B6%89%E6%9C%AC%E6%B8%AF%E6%B0%B4%E5%9F%9F%E9%9D%9E%E6%B3%95%E6%8D%95%E9%AD%9A-%E6%98%8E%E6%97%A5%E6%8F%90%E5%A0%82-140103744.html", "pub_date": "2025-01-03 22:31:09", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u4eba\u884c\uff1a\u6839\u64da\u570b\u5167\u5916\u7d93\u6fdf\u91d1\u878d\u5f62\u52e2\u53ca\u5e02\u6cc1\u3000\u64c7\u6a5f\u964d\u6e96\u964d\u606f", "description": "<div class=\"caas-body\"><p>\u4eba\u6c11\u9280\u884c\u8ca8\u5e63\u653f\u7b56\u59d4\u54e1\u6703\u8fd1\u65e5\u53ec\u958b2024\u5e74\u7b2c\u56db\u5b63\u5ea6\u4f8b\u6703\uff0c\u5efa\u8b70\u52a0\u5927\u8ca8\u5e63\u653f\u7b56\u8abf\u63a7\u5f37\u5ea6\uff0c\u63d0\u9ad8\u8ca8\u5e63\u653f\u7b56\u8abf\u63a7\u524d\u77bb\u6027\u3001\u91dd\u5c0d\u6027\u3001\u6709\u6548\u6027\uff0c\u4e26\u6839\u64da\u570b\u5167\u5916\u7d93\u6fdf\u91d1\u878d\u5f62\u52e2\u548c\u91d1\u878d\u5e02\u5834\u904b\u884c\u60c5\u6cc1\uff0c\u64c7\u6a5f\u964d\u6e96\u964d\u606f\u3002 \u6703\u8b70\u63d0\u5230\uff0c\u8981\u7528\u597d\u8b49\u5238\u3001\u57fa\u91d1\u3001\u4fdd\u96aa\u516c\u53f8\u4e92\u63db\u4fbf\u5229\uff0c\u548c\u80a1\u7968\u56de\u8cfc\u589e\u6301\u518d\u8cb8\u6b3e\u7b49\u65b0\u8a2d\u7acb\u5de5\u5177\uff0c\u7dad\u8b77\u8cc7\u672c\u5e02\u5834\u7a69\u5b9a\uff1b\u4ea6\u8981\u5145\u5be6\u5b8c\u5584\u8ca8\u5e63\u653f\u7b56\u5de5\u5177\u7bb1\uff0c\u958b\u5c55\u570b\u50b5\u8cb7\u8ce3\uff0c\u95dc\u6ce8\u9577\u671f\u6536\u76ca\u7387\u7684\u8b8a\u5316\u3002 \u6703\u8b70\u6307\uff0c\u8981\u589e\u5f37\u5916\u532f\u5e02\u5834\u97cc\u6027\uff0c\u52a0\u5f37\u5e02\u5834\u7ba1\u7406\uff0c\u9632\u6b62\u5f62\u6210\u55ae\u908a\u4e00\u81f4\u6027\u9810\u671f\uff0c\u9632\u7bc4\u532f\u7387\u8d85\u8abf\u98a8\u96aa\uff0c\u4fdd\u6301\u4eba\u6c11\u5e63\u532f\u7387\u5728\u5408\u7406\u5747\u8861\u6c34\u5e73\u4e0a\u7684\u57fa\u672c\u7a69\u5b9a\u3002 \u6703\u8b70\u63d0\u51fa\uff0c\u8981\u4fdd\u6301\u6d41\u52d5\u6027\u5145\u88d5\uff0c\u5f15\u5c0e\u91d1\u878d\u6a5f\u69cb\u52a0\u5927\u8ca8\u5e63\u4fe1\u8cb8\u6295\u653e\u529b\u5ea6\uff1b\u4e26\u5f37\u5316\u4eba\u884c\u653f\u7b56\u5229\u7387\u5f15\u5c0e\uff0c\u5b8c\u5584\u5e02\u5834\u5316\u5229\u7387\u5f62\u6210\u50b3\u5c0e\u6a5f\u5236\uff0c\u767c\u63ee\u5e02\u5834\u5229\u7387\u5b9a\u50f9\u81ea\u5f8b\u6a5f\u5236\u4f5c\u7528\uff0c\u63a8\u52d5\u4f01\u696d\u878d\u8cc7\u548c\u5c45\u6c11\u4fe1\u8cb8\u6210\u672c\u7a69\u4e2d\u6709\u964d\u3002 \u6703\u8b70\u8868\u793a\uff0c\u8981\u52a0\u5927\u8ca8\u5e63\u8ca1\u653f\u653f\u7b56\u5354\u540c\u914d\u5408\uff0c\u4fdd\u6301\u7d93\u6fdf\u7a69\u5b9a\u589e\u9577\u548c\u7269\u50f9\u7e3d\u9ad4\u7a69\u5b9a\uff1b\u4ea6\u8981\u52a0\u5927\u5b58\u91cf\u5546\u54c1\u623f\u548c\u5b58\u91cf\u571f\u5730\u76e4\u6d3b\u529b\u5ea6\uff0c\u63a8\u52d5\u623f\u5730\u7522\u5e02\u5834\u6b62\u8dcc\u56de\u7a69\uff1b\u4e26\u843d\u5be6\u4fc3\u9032\u5e73\u53f0\u7d93\u6fdf\u5065\u5eb7\u767c\u5c55\u7684\u91d1\u878d\u653f\u7b56\u63aa\u65bd\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E4%BA%BA%E8%A1%8C-%E6%A0%B9%E6%93%9A%E5%9C%8B%E5%85%A7%E5%A4%96%E7%B6%93%E6%BF%9F%E9%87%91%E8%9E%8D%E5%BD%A2%E5%8B%A2%E5%8F%8A%E5%B8%82%E6%B3%81-%E6%93%87%E6%A9%9F%E9%99%8D%E6%BA%96%E9%99%8D%E6%81%AF-125527123.html", "pub_date": "2025-01-03 21:10:55", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u7279\u65af\u62c9\u4e0a\u6d77\u5de5\u5ee0\u7684\u5e74\u5ea6\u51fa\u8ca8\u91cf\u9996\u6b21\u51fa\u73fe\u4e0b\u964d", "description": "<div class=\"caas-body\"><p>\u3010\u5f6d\u535a\u3011-- <a class=\"link\" data-i13n=\"sec:content-canvas;subsec:anchor_text;elm:context_link\" data-ylk=\"slk:\u7279\u65af\u62c9;sec:content-canvas;subsec:anchor_text;elm:context_link;itc:0\" href=\"https://hk.finance.yahoo.com/tag/\u7279\u65af\u62c9\">\u7279\u65af\u62c9</a>\u4e0a\u6d77\u5de5\u5ee0\u7684\u5e74\u5ea6\u51fa\u8ca8\u91cf\u81ea2020\u5e74\u8a72\u5ee0\u958b\u59cb\u91cf\u7522\u4ee5\u4f86\u9996\u6b21\u51fa\u73fe\u4e0b\u964d\uff0c\u9019\u6e05\u6670\u53cd\u6620\u4e86\u672c\u5730\u7af6\u722d\u52a0\u5287\u548c\u5168\u7403\u9700\u6c42\u4f4e\u8ff7\u3002</p><p>\u6839\u64da\u4e2d\u570b\u4e58\u806f\u5206\u6703\u5468\u4e94\u767c\u5e03\u7684\u521d\u6b65\u6578\u64da\uff0c\u7279\u65af\u62c92024\u5e74\u4ea4\u4ed8\u7684\u4e0a\u6d77\u7522\u96fb\u52d5\u6c7d\u8eca\u70ba916,660\u8f1b\uff0c\u540c\u6bd4\u4e0b\u964d3%\u3002\u4e0a\u6d77\u5de5\u5ee0\u662f\u8a72\u516c\u53f8\u5728\u7f8e\u570b\u5883\u5916\u7684\u7b2c\u4e00\u5bb6\u5de5\u5ee0\u3002</p><p>\u5118\u7ba1\u51fa\u53f0\u4e00\u7cfb\u5217\u5e74\u7d42\u6fc0\u52f5\u63aa\u65bd\uff0c\u7279\u65af\u62c9\u4e2d\u570b\u7522Model 3\u96fb\u52d5\u8f4e\u8eca\u548cModel Y SUV\u768412\u6708\u8e89\u552e\u92b7\u91cf\u540c\u6bd4\u4e5f\u50c5\u6301\u5e73\uff0c\u7e3d\u8a0893,766\u8f1b\u3002</p><p>\u9019\u662f\u7279\u65af\u62c9\u7e7c\u96fb\u52d5\u8eca\u5168\u5e74\u92b7\u91cf\u5341\u591a\u5e74\u4f86\u9996\u6b21\u4e0b\u964d\u4e4b\u5f8c\u7684\u53c8\u4e00\u500b\u58de\u6d88\u606f\u3002</p><p>\u4e58\u806f\u5206\u6703\u6578\u64da\u986f\u793a\uff0c12\u6708\u5168\u570b\u65b0\u80fd\u6e90\u4e58\u7528\u8eca\u5ee0\u5546\u8e89\u552e\u92b7\u91cf150\u842c\u8f1b\uff0c\u540c\u6bd4\u6210\u957735%\u3002</p><p>\u539f\u6587\u6a19\u984cTesla Annual China Shipments From Shanghai Drop for First Time</p><p>--\u806f\u5408\u5831\u5c0e Linda Lew.</p><p>More stories like this are available on <a class=\"link\" data-ylk=\"slk:bloomberg.com;elm:context_link;itc:0;sec:content-canvas\" href=\"https://www.bloomberg.com\" rel=\"nofollow noopener\" target=\"_blank\">bloomberg.com</a></p><p>\u00a92025 Bloomberg L.P.</p></div>", "link": "https://hk.news.yahoo.com/%E7%89%B9%E6%96%AF%E6%8B%89%E4%B8%8A%E6%B5%B7%E5%B7%A5%E5%BB%A0%E7%9A%84%E5%B9%B4%E5%BA%A6%E5%87%BA%E8%B2%A8%E9%87%8F%E9%A6%96%E6%AC%A1%E5%87%BA%E7%8F%BE%E4%B8%8B%E9%99%8D-110841036.html", "pub_date": "2025-01-03 20:21:03", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u653f\u5e9c\u99c1\u65a5\u4fdd\u8b77\u6d77\u6e2f\u5354\u6703\u504f\u96e2\u4e8b\u5be6\u3000\u91cd\u7533\u7121\u610f\u7dad\u6e2f\u5927\u898f\u6a21\u586b\u6d77\u9020\u5730\u5efa\u5c4b", "description": "<div class=\"caas-body\"><p>\u4fdd\u8b77\u6d77\u6e2f\u4fee\u8a02\u689d\u4f8b\u8349\u6848\u4e0a\u6708\u520a\u61b2\uff0c\u4fdd\u8b77\u6d77\u6e2f\u5354\u6703\u6182\u616e\u7576\u5c40\u6216\u9032\u884c\u5927\u898f\u6a21\u586b\u6d77\uff0c\u8a8d\u70ba\u662f\u5426\u586b\u6d77\u61c9\u7531\u6cd5\u5ead\u6c7a\u5b9a\uff0c\u5354\u6703\u5411\u7279\u9996\u5448\u4ea4\u8acb\u9858\u4fe1\uff0c\u8868\u660e\u53cd\u5c0d\u5927\u578b\u586b\u6d77\u5de5\u7a0b\u3002 \u767c\u5c55\u5c40\u900f\u904e\u793e\u4ea4\u7db2\u9801\u6f84\u6e05\uff0c\u653f\u5e9c\u5df2\u591a\u6b21\u5728\u4e0d\u540c\u5834\u5408\u516c\u958b\u8868\u660e\uff0c\u7121\u8a08\u5283\u5728\u7dad\u6e2f\u5167\u9032\u884c\u5927\u898f\u6a21\u586b\u6d77\u9020\u5730\u4f5c\u623f\u5c4b\u6216\u5176\u4ed6\u7528\u9014\uff0c\u6279\u8a55\u5354\u6703\u53ea\u6191\u4e8c\u3001\u4e09\u5341\u5e74\u524d\u65e9\u5df2\u904e\u6642\u7684\u586b\u6d77\u8a08\u5283\uff0c\u751a\u81f3\u4e0d\u60dc\u865b\u64ec\u5716\u7247\uff0c\u8a66\u5716\u6697\u793a\u653f\u5e9c\u6709\u610f\u9032\u884c\u5927\u898f\u6a21\u586b\u6d77\uff0c\u5b8c\u5168\u504f\u96e2\u4e8b\u5be6\u3002 \u767c\u5c55\u5c40\u6307\u51fa\uff0c\u4fee\u4f8b\u5efa\u8b70\u4e26\u7121\u524a\u5f31\u6cd5\u9662\u529f\u80fd\uff0c\u4ea6\u7121\u640d\u5e02\u6c11\u7684\u53f8\u6cd5\u8986\u6838\u6b0a\u5229\uff0c\u4fee\u4f8b\u5efa\u8b70\u70ba\u6539\u5584\u6d77\u6ff1\u62c6\u7246\u9b06\u7d81\uff0c\u7d55\u975e\u70ba\u5927\u578b\u586b\u6d77\u92ea\u8def\uff0c\u7576\u5c40\u4ea6\u4e00\u76f4\u6709\u56de\u8986\u5354\u6703\uff0c\u6709\u7406\u6709\u64da\u56de\u61c9\u8cea\u7591\u3002 \u767c\u5c55\u5c40\u91cd\u7533\u4fee\u4f8b\u7372\u7acb\u6cd5\u6703\u8de8\u9ee8\u6d3e\u652f\u6301\uff0c\u5f97\u5230\u6d77\u6ff1\u4e8b\u52d9\u59d4\u54e1\u6703\u5927\u90e8\u5206\u59d4\u54e1\u7684\u652f\u6301\uff0c\u516c\u773e\u4ea6\u666e\u904d\u652f\u6301\u4fee\u4f8b\u3002\u653f\u5e9c\u6703\u5168\u529b\u914d\u5408\u7acb\u6cd5\u6703\u7684\u5be9\u8b70\u5de5\u4f5c\uff0c\u8b93\u300a\u689d\u4f8b\u8349\u6848\u300b\u76e1\u65e9\u7372\u5f97\u901a\u904e\u548c\u5be6\u65bd\u3002 \u4fdd\u8b77\u6d77\u6e2f\u5354\u6703\u8868\u793a\u652f\u6301\u5c0f\u578b\u586b\u6d77\uff0c\u4f46\u4e0d\u5e0c\u671b\u6df7\u5408\u5927\u578b\u6d77\u6e2f\u586b\u6d77\u8a08\u5283\u63a8\u884c\uff0c\u53c8\u8a8d\u70ba\u662f\u5426\u586b\u6d77\u61c9\u7531\u6cd5\u5ead\u6c7a\u5b9a\uff0c\u800c\u975e\u653f\u5e9c\u81ea\u5df1\u6c7a\u5b9a\uff0c\u6182\u616e\u4e00\u65e6\u901a\u904e\u4fee\u8a02\u6703\u5f71\u97ff\u6df1\u9060\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E6%94%BF%E5%BA%9C%E9%A7%81%E6%96%A5%E4%BF%9D%E8%AD%B7%E6%B5%B7%E6%B8%AF%E5%8D%94%E6%9C%83%E5%81%8F%E9%9B%A2%E4%BA%8B%E5%AF%A6-%E9%87%8D%E7%94%B3%E7%84%A1%E6%84%8F%E7%B6%AD%E6%B8%AF%E5%A4%A7%E8%A6%8F%E6%A8%A1%E5%A1%AB%E6%B5%B7%E9%80%A0%E5%9C%B0%E5%BB%BA%E5%B1%8B-125149720.html", "pub_date": "2025-01-03 21:10:57", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u5de5\u884c\uff1a\u5927\u884c\u8981\u5e36\u982d\u5805\u6c7a\u4e0d\u6253\u300c\u50f9\u683c\u6230\u300d", "description": "<div class=\"caas-body\"><p>\u4e2d\u570b\u5de5\u5546\u9280\u884c\u884c\u9577\u5289\u73fa\u64b0\u6587\u5efa\u8b70\uff0c\u91dd\u5c0d\u9280\u884c\u696d\u4f4e\u6c34\u5e73\u300c\u5167\u5377\u300d\u554f\u984c\uff0c\u8981\u9032\u4e00\u6b65\u5f37\u5316\u81ea\u5f8b\u7ba1\u7406\uff0c\u7279\u5225\u662f\u5927\u578b\u5546\u696d\u9280\u884c\u8981\u5e36\u982d\u5805\u6c7a\u4e0d\u6253\u300c\u50f9\u683c\u6230\u300d\u3002 \u5289\u73fa\u5728\u592e\u884c\u4e3b\u7ba1\u5a92\u9ad4\u300a\u4e2d\u570b\u91d1\u878d\u300b\u96dc\u8a8c\u520a\u767b\u6587\u7ae0\uff0c\u89e3\u91cb\u91dd\u5c0d\u4e0d\u6253\u300c\u50f9\u683c\u6230\u300d\uff0c\u5c31\u662f\u5728\u8cb8\u6b3e\u7aef\uff0c\u8981\u5728\u6709\u6548\u964d\u4f4e\u793e\u6703\u878d\u8cc7\u6210\u672c\u57fa\u790e\u4e0a\uff0c\u5805\u6301\u5b9a\u50f9\u5373\u7d93\u71df\uff0c\u4e0d\u767c\u653e\u7a05\u5f8c\u5229\u7387\u4f4e\u65bc\u540c\u671f\u9650\u570b\u50b5\u6536\u76ca\u7387\u7684\u8cb8\u6b3e\uff0c\u5408\u7406\u78ba\u5b9a\u8cb8\u6b3e\u5229\u7387\u6c34\u5e73\uff0c\u9632\u6b62\u8cc7\u91d1\u6de4\u7a4d\u7a7a\u8f49\u3002\u5728\u5b58\u6b3e\u7aef\uff0c\u8981\u52a0\u5f37\u62db\u6295\u6a19\u5229\u7387\u81ea\u5f8b\u7ba1\u7406\uff0c\u843d\u5be6\u300c\u5229\u7387\u8abf\u6574\u515c\u5e95\u689d\u6b3e\u300d\u81ea\u5f8b\u5021\u8b70\uff0c\u6301\u7e8c\u898f\u7bc4\u5229\u7387\u5b9a\u50f9\u884c\u70ba\u3002 \u5289\u73fa\u53c8\u63d0\u5230\uff0c\u4f5c\u70ba\u5229\u7387\u81ea\u5f8b\u6a5f\u5236\u4e3b\u4efb\u55ae\u4f4d\uff0c\u5de5\u884c\u7a4d\u6975\u50b3\u5c0e\u843d\u5be6\u5b8f\u89c0\u653f\u7b56\u8981\u6c42\uff0c\u5e36\u982d\u505a\u597d\u81ea\u5f8b\u8868\u7387\uff0c\u56b4\u683c\u843d\u5be6\u5404\u9805\u81ea\u5f8b\u5021\u8b70\u5de5\u4f5c\u8981\u6c42\uff1b\u7ad9\u5728\u5e02\u5834\u53c3\u8207\u8005\u89d2\u5ea6\uff0c\u5354\u540c\u4e3b\u8981\u6210\u54e1\u55ae\u4f4d\u7814\u7a76\u78ba\u5b9a\u5b58\u8cb8\u6b3e\u53ca\u5176\u4ed6\u91d1\u878d\u7522\u54c1\u5229\u7387\u81ea\u5f8b\u65b9\u6848\uff0c\u66a2\u901a\u653f\u7b56\u5229\u7387\u5728\u4e0d\u540c\u5e02\u5834\u7684\u50b3\u5c0e\u6a5f\u5236\uff0c\u7dad\u8b77\u5e02\u5834\u7af6\u722d\u79e9\u5e8f\u3002 \u6587\u7ae0\u53c8\u62ab\u9732\uff0c\u624b\u5de5\u88dc\u606f\u6574\u6539\u5f8c\uff0c\u5546\u696d\u9280\u884c\u6bcf\u5e74\u53ef\u7bc0\u7701\u5229\u606f\u652f\u51fa\u903e800\u5104\u5143\u4eba\u6c11\u5e63\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E5%B7%A5%E8%A1%8C-%E5%A4%A7%E8%A1%8C%E8%A6%81%E5%B8%B6%E9%A0%AD%E5%A0%85%E6%B1%BA%E4%B8%8D%E6%89%93-%E5%83%B9%E6%A0%BC%E6%88%B0-101235003.html", "pub_date": "2025-01-03 18:31:02", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u5305\u6d69\u65af\u4e0a\u5b63\u540c\u5e97\u92b7\u552e\u6309\u5e74\u589e\u957710%", "description": "<div class=\"caas-body\"><p>\u5305\u6d69\u65af\u516c\u5e03\uff0c\u622a\u6b62\u53bb\u5e74\u5e95\u6b62\u7684\u99963\u500b\u5b63\u5ea6\uff0c\u540c\u5e97\u92b7\u552e\u6309\u5e74\u589e\u95772%\uff0c\u7576\u4e2d\uff0c\u9999\u6e2f\u540c\u5e97\u92b7\u552e\u589e\u95772%\uff0c\u6fb3\u9580\u589e3%\u3002 \u55ae\u8a08\u4e0a\u5b63\u5ea6\uff0c\u6574\u9ad4\u540c\u5e97\u92b7\u552e\u6309\u5e74\u589e\u957710%\uff0c\u9999\u6e2f\u589e\u957711%\uff0c\u6fb3\u9580\u53477%\u3002 \u81f3\u53bb\u5e74\u5e95\uff0c\u5e97\u8216\u7e3d\u657834\u9593\uff0c\u9999\u6e2f\u548c\u6fb3\u9580\u5206\u5225\u670928\u9593\u548c6\u9593\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E5%8C%85%E6%B5%A9%E6%96%AF%E4%B8%8A%E5%AD%A3%E5%90%8C%E5%BA%97%E9%8A%B7%E5%94%AE%E6%8C%89%E5%B9%B4%E5%A2%9E%E9%95%B710-094053770.html", "pub_date": "2025-01-03 18:10:55", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}, {"title": "\u672a\u8a3b\u518a\u9032\u884c\u8cb4\u91d1\u5c6c\u53ca\u5bf6\u77f3\u4ea4\u6613\u3000\u4e00\u9593\u672c\u5730\u516c\u53f8\u8463\u4e8b\u88ab\u6355\u51c6\u4fdd\u91cb\u5019\u67e5", "description": "<div class=\"caas-body\"><p>\u4e00\u9593\u672c\u5730\u516c\u53f8\u5728\u6c92\u6709\u8cb4\u91d1\u5c6c\u53ca\u5bf6\u77f3\u4ea4\u6613\u5546\u76e3\u7ba1\u5236\u5ea6\u6240\u9700\u7684\u8a3b\u518a\u60c5\u6cc1\u4e0b\uff0c\u9032\u884c\u591a\u5b97\u4ea4\u6613\u984d\u5747\u70ba12\u842c\u4ee5\u4e0a\u6e2f\u5143\u7684\u947d\u77f3\u4ea4\u6613\uff0c\u516c\u53f8\u4e00\u540d\u8463\u4e8b\u88ab\u6d77\u95dc\u62d8\u6355\u3002 \u6d77\u95dc\u6628\u65e5\u63a1\u53d6\u884c\u52d5\uff0c\u6848\u4ef6\u4ecd\u5728\u8abf\u67e5\u4e2d\uff0c\u88ab\u88dc\u4eba\u58eb\u7372\u51c6\u4fdd\u91cb\u5019\u67e5\u3002 \u6d77\u95dc\u63d0\u9192\uff0c\u6839\u64da\u300a\u6253\u64ca\u6d17\u9322\u53ca\u6050\u6016\u5206\u5b50\u8cc7\u91d1\u7c4c\u96c6\u689d\u4f8b\u300b\uff0c\u4efb\u4f55\u4eba\u5982\u6709\u610f\u5728\u9999\u6e2f\u7d93\u71df\u8cb4\u91d1\u5c6c\u53ca\u5bf6\u77f3\u696d\u52d9\uff0c\u4e26\u5728\u696d\u52d9\u904e\u7a0b\u4e2d\u5728\u9999\u6e2f\u9032\u884c\u7e3d\u984d\u70ba12\u842c\u6216\u4ee5\u4e0a\u6e2f\u5143\u7684\u4ea4\u6613\uff0c\u5747\u9808\u5411\u6d77\u95dc\u95dc\u9577\u8a3b\u518a\u3002</p></div>", "link": "https://hk.news.yahoo.com/%E6%9C%AA%E8%A8%BB%E5%86%8A%E9%80%B2%E8%A1%8C%E8%B2%B4%E9%87%91%E5%B1%AC%E5%8F%8A%E5%AF%B6%E7%9F%B3%E4%BA%A4%E6%98%93-%E9%96%93%E6%9C%AC%E5%9C%B0%E5%85%AC%E5%8F%B8%E8%91%A3%E4%BA%8B%E8%A2%AB%E6%8D%95%E5%87%86%E4%BF%9D%E9%87%8B%E5%80%99%E6%9F%A5-105351015.html", "pub_date": "2025-01-03 19:10:52", "source": "yahoo_finance_asia", "kind": 1, "language": "zh-HK"}]}