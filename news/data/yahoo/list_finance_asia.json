            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"581\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/CK8By_TbY.U6NGARxUZmqQ--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTU4OA--/https://media.zenfs.com/en/28hse_com_210/1b83da2b8ccf9c3115c93819ba82ccb1\" width=\"949\"/></div></figure></div>",
