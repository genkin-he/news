            "description": "<div class=\"atoms\"><figure class=\"mb-module-gap\"><div class=\"mx-auto w-fit max-w-full\"><img alt=\"\" class=\"rounded-lg\" height=\"540\" loading=\"lazy\" src=\"https://s.yimg.com/ny/api/res/1.2/kXZADOX8jYliV3OojfISjg--/YXBwaWQ9aGlnaGxhbmRlcjt3PTk2MDtoPTU0MA--/https://media.zenfs.com/vi/28hse_com_210/dc40ed263518c2a26e7188170b9104f2\" width=\"960\"/></div></figure></div>",
