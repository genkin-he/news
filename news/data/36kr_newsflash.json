                    "widgetContent": "\u81ea\u201c\u5e76\u8d2d\u516d\u6761\u201d\u53d1\u5e03\u4ee5\u6765\uff0c\u5e76\u8d2d\u91cd\u7ec4\u5e02\u573a\u5448\u73b0\u84ec\u52c3\u751f\u673a\u3002\u636e\u7edf\u8ba1\uff0c\u622a\u81f37\u670815\u65e5\uff0c\u968f\u7740\u798f\u8fbe\u5408\u91d1\u3001\u4e2d\u5316\u88c5\u5907\u62ab\u9732\u91cd\u7ec4\u76f8\u5173\u516c\u544a\uff0c\u201c\u5e76\u8d2d\u516d\u6761\u201d\u53d1\u5e03\u540e\u5168\u5e02\u573a\u65b0\u589e\u62ab\u9732\u91cd\u5927\u8d44\u4ea7\u91cd\u7ec4\u9879\u76ee\u5df2\u8fbe200\u5355\u3002\u4ea4\u6613\u6d3b\u8dc3\u5ea6\u663e\u8457\u63d0\u5347\u7684\u540c\u65f6\uff0c\u652f\u4ed8\u65b9\u5f0f\u591a\u5143\u5316\u6210\u4e3a\u672c\u8f6e\u5e76\u8d2d\u91cd\u7ec4\u7684\u7a81\u51fa\u7279\u5f81\u3002\uff08\u4e0a\u8bc1\u62a5\uff09",
