                    "widgetContent": "36\u6c2a\u83b7\u6089\uff0c7\u670826\u65e52025\u4e16\u754c\u4eba\u5de5\u667a\u80fd\u5927\u4f1a(WAIC)\u5f00\u5e55\u9996\u65e5\uff0c\u534e\u9cb2\u632f\u5b87\u53d1\u5e03\u57fa\u4e8e\u534e\u9cb2\u5143\u542fAI\u5f00\u53d1\u8d4b\u80fd\u5e73\u53f0\u7684\u653f\u52a1\u3001\u533b\u7597\u7b49\u8d8520\u4e2a\u884c\u4e1a\u667a\u80fd\u4f53\u5e94\u7528\u3002\u534e\u9cb2\u632f\u5b87\u526f\u603b\u88c1\u5b8b\u65cb\u8868\u793a:\u201c\u534e\u9cb2\u5143\u542fAI\u5f00\u53d1\u8d4b\u80fd\u5e73\u53f0\u76ee\u524d\u5df2\u6210\u529f\u670d\u52a1\u8d85\u8fc7500\u5bb6\u653f\u4f01\u5ba2\u6237\u3002\u5176\u4e2d\uff0c\u653f\u52a1\u3001\u533b\u7597\u3001\u5927\u4f01\u4e1a\u4ee5\u53ca\u91d1\u878d\u884c\u4e1a\u53cd\u9988\u5c24\u4e3a\u7a81\u51fa\uff0c\u4e3b\u8981\u539f\u56e0\u5728\u4e8e\u8fd9\u4e9b\u884c\u4e1a\u666e\u904d\u9762\u4e34\u4eba\u529b\u8d44\u6e90\u4e0d\u8db3\u7684\u95ee\u9898\u3002\u201d",
