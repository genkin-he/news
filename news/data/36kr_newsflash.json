                    "widgetImage": "",
                    "publishTime": 1757151037000,
                    "widgetTitle": "2024\u5e74\u5168\u56fd\u5546\u6807\u8d28\u62bc\u878d\u8d44\u767b\u8bb0\u91d1\u989d\u8d853000\u4ebf\u5143",
                    "widgetContent": "\u592e\u89c6\u8bb0\u80059\u67086\u65e5\u4ece\u7b2c\u5341\u4e94\u5c4a\u4e2d\u56fd\u56fd\u9645\u5546\u6807\u54c1\u724c\u8282\u4e0a\u83b7\u6089\uff0c\u8fd1\u5e74\u6765\uff0c\u6211\u56fd\u6301\u7eed\u52a0\u5f3a\u5546\u6807\u54c1\u724c\u5de5\u4f5c\uff0c\u6253\u9020\u4e00\u6279\u4ee5\u79d1\u6280\u521b\u65b0\u4e3a\u652f\u6491\u7684\u77e5\u540d\u5546\u6807\u54c1\u724c\uff0c2024\u5e74\u5168\u56fd\u5546\u6807\u8d28\u62bc\u878d\u8d44\u767b\u8bb0\u91d1\u989d\u8d85\u8fc73000\u4ebf\u5143\u3002\u6211\u56fd\u63a8\u8fdb\u4fee\u8ba2\u5546\u6807\u6ce8\u518c\u7533\u8bf7\u5feb\u901f\u5ba1\u67e5\u6709\u5173\u89c4\u5b9a\uff0c\u5b8c\u5584\u5ba1\u67e5\u673a\u5236\uff0c\u4e30\u5bcc\u653f\u7b56\u4f9b\u7ed9\u3002\u63a8\u52a8\u5efa\u8bbe5100\u4f59\u4e2a\u5546\u6807\u54c1\u724c\u6307\u5bfc\u7ad9\uff0c\u5168\u5e74\u670d\u52a1\u4f01\u4e1a\u8d8560\u4e07\u6b21\uff0c\u4e3a\u7ecf\u8425\u4e3b\u4f53\u63d0\u4f9b\u4fbf\u5229\u5316\u7684\u5546\u6807\u54c1\u724c\u516c\u5171\u670d\u52a1\u3002\u6b64\u5916\uff0c\u6211\u56fd\u79ef\u6781\u63a8\u52a8\u4e2d\u56fd\u54c1\u724c\u201c\u8d70\u51fa\u53bb\u201d\uff0c2024\u5e74\u4e2d\u56fd\u7533\u8bf7\u4eba\u63d0\u4ea4\u7684\u9a6c\u5fb7\u91cc\u5546\u6807\u56fd\u9645\u6ce8\u518c\u7533\u8bf75828\u4ef6\uff0c\u6bd4\u4e0a\u5e74\u589e\u957f6.3%\uff0c\u8fde\u7eed\u591a\u5e74\u4f4d\u5c45\u4e16\u754c\u7b2c\u4e09\u3002\u4e16\u754c\u77e5\u8bc6\u4ea7\u6743\u7ec4\u7ec7\u62a5\u544a\u663e\u793a\uff0c2024\u5e74\u5168\u7403\u524d5000\u4e2a\u54c1\u724c\u4e2d\uff0c\u4e2d\u56fd\u7684\u54c1\u724c\u4ef7\u503c\u8fbe1.76\u4e07\u4ebf\u7f8e\u5143\uff0c\u4f4d\u5c45\u5168\u7403\u7b2c\u4e8c\uff0c\u4e2d\u56fd\u54c1\u724c\u56fd\u9645\u5f71\u54cd\u529b\u8fdb\u4e00\u6b65\u589e\u5f3a\u3002\uff08\u592e\u89c6\u65b0\u95fb\uff09",
                    "hasRed": 0,
