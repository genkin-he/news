                    "widgetTitle": "\u6625\u8282\u571f\u8033\u5176\u8ddf\u56e2\u6e38\u7206\u5355",
                    "widgetContent": "\u8fc7\u53bb\u4e00\u5e74\uff0c\u8bb8\u591a\u56fd\u5bb6\u9646\u7eed\u5ba3\u5e03\u5bf9\u4e2d\u56fd\u516c\u6c11\u514d\u7b7e\u3002\u81ea2026\u5e741\u67082\u65e5\u8d77\uff0c\u571f\u8033\u5176\u5bf9\u4e2d\u56fd\u516c\u6c11\u5b9e\u65bd\u514d\u7b7e\u5165\u5883\u653f\u7b56\u3002\u4e2d\u56fd\u6e38\u5ba2\u5bf9\u571f\u8033\u5176\u7684\u5173\u6ce8\u5ea6\u8fc5\u901f\u98d9\u5347\uff0c\u4e0d\u5c11\u4eba\u9009\u62e9\u6765\u4e00\u573a\u201c\u8bf4\u8d70\u5c31\u8d70\u201d\u7684\u65c5\u884c\u3002\u6709\u65c5\u884c\u793e\u5de5\u4f5c\u4eba\u5458\u544a\u8bc9\u8bb0\u8005\uff0c\u8fd1\u671f\u571f\u8033\u5176\u65c5\u6e38\u7684\u54a8\u8be2\u91cf\u73af\u6bd4\u589e\u957f\u8d85\u4e24\u500d\uff0c\u6625\u8282\u671f\u95f4\u51fa\u53d1\u571f\u8033\u5176\u7684\u8ddf\u56e2\u6e38\u4ea7\u54c1\u5df2\u57fa\u672c\u552e\u7f44\u3002\uff08\u592e\u89c6\u8d22\u7ecf\uff09",
