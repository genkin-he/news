                    "widgetContent": "\u7279\u65af\u62c9\u5b98\u65b9\u8868\u793a\uff0c\u5176\u9502\u7cbe\u70bc\u5382\u5728\u8bbe\u8ba1\u4e0a\u78b3\u8db3\u8ff9\u8fdc\u4f4e\u4e8e\u4f20\u7edf\u786c\u5ca9\u9502\u7cbe\u70bc\u5382\uff1a\u65e0\u9178\u7cbe\u70bc\u5de5\u827a\u6709\u52a9\u4e8e\u4ea7\u51fa\u5b89\u5168\u7684\u526f\u4ea7\u54c1\uff1b\u751f\u4ea7\u5168\u8fc7\u7a0b\u5b9e\u73b0\u6c34\u5faa\u73af\u5229\u7528\uff0c\u6bcf\u4e00\u6ef4\u6c34\u5747\u5728\u5382\u533a\u5185\u5904\u7406\u51c0\u5316\uff1b\u65e8\u5728\u4e3a\u7535\u6c60\u4f9b\u5e94\u94fe\u6784\u5efa\u9502\u8d44\u6e90\u95ed\u73af\u4f53\u7cfb\u3002\u9a6c\u65af\u514b\u8f6c\u53d1\u76f8\u5173\u5185\u5bb9\u5e76\u8868\u793a\uff0c\u7279\u65af\u62c9\u5de5\u7a0b\u56e2\u961f\u4ece\u7269\u7406\u5b66\u7b2c\u4e00\u539f\u7406\u51fa\u53d1\uff0c\u91cd\u65b0\u8bbe\u8ba1\u4e86\u9502\u63d0\u70bc\u5de5\u827a\u3002\uff08\u65b0\u6d6a\u8d22\u7ecf\uff09",
