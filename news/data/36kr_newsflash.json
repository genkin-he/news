                    "widgetTitle": "\u96f7\u519b\uff1a\u9884\u8ba1\u5c0f\u7c73\u4eca\u5e74\u5c06\u7ee7\u7eed\u4fdd\u630130%\u4ee5\u4e0a\u589e\u901f",
                    "widgetContent": "\u57282\u670814\u65e52025\u6d77\u6dc0\u533a\u7ecf\u6d4e\u793e\u4f1a\u9ad8\u8d28\u91cf\u53d1\u5c55\u5927\u4f1a\u4e0a\uff0c\u5c0f\u7c73\u96c6\u56e2\u521b\u59cb\u4eba\u3001\u8463\u4e8b\u957f\u517cCEO\u96f7\u519b\u53d1\u8868\u4e86\u4e3b\u9898\u6f14\u8bb2\u96f7\u519b\u8868\u793a\uff0c\u8fc7\u53bb15\u5e74\uff0c\u5c0f\u7c73\u6293\u4f4f\u4e86\u65f6\u4ee3\u7684\u673a\u9047\uff0c\u4fdd\u6301\u4e86\u9ad8\u901f\u589e\u957f\u3002\u4f46\u4e5f\u66fe\u906d\u9047\u53d1\u5c55\u74f6\u9888\uff0c\u57282022\u5e74\u548c2023\u5e74\u8fde\u7eed\u4e24\u5e74\u8d1f\u589e\u957f\uff0c\u5185\u5916\u538b\u529b\u5de8\u5927\u3002\u5c0f\u7c73\u5728\u53bb\u5e74\u91cd\u65b0\u6062\u590d\u4e86\u9ad8\u901f\u589e\u957f\uff0c\u589e\u901f\u8d85\u8fc730%\uff0c\u5e76\u9884\u8ba1\u4eca\u5e74\u5c06\u7ee7\u7eed\u4fdd\u630130%\u4ee5\u4e0a\u7684\u589e\u957f\u901f\u5ea6\u3002\uff08\u8d22\u8054\u793e\uff09",
