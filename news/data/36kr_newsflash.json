                    "widgetContent": "\u4fdd\u9669\u8d44\u91d1\u914d\u7f6e\u6743\u76ca\u8d44\u4ea7\u6301\u7eed\u63a8\u8fdb\u3002\u636e\u7edf\u8ba1\uff0c\u4eca\u5e74\u4ee5\u6765\uff0c6\u5bb6\u4fdd\u9669\u516c\u53f8\u5171\u53d1\u5e0311\u6b21\u4e3e\u724c\u516c\u544a\uff0c\u4e3e\u724c\u6b21\u6570\u8d85\u8fc7\u53bb\u5e74\u540c\u671f\uff0c\u4e14\u5df2\u8d85\u8fc72023\u5e74\u5168\u5e74\uff0c\u521b\u4e0b\u5355\u5b63\u4e3e\u724c\u6570\u91cf\u65b0\u9ad8\u3002\u636e\u4e86\u89e3\uff0c\u591a\u5bb6\u9669\u4f01\u76f8\u5173\u8d1f\u8d23\u4eba\u8ba4\u4e3a\u4eca\u5e74\u80a1\u5e02\u5b58\u5728\u7ed3\u6784\u6027\u673a\u4f1a\uff0c\u9884\u8ba1\u6743\u76ca\u6295\u8d44\u6bd4\u4f8b\u5c06\u9002\u5ea6\u63d0\u5347\u3002\uff08\u8bc1\u5238\u65f6\u62a5\uff09",
