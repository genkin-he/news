                    "widgetTitle": "\u4fc4\u822a\u5929\u96c6\u56e2\u8d1f\u8d23\u4eba\uff1a\u6b63\u4e0e\u7f8e\u65b9\u8ba8\u8bba\u56fd\u9645\u7a7a\u95f4\u7ad9\u9879\u76ee\u7ed3\u675f\u540e\u8f68\u9053\u534f\u4f5c\u4e8b\u5b9c",
                    "widgetContent": "8\u670824\u65e5\uff0c\u4fc4\u7f57\u65af\u56fd\u5bb6\u822a\u5929\u96c6\u56e2\u8d1f\u8d23\u4eba\u5fb7\u7c73\u7279\u91cc\u00b7\u5df4\u5361\u8bfa\u592b\u63a5\u53d7\u91c7\u8bbf\u65f6\u8868\u793a\uff0c\u7f8e\u56fd\u56fd\u5bb6\u822a\u7a7a\u822a\u5929\u5c40\uff08NASA\uff09\u66fe\u8ba1\u5212\u52a0\u901f\u9000\u51fa\u56fd\u9645\u7a7a\u95f4\u7ad9\u9879\u76ee\u5e76\u4e8e2026\u5e74\u5bf9\u5176\u5b9e\u65bd\u53d7\u63a7\u5760\u6bc1\uff0c\u4f46\u5728\u4e0e\u4fc4\u7f57\u65af\u56fd\u5bb6\u822a\u5929\u96c6\u56e2\u8c08\u5224\u540e\u51b3\u5b9a\u5c06\u8be5\u9879\u76ee\u5ef6\u7eed\u81f32028\u5e74\uff0c\u5e76\u5171\u540c\u63a8\u8fdb\u56fd\u9645\u7a7a\u95f4\u7ad9\u57282030\u5e74\u524d\u8131\u8f68\u5de5\u4f5c\u3002\u4eca\u5e747\u670831\u65e5\uff0c\u4fc4\u7f8e\u822a\u5929\u673a\u6784\u8d1f\u8d23\u4eba\u4e3e\u884c\u4e862018\u5e74\u4ee5\u6765\u7684\u9996\u6b21\u4f1a\u8c08\uff0c\u8ba8\u8bba\u4e86\u56fd\u9645\u7a7a\u95f4\u7ad9\u7684\u540e\u7eed\u5de5\u4f5c\u3002\uff08\u592e\u89c6\u65b0\u95fb\uff09",
