                    "widgetTitle": "\u56fd\u5bb6\u7f51\u4fe1\u529e\u7b49\u4e94\u90e8\u95e8\uff1a\u652f\u6301\u7b97\u6cd5\u3001\u6846\u67b6\u3001\u82af\u7247\u7b49\u6280\u672f\u7684\u81ea\u4e3b\u521b\u65b0\uff0c\u63a8\u8fdb\u62df\u4eba\u5316\u4e92\u52a8\u670d\u52a1\u6280\u672f\u7814\u53d1\u548c\u76f8\u5173\u6807\u51c6\u5efa\u8bbe",
                    "widgetContent": "36\u6c2a\u83b7\u6089\uff0c\u300a\u4eba\u5de5\u667a\u80fd\u62df\u4eba\u5316\u4e92\u52a8\u670d\u52a1\u7ba1\u7406\u6682\u884c\u529e\u6cd5\u300b\u7b54\u8bb0\u8005\u95ee\u3002\u300a\u529e\u6cd5\u300b\u63d0\u51fa\uff0c\u9f13\u52b1\u62df\u4eba\u5316\u4e92\u52a8\u670d\u52a1\u521b\u65b0\u53d1\u5c55\uff0c\u652f\u6301\u7b97\u6cd5\u3001\u6846\u67b6\u3001\u82af\u7247\u7b49\u6280\u672f\u7684\u81ea\u4e3b\u521b\u65b0\uff0c\u63a8\u8fdb\u62df\u4eba\u5316\u4e92\u52a8\u670d\u52a1\u6280\u672f\u7814\u53d1\u548c\u76f8\u5173\u6807\u51c6\u5efa\u8bbe\uff0c\u63a2\u7d22\u5f00\u5c55\u7535\u5b50\u7b7e\u540d\u6388\u6743\u5e94\u7528\u7814\u7a76\uff1b\u9f13\u52b1\u62df\u4eba\u5316\u4e92\u52a8\u670d\u52a1\u63d0\u4f9b\u8005\u6709\u5e8f\u62d3\u5c55\u6587\u5316\u4f20\u64ad\u3001\u9002\u5e7c\u7167\u62a4\u3001\u9002\u8001\u966a\u4f34\u3001\u7279\u6b8a\u4eba\u7fa4\u652f\u6301\u7b49\u9886\u57df\u5e94\u7528\uff1b\u660e\u786e\u52a0\u5f3a\u62df\u4eba\u5316\u4e92\u52a8\u670d\u52a1\u5b89\u5168\u77e5\u8bc6\u3001\u6cd5\u5f8b\u6cd5\u89c4\u7b49\u5ba3\u4f20\u666e\u53ca\uff0c\u5f15\u5bfc\u793e\u4f1a\u516c\u4f17\u79d1\u5b66\u3001\u6587\u660e\u3001\u5b89\u5168\u3001\u4f9d\u6cd5\u4f7f\u7528\uff0c\u4fc3\u8fdb\u63d0\u5347\u4eba\u5de5\u667a\u80fd\u7d20\u517b\u3002\u540c\u65f6\uff0c\u660e\u786e\u63a8\u52a8\u4eba\u5de5\u667a\u80fd\u6c99\u7bb1\u5b89\u5168\u670d\u52a1\u5e73\u53f0\u5efa\u8bbe\uff0c\u9f13\u52b1\u62df\u4eba\u5316\u4e92\u52a8\u670d\u52a1\u63d0\u4f9b\u8005\u63a5\u5165\u6c99\u7bb1\u5e73\u53f0\u8fdb\u884c\u6280\u672f\u521b\u65b0\u3001\u5b89\u5168\u6d4b\u8bd5\uff0c\u4fc3\u8fdb\u62df\u4eba\u5316\u4e92\u52a8\u670d\u52a1\u5b89\u5168\u6709\u5e8f\u53d1\u5c55\u3002",
