                    "widgetTitle": "\u5546\u52a1\u90e8\u56de\u5e94\u7f8e\u4e0a\u8c03\u94a2\u94dd\u5173\u7a0e\uff1a\u6566\u4fc3\u7f8e\u65b9\u505c\u6b62\u6cdb\u5316\u548c\u6ee5\u7528\u56fd\u5bb6\u5b89\u5168\u6982\u5ff5",
                    "widgetContent": "\u4eca\u5929\u4e0b\u5348\uff0c\u5546\u52a1\u90e8\u4e3e\u884c\u4f8b\u884c\u65b0\u95fb\u53d1\u5e03\u4f1a\uff0c\u5546\u52a1\u90e8\u53d1\u8a00\u4eba\u4ecb\u7ecd\u8fd1\u671f\u5546\u52a1\u9886\u57df\u91cd\u70b9\u5de5\u4f5c\u6709\u5173\u60c5\u51b5\u3002\u6709\u8bb0\u8005\u63d0\u95ee\uff0c\u7f8e\u56fd\u5c06\u8fdb\u53e3\u7684\u94a2\u94dd\u4ee5\u53ca\u5176\u884d\u751f\u54c1\u5173\u7a0e\u4ece25%\u63d0\u9ad8\u523050%\uff0c\u653f\u7b56\u57284\u65e5\u5df2\u7ecf\u6b63\u5f0f\u751f\u6548\uff0c\u8bf7\u95ee\u5546\u52a1\u90e8\u6709\u4f55\u8bc4\u8bba\uff1f\u5546\u52a1\u90e8\u53d1\u8a00\u4eba\u4f55\u548f\u524d\u8868\u793a\uff0c\u4e2d\u65b9\u5df2\u591a\u6b21\u5f3a\u8c03242\u5173\u7a0e\u662f\u5178\u578b\u7684\u5355\u8fb9\u4e3b\u4e49\u548c\u4fdd\u62a4\u4e3b\u4e49\u884c\u5f84\uff0c\u65e9\u5df2\u88ab\u4e16\u8d38\u7ec4\u7ec7\u4e89\u7aef\u89e3\u51b3\u673a\u5236\u88c1\u5b9a\u8fdd\u53cd\u4e16\u8d38\u89c4\u5219\uff0c\u6b64\u6b21\u7f8e\u65b9\u518d\u4e00\u6b21\u63d0\u9ad8\u94a2\u94dd\u53ca\u5176\u884d\u751f\u5236\u54c1\u5173\u7a0e\uff0c\u4e0d\u4ec5\u635f\u4eba\u5bb3\u5df1\uff0c\u65e0\u52a9\u4e8e\u7ef4\u62a4\u4ea7\u4e1a\u5b89\u5168\uff0c\u8fd8\u5c06\u4e25\u91cd\u6270\u4e71\u5168\u7403\u4ea7\u4e1a\u94fe\u4f9b\u5e94\u94fe\u7a33\u5b9a\uff0c\u7f8e\u65b9\u505a\u6cd5\u5df2\u906d\u5230\u591a\u4e2a\u56fd\u5bb6\u53cd\u5bf9\u3002\u4e2d\u65b9\u6566\u4fc3\u7f8e\u65b9\uff0c\u5c0a\u91cd\u7ecf\u6d4e\u89c4\u5f8b\uff0c\u6452\u5f03\u96f6\u548c\u601d\u7ef4\uff0c\u505c\u6b62\u6cdb\u5316\u548c\u6ee5\u7528\u56fd\u5bb6\u5b89\u5168\u6982\u5ff5\uff0c\u4e0e\u5404\u65b9\u4e00\u9053\u7ef4\u62a4\u4ee5\u89c4\u5219\u4e3a\u57fa\u7840\u7684\u591a\u8fb9\u8d38\u6613\u4f53\u5236\uff0c\u901a\u8fc7\u5e73\u7b49\u5bf9\u8bdd\u89e3\u51b3\u5404\u81ea\u5173\u5207\uff0c\u5171\u540c\u7ef4\u62a4\u5168\u7403\u4ea7\u4e1a\u94fe\u4f9b\u5e94\u94fe\u7a33\u5b9a\u3002\uff08\u592e\u89c6\u65b0\u95fb\uff09",
