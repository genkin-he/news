                    "widgetTitle": "\u6469\u6839\u58eb\u4e39\u5229\u7b56\u7565\u5e08Wilson\uff1a\u7f8e\u80a1\u4eca\u5e74\u4e0a\u534a\u5e74\u4e0d\u4f1a\u518d\u521b\u65b0\u9ad8\u4e86",
                    "widgetContent": "\u6469\u6839\u58eb\u4e39\u5229\u7684Michael Wilson\u8868\u793a\uff0c2025\u5e74\u56f0\u6270\u534e\u5c14\u8857\u7684\u7f8e\u80a1\u5267\u70c8\u6ce2\u52a8\u53ef\u80fd\u81f3\u5c11\u6301\u7eed\u5230\u4eca\u5e74\u4e0b\u534a\u5e74\uff0c\u80a1\u4ef7\u9884\u8ba1\u5c06\u7ef4\u6301\u5728\u4e0a\u4e2a\u6708\u89e6\u53ca\u7684\u9ad8\u70b9\u4e4b\u4e0b\u3002\u8be5\u516c\u53f8\u7684\u9996\u5e2d\u7f8e\u80a1\u7b56\u7565\u5e08\u9884\u8ba1\uff0c\u9274\u4e8e\u4f01\u4e1a\u548c\u7ecf\u6d4e\u589e\u957f\u524d\u666f\u7b3c\u7f69\u5728\u4e0d\u786e\u5b9a\u6027\u4e4b\u4e0b\uff0c\u4efb\u4f55\u8fd1\u671f\u7684\u4e0a\u6da8\u90fd\u662f\u6682\u65f6\u7684\uff0c\u5e76\u4e14\u6da8\u52bf\u7531\u4f4e\u8d28\u91cf\u7684\u516c\u53f8\u5f15\u9886\u3002\u201c\u6211\u7684\u6700\u4f73\u731c\u6d4b\u662f\u8fd9\u5c06\u662f\u6eda\u52a8\u5f0f\u590d\u82cf\uff0c\u201dWilson\u5468\u56db\u5728\u63a5\u53d7\u91c7\u8bbf\u65f6\u8868\u793a\uff0c\u201c\u6211\u4eec\u8ba4\u4e3a\u4eca\u5e74\u4e0a\u534a\u5e74\u4e0d\u592a\u53ef\u80fd\u518d\u521b\u65b0\u9ad8\u3002\u201d\u4f46\u4ed6\u8865\u5145\u8bf4\u968f\u7740\u6295\u8d44\u8005\u5c06\u6ce8\u610f\u529b\u8f6c\u54112026\u5e74\uff0c\u80a1\u5e02\u57282025\u5e74\u4e0b\u534a\u5e74\u518d\u521b\u7eaa\u5f55\u9ad8\u4f4d\u662f\u6709\u53ef\u80fd\u7684\u3002\uff08\u65b0\u6d6a\u8d22\u7ecf\uff09",
