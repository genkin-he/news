                    "widgetTitle": "\u4e1a\u5185\u8ba4\u4e3a\uff1a\u975e\u4eac\u7c4d\u8d2d\u623f\u95e8\u69db\u518d\u964d\uff0c\u9884\u8ba1\u6caa\u6df1\u7b49\u57ce\u5e02\u5c06\u8ddf\u8fdb\u8c03\u6574",
                    "widgetContent": "\u7ee7\u4eca\u5e748\u6708\u4e94\u73af\u5916\u9650\u8d2d\u8c03\u6574\u540e\uff0c\u5317\u4eac\u518d\u4e00\u6b21\u5bf9\u697c\u5e02\u8c03\u63a7\u8fdb\u4e00\u6b65\u4f18\u5316\u300212\u670824\u65e5\uff0c\u5317\u4eac\u51fa\u53f0\u300a\u5173\u4e8e\u8fdb\u4e00\u6b65\u4f18\u5316\u8c03\u6574\u672c\u5e02\u623f\u5730\u4ea7\u76f8\u5173\u653f\u7b56\u7684\u901a\u77e5\u300b\uff08\u4ee5\u4e0b\u7b80\u79f0\u300a\u901a\u77e5\u300b\uff09\uff0c\u653e\u5bbd\u975e\u4eac\u7c4d\u8d2d\u623f\u4eba\u7fa4\u9650\u8d2d\u653f\u7b56\uff0c\u5546\u4e1a\u6027\u4f4f\u623f\u8d37\u6b3e\u5229\u7387\u5c06\u4e0d\u518d\u533a\u5206\u9996\u5957\u4f4f\u623f\u548c\u4e8c\u5957\u4f4f\u623f\uff0c\u516c\u79ef\u91d1\u4e8c\u5957\u623f\u6700\u4f4e\u9996\u4ed8\u6bd4\u4f8b\u753130%\u6539\u4e3a25%\u3002\u4e1a\u5185\u8ba4\u4e3a\uff0c\u6838\u5fc3\u57ce\u5e02\u5728\u7a33\u5b9a\u5168\u56fd\u5e02\u573a\u4e2d\u626e\u6f14\u7740\u201c\u538b\u8231\u77f3\u201d\u548c\u201c\u9886\u5934\u7f8a\u201d\u7684\u53cc\u91cd\u89d2\u8272\uff0c\u4e00\u7ebf\u57ce\u5e02\u52a0\u5165\u653f\u7b56\u4f18\u5316\u884c\u5217\uff0c\u610f\u5473\u7740\u201c\u56e0\u57ce\u65bd\u7b56\u201d\u7684\u6df1\u5ea6\u548c\u5e7f\u5ea6\u6b63\u5728\u62d3\u5c55\u3002\u5317\u4eac\u4e4b\u540e\uff0c\u9884\u8ba1\u6caa\u6df1\u7b49\u57ce\u5e02\u5c06\u8ddf\u8fdb\u8c03\u6574\u3002\uff08\u4e2d\u56fd\u7ecf\u8425\u62a5\uff09",
