                    "widgetTitle": "\u7f51\u4f20\u8305\u53f0\u6279\u4ef7\u8dcc\u78341499\u5143\uff1f \u591a\u5730\u9152\u5546\uff1a\u8fd9\u4e2a\u4ef7\u683c\u6839\u672c\u62ff\u4e0d\u5230\u8d27",
                    "widgetContent": "\u636e\u62a5\u9053\uff0c2025\u5e74\u98de\u5929\u8305\u53f0\uff08\u6563\u74f6\uff09\u5df2\u4f4e\u4e8e1499\u5143\u7684\u5b98\u65b9\u6307\u5bfc\u4ef7\u3002\u5bf9\u4e8e\u8be5\u60c5\u51b5\u8be2\u95ee\u4e86\u591a\u5730\u9152\u5546\u53ca\u76f8\u5173\u6e20\u9053\uff0c\u591a\u4eba\u8868\u793a\uff0c\u201c1499\u5143\u4ee5\u4e0b\u6839\u672c\u62ff\u4e0d\u5230\u8d27\u201d\uff0c\u76ee\u524d2025\u5e74\u98de\u5929\u8305\u53f0\uff08\u6563\u74f6\uff09\u7684\u6700\u65b0\u6279\u4ef7\u7ea6\u4e3a1530\u5143\u3002\u8fd8\u6709\u9152\u5546\u5f3a\u8c03\uff1a\u201c\u884c\u60c5\u6ca1\u6709\u90a3\u4e48\u4f4e\u3002\u5317\u4eac\u5730\u533a\u76ee\u524d\u7684\u6279\u53d1\u4ef7\u7a33\u5b9a\u57281600\u5143\u20141700\u5143\u533a\u95f4\u3002\u201d\uff08\u65b0\u6d6a\u8d22\u7ecf\uff09",
