                    "widgetContent": "\u534e\u7199\u751f\u7269\u5b98\u65b9\u5fae\u535a\u53d1\u5e03\u300a\u5173\u4e8e\u7f51\u7edc\u4e0d\u5b9e\u4fe1\u606f\u7684\u4e25\u6b63\u58f0\u660e\u300b \u79f0\uff0c\u6628\u65e5\u665a\u95f4\u53d1\u73b0\u90e8\u5206\u7f51\u7edc\u5e73\u53f0\u7528\u6237\u53d1\u5e03\u5173\u4e8e\u516c\u53f8\u7684\u4e25\u91cd\u4e0d\u5b9e\u4fe1\u606f\u3002\u7ecf\u6838\u5b9e\uff0c\u4fe1\u606f\u53d1\u5e03\u4e8e\u5883\u5916\u7f51\u7ad9\uff0c\u5185\u5bb9\u7eaf\u5c5e\u634f\u9020\uff0c\u6076\u610f\u6b6a\u66f2\u4e8b\u5b9e\uff0c\u5176\u4e2d\u90e8\u5206\u5185\u5bb9\u6d89\u53ca\u653f\u6cbb\u8c23\u8a00\uff0c\u6027\u8d28\u6781\u5176\u6076\u52a3\u3002\u7ecf\u67e5\uff0c\u8be5\u4fe1\u606f\u53d1\u5e03\u8005\u674e\u67d0\u66fe\u4efb\u534e\u7199\u6615\u5b87\u6295\u8d44\u6709\u9650\u516c\u53f8\u5e02\u573a\u90e8\u603b\u76d1\uff0c\u4e8b\u53d1\u524d\u66fe\u5728\u534e\u7199\u5de5\u4f5c18\u4e2a\u6708\u3002\uff08\u8d22\u8054\u793e\uff09",
