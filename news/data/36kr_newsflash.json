                    "widgetImage": "",
                    "publishTime": 1756078318000,
                    "widgetTitle": "\u5168\u5e02\u573aETF\u603b\u89c4\u6a21\u5df2\u7a81\u78344.9\u4e07\u4ebf\u5143\uff0c\u8f83\u53bb\u5e74\u5e74\u672b\u589e\u52a0\u903e\u4e07\u4ebf\u5143",
