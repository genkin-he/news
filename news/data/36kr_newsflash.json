                    "widgetTitle": "\u970d\u5c14\u6728\u5179\u6d77\u5ce1\u91cd\u5f00 \u56fd\u9645\u91d1\u94f6\u4ef7\u683c\u5927\u6da8",
                    "widgetContent": "\u5f53\u5730\u65f6\u95f417\u65e5\uff0c\u4f0a\u6717\u65b9\u9762\u5ba3\u5e03\u5411\u6240\u6709\u5546\u8239\u5f00\u653e\u970d\u5c14\u6728\u5179\u6d77\u5ce1\u3002\u968f\u540e\uff0c\u56fd\u9645\u9ec4\u91d1\u3001\u767d\u94f6\u4ef7\u683c\u5927\u6da8\u3002\u7f8e\u56fd\u4e1c\u90e8\u65f6\u95f417\u65e5\u4e0a\u5348\uff0c\u7ebd\u7ea6\u5546\u54c1\u4ea4\u6613\u62406\u6708\u9ec4\u91d1\u671f\u4ef7\u6da8\u5e45\u4e00\u5ea6\u63a5\u8fd12%\uff0c5\u6708\u767d\u94f6\u671f\u4ef7\u6da8\u5e45\u4e00\u5ea6\u8d85\u8fc74%\u3002\u5206\u6790\u4eba\u58eb\u8ba4\u4e3a\uff0c\u4f0a\u65b9\u8fd9\u4e00\u58f0\u660e\u5f15\u53d1\u56fd\u9645\u6cb9\u4ef7\u5927\u8dcc\uff0c\u77ed\u671f\u5185\u6709\u52a9\u4e8e\u7f13\u89e3\u901a\u80c0\u538b\u529b\uff0c\u540c\u65f6\u63d0\u632f\u5e02\u573a\u60c5\u7eea\uff0c\u524a\u5f31\u5bf9\u7f8e\u5143\u7684\u9700\u6c42\u3002\u7531\u4e8e\u7f8e\u5143\u8d70\u5f31\u3001\u6cb9\u4ef7\u5927\u8dcc\uff0c\u91d1\u94f6\u4ef7\u683c\u4e0a\u6da8\u660e\u663e\u3002\uff08\u8bc1\u5238\u65f6\u62a5\uff09",
