                    "widgetImage": "",
                    "publishTime": 1745040547013,
                    "widgetTitle": "\u6211\u56fd\u79d1\u5b66\u5bb6\u201c\u642d\u79ef\u6728\u201d\u642d\u51fa9\u5398\u7c73\u5fae\u578b\u65e0\u7ebf\u9646\u7a7a\u4e24\u6816\u673a\u5668\u4eba",
                    "widgetContent": "\u6e05\u534e\u5927\u5b66\u79d1\u7814\u56e2\u961f\u6700\u65b0\u7814\u5236\u51fa\u4e00\u79cd\u8584\u819c\u72b6\u7684\u5fae\u578b\u9a71\u52a8\u5668\uff0c\u53ef\u50cf\u201c\u53d8\u5f62\u91d1\u521a\u201d\u4e00\u822c\u8ba9\u5fae\u578b\u673a\u5668\u4eba\u5b9e\u73b0\u8fde\u7eed\u5f62\u72b6\u53d8\u5316\u4e14\u201c\u9501\u5b9a\u201d\u5176\u7279\u5b9a\u52a8\u4f5c\u5f62\u6001\uff0c\u63d0\u5347\u5176\u73af\u5883\u9002\u5e94\u80fd\u529b\u3002\u7814\u7a76\u4eba\u5458\u8868\u793a\uff0c\u5229\u7528\u6b64\u9a71\u52a8\u5668\u4ee5\u53ca\u56e2\u961f\u6784\u5efa\u7684\u4e00\u79cd\u201c\u642d\u79ef\u6728\u201d\u5f0f\u7684\u8bbe\u8ba1\u65b9\u6cd5\uff0c\u5236\u5907\u51fa\u4e86\u76ee\u524d\u5df2\u77e5\u4e16\u754c\u6700\u5c0f\u3001\u6700\u8f7b\u7684\u5fae\u578b\u65e0\u7ebf\u9646\u7a7a\u4e24\u6816\u673a\u5668\u4eba\uff0c\u5176\u4f53\u957f\u4e3a9\u5398\u7c73\u3001\u91cd25\u514b\u3002\u8be5\u6210\u679c4\u670818\u65e5\u665a\u5728\u7ebf\u53d1\u8868\u4e8e\u56fd\u9645\u6743\u5a01\u671f\u520a\u300a\u81ea\u7136\u2014\u673a\u5668\u667a\u80fd\u300b\u3002\uff08\u65b0\u534e\u793e\uff09",
