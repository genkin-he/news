                    "widgetContent": "\u968f\u7740\u5404\u56fd\u592e\u884c\u589e\u52a0\u9ec4\u91d1\u50a8\u5907\uff0c\u52a0\u4e0a\u5e02\u573a\u6761\u4ef6\u6709\u5229\u4e8e\u5f3a\u52b2\u9700\u6c42\uff0c\u5404\u673a\u6784\u666e\u904d\u5bf9\u9ec4\u91d1\u4ecd\u6301\u770b\u6da8\u6001\u5ea6\u3002\u5728\u9ad8\u91d1\u4ef7\u4e0b\uff0c\u56fd\u5185\u91d1\u77ff\u516c\u53f8\u4e1a\u7ee9\u53d7\u76ca\u660e\u663e\u3002\u5176\u4e2d\uff0cST\u76db\u5c6f\u3001\u6653\u7a0b\u79d1\u6280\u3001\u897f\u90e8\u9ec4\u91d1\u3001\u8d64\u5cf0\u9ec4\u91d1\u3001\u76db\u8fbe\u8d44\u6e90\u3001\u4e1c\u65b9\u9506\u4e1a\u9884\u8ba12024\u5e74\u51c0\u5229\u6da6\u589e\u5e45\u7ffb\u500d\uff08\u542b\u626d\u4e8f\uff09\u3002\u4ece\u6700\u65b0\u6536\u76d8\u4ef7\u6765\u770b\uff0c\u591a\u53ea\u9ec4\u91d1\u6982\u5ff5\u80a1\u4f30\u503c\u4f4e\u4e8e30\u500d\uff0c\u5176\u4e2dST\u76db\u5c6f\u4e0d\u8db310\u500d\u3002\u672c\u6708\u4ee5\u6765\uff0c\u673a\u6784\u8d44\u91d1\u52a0\u901f\u6d41\u5165\u4f4e\u4f30\u503c\u4e2a\u80a1\uff0c19\u53ea\u4e2a\u80a1\u83b7\u4ebf\u5143\u51c0\u4e70\u5165\uff0c\u5176\u4e2d\u7d2b\u91d1\u77ff\u4e1a\u3001\u6d1b\u9633\u94bc\u4e1a\u51c0\u4e70\u5165\u8d8510\u4ebf\u5143\u3002\u8d64\u5cf0\u9ec4\u91d1\u672c\u6708\u673a\u6784\u8d44\u91d1\u51c0\u4e70\u5165\u4e3a2.67\u4ebf\u5143\u3002\uff08\u8bc1\u5238\u65f6\u62a5\uff09",
