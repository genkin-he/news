                    "widgetImage": "",
                    "publishTime": 1752890345000,
                    "widgetTitle": "\u7279\u6717\u666e\u529b\u63a8\u5bf9\u6240\u6709\u6b27\u76df\u5546\u54c1\u5f81\u653615%-20%\u7684\u6700\u4f4e\u5173\u7a0e",
