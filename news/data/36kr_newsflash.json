                    "widgetTitle": "\u56fd\u6295\u8bc1\u5238\u7814\u7a76\u6240\u6240\u957f\u6362\u4eba \u8001\u5c06\u97e9\u6656\u63a5\u4efb",
                    "widgetContent": "\u8fd1\u65e5\uff0c\u56fd\u6295\u8bc1\u5238\u7814\u7a76\u4e1a\u52a1\u6761\u7ebf\u51fa\u73b0\u65b0\u7684\u4eba\u4e8b\u8c03\u6574\u3002\u5176\u4e2d\uff0c\u90b5\u7433\u7433\u4e0d\u518d\u62c5\u4efb\u56fd\u6295\u4ea7\u4e1a\u7814\u7a76\u9662\u8bc1\u5238\u7814\u7a76\u6240\u603b\u7ecf\u7406\uff08\u5373\u5916\u754c\u6240\u8a00\u201c\u8bc1\u5238\u7814\u7a76\u6240\u6240\u957f\u201d\uff09\uff0c\u8f6c\u4efb\u56fd\u6295\u4ea7\u4e1a\u7814\u7a76\u9662\u4ea7\u4e1a\u7814\u7a76\u6240\u603b\u7ecf\u7406\uff0c\u7531\u8be5\u516c\u53f8\u6218\u7565\u53d1\u5c55\u90e8\u603b\u7ecf\u7406\u97e9\u6656\u517c\u4efb\u56fd\u6295\u4ea7\u4e1a\u7814\u7a76\u9662\u6267\u884c\u9662\u957f\u3001\u8bc1\u5238\u7814\u7a76\u6240\u603b\u7ecf\u7406\u3002\u5c65\u5386\u663e\u793a\uff0c\u97e9\u6656\u662f\u56fd\u6295\u8bc1\u5238\u6210\u7acb\u4ee5\u6765\u7684\u8001\u5c06\uff0c\u6df1\u8015\u8bc1\u5238\u5e02\u573a\u8fd1\u4e09\u5341\u5e74\uff0c\u91d1\u878d\u4e13\u4e1a\u529f\u5e95\u624e\u5b9e\uff0c\u5c97\u4f4d\u5386\u7ec3\u4e30\u5bcc\uff0c\u5148\u540e\u62c5\u4efb\u56fd\u6295\u8bc1\u5238\uff08\u539f\u5b89\u4fe1\u8bc1\u5238\uff09\u8425\u4e1a\u90e8\u603b\u7ecf\u7406\u3001\u56fd\u8bc1\u56fd\u9645\u8463\u4e8b\u517c\u603b\u88c1\u3001\u56fd\u6295\u8bc1\u5238\u6218\u7565\u53d1\u5c55\u90e8\u603b\u7ecf\u7406\u7b49\u804c\u3002\u5bf9\u4e8e\u6b64\u6b21\u7814\u7a76\u4e1a\u52a1\u4eba\u4e8b\u8c03\u6574\uff0c\u56fd\u6295\u8bc1\u5238\u5bf9\u8bc1\u5238\u65f6\u62a5\u8bb0\u8005\u56de\u5e94\u79f0\uff0c\u8fd9\u662f\u6839\u636e\u8be5\u516c\u53f8\u5185\u90e8\u7ecf\u8425\u7ba1\u7406\u9700\u8981\uff0c\u505a\u51fa\u7684\u6b63\u5e38\u7684\u5de5\u4f5c\u8c03\u6574\u5b89\u6392\uff0c\u65e8\u5728\u8fdb\u4e00\u6b65\u5f3a\u5316\u7814\u7a76\u56e2\u961f\u7684\u4e13\u4e1a\u80fd\u529b\u548c\u7ba1\u7406\u6548\u80fd\u3002\u8be5\u516c\u53f8\u59cb\u7ec8\u91cd\u89c6\u4eba\u624d\u5efa\u8bbe\u548c\u7ba1\u7406\u6548\u80fd\u63d0\u5347\uff0c\u672a\u6765\uff0c\u5c06\u7ee7\u7eed\u79c9\u6301\u4e13\u4e1a\u3001\u521b\u65b0\u7684\u7406\u5ff5\uff0c\u4e3a\u5ba2\u6237\u548c\u884c\u4e1a\u63d0\u4f9b\u66f4\u9ad8\u8d28\u91cf\u7684\u7814\u7a76\u670d\u52a1\u3002\uff08\u8bc1\u5238\u65f6\u62a5\uff09",
