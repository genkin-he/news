            {
                "itemId": 3167513262861058,
                "itemType": 20,
                "templateMaterial": {
                    "itemId": 3167513262861058,
                    "templateType": 0,
                    "widgetImage": "",
                    "publishTime": 1739601666922,
                    "widgetTitle": "\u5317\u4eac\u6d77\u6dc0\u53d1\u5e03\u96c6\u6210\u7535\u8def\u4ea7\u4e1a\u65b0\u63aa\u65bd \u5355\u4e2a\u4f01\u4e1a\u8865\u8d34\u6700\u9ad81500\u4e07",
                    "widgetContent": "\u300a\u4e2d\u5173\u6751\u79d1\u5b66\u57ce\u96c6\u6210\u7535\u8def\u6d41\u7247\u8865\u8d34\u7533\u62a5\u6307\u5357\u300b2\u670814\u65e5\u57282025\u6d77\u6dc0\u533a\u7ecf\u6d4e\u793e\u4f1a\u9ad8\u8d28\u91cf\u53d1\u5c55\u5927\u4f1a\u4e0a\u6b63\u5f0f\u53d1\u5e03\uff0c\u9762\u5411\u6d77\u6dc0\u533a\u4ece\u4e8b\u96c6\u6210\u7535\u8def\u8bbe\u8ba1\u4e1a\u52a1\u7684\u4f01\u4e1a\uff0c\u652f\u6301\u96c6\u6210\u7535\u8def\u8bbe\u8ba1\u4f01\u4e1a\u5f00\u5c55\u591a\u9879\u76ee\u6676\u5706\uff08MPW\uff09\u6216\u5de5\u7a0b\u4ea7\u54c1\u9996\u8f6e\u6d41\u7247\uff08\u5168\u63a9\u819c\uff09\uff0c\u5355\u4e2a\u4f01\u4e1a\u8865\u8d34\u6700\u9ad81500\u4e07\u3002\u5728\u652f\u6301\u96c6\u6210\u7535\u8def\u8bbe\u8ba1\u4f01\u4e1a\u5f00\u5c55\u5de5\u7a0b\u4ea7\u54c1\u9996\u8f6e\u6d41\u7247\uff08\u5168\u63a9\u819c\uff09\u65b9\u9762\uff0c\u5bf9\u5883\u5185\u5f00\u5c55\u5148\u8fdb\u5236\u7a0b\uff0814nm\u53ca\u4ee5\u4e0b\uff09\u5de5\u7a0b\u4ea7\u54c1\u9996\u8f6e\u6d41\u7247\uff08\u5168\u63a9\u819c\uff09\u7684\u4f01\u4e1a\uff0c\u6309\u7167\u4e0d\u8d85\u8fc7\u4ea7\u54c1\u6d41\u7247\u8d39\u7528\u768430%\u4e88\u4ee5\u5956\u52b1\uff0c\u5355\u4e2a\u4f01\u4e1a\u4e0a\u9650800\u4e07\u5143\uff1b\u5bf9\u5728\u5883\u5185\u5f00\u5c55\u6210\u719f\u5236\u7a0b\uff0814nm\u4ee5\u4e0a\uff09\u5de5\u7a0b\u4ea7\u54c1\u9996\u8f6e\u6d41\u7247\uff08\u5168\u63a9\u819c\uff09\u7684\u4f01\u4e1a\uff0c\u6309\u7167\u4e0d\u8d85\u8fc7\u4ea7\u54c1\u6d41\u7247\u8d39\u7528\u768420%\u4e88\u4ee5\u5956\u52b1\uff0c\u5355\u4e2a\u4f01\u4e1a\u4e0a\u9650500\u4e07\u5143\uff1b\u5bf9\u5728\u5883\u5916\u5f00\u5c55\u5148\u8fdb\u5236\u7a0b\uff0814nm\u53ca\u4ee5\u4e0b\uff09\u5de5\u7a0b\u4ea7\u54c1\u9996\u8f6e\u6d41\u7247\uff08\u5168\u63a9\u819c\uff09\u7684\u4f01\u4e1a\uff0c\u6309\u7167\u4e0d\u8d85\u8fc7\u4ea7\u54c1\u6d41\u7247\u8d39\u7528\u768415%\u4e88\u4ee5\u5956\u52b1\uff0c\u5355\u4e2a\u4f01\u4e1a\u4e0a\u9650500\u4e07\u5143\u3002\uff08\u8d22\u8054\u793e\uff09",
