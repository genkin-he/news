                    "widgetTitle": "\u6d59\u6c5f\u5f00\u5c55\u201c\u516d\u5927\u884c\u52a8\u201d\u5f3a\u7ef4\u6743\u4fc3\u6d88\u8d39",
                    "widgetContent": "\u636e\u6d59\u6c5f\u53d1\u5e03\uff0c\u7531\u6d59\u6c5f\u7701\u6d88\u8d39\u8005\u6743\u76ca\u4fdd\u62a4\u59d4\u5458\u4f1a\u3001\u6d59\u6c5f\u7701\u5e02\u573a\u76d1\u7763\u7ba1\u7406\u5c40\u4e3b\u529e\u76842025\u5e74\u201c3\u00b715\u56fd\u9645\u6d88\u8d39\u8005\u6743\u76ca\u65e5\u201d\u7eaa\u5ff5\u6d3b\u52a8\u65e5\u524d\u5728\u676d\u5dde\u4e3e\u884c\u30022025\u5e74\uff0c\u6d59\u6c5f\u5c06\u5b9e\u65bd\u66f4\u5927\u529b\u5ea6\u7684\u4fc3\u6d88\u8d39\u653f\u7b56\uff0c\u540c\u65f6\u5f00\u5c55\u201c\u5b88\u62a4\u6d88\u8d39\u201d\u94c1\u62f3\u884c\u52a8\u7b49\u201c\u516d\u5927\u884c\u52a8\u201d\u3002\u5176\u4e2d\u63d0\u51fa\uff0c\u5b9e\u65bd\u6267\u6cd5\u4eae\u5251\u62a4\u6c11\u884c\u52a8\uff0c\u4ece\u7834\u89e3\u6d88\u8d39\u8005\u53cd\u6620\u5f3a\u70c8\u7684\u95ee\u9898\u51fa\u53d1\uff0c\u6df1\u5316\u98df\u54c1\u9886\u57df\u201c\u4e24\u8d85\u4e00\u975e\u201d\u3001\u8ba1\u91cf\u4f5c\u5f0a\u3001\u4ef7\u683c\u6b3a\u8bc8\u3001\u8fdd\u6cd5\u5e7f\u544a\u3001\u865a\u5047\u68c0\u6d4b\u8ba4\u8bc1\u3001\u201c\u5185\u5377\u5f0f\u201d\u7ade\u4e89\u7b49\u5e02\u573a\u987d\u75be\u4e13\u9879\u6574\u6cbb\uff0c\u534f\u540c\u884c\u4e1a\u4e3b\u7ba1\u90e8\u95e8\u63a8\u8fdb\u9884\u4ed8\u5f0f\u6d88\u8d39\u7b49\u91cd\u70b9\u9886\u57df\u6cbb\u7406\uff0c\u5316\u89e3\u6d88\u8d39\u75db\u70b9\u5835\u70b9\uff0c\u89e3\u51b3\u6d88\u8d39\u8005\u7684\u201c\u70e6\u5fc3\u4e8b\u201d\u3002\uff08e\u516c\u53f8\uff09",
