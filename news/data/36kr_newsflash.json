                    "widgetTitle": "\u6709\u8d5e\u767b\u9646\u6e2f\u4ea4\u6240\u4e3b\u677f",
                    "widgetContent": "36\u6c2a\u83b7\u6089\uff0c\u6709\u8d5e\u79d1\u6280\u6b63\u5f0f\u5728\u9999\u6e2f\u8054\u4ea4\u6240\u4e3b\u677f\u6302\u724c\uff0c\u4eceGEM\u677f\u8f6c\u81f3\u4e3b\u677f\u3002\u6839\u636e\u6709\u8d5e2025\u5e74\u5168\u5e74\u4e1a\u7ee9\u62a5\u544a\uff0c\u516c\u53f8\u5168\u5e74\u6536\u5165\u7ea614.9\u4ebf\u5143\uff0c\u7ecf\u8425\u6027\u76c8\u5229\u7ea61.8\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f81%\u3002\u7ba1\u7406\u5c42\u9884\u8ba1\uff0c2026\u5e74\u6709\u8d5eAI\u76f8\u5173\u76f4\u63a5\u6536\u5165\u5c06\u8d85\u8fc71\u4ebf\u5143\uff0c\u5e76\u5e26\u52a8\u6570\u4ebf\u5143\u5173\u8054\u6536\u5165\u589e\u957f\u3002",
