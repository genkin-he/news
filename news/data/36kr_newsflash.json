                    "widgetTitle": "\u4e8c\u5b63\u5ea6\u517b\u8001\u57fa\u91d1\u65b0\u8fdb\u516520\u4f59\u53ea\u4e2a\u80a1\u524d\u5341\u5927\u6d41\u901a\u80a1\u4e1c\u540d\u5355",
                    "widgetContent": "\u8fd1\u671f\uff0cA\u80a1\u4e0a\u5e02\u516c\u53f8\u534a\u5e74\u62a5\u52a0\u901f\u62ab\u9732\uff0c\u524d\u5341\u5927\u6d41\u901a\u80a1\u4e1c\u6570\u636e\u900f\u9732\u51fa\u673a\u6784\u884c\u8e2a\u3002Wind\u6570\u636e\u663e\u793a\uff0c\u4e8c\u5b63\u5ea6\u517b\u8001\u57fa\u91d1\u65b0\u8fdb\u516520\u4f59\u53ea\u4e2a\u80a1\u7684\u524d\u5341\u5927\u6d41\u901a\u80a1\u4e1c\u540d\u5355\u3002\u6839\u636e\u4e8c\u5b63\u5ea6\u672b\u7684\u80a1\u4ef7\u6570\u636e\u8ba1\u7b97\uff0c\u517b\u8001\u57fa\u91d1\u4e8c\u5b63\u5ea6\u65b0\u589e\u6301\u6709\u5e02\u503c\u8d851\u4ebf\u5143\u7684\u4e2a\u80a1\u670911\u53ea\uff0c\u5206\u522b\u4e3a\u5b8f\u53d1\u80a1\u4efd\u3001\u536b\u661f\u5316\u5b66\u3001\u751f\u76ca\u7535\u5b50\u3001\u9c7c\u8dc3\u533b\u7597\u3001\u6770\u745e\u80a1\u4efd\u3001\u5b89\u742a\u9175\u6bcd\u3001\u6cf0\u6069\u5eb7\u3001\u534e\u6d4b\u68c0\u6d4b\u3001\u6d77\u4fe1\u5bb6\u7535\u3001\u5171\u8fbe\u7535\u58f0\u3001\u5251\u6865\u79d1\u6280\u3002\u6b64\u5916\uff0c\u517b\u8001\u57fa\u91d1\u4e8c\u5b63\u5ea6\u65b0\u8fdb\u5165\u6f4d\u67f4\u91cd\u673a\u3001\u534e\u5cf0\u94dd\u4e1a\u3001\u9c81\u897f\u5316\u5de5\u3001\u4eac\u80fd\u7535\u529b\u3001\u8bfa\u74e6\u661f\u4e91\u3001\u798f\u8fbe\u80a1\u4efd\u7b49\u4e2a\u80a1\u7684\u524d\u5341\u5927\u6d41\u901a\u80a1\u4e1c\u540d\u5355\u3002\uff08\u4e2d\u8bc1\u7f51\uff09",
