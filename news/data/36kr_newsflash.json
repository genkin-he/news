                    "widgetContent": "\u968f\u7740\u4e00\u6279\u5546\u4e1a\u706b\u7bad\u3001\u5546\u4e1a\u536b\u661f\u9646\u7eed\u5347\u7a7a\uff0c\u56fd\u5185\u5546\u4e1a\u822a\u5929\u9886\u57df\u8fce\u6765\u201c\u6280\u672f\u7a81\u7834\u201d\u548c\u201c\u89c4\u6a21\u7206\u53d1\u201d\u7684\u53cc\u91cd\u62d0\u70b9\u3002\u572812\u67083\u65e5\u81f34\u65e5\u4e3e\u884c\u76842025\u5546\u4e1a\u822a\u5929\u8bba\u575b\u4e0a\uff0c\u591a\u5bb6\u5546\u4e1a\u822a\u5929\u516c\u53f8\u5c55\u793a\u4e86\u706b\u7bad\u53d1\u5c04\u3001\u661f\u5ea7\u6d4b\u63a7\u7ba1\u7406\u3001\u7a7a\u95f4\u5728\u8f68\u670d\u52a1\u7b49\u4ea7\u4e1a\u94fe\u4e0a\u5404\u73af\u8282\u7684\u6700\u65b0\u8fdb\u5c55\u3002\u591a\u540d\u4e1a\u5185\u4eba\u58eb\u8868\u793a\uff0c\u65e0\u8bba\u662f\u653f\u7b56\u3001\u6280\u672f\u8fd8\u662f\u751f\u6001\uff0c\u4e2d\u56fd\u5546\u4e1a\u822a\u5929\u6b63\u8fce\u6765\u524d\u6240\u672a\u6709\u7684\u53d1\u5c55\u673a\u9047\u3002\u968f\u7740\u56fd\u5bb6\u91cd\u5927\u822a\u5929\u5de5\u7a0b\u5411\u5546\u4e1a\u529b\u91cf\u5f00\u653e\u3001\u5728\u8f68\u670d\u52a1\u80fd\u529b\u52a0\u901f\u6784\u5efa\u4ee5\u53ca\u5730\u65b9\u4ea7\u4e1a\u96c6\u7fa4\u521d\u5177\u89c4\u6a21\uff0c\u4e00\u4e2a\u4e07\u4ebf\u7ea7\u7684\u5e02\u573a\u6b63\u84c4\u52bf\u5f85\u53d1\u3002\uff08\u4e0a\u8bc1\u62a5\uff09",
