                    "widgetTitle": "\u7b2c7\u53f7\u53f0\u98ce\u201c\u8303\u65af\u9ad8\u201d\u505c\u6b62\u7f16\u53f7 \u201c\u7af9\u8282\u8349\u201d\u51cf\u5f31\u4e3a\u70ed\u5e26\u4f4e\u538b",
                    "widgetContent": "\u4e2d\u592e\u6c14\u8c61\u53f07\u670826\u65e506\u65f6\u89e3\u9664\u53f0\u98ce\u84dd\u8272\u9884\u8b66\uff1a\u4eca\u5e74\u7b2c7\u53f7\u53f0\u98ce\u201c\u8303\u65af\u9ad8\u201d\u51cf\u5f31\u540e\u7684\u70ed\u5e26\u4f4e\u538b\u5728\u4e1c\u6d77\u897f\u90e8\u6301\u7eed\u51cf\u5f31\uff0c\u4e2d\u592e\u6c14\u8c61\u53f0\u4eca\u5929\uff087\u670826\u65e5\uff09\u65e9\u66685\u70b9\u949f\u5bf9\u5176\u505c\u6b62\u7f16\u62a5\u3002\u53e6\u5916\uff0c\u4eca\u5e74\u7b2c8\u53f7\u53f0\u98ce\u201c\u7af9\u8282\u8349\u201d\u5df2\u4e8e\u6628\u5929\u591c\u95f4\u51cf\u5f31\u4e3a\u70ed\u5e26\u4f4e\u538b\uff0c\u4eca\u5929\u65e9\u66685\u70b9\u949f\u5176\u4e2d\u5fc3\u4f4d\u4e8e\u7409\u7403\u7fa4\u5c9b\u90a3\u9738\u5e02\u897f\u504f\u5357\u65b9\u5411295\u516c\u91cc\u7684\u6d0b\u9762\u4e0a\uff0c\u5c31\u662f\u5317\u7eac24.8\u5ea6\u3001\u4e1c\u7ecf125.2\u5ea6\uff0c\u4e2d\u5fc3\u9644\u8fd1\u6700\u5927\u98ce\u529b\u67097\u7ea7\uff0815\u7c73/\u79d2\uff09\uff0c\u4e2d\u5fc3\u6700\u4f4e\u6c14\u538b\u4e3a995\u767e\u5e15\u3002\u9884\u8ba1\uff0c\u201c\u7af9\u8282\u8349\u201d\u5c06\u4ee5\u6bcf\u5c0f\u65f615-20\u516c\u91cc\u7684\u901f\u5ea6\u5411\u5317\u504f\u4e1c\u65b9\u5411\u79fb\u52a8\uff0c\u5f3a\u5ea6\u7ee7\u7eed\u51cf\u5f31\u3002\uff08\u592e\u89c6\u65b0\u95fb\uff09",
