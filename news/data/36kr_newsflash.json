                    "widgetContent": "\u5317\u4eac\u5e02\u59d4\u526f\u4e66\u8bb0\u3001\u5e02\u957f\u6bb7\u52c76\u65e5\u57282025\u667a\u6e90\u5927\u4f1a\u5f00\u5e55\u5f0f\u4e0a\u8868\u793a\uff0c\u9762\u5411\u672a\u6765\uff0c\u5317\u4eac\u5c06\u575a\u6301\u521b\u65b0\u4e0e\u5e94\u7528\u5e76\u91cd\uff0c\u52a0\u5feb\u5efa\u8bbe\u5177\u6709\u5168\u7403\u5f71\u54cd\u529b\u7684\u4eba\u5de5\u667a\u80fd\u521b\u65b0\u7b56\u6e90\u5730\u548c\u4ea7\u4e1a\u9ad8\u5730\u3002\u6bb7\u52c7\u8fd8\u8868\u793a\uff0c\u5317\u4eac\u5c06\u6301\u7eed\u51dd\u805a\u9876\u5c16\u4eba\u624d\uff0c\u5b9e\u65bd\u66f4\u5927\u529b\u5ea6\u66f4\u957f\u5468\u671f\u7684\u652f\u6301\u653f\u7b56\uff0c\u63a8\u52a8\u4e2d\u5173\u6751\u5b66\u9662\u7b49\u521b\u65b0\u6a21\u5f0f\u4ea7\u6559\u878d\u5408\uff0c\u57f9\u517b\u9752\u5e74\u590d\u5408\u4eba\u624d\uff1b\u5c06\u6301\u7eed\u5f3a\u5316\u6280\u672f\u521b\u65b0\uff0c\u63a2\u7d22AI for Science\u3001\u901a\u7528\u4eba\u5de5\u667a\u80fd\u7b49\u53d1\u5c55\u7684\u65b0\u8def\u5f84\uff0c\u52a0\u5feb\u57f9\u80b2\u7c7b\u8111\u667a\u80fd\u7b49\u98a0\u8986\u6027\u7684\u6280\u672f\uff1b\u5c06\u6301\u7eed\u63a8\u52a8\u5782\u76f4\u5e94\u7528\uff0c\u805a\u7126\u6559\u80b2\u3001\u533b\u7597\u3001\u91d1\u878d\u7b49\u9886\u57df\uff0c\u63a8\u51fa\u4e00\u6279\u6807\u6746\u6027\u7684\u5e94\u7528\u5de5\u7a0b\uff0c\u5168\u529b\u63a8\u52a8\u4eba\u5de5\u667a\u80fd\u8d4b\u80fd\u5343\u884c\u767e\u4e1a\uff1b\u5c06\u6301\u7eed\u63a8\u8fdb\u5f00\u653e\u521b\u65b0\uff0c\u652f\u6301\u4f01\u4e1a\u6301\u7eed\u5f00\u6e90\u6a21\u578b\u67b6\u6784\uff0c\u5efa\u8bbe\u5f00\u6e90\u901a\u7528\u6570\u636e\u96c6\uff0c\u6253\u9020\u5168\u7403\u5f00\u6e90\u5171\u4eab\u4e4b\u90fd\u3002\uff08\u4e0a\u8bc1\u62a5\uff09",
