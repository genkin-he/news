                    "widgetTitle": "\u534e\u6cf0\u8bc1\u5238\uff1a\u5173\u6ce8\u7eff\u8272\u71c3\u6599\u677f\u5757",
                    "widgetContent": "36\u6c2a\u83b7\u6089\uff0c\u534e\u6cf0\u8bc1\u5238\u7814\u62a5\u8868\u793a\uff0c\u5e02\u573a\u4e00\u81f4\u9884\u671f\u8ba4\u4e3aNDC\uff08\u56fd\u5bb6\u81ea\u4e3b\u8d21\u732e\uff09\u662f\u8fdc\u671f\u6982\u5ff5\u3001\u7eff\u8bc1\u4f9b\u7ed9\u8fc7\u5269\u4ef7\u683c\u96be\u6da8\u3001\u7eff\u7535\u8fd0\u8425\u5546\u4ec5\u662f\u201c\u7c7b\u503a\u201d\u9632\u5fa1\u8d44\u4ea7\u3002\u534e\u6cf0\u8bc1\u5238\u8ba4\u4e3a\uff1a1.2028\u20142030\u5e74\u78b3\u8fbe\u5cf0\u5012\u8ba1\u65f6\u4ec5\u52692\u20144\u5e74\uff0cNDC\u6216\u6210\u4e3a\u5e74\u5ea6\u8003\u6838\u786c\u7ea6\u675f\uff1b2.\u673a\u5236\u7535\u91cf\u5212\u8f6c\u3001\u6709\u6548\u671f\u9519\u914d\u5bfc\u81f4\u5b9e\u9645\u53ef\u4ea4\u5272\u65b0\u8bc1\u4f9b\u4e0d\u5e94\u6c42\uff0c2026\u5e742\u6708\u65b0\u8bc1\u4ea4\u6613\u5360\u6bd4\u5df2\u8fbe84%\uff0c\u4f9b\u9700\u683c\u5c40\u5df2\u9006\u8f6c\uff1b3.\u5e02\u573a\u672a\u5b9a\u4ef7\u7eff\u7535\u8fd0\u8425\u5546\u7684\u201c\u6210\u957f\u5c5e\u6027\u201d\uff0c\u7eff\u8bc1\u6536\u76ca\u663e\u6027\u5316\uff0c\u6709\u671b\u9a71\u52a8A/H\u80a1\u7eff\u7535\u4f30\u503c\u4e2d\u67a2\u4e0a\u79fb\u3002\u73af\u5883\u4ef7\u503c\u91cd\u4f30\u5c06\u6cbf\u4e09\u6761\u4e3b\u7ebf\u5c55\u5f00\uff0c\u5229\u597d\u7eff\u7535\u8fd0\u8425\u5546\u4e0e\u9ad8\u8017\u80fd\u9f99\u5934\u7eff\u7535\u76f4\u8fde\uff0c\u5173\u6ce8\u7eff\u8272\u71c3\u6599\u677f\u5757\u3002",
