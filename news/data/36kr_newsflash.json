                    "widgetContent": "\u4e3a\u786e\u4fdd\u7535\u68af\u5b89\u5168\u5e73\u7a33\u8fd0\u884c\uff0c\u5317\u4eac\u5e02\u5e02\u573a\u76d1\u7ba1\u5c40\u63d0\u524d\u884c\u52a8\uff0c\u8fde\u65e5\u6765\u91c7\u53d6\u591a\u9879\u5de5\u4f5c\u4e3e\u63aa\uff0c\u5bf9\u5168\u5e02\u201c\u516b\u7ad9\u4e24\u573a\u201d\u3001\u5730\u94c1\u3001\u5546\u573a\u7b49\u4eba\u5458\u5bc6\u96c6\u573a\u6240\u7535\u68af\u5b89\u5168\u5f00\u5c55\u76d1\u7763\u68c0\u67e5\uff0c\u6df1\u5165\u6392\u67e5\u6d88\u9664\u98ce\u9669\u9690\u60a3\uff0c\u7763\u4fc3\u4f01\u4e1a\u548c\u7535\u68af\u7ef4\u4fdd\u5355\u4f4d\u505a\u597d\u7ba1\u7406\u548c\u8fd0\u884c\u7ef4\u62a4\uff0c\u505a\u597d\u6625\u8282\u671f\u95f4\u5168\u5e02\u7535\u68af\u5b89\u5168\u8fd0\u884c\u670d\u52a1\u4fdd\u969c\u5de5\u4f5c\u3002\u9488\u5bf9\u5c81\u672b\u5e74\u521d\u4eba\u5458\u5bc6\u96c6\u573a\u6240\u7535\u68af\u5ba2\u6d41\u5927\u3001\u8fd0\u884c\u65f6\u95f4\u957f\u7b49\u7279\u70b9\uff0c\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u5c06\u4eba\u6d41\u5ba2\u6d41\u5927\u7684\u5730\u94c1\u3001\u706b\u8f66\u7ad9\u3001\u673a\u573a\u548c\u5546\u573a\u7b49\u4f5c\u4e3a\u91cd\u70b9\uff0c\u8fdb\u884c\u5b89\u5168\u68c0\u67e5\u3002\u5e02\u5e02\u573a\u76d1\u7ba1\u5c40\u7ec4\u7ec7\u7535\u68af\u6280\u672f\u4e13\u5bb6\u5bf9\u5168\u5e021500\u4f59\u53f0\u7535\u68af\u5f00\u5c55\u73b0\u573a\u68c0\u67e5\u3002",
