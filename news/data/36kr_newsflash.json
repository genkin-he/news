                    "widgetContent": "\u4e24\u540d\u53c2\u4e0e\u8c08\u5224\u7684\u4eba\u58eb3\u65e5\u8868\u793a\uff0c\u82f1\u7279\u5c14\u548c\u53f0\u79ef\u7535\u5df2\u8fbe\u6210\u521d\u6b65\u534f\u8bae\uff0c\u5c06\u6210\u7acb\u4e00\u5bb6\u5408\u8d44\u4f01\u4e1a\u6765\u8fd0\u8425\u8fd9\u5bb6\u7f8e\u56fd\u82af\u7247\u5236\u9020\u5546\u7684\u5de5\u5382\u3002\u62a5\u9053\u79f0\uff0c\u5168\u7403\u6700\u5927\u82af\u7247\u4ee3\u5de5\u5546\u53f0\u79ef\u7535\u5c06\u6301\u6709\u65b0\u516c\u53f820%\u7684\u80a1\u4efd\u3002\u636e\u6089\uff0c\u7f8e\u56fd\u767d\u5bab\u548c\u5546\u52a1\u90e8\u5b98\u5458\u4e00\u76f4\u5728\u6566\u4fc3\u53f0\u79ef\u7535\u548c\u82f1\u7279\u5c14\u8fbe\u6210\u534f\u8bae\uff0c\u4ee5\u89e3\u51b3\u82f1\u7279\u5c14\u7684\u957f\u671f\u5371\u673a\u3002\uff08\u8d22\u8054\u793e\uff09",
