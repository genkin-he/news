                    "widgetTitle": "\u9648\u8302\u6ce2\uff1a\u53d1\u503a\u878d\u8d44\u63a8\u52a8\u57fa\u5efa\u63d0\u901f\u53d1\u5c55\u5317\u90e8\u90fd\u4f1a\u533a",
                    "widgetContent": "\u9999\u6e2f\u7279\u533a\u653f\u5e9c\u8d22\u653f\u53f8\u53f8\u957f\u9648\u8302\u6ce22\u670816\u65e5\u53d1\u8868\u7f51\u5fd7\u79f0\uff0c\u63d0\u901f\u53d1\u5c55\u5317\u90e8\u90fd\u4f1a\u533a\u662f\u9999\u6e2f\u628a\u63e1\u79d1\u6280\u53d8\u9769\u673a\u9047\u7684\u5173\u952e\u3002\u7279\u533a\u653f\u5e9c\u4f1a\u901a\u8fc7\u53d1\u884c\u653f\u5e9c\u503a\u5238\u878d\u8d44\uff0c\u786e\u4fdd\u5317\u90e8\u90fd\u4f1a\u533a\u9879\u76ee\u8fdb\u5ea6\u4e0d\u4f1a\u56e0\u516c\u5171\u8d22\u653f\u72b6\u51b5\u800c\u53d7\u5230\u5236\u7ea6\u3002\u9648\u8302\u6ce2\u8868\u793a\uff0c\u9999\u6e2f\u9700\u8981\u52a0\u901f\u5317\u90e8\u90fd\u4f1a\u533a\u5efa\u8bbe\uff0c\u63d0\u4f9b\u8db3\u591f\u7a7a\u95f4\u53ca\u57fa\u7840\u8bbe\u65bd\uff0c\u5438\u5f15\u79d1\u6280\u4f01\u4e1a\u843d\u6237\u9999\u6e2f\u3001\u52a0\u5927\u5176\u5728\u6e2f\u7814\u53d1\u6216\u9ad8\u7aef\u5236\u9020\u4e1a\u52a1\u7684\u89c4\u6a21\uff0c\u6293\u7d27\u524d\u6cbf\u79d1\u6280\u8fc5\u901f\u53d1\u5c55\u5e26\u6765\u7684\u673a\u9047\u3002\u672a\u6765\u51e0\u5e74\uff0c\u5317\u90e8\u90fd\u4f1a\u533a\u76f8\u5173\u5de5\u7a0b\u9646\u7eed\u542f\u52a8\uff0c\u52a0\u4e0a\u5176\u4ed6\u91cd\u8981\u6c11\u751f\u76f8\u5173\u7684\u57fa\u5efa\u5de5\u7a0b\uff0c\u7279\u533a\u653f\u5e9c\u7684\u5de5\u7a0b\u5f00\u652f\u8fdb\u5165\u9ad8\u5cf0\u671f\u3002\u4ed6\u79f0\uff0c\u53d1\u884c\u503a\u5238\u4ee5\u652f\u6301\u57fa\u5efa\u5de5\u7a0b\u3001\u6295\u8d44\u672a\u6765\uff0c\u662f\u56fd\u9645\u60ef\u5e38\u548c\u666e\u904d\u505a\u6cd5\u3002\u9999\u6e2f\u503a\u52a1\u6c34\u5e73\u4ecd\u5904\u4e8e\u4f4e\u6c34\u5e73\u3002\u73af\u987e\u4e00\u4e9b\u5148\u8fdb\u7ecf\u6d4e\u4f53\uff0c\u5176\u653f\u5e9c\u503a\u52a1\u76f8\u5bf9\u751f\u4ea7\u603b\u503c\u7684\u6bd4\u7387\u5747\u8d85\u8fc7100%\uff1b\u76f8\u8f83\u4e4b\u4e0b\uff0c\u9999\u6e2f\u5f53\u524d\u76f8\u5173\u6bd4\u7387\u4ec5\u7ea69.3%\uff0c\u5373\u4f7f\u7a0d\u5fae\u63d0\u9ad8\uff0c\u4ecd\u5c5e\u7a33\u5065\u6c34\u5e73\u3002\uff08\u754c\u9762\u65b0\u95fb\uff09",
