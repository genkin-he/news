                    "widgetTitle": "\u7279\u6717\u666e\u79f0\u7f8e\u56fd\u5fc5\u987b\u5141\u8bb8\u6280\u672f\u79fb\u6c11\uff0c\u627f\u8ba4\u6b64\u7acb\u573a\u6216\u5f15\u53d1MAGA\u652f\u6301\u8005\u4e0d\u6ee1",
                    "widgetContent": "\u5c3d\u7ba1\u4fdd\u5b88\u6d3e\u652f\u6301\u8005\u7684\u53cd\u5bf9\u58f0\u65e5\u76ca\u9ad8\u6da8\uff0c\u7279\u6717\u666e\u4ecd\u575a\u6301\u8ba4\u4e3a\u5e94\u5141\u8bb8\u6280\u672f\u79fb\u6c11\u8fdb\u5165\u7f8e\u56fd\uff0c\u4ee5\u652f\u6301\u672c\u571f\u5148\u8fdb\u5236\u9020\u4e1a\u7684\u6269\u5f20\u3002\u7279\u6717\u666e\u5468\u4e09\u5728\u534e\u76db\u987f\u53d1\u8868\u8bb2\u8bdd\uff0c\u7279\u522b\u63d0\u5230\u65b0\u5efa\u5de5\u5382\u7684\u52b3\u52a8\u529b\u9700\u6c42\uff0c\u5305\u62ec\u53f0\u79ef\u7535\u6b63\u5728\u4e9a\u5229\u6851\u90a3\u5dde\u5efa\u8bbe\u7684\u4e00\u5ea7\u5de5\u5382\u3002\u201c\u4f60\u4e0d\u80fd\u8fc7\u6765\u6295\u5165\u6570\u5341\u4ebf\u7f8e\u5143\u5efa\u4e00\u5ea7\u5e9e\u5927\u7684\u8ba1\u7b97\u673a\u82af\u7247\u5de5\u5382\uff0c\u5c31\u50cf\u5728\u4e9a\u5229\u6851\u90a3\u5dde\u90a3\u6837\uff0c\u7136\u540e\u4ee5\u4e3a\u80fd\u4ece\u5931\u4e1a\u7fa4\u4f53\u76f4\u63a5\u62db\u4eba\u6765\u8fd0\u8425\uff0c\u201d\u7279\u6717\u666e\u5728\u7f8e\u6c99\u6295\u8d44\u8bba\u575b\u4e0a\u8868\u793a\uff0c\u201c\u4ed6\u4eec\u5fc5\u987b\u5e26\u6210\u5343\u4e0a\u4e07\u7684\u4eba\u5458\u4e00\u540c\u6765\uff0c\u6211\u4f1a\u6b22\u8fce\u8fd9\u4e9b\u4eba\u3002\u201d\uff08\u65b0\u6d6a\u8d22\u7ecf\uff09",
