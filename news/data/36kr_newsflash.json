                    "widgetTitle": "\u9a6c\u65af\u514b\uff1aSpaceX\u548c\u7279\u65af\u62c9\u59cb\u7ec8\u662f\u53f0\u79ef\u7535\u7684\u91cd\u8981\u5ba2\u6237",
                    "widgetContent": "\u5f53\u5730\u65f6\u95f44\u670817\u65e5\uff0c\u9a6c\u65af\u514b\u53d1\u6587\u79f0\uff0cSpaceX\u548c\u7279\u65af\u62c9\u59cb\u7ec8\u662f\u53f0\u79ef\u7535\u7684\u91cd\u8981\u5ba2\u6237\uff0c\u800c\u975e\u901a\u5e38\u610f\u4e49\u4e0a\u7684\u7ade\u4e89\u5bf9\u624b\u3002\u53f0\u79ef\u7535\u65e0\u6cd5\u751f\u4ea7\u6240\u9700\u6570\u91cf\u5982\u6b64\u5e9e\u5927\u7684\u82af\u7247\uff0c\u6240\u4ee5\u9700\u8981\u201cTerafab\u201d\u82af\u7247\u5de5\u5382\u9879\u76ee\u3002\u53f0\u79ef\u7535\u6b64\u524d16\u65e5\u5728\u4e1a\u7ee9\u4ea4\u6d41\u4f1a\u4e0a\u5c31\u201cTerafab\u201d\u9879\u76ee\u8868\u793a\uff0c\u82f1\u7279\u5c14\u548c\u7279\u65af\u62c9\u90fd\u662f\u53f0\u79ef\u7535\u7684\u5ba2\u6237\uff0c\u4e5f\u662f\u7ade\u4e89\u5bf9\u624b\u3002\uff08\u754c\u9762\u65b0\u95fb\uff09",
