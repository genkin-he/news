                    "widgetTitle": "\u82f1\u4f1f\u8fbeCEO\u9ec4\u4ec1\u52cb\u56de\u5e94\u4efb\u6b63\u975e\u6700\u65b0\u8bb2\u8bdd",
                    "widgetContent": "\u82f1\u4f1f\u8fbeCEO\u9ec4\u4ec1\u52cb\u8fd1\u65e5\u5bf9\u4efb\u6b63\u975e\u7684\u8bb2\u8bdd\u8868\u8fbe\u4e86\u4ed6\u7684\u89c2\u70b9\u3002\u4ed6\u8868\u793a\u201c\uff08\u867d\u7136\uff09\u6211\u4eec\u7684\u6280\u672f\u6bd4\u4ed6\u4eec\u9886\u5148\u4e00\u4ee3\uff0c\u4f46\u91cd\u8981\u7684\u662f\u8981\u8bb0\u4f4f\uff0c\u6280\u672f\u5c42\u9762\u7684\u4eba\u5de5\u667a\u80fd\u662f\u4e00\u4e2a\u5e76\u884c\u95ee\u9898\u3002\u5982\u679c\u6bcf\u53f0\u8ba1\u7b97\u673a\u7684\u6027\u80fd\u4e0d\u591f\u5f3a\uff0c\u90a3\u5c31\u7528\u66f4\u591a\u7684\u8ba1\u7b97\u673a\u3002\u4ed6\u6240\u8bf4\u7684\u662f\uff0c\u4e2d\u56fd\u6709\u5145\u8db3\u7684\u80fd\u6e90\uff0c\u4ed6\u4eec\u4f1a\u4f7f\u7528\u66f4\u591a\u7684\u82af\u7247\u3002\u6240\u4ee5\u5728\u5f88\u591a\u65b9\u9762\uff0c\u4ed6\u662f\u5728\u8bf4\u4e2d\u56fd\u7684\u6280\u672f\u5bf9\u4e2d\u56fd\u6765\u8bf4\u5df2\u7ecf\u8db3\u591f\u597d\u4e86\u3002\u5982\u679c\u7f8e\u56fd\u4e0d\u60f3\u53c2\u4e0e\u4e2d\u56fd\uff08\u7684\u5e02\u573a\uff09\uff0c\u534e\u4e3a\u80fd\u8986\u76d6\u4e2d\u56fd\u5e02\u573a\u7684\u9700\u6c42\uff0c\u4e5f\u80fd\u8986\u76d6\u5176\u4ed6\u6240\u6709\u5730\u533a\u3002\u201d\n\n6\u670810\u65e5\uff0c\u534e\u4e3a\u521b\u59cb\u4eba\u4efb\u6b63\u975e\u8868\u793a\uff0c\u82af\u7247\u95ee\u9898\u5176\u5b9e\u6ca1\u5fc5\u8981\u62c5\u5fc3\uff0c\u7528\u53e0\u52a0\u548c\u96c6\u7fa4\u7b49\u65b9\u6cd5\uff0c\u8ba1\u7b97\u7ed3\u679c\u4e0a\u4e0e\u6700\u5148\u8fdb\u6c34\u5e73\u662f\u76f8\u5f53\u7684\u3002\uff08\u7b2c\u4e00\u8d22\u7ecf\uff09",
