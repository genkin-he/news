                    "widgetTitle": "\u5929\u6d25\u201c\u5341\u4e94\u4e94\u201d\u89c4\u5212\u5efa\u8bae\uff1a\u7528\u597d\u8d44\u672c\u5e02\u573a\uff0c\u52a0\u5f3a\u533a\u57df\u6027\u80a1\u6743\u5e02\u573a\u5efa\u8bbe",
                    "widgetContent": "\u4e2d\u5171\u5929\u6d25\u5e02\u59d4\u5173\u4e8e\u5236\u5b9a\u5929\u6d25\u5e02\u56fd\u6c11\u7ecf\u6d4e\u548c\u793e\u4f1a\u53d1\u5c55\u7b2c\u5341\u4e94\u4e2a\u4e94\u5e74\u89c4\u5212\u7684\u5efa\u8bae\u53d1\u5e03\uff0c\u5176\u4e2d\u63d0\u51fa\uff0c\u6df1\u5316\u8981\u7d20\u5e02\u573a\u5316\u914d\u7f6e\u6539\u9769\u3002\u5efa\u7acb\u5065\u5168\u57ce\u4e61\u7edf\u4e00\u7684\u5efa\u8bbe\u7528\u5730\u5e02\u573a\uff0c\u4f9d\u6cd5\u7a33\u59a5\u63a8\u8fdb\u5de5\u5546\u4e1a\u7528\u5730\u4f7f\u7528\u6743\u7eed\u671f\u5de5\u4f5c\u3002\u7528\u597d\u8d44\u672c\u5e02\u573a\uff0c\u52a0\u5f3a\u533a\u57df\u6027\u80a1\u6743\u5e02\u573a\u5efa\u8bbe\uff0c\u6df1\u5316\u5236\u5ea6\u548c\u4e1a\u52a1\u521b\u65b0\u8bd5\u70b9\uff0c\u652f\u6301\u4f01\u4e1a\u4e0a\u5e02\u53d1\u5c55\u3002\u5b8c\u5584\u5f15\u5bfc\u52b3\u52a8\u529b\u548c\u4eba\u624d\u5408\u7406\u516c\u6b63\u7545\u901a\u6709\u5e8f\u6d41\u52a8\u7684\u4f53\u5236\u673a\u5236\uff0c\u63a8\u8fdb\u4eba\u529b\u8d44\u6e90\u670d\u52a1\u4ea7\u4e1a\u56ed\u5efa\u8bbe\u3002\u5efa\u8bbe\u8f6c\u5316\u9ad8\u6548\u7684\u6280\u672f\u5e02\u573a\uff0c\u89c4\u8303\u53d1\u5c55\u77e5\u8bc6\u4ea7\u6743\u8bc1\u5238\u5316\u3001\u77e5\u8bc6\u4ea7\u6743\u4fdd\u9669\u3001\u77e5\u8bc6\u4ea7\u6743\u8d28\u62bc\u878d\u8d44\u7b49\u6a21\u5f0f\u3002\u5065\u5168\u6570\u636e\u4ea7\u6743\u767b\u8bb0\u3001\u6d41\u901a\u3001\u4ea4\u6613\u7b49\u5236\u5ea6\u4f53\u7cfb\uff0c\u5927\u529b\u62d3\u5c55\u89c4\u8303\u5316\u6570\u636e\u5f00\u53d1\u5e94\u7528\u573a\u666f\u3002\uff08\u8bc1\u5238\u65f6\u62a5\uff09",
