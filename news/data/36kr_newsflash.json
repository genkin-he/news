                    "widgetImage": "",
                    "publishTime": 1763184620000,
                    "widgetTitle": "\u718a\u7ee7\u519b\u4f1a\u89c1\u56fd\u9645\u6807\u51c6\u5316\u7ec4\u7ec7/\u56fd\u9645\u7535\u5de5\u59d4\u5458\u4f1a\u7b2c\u4e00\u8054\u5408\u6280\u672f\u59d4\u5458\u4f1a\u4e3b\u5e2d\u83f2\u5c14\u00b7\u6e29\u5e03\u6d1b\u59c6",
                    "widgetContent": "\u5de5\u4e1a\u548c\u4fe1\u606f\u5316\u90e8\u526f\u90e8\u957f\u718a\u7ee7\u519b11\u670815\u65e5\u5728\u6210\u90fd\u4f1a\u89c1\u56fd\u9645\u6807\u51c6\u5316\u7ec4\u7ec7/\u56fd\u9645\u7535\u5de5\u59d4\u5458\u4f1a\u7b2c\u4e00\u8054\u5408\u6280\u672f\u59d4\u5458\u4f1a\uff08ISO/IEC JTC 1\uff09\u73b0\u4efb\u4e3b\u5e2d\u83f2\u5c14\u00b7\u6e29\u5e03\u6d1b\u59c6\u3001\u5019\u4efb\u4e3b\u5e2d\u52b3\u62c9\u00b7\u6797\u8d5b\u7b49\u56fd\u9645\u6807\u51c6\u7ec4\u7ec7\u8d1f\u8d23\u4eba\uff0c\u5c31\u5171\u540c\u4fc3\u8fdb\u5168\u7403\u4fe1\u606f\u6280\u672f\u56fd\u9645\u4ea4\u6d41\u4e0e\u6807\u51c6\u5316\u5408\u4f5c\u7b49\u4ea4\u6362\u610f\u89c1\u3002\n\u718a\u7ee7\u519b\u8868\u793a\uff0c\u5728\u5148\u8fdb\u8ba1\u7b97\u3001\u4eba\u5de5\u667a\u80fd\u3001\u7269\u8054\u7f51\u3001\u65e0\u4eba\u7cfb\u7edf\u3001\u6570\u5b57\u5316\u8f6c\u578b\u7b49\u4fe1\u606f\u6280\u672f\u9886\u57df\uff0c\u4e2d\u56fd\u79ef\u7d2f\u4e86\u4e30\u5bcc\u7684\u7814\u53d1\u7ecf\u9a8c\u548c\u5b9e\u8df5\u6210\u679c\u3002\u4e2d\u65b9\u5c06\u575a\u5b9a\u4e0d\u79fb\u63a8\u8fdb\u9ad8\u6c34\u5e73\u5bf9\u5916\u5f00\u653e\uff0c\u79ef\u6781\u53c2\u4e0eISO\u3001IEC\u3001ITU\u7b49\u56fd\u9645\u6807\u51c6\u5316\u7ec4\u7ec7\u5de5\u4f5c\uff0c\u613f\u4e0e\u5168\u7403\u5404\u56fd\u7684\u5408\u4f5c\u4f19\u4f34\u4eec\u5206\u4eab\u5b9d\u8d35\u7ecf\u9a8c\uff0c\u4fc3\u8fdb\u4e2d\u56fd\u7684\u6280\u672f\u4f18\u52bf\u8f6c\u5316\u4e3a\u5168\u7403\u901a\u7528\u7684\u6807\u51c6\u3002\u671f\u5f85\u672a\u6765\u5728\u4fe1\u606f\u6280\u672f\u56fd\u9645\u6807\u51c6\u5316\u3001\u6280\u672f\u548c\u4ea7\u4e1a\u843d\u5730\u7b49\u65b9\u9762\u8d21\u732e\u66f4\u591a\u4e2d\u56fd\u529b\u91cf\u3002\n\u83f2\u5c14\u00b7\u6e29\u5e03\u6d1b\u59c6\u611f\u8c22\u4e2d\u56fd\u5de5\u4e1a\u548c\u4fe1\u606f\u5316\u90e8\u7b49\u90e8\u95e8\u5bf9\u4fe1\u606f\u6280\u672f\u56fd\u9645\u6807\u51c6\u5316\u5de5\u4f5c\u7684\u5927\u529b\u652f\u6301\uff0c\u5e0c\u671b\u4e2d\u56fd\u4e0d\u65ad\u52a0\u5927\u56fd\u9645\u6807\u51c6\u5316\u6295\u5165\u529b\u5ea6\uff0c\u5c06\u66f4\u591a\u79d1\u6280\u6210\u679c\u8f6c\u5316\u4e3a\u56fd\u9645\u6807\u51c6\u3002\n\u5de5\u4e1a\u548c\u4fe1\u606f\u5316\u90e8\u6709\u5173\u53f8\u5c40\u3001\u56fd\u5bb6\u5e02\u573a\u76d1\u7763\u7ba1\u7406\u603b\u5c40\u6807\u51c6\u521b\u65b0\u53f8\uff0c\u90e8\u5c5e\u5355\u4f4d\u8d1f\u8d23\u4eba\u53c2\u52a0\u4f1a\u89c1\u3002",
