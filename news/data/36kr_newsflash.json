                    "widgetContent": "11\u670828\u65e5\uff0c\u8bc1\u76d1\u4f1a\u62ab\u9732\u300a\u8d44\u4ea7\u7ba1\u7406\u673a\u6784\u5f00\u5c55\u516c\u52df\u57fa\u91d1\u7ba1\u7406\u4e1a\u52a1\u8d44\u683c\u5ba1\u6279\u300b\u6392\u961f\u60c5\u51b5\uff0c\u539f\u672c\u4e0a\u4e00\u5468\u8fd8\u5728\u6392\u961f\u7684\u56fd\u91d1\u8d44\u7ba1\uff0c\u4e5f\u4e0d\u89c1\u4e86\u8e2a\u5f71\u3002\u8fd9\u610f\u5473\u7740\uff0c\u5e74\u521d\u539f\u672c\u8fd8\u5728\u6392\u961f\u7533\u8bf7\u516c\u52df\u724c\u7167\u7684\u5e7f\u53d1\u8d44\u7ba1\u3001\u5149\u8bc1\u8d44\u7ba1\u3001\u56fd\u8bc1\u8d44\u7ba1\u548c\u56fd\u91d1\u8d44\u7ba14\u5bb6\u5238\u5546\u8d44\u7ba1\u5b50\u516c\u53f8\uff0c\u5728\u83b7\u53d6\u516c\u52df\u724c\u7167\u65b9\u9762\u5ba3\u544a\u201c\u56e2\u706d\u201d\u30022018\u5e74\u8d44\u7ba1\u65b0\u89c4\u8981\u6c42\uff0c\u5238\u5546\u201c\u53c2\u516c\u5927\u96c6\u5408\u201d\u57282025\u5e74\u5e95\u524d\u5b8c\u6210\u516c\u52df\u5316\u6539\u9020\u3002\u968f\u7740\u622a\u6b62\u65e5\u671f\u4e34\u8fd1\uff0c\u5238\u5546\u8d44\u7ba1\u884c\u4e1a\u8fdb\u5165\u51b2\u523a\u9636\u6bb5\uff0c\u4e3b\u8981\u8f6c\u578b\u8def\u5f84\u5305\u62ec\u7ba1\u7406\u4eba\u53d8\u66f4\u3001\u6e05\u76d8\u6216\u8f6c\u578b\u79c1\u52df\u3002\uff08\u8bc1\u5238\u65f6\u62a5\uff09",
