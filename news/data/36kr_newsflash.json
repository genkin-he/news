                    "widgetTitle": "\u5e7f\u897f\u805a\u7126\u201c\u4eba\u5de5\u667a\u80fd+\u201d\u7b49\u65b0\u5174\u4ea7\u4e1a\uff0c\u5168\u9762\u542f\u52a8\u5927\u533a\u62db\u5546",
                    "widgetContent": "\u5e7f\u897f\u58ee\u65cf\u81ea\u6cbb\u533a\u56ed\u533a\u53d1\u5c55\u548c\u6295\u8d44\u4fc3\u8fdb\u670d\u52a1\u4e2d\u5fc3\u4ecb\u7ecd\uff0c2025\u5e74\u5e7f\u897f\u5927\u533a\u62db\u5546(\u7ca4\u6e2f\u6fb3\u5927\u6e7e\u533a)\u542f\u52a8\u4f1a15\u65e5\u5728\u6df1\u5733\u5e02\u4e3e\u884c\uff0c\u5e7f\u897f\u5c06\u805a\u7126\u201c\u4eba\u5de5\u667a\u80fd+\u201d\u3001\u7535\u5b50\u4fe1\u606f\u3001\u751f\u7269\u533b\u836f\u7b49\u65b0\u5174\u4ea7\u4e1a\uff0c\u56f4\u7ed5\u4e2d\u56fd\u2014\u4e1c\u76df\u4ea7\u4e1a\u5408\u4f5c\u533a\u7b49\u91cd\u70b9\u62db\u5546\u5e73\u53f0\uff0c\u5728\u7ca4\u6e2f\u6fb3\u5927\u6e7e\u533a\u3001\u957f\u4e09\u89d2\u5730\u533a\u3001\u4eac\u6d25\u5180\u53ca\u6210\u6e1d\u5730\u533a\u7b49\u91cd\u70b9\u533a\u57df\u7ec4\u7ec7\u5f00\u5c55\u5927\u533a\u62db\u5546\u7cfb\u5217\u6d3b\u52a8\u3002\u5f53\u5929\uff0c\u5e7f\u897f\u58ee\u65cf\u81ea\u6cbb\u533a\u4eba\u6c11\u653f\u5e9c\u515a\u7ec4\u6210\u5458\uff0c\u5e7f\u897f\u58ee\u65cf\u81ea\u6cbb\u533a\u4ea7\u4e1a\u56ed\u533a\u6539\u9769\u53d1\u5c55\u529e\u516c\u5ba4\u4e3b\u4efb\u90b9\u5c55\u4e1a\u7387\u961f\u62dc\u8bbf\u6df1\u5733\u8fbe\u5b9e\u667a\u80fd\u80a1\u4efd\u6709\u9650\u516c\u53f8\u3001\u6df1\u5733\u50b2\u5f97\u79d1\u6280\u96c6\u56e2\uff0c\u5bf9\u63a5\u6d3d\u8c08\u6295\u8d44\u5408\u4f5c\u4e8b\u9879\uff0c\u8fbe\u6210\u5efa\u8bbe\u667a\u6167\u56ed\u533a\u3001\u96f6\u78b3\u56ed\u533a\u5408\u4f5c\u610f\u5411\uff0c\u5c06\u63a8\u8fdb\u901a\u822a\u98de\u884c\u5668\u7814\u53d1\u548c\u5236\u9020\u4ea7\u4e1a\u9879\u76ee\u5408\u4f5c\u3002\uff08\u8d22\u8054\u793e\uff09",
