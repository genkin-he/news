                    "widgetContent": "36\u6c2a\u83b7\u6089\uff0c\u4e0a\u6d77\u5e02\u4eba\u6c11\u653f\u5e9c\u529e\u516c\u5385\u5370\u53d1\u300a\u4e0a\u6d77\u5e02\u4fc3\u8fdb\u4e13\u7cbe\u7279\u65b0\u4e2d\u5c0f\u4f01\u4e1a\u53d1\u5c55\u58ee\u5927\u7684\u82e5\u5e72\u63aa\u65bd\u300b\u3002\u63aa\u65bd\u63d0\u5230\uff0c\u5bf9\u5f53\u5e74\u9996\u6b21\u5347\u89c4\u5e76\u7b26\u5408\u6761\u4ef6\u7684\u5de5\u4e1a\u3001\u4e92\u8054\u7f51\u548c\u76f8\u5173\u670d\u52a1\u3001\u8f6f\u4ef6\u548c\u4fe1\u606f\u6280\u672f\u670d\u52a1\u4e1a\u4f01\u4e1a\uff0c\u7ed9\u4e88\u6700\u9ad850\u4e07\u5143\u7684\u4e00\u6b21\u6027\u5956\u52b1\uff1b\u5bf9\u89c4\u4e0a\u7b26\u5408\u6761\u4ef6\u7684\u5de5\u4e1a\u3001\u4e92\u8054\u7f51\u548c\u76f8\u5173\u670d\u52a1\u3001\u8f6f\u4ef6\u548c\u4fe1\u606f\u6280\u672f\u670d\u52a1\u4e1a\u4f01\u4e1a\uff0c\u6839\u636e\u5f53\u5e74\u589e\u957f\u60c5\u51b5\uff0c\u7ed9\u4e88\u6700\u9ad840\u4e07\u5143\u7684\u4e00\u6b21\u6027\u5956\u52b1\u3002\u6301\u4e13\u7cbe\u7279\u65b0\u201c\u5c0f\u5de8\u4eba\u201d\u4f01\u4e1a\u505a\u5927\u505a\u5f3a\uff0c\u5bf9\u4e13\u7cbe\u7279\u65b0\u201c\u5c0f\u5de8\u4eba\u201d\u4f01\u4e1a\u8fde\u7eed\u4e24\u5e74\u4ea7\u503c\uff08\u8425\u6536\uff09\u589e\u901f20%\u4ee5\u4e0a\u7684\uff0c\u4e88\u4ee5\u6700\u9ad850\u4e07\u5143\u5956\u52b1\u3002",
