                    "widgetTitle": "\u5168\u56fd\u94c1\u8def\u8fce\u6765\u5ba2\u6d41\u9ad8\u5cf0 \u7aef\u5348\u8282\u5047\u671f\u7b2c1\u5929\u9884\u8ba1\u53d1\u9001\u65c5\u5ba21780\u4e07\u4eba\u6b21",
                    "widgetContent": "5\u670831\u65e5\u7aef\u5348\u8282\u5047\u671f\u7b2c1\u5929\uff0c\u5168\u56fd\u94c1\u8def\u8fce\u6765\u5ba2\u6d41\u9ad8\u5cf0\uff0c\u9884\u8ba1\u53d1\u9001\u65c5\u5ba21780\u4e07\u4eba\u6b21\uff0c\u8ba1\u5212\u52a0\u5f00\u65c5\u5ba2\u5217\u8f661029\u5217\u30025\u670830\u65e5\uff0c\u5168\u56fd\u94c1\u8def\u53d1\u9001\u65c5\u5ba21577.7\u4e07\u4eba\u6b21\uff0c\u8fd0\u8f93\u5b89\u5168\u5e73\u7a33\u6709\u5e8f\u3002\uff08e\u516c\u53f8\uff09",
