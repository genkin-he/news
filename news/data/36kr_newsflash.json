                    "widgetContent": "\u6b27\u76df\u5e0c\u671b\u963b\u6b62\u8fdb\u53e3\u67d0\u4e9b\u6309\u7167\u4e0d\u540c\u6807\u51c6\u751f\u4ea7\u7684\u98df\u54c1\u4ee5\u4fdd\u62a4\u6b27\u6d32\u519c\u6c11\uff0c\u4ee5\u6b64\u4f5c\u4e3a\u5bf9\u7f8e\u56fd\u603b\u7edf\u7279\u6717\u666e\u8d38\u6613\u653f\u7b56\u7684\u56de\u5e94\u3002\u636e\u4e09\u4f4d\u5b98\u5458\u900f\u9732\uff0c\u6b27\u76df\u59d4\u5458\u4f1a\u5c06\u4e8e\u4e0b\u5468\u540c\u610f\u63a2\u8ba8\u6269\u5927\u8fdb\u53e3\u9650\u5236\uff0c\u6b64\u4e3e\u6216\u5c06\u5f15\u53d1\u4e0e\u8d38\u6613\u4f19\u4f34\u7684\u7d27\u5f20\u5173\u7cfb\u3002\u636e\u6089\uff0c\u65e9\u671f\u7684\u76ee\u6807\u53ef\u80fd\u5305\u62ec\u5927\u8c46\u7b49\u7f8e\u56fd\u4f5c\u7269\uff0c\u8fd9\u4e9b\u4f5c\u7269\u5728\u79cd\u690d\u65f6\u4f7f\u7528\u4e86\u6b27\u76df\u519c\u6c11\u4e0d\u5f97\u4f7f\u7528\u7684\u519c\u836f\u3002\u957f\u671f\u4ee5\u6765\uff0c\u6b27\u76df\u59d4\u5458\u4f1a\u4e00\u76f4\u53cd\u5bf9\u6cd5\u56fd\u548c\u5176\u4ed6\u6210\u5458\u56fd\u5b9e\u65bd\u8d38\u6613\u9650\u5236\u7684\u547c\u5401\uff0c\u8ba4\u4e3a\u8fd9\u53ef\u80fd\u8fdd\u53cd\u4e16\u8d38\u7ec4\u7ec7\u89c4\u5219\uff0c\u800c\u53ea\u5141\u8bb8\u4ee5\u79d1\u5b66\u4e3a\u7531\u8fdb\u884c\u4e0d\u6b67\u89c6\u8fdb\u53e3\u7684\u9650\u5236\u3002\uff08\u82f1\u56fd\u91d1\u878d\u65f6\u62a5\uff09",
