                    "widgetTitle": "\u4e91\u5357\uff1a\u57f9\u80b2\u201c\u4eba\u5de5\u667a\u80fd+\u201d\u4f4e\u7a7a\u7ecf\u6d4e\u4ea7\u4e1a\u4e1a\u6001",
                    "widgetContent": "36\u6c2a\u83b7\u6089\uff0c\u4e91\u5357\u7701\u4eba\u6c11\u653f\u5e9c\u529e\u516c\u5385\u5370\u53d1\u300a\u4e91\u5357\u7701\u5168\u9762\u5b9e\u65bd\u201c\u4eba\u5de5\u667a\u80fd+\u201d\u884c\u52a8\u8ba1\u5212\u300b\u7684\u901a\u77e5\u3002\u901a\u77e5\u6307\u51fa\uff0c\u201c\u4eba\u5de5\u667a\u80fd+\u201d\u4ea4\u901a\u7269\u6d41\u3002\u8fd0\u7528\u4eba\u5de5\u667a\u80fd\u8d4b\u80fd\u667a\u6167\u7269\u6d41\u3001\u667a\u80fd\u4ea4\u901a\u3001\u4f4e\u7a7a\u7ecf\u6d4e\u7b49\u573a\u666f\u5e94\u7528\u3002\u63a8\u8fdb\u8d27\u8fd0\u5bc4\u9012\u6570\u636e\u3001\u8fd0\u5355\u6570\u636e\u3001\u7ed3\u7b97\u6570\u636e\u7b49\u5171\u4eab\u4e92\u8ba4\uff0c\u63a2\u7d22\u53d1\u5c55\u667a\u6167\u4ed3\u50a8\u7269\u6d41\u4e1a\uff0c\u63d0\u5347\u591a\u5f0f\u8054\u8fd0\u6548\u80fd\u3002\u6df1\u5316\u201c\u7eff\u7f8e\u901a\u9053\u4ea4\u901a\u5927\u6a21\u578b\u201d\u7b49\u5927\u6a21\u578b\u5728\u89c4\u5212\u8bbe\u8ba1\u3001\u667a\u80fd\u5efa\u9020\u3001\u8fd0\u884c\u76d1\u6d4b\u3001\u5e94\u6025\u5b89\u5168\u3001\u7ba1\u7406\u51b3\u7b56\u7b49\u65b9\u9762\u7684\u7814\u53d1\u548c\u5e94\u7528\uff0c\u52a0\u5feb\u5b9e\u65bd\u4ea4\u901a\u8fd0\u8f93\u5178\u578b\u573a\u666f\u53ca\u7efc\u5408\u4ea4\u901a\u8fd0\u8f93\u5927\u6a21\u578b\u7814\u53d1\uff0c\u52a0\u5f3a\u4ea4\u901a\u667a\u80fd\u4f53\u548c\u667a\u80fd\u7ec8\u7aef\u5e94\u7528\u3002\u57f9\u80b2\u201c\u4eba\u5de5\u667a\u80fd+\u201d\u4f4e\u7a7a\u7ecf\u6d4e\u4ea7\u4e1a\u4e1a\u6001\uff0c\u670d\u52a1\u77ed\u9014\u8d27\u8fd0\u548c\u5e94\u6025\u7269\u6d41\u3002",
