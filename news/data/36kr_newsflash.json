                    "widgetTitle": "\u4e0a\u4ea4\u6240\u5728\u957f\u4e09\u89d2\u533a\u57df\u6301\u7eed\u5f00\u5c55\u79d1\u521b\u677f\u6539\u9769\u201c1+6\u201d\u653f\u7b56\u5ba3\u8d2f",
                    "widgetContent": "36\u6c2a\u83b7\u6089\uff0c\u636e\u4e0a\u4ea4\u6240\u53d1\u5e03\uff0c\u4e3a\u5168\u9762\u505a\u597d\u79d1\u521b\u677f\u6539\u9769\u201c1+6\u201d\u653f\u7b56\u5728\u957f\u4e09\u89d2\u533a\u57df\u7684\u5ba3\u8d2f\uff0c\u63a8\u52a8\u672c\u6b21\u6539\u9769\u4e3e\u63aa\u5728\u957f\u4e09\u89d2\u533a\u57df\u7684\u7cbe\u51c6\u843d\u5730\u3001\u6709\u6548\u5b9e\u65bd\uff0c\u5168\u9762\u63d0\u5347\u8d44\u672c\u5e02\u573a\u670d\u52a1\u957f\u4e09\u89d2\u533a\u57df\u79d1\u6280\u521b\u65b0\u548c\u7ecf\u6d4e\u9ad8\u8d28\u91cf\u53d1\u5c55\u7684\u8d28\u6548\uff0c\u81ea\u79d1\u521b\u677f\u6539\u9769\u201c1+6\u201d\u653f\u7b56\u63a8\u51fa\u540e\uff0c\u4e0a\u4ea4\u6240\u7acb\u5373\u884c\u52a8\uff0c\u5148\u540e\u5728\u4e0a\u6d77\u3001\u676d\u5dde\u3001\u5357\u4eac\u3001\u5408\u80a5\u7b49\u957f\u4e09\u89d2\u533a\u57df\u91cd\u70b9\u57ce\u5e02\u8054\u5408\u5730\u65b9\u653f\u5e9c\u76f8\u5173\u90e8\u95e8\u3001\u8bc1\u76d1\u5c40\u4e3e\u529e\u79d1\u521b\u677f\u6539\u9769\u201c1+6\u201d\u653f\u7b56\u5ba3\u4ecb\u4f1a\uff0c\u5730\u65b9\u91d1\u878d\u3001\u79d1\u6280\u3001\u5de5\u4fe1\u7b49\u76f8\u5173\u90e8\u95e8\u3001\u91cd\u70b9\u56ed\u533a\u3001400\u4f59\u5bb6\u957f\u4e09\u89d2\u533a\u57df\u79d1\u6280\u4f01\u4e1a\u4ee5\u53ca\u5e02\u573a\u673a\u6784\u4ee3\u8868\u7d2f\u8ba1\u8d85\u8fc7800\u4eba\u53c2\u4f1a\u3002\u4e0e\u6b64\u540c\u65f6\uff0c\u4e0a\u4ea4\u6240\u8fd8\u5728\u957f\u4e09\u89d2\u533a\u57df\u90e8\u5206\u57ce\u5e02\u4e3e\u529e\u79d1\u6280\u4f01\u4e1a\u5ea7\u8c08\u4f1a\uff0c\u4e0e\u79d1\u6280\u4f01\u4e1a\u9762\u5bf9\u9762\u6df1\u5165\u4ea4\u6d41\uff0c\u5145\u5206\u542c\u53d6\u79d1\u6280\u4f01\u4e1a\u5bf9\u843d\u5b9e\u79d1\u521b\u677f\u6539\u9769\u201c1+6\u201d\u4e3e\u63aa\u7684\u610f\u89c1\u4e0e\u5efa\u8bae\uff0c\u53ca\u65f6\u89e3\u7b54\u79d1\u6280\u4f01\u4e1a\u7591\u95ee\u3002",
