                    "widgetTitle": "\u851a\u6765\u674e\u658c\u56de\u5e94\u6362\u7535\u7ad9\u88ab\u5356\u4f20\u95fb\uff1a\u4e0d\u4fe1\u8c23\u4e0d\u4f20\u8c23",
                    "widgetContent": "\u9488\u5bf9\u8fd1\u671f\u201c\u851a\u6765\u6362\u7535\u7ad9\u5c06\u88ab\u5b81\u5fb7\u65f6\u4ee3\u6536\u8d2d\u63a7\u80a1\u6743\u201d\u7684\u4f20\u95fb\uff0c\u6709\u4eba\u6652\u51fa\u7fa4\u804a\u622a\u56fe\u663e\u793a\uff0c\u6709\u851a\u6765\u8f66\u4e3b\u5411\u851a\u6765\u8463\u4e8b\u957f\u674e\u658c\u6c42\u8bc1\u201c\u6362\u7535\u7ad9\u771f\u5356\u4e86\u5417\u201d\uff0c\u851a\u6765\u8463\u4e8b\u957f\u674e\u658c\u5728\u851a\u6765\u8f66\u4e3b\u7fa4\u4e2d\u56de\u5e94\u79f0\uff1a\u201c\u4e0d\u4fe1\u8c23\u4e0d\u4f20\u8c23\u201d\uff0c\u4f46\u672a\u4f5c\u8fdb\u4e00\u6b65\u89e3\u91ca\u3002\u5b81\u5fb7\u65f6\u4ee3\u65b9\u9762\u5c31\u6b64\u6536\u8d2d\u4f20\u95fb\u56de\u5e94\u79f0\uff0c\u76ee\u524d\u201c\u6ca1\u6709\u66f4\u591a\u4fe1\u606f\u201d\u3002\u851a\u6765\u65b9\u9762\u53ea\u8868\u793a\uff0c\u201c\u6b63\u5728\u4e0e\u5305\u62ec\u5b81\u5fb7\u65f6\u4ee3\u5728\u5185\u7684\u591a\u5bb6\u6295\u8d44\u8005\uff0c\u5171\u540c\u63a8\u8fdb\u7535\u6c60\u6362\u7535\u7ad9\u7684\u5171\u5efa\u201d\uff08\u754c\u9762\uff09",
