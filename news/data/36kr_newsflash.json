                    "widgetTitle": "\u64ce\u6717\u53d1\u5e03\u65b0\u6b3e\u53cc\u8db3\u4eba\u5f62\u5177\u8eab\u670d\u52a1\u673a\u5668\u4ebaXMAN-F1",
                    "widgetContent": "36\u6c2a\u83b7\u6089\uff0c7\u670826\u65e5\uff0c\u5168\u7403\u5177\u8eab\u670d\u52a1\u673a\u5668\u4eba\u5382\u5546\u64ce\u6717\u667a\u80fd\u63a8\u51fa\u65b0\u6b3e\u53cc\u8db3\u4eba\u5f62\u5177\u8eab\u670d\u52a1\u673a\u5668\u4ebaXMAN-F1\uff0c\u4f9d\u6258\u64ce\u6717\u5c97\u4f4d\u5316\u5782\u57df\u6a21\u578bProS\uff0c\u7a81\u7834\u670d\u52a1\u8fb9\u754c\uff0c\u8fdb\u4e00\u6b65\u5b8c\u5584\u64ce\u6717\u591a\u5f62\u6001\u5177\u8eab\u670d\u52a1\u673a\u5668\u4eba\u77e9\u9635\u3002\u57fa\u4e8e\u64ce\u6717\u5168\u573a\u666f\u4ea7\u54c1\u77e9\u9635\u4e0e\u5e7f\u6cdb\u7684\u5546\u7528\u843d\u5730\u7ecf\u9a8c\uff0c\u64ce\u6717\u6301\u7eed\u5f00\u53d1\u5e76\u6b63\u5f0f\u63a8\u51fa\u5168\u7403\u9996\u4e2a\u9488\u5bf9\u670d\u52a1\u4e1a\u7684\u5c97\u4f4d\u5316\u5782\u57df\u6a21\u578bProS\uff0c\u901a\u8fc7\u7ed3\u5408\u901a\u7528\u5927\u6a21\u578b\u63d0\u4f9b\u8de8\u573a\u666f\u57fa\u7840\u80fd\u529b\uff0cXMAN-F1\u5b9e\u73b0\u4e86\u4ece\u5355\u4e00\u4efb\u52a1\u6267\u884c\u5230\u5168\u573a\u666f\u670d\u52a1\u95ed\u73af\u7684\u8de8\u8d8a\uff0c\u53ef\u5b9e\u73b0\u9910\u5385\u3001\u9152\u5e97\u3001\u96f6\u552e\u7b49\u7ec6\u5206\u9886\u57df\u7684\u6807\u51c6\u5316\u670d\u52a1\u95ed\u73af\uff0c\u53ef\u80dc\u4efb\u9910\u98df\u5236\u4f5c\u3001\u914d\u9910\u6536\u53f0\u3001\u623f\u95f4\u6574\u7406\u7b49\u5c97\u4f4d\u6807\u51c6\u5316\u64cd\u4f5c\u3002",
