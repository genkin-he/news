                    "widgetContent": "\u968f\u7740\u5e7f\u5dde\u65b0\u673a\u573a\u7b49\u4e00\u6279\u91cd\u70b9\u9879\u76ee\u5f00\u5de5\u5efa\u8bbe\uff0c\u57fa\u5efa\u6295\u8d44\u6210\u4e3a\u7a33\u589e\u957f\u7684\u5173\u952e\u529b\u91cf\u3002\u4e0e\u6b64\u540c\u65f6\uff0c\u5404\u5730\u56e0\u5730\u5236\u5b9c\u53d1\u5c55\u65b0\u8d28\u751f\u4ea7\u529b\uff0c\u5e26\u52a8\u9ad8\u6280\u672f\u4ea7\u4e1a\u6295\u8d44\u8f83\u5feb\u589e\u957f\u3002\u4e13\u5bb6\u9884\u8ba1\uff0c\u968f\u7740\u6269\u6295\u8d44\u653f\u7b56\u6301\u7eed\u53d1\u529b\u3001\u91cd\u5927\u5de5\u7a0b\u9879\u76ee\u52a0\u5feb\u63a8\u8fdb\uff0c\u5bf9\u6295\u8d44\u589e\u957f\u7684\u652f\u6491\u529b\u5ea6\u4ecd\u5c06\u8f83\u5f3a\u3002\uff08\u4e2d\u8bc1\u7f51\uff09",
