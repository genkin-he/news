                    "widgetTitle": "\u6c88\u4e39\u9633\uff1a\u5916\u8d44\u6765\u534e\u6295\u8d44\u6709\u56db\u4e2a\u65b0\u5546\u673a",
                    "widgetContent": "3\u67085\u65e5\uff0c\u300a\u653f\u5e9c\u5de5\u4f5c\u62a5\u544a\u300b\u8d77\u8349\u7ec4\u8d1f\u8d23\u4eba\u3001\u56fd\u52a1\u9662\u7814\u7a76\u5ba4\u4e3b\u4efb\u6c88\u4e39\u9633\u5728\u56fd\u65b0\u529e\u5439\u98ce\u4f1a\u4e0a\u8868\u793a\uff0c\u4eca\u5e74\u300a\u653f\u5e9c\u5de5\u4f5c\u62a5\u544a\u300b\u63d0\u51fa\u201c\u4fc3\u8fdb\u5916\u8d44\u5883\u5185\u518d\u6295\u8d44\u3001\u6269\u5927\u672c\u5730\u5316\u751f\u4ea7\u201d\uff0c\u4f53\u73b0\u4e86\u4e2d\u56fd\u653f\u5e9c\u6301\u7eed\u63a8\u8fdb\u9ad8\u6c34\u5e73\u5bf9\u5916\u5f00\u653e\uff0c\u6b22\u8fce\u8de8\u56fd\u516c\u53f8\u957f\u671f\u6df1\u8015\u4e2d\u56fd\u7684\u575a\u5b9a\u51b3\u5fc3\u4fe1\u5fc3\u3002\u6211\u56fd\u4f5c\u4e3a\u5168\u7403\u8d44\u672c\u7406\u60f3\u7684\u6295\u8d44\u76ee\u7684\u5730\uff0c\u4e00\u76f4\u5177\u6709\u8f83\u5f3a\u5438\u5f15\u529b\u3002\u6c88\u4e39\u9633\u8c08\u5230\uff0c\u4e00\u4e9b\u5916\u8d44\u673a\u6784\u8fd1\u671f\u5bf9\u8de8\u56fd\u4f01\u4e1a\u7684\u8c03\u67e5\u663e\u793a\uff0c9\u6210\u4ee5\u4e0a\u7684\u53d7\u8bbf\u4f01\u4e1a\u5c06\u7ee7\u7eed\u5728\u534e\u6295\u8d44\uff0c\u8fd17\u6210\u7684\u4f01\u4e1a\u9ad8\u7ba1\u5bf9\u672a\u67653\u20145\u5e74\u5728\u4e2d\u56fd\u7684\u53d1\u5c55\u6709\u4fe1\u5fc3\u3002\u6c88\u4e39\u9633\u8868\u793a\uff0c\u4ece\u5f53\u524d\u60c5\u51b5\u770b\uff0c\u5916\u8d44\u6765\u534e\u6295\u8d44\u6709\u8d85\u5927\u89c4\u6a21\u5e02\u573a\u3001\u670d\u52a1\u4e1a\u53d1\u5c55\u3001\u521b\u65b0\u751f\u6001\u3001\u5f00\u653e\u9ad8\u5730\u7b49\u56db\u4e2a\u65b0\u7684\u5546\u673a\u3002\uff08\u8bc1\u5238\u65f6\u62a5\uff09",
