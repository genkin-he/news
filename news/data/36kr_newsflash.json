                    "widgetTitle": "\u7eff\u8335\u7ecf\u6d4e\u201c\u8e22\u201d\u51fa\u5927\u5e02\u573a \u5c0f\u57ce\u8d5b\u4e8b\u62c9\u52a812\u4ebf\u6d88\u8d39",
                    "widgetContent": "\u4eca\u5e74\u7fa4\u4f17\u6027\u4f53\u80b2\u8fd0\u52a8\u7684\u9ad8\u53c2\u4e0e\u5ea6\uff0c\u6210\u4e3a\u4f53\u80b2\u5e02\u573a\u7684\u4e00\u5927\u4eae\u70b9\u3002\u5728\u6e56\u5357\u6c38\u5dde\u8fd9\u5ea7\u5c0f\u57ce\uff0c\u5728\u6b63\u5f0f\u6bd4\u8d5b\u524d\uff0c\u751a\u81f3\u90fd\u6ca1\u6709\u4e00\u4e2a\u6b63\u89c4\u7684\u8d5b\u4e8b\u8db3\u7403\u573a\u3002\u4f46\u7ecf\u8fc7\u77ed\u77ed\u4e24\u4e09\u4e2a\u6708\uff0c\u8fd9\u91cc\u5374\u6210\u4e3a\u4e0d\u5c11\u6e38\u5ba2\u4e89\u76f8\u6253\u5361\u7684\u65b0\u76ee\u7684\u5730\uff0c\u4f53\u80b2\u573a\u7684\u201c\u7eff\u8335\u7ecf\u6d4e\u201d\u4e5f\u4e3a\u5f53\u5730\u62d3\u5c55\u51fa\u66f4\u591a\u65b0\u7684\u6d88\u8d39\u4e1a\u6001\u3002\u7f51\u7edc\u5e73\u53f0\u5927\u6570\u636e\u663e\u793a\uff0c\u6574\u4e2a\u8d5b\u4e8b\u671f\u95f4\uff0c\u6c38\u5dde\u5e02\u7684\u9152\u5e97\u9884\u8ba2\u91cf\u8f83\u53bb\u5e74\u540c\u671f\u589e\u957f87%\uff0c\u8d5b\u4e8b\u76f8\u5173\u6587\u65c5\u6d88\u8d39\u603b\u989d\u8d85\u8fc76.2\u4ebf\u5143\u3002\u6e56\u5357\u7701\u6c38\u5dde\u5e02\u5546\u52a1\u5c40\u526f\u5c40\u957f\u9093\u5efa\u534e\u8868\u793a\uff0c\u5e26\u52a8\u5ba2\u6d41\u91cf\u8fd1800\u4e07\u4eba\u6b21\uff0c\u62c9\u52a8\u6d88\u8d39\u8fd112\u4ebf\u5143\u3002\u5b9e\u73b0\u4e86\u8d5b\u4e8b\u7ecf\u6d4e\u4e0e\u533a\u57df\u6d88\u8d39\u7684\u53cc\u5411\u8d4b\u80fd\u3002",
