                    "widgetContent": "\u9999\u6e2f\u7279\u522b\u884c\u653f\u533a\u653f\u5e9c\u4e8e5\u670830\u65e5\u5728\u5baa\u62a5\u520a\u767b\u300a\u7a33\u5b9a\u5e01\u6761\u4f8b\u300b\uff0c\u8fd9\u610f\u5473\u7740\u300a\u7a33\u5b9a\u5e01\u6761\u4f8b\u300b\u6b63\u5f0f\u6210\u4e3a\u6cd5\u4f8b\u3002\u6b64\u524d\uff0c\u9999\u6e2f\u7acb\u6cd5\u4f1a\u5df2\u7ecf\u57285\u670821\u65e5\u6b63\u5f0f\u901a\u8fc7\u8be5\u6761\u4f8b\u8349\u6848\uff0c\u7528\u4ee5\u5728\u9999\u6e2f\u8bbe\u7acb\u201c\u6cd5\u5e01\u7a33\u5b9a\u5e01\u201d (\u6302\u94a9\u6cd5\u5b9a\u8d27\u5e01\u7684\u7a33\u5b9a\u5e01)\u53d1\u884c\u4eba\u7684\u53d1\u724c\u5236\u5ea6\u3002\u8be5\u6cd5\u4f8b\u65e8\u5728\u63a8\u52a8\u91d1\u878d\u521b\u65b0\u7684\u540c\u65f6\u4fdd\u6301\u91d1\u878d\u7a33\u5b9a\uff0c\u5e76\u6807\u5fd7\u7740\u9999\u6e2f\u5728\u6570\u5b57\u8d44\u4ea7\u9886\u57df\u8fc8\u51fa\u4e86\u91cd\u8981\u7684\u4e00\u6b65\u3002\uff08e\u516c\u53f8\uff09",
