                    "widgetContent": "\u4e2d\u957f\u671f\u8d44\u91d1\u662f\u8d44\u672c\u5e02\u573a\u5065\u5eb7\u8fd0\u884c\u7684\u201c\u7a33\u5b9a\u5668\u201d\u201c\u538b\u8231\u77f3\u201d\u3002\u653f\u5e9c\u5de5\u4f5c\u62a5\u544a\u63d0\u51fa\u201c\u6df1\u5316\u8d44\u672c\u5e02\u573a\u6295\u878d\u8d44\u7efc\u5408\u6539\u9769\uff0c\u5927\u529b\u63a8\u52a8\u4e2d\u957f\u671f\u8d44\u91d1\u5165\u5e02\u201d\u3002\u4e2d\u56fd\u8bc1\u76d1\u4f1a\u4e3b\u5e2d\u5434\u6e05\u5728\u5341\u56db\u5c4a\u5168\u56fd\u4eba\u5927\u4e09\u6b21\u4f1a\u8bae\u7ecf\u6d4e\u4e3b\u9898\u8bb0\u8005\u4f1a\u4e0a\u8868\u793a\uff0c\u9010\u9879\u6253\u901a\u793e\u4fdd\u3001\u4fdd\u9669\u3001\u7406\u8d22\u7b49\u4e2d\u957f\u671f\u8d44\u91d1\u5165\u5e02\u5361\u70b9\u5835\u70b9\uff0c\u4e0d\u65ad\u5f15\u5165\u201c\u6e90\u5934\u6d3b\u6c34\u201d\u3002\u5728\u4e1a\u5185\u4eba\u58eb\u770b\u6765\uff0c\u5927\u529b\u63a8\u52a8\u4e2d\u957f\u671f\u8d44\u91d1\u5165\u5e02\uff0c\u65e2\u662f\u8d44\u672c\u5e02\u573a\u7a33\u5b9a\u53d1\u5c55\u7684\u91cd\u8981\u4e3e\u63aa\uff0c\u4e5f\u662f\u6df1\u5316\u6295\u878d\u8d44\u6539\u9769\u7684\u5173\u952e\u4e00\u73af\u3002\u4e2d\u957f\u671f\u8d44\u91d1\u6301\u7eed\u5165\u5e02\u4e0d\u4ec5\u4e3a\u8d44\u672c\u5e02\u573a\u7a33\u5b9a\u8fd0\u884c\u63d0\u4f9b\u4e86\u6709\u6548\u7684\u8d44\u91d1\u652f\u6301\uff0c\u8fd8\u80fd\u66f4\u597d\u53d1\u6325\u8d44\u672c\u5e02\u573a\u98ce\u9669\u5171\u62c5\u3001\u5229\u76ca\u5171\u4eab\u673a\u5236\uff0c\u52a9\u529b\u63a8\u52a8\u6211\u56fd\u7ecf\u6d4e\u7ed3\u6784\u8f6c\u578b\u4e0e\u9ad8\u8d28\u91cf\u53d1\u5c55\u3002\uff08\u4e0a\u8bc1\u62a5\uff09",
