                    "widgetTitle": "\u90ed\u660e\ud86d\udcf9\uff1a\u65b0\u5173\u7a0e\u653f\u7b56\u5bf9\u82f9\u679c\u662f\u8d1f\u9762\u5f71\u54cd\uff0c\u4f46\u6709\u8bb8\u591a\u65b9\u5f0f\u53ef\u8f6c\u5ac1\u5173\u7a0e\u6210\u672c",
                    "widgetContent": "\u77e5\u540d\u82f9\u679c\u5206\u6790\u5e08\u90ed\u660e\ud86d\udcf9\u8868\u793a\uff0c\u65b0\u5173\u7a0e\u653f\u7b56\u5bf9\u82f9\u679c\u65e0\u7591\u662f\u8d1f\u9762\u5f71\u54cd\uff0c\u4f46\u82f9\u679c\u5e76\u975e\u65e0\u8ba1\u53ef\u65bd\u3002\u5728\u7f8e\u56fd\u5e02\u573a\uff0c\u65b0\u6b3e\u9ad8\u9636iPhone\u5360\u6bd465-70%\uff0c\u800c\u9ad8\u9636\u7528\u6237\u76f8\u5bf9\u80fd\u63a5\u53d7\u82f9\u679c\u6da8\u4ef7\u3002\u6b64\u5916\uff0c\u82f9\u679c\u6709\u8bb8\u591a\u65b9\u5f0f\u53ef\u8f6c\u5ac1\u5173\u7a0e\u6210\u672c\uff0c\u4ee5\u964d\u4f4e\u6d88\u8d39\u8005\u5bf9\u6da8\u4ef7\u7684\u8d1f\u9762\u89c2\u611f\uff0c\u5982\u4e0e\u7535\u4fe1\u8fd0\u8425\u5546\u5408\u4f5c\u63d0\u9ad8\u8865\u8d34\u91d1\u989d\u3001\u964d\u4f4eTrade In\u6362\u8d2d\u65b9\u6848\u6298\u6263\u7b49\u3002\u53e6\u4e00\u4e2a\u65b9\u5f0f\u662f\u52a0\u5927\u5bf9\u4f9b\u5e94\u94fe\u7684\u780d\u4ef7\u529b\u9053\u3002\u9884\u671f\u5927\u90e8\u5206\u7684\u82f9\u679c\u4f9b\u5e94\u94fe\u5c06\u9762\u4e34\u66f4\u5927\u7684\u780d\u4ef7\u538b\u529b\u3002\u5982\u679c\u82f9\u679c\u7684\u6bdb\u5229\u7387\u56e0\u5173\u7a0e\u800c\u6ed1\u843d\u81f340%\u4ee5\u4e0b\uff0c\u8fd9\u5e94\u8be5\u662f\u6682\u65f6\u7684\u73b0\u8c61\uff0c\u957f\u671f\u5e94\u8be5\u8fd8\u662f\u80fd\u7ef4\u630140%\u4ee5\u4e0a\u3002\uff08\u65b0\u6d6a\u8d22\u7ecf\uff09",
