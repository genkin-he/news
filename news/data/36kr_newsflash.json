                    "widgetTitle": "\u4fdd\u969c\u5927\u6e7e\u533a\u57ce\u5e02\u7fa4\u4f9b\u6c34\u5b89\u5168\uff0c\u73e0\u6c5f\u201c\u538b\u54b8\u8865\u6de1\u201d\u8c03\u5ea6\u8865\u6c34\u8fd190\u4ebf\u7acb\u65b9\u7c73",
                    "widgetContent": "\u6c34\u5229\u90e8\u6d88\u606f\uff0c\u53bb\u5e7411\u6708\u8fdb\u5165\u67af\u6c34\u671f\u4ee5\u6765\uff0c\u73e0\u6c5f\u6d41\u57df\u5927\u90e8\u964d\u96e8\u91cf\u8f83\u5e38\u5e74\u504f\u5c11\u4e09\u6210\uff0c\u73e0\u6c5f\u6cb3\u53e3\u54b8\u6f6e\u4e0a\u6eaf\u8fdb\u5165\u6d3b\u8dc3\u671f\u3002\u622a\u81f3\u76ee\u524d\uff0c\u6c34\u5229\u90e8\u73e0\u6c5f\u6c34\u5229\u59d4\u5458\u4f1a\u79d1\u5b66\u8c03\u5ea6\u897f\u6c5f\u4e0a\u6e38\u9f99\u6ee9\u3001\u5927\u85e4\u5ce1\u3001\u767e\u8272\u7b49\u6c34\u5e93\u7fa4\u5411\u4e0b\u6e38\u8865\u6c34\u8fd190\u4ebf\u7acb\u65b9\u7c73\uff0c\u897f\u6c5f\u5e72\u6d41\u63a7\u5236\u7ad9\u68a7\u5dde\u6c34\u6587\u7ad9\u5e73\u5747\u6d41\u91cf\u63d0\u9ad860%\uff0c\u5168\u9762\u538b\u5236\u6cb3\u53e3\u54b8\u6f6e\u4e0a\u6eaf\uff0c\u7ca4\u6e2f\u6fb3\u5927\u6e7e\u533a\u57ce\u5e02\u7fa4\u53d6\u6de1\u84c4\u6c34\u60c5\u51b5\u4e3a\u8fd110\u5e74\u6765\u6700\u4f18\uff0c\u5168\u529b\u4fdd\u969c\u6625\u8282\u671f\u95f4\u7ca4\u6e2f\u6fb3\u5927\u6e7e\u533a\u57ce\u5e02\u7fa4\u4f9b\u6c34\u5b89\u5168\u3002",
