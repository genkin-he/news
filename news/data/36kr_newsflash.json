                    "widgetTitle": "\u7279\u6717\u666e\uff1a\u6b63\u5728\u5173\u6ce8\u534a\u5bfc\u4f53\u548c\u6574\u4e2a\u7535\u5b50\u4f9b\u5e94\u94fe",
                    "widgetContent": "\u5728\u5468\u672b\u5f15\u53d1\u6df7\u4e71\u5e76\u7ed9\u5176\u5168\u7403\u8d38\u6613\u8ba1\u5212\u589e\u6dfb\u65b0\u7684\u4e0d\u786e\u5b9a\u6027\u4e4b\u540e\uff0c\u7f8e\u56fd\u603b\u7edf\u7279\u6717\u666e\u8bd5\u56fe\u6f84\u6e05\u7f8e\u56fd\u5bf9\u9ad8\u79d1\u6280\u4ea7\u54c1\u5173\u7a0e\u7684\u72b6\u51b5\u3002\u7279\u6717\u666e\u5728\u793e\u4ea4\u5a92\u4f53\u4e0a\u8868\u793a\uff1a\u6ca1\u6709\u4efb\u4f55\u56fd\u5bb6\u80fd\u591f\u56e0\u4e3a\u5bf9\u6211\u4eec\u5b9e\u884c\u4e0d\u516c\u5e73\u7684\u8d38\u6613\u9006\u5dee\u548c\u975e\u8d27\u5e01\u6027\u5173\u7a0e\u58c1\u5792\u800c\u201c\u9003\u8131\u60e9\u7f5a\u201d\u3002\u5468\u4e94\u5e76\u6ca1\u6709\u5ba3\u5e03\u4efb\u4f55\u201c\u5173\u7a0e\u8c41\u514d\u201d\u3002\u5b83\u4eec\u53ea\u662f\u88ab\u5f52\u5165\u4e86\u4e0d\u540c\u7684\u5173\u7a0e\u201c\u7c7b\u522b\u201d\u3002\u5f53\u5730\u65f6\u95f4\u5468\u4e94\u665a\u4e0a\uff0c\u7f8e\u56fd\u6d77\u5173\u4e0e\u8fb9\u5883\u4fdd\u62a4\u5c40\u53d1\u5e03\u89c4\u5b9a\uff0c\u667a\u80fd\u624b\u673a\u3001\u7b14\u8bb0\u672c\u7535\u8111\u548c\u786c\u76d8\u7b49\u7279\u5b9a\u9ad8\u79d1\u6280\u4ea7\u54c1\u53ef\u514d\u53d7\u7279\u6717\u666e\u7684 \u201c\u5bf9\u7b49\u201d \u5173\u7a0e\u3002\uff08\u65b0\u6d6a\u8d22\u7ecf\uff09",
