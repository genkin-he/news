                    "widgetTitle": "\u201c\u5e02\u573a\u6b63\u56e0\u8d38\u6613\u6218\u9677\u5165\u9707\u8361\u201d\uff0c\u7f8e\u4ebf\u4e07\u5bcc\u7fc1\u547c\u5401\u7f8e\u653f\u5e9c\u6682\u505c\u5173\u7a0e\u653f\u7b56",
                    "widgetContent": "\u5f53\u5730\u65f6\u95f44\u67089\u65e5\uff0c\u636e\u7f8e\u56fd\u5168\u56fd\u5e7f\u64ad\u516c\u53f8\u62a5\u9053\uff0c\u652f\u6301\u7279\u6717\u666e\u7684\u7f8e\u56fd\u4ebf\u4e07\u5bcc\u7fc1\u3001\u7f8e\u56fd\u6f58\u5174\u5e7f\u573a\u8d44\u672c\u7ba1\u7406\u516c\u53f8\u9996\u5e2d\u6267\u884c\u5b98\u6bd4\u5c14\u00b7\u963f\u514b\u66fc\u547c\u5401\u6682\u505c\u5f53\u524d\u7684\u5173\u7a0e\u63aa\u65bd\uff0c\u79f0\u5e02\u573a\u6b63\u56e0\u65e5\u76ca\u5347\u7ea7\u7684\u8d38\u6613\u6218\u800c\u9677\u5165\u9707\u8361\u3002\u963f\u514b\u66fc\u8868\u793a\uff1a\u201c\u5982\u679c\u603b\u7edf\u4e0d\u5c3d\u5feb\u6682\u505c\u5173\u7a0e\u7684\u5f71\u54cd\uff0c\u8bb8\u591a\u5c0f\u4f01\u4e1a\u5c06\u4f1a\u7834\u4ea7\u3002\u201d\u4ed6\u8865\u5145\u9053\uff1a\u201c\u63a5\u4e0b\u6765\u5c06\u662f\u4e2d\u578b\u4f01\u4e1a\u3002\u6682\u505c90\u5929\u5c06\u4f7f\u7279\u6717\u666e\u80fd\u591f\u5b9e\u73b0\u5176\u76ee\u6807\uff0c\u540c\u65f6\u907f\u514d\u5728\u77ed\u671f\u5185\u6467\u6bc1\u5c0f\u4f01\u4e1a\u3002\u5e0c\u671b\u7406\u6027\u6700\u7ec8\u5360\u4e0a\u98ce\u3002\u201d\uff08\u592e\u89c6\u65b0\u95fb\uff09",
