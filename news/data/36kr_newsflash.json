                    "widgetContent": "\u4eca\u5e74\u4ee5\u6765\uff0c\u57fa\u91d1\u5206\u7ea2\u5408\u8ba1\u903e2000\u4ebf\u5143\uff0c\u5176\u4e2d\u6743\u76ca\u7c7b\u57fa\u91d1\u52a0\u5927\u5206\u7ea2\u529b\u5ea6\uff0cETF\u5206\u7ea2\u8868\u73b0\u4eae\u773c\u3002\u4e1a\u5185\u4eba\u58eb\u8868\u793a\uff0c\u57fa\u91d1\u5206\u7ea2\u662f\u63d0\u9ad8\u6295\u8d44\u8005\u83b7\u5f97\u611f\u548c\u63d0\u5347\u6301\u6709\u4f53\u9a8c\u7684\u91cd\u8981\u65b9\u5f0f\u4e4b\u4e00\u3002\u672a\u6765\uff0c\u8d8a\u6765\u8d8a\u591a\u57fa\u91d1\u516c\u53f8\u6709\u671b\u52a0\u5927\u5206\u7ea2\u529b\u5ea6\u56de\u9988\u6295\u8d44\u8005\u3002\u5609\u5b9e\u57fa\u91d1\u8868\u793a\uff0c\u5728\u5e02\u573a\u56de\u8c03\u4e2d\uff0c\u53ef\u4ee5\u901a\u8fc7\u57fa\u91d1\u5206\u7ea2\u9501\u5b9a\u4e00\u90e8\u5206\u6536\u76ca\uff0c\u4e5f\u6709\u52a9\u4e8e\u89c4\u6a21\u826f\u6027\u53d1\u5c55\uff0c\u4f7f\u57fa\u91d1\u7ba1\u7406\u56e2\u961f\u7684\u64cd\u4f5c\u66f4\u7075\u6d3b\uff0c\u4ece\u800c\u63d0\u5347\u6295\u8d44\u8005\u7684\u6295\u8d44\u4f53\u9a8c\u3002\uff08\u4e2d\u8bc1\u62a5\uff09",
