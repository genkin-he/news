                    "widgetContent": "\u4e0a\u8bc9\u6cd5\u9662\u8981\u6c42\u5468\u672b\u5c31\u7279\u6717\u666e\u5bfb\u6c42\u7f62\u514d\u7f8e\u8054\u50a8\u7406\u4e8b\u4e3d\u838e\u00b7\u5e93\u514b\u63d0\u4ea4\u4e66\u9762\u8bba\u8bc1\uff0c\u8fd9\u610f\u5473\u7740\u88c1\u51b3\u6700\u65e9\u53ef\u80fd\u5728\u5468\u65e5\u665a\u95f4\u505a\u51fa\u3002\u53f8\u6cd5\u90e8\u5468\u56db\u8bf7\u6c42\u534e\u76db\u987f\u4e09\u540d\u6cd5\u5b98\u7ec4\u6210\u7684\u5c0f\u7ec4\u53d1\u5e03\u6240\u8c13\u201c\u6682\u7f13\u6267\u884c\u4ee4\u201d\uff0c\u8fd9\u9879\u547d\u4ee4\u5f88\u53ef\u80fd\u4f1a\u4f7f\u7279\u6717\u666e\u5bf9\u5e93\u514b\u7684\u89e3\u804c\u51b3\u5b9a\u5728\u4e0a\u8bc9\u7533\u8bf7\u6b63\u5f0f\u5ba1\u7406\u524d\u751f\u6548\u3002\u5468\u56db\u665a\u95f4\uff0c\u6cd5\u5b98\u5c0f\u7ec4\u4e0b\u4ee4\u5e93\u514b\u987b\u5728\u5468\u516d\u4e0b\u53485\u70b9\u524d\u5bf9\u7279\u6717\u666e\u7684\u8bf7\u6c42\u4f5c\u51fa\u56de\u5e94\u3002\u53f8\u6cd5\u90e8\u5219\u88ab\u8981\u6c42\u5728\u5468\u65e5\u4e0b\u53483\u70b9\u524d\u63d0\u4ea4\u5bf9\u5e93\u514b\u7684\u7b54\u590d\u3002\u5982\u679c\u4e0a\u8bc9\u6cd5\u9662\u62d2\u7edd\u53f8\u6cd5\u90e8\u7684\u8bf7\u6c42\uff0c\u90a3\u4e48\u7279\u6717\u666e\u53ef\u80fd\u4f1a\u8fc5\u901f\u8981\u6c42\u6700\u9ad8\u6cd5\u9662\u5ba1\u7406\u6b64\u6848\u3002\uff08\u65b0\u6d6a\u8d22\u7ecf\uff09",
