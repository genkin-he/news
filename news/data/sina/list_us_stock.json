        {
            "id": "851726793",
            "title": "日韩股市集体高开 韩国首尔综指高开2.9%",
            "description": "<div class=\"article\" id=\"artibody\">\n<!-- 相关专题top start-->\n<!-- 相关专题top end-->\n<!-- 期货推广begin -->\n<!-- 期货推广end -->\n<!-- 秒拍begin -->\n<!-- 秒拍end -->\n<!-- 视频播放器start -->\n<!-- 视频播放器end -->\n<!-- 行情图begin -->\n<!-- 行情图end -->\n<p>　　日经225指数开盘上涨0.7%，报58265.18点，金融股领涨。韩国综合股价指数（KOSPI）开盘上涨2.9%，至6141.60点。</p><!-- news_keyword_pub,usstock, -->\n<!-- 正文下iframe -->\n<!-- 正文下iframe -->\n<!-- 总声明-->\n<!-- 总声明-->\n<!-- 文末二维码 start -->\n<!-- 文末二维码 start -->\n\n\n<!-- 文末二维码 start -->\n<!-- 文末二维码 start -->\n<!-- 编辑姓名及工作代码 -->\n\n<!-- 编辑姓名及工作代码-->\n</div>",
            "link": "https://finance.sina.com.cn/stock/usstock/c/2026-04-15/doc-inhupqxh1035806.shtml",
