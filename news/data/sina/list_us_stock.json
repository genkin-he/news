            "description": "<div class=\"article\" id=\"artibody\">\n<!-- 相关专题top start-->\n<!-- 相关专题top end-->\n<!-- 期货推广begin -->\n<!-- 期货推广end -->\n<!-- 秒拍begin -->\n<!-- 秒拍end -->\n<!-- 视频播放器start -->\n<!-- 视频播放器end -->\n<!-- 行情图begin -->\n<!-- 行情图end -->\n<p>　　边疆航空等公司向政府申请25亿美元资金，以抵消高昂的航空燃油成本。与此同时，精神航空正在寻求另一项独立的5亿美元救助计划。</p><!-- news_keyword_pub,usstock, -->\n<!-- 正文下iframe -->\n<!-- 正文下iframe -->\n<!-- 总声明-->\n<!-- 总声明-->\n<!-- 文末二维码 start -->\n<!-- 文末二维码 start -->\n\n\n<!-- 文末二维码 start -->\n<!-- 文末二维码 start -->\n<!-- 编辑姓名及工作代码 -->\n\n<!-- 编辑姓名及工作代码-->\n</div>",
