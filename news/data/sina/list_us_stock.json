            "description": "<div class=\"article\" id=\"artibody\">\n<!-- 相关专题top start-->\n<!-- 相关专题top end-->\n<!-- 期货推广begin -->\n<!-- 期货推广end -->\n<!-- 秒拍begin -->\n<!-- 秒拍end -->\n<!-- 视频播放器start -->\n<!-- 视频播放器end -->\n<!-- 行情图begin -->\n<!-- 行情图end -->\n<p>　　韩国娱乐、文化和化妆品类股大涨，YG娱乐一度上涨9.6%，为11月1日以来最大盘中涨幅，JYP娱乐上涨6.6%，Hybe涨7.4%，SM娱乐涨11%，Studio Dragon 上涨24%。韩国KOSPI指数跌0.3%，科斯达克指数涨0.3%。</p><!-- news_keyword_pub,usstock, --><!-- 开户二维码 start -->\n<div id=\"app-kaihu-stock\"></div>\n\n<!-- 开户二维码 end -->\n<!-- 正文下iframe -->\n<!-- 正文下iframe -->\n<!-- 总声明-->\n<!-- 总声明-->\n<!-- 文末二维码 start -->\n<!-- 文末二维码 start -->\n\n\n<!-- 文末二维码 start -->\n<!-- 文末二维码 start -->\n<!-- 编辑姓名及工作代码 -->\n\n<!-- 编辑姓名及工作代码-->\n</div>",
