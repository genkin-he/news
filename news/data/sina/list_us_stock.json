            "description": "<div class=\"article\" id=\"artibody\">\n<!-- 相关专题top start-->\n<!-- 相关专题top end-->\n<!-- 期货推广begin -->\n<!-- 期货推广end -->\n<!-- 秒拍begin -->\n<!-- 秒拍end -->\n<!-- 视频播放器start -->\n<!-- 视频播放器end -->\n<!-- 行情图begin -->\n<!-- 行情图end -->\n<p>　　由于伊朗战争导致霍尔木兹海峡运输中断，能源供应紧张，亚洲多个国家政府实施了居家办公、缩短工作周等措施。</p><!-- news_keyword_pub,usstock, -->\n<!-- 正文下iframe -->\n<!-- 正文下iframe -->\n<!-- 总声明-->\n<!-- 总声明-->\n<!-- 文末二维码 start -->\n<!-- 文末二维码 start -->\n\n\n<!-- 文末二维码 start -->\n<!-- 文末二维码 start -->\n<!-- 编辑姓名及工作代码 -->\n\n<!-- 编辑姓名及工作代码-->\n</div>",
