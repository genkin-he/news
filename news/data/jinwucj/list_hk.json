{"data": [{"id": 254992373, "title": "\u7f8e\u56fd9\u6708\u8fdb\u53e3\u7269\u4ef7\u6307\u6570\u6708\u7387\u4e3a-0.4% \u7b26\u5408\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd9\u6708\u8fdb\u53e3\u7269\u4ef7\u6307\u6570\u6708\u7387\u4e3a-0.4%\u3002\u524d\u503c\u7531-0.3%\u4fee\u6b63\u4e3a-0.2%\uff0c\u9884\u671f-0.4%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254992373", "pub_date": "2024-10-16 20:36:27"}, {"id": 254986718, "title": "Stellantis(STLA)\u56e0\u5236\u52a8\u8e0f\u677f\u5b58\u5728\u95ee\u9898 \u5728\u7f8e\u53ec\u56de\u8d852\u4e07\u8f86\u6df7\u5408\u52a8\u529b\u8de8\u754cSUV", "description": "<p>\u91d1\u543e\u8d22\u8baf | Stellantis(STLA)\u5468\u4e09\u8868\u793a\uff0c\u516c\u53f8\u5c06\u5728\u7f8e\u56fd\u53ec\u56de20,755\u8f86\u6df7\u5408\u52a8\u529b\u8de8\u754c SUV\uff0c\u7531\u4e8e\u8be5\u8f66\u578b\u7684\u5236\u52a8\u8e0f\u677f\u5b58\u5728\u95ee\u9898\u3002<br/><br/>\u8be5\u6c7d\u8f66\u5236\u9020\u5546\u8868\u793a\uff0c\u4e00\u4e9b SUV \u914d\u5907\u7684\u5236\u52a8\u8e0f\u677f\u5728\u4f7f\u7528\u8fc7\u7a0b\u4e2d\u53ef\u80fd\u4f1a\u610f\u5916\u8131\u79bb\u3002<br/><br/>Stellantis \u8868\u793a\uff0c\u5176\u5df2\u83b7\u6089\u5168\u7403\u8303\u56f4\u5185\u53d1\u751f\u4e86 15 \u8d77\u6b64\u7c7b\u4e8b\u4ef6\uff0c\u5176\u4e2d\u5305\u62ec\u4e00\u8d77\u4e8b\u6545\uff0c\u4f46\u5e76\u672a\u9020\u6210\u4eba\u5458\u4f24\u4ea1\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254986718", "pub_date": "2024-10-16 19:57:54"}, {"id": 254985854, "title": "\u7f8e\u56fd\u62b5\u62bc\u8d37\u6b3e\u5229\u7387\u5927\u5e45\u6500\u5347 30\u5e74\u671f\u5229\u7387\u4e24\u5468\u5185\u4e0a\u6da838\u4e2a\u57fa\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u62b5\u62bc\u8d37\u6b3e\u5229\u7387\u8fde\u7eed\u7b2c\u4e8c\u5468\u663e\u8457\u6500\u5347\uff0c\u8fbe\u5230\u81ea8\u6708\u521d\u4ee5\u6765\u7684\u6700\u9ad8\u6c34\u5e73\uff0c\u5bfc\u81f4\u8d2d\u623f\u548c\u518d\u878d\u8d44\u6d3b\u52a8\u660e\u663e\u51cf\u5c11\u3002\u6839\u636e\u7f8e\u56fd\u62b5\u62bc\u8d37\u6b3e\u94f6\u884c\u5bb6\u534f\u4f1a\uff08MBA\uff09\u5468\u4e09\u53d1\u5e03\u7684\u6570\u636e\uff0c\u622a\u81f310\u670811\u65e5\u5f53\u5468\uff0c30\u5e74\u671f\u56fa\u5b9a\u5229\u7387\u62b5\u62bc\u8d37\u6b3e\u7684\u5408\u540c\u5229\u7387\u4e0a\u6da8\u4e8616\u4e2a\u57fa\u70b9\uff0c\u8fbe\u52306.52%\u3002\u8fd9\u4e00\u5229\u7387\u5728\u8fc7\u53bb\u4e24\u5468\u5185\u7d2f\u8ba1\u4e0a\u6da8\u4e8638\u4e2a\u57fa\u70b9\uff0c\u521b\u4e0b\u81ea2023\u5e742\u6708\u4ee5\u6765\u7684\u6700\u5927\u6da8\u5e45\u300215\u5e74\u671f\u56fa\u5b9a\u5229\u7387\u62b5\u62bc\u8d37\u6b3e\u7684\u5408\u540c\u5229\u7387\u5219\u98d9\u5347\u4e8623\u4e2a\u57fa\u70b9\uff0c\u8fbe\u52305.94%\uff0c\u8fd9\u662f\u81ea5\u6708\u4ee5\u6765\u7684\u6700\u5927\u6da8\u5e45\u3002<br/><br/>\u8fd1\u671f\u62b5\u62bc\u8d37\u6b3e\u5229\u7387\u7684\u4e0a\u5347\u8d8b\u52bf\u4e0e\u7f8e\u56fd\u56fd\u503a\u6536\u76ca\u7387\u7684\u8d70\u52bf\u4e00\u81f4\uff0c\u4e3b\u8981\u662f\u56e0\u4e3a\u7ecf\u6d4e\u6570\u636e\u663e\u793a\u5c31\u4e1a\u589e\u957f\u5f3a\u52b2\u4e14\u901a\u80c0\u6301\u7eed\u9ad8\u4f4d\uff0c\u8fd9\u4f7f\u5f97\u6295\u8d44\u8005\u964d\u4f4e\u4e86\u5bf9\u672a\u6765\u5927\u5e45\u964d\u606f\u7684\u9884\u671f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254985854", "pub_date": "2024-10-16 19:51:17"}, {"id": 254984853, "title": "\u6469\u6839\u58eb\u4e39\u5229(MS)\u76d8\u524d\u6da8\u903e2% \u7b2c\u4e09\u5b63\u5ea6\u51c0\u8425\u6536\u8d85\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6469\u6839\u58eb\u4e39\u5229(MS)\u76d8\u524d\u80a1\u4ef7\u5411\u597d\uff0c\u6682\u6da82.01%\uff0c\u62a5114.48\u7f8e\u5143\u3002<br/><br/>\u516c\u53f8\u4e1a\u7ee9\u663e\u793a\uff0c\u7b2c\u4e09\u5b63\u5ea6\u51c0\u8425\u6536153.8\u4ebf\u7f8e\u5143\uff0c\u5e02\u573a\u9884\u671f143.5\u4ebf\u7f8e\u5143\u3002\u7b2c\u4e09\u5b63\u5ea6\u8d22\u5bcc\u7ba1\u7406\u51c0\u6536\u5165\u4e3a72.7\u4ebf\u7f8e\u5143\uff0c\u5e02\u573a\u9884\u671f\u4e3a68.8\u4ebf\u7f8e\u5143\u3002\u6295\u8d44\u94f6\u884c\u4e1a\u52a1\u6536\u5165\u4e3a14.6\u4ebf\u7f8e\u5143\uff0c\u5e02\u573a\u9884\u671f\u4e3a13.7\u4ebf\u7f8e\u5143\u3002\u56fa\u5b9a\u6536\u76ca\u3001\u5916\u6c47\u53ca\u5927\u5b97\u5546\u54c1\u4e1a\u52a1(FICC)\u9500\u552e\u548c\u4ea4\u6613\u6536\u5165\u4e3a20\u4ebf\u7f8e\u5143\uff0c\u5e02\u573a\u9884\u671f\u4e3a18.5\u4ebf\u7f8e\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254984853", "pub_date": "2024-10-16 19:44:28"}, {"id": 254983291, "title": "\u8054\u5408\u5927\u9646\u822a\u7a7a(UAL)\u76d8\u524d\u6da81.17% \u7b2c\u4e09\u5b63\u5ea6\u8425\u6536\u548c\u7ecf\u8c03\u6574\u6bcf\u80a1\u6536\u76ca\u80dc\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u8054\u5408\u5927\u9646\u822a\u7a7a(UAL)\u76d8\u524d\u80a1\u4ef7\u626c\u5347\uff0c\u6682\u6da81.17%\uff0c\u62a564.8\u7f8e\u5143\u3002<br/><br/>\u516c\u53f8\u516c\u5e03\u7684\u4e1a\u7ee9\u663e\u793a\uff0c\u7b2c\u4e09\u5b63\u5ea6\u8425\u6536\u4e3a148.43\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f2.5%\uff0c\u597d\u4e8e\u666e\u904d\u9884\u671f\u7684147.8\u4ebf\u7f8e\u5143\u3002\u7b2c\u4e09\u5b63\u5ea6\u8c03\u6574\u540e\u7684\u6bcf\u80a1\u6536\u76ca\u4e3a3.33\u7f8e\u5143\uff0c\u597d\u4e8e\u666e\u904d\u9884\u671f\u76843.07\u7f8e\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254983291", "pub_date": "2024-10-16 19:33:17"}, {"id": 254979766, "title": "\u745e\u5178\u91d1\u878d\u79d1\u6280\u5de8\u5934Klarna Bank AB\u51fa\u552e\u201c\u5148\u4e70\u540e\u4ed8\u201d\u8d37\u6b3e", "description": "<p>\u91d1\u543e\u8d22\u8baf | Klarna Bank AB\u8ba1\u5212\u516c\u5f00\u4e0a\u5e02\u524d\uff0c\u901a\u8fc7\u51fa\u552e\u5176\u5728\u82f1\u56fd\u53d1\u653e\u7684\u201c\u5148\u4e70\u540e\u4ed8\u201d\u8d37\u6b3e\u6765\u91ca\u653e\u8d44\u672c\u3002<br/><br/>\u5bf9\u51b2\u57fa\u91d1 Elliott Investment Management\u5b50\u516c\u53f8\u8fbe\u6210\u7684\u534f\u8bae\u5c06\u4e3aKlarna\u5728\u672a\u6765\u51e0\u5e74\u5e26\u6765300\u4ebf\u82f1\u9551\uff08390\u4ebf\u7f8e\u5143\uff09\u7684\u65b0\u589e\u8d44\u91d1\uff0c\u8be5\u516c\u53f8\u6b63\u5bfb\u6c42\u5728\u5168\u7403\u8303\u56f4\u5185\u62d3\u5c55\u4e1a\u52a1\u3002Klarna\u5c06\u7ee7\u7eed\u4e3a\u534f\u8bae\u4e2d\u5305\u542b\u7684\u8d37\u6b3e\u63d0\u4f9b\u670d\u52a1\u3002<br/><br/>Klarna\u9996\u5e2d\u8d22\u52a1\u5b98Niclas Neglen\u5728\u5ba3\u5e03\u8be5\u4ea4\u6613\u7684\u58f0\u660e\u4e2d\u8868\u793a\uff1a\u201c\u901a\u8fc7\u6709\u6548\u7ba1\u7406\u6211\u4eec\u7684\u8d44\u4ea7\uff0c\u6211\u4eec\u53ef\u4ee5\u66f4\u6709\u6548\u5730\u914d\u7f6e\u80a1\u4e1c\u6743\u76ca\u3002\u8fd9\u662f\u4e00\u9879\u72ec\u7279\u7684\u4ea4\u6613\uff0c\u65e8\u5728\u652f\u6301Klarna\u7684\u5168\u7403\u589e\u957f\u3002\u201d</p>", "link": "https://sky.szfiu.com/info/hk/details/254979766", "pub_date": "2024-10-16 19:08:15"}, {"id": 254978366, "title": "\u73b0\u8d27\u9ec4\u91d1\u77ed\u7ebf\u62c9\u5347 \u65e5\u5185\u6da80.45% \u5e02\u573a\u805a\u7126\u7f8e\u56fd\u5927\u9009\u548c\u7f8e\u8054\u50a8\u5229\u7387", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u73b0\u8d27\u9ec4\u91d1\u77ed\u7ebf\u62c9\u5347\uff0c\u65e5\u5185\u6da80.45%\uff0c\u62a52675.17\u7f8e\u5143/\u76ce\u53f8\u3002</p><p>\u968f\u7740\u6295\u8d44\u8005\u5c06\u6ce8\u610f\u529b\u8f6c\u5411\u5373\u5c06\u5230\u6765\u7684\u7f8e\u56fd\u5927\u9009\uff0c\u9ec4\u91d1\u4ef7\u683c\u4e0a\u6da8\u81f3\u65b0\u7684\u5386\u53f2\u9ad8\u4f4d\uff0c\u6c11\u610f\u8c03\u67e5\u9884\u6d4b\uff0c\u8ddd\u79bb\u5927\u9009\u8fd8\u6709\u4e0d\u5230\u4e09\u5468\u7684\u65f6\u95f4\uff0c\u9009\u4e3e\u7ed3\u679c\u5c06\u975e\u5e38\u63a5\u8fd1\u3002</p><p>\u9ec4\u91d1\u662f2024\u5e74\u8868\u73b0\u6700\u5f3a\u52b2\u7684\u5927\u5b97\u5546\u54c1\u4e4b\u4e00\uff0c\u7531\u4e8e\u5176\u4f5c\u4e3a\u907f\u9669\u8d44\u4ea7\u7684\u5438\u5f15\u529b\u548c\u592e\u884c\u7684\u75af\u72c2\u8d2d\u4e70\uff0c\u9ec4\u91d1\u4ef7\u683c\u5c61\u521b\u65b0\u9ad8\u3002\u73b0\u5728\uff0c\u968f\u7740\u6574\u4e2a\u91d1\u878d\u5e02\u573a\u7684\u6295\u8d44\u8005\u4e3a\u5e94\u5bf9\u7f8e\u56fd\u603b\u7edf\u5927\u9009\u7ed3\u679c\u7684\u4e0d\u786e\u5b9a\u6027\u800c\u91cd\u65b0\u914d\u7f6e\u6295\u8d44\u7ec4\u5408\uff0c\u9ec4\u91d1\u4ef7\u683c\u83b7\u5f97\u4e86\u65b0\u7684\u652f\u6491\u3002</p><p>\u7ecf\u6d4e\u5b66\u5bb6\u666e\u904d\u8ba4\u4e3a\uff0c\u7279\u6717\u666e\u7684\u8d38\u6613\u653f\u7b56\u6700\u7ec8\u5c06\u652f\u6491\u7f8e\u5143\uff0c\u56e0\u4e3a\u8fdb\u53e3\u5173\u7a0e\u5c06\u963b\u6b62\u7f8e\u5143\u6d41\u5411\u6d77\u5916\uff0c\u5e76\u53ef\u80fd\u63a8\u9ad8\u901a\u80c0\u548c\u5229\u7387\u3002\u957f\u671f\u8d38\u6613\u6218\u4e5f\u5c06\u6253\u538b\u5168\u7403\u98ce\u9669\u60c5\u7eea\uff0c\u8fdb\u4e00\u6b65\u652f\u6491\u907f\u9669\u8d27\u5e01\u7f8e\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254978366", "pub_date": "2024-10-16 18:58:36"}, {"id": 254977810, "title": "KKR & Co(KKR)\u8ba1\u5212\u51fa\u552e\u65b0\u52a0\u5761Goodpack \u4f30\u503c\u7ea618\u4ebf\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u77e5\u60c5\u4eba\u58eb\u900f\u9732\uff0cKKR &amp; Co(KKR)\u5373\u5c06\u542f\u52a8\u65b0\u52a0\u5761\u603b\u90e8\u7684Goodpack\u516c\u53f8\u7684\u51fa\u552e\u6d41\u7a0b\uff0c\u6b64\u6b21\u4ea4\u6613\u5bf9\u8be5\u96c6\u88c5\u7bb1\u53ca\u7269\u6d41\u670d\u52a1\u4f9b\u5e94\u5546\u7684\u4f30\u503c\u7ea6\u4e3a18\u4ebf\u7f8e\u5143\u3002</p><p>KKR &amp; Co\u5df2\u59d4\u4efb\u5fb7\u610f\u5fd7\u94f6\u884c\u7b49\u673a\u6784\u62c5\u4efb\u6b64\u6b21\u51fa\u552e\u7684\u987e\u95ee\uff0c\u5e76\u8ba1\u5212\u5728\u672a\u6765\u6570\u5468\u5185\u6b63\u5f0f\u542f\u52a8\u51fa\u552e\u7a0b\u5e8f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254977810", "pub_date": "2024-10-16 18:54:11"}, {"id": 254976844, "title": "\u9ec4\u91d1\u80a1\u76d8\u524d\u666e\u5347 \u91d1\u7530(GFI)\u6da8\u8fd15% \u884c\u4e1a\u8c03\u67e5\u9884\u8ba1\u672a\u6765\u4e00\u5e74\u91d1\u4ef7\u5c06\u6500\u5347\u81f3\u5386\u53f2\u65b0\u9ad8", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9ec4\u91d1\u80a1\u76d8\u524d\u666e\u5347\uff0c\u91d1\u7530(GFI)\u6da84.84%\uff0c\u54c8\u83ab\u5c3c\u9ec4\u91d1(HMY)\u6da83.88%\uff0c\u79d1\u5c14\u9edb\u4f26\u77ff\u4e1a(CDE)\u6da81.84%\uff0c\u6cdb\u7f8e\u767d\u94f6(PAAS)\u6da81.39%<br/><br/>\u6839\u636e\u4e00\u6b21\u5927\u578b\u5e74\u5ea6\u4f1a\u8bae\u4e0a\u5bf9\u9ec4\u91d1\u884c\u4e1a\u8fdb\u884c\u7684\u8c03\u67e5\uff0c\u9884\u8ba1\u672a\u6765\u4e00\u5e74\u91d1\u4ef7\u5c06\u6500\u5347\u81f3\u5386\u53f2\u65b0\u9ad8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254976844", "pub_date": "2024-10-16 18:47:35"}, {"id": 254973830, "title": "\u6b27\u6d32\u822a\u53f8\u9762\u4e34\u7a7a\u4e2d\u5ba2\u8f66\u548c\u6ce2\u97f3\u7684\u98de\u673a\u4ea4\u4ed8\u5ef6\u8bef\u95ee\u9898", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6b27\u6d32\u822a\u7a7a\u516c\u53f8\u5728\u5468\u4e09\u7684\u4f1a\u8bae\u4e0a\u8868\u793a\uff0c\u5b83\u4eec\u6b63\u52aa\u529b\u5e94\u5bf9\u98de\u673a\u5236\u9020\u5546\u7a7a\u4e2d\u5ba2\u8f66\u548c\u6ce2\u97f3\u7684\u4ea4\u8d27\u5ef6\u8fdf\uff0c\u4e0d\u8fc7\u5ec9\u4ef7\u822a\u7a7a\u516c\u53f8\u745e\u5b89\u822a\u7a7a\u6307\u51fa\uff0c\u8fd0\u529b\u9650\u5236\u5c06\u6709\u5229\u4e8e\u673a\u7968\u5b9a\u4ef7\u3002<br/><br/>\u745e\u5b89\u822a\u7a7a\u96c6\u56e2\u9996\u5e2d\u6267\u884c\u5b98\u8fc8\u514b\u5c14\u5965\u5229\u91cc(MichaelO'Leary)\u8868\u793a\uff0c\u5982\u679c\u660e\u5e743\u6708\u540e\u4ece\u6ce2\u97f3\u516c\u53f8\u83b7\u5f9710\u621615\u67b6\u98de\u673a\uff08\u800c\u4e0d\u662f\u9884\u671f\u768430\u67b6\uff09\uff0c\u516c\u53f8\u7684\u4e1a\u7ee9\u5c06\u4f1a\u5f88\u597d\u3002<br/><br/>\u6cd5\u822a\u8377\u822a\u8868\u793a\uff0c\u5176\u7a7a\u5ba2A220\u8ba2\u5355\u53d7\u5230\u666e\u60e0\u53d1\u52a8\u673a\u95ee\u9898\u7684\u5f71\u54cd\uff0c\u800c\u6c49\u838e\u822a\u7a7a\u5219\u8868\u793a\uff0c\u4ece\u672a\u89c1\u8fc7\u50cf\u6ce2\u97f3777X\u8fd9\u6837\u7684\u5ef6\u8bef\uff0c\u5e76\u8865\u5145\u8bf4\u5ef6\u8bef\u65f6\u95f4\u5df2\u8fbe\u5230\u4e94\u5e74\u5de6\u53f3\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254973830", "pub_date": "2024-10-16 18:25:38"}]}