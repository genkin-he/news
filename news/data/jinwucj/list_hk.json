\u6269\u5927\uff0c\u4f46\u5176\u540e\u6d77\u5916\u51cf\u606f\u9884\u671f\u964d\u6e29\uff0c\u6e2f\u80a1\u5e02\u573a\u56de\u5410\u90e8\u5206\u6da8\u5e45\u3002\u4eba\u6c11\u5e01\u6c47\u7387\u548c\u6e2f\u80a1\u8d70\u52bf\u76f8\u8054\u52a8\uff0c\u80cc\u540e\u6709\u76f8\u4f3c\u7684\u9a71\u52a8\u3002\u56fd\u5185\u653f\u7b56\u6301\u7eed\u63a8\u51fa\uff0c\u6d77\u5916\u964d\u606f\u8d8b\u52bf\u786e\u5b9a\uff0c\u6e2f\u80a1\u5e02\u573a\u672a\u6765\u8d70\u52bf\u4ee5\u5411\u4e0a\u4e3a\u4e3b\uff0c\u5229\u7387\u654f\u611f\u578b\u884c\u4e1a\u80a1\u4ef7\u5f39\u6027\u66f4\u5927\uff0c\u5305\u62ec\u4e92\u8054\u7f51\u9f99\u5934\u3001\u533b\u836f\u548c\u6d88\u8d39\u7b49\u884c\u4e1a\uff1b\u53e6\u5916\uff0c\u9ad8\u5206\u7ea2(\u516c\u7528\u4e8b\u4e1a\u3001\u94f6\u884c\u3001\u901a\u4fe1\u8fd0\u8425\u5546)\u98ce\u683c\u884c\u4e1a\u914d\u7f6e\u4ef7\u503c\u8f83\u9ad8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255179783", "pub_date": "2024-10-18 14:25:00"}, {"id": 255178560, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u8d22\u901a\u8bc1\u5238\u7ef4\u6301\u6cc9\u5cf0\u63a7\u80a1(02285)\u201c\u589e\u6301\u201d\u8bc4\u7ea7 \u516c\u53f8Q3\u4e1a\u7ee9\u9884\u544a\u8d85\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u8d22\u901a\u8bc1\u5238\u53d1\u5e03\u7814\u62a5\u6307\uff0c\u6cc9\u5cf0\u63a7\u80a1(02285)\u516c\u53f8\u53d1\u5e03\u6b63\u9762\u76c8\u5229\u9884\u544a\uff0c\u9884\u8ba11-9\u6708\u4efd\u5b9e\u73b0\u51c0\u5229\u6da6\u7ea61\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u6da8\u5e45\u8d85300%\uff1b1H2024\u516c\u53f8\u51c0\u5229\u6da60.62\u4ebf\u7f8e\u5143\uff0c\u5219\u9884\u8ba1\u5355Q3\u5b9e\u73b0\u76c8\u5229\u7ea60.38\u4ebf\u7f8e\u5143\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u516c\u53f8\u65d7\u8230\u54c1\u724cEGO\u8868\u73b0\u5f3a\u52b2\uff0c\u5e26\u52a8Q3\u6536\u5165\u589e\u957f\u52a0\u901f\u3002\u6839\u636e\u5168\u5e74\u76ee\u6807\u9884\u8ba1\u516c\u53f8H2\u6536\u5165\u589e\u901f\u6709\u671b\u8fbe30%\u3002\u53d7\u76ca\u4e8e\u6210\u672c\u644a\u8584\uff0c\u516c\u53f8\u6bdb\u5229\u7387\u6301\u7eed\u63d0\u5347\uff0c\u4e00\u5b9a\u7a0b\u5ea6\u62b5\u6d88\u4eba\u6c11\u5e01\u5347\u503c\u7684\u4e0d\u5229\u5f71\u54cd\u3002\u6e20\u9053\u53bb\u5e93\u7ed3\u675f\u53e0\u52a0\u964d\u606f\u50ac\u5316\uff0c\u516c\u53f8H2\u6536\u5165\u9ad8\u589e\u6709\u671b\u6301\u7eed\u3002<br/><br/>\u8be5\u884c\u9884\u6d4b\uff0c\u516c\u53f8\u4e09\u5b63\u5ea6\u9884\u544a\u8d85\u9884\u671f\uff0cOPE\u884c\u4e1a\u5411\u4e0a\u5f39\u6027\u5145\u8db3\uff0c\u8be5\u884c\u6839\u636e\u516c\u544a\u4e0a\u8c03\u76c8\u5229\u9884\u671f\uff0c\u5f53\u524d\u4f30\u503c\u6027\u4ef7\u6bd4\u8fdb\u4e00\u6b65\u51f8\u663e\u3002\u8be5\u884c\u9884\u8ba1\u516c\u53f82024-2026\u5e74\u5b9e\u73b0\u6536\u516516.7/19.7/22.4\u4ebf\u7f8e\u5143\uff0c\u5f52\u6bcd\u51c0\u5229\u6da61.3/1.5/1.7\u4ebf\u7f8e\u5143\uff0c\u5bf9\u5e94PE11/9/8\u500d\uff0c\u7ef4\u6301\u201c\u589e\u6301\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255178560", "pub_date": "2024-10-18 14:12:23"}, {"id": 255178559, "title": "\u65e5\u7ecf225\u6307\u6570\u6536\u76d8\u6da80.18% \u62a538981.75\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u65e5\u7ecf225\u6307\u6570\u6536\u76d8\u6da80.18%\uff0c\u62a538981.75\u70b9\u3002<br/><br/>\u65e5\u672c9\u6708\u6d88\u8d39\u7269\u4ef7\u6307\u6570\u7b26\u5408\u5e02\u573a\u9884\u671f\u3002\u75318\u6708\u7684\u6309\u5e74\u53473%\uff0c\u56de\u843d\u81f3\u53472.5%\u3002\u81f3\u4e8e\u6487\u9664\u65b0\u9c9c\u98df\u54c1\u7684\u6838\u5fc3\u6d88\u8d39\u7269\u4ef7\u6307\u6570\u6309\u5e74\u53472.4%\uff0c\u8f83\u9884\u671f\u9ad80.1\u4e2a\u767e\u5206\u70b9\u3002<br/><br/>\u65e5\u672c\u592e\u884c\u884c\u957f\u690d\u7530\u548c\u7537\u66fe\u8868\u793a\uff0c\u82e5\u901a\u80c0\u7387\u7a33\u5b9a\u5730\u8fbe\u52302%\uff0c\u5c06\u6301\u7eed\u63d0\u9ad8\u5229\u7387\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255178559", "pub_date": "2024-10-18 14:12:28"}, {"id": 255177360, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u56fd\u6cf0\u541b\u5b89\uff1a\u6d77\u5916\u964d\u606f\u8d8b\u52bf\u786e\u5b9a \u6e2f\u80a1\u5e02\u573a\u672a\u6765\u8d70\u52bf\u4ee5\u5411\u4e0a\u4e3a\u4e3b", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u56fd\u6cf0\u541b\u5b89\u53d1\u5e03\u7814\u62a5\u6307\uff0c\u4ece\u4eba\u6c11\u5e01\u6c47\u7387\u8d70\u52bf\u7684\u89c6\u89d2\u770b\u5f85\u6e2f\u80a1\u884c\u60c5\uff0c\u6211\u4eec\u8ba4\u4e3a\u56fd\u5e86\u8282\u524d\u6e2f\u80a1\u548c\u4eba\u6c11\u5e01\u540c\u6da8\uff0c\u4e3b\u8981\u6765\u81ea\u56fd\u5185\u7ecf\u6d4e\u652f\u6301\u653f\u7b56\u6301\u7eed\u51fa\u53f0\uff0c\u56fd\u5185\u7ecf\u6d4e\u524d\u666f\u6539\u5584\u4ee5\u53ca\u6d77\u5916\u964d\u606f\u9884\u671f\u5347\u6e29\u5171\u540c\u9a71\u52a8\u3002\u7136\u800c\uff0c\u8282\u540e\u4eba\u6c11\u5e01\u5151\u7f8e\u5143\u4e0b\u8dcc\uff0c\u4e3b\u8981\u662f\u56e0\u4e3a\u7f8e\u56fd\u7ecf\u6d4e\u8d85\u9884\u671f\u5bfc\u81f4\u7f8e\u5143\u5f3a\u52bf\u6240\u5f15\u53d1\uff0c\u800c\u4e0d\u662f\u4eba\u6c11\u5e01\u672c\u8eab\u9690\u542b\u7684\u56fd\u5185\u7ecf\u6d4e\u524d\u666f\u4e0b\u4fee\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u4eba\u6c11\u5e01\u6c47\u7387\u89e6\u53ca\u9636\u6bb5\u6027\u9ad8\u70b9\u540e\uff0c\u968f\u7740\u8fd1\u671f\u7f8e\u56fd\u7ecf\u6d4e\u6570\u636e\u597d\u4e8e\u5e02\u573a\u9884\u671f\uff0c\u7f8e\u5143\u5f3a\u52bf\u5bfc\u81f4\u79bb\u5cb8\u4eba\u6c11\u5e01\u6c47\u7387\u76f8\u5bf9\u4e0b\u8dcc\uff0c\u4eba\u6c11\u5e01\u4e0e\u6e2f\u80a1\u5e02\u573a\u56de\u843d\u5448\u73b0\u76f8\u540c\u7684\u8868\u73b0\u3002\u66f4\u957f\u8fdc\u7684\u89c6\u89d2\u6765\u770b\uff0c\u6e2f\u80a1\u5e02\u573a\u4e2d\u6709\u8f83\u5927\u7684\u6bd4\u91cd\u662f\u4e2d\u8d44\u4f01\u4e1a\uff0c\u6e2f\u80a1\u548c\u4eba\u6c11\u5e01\u8d70\u52bf\u7684\u80cc\u540e\u53cd\u6620\u7684\u90fd\u662f\u5bf9\u4e2d\u56fd\u7ecf\u6d4e\u9884\u671f\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0c\u9a71\u52a8\u6e2f\u80a1\u8fd1\u671f\u8d70\u5f3a\u7684\u4e3b\u56e0\u662f\u56fd\u5185\u653f\u7b56\u9884\u671f\u589e\u5f3a\u53e0\u52a0\u6d77\u5916\u5e74\u5185\u964d\u606f\u9884\u671f\u5e45\u5ea6\u6269\u5927\uff0c\u4f46\u5176\u540e\u6d77\u5916\u51cf\u606f\u9884\u671f\u964d\u6e29\uff0c\u6e2f\u80a1\u5e02\u573a\u56de\u5410\u90e8\u5206\u6da8\u5e45\u3002\u5f80\u524d\u770b\uff0c\u6e2f\u80a1\u5e02\u573a\u672a\u6765\u8d70\u52bf\u4ee5\u5411\u4e0a\u4e3a\u4e3b\uff0c\u5229\u7387\u654f\u611f\u578b\u884c\u4e1a\u80a1\u4ef7\u5f39\u6027\u66f4\u5927\uff0c\u5305\u62ec\u4e92\u8054\u7f51\u9f99\u5934\u3001\u533b\u836f\u548c\u6d88\u8d39\u7b49\u884c\u4e1a\uff1b\u53e6\u5916\uff0c\u9ad8\u5206\u7ea2\uff08\u516c\u7528\u4e8b\u4e1a\u3001\u94f6\u884c\u3001\u901a\u4fe1\u8fd0\u8425\u5546\uff09\u98ce\u683c\u884c\u4e1a\u914d\u7f6e\u4ef7\u503c\u8f83\u9ad8\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255177360", "pub_date": "2024-10-18 14:00:41"}]}