:middle;\">-1.84</td></tr></tbody></table></div>", "link": "https://sky.szfiu.com/info/hk/details/261261295", "pub_date": "2024-12-20 11:00:00"}, {"id": 261260536, "title": "\u5168\u56fd\u7535\u52a8\u81ea\u884c\u8f66\u4ee5\u65e7\u6362\u65b0\u6570\u91cf\u7a81\u7834100\u4e07\u8f86", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u65b0\u534e\u793e\u62a5\u9053\uff0c\u4ece\u5546\u52a1\u90e8\u83b7\u6089\uff0c\u622a\u81f312\u670819\u65e5\uff0c\u5168\u56fd\u7535\u52a8\u81ea\u884c\u8f66\u5b9e\u73b0\u552e\u65e7\u3001\u6362\u65b0\u5404102.3\u4e07\u8f86\uff0c\u5e26\u52a8\u65b0\u8f66\u9500\u552e27.3\u4ebf\u5143\u3002<br/><br/>\u636e\u4e86\u89e3\uff0c\u53c2\u4e0e\u4e3b\u4f53\u4e0d\u65ad\u589e\u52a0\u3002\u53c2\u52a0\u7535\u52a8\u81ea\u884c\u8f66\u4ee5\u65e7\u6362\u65b0\u7684\u9500\u552e\u95e8\u5e97\u6570\u91cf\u753110\u6708\u521d\u76842.6\u4e07\u5bb6\u589e\u81f3\u76ee\u524d\u76844.1\u4e07\u5bb6\uff0c\u589e\u957f57.7%\u3002\u6d3b\u52a8\u6570\u91cf\u6301\u7eed\u589e\u591a\u3002\u5404\u5730\u7535\u52a8\u81ea\u884c\u8f66\u4ee5\u65e7\u6362\u65b0\u6d3b\u52a8\u6570\u91cf\u753110\u6708\u521d\u7684532\u573a\u589e\u81f3\u76ee\u524d\u76843534\u573a\uff0c\u589e\u957f564.3%\u3002\u8986\u76d6\u8303\u56f4\u4e0d\u65ad\u6269\u5927\u300231\u4e2a\u7701\u3001\u81ea\u6cbb\u533a\u3001\u76f4\u8f96\u5e02\u53ca\u65b0\u7586\u751f\u4ea7\u5efa\u8bbe\u5175\u56e2\u5747\u5df2\u5f00\u5c55\u4e86\u7535\u52a8\u81ea\u884c\u8f66\u4ee5\u65e7\u6362\u65b0\u5de5\u4f5c\uff0c\u9664\u5c11\u6570\u7981\u884c\u5730\u533a\u5916\uff0c\u57fa\u672c\u5b9e\u73b0\u5730\u5e02\u5168\u8986\u76d6\u3002\u7f6e\u6362\u8fdb\u5ea6\u4e0d\u65ad\u52a0\u5feb\u30029\u6708\u300110\u6708\u300111\u6708\u4ee5\u65e7\u6362\u65b0\u6570\u91cf\u5206\u522b\u4e3a1.6\u4e07\u8f86\u300129.1\u4e07\u8f86\u300134.1\u4e07\u8f86\uff0c12\u67081\u65e5\u81f319\u65e5\u8fbe37.5\u4e07\u8f86\uff0c\u4e14\u8fdb\u5ea6\u4ecd\u5728\u6301\u7eed\u52a0\u5feb\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/261260536", "pub_date": "2024-12-20 10:47:09"}, {"id": 261260535, "title": "\u817e\u8baf\u65d7\u4e0b\u4e09\u6b3e\u6e38\u620f\u5305\u63fd11\u6708\u4e2d\u56fdiOS\u624b\u6e38\u6536\u5165\u699c\u524d\u4e09\u540d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636eSensor Tower\u5546\u5e97\u60c5\u62a5\u5e73\u53f0\u663e\u793a\uff0c2024\u5e7411\u6708\u517135\u4e2a\u4e2d\u56fd\u5382\u5546\u5165\u56f4\u5168\u7403\u624b\u6e38\u53d1\u884c\u5546\u6536\u5165\u699cTOP100\uff0c\u5408\u8ba1\u5438\u91d118.7\u4ebf\u7f8e\u5143\uff0c\u5360\u672c\u671f\u5168\u7403TOP100\u624b\u6e38\u53d1\u884c\u5546\u6536\u516534.8%\u3002\u817e\u8baf\u65d7\u4e0b\u300a\u738b\u8005\u8363\u8000\u300b\u3001\u300a\u548c\u5e73\u7cbe\u82f1\u300b\u548c\u300a\u5730\u4e0b\u57ce\u4e0e\u52c7\u58eb\uff1a\u8d77\u6e90\u300b\u5305\u63fd\u672c\u671f\u4e2d\u56fdiOS\u624b\u6e38\u6536\u5165\u699c\u524d\u4e09\u540d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/261260535", "pub_date": "2024-12-20 10:47:26"}, {"id": 261259058, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4e2d\u4fe1\u8bc1\u5238\u770b\u597d\u65e5\u80a1\u7684\u4e2d\u957f\u671f\u914d\u7f6e\u4ef7\u503c", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u4fe1\u8bc1\u5238\u8868\u793a\uff0c\u65e5\u672c\u592e\u884c\uff08\u65e5\u94f6\uff0912\u6708\u8d27\u5e01\u653f\u7b56\u4f1a\u8bae\u5982\u671f\u7ef4\u6301\u653f\u7b56\u5229\u7387\u76ee\u6807\u4e0d\u53d8\uff0c\u5bf9\u7ecf\u6d4e\u73b0\u72b6\u3001\u524d\u666f\u3001\u98ce\u9669\u7684\u8bc4\u4f30\u90fd\u5927\u81f4\u4e0d\u53d8\uff0c\u884c\u957f\u690d\u7530\u548c\u7537\u6570\u5ea6\u63d0\u53ca\u5bf9\u6da8\u85aa\u524d\u666f\u548c\u7279\u6717\u666e\u653f\u7b56\u201c\u4e0d\u786e\u5b9a\u6027\u201d\u7684\u5173\u6ce8\uff0c\u8868\u793a\u7f3a\u4e4f\u85aa\u8d44\u65b9\u9762\u7684\u4fe1\u606f\u662f\u672c\u6b21\u51b3\u8bae\u4fdd\u6301\u5229\u7387\u4e0d\u53d8\u7684\u539f\u56e0\u4e4b\u4e00\u3002\u8be5\u884c\u9884\u8ba1\u65e5\u94f62025\u5e74\u5c06\u81f3\u5c11\u52a0\u606f\u4e24\u6b21\u540425bps\uff0c\u4e14\u4e00\u5b63\u5ea6\u5373\u6709\u53ef\u80fd\u52a0\u606f\uff0c\u4f46\u76ee\u524d\u770b\u5c4a\u65f6\u91cd\u6f14\u4eca\u590f\u5957\u606f\u4ea4\u6613\u5feb\u901f\u9006\u8f6c\u7684\u98ce\u9669\u4e0d\u7b97\u5f88\u5927\u3002\u8be5\u884c\u9884\u8ba1\u65e5\u5143\u5728\u7279\u6717\u666e\u4e0a\u4efb\u524d\u6216\u8f83\u96be\u6709\u4eae\u773c\u8868\u73b0\uff0c\u4ecd\u7136\u5efa\u8bae\u56de\u907f\u65e5\u503a\uff0c\u770b\u597d\u65e5\u80a1\u7684\u4e2d\u957f\u671f\u914d\u7f6e\u4ef7\u503c\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/261259058", "pub_date": "2024-12-20 10:21:42"}, {"id": 261259144, "title": "\u6c7d\u8f66\u80a1\u90e8\u5206\u8d70\u9ad8 \u96f6\u8dd1\u6c7d\u8f66(09863)\u6da8\u8d853% \u5d14\u4e1c\u6811\u79f0\u4e58\u7528\u8f66\u672a\u6765\u4fc3\u9500\u8d39\u53d1\u5c55\u7a7a\u95f4\u5de8\u5927", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6c7d\u8f66\u80a1\u90e8\u5206\u8d70\u9ad8\uff0c\u96f6\u8dd1\u6c7d\u8f66(09863)\u6da83.06%\uff0c\u62a531.95\u6e2f\u5143\uff1b\u7406\u60f3\u6c7d\u8f66(02015)\u6da82.31%\uff0c\u62a593.15\u6e2f\u5143\uff1b\u851a\u6765(09866)\u3001\u5c0f\u9e4f\u6c7d\u8f66(09868)\u6da8\u8d851%\u3002</p><p>\u4e58\u8054\u5206\u4f1a\u79d8\u4e66\u957f\u5d14\u4e1c\u6811\u53d1\u5e03\u300a11\u6708\u4e58\u7528\u8f66\u4ef7\u683c\u6bb5\u5e02\u573a\u7ed3\u6784\u5206\u6790\u300b\u3002\u6839\u636e\u4e58\u8054\u6570\u636e\uff0c\u622a\u81f32024\u5e74\u4e0a\u534a\u5e74\u8f66\u5e02\u9500\u552e\u5747\u4ef7\u4e00\u76f4\u5448\u73b0\u4e0a\u5347\u6001\u52bf\uff0c2024\u5e74\u4e0a\u534a\u5e74\u8fbe\u523018.6\u4e07\u5143\u3002\u53d7\u5230\u56fd\u5bb6\u62a5\u5e9f\u66f4\u65b0\u548c\u4ee5\u65e7\u6362\u65b0\u653f\u7b56\u8865\u8d34\u7684\u4fc3\u8fdb\uff0c\u5165\u95e8\u7ea7\u8f66\u578b\u9500\u552e\u5360\u6bd4\u63d0\u5347\uff0c\u8fd1\u51e0\u5e74\u5168\u56fd\u4e58\u7528\u8f66\u5e02\u573a\u4ef7\u683c\u6bb5\u9500\u91cf\u7ed3\u6784\u8d70\u52bf\u4e0a\u884c\u8d8b\u52bf\u6539\u53d8\uff0c\u5168\u56fd\u4e58\u7528\u8f66\u5747\u4ef7\u4ece2023\u5e74\u768418.3\u4e07/\u53f0\u964d\u523011\u6708\u768417\u4e07/\u53f0\uff0c\u5404\u4ef7\u6bb5\u5e02\u573a\u5168\u9762\u8d70\u5f3a\u3002\u4e2d\u56fd\u79c1\u8f66\u666e\u53ca\u4ecd\u5904\u4e8e\u5343\u4eba\u4e58\u7528\u8f66\u4fdd\u6709\u91cf200\u53f0\u7684\u4e16\u754c\u4e2d\u4f4e\u4f4d\u6c34\u5e73\uff0c\u4e58\u7528\u8f66\u9500\u552e\u5747\u4ef7\u964d\u4f4e\u63a8\u52a8\u5e02\u573a\u666e\u53ca\u548c\u5347\u7ea7\u5168\u65b9\u4f4d\u53d1\u5c55\uff0c\u672a\u6765\u4fc3\u9500\u8d39\u7684\u53d1\u5c55\u7a7a\u95f4\u5de8\u5927\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/261259144", "pub_date": "2024-12-20 10:23:05"}, {"id": 261259143, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u91ce\u6751\uff1a\u9884\u8ba1\u9999\u6e2f2025\u7ecf\u6d4e\u589e\u901f\u653e\u7f13\u81f32.3%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u91ce\u6751\u8bc1\u5238\u8fd1\u65e5\u53d1\u5e03\u7684\u300a\u9999\u6e2f2025\u5c55\u671b\u300b\u7814\u62a5\u4e2d\u6307\u51fa\uff0c2025\u5e74\u9999\u6e2f\u7ecf\u6d4e\u5c06\u9762\u4e34\u591a\u91cd\u6311\u6218\u3002\u56fd\u9645\u65b9\u9762\uff0c\u9884\u8ba12025\u5e74\u5c06\u7206\u53d1\u65b0\u7684\u4e2d\u7f8e\u8d38\u6613\u6218\uff0c\u7279\u6717\u666e\u653f\u5e9c\u53ef\u80fd\u5bf9\u4e2d\u56fd\u5546\u54c1\u5f81\u6536\u9ad8\u8fbe60%\u7684\u5173\u7a0e\uff0c\u5e76\u5bf9\u6240\u6709\u5546\u54c1\u5f81\u653610%\u7684\u5173\u7a0e\uff0c\u8fd9\u5c06\u5bf9\u4e2d\u56fd\u7684\u51fa\u53e3\u4ea7\u751f\u91cd\u5927\u5f71\u54cd\uff0c\u8fdb\u800c\u5bf9\u9999\u6e2f\u7684\u8f6c\u53e3\u8d38\u6613\u5e26\u6765\u538b\u529b\u3002\u56fd\u5185\u65b9\u9762\uff0c\u9999\u6e2f\u672c\u5730\u6d88\u8d39\u6301\u7eed\u53d7\u5230\u5317\u5411\u65c5\u884c\u89c4\u6a21\u6269\u5927\u7684\u5f71\u54cd\uff0c2024\u5e74\u524d\u4e09\u5b63\u5ea6\u540d\u4e49\u96f6\u552e\u9500\u552e\u989d\u540c\u6bd4\u4e0b\u964d7.6%\uff0c\u4e14\u5e73\u5747\u6bd42018\u5e74\u4f4e22.7%\u3002\u6b64\u5916\uff0c\u9999\u6e2f\u653f\u5e9c\u7684\u8d22\u653f\u72b6\u51b5\u4e5f\u9762\u4e34\u4e25\u5cfb\u6311\u6218\uff0c\u571f\u5730\u51fa\u8ba9\u91d1\u6536\u5165\u5927\u5e45\u4e0b\u964d\uff0c\u8d22\u653f\u50a8\u5907\u4e0d\u65ad\u7f29\u51cf\uff0c\u9884\u8ba12024-2025\u8d22\u5e74\u8d22\u653f\u8d64\u5b57\u5c06\u8fdb\u4e00\u6b65\u589e\u52a0\u81f3\u7ea62100\u4ebf\u6e2f\u5143\uff0c\u8d22\u653f\u50a8\u5907\u53ef\u80fd\u5728\u672a\u6765\u4e09\u5e74\u5185\u8017\u5c3d\u3002</p><p>\u91ce\u6751\u8bc1\u5238\u8ba4\u4e3a\uff0c\u5c3d\u7ba1\u9999\u6e2f\u7ecf\u6d4e\u57282024\u5e74\u4e0a\u534a\u5e74\u5f97\u76ca\u4e8e\u51c0\u51fa\u53e3\u589e\u957f\u7684\u5f3a\u52b2\u53cd\u5f39\uff0c\u5b9e\u73b0\u4e862.5%\u7684GDP\u589e\u957f\uff0c\u4f462025\u5e74\u7ecf\u6d4e\u589e\u957f\u9884\u8ba1\u5c06\u653e\u7f13\u81f32.3%\u3002\u901a\u80c0\u7387\u9884\u8ba1\u5c06\u4fdd\u6301\u57281.8%\u4e0d\u53d8\u3002\u5728\u6d88\u8d39\u65b9\u9762\uff0c\u867d\u7136\u5185\u5730\u6e38\u5ba2\u548c\u5916\u56fd\u6e38\u5ba2\u7684\u6062\u590d\u5c06\u4e3a\u6d88\u8d39\u5e26\u6765\u4e00\u5b9a\u652f\u6491\uff0c\u4f46\u5317\u5411\u65c5\u884c\u7684\u6301\u7eed\u589e\u52a0\u4ecd\u5c06\u5bf9\u672c\u5730\u6d88\u8d39\u6784\u6210\u538b\u529b\uff0c\u9884\u8ba1\u79c1\u4eba\u6d88\u8d39\u57282024\u5e74\u5c06\u4fdd\u6301\u5e73\u7a33\u3002\u623f\u5730\u4ea7\u5e02\u573a\u65b9\u9762\uff0c\u9884\u8ba12025\u5e74\u623f\u4ef7\u5c06\u7ee7\u7eed\u4ee5\u6e29\u548c\u7684\u901f\u5ea6\u4e0b\u8dcc\uff0c\u5e74\u964d\u5e45\u9884\u8ba1\u4e3a5%\u3002\u6b64\u5916\uff0c\u7f8e\u8054\u50a8\u7684\u964d\u606f\u9884\u671f\u5927\u5e45\u51cf\u5f31\uff0c\u9884\u8ba12025\u5e74\u4ec5\u4f1a\u964d\u606f25\u4e2a\u57fa\u70b9\uff0c\u8fd9\u5c06\u9650\u5236\u9999\u6e2f\u6309\u63ed\u5229\u7387\u7684\u8fdb\u4e00\u6b65\u4e0b\u964d\u7a7a\u95f4\uff0c\u5728\u4eba\u53e3\u7ed3\u6784\u672a\u53d1\u751f\u91cd\u5927\u8f6c\u53d8\u548c\u672c\u5730\u7ecf\u6d4e\u524d\u666f\u4ecd\u4e0d\u7a33\u5b9a\u7684\u80cc\u666f\u4e0b\uff0c\u9999\u6e2f\u623f\u4ef7\u9884\u8ba1\u5c06\u7ee7\u7eed\u627f\u538b\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/261259143", "pub_date": "2024-12-20 10:23:40"}]}