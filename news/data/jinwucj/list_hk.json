403\u534e\u8bedIP\u76db\u5178\u7b49\u4e00\u7cfb\u5217\u7ebf\u4e0b\u6d3b\u52a8", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u201c\u8c37\u5b50\u7ecf\u6d4e\u201d\u5174\u8d77\uff0c\u9605\u6587\u96c6\u56e2(00772)\u5348\u540e\u80a1\u4ef7\u9707\u8361\u626c\u5347\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da83.05%\uff0c\u62a528.7\u6e2f\u5143\uff0c\u6210\u4ea4\u989d7338.91\u4e07\u6e2f\u5143\u3002<br/><br/>\u76ee\u524d\u5361\u724cIP\u5df2\u8d21\u732e\u89c4\u6a21\u5316\u6536\u5165\uff0c2024\u5e74\u4e0a\u534a\u5e74\u9605\u6587\u96c6\u56e2\u7248\u6743\u8fd0\u8425\u6536\u5165\u540c\u6bd4\u589e\u957f75.7%\u81f322.03\u4ebf\u5143\uff0c\u5176\u4e2dIP\u5361\u724c\u7684GMV\u5408\u8ba1\u7ea6\u4e3a1\u4ebf\u5143\u3002\u4eca\u5e74\u4ee5\u6765\uff0c\u9605\u6587\u65d7\u4e0bIP\u884d\u751f\u54c1\u5382\u724c\u9605\u6587\u597d\u7269\u63a8\u51fa\u591a\u6b3e\u7545\u9500\u4ea7\u54c1\uff0c\u5982\u300a\u5168\u804c\u9ad8\u624b\u300b\u6536\u85cf\u5361\u603bGMV\u7a81\u78345000\u4e07\u5143\uff0c\u300a\u5e86\u4f59\u5e74\u300b\u76f2\u76d2\u9500\u91cf\u8d8520\u4e07\u53ea\u3002<br/><br/>\u96c6\u56e2\u9996\u5e2d\u6267\u884c\u5b98\u517c\u603b\u88c1\u4faf\u6653\u6960\u8fd1\u65e5\u8868\u793a\uff0c\u5728\u4e1c\u5357\u4e9a\u7684\u89c6\u9891\u70b9\u64ad\u5e02\u573a\uff0c\u4e2d\u56fd\u5267\u5df2\u6210\u4e3a\u5f53\u5730\u7528\u6237\u7684\u7b2c\u4e8c\u5927\u5a31\u4e50\u5185\u5bb9\uff0c\u5c24\u5176\u5728\u514d\u8d39\u589e\u503c\u9886\u57df\uff0c\u4e2d\u56fd\u5267\u5360\u6bd4\u5df2\u8fbe40%\u4efd\u989d\uff0c\u6210\u4e3a\u7b2c\u4e00\u5927\u5f71\u89c6\u5267\u3002\u5728\u201cIP+\u6587\u65c5\u201d\u9886\u57df\uff0c\u9605\u6587\u5373\u5c06\u5728\u65b0\u52a0\u5761\u4e3e\u529e\u8de8\u5e74\u97f3\u4e50\u8282\u3001IP\u5e02\u96c6\u53ca\u9605\u6587\u5168\u7403\u534e\u8bedIP\u76db\u5178\u7b49\u4e00\u7cfb\u5217\u7ebf\u4e0b\u6d3b\u52a8\uff0c\u5728\u6d77\u5916\u5e02\u573a\u63a2\u7d22\u6587\u65c5\u878d\u5408\u65b0\u6a21\u5f0f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259657202", "pub_date": "2024-12-05 14:31:33"}, {"id": 259655109, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u534e\u5174\u8bc1\u5238\u7ef4\u6301\u5c0f\u7c73(01810)\u4e70\u5165\u8bc4\u7ea7 \u6599IoT\u548c\u5bb6\u7535SKU\u53ef\u53ca\u5ea6\u63d0\u5347\u5c06\u5e26\u52a8\u5176\u4e1c\u5357\u4e9a\u5e02\u573a\u589e\u957f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u534e\u5174\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u6839\u636e\u8be5\u884c\u8ba1\u7b97\uff0c\u6cf0\u56fd\u3001\u9a6c\u6765\u897f\u4e9a\u3001\u5370\u5c3c\u3001\u8d8a\u5357\u548c\u83f2\u5f8b\u5bbe\uff0c\u4ee5\u4e0a\u4e1c\u5357\u4e9a\u4e94\u56fd\u5f53\u524d\u667a\u80fd\u624b\u673a\u7684\u66ff\u6362\u5468\u671f\u4e3a35-64\u4e2a\u6708\uff08\u5bf9\u6bd4\u4e2d\u56fd\u4e3a30-36\u4e2a\u6708\uff09\uff0c\u8868\u660e\u968f\u7740\u7ecf\u6d4e\u589e\u957f\uff0c\u66ff\u6362\u5468\u671f\u7f29\u77ed\u6709\u671b\u5e26\u6765\u9500\u91cf\u589e\u957f\u7a7a\u95f4\u3002\u5047\u8bbe\u5c0f\u7c73(01810)\u5728\u4e1c\u5357\u4e9a\u7684\u5e02\u5360\u7387\u4ece3Q24\u768415%\uff08IDC\u6570\u636e\uff09\u6269\u5927\u81f32026\u5e74\u768418%\uff0c\u8be5\u884c\u9884\u8ba1\u4e1c\u5357\u4e9a\u5e02\u573a2026\u5e74\u667a\u80fd\u624b\u673a\u51fa\u8d27\u91cf\u5c06\u589e\u81f31,700\u4e07\u90e8\uff0c\u8f83\u5c0f\u7c732024\u5e74\u7684\u603b\u51fa\u8d27\u91cf\u9ad84%\u3002<br/><br/>\u8be5\u884c\u6307\u51fa\uff0c\u8fd1\u4e09\u5e74\u6765\uff0c\u4e2d\u56fd\u667a\u80fd\u624b\u673a\u5355\u4ef7\u76f8\u5bf9\u4e1c\u5357\u4e9a\u5e02\u573a\u7684\u6ea2\u4ef7\u5df2\u6709\u6240\u6536\u7a84\u3002\u7136\u800c\uff0c\u8be5\u884c\u770b\u5230\u56fd\u5185\u76f8\u5bf9\u5370\u5c3c\u7684\u6ea2\u4ef7\u9ad8\u8fbe150%\uff0c\u90a3\u91cc5G\u6e17\u900f\u7387\u4ec5\u4e3a\u4f4e\u5355\u4f4d\u6570\u767e\u5206\u6bd4\u3002\u8be5\u884c\u9884\u8ba1\u4e1c\u5357\u4e9a\u5730\u533a\u7684\u624b\u673a\u5355\u4ef7\u4f1a\u63d0\u5347\uff0c2026\u5e74\u6f5c\u5728\u5e02\u573a\u6269\u5927\u81f330\u4ebf\u7f8e\u5143\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0cIoT\u88ab\u8bc1\u660e\u662f\u5c0f\u7c73\u7684\u5173\u952e\u533a\u5206\u56e0\u5b50\uff0c\u5e26\u52a8\u4e86\u5c0f\u7c73\u5728\u4e2d\u56fd\u53d6\u5f97\u6210\u529f\u3002\u8be5\u884c\u8ba4\u4e3a\u63d0\u9ad8IoT\u548c\u5bb6\u7535SKU\u5728\u4e1c\u5357\u4e9a\u7684\u53ef\u53ca\u5ea6\u80fd\u591f\u8fdb\u4e00\u6b65\u63a8\u52a8\u5c0f\u7c73\u5728\u8be5\u5730\u533a\u7684\u589e\u957f\u3002\u8be5\u884c\u8ba4\u4e3a\u5c0f\u7c73\u72ec\u6709\u7684\u987e\u5ba2\u7ecf\u9a8c\u662f\u5176\u957f\u671f\u6210\u529f\u7684\u5173\u952e\u3002<br/><br/>\u8be5\u884c\u7ef4\u6301\u516c\u53f8\u4e70\u5165\u8bc4\u7ea7\u548c\u76ee\u6807\u4ef734.00\u6e2f\u5143\uff0c\u57fa\u4e8e28.5\u500d\u76842025\u5e74\u8c03\u6574\u540eEPS\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259655109", "pub_date": "2024-12-05 14:14:50"}, {"id": 259653159, "title": "\u7164\u70ad\u591a\u6570\u56de\u8c03 \u5357\u5357\u8d44\u6e90(01229)\u8dcc4.76% \u673a\u6784\u6599\u660e\u5e74\u7164\u4ef7\u6709\u5e95\u65e0\u60e7\u8fb9\u9645\u4f9b\u9700\u7565\u8d70\u5f31", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7164\u70ad\u591a\u6570\u56de\u8c03\uff0c\u5357\u5357\u8d44\u6e90(01229)\u8dcc4.76%\uff0c\u8499\u53e4\u80fd\u6e90(00276)\u8dcc3.03%\uff0c\u5156\u77ff\u80fd\u6e90(01171)\u8dcc1.71%\uff0c\u5357\u6208\u58c1(01878)\u8dcc1.56%\uff0c\u4e2d\u56fd\u795e\u534e(01088)\u8dcc0.88%\u3002<br/><br/>\u56fd\u6cf0\u541b\u5b89\u8868\u793a\uff0c\u5c55\u671b2025\u5e74\uff0c\u201c\u7a33\u6001\u201d\u4f9d\u7136\u662f\u7164\u70ad\u884c\u4e1a\u7684\u5173\u952e\u8bcd\uff0c\u7164\u4ef7\u6709\u5e95\u65e0\u60e7\u8fb9\u9645\u4f9b\u9700\u7565\u8d70\u5f31\u3002\u8be5\u884c\u5224\u65ad\u5728\u4e2d\u6027\u7684\u653f\u7b56\u9884\u671f\u5047\u8bbe\u4e0b\uff0c\u7164\u70ad\u7684\u7eb8\u9762\u8fb9\u9645\u4f9b\u9700\u8f832024\u5e74\u7565\u8d70\u5f31\uff1a\u4f9b\u7ed9\u7684\u6838\u5fc3\u589e\u91cf\u6765\u6e90\u4e8e\u5c71\u897f\u589e\u4ea7\uff08\u7ea6\u540c\u6bd4\u589e\u52a07000\u4e07\u5428\uff09\uff0c\u4f46\u5224\u65ad\u5b9e\u9645\u9500\u91cf\u7684\u51b2\u51fb\u4f1a\u5f31\u4e8e\u4ea7\u91cf\u6570\u636e\uff1b\u9700\u6c42\u7aef\uff0c\u7535\u7164\u7684\u9700\u6c42\u5728\u6c34\u7535\u548c\u65b0\u80fd\u6e90\u8d21\u732e\u8fb9\u9645\u8d70\u5f31\u80cc\u666f\u4e0b\uff0c\u4f9d\u7136\u53ef\u80fd\u4fdd\u63012.5-3%\u7684\u8f83\u597d\u589e\u957f\uff0c\u975e\u7535\u7164\u4e0d\u8003\u8651\u653f\u7b56\u5f71\u54cd\uff0c\u94a2\u94c1\u6c34\u6ce5\u9700\u6c42\u53ef\u80fd\u7ee7\u7eed\u4e0b\u964d\uff0c\u4f46\u4e0b\u884c\u6709\u5e95\uff0c\u8fb9\u9645\u62d6\u7d2f\u51cf\u5f31\uff0c\u5316\u5de5\u4f9d\u7136\u4fdd\u6301\u8f83\u597d\u589e\u957f\u3002\u5224\u65ad2025\u5e74\u7164\u70ad\u4f9b\u5927\u4e8e\u6c42\u57281.2%\u5de6\u53f3\uff0c\u7565\u5927\u4e8e2024\u5e74\u76840.9%\uff0c\u7164\u4ef7\u4e2d\u67a2\u53ef\u80fd\u7565\u6709\u4e0b\u884c\uff0c800\u5143/\u5428\u7684\u7164\u4ef7\u5e95\u90e8\u6e05\u6670\uff0c\u786e\u5b9a\u6027\u4f9d\u7136\u8f83\u5f3a\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259653159", "pub_date": "2024-12-05 13:58:33"}, {"id": 259653158, "title": "\u3010\u5238\u5546\u6df1\u5ea6\u3011\u6469\u6839\u58eb\u4e39\u5229\u524a\u5706\u901a\u901f\u9012\u76ee\u6807\u4ef720.6% \u6307\u5176\u5c06\u9762\u4e34\u66f4\u52a0\u6fc0\u70c8\u7684\u5e02\u573a\u7ade\u4e89", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6469\u6839\u58eb\u4e39\u5229\u6700\u65b0\u53d1\u5e03\u7684\u7814\u7a76\u62a5\u544a\u5bf9\u5706\u901a\u901f\u9012\u96c6\u56e2\u80a1\u4efd\u6709\u9650\u516c\u53f8(600233)\u7684\u4e1a\u7ee9\u73b0\u72b6\u53ca\u672a\u6765\u5c55\u671b\u8fdb\u884c\u4e86\u5206\u6790\u3002\u62a5\u544a\u6307\u51fa\uff0c\u5706\u901a\u901f\u9012\u5728\u884c\u4e1a\u9886\u5148\u8005\u8f6c\u53d8\u6218\u7565\u3001\u805a\u7126\u5e02\u573a\u4efd\u989d\u7684\u80cc\u666f\u4e0b\uff0c2025\u5e74\u5c06\u9762\u4e34\u66f4\u52a0\u6fc0\u70c8\u7684\u5e02\u573a\u7ade\u4e89\uff0c\u8fd9\u53ef\u80fd\u5bf9\u516c\u53f8\u76c8\u5229\u6784\u6210\u5a01\u80c1\u3002\u5c3d\u7ba1\u5feb\u9012\u884c\u4e1a\u6574\u4f53\u4e1a\u52a1\u91cf\u589e\u957f\u5f3a\u52b2\uff0c\u4f46\u5706\u901a\u901f\u9012\u57282024\u5e74\u81f3\u4eca\u7684\u5e02\u573a\u4efd\u989d\u548c\u4e1a\u52a1\u7ed3\u6784\u51fa\u73b0\u4e86\u6076\u5316\u3002\u6b64\u5916\uff0c\u516c\u53f8\u8ba1\u5212\u589e\u52a02025\u5e74\u7684\u8d44\u672c\u652f\u51fa\u81f36\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u9ad8\u4e8e\u6b64\u524d\u76845\u4ebf\u5143\u8ba1\u5212\uff0c\u4ee5\u5e94\u5bf9\u5e02\u573a\u7ade\u4e89\u548c\u5347\u7ea7\u57fa\u7840\u8bbe\u65bd\uff0c\u8fd9\u53ef\u80fd\u4f1a\u5bfc\u81f4\u81ea\u7531\u73b0\u91d1\u6d41\u51cf\u5c11\u3002</p><p>\u62a5\u544a\u8ba4\u4e3a\uff0c\u5c3d\u7ba1\u5706\u901a\u901f\u9012\u9762\u4e34\u7ade\u4e89\u52a0\u5267\u5bfc\u81f4\u76c8\u5229\u589e\u957f\u653e\u7f13\u7684\u98ce\u9669\uff0c\u4f46\u516c\u53f8\u5728\u6280\u672f\u521b\u65b0\u65b9\u9762\u7684\u9886\u5148\u5730\u4f4d\u53ef\u80fd\u6709\u52a9\u4e8e\u7f13\u89e3\u8fd9\u4e00\u98ce\u9669\u3002\u4f5c\u4e3a\u4e2d\u56fd\u5feb\u9012\u884c\u4e1a\u6b21\u5e2d\uff0c\u5706\u901a\u901f\u9012\u6709\u671b\u4ece\u884c\u4e1a\u6574\u5408\u4e2d\u957f\u671f\u53d7\u76ca\u3002\u6469\u6839\u58eb\u4e39\u5229\u9884\u8ba1\u5706\u901a\u901f\u90122025\u5e74\u7684\u51c0\u5229\u6da6\u5c06\u4e0b\u964d12-13%\uff0c\u9884\u8ba1\u51762025\u5e74\u7684\u5e02\u76c8\u7387\u4e3a13\u500d\uff0c\u4e0e\u56fd\u5185\u540c\u884c\u4e1a\u5e73\u5747\u6c34\u5e73\u76f8\u5f53\u3002</p><p>\u6469\u6839\u58eb\u4e39\u5229\u5bf9\u5706\u901a\u901f\u9012\u7684\u8bc4\u7ea7\u7531\u201c\u589e\u6301\u201d\u8c03\u6574\u81f3\u201c\u4e2d\u6027\u201d\uff0c\u76ee\u6807\u4ef7\u4ece20.90\u5143\u4eba\u6c11\u5e01\u4e0b\u8c03\u81f316.60\u5143\u4eba\u6c11\u5e01\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259653158", "pub_date": "2024-12-05 13:58:55"}]}