b\u4e3a\u67ec\u57d4\u5be8125.37%\uff0c\u9a6c\u6765\u897f\u4e9a21.37%\uff08\u5176\u4e2d\u5b9d\u4f73\u65b0\u80fd\u6e90\u7b49\u51e0\u5bb6\u516c\u53f8\u4e3a81.24%\uff09\uff0c\u6cf0\u56fd77.85%\uff08\u9633\u5149\u7535\u6c14\u80fd\u6e90\u548c\u6cf0\u534e\u65b0\u80fd\u6e90\u4e3a154.68%\uff09\uff0c\u8d8a\u5357271.28%\u3002\u503c\u5f97\u6ce8\u610f\u7684\u662f\uff0c\u51e0\u5bb6\u4e3b\u8981\u7684\u4e2d\u56fd\u5149\u4f0f\u5236\u9020\u5546\u5982\u6676\u6fb3\u592a\u9633\u80fd\u3001\u6676\u79d1\u80fd\u6e90\u3001\u5929\u5408\u5149\u80fd\u5206\u522b\u83b7\u5f97\u4e8653.3%\u300156.51%\u300154.56%\u7684\u7a0e\u7387\uff0c\u800c\u9686\u57fa\u83b7\u5f97\u4e86271.28%\u7684\u7a0e\u7387\u3002\u7f8e\u56fd\u5546\u52a1\u90e8\u6700\u7ec8\u88c1\u5b9a\u8ba1\u5212\u4e8e2025\u5e744\u670818\u65e5\u53d1\u5e03\uff0c2025\u5e746\u67082\u65e5\u7f8e\u56fd\u56fd\u9645\u8d38\u6613\u59d4\u5458\u4f1a\uff08ITC\uff09\u5c06\u505a\u51fa\u6700\u7ec8\u88c1\u5b9a\uff0c\u9884\u8ba1\u6700\u7ec8\u547d\u4ee4\u5c06\u4e8e2025\u5e746\u67089\u65e5\u53d1\u5e03\u3002<br/><br/>\u6469\u6839\u58eb\u4e39\u5229\u5206\u6790\u6307\u51fa\uff0c\u521d\u6b65\u7ed3\u679c\u4e0e\u8fd9\u4e9b\u9f99\u5934\u4f01\u4e1a\u7684\u9884\u671f\u5927\u81f4\u4e00\u81f4\u3002\u9664\u4e86\u5728\u67ec\u57d4\u5be8\u7684\u5149\u4f0f\u9f99\u5934\u4ea7\u80fd\u6ca1\u6709\u66dd\u5149\u5916\uff0c\u8be5\u673a\u6784\u8ba4\u4e3a\u8d8a\u5357\u548c\u6cf0\u56fd\u7684\u9ad8\u7a0e\u7387\u5c06\u6291\u5236\u5f53\u5730\u4f01\u4e1a\u5bf9\u7f8e\u56fd\u7684\u51fa\u53e3\uff0c\u800c\u7531\u4e8e\u7f8e\u56fd\u5728\u5149\u4f0f\u751f\u4ea7\u73af\u8282\u7f3a\u4e4f\u672c\u5730\u4f9b\u5e94\uff0c\u7a0e\u7387\u8f83\u4f4e\u7684\u9a6c\u6765\u897f\u4e9a\u7535\u6c60\u51fa\u53e3\u53ef\u80fd\u4f1a\u53d7\u76ca\u3002<br/><br/>\u6469\u6839\u58eb\u4e39\u5229\u8868\u793a\u8fd9\u4e00\u88c1\u5b9a\u5c06\u5bf9\u592a\u9633\u80fd\u884c\u4e1a\u7684\u5168\u7403\u4f9b\u5e94\u94fe\u4ea7\u751f\u91cd\u5927\u5f71\u54cd\uff0c\u5c24\u5176\u662f\u5728\u7f8e\u56fd\u5e02\u573a\u3002\u9884\u8ba1\u90e8\u5206\u5236\u9020\u5546\u8003\u8651\u5230\u7a0e\u7387\u7684\u63d0\u9ad8\uff0c\u53ef\u80fd\u4f1a\u8c03\u6574\u5176\u51fa\u53e3\u7b56\u7565\uff0c\u5bfb\u627e\u65b0\u7684\u5e02\u573a\u6216\u589e\u52a0\u5728\u7f8e\u56fd\u672c\u571f\u7684\u751f\u4ea7\u3002\u957f\u671f\u6765\u770b\uff0c\u8fd9\u4e00\u88c1\u5b9a\u53ef\u80fd\u4f1a\u4fc3\u4f7f\u592a\u9633\u80fd\u884c\u4e1a\u8fdb\u4e00\u6b65\u591a\u5143\u5316\u5176\u5168\u7403\u4f9b\u5e94\u94fe\uff0c\u4ee5\u51cf\u5c11\u5bf9\u5355\u4e00\u5e02\u573a\u7684\u4f9d\u8d56\u3002\u540c\u65f6\uff0c\u8fd9\u4e5f\u53ef\u80fd\u4f1a\u52a0\u901f\u7f8e\u56fd\u672c\u571f\u592a\u9633\u80fd\u5236\u9020\u4e1a\u7684\u53d1\u5c55\uff0c\u4ee5\u6ee1\u8db3\u56fd\u5185\u5e02\u573a\u9700\u6c42\u5e76\u51cf\u5c11\u5bf9\u8fdb\u53e3\u7684\u4f9d\u8d56\u3002\u6469\u6839\u58eb\u4e39\u5229\u5efa\u8bae\u6295\u8d44\u8005\u5bc6\u5207\u5173\u6ce8\u540e\u7eed\u7684\u6700\u7ec8\u88c1\u5b9a\u548c\u53ef\u80fd\u7684\u8d38\u6613\u653f\u7b56\u53d8\u5316\uff0c\u4ee5\u53ca\u8fd9\u4e9b\u53d8\u5316\u5bf9\u592a\u9633\u80fd\u884c\u4e1a\u7684\u5f71\u54cd\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259370464", "pub_date": "2024-12-03 14:47:22"}, {"id": 259370401, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4e2d\u4fe1\u5efa\u6295\u7ef4\u6301\u7b2c\u56db\u8303\u5f0f(06682)\u4e70\u5165\u8bc4\u7ea7 \u6307\u5176\u672a\u6765\u6709\u671b\u6301\u7eed\u63d0\u5347\u4efd\u989d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u4fe1\u5efa\u6295\u53d1\u7814\u62a5\u6307\uff0c\u7b2c\u56db\u8303\u5f0f(06682)\u6838\u5fc3\u4e1a\u52a1\u6536\u5165\u9ad8\u901f\u589e\u957f\u3002\u516c\u53f8\u524d\u4e09\u5b63\u5ea6\u5b9e\u73b0\u6536\u516532.18\u4ebf\u5143\uff0c\u540c\u6bd4\u4e0a\u534726.1%\uff0c\u5b9e\u73b0\u6bdb\u5229\u6da613.50\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f12.5%\uff0c\u5176\u4e2d\u6838\u5fc3\u4e1a\u52a1\u201c\u5148\u77e5AI\u5e73\u53f0\u201d\u5b9e\u73b0\u8425\u653621.71\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f50.2%\uff0c\u5360\u603b\u6536\u5165\u6bd4\u4f8b\u8d8567%\u3002\u516c\u53f8\u6807\u6746\u5ba2\u6237\u5e73\u5747\u8425\u65361487\u4e07\u5143\uff0c\u6807\u6746\u7528\u6237\u6570\u4e3a98\u4e2a\uff0c\u5360\u603b\u6570\u768444%\u3002\u516c\u53f8\u884c\u4e1a\u5927\u6a21\u578b\u5546\u4e1a\u5316\u8fdb\u7a0b\u52a0\u5feb\uff0c\u6301\u7eed\u6253\u9020\u91d1\u878d\u3001\u80fd\u6e90\u3001\u8fd0\u8425\u5546\u3001\u533b\u7597\u3001\u8fd0\u8f93\u3001\u5236\u9020\u7b49\u884c\u4e1a\u7684\u6807\u6746\u5ba2\u6237\u548c\u89e3\u51b3\u65b9\u6848\uff0c\u57fa\u4e8e\u5404\u884c\u4e1a\u573a\u666f\u7684\u4e0d\u540c\u6a21\u6001\u6570\u636e\u6784\u5efa\u884c\u4e1a\u5927\u6a21\u578b\uff0c\u62d3\u5c55\u884c\u4e1a\u5927\u6a21\u578b\u5e94\u7528\u9886\u57df\u3002 <br/><br/>\u8be5\u884c\u6307\uff0c\u516c\u53f8\u4f5c\u4e3a\u4f01\u4e1a\u7ea7AI\u9886\u8dd1\u8005\uff0c\u8fd1\u5e74\u6765\u6536\u5165\u6301\u7eed\u9ad8\u589e\uff0c\u51c0\u4e8f\u635f\u6301\u7eed\u6536\u7a84\uff0c\u76c8\u5229\u6a21\u5f0f\u6108\u53d1\u6e05\u6670\u3002\u6807\u6746\u5ba2\u6237\u6570\u548c\u6536\u5165\u7a33\u5b9a\u589e\u957f\uff0c\u4e0b\u6e38\u884c\u4e1a\u62d3\u5c55\u987a\u5229\u30022023\u5e74\u63a8\u51fa\u7684\u5f0f\u8bf4\u5927\u6a21\u578b\u548cAIGS\u670d\u52a1\u5e73\u53f0\u4e3a\u516c\u53f8\u6253\u5f00\u4e86\u751f\u6210\u5f0fAI\u7684\u5e02\u573a\u7a7a\u95f4\uff0c\u51ed\u501f\u5bf9\u4f01\u4e1a\u7ea7\u6570\u636e\u3001\u75db\u70b9\u548c\u81ea\u8eab\u5f3a\u5927\u7684\u8f6f\u4ef6\u80fd\u529b\uff0c\u672a\u6765\u6709\u671b\u6301\u7eed\u63d0\u5347\u4efd\u989d\u3002</p><p>\u8be5\u884c\u9884\u8ba1\u516c\u53f82024-2026\u5e74\u8425\u4e1a\u6536\u5165\u5206\u522b\u4e3a54.10\u300166.91\u548c80.86\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u901f\u5206\u522b\u4e3a28.68%\u300123.67%\u300120.86%\u3002\u5bf9\u5e942024-2026\u5e74PS\u5206\u522b\u4e3a3.23x\u30012.6x2\u30012.16x\u3002\u9884\u8ba1\u516c\u53f82023-2025\u5e74\u5f52\u6bcd\u51c0\u5229\u6da6\u5206\u522b\u4e3a-3.13\u3001-0.40\u548c3.14\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u901f\u5206\u522b\u4e3a65.55%\u300187.20%\u548c883.81%\u3002\u8003\u8651\u5230\u516c\u53f8\u7684AI\u5e73\u53f0\u5316\u80fd\u529b\u53ca\u6210\u957f\u6027\uff0c\u4e0b\u6e38\u4f18\u8d28\u5ba2\u6237\u5360\u6bd4\u9ad8\uff0c\u6280\u672f\u79ef\u7d2f\u6df1\u539a\uff0c\u53c2\u8003\u6d77\u5916\u53ef\u6bd4\u516c\u53f8\u4f30\u503c\uff0c\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259370401", "pub_date": "2024-12-03 14:47:23"}, {"id": 259370400, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4e2d\u4fe1\u5efa\u6295\u7ef4\u6301\u654f\u534e\u63a7\u80a1(01999)\u201c\u4e70\u5165\u201d\u8bc4\u7ea7 \u6599\u540e\u7eed\u4ee5\u65e7\u6362\u65b0\u653f\u7b56\u8865\u8d34\u6709\u671b\u5e26\u52a8\u5185\u9500\u7ec8\u7aef\u9700\u6c42\u6539\u5584", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u4fe1\u5efa\u6295\u53d1\u7814\u62a5\u6307\uff0c\u654f\u534e\u63a7\u80a1(01999)FY25H1\uff08\u81ea\u7136\u5e74\u4e3a24\u5e744-9\u6708\uff09\u8425\u6536\u3001\u5f52\u6bcd\u51c0\u5229\u6da6\u5206\u522b\u540c\u6bd4-7.4%\u3001+0.3%\u3002\u5176\u4e2d\u4e2d\u56fd\u3001\u5317\u7f8e\u3001\u6b27\u6d32\u5e02\u573a\u8425\u6536\u540c\u6bd4-17.2%\u3001+5.7%\u3001+37.7%\uff0c\u8425\u6536\u5360\u6bd4\u5206\u522b\u4e3a59.9%\u300125.9%\u30018.8%\u3002\u5185\u9500\u4e3b\u8981\u7cfb\u5730\u4ea7\u7ae3\u5de5\u4e0b\u884c\u53e0\u52a0\u6d88\u8d39\u4f4e\u8ff7\u6240\u81f4\uff0c\u671f\u95f4\u516c\u53f8\u5185\u9500\u7ebf\u4e0b\u6e20\u9053\u7ee7\u7eed\u52a0\u5927\u4e0b\u6c89\u6269\u5f20\uff0c\u622a\u6b629\u6708\u5e95\u7ebf\u4e0b\u95e8\u5e97\u65707516\u5bb6/\u51c0\u589e280\u5bb6\uff1b\u5916\u9500\u5e02\u573a\u516c\u53f8\u52a0\u5f3a\u65b0\u6e20\u9053\u548c\u65b0\u5ba2\u6237\u7684\u5f00\u62d3\uff0c\u5317\u7f8e\u7a33\u5065\u589e\u957f\u3001\u6b27\u6d32\u589e\u957f\u663e\u7740\u3002FY25H1\u516c\u53f8\u6bdb\u5229\u7387\u4e3a39.5%/+0.4pct\uff0c\u5916\u9500\u6bdb\u5229\u7387\u63d0\u5347\u660e\u663e\u4e3b\u8981\u53d7\u76ca\u4e8e\u94a2\u6750\u3001\u771f\u76ae\u7b49\u539f\u6750\u6599\u4ef7\u683c\u5206\u522b-8.3%\u3001-5.3%\u3002FY25H1\u51c0\u5229\u7387\u4e3a14.38%/+1.13pct\u3002\u5c55\u671b\u540e\u7eed\uff0c\u4ee5\u65e7\u6362\u65b0\u653f\u7b56\u8865\u8d34\u6709\u671b\u5e26\u52a8\u5185\u9500\u7ec8\u7aef\u9700\u6c42\u6539\u5584\uff0c\u5916\u9500\u51fa\u53e3\u81f3\u6b27\u6d32\u6301\u7eed\u63d0\u5347\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0c\u8d22\u5e74\u622a\u81f3\u5f53\u5e743\u6708\u4efd\uff0c\u9884\u8ba1\u516c\u53f8FY25-FY27\u8425\u6536\u5206\u522b\u4e3a178.9\u3001189.4\u3001198.7 \u4ebf\u6e2f\u5143\uff0c\u5206\u522b\u540c\u6bd4-2.9%\u3001+5.9%\u3001+4.9%\uff1b\u5f52\u6bcd\u51c0\u5229\u6da6\u5206\u522b\u4e3a23.4\u300125.2\u300126.8 \u4ebf\u6e2f\u5143\uff0c\u5206\u522b\u540c\u6bd4+1.7%\u3001+7.5%\u3001+6.6%\uff1b\u5bf9\u5e94PE\u4e3a8.0x\u30017.5x\u30017.0x\u3002\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002&nbsp;</p>", "link": "https://sky.szfiu.com/info/hk/details/259370400", "pub_date": "2024-12-03 14:47:39"}, {"id": 259369949, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u745e\u94f6\uff1a\u667a\u80fd\u624b\u673a\u8d2d\u4e70\u610f\u5411\u7a33\u5b9a\u4e14\u5e02\u573a\u9884\u671f\u9002\u5ea6\u589e\u957f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u745e\u94f6\u8fd1\u65e5\u53d1\u5e03\u7684\u7814\u62a5\u6307\u51fa\uff0c\u5168\u7403\u667a\u80fd\u624b\u673a\u8d2d\u4e70\u610f\u5411\u57282024\u5e74\u7b2c\u56db\u5b63\u5ea6\u4fdd\u6301\u7a33\u5b9a\u3002\u8c03\u67e5\u663e\u793a\uff0c39%\u7684\u53d7\u8bbf\u8005\u8ba1\u5212\u5728\u672a\u676512\u4e2a\u6708\u5185\u8d2d\u4e70\u667a\u80fd\u624b\u673a\uff0c\u4e0e\u53bb\u5e74\u540c\u671f\u76f8\u6bd4\u6301\u5e73\uff0c\u4e14\u6bd4\u4e0a\u4e00\u5b63\u5ea6\u768436%\u6709\u6240\u4e0a\u5347\u3002\u5c3d\u7ba1\u4e2d\u56fd\u7684\u8d2d\u4e70\u610f\u5411\u540c\u6bd4\u4e0b\u964d\u81f350%\uff0c\u4f46\u4e0e\u4e0a\u5b63\u5ea6\u76f8\u6bd4\u4fdd\u6301\u7a33\u5b9a\u3002\u62a5\u544a\u8fd8\u5bf9\u5168\u7403\u667a\u80fd\u624b\u673a\u5355\u4f4d\u9500\u552e\u91cf\uff08Sell-In\uff09\u8fdb\u884c\u4e86\u9884\u6d4b\uff0c\u9884\u8ba12024\u5e74\u548c2025\u5e74\u7684\u9500\u552e\u91cf\u5c06\u5206\u522b\u8fbe\u523012.1\u4ebf\u90e8\uff08\u540c\u6bd4\u589e\u957f4.0%\uff09\u548c12.3\u4ebf\u90e8\uff08\u540c\u6bd4\u589e\u957f2.0%\uff09\uff0c\u5e76\u9996\u6b21\u5bf92026\u5e74\u7684\u9500\u552e\u91cf\u8fdb\u884c\u9884\u6d4b\uff0c\u9884\u8ba1\u4e3a12.5\u4ebf\u90e8\uff08\u540c\u6bd4\u589e\u957f1.0%\uff09\u3002<br/><br/>\u745e\u94f6\u5206\u6790\u6307\u51fa\uff0c\u5c3d\u7ba1\u5168\u7403\u667a\u80fd\u624b\u673a\u5e02\u573a\u589e\u957f\u653e\u7f13\uff0c\u4f46\u8d2d\u4e70\u610f\u5411\u7684\u7a33\u5b9a\u548c\u667a\u80fd\u624b\u673a\u66f4\u6362\u5468\u671f\u7684\u6301\u7eed\u7a33\u5b9a\u8868\u660e\u5e02\u573a\u5e76\u672a\u51fa\u73b0\u5927\u5e45\u4e0b\u6ed1\u3002\u7279\u522b\u662f\u5728\u4e2d\u56fd\u5e02\u573a\uff0c\u5c3d\u7ba1\u8d2d\u4e70\u610f\u5411\u6709\u6240\u4e0b\u964d\uff0c\u4f46\u4ecd\u4fdd\u6301\u5728\u8f83\u9ad8\u6c34\u5e73\u3002\u6b64\u5916\uff0c\u62a5\u544a\u8fd8\u63d0\u5230\uff0c\u5c3d\u7ba1\u751f\u6210\u5f0f\u4eba\u5de5\u667a\u80fd\uff08Generative AI\uff09\u5728\u667a\u80fd\u624b\u673a\u4e0a\u7684\u5e94\u7528\u5f15\u8d77\u4e86\u4e00\u5b9a\u5174\u8da3\uff0c\u4f46\u76ee\u524d\u5176\u5bf9\u667a\u80fd\u624b\u673a\u8d2d\u4e70\u610f\u5411\u7684\u5f71\u54cd\u6709\u9650\u3002<br/><br/>\u745e\u94f6\u8ba4\u4e3a\uff0c\u751f\u6210\u5f0fAI\u7279\u6027\u53ef\u80fd\u4f1a\u5bf9\u9ad8\u7aef\u667a\u80fd\u624b\u673a\u5e02\u573a\u4ea7\u751f\u4e00\u5b9a\u5f71\u54cd\uff0c\u4f46\u76ee\u524d\u6d88\u8d39\u8005\u5bf9\u4e8e\u8fd9\u4e9b\u7279\u6027\u7684\u652f\u4ed8\u610f\u613f\u4ecd\u7136\u6709\u9650\u3002\u603b\u4f53\u800c\u8a00\uff0c\u745e\u94f6\u5bf9\u667a\u80fd\u624b\u673a\u884c\u4e1a\u7684\u524d\u666f\u6301\u8c28\u614e\u4e50\u89c2\u6001\u5ea6\uff0c\u9884\u8ba1\u672a\u6765\u51e0\u5e74\u5168\u7403\u667a\u80fd\u624b\u673a\u5e02\u573a\u5c06\u4fdd\u6301\u9002\u5ea6\u589e\u957f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259369949", "pub_date": "2024-12-03 14:43:21"}, {"id": 259369950, "title": "\u97e9\u56fd\u7efc\u5408\u6307\u6570\u6536\u6da81.86% \u62a52500.1\u70b9", "description": "<p>\u91d1\u543e