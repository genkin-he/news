c\u534f\u52a9\u4e2d\u8d44\u4f01\u4e1a\u52a0\u5feb\u5728\u6e2f\u4e0a\u5e02", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u636e\u5a92\u4f53\u62a5\u9053\uff0c\u5185\u5730\u53ca\u9999\u6e2f\u7684\u76d1\u7ba1\u673a\u6784\u5df2\u7ecf\u901a\u77e5\u4e86\u4e00\u4e9b\u5168\u7403\u5927\u578b\u6295\u8d44\u94f6\u884c\uff0c\u8981\u6c42\u4ed6\u4eec\u534f\u52a9\u4e2d\u8d44\u4f01\u4e1a\u52a0\u5feb\u5728\u9999\u6e2f\u7684\u4e0a\u5e02\u8fc7\u7a0b\u3002\u8fd9\u4e00\u63aa\u65bd\u65e8\u5728\u4fc3\u8fdb\u4f01\u4e1a\u7b79\u96c6\u8d44\u91d1\uff0c\u5e76\u4f5c\u4e3a\u63d0\u632f\u4e2d\u56fd\u7ecf\u6d4e\u7684\u4e3e\u63aa\u3002\u62a5\u9053\u8fd8\u79f0\uff0c\u5185\u5730\u76d1\u7ba1\u673a\u6784\u572810\u6708\u4e3e\u884c\u7684\u4e24\u6b21\u4f1a\u8bae\u4e0a\u8868\u793a\uff0c\u6b63\u5728\u81f4\u529b\u4e8e\u52a0\u5feb\u90e8\u5206\u79bb\u5cb8\u4e0a\u5e02\u516c\u53f8\u7684\u65f6\u95f4\u8868\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/260102032", "pub_date": "2024-12-10 12:22:48"}, {"id": 260102090, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u82b1\u65d7\u6599\u7279\u6717\u666e\u7b2c\u4e8c\u4efb\u671f\u5229\u7a7a\u539f\u6cb9 \u9ec4\u91d1\u767d\u94f6\u5c06\u5373\u5c06\u6062\u590d\u5176\u6e10\u8fdb\u7684\u4e0a\u5347\u8d8b\u52bf", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u82b1\u65d7\u53d1\u5e03\u5927\u5b97\u5546\u54c1\u5e02\u573a2025\u5e74\u5c55\u671b\uff0c\u7f8e\u56fd\u7ecf\u6d4e\u548c\u52b3\u52a8\u529b\u5e02\u573a\u5728\u8fc7\u53bb\u4e24\u5e74\u591a\u7684\u65f6\u95f4\u91cc\u5df2\u7ecf\u9010\u6e10\u653e\u7f13\uff0c\u800c\u540d\u4e49\u5229\u7387\u3001\u6838\u5fc3\u901a\u80c0\u7387\u548c\u5b9e\u9645\u5229\u7387\u4eca\u5929\u4ecd\u7136\u660e\u663e\u9ad8\u4e8e2017\u5e74\u7684\u6c34\u5e73\uff08\u4e0a\u6b21\u7279\u6717\u666e\u5f53\u9009\u65f6\uff0c\u7f8e\u56fd\u7684\u5b9e\u9645\u5229\u7387\u4e3a\u8d1f\uff0c\u540d\u4e49\u5229\u7387\u548c\u6838\u5fc3\u901a\u80c0\u5747\u4e3a2%\uff09\u3002\u7f8e\u56fd\u653f\u5e9c\u503a\u52a1\u4e5f\u6b63\u5728\u6025\u5267\u4e0a\u5347\uff0c\u5e76\u5904\u4e8e\u201c\u4e0d\u53ef\u6301\u7eed\u7684\u8def\u5f84\u201d\u4e0a\u3002<br/><br/>\u82b1\u65d7\u5916\u6c47\u7b56\u7565\u5e08\u8ba4\u4e3a\uff0c\u7f8e\u5143\u6307\u6570(DXY)\u57282025\u5e74\u5c06\u4fdd\u6301\u5728\u5f53\u524d\u7684106\u6c34\u5e73\u6216\u4ee5\u4e0a\uff0c\u800c\u82b1\u65d7\u7ecf\u6d4e\u5b66\u5bb6\u9884\u8ba1\u7f8e\u56fd\u7ecf\u6d4e\u589e\u957f\u5c06\u57282025\u5e74\u4ece2024\u5e74\u76842.5%\u548c2023\u5e74\u76842.6%\u5b9e\u8d28\u6027\u5730\u51cf\u7f13\u81f31.0%\u3002\u4e3a\u4e86\u7ed9\u7f8e\u56fd\u7684\u589e\u957f\u548c\u52b3\u52a8\u529b\u5e02\u573a\u8bbe\u5b9a\u5e95\u7ebf\uff0c\u82b1\u65d7\u7684\u7f8e\u56fd\u7ecf\u6d4e\u5b66\u5bb6\u8ba4\u4e3a\u7f8e\u8054\u50a8\u5c06\u5728\u63a5\u4e0b\u6765\u76845\u6b21\u4f1a\u8bae\u4e0a\u964d\u606f\uff0c\u4f7f\u73b0\u91d1\u5229\u7387\u52302025\u5e74\u4e2d\u671f\u964d\u81f33-3.25%\u3002<br/><br/>\u8be5\u884c\u9884\u8ba1\u539f\u6cb9\u4ef7\u683c\u5c06\u57282025\u5e74\u4e2d\u671f\u9010\u6b65\u964d\u81f3\u6bcf\u687660\u7f8e\u5143\uff08-15\u81f3-20%\uff09\uff0c\u5e76\u57282026\u5e74\u7ef4\u6301\u8fd9\u4e00\u6c34\u5e73\uff0c\u8fd9\u662f\u8be5\u884c\u57fa\u51c6\u60c5\u666f\u4e0b\u7684\u9884\u6d4b\u3002\u8be5\u884c\u8ba4\u4e3a\u7279\u6717\u666e\u7b2c\u4e8c\u4efb\u671f\u5185\u603b\u4f53\u4e0a\u662f\u7ad9\u5728\u770b\u7a7a\u77f3\u6cb9\u7684\u4e00\u65b9\uff0c\u65e0\u8bba\u662f\u51fa\u4e8e\u653f\u7b56\u627f\u8bfa\uff08\u5982\u964d\u4f4e\u80fd\u6e90\u6210\u672c50%\uff0c\u63a8\u52a8\u7f8e\u56fd\u80fd\u6e90\u4e3b\u5bfc\u6743\uff0c\u201c\u7ed3\u675f\u6218\u4e89\u800c\u4e0d\u662f\u53d1\u52a8\u6218\u4e89\u201d\u7b49\uff09\uff0c\u8fd8\u662f\u4f5c\u4e3a\u964d\u4f4e\u901a\u80c0\u3001\u5229\u7387\u4ee5\u53ca\u7f8e\u56fd\u653f\u5e9c\u503a\u52a1\u670d\u52a1\u8d1f\u62c5\u7684\u5de5\u5177\uff0c\u4ee5\u652f\u6301\u7f8e\u56fd\u7ecf\u6d4e\u589e\u957f\u548c\u52b3\u52a8\u529b\u5e02\u573a\u3002<br/><br/>\u5982\u679c\u6709\u5173\u5168\u9762\u5173\u7a0e\u7684\u6d88\u606f\u51b2\u51fb\u4ea4\u6613\u6240\uff08\u5b9e\u7269\u7ed3\u7b97\u7684\u5546\u54c1\u671f\u8d27\uff09\uff0c\u7f8e\u56fd\u5e02\u573a\u4ef7\u683c\u53ef\u80fd\u51fa\u73b0\u5927\u5e45\u4e0a\u6da8\u3002\u5177\u6709\u9ad8\u4ef7\u683c\u5dee\u5f02\u6bd4\u7387\uff08\u8303\u56f4\uff09\u7684\u5927\u5b97\u5546\u54c1\uff0c\u5982\u8d35\u91d1\u5c5e\u548c\u94dc\uff0c\u5c06\u53d7\u5230\u6700\u5927\u5f71\u54cd\u3002\u867d\u7136\u8be5\u884c\u6700\u7ec8\u9884\u8ba1FTA\u56fd\u5bb6\u548c\u9ec4\u91d1\u4f1a\u88ab\u6392\u9664\u5728\u5916\uff0c\u4f46\u5934\u6761\u65b0\u95fb\uff08\u53ca\u5b9e\u9645\uff09\u98ce\u9669\u4f9d\u7136\u5b58\u5728\u3002\u56e0\u6b64\uff0c\u8be5\u884c\u5efa\u8bae\u4efb\u4f55\u5728\u7f8e\u56fd\u5e02\u573a\u4e0a\u505a\u7a7a\u6216\u5bf9\u51b2\u5176\u9ec4\u91d1\u3001\u94dc\u548c\u77f3\u6cb9\u655e\u53e3\u7684\u6295\u8d44\u8005\u8003\u8651\u5c06\u5176\u7a7a\u5934\u5934\u5bf8\u8f6c\u79fb\u5230\u975e\u7f8e\u56fd\u5e02\u573a\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u9ec4\u91d1\u548c\u767d\u94f6\u725b\u5e02\u5728\u8fc7\u53bb\u4e00\u4e2a\u6708\u4e2d\u6682\u505c\uff0c\u4f46\u5728\u63a5\u4e0b\u6765\u76843-12\u4e2a\u6708\u5185\u5c06\u6062\u590d\u5176\u6e10\u8fdb\u7684\u4e0a\u5347\u8d8b\u52bf\uff0c\u5206\u522b\u5347\u81f3\u6bcf\u76ce\u53f83,000\u7f8e\u5143\uff08+15%\uff09\u548c\u6bcf\u76ce\u53f836\u7f8e\u5143\uff08+15-20%\uff09\u3002<br/><br/>\u8be5\u884c\u770b\u597d2025\u5e74\u7684\u4ea8\u5229\u6e2f\u5929\u7136\u6c14\u4ef7\u683c\uff0c\u9884\u8ba12025\u5e74\u7b2c\u4e8c\u5b63\u5ea6\u76f8\u6bd4\u5f53\u524d\u8fdc\u671f\u66f2\u7ebf\u5c06\u670940-50%\u7684\u4e0a\u884c\u7a7a\u95f4\u3002\u5c3d\u7ba1\u77ed\u671f\u5185\u6ce2\u52a8\u6027\u53d6\u51b3\u4e8e\u51ac\u5b63\u5929\u6c14\u7684\u53d1\u5c55\uff0c\u4f46\u8be5\u884c\u9884\u8ba1\u968f\u7740\u5e02\u573a\u5173\u6ce8\u70b9\u8f6c\u5411\u4f4e\u4e8e\u9884\u671f\u7684\u56fd\u5185\u751f\u4ea7\u548c\u66f4\u9ad8\u7684\u6db2\u5316\u5929\u7136\u6c14\u51fa\u53e3\uff0c2025\u5e74\u8fdb\u4e00\u6b65\u6df1\u5165\u540e\u4ef7\u683c\u4f1a\u6709\u66f4\u597d\u7684\u4e0a\u884c\u6f5c\u529b\u3002\u8bf7\u53c2\u9605\u7b2c50-64\u9875\u3002<br/><br/>\u8be5\u884c\u770b\u597d\u539f\u7cd6\uff0c\u5e76\u9884\u8ba1\u5728\u672a\u67656-12\u4e2a\u6708\u5185\u5c06\u6709\u8fd120%\u7684\u4e0a\u884c\u7a7a\u95f4\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260102090", "pub_date": "2024-12-10 12:22:57"}, {"id": 260100822, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u77f3\u56db\u836f\u96c6\u56e2(02005)\u53d6\u5f97\u5730\u62c9\u7f57\u53f8\u5206\u6563\u7247(125mg)\u7684\u836f\u54c1\u751f\u4ea7\u6ce8\u518c\u6279\u4ef6", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u77f3\u56db\u836f\u96c6\u56e2(02005)\u516c\u5e03\uff0c\u96c6\u56e2\u5df2\u53d6\u5f97\u4e2d\u56fd\u56fd\u5bb6\u836f\u54c1\u76d1\u7763\u7ba1\u7406\u5c40\u6709\u5173\u5730\u62c9\u7f57\u53f8\u5206\u6563\u7247\uff08125mg\uff09\u7684\u836f\u54c1\u751f\u4ea7\u6ce8\u518c\u6279\u4ef6\uff0c\u5c5e\u4e8e\u5316\u5b66\u836f\u54c1\u7b2c4\u7c7b\uff0c\u89c6\u540c\u901a\u8fc7\u4e00\u81f4\u6027\u8bc4\u4ef7\u3002<br/><br/>\u5730\u62c9\u7f57\u53f8\u5206\u6563\u7247\u4e3b\u8981\u7528\u4e8e\u6cbb\u7597\u5927\u4e8e\u4e24\u5c81\u7684\u03b2-\u5730\u4e2d\u6d77\u8d2b\u8840\u60a3\u8005\u56e0\u9891\u7e41\u8f93\u8840\u6240\u81f4\u6162\u6027\u94c1\u8fc7\u8f7d\uff0c\u53ca\u6cbb\u7597\u5341\u5c81\u53ca\u5341\u5c81\u4ee5\u4e0a\u975e\u8f93\u8840\u4f9d\u8d56\u6027\u5730\u4e2d\u6d77\u8d2b\u8840\u7efc\u5408\u75c7\u60a3\u8005\u7684\u6162\u6027\u94c1\u8fc7\u8f7d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260100822", "pub_date": "2024-12-10 12:11:48"}]}