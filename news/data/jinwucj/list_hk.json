5\u8fd1\u5065\u5eb7\u6c34\u5e73\u3002\u6c7d\u8f66\u9700\u6c42\u4e5f\u5c06\u89e6\u5e95\uff0c\u9884\u793a\u7740\u9700\u6c42\u5373\u5c06\u6062\u590d\u3002\u8fd9\u4e24\u4e2a\u5e02\u573a\u5bf9\u529f\u7387\u5668\u4ef6\u3001\u6a21\u62df\u82af\u7247\u548cMCU\u4ea7\u751f\u4e86\u5f88\u5927\u5f71\u54cd\u3002WSTS\u7684\u6700\u65b0\u9884\u6d4b\u8868\u660e\uff0c\u5168\u7403\u534a\u5bfc\u4f53\u5e02\u573a\u5c06\u57282024\u5e74\u540c\u6bd4\u589e\u957f19%\u81f36270\u4ebf\u7f8e\u5143\uff0c\u968f\u540e\u5728 2025\u5e74\u540c\u6bd4\u589e\u957f11%\u3002\u540c\u6837\u7684\u5468\u671f\u6a21\u5f0f\u4e5f\u51fa\u73b0\u5728\u5360\u6574\u4e2a\u534a\u5bfc\u4f53\u5e02\u573a85%\u7684\u96c6\u6210\u7535\u8def (IC) \u5e02\u573a\u3002<br/><br/>\u5e73\u5b89\u8bc1\u5238\u8868\u793a\uff0c2025\u5e74\uff0c\u534a\u5bfc\u4f53\u884c\u4e1a\u6574\u4f53\u589e\u957f\u8d8b\u4e8e\u5e73\u7a33\uff0c\u4f46\u589e\u957f\u76f8\u8f832024\u5e74\u66f4\u4e3a\u5747\u8861\u3001\u5065\u5eb7\u3002\u4ece\u6295\u8d44\u65b9\u5411\u770b\uff0c\u4e3b\u8981\u662f\uff1a1\uff09AI\u53ca\u76f8\u5173\u8d5b\u9053\uff0c\u63a8\u8350\u5904\u7406\u5668\u82af\u7247\u516c\u53f8\u3001HBM\u65b9\u5411\uff1b\u7f51\u7edc\u82af\u7247\u548c\u5149\u7535\u5b50\u9886\u57df\uff1b\u7aef\u4fa7\u91cd\u70b9\u5173\u6ce8SoC\u82af\u7247\u7b49\u516c\u53f8\u30022\uff09\u56fd\u4ea7\u5316\u65b9\u5411\u3002EDA\u5de5\u5177\u65b9\u9762\u3001\u5c01\u88c5\u65b9\u9762\u3001\u4ea7\u54c1\u548c\u5668\u4ef6\u65b9\u9762\uff0c\u540e\u7eed\u56fd\u4ea7\u5316\u66ff\u4ee3\u7684\u7a7a\u95f4\u8f83\u5927\uff0c\u6750\u6599\u65b9\u9762\u7b49\u76f8\u5173\u516c\u53f8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/261257615", "pub_date": "2024-12-20 09:52:20"}, {"id": 261257228, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u5fae\u76df\u96c6\u56e2(02013)\u7eed\u534715.61% \u4e2d\u91d1\u6599\u5176\u53d7\u76ca\u4e8e\u5fae\u4fe1\u7535\u5546\u751f\u6001\u6d3b\u8dc3\u5ea6\u63d0\u5347", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5fae\u76df\u96c6\u56e2(02013)\u5ef6\u7eed\u6628\u65e5\u6da8\u52bf\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da815.61%\uff0c\u62a52.37\u6e2f\u5143\uff0c\u6210\u4ea4\u989d8.5\u4ebf\u6e2f\u5143\u3002\u503c\u5f97\u6ce8\u610f\u7684\u662f\uff0c\u8be5\u80a1\u4e24\u65e5\u7d2f\u8ba1\u6da8\u5e45\u8d8560%\u3002<br/><br/>\u5fae\u4fe1\u56e2\u961f\u516c\u544a\u79f0\uff0c\u5fae\u4fe1\u5c0f\u5e97\u5f00\u542f\u201c\u9001\u793c\u7269\u201d\u529f\u80fd\u7684\u7070\u5ea6\u6d4b\u8bd5\u3002\u5fae\u4fe1\u7528\u6237\u6570\u4f53\u91cf\u4e0e\u89c6\u9891\u53f7\u7a33\u5b9a\u53d1\u5c55\uff0c\u751f\u6001\u76f8\u4e92\u878d\u5408\u4e3a\u5fae\u4fe1\u5c0f\u5e97\u63d0\u4f9b\u57fa\u7840\u3002\u5728\u4e0a\u4e00\u6b21\u5fae\u4fe1\u7528\u793e\u4ea4\u901a\u8fc7\u5fae\u4fe1\u7ea2\u5305\u5927\u529b\u52a9\u63a8\u5fae\u4fe1\u652f\u4ed8\u6210\u529f\u540e\uff0c\u6b64\u6b21\u5fae\u4fe1\u5c0f\u5e97\u201c\u9001\u793c\u7269\u201d\u5c06\u793e\u4ea4\u4e0e\u7535\u5546\u518d\u6b21\u94fe\u63a5\uff0c\u88ab\u4e1a\u5185\u4eba\u58eb\u8ba4\u4e3a\uff0c\u8fd9\u53ef\u80fd\u662f\u5fae\u4fe1\u7ea2\u53052.0\u7248\u672c\uff0c\u5fae\u4fe1\u5c0f\u5e97\u201c\u9001\u793c\u7269\u201d\u529f\u80fd\u6d4b\u8bd5\uff0c\u6709\u5229\u4e8e\u901a\u8fc7\u793e\u4ea4\u52a9\u63a8\u5fae\u4fe1\u7535\u5546\u53d1\u5c55\u3002<br/><br/>\u4e2d\u91d1\u53d1\u5e03\u7814\u7a76\u62a5\u544a\u79f0\uff0c\u7ef4\u6301\u96c6\u56e22024\u548c2025\u5e74\u4e1a\u7ee9\u9884\u6d4b\u4e0d\u53d8\u3002\u7ef4\u6301\u201c\u8dd1\u8d62\u884c\u4e1a\u201d\u8bc4\u7ea7\uff0c\u8003\u8651\u884c\u4e1a\u4f30\u503c\u4e2d\u67a2\u4e0a\u884c\u3001\u4e2d\u671f\u589e\u957f\u786e\u5b9a\u6027\u63d0\u5347\uff0c\u4e0a\u8c03\u76ee\u6807\u4ef756%\u81f32.8\u6e2f\u5143\u300212\u670818\u65e5\uff0c\u5fae\u4fe1\u5c0f\u5e97\u5f00\u542f\u201c\u9001\u793c\u7269\u201d\u529f\u80fd\u7684\u7070\u5ea6\u6d4b\u8bd5\u3002\u4f34\u968f\u5fae\u4fe1\u7535\u5546\u751f\u6001\u6d3b\u8dc3\u5ea6\u9010\u6b65\u63d0\u5347\uff0c\u8be5\u884c\u9884\u8ba1\u5fae\u76df\u4f5c\u4e3a\u5934\u90e8\u7b2c\u4e09\u65b9\u670d\u52a1\u5546\u6709\u671b\u53d7\u76ca\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/261257228", "pub_date": "2024-12-20 09:43:47"}, {"id": 261256937, "title": "\u3010\u7279\u7ea6\u5927V\u3011\u9093\u58f0\u5174\uff1a\u7f8e\u8054\u50a8\u6682\u7f13\u51cf\u606f\u62d6\u7d2f \u4e2d\u6e2f\u80a1\u5e02\u504f\u5f31", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6052\u6307\u5468\u56db(19\u65e5)\u6536\u5e02\u62a519752\uff0c\u8dcc112\u70b9\u62160.56%\u3002\u5927\u5e02\u5168\u65e5\u6210\u4ea41428\u4ebf\u5143\u3002\u56fd\u6307\u8dcc28\u70b9\u62160.4%\uff0c\u62a57152\u3002\u79d1\u6307\u8dcc29\u70b9\u62160.7%\uff0c\u62a54439\u3002\u9999\u6e2f\u672c\u5730\u5730\u4ea7\u80a1\u62c5\u5fc3\u5229\u7387\u672a\u6765\u6216\u4e8e\u76f8\u5bf9\u9ad8\u4f4d\u4fdd\u6301\u66f4\u957f\u65f6\u95f4\uff0c\u5730\u4ea7\u80a1\u53d7\u538b\u3002\u65b0\u5730(00016)\u8dcc2.2%\uff1b\u6052\u5730(00012)\u63d23.3%\uff1b\u79bb\u5cb8\u4eba\u6c11\u5e01\u9694\u665a\u66fe\u8d2c\u81f37.3270\uff0c\u968f\u540e\u7565\u53cd\u5f39\uff0c\u5185\u623f\u80a1\u4ecd\u666e\u904d\u5411\u4e0b\uff0c\u878d\u521b\u4e2d\u56fd(01918)\u632b2.4%\u3002<br/><br/>\u9053\u6307\u5468\u56db(19\u65e5)\u6536\u62a542342\u70b9\uff0c\u534715\u70b9\u62160.04%\u3002\u6807\u6307\u5012\u8dcc0.09%\uff0c\u62a55867\u70b9\uff1b\u7eb3\u6307\u8f6c\u632b0.1%\uff0c\u62a519372\u70b9\uff1b\u91cd\u78c5\u80a1\u4e2d\uff0c\u7279\u65af\u62c9(Tesla)\u53cd\u8986\u56de\u54100.9%\uff0c\u8f89\u8fbe(Nvidia)\u53caNetflix\u9f50\u56de\u53471.4%\u3002\u6676\u7247\u5546\u7f8e\u5149\u79d1\u6280(Micron)\u4e1a\u7ee9\u5c55\u671b\u8fdc\u900a\u9884\u671f\uff0c\u80a1\u4ef7\u63d2\u6c3416.2%\u3002\u6ce2\u97f3\u53cd\u5f392.6%\uff0c\u4e3a\u5347\u5e45\u6700\u5927\u9053\u6307\u6210\u4efd\u80a1\u3002\u7f8e\u56fd\u8fd0\u901a\u548cVISA\u5206\u522b\u4e0a\u6da81.8%\u548c1.7%\u3002\u4e9a\u592a\u80a1\u5e02\u4eca\u65e9(20\u65e5)\u4e2a\u522b\u8d70\uff0c\u65e5\u7ecf225\u6307\u6570\u73b0\u65f6\u62a538841\u70b9\uff0c\u534728\u70b9\u62160.07%\u3002\u5357\u97e9\u7efc\u5408\u6307\u6570\u73b0\u65f6\u62a52411\u70b9\uff0c\u8dcc24\u70b9\u62161.02%\u3002\u7f8e\u8054\u50a8\u6682\u7f13\u51cf\u606f\u62d6\u7d2f\uff0c\u4e2d\u6e2f\u80a1\u5e02\u504f\u5f31\u3002<br/><br/>\u5e02\u573a\u7126\u70b9\uff1a\u6b4c\u793c\u5236\u836f-B(01672)<br/><br/>\u5bf9\u4e8e\u533b\u836f\u677f\u5757\uff0c\u533b\u836f\u521b\u65b0\u662f\u533b\u836f\u589e\u957f\u7684\u6838\u5fc3\u52a8\u529b\u3002\u6b64\u5916\uff0c\u5728\u300c\u533b\u4fdd+\u5546\u4fdd\u300d\u6a21\u5f0f\u4e0d\u65ad\u63a8\u8fdb\u3001\u653f\u7b56\u652f\u6301\u7b49\u56e0\u7d20\u9a71\u52a8\u4e0b\uff0c\u884c\u4e1a\u89c4\u6a21\u6709\u671b\u8fdb\u4e00\u6b65\u6269\u5927\u3002\u52a0\u4e4b\u968f\u7740\u7f8e\u8054\u50a8\u5f00\u542f\u964d\u606f\u5468\u671f\uff0c\u53e0\u52a0AH\u9ad8\u6ea2\u4ef7\u7387\u4e0b\u6e2f\u80a1\u6027\u4ef7\u6bd4\u51f8\u663e\uff0c\u6e2f\u80a1\u6d41\u52a8\u6027\u8d8b\u4e8e\u6539\u5584\u3002\u770b\u597d\u6b4c\u793c\u5236\u836f-B\u516c\u5e03\uff0c\u540c\u7c7b\u9996\u521b\u6cbb\u7597\u80a5\u80d6\u75c7\u7684\u51cf\u91cd\u4e0d\u51cf\u808c\u5019\u9009\u836f\u7269ASC47\u4e0e\u53f8\u7f8e\u683c\u9c81\u80bd\u8054\u5408\u7528\u836f\u5728\u996e\u98df\u8bf1\u5bfc\u80a5\u80d6(DIO)\u5c0f\u9f20\u6a21\u578b\u7814\u7a76\u4e2d\u663e\u793a\u4ee4\u4eba\u9f13\u821e\u7684\u7597\u6548\u3002ASC47\u662f\u6b4c\u793c\u81ea\u4e3b\u7814\u53d1\u7684\u8102\u80aa\u9776\u5411\uff0c\u5177\u6709\u72ec\u7279\u7684\u5dee\u5f02\u5316\u7279\u6027\uff0c\u80fd\u591f\u9776\u5411\u8102\u80aa\uff0c\u4ece\u800c\u5728\u8102\u80aa\u7ec4\u7ec7\u4e2d\u4ea7\u751f\u5242\u91cf\u4f9d\u8d56\u6027\u7684\u9ad8\u836f\u7269\u6d53\u5ea6\u3002ASC47\u5f53\u524d\u6b63\u5728\u6fb3\u6d32\u8fdb\u884c\u80a5\u80d6\u75c7\u60a3\u8005\u4e34\u5e8a\u8bd5\u9a8c\uff0cIIa\u671f\u7814\u7a76\u9876\u7ebf\u6570\u636e\u9884\u8ba1\u5c06\u4e8e2025\u5e74\u7b2c\u4e8c\u5b63\u5ea6\u516c\u5e03\u3002\u672a\u6765\u6210\u529f\u63a8\u51fa\u5e02\u573a\u53ca\u5927\u89c4\u6a21\u91cf\u4ea7\u5316\uff0c\u76f8\u4fe1\u80fd\u5f88\u597d\u7684\u5e2e\u52a9\u96c6\u56e2\u63d0\u5347\u5229\u6da6\u3002\u76ee\u6807\u4ef7$4.2\uff0c\u6b62\u8680\u4ef7$2.2\u3002<br/><br/>(\u7b14\u8005\u4e3a\u8bc1\u76d1\u4f1a\u6301\u724c\u4eba\u58eb\u53ca\u7b14\u8005\u672a\u6301\u6709\u4e0a\u8ff0\u80a1\u4efd)</p><p>\u4f5c\u8005\uff1a\u9999\u6e2f\u80a1\u7968\u5206\u6790\u5e08\u534f\u4f1a\u4e3b\u5e2d\u9093\u58f0\u5174\u535a\u58eb</p>", "link": "https://sky.szfiu.com/info/hk/details/261256937", "pub_date": "2024-12-20 09:36:46"}, {"id": 261257060, "title": "\u6b4c\u793c\u5236\u836f(01672)\u76d8\u521d\u5347\u903e5% ASC47\u4e0e\u53f8\u7f8e\u683c\u9c81\u80bd\u8054\u5408\u7528\u836f\u51cf\u91cd\u8868\u73b0\u79ef\u6781", "description": "<p>\u91d1\u543e\u8d22\u8baf  | \u6b4c\u793c\u5236\u836f(01672)\u76d8\u521d\u8d70\u9ad8\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da85.69%\uff0c\u62a52.6\u6e2f\u5143\uff0c\u6210\u4ea4\u989d60.08\u4e07\u6e2f\u5143\u3002</p><p>\u8463\u4e8b\u4f1a\u8fd1\u65e5\u5ba3\u5e03\uff0c\u540c\u7c7b\u9996\u521b\u6cbb\u7597\u80a5\u80d6\u75c7\u7684\u51cf\u91cd\u4e0d\u51cf\u808c\u5019\u9009\u836f\u7269ASC47\u4e0e\u53f8\u7f8e\u683c\u9c81\u80bd\u8054\u5408\u7528\u836f\u5728\u996e\u98df\u8bf1\u5bfc\u80a5\u80d6(DIO)\u5c0f\u9f20\u6a21\u578b\u7814\u7a76\u4e2d\u663e\u793a\u51fa\u4ee4\u4eba\u9f13\u821e\u7684\u7597\u6548\u3002ASC47\u662f\u6b4c\u793c\u81ea\u4e3b\u7814\u53d1\u7684\u8102\u80aa\u9776\u5411\u3001\u6bcf\u6708\u4e00\u6b21\u76ae\u4e0b\u6ce8\u5c04\u7684\u7532\u72b6\u817a\u6fc0\u7d20\u53d7\u4f53\u03b2(THR\u03b2)\u9009\u62e9\u6027\u5c0f\u5206\u5b50\u6fc0\u52a8\u5242\u3002ASC47\u5177\u6709\u72ec\u7279\u7684\u5dee\u5f02\u5316\u7279\u6027\uff0c\u80fd\u591f\u9776\u5411\u8102\u80aa\uff0c\u4ece\u800c\u5728\u8102\u80aa\u7ec4\u7ec7\u4e2d\u4ea7\u751f\u5242\u91cf\u4f9d\u8d56\u6027\u7684\u9ad8\u836f\u7269\u6d53\u5ea6\u3002</p><p>\u5728\u6fb3\u5927\u5229\u4e9a\u8fdb\u884c\u7684\u4f4e\u5bc6\u5ea6\u8102\u86cb\u767d\u80c6\u56fa\u9187(LDL-C)\u504f\u9ad8\u53d7\u8bd5\u8005I\u671f\u5355\u5242\u91cf\u9012\u589e(SAD)\u7814\u7a76(NCT06427590)\u7684\u671f\u4e2d\u6570\u636e\u663e\u793a\uff0c\u76ae\u4e0b\u6ce8\u5c04ASC47\u7684\u534a\u8870\u671f\u4e3a21\u5929\u3002\u6b64\u5916\uff0cASC47\u663e\u793a\u51fa\u4e86\u826f\u597d\u7684\u8010\u53d7\u6027\uff0c\u5f53\u524d\u5242\u91cf\u5df2\u9012\u589e\u81f390mg\uff0c\u65e0\u4e25\u91cd\u4e0d\u826f\u4e8b\u4ef6(SAE)\u53d1\u751f\uff0c\u4e5f\u672a\u53d1\u751f\u56e0\u4e0d\u826f\u4e8b\u4ef6(AE)\u800c\u5bfc\u81f4\u7684\u505c\u836f\u3002\u5927\u591a\u6570AE\u4e3a\u8f7b\u5ea6(1\u7ea7)\u3002\u6ca1\u6709\u62a5\u544a\u80c3\u80a0\u9053\u548c\u5fc3\u810fAE\uff0c\u6ca1\u6709\u62a5\u544a\u809d\u9176\u5f02\u5e38(\u94fe\u63a5)\u3002\u66f4\u9ad8\u5242\u91cf\u7684\u7814\u7a76\u4ecd\u5728\u8fdb\u884c\u4e2d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/261257060", "pub_date": "2024-12-20 09:39:58"}]}