1a\u5177\u4f53\u653f\u7b56\u843d\u5b9e", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u80a1\u5468\u4e00\u8868\u73b0\u5411\u4e0b\uff0c\u5927\u5e02\u8fde\u5347\u591a\u65e5\u540e\u7531\u9ad8\u4f4d\u56de\u843d\uff0c\u4e09\u5927\u6307\u6570\u5747\u5f55\u5f97\u8dcc\u5e45\u6536\u5e02\u3002\u7f8e\u5143\u53cd\u8986\u9760\u7a33\uff0c\u7f8e\u56fd\u5341\u5e74\u671f\u503a\u606f\u56de\u5347\u81f34.19\u5398\u6c34\u5e73\uff0c\u91d1\u4ef7\u8868\u73b0\u5411\u597d\uff0c\u6cb9\u4ef7\u8d70\u52bf\u4ea6\u53d7\u5730\u7f18\u653f\u5c40\u6d88\u606f\u652f\u6301\u3002\u6e2f\u80a1\u9884\u6258\u8bc1\u5238\u666e\u904d\u4e0a\u5347\uff0c\u9884\u6599\u5927\u5e02\u65e9\u6bb5\u8ddf\u968f\u5927\u5e45\u9ad8\u5f00\u3002\u5185\u5730\u80a1\u5e02\u6628\u65e5\u9760\u7a33\uff0c\u6caa\u7efc\u6307\u9ad8\u5f00\u4f4e\u8d70\uff0c\u6536\u5e02\u5fae\u8dcc1\u70b9\uff0c\u6caa\u6df1\u4e24\u5e02\u6210\u4ea4\u989d\u4ea6\u7565\u4e3a\u7f29\u51cf\u3002\u6e2f\u80a1\u8d70\u52bf\u663e\u7740\u56de\u5347\uff0c\u5927\u5e02\u4f4e\u5f00\u540e\u53cd\u8986\u5411\u4e0a\uff0c\u4e2d\u592e\u653f\u6cbb\u5c40\u4f1a\u8bae\u8868\u793a\u5c06\u79ef\u6781\u5b9e\u65bd\u8d22\u653f\u653f\u7b56\u53ca\u9002\u5ea6\u653e\u5bbd\u8d27\u5e01\u653f\u7b56\uff0c\u7a33\u4f4f\u697c\u5e02\u53ca\u80a1\u5e02\u8868\u73b0\uff0c\u523a\u6fc0\u5927\u5e02\u6389\u5934\u5411\u4e0a\uff0c\u91cd\u4e0a20,000\u70b9\u6c34\u5e73\uff0c\u6574\u4f53\u6210\u4ea4\u4ea6\u6025\u589e\u81f32,000\u4ebf\u5143\u4ee5\u4e0a\u3002\u5e02\u573a\u61a7\u61ac\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\u5c06\u6709\u66f4\u591a\u5177\u4f53\u653f\u7b56\u843d\u5b9e\uff0c\u6307\u6570\u6709\u671b\u8fdb\u4e00\u6b65\u6311\u621821,500\u70b9\u963b\u529b\uff0c\u4e0b\u65b9\u652f\u6301\u5728 20,500\u70b9\u6c34\u5e73\u3002<br/><br/>\u884c\u4e1a\u6d88\u606f<br/>\u8d1d\u58f3(2423)\u65e9\u524d\u516c\u5e03\u7b2c\u4e09\u5b63\u7ecf\u8c03\u6574\u51c0\u5229\u6da617.85\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u4e0b\u8dcc16.8%\u3002\u671f\u5185\u51c0\u6536\u5165225.85\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u4e0a\u534