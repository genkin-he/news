9\u80cc\u540e\u6709\u4e00\u4e2a\u975e\u5e38\u5177\u4f53\u7684\u76d1\u7ba1\u6d41\u7a0b\uff0c\u6211\u4eec\u9700\u8981\u8d70\u5b8c\u8fd9\u4e2a\u6d41\u7a0b\uff0c\u4e5f\u5e0c\u671b\u5c3d\u5feb\u5c06\u5b83\u5e26\u7ed9\u4e2d\u56fd\u6d88\u8d39\u8005\u3002\u201d</p>", "link": "https://sky.szfiu.com/info/hk/details/255598180", "pub_date": "2024-10-23 21:24:56"}, {"id": 255597067, "title": "Meta Platforms(META)\u6210\u529f\u9a73\u56de\u4e00\u9879\u6307\u63a7\u5176\u513f\u7ae5\u4fdd\u62a4\u4fe1\u606f\u62ab\u9732\u4e0d\u8db3\u7684\u8bc9\u8bbc", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u5a92\u4f53\uff0cMeta Platforms(META)\u6210\u529f\u9a73\u56de\u4e86\u4e00\u9879\u8bc9\u8bbc\uff0c\u8be5\u8bc9\u8bbc\u58f0\u79f0Meta\u5728\u4ee3\u7406\u58f0\u660e\u4e2d\u5c31\u6709\u80fd\u529b\u786e\u4fdd\u4f7f\u7528Facebook\u548cInstagram\u7684\u513f\u7ae5\u7528\u6237\u7684\u5b89\u5168\u8fd9\u4e00\u4e8b\u9879\u8bef\u5bfc\u4e86\u80a1\u4e1c\u3002\u5728\u5468\u4e8c\u7684\u4e00\u9879\u88c1\u51b3\u4e2d\uff0c\u65e7\u91d1\u5c71\u7f8e\u56fd\u5730\u533a\u6cd5\u5b98Charles Breyer\u8868\u793a\uff0c\u539f\u544aMatt Eisner\u672a\u80fd\u8bc1\u660e\u80a1\u4e1c\u56e0Meta\u6240\u8c13\u7684\u4fe1\u606f\u62ab\u9732\u4e0d\u8db3\u800c\u906d\u53d7\u7ecf\u6d4e\u635f\u5931\u3002\u4ed6\u8fd8\u8868\u793a\uff0c\u8054\u90a6\u8bc1\u5238\u6cd5\u5e76\u672a\u8981\u6c42Meta\u8be6\u7ec6\u8bf4\u660e\u5176\u5e73\u53f0\u4e0a\u8272\u60c5\u5185\u5bb9\u548c\u513f\u7ae5\u6027\u5265\u524a\u7684\u4e25\u91cd\u7a0b\u5ea6\uff0c\u6216\u5bf9\u5176\u51b3\u5b9a\u4e0d\u91c7\u7528\u7684\u6240\u6709\u513f\u7ae5\u4fdd\u62a4\u7b56\u7565\u505a\u51fa\u8981\u6c42\u3002\u9664\u6b64\u4e4b\u5916\uff0cMeta\u4ecd\u9762\u4e34\u6570\u5341\u540d\u5dde\u68c0\u5bdf\u957f\u7684\u8bc9\u8bbc\uff0c\u6307\u63a7\u8be5\u516c\u53f8\u8ba9\u513f\u7ae5\u6c89\u8ff7\u4e8e\u793e\u4ea4\u5e94\u7528\uff0c\u540c\u65f6\u6de1\u5316\u8fd9\u4e00\u98ce\u9669\u3002Meta\u8fd8\u9762\u4e34\u6570\u767e\u8d77\u513f\u7ae5\u3001\u4ed6\u4eec\u7684\u7236\u6bcd\u548c\u5b66\u533a\u56e0\u793e\u4ea4\u5a92\u4f53\u6210\u763e\u800c\u63d0\u8d77\u7684\u8bc9\u8bbc\u3002TikTok\u3001Snapchat\u548c\u5176\u4ed6\u5e94\u7528\u7a0b\u5e8f\u7684\u8fd0\u8425\u5546\u4e5f\u9762\u4e34\u7740\u6570\u767e\u8d77\u7c7b\u4f3c\u7684\u8bc9\u8bbc\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255597067", "pub_date": "2024-10-23 21:17:20"}, {"id": 255596435, "title": "\u7279\u65af\u62c9(TSLA)\u9996\u6279\u5165\u5217 \u4e2d\u56fd\u6b63\u5f0f\u542f\u52a8\u589e\u503c\u7535\u4fe1\u4e1a\u52a1\u5bf9\u5916\u5f00\u653e\u8bd5\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u5a92\u4f53\uff0c\u4ece\u5de5\u4e1a\u548c\u4fe1\u606f\u5316\u90e8\u83b7\u6089\uff0c10\u670823\u65e5\u8d77\uff0c\u5317\u4eac\u3001\u4e0a\u6d77\u3001\u6d77\u5357\u3001\u6df1\u57334\u5730\u6b63\u5f0f\u542f\u52a8\u589e\u503c\u7535\u4fe1\u4e1a\u52a1\u6269\u5927\u5bf9\u5916\u5f00\u653e\u8bd5\u70b9\u5de5\u4f5c\u3002\u5728\u83b7\u6279\u5f00\u5c55\u8bd5\u70b9\u7684\u5730\u533a\uff0c\u5916\u8d44\u4f01\u4e1a\u53ef\u72ec\u8d44\u7ecf\u8425\u4e92\u8054\u7f51\u6570\u636e\u4e2d\u5fc3\u7b49\u589e\u503c\u7535\u4fe1\u4e1a\u52a1\u3002\u4e0a\u6d77\u5e02\u7ecf\u6d4e\u548c\u4fe1\u606f\u5316\u59d4\u5458\u4f1a\u526f\u4e3b\u4efb\u5f20\u5b8f\u97ec\u5728\u63a5\u53d7\u91c7\u8bbf\u65f6\u8868\u793a\uff0c\u4e0a\u6d77\u8bd5\u70b9\u4e2d\uff0c\u76ee\u524d\u5df2\u9884\u586b\u7533\u62a5\u8868\u683c\u7684\u4f01\u4e1a\u5305\u62ec\u7279\u65af\u62c9\u3001\u6258\u514b\u3001\u6c47\u4e30\u91d1\u79d1\u3001\u897f\u95e8\u5b50\u6570\u5b57\u533b\u7597\u79d1\u6280\u3001\u730e\u8058\u3001\u52e4\u8fbe\u777f\u3001\u4ebf\u5229\u4e92\u8054\u3001Unity\u3001\u666e\u6d1b\u65af\u7b4910\u5bb6\u5916\u8d44\u4f01\u4e1a\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255596435", "pub_date": "2024-10-23 21:13:44"}, {"id": 255592510, "title": "\u9ea6\u5f53\u52b3(MCD)\u76d8\u524d\u8dcc\u903e7% \u7f8e\u56fd49\u4eba\u56e0\u98df\u7528\u201c\u56db\u5206\u4e4b\u4e00\u78c5\u6c49\u5821\u5305\u201d\u60a3\u75c5", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9ea6\u5f53\u52b3(MCD)\u76d8\u524d\u8dcc\u903e7%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a5293\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u636e\u5a92\u4f53\uff0c\u5f53\u5730\u65f6\u95f422\u65e5\uff0c\u7f8e\u56fd\u75be\u75c5\u63a7\u5236\u4e0e\u9884\u9632\u4e2d\u5fc3(CDC)\u53d1\u5e03\u58f0\u660e\u8b66\u544a\u79f0\uff0c\u9ea6\u5f53\u52b3\u7684\u201c\u56db\u5206\u4e4b\u4e00\u78c5\u6c49\u5821\u5305\u201d\u5728\u7f8e\u56fd\u591a\u5dde\u5f15\u53d1\u4e0e\u5927\u80a0\u6746\u83cc\u76f8\u5173\u7684\u75be\u75c5\u3002\u5f53\u5929\uff0c\u7f8e\u56fd\u75be\u75c5\u63a7\u5236\u4e0e\u9884\u9632\u4e2d\u5fc3\u5728\u4e00\u4efd\u62a5\u544a\u4e2d\u8868\u793a\uff0c\u7f8e\u56fd\u76ee\u524d\u5df2\u670949\u4eba\u56e0\u98df\u7528\u201c\u56db\u5206\u4e4b\u4e00\u78c5\u6c49\u5821\u5305\u201d\u800c\u60a3\u75c5\uff0c\u5176\u4e2d10\u4eba\u4f4f\u9662\uff0c\u53e6\u67091\u4eba\u6b7b\u4ea1\u3002\u5f53\u524d\uff0cCDC\u5df2\u5bf9\u6b64\u5c55\u5f00\u8c03\u67e5\u3002CDC\u8fd8\u8868\u793a\uff0c\u8fd9\u4e9b\u60a3\u8005\u62a5\u544a\u5728\u53d1\u75c5\u524d\u66fe\u5728\u9ea6\u5f53\u52b3\u7528\u9910\uff0c\u7279\u522b\u63d0\u5230\u5403\u4e86\u201c\u56db\u5206\u4e4b\u4e00\u78c5\u6c49\u5821\u5305\u201d\u3002<br/><br/>\u6b64\u5916\uff0c\u5728\u79d1\u7f57\u62c9\u591a\u5dde\u548c\u5185\u5e03\u62c9\u65af\u52a0\u5dde\uff0c\u4fc4\u52d2\u5188\u5dde\u3001\u5a01\u65af\u5eb7\u661f\u5dde\u4e5f\u62a5\u544a\u4e86\u75c5\u4f8b\u3002CDC\u8868\u793a\uff0c\u98df\u54c1\u53d7\u6c61\u67d3\u7684\u6210\u5206\u5c1a\u672a\u786e\u5b9a\u3002\u9ea6\u5f53\u52b3\u8868\u793a\uff0c\u521d\u6b65\u8c03\u67e5\u53d1\u73b0\u201c\u90e8\u5206\u60a3\u8005\u60a3\u75c5\u201d\u4e0e\u4e00\u5bb6\u4f9b\u5e94\u5546\u63d0\u4f9b\u7684\u6d0b\u8471\u4e1d\u6709\u5173\uff0c\u8be5\u4f9b\u5e94\u5546\u4e3a\u9ea6\u5f53\u52b3\u4e09\u4e2a\u914d\u9001\u4e2d\u5fc3\u63d0\u4f9b\u670d\u52a1\u3002\u9ea6\u5f53\u52b3\u8fd8\u79f0\uff0c\u5df2\u7ecf\u4e34\u65f6\u6027\u5730\u64a4\u8d70\u4e0e\u4e8b\u6545\u76f8\u5173\u7684\u7591\u4f3c\u539f\u6599\uff0c\u6d89\u4e8b\u5546\u54c1\u5728\u67d0\u4e9b\u5dde\u4e0d\u4f1a\u4e0a\u67b6\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255592510", "pub_date": "2024-10-23 20:48:04"}, {"id": 255588922, "title": "\u6781\u6c2a(ZK)\u76d8\u524d\u6da8\u8d853% \u6781\u6c2aMIX\u4ece10%\u5145\u81f380%\u7684\u7535\u91cf\u4ec5\u970010.5\u5206\u949f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6781\u6c2a(ZK)\u76d8\u524d\u6da8\u8d853%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a524.05\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u5728\u4eca\u5929\u7684\u53d1\u5e03\u4f1a\u4e0a\uff0c\u6781\u6c2a\u6c7d\u8f66\u9996\u6b21\u62ab\u9732\u4e86\u6781\u6c2aMIX\u7684\u7eed\u822a\u80fd\u529b\u3002\u8fd9\u6b3e\u65b0\u8f66\u914d\u5907\u4e86\u7b2c\u4e8c\u4ee3\u91d1\u7816\u7535\u6c60\u548c\u9e92\u9e9f\u7535\u6c60\uff0c\u5176\u4e2d76\u5ea6\u7b2c\u4e8c\u4ee3\u91d1\u7816\u7535\u6c60\u80fd\u591f\u63d0\u4f9b550\u516c\u91cc\u7684\u7eed\u822a\u3002\u5728\u5145\u7535\u901f\u5ea6\u4e0a\uff0c\u8be5\u7535\u6c60\u652f\u63015.5C\u7684\u8d85\u7ea7\u5feb\u5145\uff0c\u4ece10%\u5145\u81f380%\u7684\u7535\u91cf\u4ec5\u970010.5\u5206\u949f\uff0c\u5168\u7403\u6700\u5feb\u3002<br/><br/>\u66f4\u5f15\u4eba\u6ce8\u76ee\u7684\u662f102\u5ea6\u7684\u9e92\u9e9f\u7535\u6c60\uff0c\u5b83\u80fd\u591f\u5b9e\u73b0\u8d85\u8fc7700\u516c\u91cc\u7684\u6700\u5927\u7eed\u822a\u91cc\u7a0b\uff0c\u800c15\u5206\u949f\u7684\u5145\u7535\u65f6\u95f4\u5373\u53ef\u589e\u52a0500\u516c\u91cc\u7684\u7eed\u822a\u3002<br/><br/>\u6b64\u5916\uff0c\u6781\u6c2aCEO\u5b89\u806a\u6167\u5728\u6781\u6c2aMIX\u53d1\u5e03\u4f1a\u4e0a\u79f0\uff0c\u6781\u6c2a\u8054\u5408WAYMO\u6253\u9020\u7684\u65e0\u4eba\u9a7e\u9a76\u51fa\u884c\u673a\u5668\u4eba\u5c06\u662f\u5168\u4e16\u754c\u9996\u6b3e\u5927\u89c4\u6a21\u91cf\u4ea7\u4ea4\u4ed8\u7684\u539f\u751f\u65e0\u4eba\u9a7e\u9a76\u6c7d\u8f66\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255588922", "pub_date": "2024-10-23 20:25:02"}]}