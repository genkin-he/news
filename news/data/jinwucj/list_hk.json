u5e7410\u670810\u65e5\uff0c\u6e2f\u5143\u62c6\u606f\u591a\u6570\u4e0a\u6da8\uff0c\u9694\u591c\u62c6\u606f\u6da8\u81f34.60893\u5398\uff1b1\u661f\u671f\u62c6\u606f\u6da8\u81f34.63464\u5398\uff1b2\u661f\u671f\u62c6\u606f\u6da8\u81f34.56446\u5398\u3002<br/><br/>\u53e6\u5916\uff0c\u4e0e\u697c\u6309\u76f8\u5173\u76841\u4e2a\u6708\u62c6\u606f\u8dcc\u81f34.41524\u5398\uff1b\u53cd\u6620\u94f6\u884c\u8d44\u91d1\u6210\u672c\u76843\u4e2a\u6708\u62c6\u606f\u6da8\u81f34.36119\u5398\u3002<br/><br/>\u957f\u606f\u65b9\u9762\uff0c6\u4e2a\u6708\u62c6\u606f\u6da8\u81f34.18601\u5398\uff1b1\u5e74\u671f\u62c6\u606f\u6da8\u81f34.08601\u5398\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254506889", "pub_date": "2024-10-10 11:33:10"}, {"id": 254506888, "title": "\u3010AH\u4e92\u52a8\u3011A\u80a1\u4e09\u5927\u6307\u6570\u65e9\u76d8\u5f3a\u52bf \u6caa\u6307\u534a\u65e5\u6da82.95% \u98ce\u7535\u8bbe\u5907\u3001\u8239\u8236\u5236\u9020\u7b49\u677f\u5757\u6da8\u5e45\u5c45\u524d", "description": "<p>\u91d1\u543e\u8d22\u8baf | A\u80a1\u4e09\u5927\u6307\u6570\u65e9\u76d8\u5f3a\u52bf\uff0c\u622a\u81f3\u5348\u95f4\u6536\u76d8\uff0c\u6caa\u6307\u6da82.95%\uff0c\u6df1\u8bc1\u6210\u6307\u6da81.61%\uff0c\u521b\u4e1a\u677f\u6307\u6da80.45%\u3002<br/><br/>\u677f\u5757\u65b9\u9762\uff0c\u98ce\u7535\u8bbe\u5907\u3001\u8239\u8236\u5236\u9020\u3001\u7164\u70ad\u884c\u4e1a\u7b49\u677f\u5757\u6da8\u5e45\u5c45\u524d\uff1b\u8bc1\u5238\u3001\u591a\u5143\u91d1\u878d\u3001\u534a\u5bfc\u4f53\u7b49\u677f\u5757\u8dcc\u5e45\u5c45\u524d\u3002<br/><br/>\u4e2d\u4fe1\u8bc1\u5238\u6307\u51fa\uff0c\u81ea9\u670824\u65e5\u548c26\u65e5\u91cd\u5927\u653f\u7b56\u53d1\u5e03\u4ee5\u6765\uff0cA\u80a1\u83b7\u5f97\u8f83\u5927\u4f53\u91cf\u8d44\u91d1\u6d41\u5165\u3002\u5f53\u524d\u5206\u6790\u5e08\u9884\u671f\u603b\u4f53\u7a33\u5b9a\uff0c\u7ed3\u6784\u4e0a\u6709\u6240\u8f6c\u597d\uff0c\u56fd\u5e86\u8282\u524d\u5168\u5e02\u573a2024\u5e74\u4e00\u81f4\u9884\u671f\u51c0\u5229\u6da6\u603b\u989d\u5468\u5ea6\u73af\u6bd4\u53d8\u5316\u7387\u4e3a-0.1%\uff0c\u964d\u5e45\u5927\u5e45\u6536\u7a84\uff0c\u5730\u4ea7\u884c\u4e1a\u5168\u5e74\u4e00\u81f4\u9884\u671f\u51c0\u5229\u6da6\u663e\u8457\u6539\u5584\u3002\u590d\u76d82008\u5e74\u4ee5\u6765\u56db\u8f6e\u91cd\u5927\u653f\u7b56\u5bf9\u5e95\u90e8\u62d0\u70b9\u7684\u50ac\u5316\u8fc7\u7a0b\uff0c\u76ee\u524d\u5e02\u573a\u4ecd\u5904\u4e8e\u7531\u60c5\u7eea\u4e3b\u5bfc\u7684\u53cd\u5f39\u7b2c\u4e00\u9636\u6bb5\uff0c\u53cd\u8f6c\u98ce\u683c\u8868\u73b0\u5927\u5e45\u9886\u5148\uff0c\u4f46\u4e2d\u957f\u671f\u4ecd\u9700\u5173\u6ce8\u5177\u4f53\u7684\u653f\u7b56\u843d\u5b9e\u7684\u65b9\u5411\u4ee5\u53ca\u6548\u679c\uff0c\u5efa\u8bae\u5173\u6ce8\u57fa\u7840\u8bbe\u65bd\u5efa\u8bbe\u3001\u623f\u5730\u4ea7\u53d1\u5c55\u65b0\u6a21\u5f0f\u3001\u6269\u5927\u5185\u9700\u7b49\u653f\u7b56\u91cd\u70b9\u652f\u6301\u9886\u57df\u76f8\u5173\u884c\u4e1a\uff0c\u6b64\u5916\u5982\u5546\u8d38\u96f6\u552e\u3001\u7eba\u7ec7\u670d\u88c5\u3001\u8f7b\u529f\u5236\u9020\u7b49\u524d\u671f\u8dcc\u5e45\u8f83\u9ad8\uff0c\u4f46\u5728\u672c\u8f6e\u53cd\u5f39\u4e2d\u6da8\u5e45\u8f83\u5c11\u7684\u884c\u4e1a\u4e5f\u503c\u5f97\u5173\u6ce8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254506888", "pub_date": "2024-10-10 11:33:28"}, {"id": 254506396, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u534e\u6e90\u8bc1\u5238\u9996\u4e88\u65b0\u5929\u7eff\u8272\u80fd\u6e90(00956)\u4e70\u5165\u8bc4\u7ea7  \u6307\u5176\u4f30\u503c\u6c34\u5e73\u6709\u671b\u968f\u677f\u5757\u5feb\u901f\u4fee\u590d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u534e\u6e90\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u7ecf\u8fc7\u591a\u5e74\u53d1\u5c55\uff0c\u65b0\u5929\u7eff\u8272\u80fd\u6e90(00956)\u5f62\u6210\u4e86\u4ee5\u98ce\u7535\u4e3a\u4e3b\u3001\u5929\u7136\u6c14\u4e3a\u8f85\u7684\u4e3b\u8981\u76c8\u5229\u683c\u5c40\uff1a2023\u5e74\u5b9e\u73b0\u8425\u6536202.82\u4ebf\u5143\uff0c\u5f52\u6bcd\u51c0\u5229\u6da622.07\u4ebf\u5143\uff0c\u98ce\u7535\u548c\u5149\u4f0f\u5206\u90e8\u8d21\u732e\u7ea62/3\u5f52\u6bcd\u51c0\u5229\u6da6\uff0c\u5929\u7136\u6c14\u5206\u90e8\u5bf9\u5f52\u6bcd\u51c0\u5229\u6da6\u8d21\u732e\u7ea626%\u3002<br/><br/>\u8be5\u884c\u6307\u51fa\uff0c\u8fd1\u5e74\u6765\u968f\u7740\u5bf9\u4e0b\u6e38\u57ce\u71c3\u9879\u76ee\u7684\u5e76\u8d2d\uff0c\u516c\u53f8\u96f6\u552e\u6c14\u91cf\u5360\u6bd4\u9010\u6e10\u63d0\u5347\uff0c\u5e26\u52a8\u603b\u4f53\u552e\u6c14\u8d2d\u9500\u4ef7\u5dee\u6709\u6240\u63d0\u9ad8\u3002\u5510\u5c71LNG\u9879\u76ee\u7b2c\u4e00\u9636\u6bb5\u53ca\u5916\u8f93\u7ba1\u7ebf\u4e8e2023\u5e74\u5efa\u6210\u6295\u4ea7\uff0cLNG\u6210\u4e3a\u5f53\u524d\u552e\u6c14\u589e\u91cf\u4e3b\u8981\u6765\u6e90\uff0c2024H1\u552e\u6c14\u91cf30.17\u4ebf\u7acb\u65b9\u7c73\uff0c\u5176\u4e2dLNG\u552e\u6c14\u91cf6.91\u4ebf\u7acb\u65b9\u7c73\u3001\u8d85\u8fc72023\u5168\u5e74\uff0c2024\u5168\u5e74\u552e\u6c14\u91cf\u6709\u671b\u589e\u957f25%\u4ee5\u4e0a\uff1b\u5728\u56fd\u9645\u5929\u7136\u6c14\u4ef7\u683c\u56de\u5f52\u5408\u7406\u533a\u95f4\u60c5\u51b5\u4e0b\uff0c\u5510\u5c71LNG\u9879\u76ee\u4ea6\u6709\u52a9\u4e8e\u63d0\u5347\u516c\u53f8\u6c14\u6e90\u6210\u672c\u7ba1\u63a7\u6c34\u5e73\u3002\u6b64\u5916\u6cb3\u5317\u987a\u4ef7\u5de5\u4f5c\u5df2\u4e8e2023\u5e74\u5168\u9762\u843d\u5730\uff0c\u516c\u53f8\u96f6\u552e\u6c14\u91cf\u6bdb\u5dee\u6709\u671b\u56de\u5347\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u7acb\u8db3\u5f53\u524d\u65f6\u70b9\uff0c\u5728\u6e2f\u80a1\u6d41\u52a8\u6027\u663e\u8457\u4fee\u590d\u3001\u5e02\u573a\u98ce\u9669\u504f\u597d\u56de\u5f52\u7684\u5927\u80cc\u666f\u4e0b\uff0c\u7eff\u7535\u677f\u5757\u6574\u4f53\u4f30\u503c\u6c34\u5e73\u6709\u671b\u62ac\u5347\uff1b\u516c\u53f8\u4f5c\u4e3a\u677f\u5757\u5185\u8d44\u4ea7\u8d28\u91cf\u8f83\u4f18\u6807\u7684\uff0c\u4f30\u503c\u6c34\u5e73\u6709\u671b\u5feb\u901f\u4fee\u590d\u3002<br/><br/>\u8be5\u884c\u9884\u6d4b\u516c\u53f82024-2026\u5e74\u5f52\u6bcd\u51c0\u5229\u6da6\u5206\u522b\u4e3a23.8\u300130.7\u300134.1\u4ebf\u5143\uff0c\u5206\u522b\u540c\u6bd4\u589e\u957f7.8%\u300129.0%\u300111.1%\u3002\u4fdd\u5b88\u8003\u8651\u4e0b\u6682\u4e0d\u7ed9\u5176\u4ed6\u4e1a\u52a1\u4f30\u503c\uff0c\u5219\u516c\u53f8\u5185\u5728\u4ef7\u503c\u7ea6\u4e3a274\u4ebf\u6e2f\u5143\uff0c\u8f83\u5f53\u524d\u5e02\u503c\u4ecd\u6709\u7ea649%\u4e0a\u6da8\u7a7a\u95f4\u3002\u9996\u6b21\u8986\u76d6\uff0c\u7ed9\u4e88\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254506396", "pub_date": "2024-10-10 11:27:26"}, {"id": 254505916, "title": "\u6e2f\u80a1\u5927\u76d8\u5348\u524d\u6da8\u5e45\u6269\u5927 \u6052\u6307\u6da84% \u9f99\u6e56\u96c6\u56e2(00960)\u6da811.16%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6e2f\u80a1\u5927\u76d8\u5348\u524d\u6da8\u5e45\u6269\u5927\uff0c\u6052\u6307\u6da84%\uff0c\u6052\u751f\u79d1\u6280\u6307\u6570\u6da83.55%\uff0c\u56fd\u4f01\u6307\u6570\u6da84.58%\u3002</p><p>\u9f99\u6e56\u96c6\u56e2(00960)\u6da811.16%\u9886\u5347\u84dd\u7b79\uff0c\u4e2d\u5347\u63a7\u80a1(00881)\u6da810.82%\uff0c\u5409\u5229\u6c7d\u8f66(00175)\u3001\u6d77\u5e95\u635e(06862)\u6da8\u8d859%\uff0c\u534e\u6da6\u7535\u529b(00836)\u6da88.01%\uff0c\u4e2d\u56fd\u5e73\u5b89(02318)\u6da87.58%\u3002</p><p>\u8d22\u653f\u53f8\u53f8\u957f\u9648\u8302\u6ce2\u8868\u793a\uff0c\u56fd\u5bb6\u4e0a\u6708\u5e95\u516c\u5e03\u652f\u6301\u7ecf\u6d4e\u7684\u63aa\u65bd\u540e\uff0c\u5e02\u573a\u5f55\u5f97\u8f83\u5927\u589e\u957f\uff0c\u4f46\u5f53\u4e2d\u4f1a\u6709\u53cd\u8986\uff0c\u76f8\u4fe1\u56de\u8c03\u540e\u4f1a\u518d\u5f80\u524d\u53d1\u5c55\u3002\u4ed6\u6307\u51fa\uff0c\u56fd\u5bb6\u516c\u5e03\u7684\u63aa\u65bd\uff0c\u7a33\u5b9a\u5927\u5bb6\u5bf9\u5185\u5730\u7ecf\u6d4e\u53d1\u5c55\u524d\u666f\u7684\u9884\u671f\uff0c\u4ea6\u5728\u6d41\u52a8\u6027\u65b9\u9762\u91ca\u51fa\u6e05\u6670\u7684\u8baf\u53f7\uff0c\u4f46\u5177\u4f53\u63aa\u65bd\u7684\u6210\u6548\u9700\u65f6\u5728\u5b9e\u4f53\u7ecf\u6d4e\u53cd\u6620\uff0c\u80a1\u5e02\u77ed\u671f\u5185\u6709\u6ce2\u52a8\u662f\u5728\u6240\u96be\u514d\uff0c\u52a0\u4e0a\u91d1\u878d\u5e02\u573a\u53d7\u5f88\u591a\u56e0\u7d20\u5f71\u54cd\uff0c\u547c\