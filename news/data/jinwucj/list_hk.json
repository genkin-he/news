6216\u5b58\u5728\u77ed\u671f\u83b7\u5229\u4e86\u7ed3\u53ef\u80fd", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u4e2d\u8d44\u5238\u5546\u80a1\u7531\u6da8\u8f6c\u8dcc\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62db\u5546\u8bc1\u5238(06099)\u8dcc5.23%\uff0c\u4e2d\u4fe1\u8bc1\u5238(06030)\u8dcc4.11%\uff0c\u4e2d\u4fe1\u5efa\u6295\u8bc1\u5238(06066)\u8dcc3.5%\uff0c\u5149\u5927\u8bc1\u5238(06178)\u6da83.41%\uff0c\u4e2d\u91d1\u516c\u53f8(03908)\u8dcc2.76%\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u4e2d\u5171\u4e2d\u592e\u653f\u6cbb\u5c4012\u67089\u65e5\u53ec\u5f00\u4f1a\u8bae\uff0c\u5206\u6790\u7814\u7a762025\u5e74\u7ecf\u6d4e\u5de5\u4f5c\u3002\u62db\u5546\u8bc1\u5238\u6307\u51fa\uff0c\u7ee7\u201c\u8d44\u672c\u5e02\u573a\u201d\u4e00\u8bcd\u51fa\u73b0\u5728\u653f\u6cbb\u5c40\u4f1a\u8bae\u901a\u7a3f\u4e2d\uff0c\u672c\u6b21\u653f\u6cbb\u5c40\u4f1a\u8bae\u8fdb\u4e00\u6b65\u660e\u786e\u201c\u7a33\u5b9a\u80a1\u5e02\u201d\uff0c\u8db3\u89c1\u51b3\u7b56\u5c42\u5bf9\u4e8e\u80a1\u5e02\u7684\u9ad8\u5ea6\u91cd\u89c6\uff0c\u4ea6\u53cd\u5e94\u51b3\u7b56\u5c42\u5bf9\u80a1\u5e02\u5728\u7ecf\u6d4e\u793e\u4f1a\u751f\u6d3b\u91cd\u8981\u4f5c\u7528\u7684\u9ad8\u5ea6\u8ba4\u540c\u3002\u6392\u5e8f\u4e0a\u770b\uff0c\u201c\u7a33\u4f4f\u697c\u5e02\u80a1\u5e02\u201d\u8868\u8ff0\u4f4d\u7f6e\u9760\u524d\uff0c\u53cd\u5e94\u51b3\u7b56\u5c42\u5bf9\u4e8e\u80a1\u5e02\u91cd\u89c6\u7a0b\u5ea6\u63d0\u9ad8\uff0c\u201c\u7a33\u4f4f\u201d\u53cd\u5e94\u51b3\u7b56\u5c42\u671f\u5f85\u66f4\u4e3a\u660e\u786e\u3002\u6b64\u5916\uff0c\u4f1a\u8bae\u7279\u522b\u6307\u51fa\u201c\u52a0\u5f3a\u8d85\u5e38\u89c4\u9006\u5468\u671f\u8c03\u8282\u201d\u3001\u201c\u66f4\u52a0\u79ef\u6781\u7684\u8d22\u653f\u653f\u7b56\u548c\u9002\u5ea6\u5bbd\u677e\u7684\u8d27\u5e01\u653f\u7b56\u201d\uff0c\u5c06\u76f4\u63a5\u5f71\u54cd\u80a1\u5e02\u5206\u5b50\u7aef\u548c\u5206\u6bcd\u7aef\u8868\u73b0\u3002\u671f\u5f85\u540e\u7eed\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\u66f4\u591a\u5b9e\u8d28\u6027\u653f\u7b56\u63a5\u6b21\u51fa\u53f0\u3002<br/><br/>\u53d7\u6b64\u5f71\u54cd\uff0c\u6628\u65e5\u6e2f\u80a1\u5c3e\u76d8\u5238\u5546\u80a1\u5168\u7ebf\u4e0a\u626c\uff0c\u62db\u5546\u8bc1\u5238\u6628\u65e5\u6536\u6da813.65%\uff0c\u4e2d\u4fe1\u8bc1\u5238\u6536\u6da87.93%\uff0c\u4e2d\u4fe1\u5efa\u6295\u8bc1\u5238\u6536\u6da86.33%\u3002\u4eca\u65e5\u5238\u5546\u677f\u5757\u5168\u7ebf\u9ad8\u5f00\uff0c\u5176\u4e2d\u62db\u5546\u8bc1\u5238\u9ad8\u5f005.78%\uff0c\u5b58\u5728\u77ed\u671f\u83b7\u5229\u4e86\u7ed3\u53ef\u80fd\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260112375", "pub_date": "2024-12-10 13:50:11"}, {"id": 260112376, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u91ce\u6751\u7ef4\u6301\u4eac\u4e1c\u7269\u6d41(02618)\u201c\u4e70\u5165\u201d\u8bc4\u7ea7 \u6307\u8d2d\u8de8\u8d8a\u901f\u8fd0\u4f59\u4e0b\u6743\u76ca\u4f30\u503c\u5408\u7406", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u91ce\u6751\u53d1\u7814\u62a5\u6307\uff0c\u4eac\u4e1c\u7269\u6d41(02618)\u6536\u8d2d\u8de8\u8d8a\u901f\u8fd0\u4f59\u4e0b\u6743\u76ca\u7684\u4ea4\u6613\u4f30\u503c\u5408\u7406\uff0c\u534f\u8bae\u8bbe\u4e0e\u4e1a\u7ee9\u6302\u94a9\u7684\u5bf9\u4ef7\u8c03\u6574\u673a\u5236\uff0c\u4ee5\u6700\u9ad8\u4ee3\u4ef7\u8ba1\u662f\u6b21\u6536\u8d2d\u8de8\u8d8a\u901f\u8fd0\u7684\u4ea4\u6613\u4f30\u503c\u4e3a\u540e\u8005\u53bb\u5e74\u53ca\u9884\u6d4b\u4eca\u5e74\u5e02\u76c8\u7387\u768412\u500d\u53ca8\u500d\uff0c\u4f4e\u4e8e\u884c\u4e1a\u5e73\u5747\u6c34\u5e73\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0c\u622a\u81f3\u4eca\u5e74\u4e0a\u534a\u5e74\u4eac\u4e1c\u7269\u6d41\u624b\u5934\u51c0\u73b0\u91d1\u8fbe173\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u6709\u80fd\u529b\u652f\u4ed8\u6b64\u6b21\u4ea4\u6613\u4f5c\u4ef7\uff0c\u534f\u8bae\u6240\u8bbe\u7684\u5206\u671f\u4ed8\u6b3e\u65b9\u5f0f\u4ea6\u53ef\u8fdb\u4e00\u6b65\u7ebe\u7f13\u516c\u53f8\u7684\u538b\u529b\u3002\u91ce\u6751\u76f8\u4fe1\u8de8\u8d8a\u901f\u8fd0\u662f\u4e00\u9879\u6709\u4ef7\u503c\u7684\u8d44\u4ea7\uff0c\u9884\u6599\u5b8c\u6210\u6536\u8d2d\u540e\u4eac\u4e1c\u7269\u6d41\u53ef\u66f4\u597d\u5730\u6574\u5408\u4e24\u8005\u8d44\u6e90\uff0c\u589e\u5f3a\u5176\u81ea\u8eab\u7ade\u4e89\u529b\uff0c\u63d0\u5347\u8425\u8fd0\u6548\u7387\uff0c\u53d1\u6325\u534f\u540c\u6548\u5e94\u3002\u91ce\u6751\u7ef4\u6301\u5bf9\u4eac\u4e1c\u7269\u6d41\u7684\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0c\u76ee\u6807\u4ef717.8\u6e2f\u5143\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/260112376", "pub_date": "2024-12-10 13:50:17"}, {"id": 260111452, "title": "\u7279\u65af\u62c9(TSLA)\u56e0\u65d7\u4e0b\u6c7d\u8f66\u53d1\u751f\u81f4\u547d\u8f66\u7978\u800c\u906d\u5230\u8d77\u8bc9", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u7279\u65af\u62c9(TSLA)\u518d\u56e0\u65d7\u4e0b\u6c7d\u8f66\u53d1\u751f\u81f4\u547d\u8f66\u7978\u800c\u906d\u5230\u8d77\u8bc9\uff0c\u7f8e\u56fd\u4e00\u540d\u53f8\u673aGenesis Giovanni Mendoza-Martinez\u4e8e2023\u5e74\u5728\u52a0\u5dde\u9a7e\u9a76\u4e00\u8f86Model S\uff0c\u5728\u5f00\u542f\u6c7d\u8f66\u81ea\u52a8\u8f85\u52a9\u9a7e\u9a76\u7cfb\u7edfAutopilot\u65f6\u649e\u4e0a\u4e00\u8f86\u505c\u653e\u5728\u8def\u4e0a\u7684\u6d88\u9632\u8f66\uff0c\u53f8\u673a\u4e8e\u4e8b\u6545\u4e2d\u4e27\u751f\uff0c\u540c\u8f66\u4e58\u5ba2\u3001\u5373\u8be5\u53f8\u673a\u7684\u5144\u5f1f\u5219\u53d7\u91cd\u4f24\u3002\u4e24\u4eba\u5bb6\u5c5e\u4eca\u5e7410\u6708\u5165\u7980\u8d77\u8bc9\u7279\u65af\u62c9\uff0c\u6307\u8be5\u516c\u53f8\u5bf9Autopilot\u7cfb\u7edf\u7684\u5b89\u5168\u6027\u4f5c\u51fa\u6b3a\u8bc8\u6027\u4e0d\u5b9e\u9648\u8ff0\uff0c\u81f4\u4f7f\u8f66\u7978\u53d1\u751f\uff0c\u6848\u4ef6\u5df2\u79fb\u4ea4\u81f3\u52a0\u5dde\u5317\u90e8\u8054\u90a6\u6cd5\u9662\u5ba1\u7406\u3002<br/><br/>\u7279\u65af\u62c9\u516c\u53f8\u5f8b\u5e08\u56de\u5e94\u6307\uff0c\u9a7e\u9a76\u8005\u7684\u758f\u5ffd\u884c\u4e3a\u6216\u4e0d\u4f5c\u4e3a\u624d\u662f\u9020\u6210\u4e8b\u6545\u7684\u539f\u56e0\uff0c\u5f3a\u8c03\u7279\u65af\u62c9\u7684\u6c7d\u8f66\u548c\u7cfb\u7edf\u5177\u6709\u76f8\u5f53\u5b89\u5168\u7684\u8bbe\u8ba1\uff0c\u7b26\u5408\u5dde\u53ca\u8054\u90a6\u6cd5\u5f8b\u89c4\u5b9a\u3002\u636e\u7edf\u8ba1\uff0c\u76ee\u524d\u7279\u65af\u62c9\u6b63\u9762\u4e34\u81f3\u5c1115\u4e2a\u5176\u4ed6\u7c7b\u4f3c\u8bc9\u8bbc\uff0c\u6d89\u53caAutopilot\u6216\u5168\u81ea\u52a8\u9a7e\u9a76(Full Self-Driving)\u7684\u76f8\u5173\u610f\u5916\uff0c\u5f53\u4e2d\u67093\u5b97\u5df2\u79fb\u4ea4\u81f3\u7f8e\u56fd\u8054\u90a6\u6cd5\u9662\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260111452", "pub_date": "2024-12-10 13:42:33"}, {"id": 260111451, "title": "\u53f0\u79ef\u7535(TSM)\u524d11\u4e2a\u6708\u7d2f\u8ba1\u9500\u552e\u989d\u540c\u6bd4\u589e\u957f31.8%", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u53f0\u79ef\u7535(TSM)11\u6708\u9500\u552e\u989d2760.6\u4ebf\u65b0\u53f0\u5e01\uff0c\u540c\u6bd4\u589e\u957f34%\uff1b\u4eca\u5e74\u524d11\u4e2a\u6708\u7d2f\u8ba1\u9500\u552e\u989d\u7ea62.62\u4e07\u4ebf\u65b0\u53f0\u5e01\uff0c\u540c\u6bd4\u589e\u957f31.8%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260111451", "pub_date": "2024-12-10 13:42:36"}, {"id": 260110786, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u9ad8\u76db\u6307\u4e2d\u56fd11\u6708CPI\u6570\u636e\u4f4e\u4e8e\u5e02\u573a\u9884\u671f PPI\u8d85\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9ad8\u76db\u7814\u62a5\u6307\uff0c\u4e2d\u56fd11\u6708CPI\u6570\u636e\u4f4e\u4e8e\u5e02\u573a\u5171\u8bc6\u9884\u671f\uff0c\u800cPPI\u5219\u8d85\u51fa\u4e86\u9884\u671f\uff0c\u7ed9\u5e02\u573a\u5e26\u6765\u4e86\u60ca\u559c\u3002CPI\u901a\u80c0\u7684\u5c0f\u5e45\u4e0b\u964d\u4e3b\u8981\u662f\u7531\u4e8e\u524d\u671f\u4f9b\u5e94\u4e2d\u65ad\u5f71\u54cd\u6d88\u9000\u540e\uff0c\u65b0\u9c9c\u852c\u83dc\u548c\u6c34\u679c\u4ef7\u683c\u8fdb\u4e00\u6b65\u6062\u590d\u6b63\u5e38\u5316\u300211\u6708\u4efd\u7684\u6838\u5fc3\u5546\u54c1\u901a\u80c0\u6709\u6240\u6539\u5584\u3002</p><p>\u4e2d\u56fd11\u6708\u4efd\u7684\u603b\u4f53CPI\u901a\u80c0\u7387\u4ece10\u6708\u4efd\u7684+0.3%\u964d\u81f3+0.2%\uff0c\u4e3b\u8981\u539f\u56e0\u5728\u4e8e\u98df\u54c1\u901a\u80c0\u7684\u4e0b\u964d\u3002\u6309\u6708\u8ba1\u7b97\uff0cCPI\u901a\u80c0\u572811\u6708\u964d\u81f3-2.3%\uff08\u7ecf\u5b63\u8282\u8c03\u6574\u7684\u5e74\u7387\uff09\uff0c\u76f8\u6bd410\u6708\u7684-1.9%\u6709\u6240\u52a0\u6df1\u3002</p><p>\u98df\u54c1\u7c7bCPI\u540c\u6bd4\u901a\u80c0\u4ece10\u6708\u4efd\u7684+2.9%\u964d\u81f311\u6708\u4efd\u7684+1.0%\uff0c\u4e3b\u8981\u662f\u7531\u4e8e\u524d\u671f\u4f9b\u5e94\u4e2d\u65ad\u5f71\u54cd\u6d88\u9000\u540e\u65b0\u9c9c\u852c\u83dc\u548c\u6c34\u679c\u4ef7\u683c\u8fdb\u4e00\u6b65\u6b63\u5e38\u5316\u3002\u975e\u98df\u54c1\u7c7bCPI\u901a\u80c0\u572811\u6708\u4efd\u4ece10\u6708\u4efd\u7684-0.3%\u540c\u6bd4\u4e0a\u5347\u81f30.0%\uff0c\u8fd9\u4e00\u7f13\u548c\u4e3b\u8981\u662f\u7531\u4e8e\u6838\u5fc3\u5546\u54c1\u4ef7\u683c\u7684\u4e0a\u6da8\u3002\u8be5\u884c\u8861\u91cf\u7684\u6838\u5fc3\u5546\u54c1\u901a\u80c0\u6307\u6807\u572811\u6708\u4e5f\u589e\u52a0\u5230\u4e86+0.1%\uff0810\u6708\u4e3a-0.4%\uff09\u3002\u670d\u52a1\u7c7b\u901a\u80c0\u5219\u4fdd\u6301\u4e0d\u53d8\uff0c11\u6708\u540c\u6bd4\u4e3a+0.4%\u3002</p><p>PPI\u901a\u80c0\u65b9\u9762\uff0c11\u6708\u4efd\u540c\u6bd4\u4ece10\u6708\u4efd\u7684-2.9%\u56de\u5347\u81f3-2.5%\u3002\u4e0a\u6e38\u548c\u4e0b\u6e38\u7684\u901a\u7f29\u538b\u529b\u5747\u6709\u6240\u7f13\u89e3\u3002\u6309\u6708\u8ba1\u7b97\uff0cPPI\u901a\u80c0\u572811\u6708\u5347\u81f3-2.0%\uff08\u7ecf\u5b63\u8282\u8c03\u6574\u7684\u5e74\u7387\uff09\uff0c\u6bd410\u6708\u7684-4.9%\u6709\u660e\u663e\u6539\u5584\u3002\u751f\u4ea7\u8005\u8d27\u7269\u7684PPI\u901a\u80c0\u4ece10\u6708\u7684-3.3%\u540c\u6bd4\u5347\u81f311\u6708\u7684-2.9%\uff0c\u800c\u6d88\u8d39\u54c1\u7684PPI\u901a\u80c0\u4ece10\u6708\u7684-1.6%\u540c\u6bd4\u5347\u81f311\u6708\u7684-1.4%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260110786", "pub_date": "2024-12-10 13:37:09"}, {"id": 260110186, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5927\u534e\u7ee7\u663e\u7ef4\u6301\u5185\u623f\u80a1\u201c\u589e\u6301\u201d\u8bc4\u7ea7 \u6599\u4f1a\u6709\u66f4\u591a\u653f\u7b56\u652f\u6301\u51fa\u53f0", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u5927\u534e\u7ee7\u663e\u53d1\u7814\u62a5\u6307\uff0c\u4e2d\u56fd\u653f\u6cbb\u5c40\u4f1a\u8bae\u57289\u65e5\u660e\u786e\u8868\u793a\u5c06\u57282025\u5e74\u5b9e\u65bd\u9002\u5ea6\u5bbd\u677e\u7684\u8d27\u5e01\u653f\u7b56\uff0c\u8fd9\u662f\u81ea2012\u5e74\u4ee5\u6765\u7684\u9996\u6b21\u653e\u5bbd\u653f\u7b56\u7acb\u573a\u3002\u8be5\u884c\u8868\u793a\uff0c\u8fd9\u79cd\u7acb\u573a\u53ef\u80fd\u9884\u793a\u7740\u672a\u6765\u5c06\u63a8\u51fa\u66f4\u591a\u652f\u6301\u6027\u653f\u7b56\uff0c\u8fd9\u5bf9\u4e8e\u623f\u5730\u4ea7\u5e02\u573a\u5c06\u4ea7\u751f\u79ef\u6781\u5f71\u54cd\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0c\u867d\u7136\u4e70\u5bb6\u4fe1\u5fc3\u6062\u590d\u9700\u65f6\uff0c\u4f46\u4f30\u8ba1\u9884\u671f\u8f83\u4f4e\u7684LPR\u3001\u4e3a\u5730\u65b9\u653f\u5e9c\u8bbe\u7acb\u7ee9\u6548\u6307\u6807\uff0c\u4ee5\u53ca\u4e2d\u592e\u653f\u5e9c\u4ee5\u503a\u5238\u652f\u6301\u53bb\u5e93\u5b58\u5de5\u4f5c\u7b49\uff0c\u90fd\u5bf9\u7a33\u5b9a\u5e02\u51b5\u81f3\u5173\u91cd\u8981\uff0c\u800c11\u6708\u571f\u5730\u5e02\u573a\u6c14\u6c1b\u5df2\u6709\u6539\u5584\uff0c\u4e0d\u5c11\u6c11\u8425\u5f00\u53d1\u5546\u91cd\u65b0\u53c2\u4e0e\u6295\u5730\uff0c\u53cd\u6620\u6295\u8d44\u6c14\u6c1b\u6709\u6240\u6539\u5584\u3002<br/><br/>\u8be5\u884c\u5bf9\u5185\u623f\u5e02\u573a\u7ef4\u6301\u201c\u589e\u6301\u201d\u8bc4\u7ea7\uff0c\u5e76\u9884\u8ba1\u4f1a\u6709\u66f4\u591a\u653f\u7b56\u652f\u6301\u51fa\u53f0\u3002\u5bf9\u534e\u6da6\u7f6e\u5730(01109)\u3001\u4e2d\u56fd\u6d77\u5916\u53d1\u5c55(00688)\u53ca\u9f99\u6e56\u96c6\u56e2(00960)\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0c\u76ee\u6807\u4ef7\u5206\u522b\u4e3a32.4\u6e2f\u5143\u300118.6\u6e2f\u5143\u53ca17.2\u6e2f\u5143\uff0c\u5f53\u4e2d\u9f99\u6e56\u53ca\u4e2d\u56fd\u6d77\u5916\u5206\u522b\u4e3a\u6c11\u8425\u53ca\u56fd\u4f01\u80cc\u666f\u5f00\u53d1\u5546\u7684\u9996\u9009\u80a1\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/260110186", "pub_date": "2024-12-10 13:32:38"}, {"id": 260108816, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u82b1\u65d7\u6307\u97e9\u56fd\u653f\u6cbb\u4e0d\u786e\u5b9a\u6027\u52a0\u5267 \u97e9\u5143\u9762\u4e34\u538b\u529b", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u82b1\u65d7\u603b\u7ed3\u4e86\u82b1\u65d7\u5bf9\u4e8e\u97e9\u56fd\u5f53\u524d\u653f\u6cbb\u73af\u5883\u53ca\u5176\u5bf9\u7ecf\u6d4e\u548c\u8d27\u5e01\u5e02\u573a\u53ef\u80fd\u4ea7\u751f\u7684\u5f71\u54cd\u7684\u770b\u6cd5\u3002\u8be5\u884c\u8ba4\u4e3a\uff0c\u7531\u4e8e\u5404\u653f\u515a\u5bf9\u9009\u4e3e\u65f6\u95f4\u7684\u4e0d\u540c\u6fc0\u52b1\uff0c\u653f\u6cbb\u4e0d\u786e\u5b9a\u6027\u53ef\u80fd\u4f1a\u66f4\u957f\u65f6\u95f4\u5730\u52a0\u5267\u3002\u957f\u65f6\u95f4\u7684\u653f\u6cbb\u4e0d\u786e\u5b9a\u6027\u53ef\u80fd\u4f1a\u663e\u8457\u524a\u5f31\u5e7f\u6cdb\u7684\u7ecf\u6d4e\u60c5\u7eea\u4ee5\u53ca\u53ef\u81ea\u7531\u652f\u914d\u7684\u652f\u51fa\u3002\u5c3d\u7ba1\u7f8e\u5143\u5151\u97e9\u5143\u6c47\u7387\u53ef\u80fd\u4fdd\u6301\u6ce2\u52a8\uff0c\u4f46\u5982\u679c\u56fd\u4f1a\u672a\u80fd\u572812\u6708\u901a\u8fc72025\u5e74\u7684\u9884\u7b97\uff0c\u4ece1\u670816\u65e5\u7684\u8d27\u5e01\u653f\u7b56\u59d4\u5458\u4f1a\u4f1a\u8bae\uff08\u6216\u4e34\u65f6\u4f1a\u8bae\uff09\u5f00\u59cb\uff0c\u97e9\u56fd\u94f6\u884c\uff08BoK\uff09\u8fde\u7eed\u964d\u606f\u81f32.75%\u7684\u53ef\u80fd\u6027\u5c06\u589e\u52a0\u3002</p><p>\u8be5\u884c\u6700\u8fd1\u5c06\u7f8e\u5143\u5151\u97e9\u5143\u6c47\u7387\u7684\u9884\u6d4b\u63d0\u9ad8\u5230\u672a\u67650-3\u4e2a\u6708\u4e3a1,450\uff0c6-12\u4e2a\u6708\u4e3a1,430\u3002\u82b1\u65d7\u5916\u6c47\u4e0e\u5229\u7387\u7b56\u7565\u56e2\u961f\u6307\u51fa\uff0c\u653f\u6cbb\u53d1\u5c55\u53ef\u80fd\u5bfc\u81f4\u66f4\u9ad8\u7684\u8d44\u91d1\u5916\u6d41\u538b\u529b\uff0c\u5e76\u5bf9\u7f8e\u5143\u5151\u97e9\u5143\u6c47\u7387\u6784\u6210\u4e0a\u884c\u98ce\u9669\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260108816", "pub_date": "2024-12-10 13:20:54"}, {"id": 260108344, "title": "\u793c\u6765(LLY)\u6279\u51c6150\u4ebf\u7f8e\u5143\u80a1\u7968\u56de\u8d2d \u63d0\u9ad8\u5b63\u5ea6\u80a1\u606f15%", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u793c\u6765(LLY)\u5468\u4e00\u6279\u51c6\u4e86\u4e00\u9879\u81f3\u591a150\u4ebf\u7f8e\u5143\u7684\u80a1\u7968\u56de\u8d2d\u8ba1\u5212\uff0c\u5e76\u5c06\u5b63\u5ea6\u80a1\u606f\u63d0\u9ad8\u4e8615%\u3002<br/><br/>\u636e\u6089\uff0c\u8be5\u516c\u53f8\u7684\u51cf\u80a5\u548c\u7cd6\u5c3f\u75c5\u836f\u7269\u5927\u83b7\u6210\u529f\uff0c\u4f7f\u5176\u6210\u4e3a\u5168\u7403\u5e02\u503c\u6700\u9ad8\u7684\u5236\u836f\u516c\u53f8\u3002\u4eca\u5e74\u4ee5\u6765\uff0c\u793c\u6765\u80a1\u4ef7\u7d2f\u8ba1\u4e0a\u6da839%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260108344", "pub_date": "2024-12-10 13:16:15"}]}