7684\u4e13\u4e1a\u80fd\u529b\u3002<br/><br/>\u4e2a\u80a1\u65b9\u9762\uff0c\u4e2d\u56fd\u8054\u901a(00762)\u6da83.94%\uff0c\u62a57.13\u6e2f\u5143\uff0c\u6210\u4ea4\u989d2.79\u4ebf\u6e2f\u5143\u3002\u516c\u53f8\u65e5\u524d\u516c\u544a\uff0c2024\u5e74\u524d\u4e09\u5b63\u5ea6\u516c\u53f8\u6743\u76ca\u6301\u6709\u8005\u5e94\u5360\u76c8\u5229\u8fbe\u5230\u4eba\u6c11\u5e01190.3\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f10.3%\u3002\u671f\u5185\u8425\u4e1a\u6536\u5165\u8fbe\u5230\u4eba\u6c11\u5e012,901.2\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f3.0%\u3002EBITDA\u8fbe\u5230\u4eba\u6c11\u5e01804.0\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f2.0%\u3002<br/><br/>\u5468\u5927\u798f(01929)\u76c8\u8b66\u540e\u4ecd\u4e0a\u6da8\uff0c\u6da87.55%\uff0c\u62a57.83\u6e2f\u5143\uff0c\u6210\u4ea4\u989d1.64\u4ebf\u6e2f\u5143\u3002\u4e2d\u91d1\u53d1\u62a5\u79f0\uff0c\u6839\u636e\u516c\u53f8\u516c\u5e032QFY25(7-9\u6708)\u7ecf\u8425\u6570\u636e\uff0c\u5468\u5927\u798f\u6574\u4f53\u96f6\u552e\u989d\u540c\u6bd4\u4e0b\u6ed121%\uff0c\u5176\u4e2d\u4e2d\u56fd\u5185\u5730\u96f6\u552e\u989d\u540c\u6bd4\u4e0b\u6ed119%\uff0c\u4e2d\u56fd\u9999\u6e2f\u3001\u4e2d\u56fd\u6fb3\u95e8\u53ca\u5176\u4ed6\u5e02\u573a\u96f6\u552e\u989d\u540c\u6bd4\u4e0b\u6ed131%\u3002\u516c\u53f8\u9884\u8ba11HFY25\u6536\u5165\u540c\u6bd4\u4e0b\u964d18-22%\uff0c\u51c0\u5229\u6da6\u4e0b\u964d42-46%\uff0c\u4f46\u82e5\u5254\u9664\u9ec4\u91d1\u501f\u8d37\u635f\u76ca\u5f71\u54cd\u540e\uff0c\u516c\u53f8\u9884\u8ba1\u8c03\u6574\u540e\u51c0\u5229\u6da6\u540c\u6bd4\u4e0b\u964d12-16%\u53cd\u6620\u8c03\u6574\u540e\u51c0\u5229\u7387\u4ecd\u6709\u5c0f\u5e45\u540c\u6bd4\u63d0\u5347\u3002\u8be5\u884c\u9884\u8ba1\u56e0\u91d1\u4ef7\u4e0a\u6da8\u548c\u5b9a\u4ef7\u9ec4\u91d1\u4ea7\u54c1\u5360\u6bd4\u63d0\u5347\u5e26\u6765\u6bdb\u5229\u7387\u540c\u6bd4\u63d0\u5347\u3002\u8be5\u884c\u57fa\u672c\u7ef4\u6301\u5468\u5927\u798fFY25/26\u5e74EPS\u9884\u6d4b0.58/0.69\u6e2f\u5143\uff0c\u7ef4\u6301\u201c\u8dd1\u8d62\u884c\u4e1a\u201d\u8bc4\u7ea7\u548c\u76ee\u6807\u4ef77.82\u6e2f\u5143\u4e0d\u53d8\u3002<br/><br/>\u4e2d\u6cf0\u56fd\u9645\u8868\u793a\uff0c\u77ed\u671f\u6765\u770b\uff0c\u5e02\u573a\u5bf9\u4e8e\u4eba\u5927\u5e38\u59d4\u4f1a\u4ecd\u6709\u589e\u91cf\u8d22\u653f\u653f\u7b56\u7684\u9884\u671f\uff0c\u4f46\u9884\u671f\u523a\u6fc0\u7684\u89c4\u6a21\u548c\u8d64\u5b57\u7387\u6216\u76f8\u5bf9\u4fdd\u5b88\uff0c\u4e00\u65b9\u9762\uff0c\u5728\u7edf\u7b79\u9ad8\u8d28\u91cf\u53d1\u5c55\u548c\u9ad8\u6c34\u5e73\u5b89\u5168\u7684\u653f\u7b56\u6846\u67b6\u4e0b\uff0c\u5f3a\u523a\u6fc0\u653f\u7b56\u9884\u671f\u6b63\u5728\u8d8b\u4e8e\u51b7\u9759\uff1b\u53e6\u4e00\u65b9\u9762\uff0c\u56db\u5b63\u5ea6\u7f8e\u8054\u50a8\u964d\u606f\u8282\u594f\u5927\u6982\u7387\u653e\u6162\uff0c\u7f8e\u56fd\u5927\u9009\u4e34\u8fd1\u4e5f\u5e26\u6765\u66f4\u591a\u653f\u6cbb\u6ce2\u52a8\u6027\uff0c\u4e0d\u6392\u9664\u8d22\u653f\u653f\u7b56\u9700\u8981\u4e3a\u56db\u5b63\u5ea6\u5916\u90e8\u73af\u5883\u4e0d\u786e\u5b9a\u6027\u7684\u4e0a\u5347\u7559\u8db3\u5e94\u5bf9\u7a7a\u95f4\u3002\u56e0\u6b64\uff0c\u77ed\u671f\u5e02\u573a\u5927\u6982\u7387\u4ecd\u5ef6\u7eed\u9707\u8361\uff0c\u4ece\u4f30\u503c\u53ca\u98ce\u9669\u6ea2\u4ef7\u7684\u89d2\u5ea6\uff0c\u6052\u6307\u572819,500\u4ee5\u4e0b\u624d\u4f1a\u6709\u66f4\u5927\u7684\u5438\u5f15\u529b\uff0c\u4f46\u77ed\u671f\u5219\u572819,700\u81f320,100\u6709\u6280\u672f\u6027\u652f\u6491\u3002\u6052\u630721,200\u70b9\u4ee5\u4e0a\u7684\u6210\u4ea4\u5bc6\u96c6\u533a\u7684\u6cbd\u538b\u4f1a\u6bd4\u8f83\u5927\uff0c\u9700\u8981\u66f4\u5927\u50ac\u5316\u5242\u624d\u80fd\u4f01\u7a33\u3002\u5f53\u524d\u7b56\u7565\u4ee5\u6355\u6349\u533a\u95f4\u6ce2\u6bb5\u4e3a\u4e3b\u3002<br/><br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255528614", "pub_date": "2024-10-23 12:16:08"}, {"id": 255528792, "title": "\u6df1\u573310\u6708\u65b0\u623f\u7d2f\u8ba1\u8ba4\u8d2d\u91cf\u8fbe8405\u5957", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u6df1\u5733\u53d1\u5e03\u516c\u4f17\u53f7\u6d88\u606f\uff0c\u6df1\u5733\u65b0\u623f\u5e02\u573a\u6301\u7eed\u706b\u7206\uff0c\u4e50\u6709\u5bb6\u7814\u7a76\u4e2d\u5fc3\u76d1\u6d4b\u663e\u793a\uff0c\u622a\u6b62\u523010\u670822\u65e5\uff0c\u5168\u5e02\u4e00\u624b\u4f4f\u5b85\u7d2f\u8ba1\u8ba4\u8d2d\u91cf\u8fbe\u52308405\u5957\uff0c\u8fbe\u5230\u6df1\u5733\u4ea4\u6613\u91cf\u7684\u7e41\u8363\u7ebf\u6c34\u5e73\uff0c\u5e73\u5747\u6bcf\u5929\u8ba4\u8d2d382\u5957\u3002\u6309\u6b64\u8d8b\u52bf\u53d1\u5c55\uff0c\u6708\u5e95\u7d2f\u8ba1\u8ba4\u8d2d\u91cf\u6709\u671b\u8d8510000\u5957\u3002<br/><br/>\u4ece\u5168\u5e02\u699c\u5355\u6765\u770b\uff0c\u5355\u4ef7\u8f83\u4f4e\u7684\u9879\u76ee\u4e5f\u76f8\u5bf9\u53d7\u6b22\u8fce\uff0c\u524d\u5341\u7684\u699c\u5355\u91cc\u67096\u4e2a\u9879\u76ee\u5747\u4ef7\u4f4e\u4e8e5\u4e07\u5143/\u33a1\uff0c2\u4e2a\u9879\u76ee\u57285-6\u4e07\u5143/\u33a1\u51fa\u5934\uff0c\u53ea\u6709\u6df1\u5733\u6e7e\u7684\u6df1\u6e7e\u7396\u5e8f\u4ef7\u683c\u8f83\u9ad8\u3002\u6b64\u5916\uff0c\u70ed\u95e8\u65b0\u623f\u9879\u76ee\u5927\u591a\u5177\u6709\u6838\u5fc3\u533a\u57df\u3001\u4f18\u8d28\u6559\u80b2\u914d\u5957\u7684\u7279\u70b9\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255528792", "pub_date": "2024-10-23 12:18:22"}, {"id": 255528882, "title": "\u745e\u79d1\u751f\u7269(02179)\u81ea\u7814\u65b0\u4f50\u5242\u91cd\u7ec4\u5e26\u72b6\u75b1\u75b9\u75ab\u82d7REC610\u542f\u52a8\u4e2d\u56fdIII\u671f\u4e34\u5e8a\u7814\u7a76", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u745e\u79d1\u751f\u7269(02179)\u5ba3\u5e03\uff0c\u516c\u53f8\u81ea\u4e3b\u7814\u53d1\u7684\u65b0\u4f50\u5242\u91cd\u7ec4\u5e26\u72b6\u75b1\u75b9\u75ab\u82d7REC610\uff0c\u5df2\u4e8e\u8fd1\u65e5\u6b63\u5f0f\u542f\u52a8\u4e2d\u56fdIII\u671f\u4e34\u5e8a\u7814\u7a76\u5e76\u5b8c\u6210\u9996\u6279\u53d7\u8bd5\u8005\u5165\u7ec4\u3002\u4e2d\u56fdIII\u671f\u4e34\u5e8a\u7814\u7a76\u91c7\u7528\u968f\u673a\u3001\u53cc\u76f2\u3001\u5b89\u6170\u5242\u5bf9\u7167\u8bbe\u8ba1\uff0c\u5728\u4e2d\u56fd\u5883\u5185\u62db\u52df24,640\u4f8b40\u5c81\u53ca\u4ee5\u4e0a\u5065\u5eb7\u53d7\u8bd5\u8005\uff0c\u4ee5\u8bc4\u4ef7REC610\u7684\u4fdd\u62a4\u6548\u529b\u3001\u5b89\u5168\u6027\u53ca\u514d\u75ab\u539f\u6027\u3002<br/><br/>\u5e26\u72b6\u75b1\u75b9\u662f\u4e00\u79cd\u5e38\u89c1\u7684\u75c5\u6bd2\u611f\u67d3\u6027\u75be\u75c5\uff0c\u60a3\u8005\u53ef\u80fd\u5e76\u53d1\u5e26\u72b6\u75b1\u75b9\u540e\u795e\u7ecf\u75db\uff0c\u8fd9\u79cd\u5267\u70c8\u7684\u795e\u7ecf\u75bc\u75db\u4e25\u91cd\u5f71\u54cd\u60a3\u8005\u751f\u6d3b\u8d28\u91cf\u3002\u636e\u7edf\u8ba1\uff0c\u4e2d\u56fd\u6bcf\u5e74\u7ea6\u6709600\u4e07\u5e26\u72b6\u75b1\u75b9\u75c5\u4f8b\uff0c\u4e14\u8fd1\u5e74\u6765\u5176\u53d1\u75c5\u6709\u9010\u6b65\u5e74\u8f7b\u5316\u7684\u8d8b\u52bf\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255528882", "pub_date": "2024-10-23 12:19:41"}]}