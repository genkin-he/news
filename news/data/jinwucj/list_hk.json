{"data": [{"id": 255712855, "title": "\u7231\u9a6c\u4ed5(HESAY)\u76d8\u524d\u6da8\u8d851% \u4e09\u5b63\u5ea6\u9500\u552e\u989d\u9006\u52bf\u589e\u957f11.3%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7231\u9a6c\u4ed5(HESAY)\u76d8\u524d\u6da8\u8d851%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a5225\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u7231\u9a6c\u4ed5\u53d1\u5e03\u58f0\u660e\u79f0\uff0c\u7b2c\u4e09\u5b63\u5ea6\u7684\u6536\u5165\u4e3a37\u4ebf\u6b27\u5143\uff0839.9\u4ebf\u7f8e\u5143\uff09\uff0c\u9500\u552e\u989d\u6309\u56fa\u5b9a\u6c47\u7387\u8ba1\u7b97\u589e\u957f\u4e8611.3%\uff0c\u7565\u9ad8\u4e8e\u5206\u6790\u5e08\u7684\u9884\u671f11%\u3002<br/><br/>\u6309\u5730\u533a\u6765\u770b\uff0c\u7231\u9a6c\u4ed5\u5728\u6b27\u6d32\u3001\u65e5\u672c\u548c\u7f8e\u6d32\u7684\u9500\u552e\u989d\u5747\u8d85\u51fa\u9884\u671f\uff1b\u6309\u4e1a\u52a1\u6765\u770b\uff0c\u9664\u4e86\u624b\u8868\u90e8\u95e8\u9500\u552e\u989d\u4e0b\u6ed118%\uff0c\u5176\u4f59\u4e1a\u52a1\u90e8\u95e8\u9500\u552e\u989d\u5747\u5b9e\u73b0\u589e\u957f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255712855", "pub_date": "2024-10-24 20:33:41"}, {"id": 255711255, "title": "\u82f1\u7279\u5c14(INTC)\u8d62\u5f97\u6b27\u76df11\u4ebf\u7f8e\u5143\u53cd\u5784\u65ad\u8bc9\u8bbc", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6b27\u6d32\u6700\u9ad8\u6cd5\u9662\u201c\u6b27\u76df\u6cd5\u9662\u201d\u5468\u56db\u4f5c\u51fa\u4e86\u6709\u5229\u4e8e\u82f1\u7279\u5c14(INTC)\u7684\u88c1\u51b3\uff0c\u7ed3\u675f\u4e86\u8fd9\u5bb6\u7f8e\u56fd\u82af\u7247\u5236\u9020\u5546\u4e0e\u6b27\u76df\u76d1\u7ba1\u673a\u6784\u4e4b\u95f4\u957f\u8fbe\u8fd120\u5e74\u7684\u6597\u4e89\u3002\u6b27\u76df\u76d1\u7ba1\u673a\u6784\u6307\u63a7\u82f1\u7279\u5c14\u66fe\u8bd5\u56fe\u963b\u6320\u7ade\u4e89\u5bf9\u624b\u3002\u6b27\u76df\u76d1\u7ba1\u673a\u6784\u6700\u521d\u5bf9\u82f1\u7279\u5c14\u5904\u4ee510.6\u4ebf\u6b27\u5143(11.4\u4ebf\u7f8e\u5143)\u7684\u7f5a\u6b3e\uff0c\u4f46\u4e0b\u7ea7\u6cd5\u5ead\u64a4\u9500\u4e86\u8fd9\u4e00\u88c1\u51b3\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255711255", "pub_date": "2024-10-24 20:23:50"}, {"id": 255708393, "title": "\u8d1d\u83b1\u5fb7\u79f0\u5e02\u573a\u4f4e\u4f30\u4e86\u7f8e\u56fd\u603b\u7edf\u5927\u9009\u7ed3\u679c\u5b58\u5728\u4e89\u8bae\u7684\u98ce\u9669", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u5a92\u4f53\uff0c\u8d1d\u83b1\u5fb7\u8868\u793a\uff0c\u5e02\u573a\u4f4e\u4f30\u4e86\u7f8e\u56fd\u603b\u7edf\u5927\u9009\u7ed3\u679c\u5b58\u5728\u4e89\u8bae\u7684\u98ce\u9669\uff0c\u6709\u4e89\u8bae\u7684\u7ade\u9009\u80dc\u5229\u53ef\u80fd\u4f1a\u5bfc\u81f4\u201c\u6570\u5468\u975e\u5e38\u6df7\u4e71\u7684\u6cd5\u5f8b\u7ea0\u7eb7\u201d\uff0c\u8fd9\u5c06\u5bf9\u8d44\u4ea7\u4ea7\u751f\u8d1f\u9762\u5f71\u54cd\u3002\u8bd5\u56fe\u5229\u7528\u7f8e\u56fd\u5927\u9009\u8fdb\u884c\u4ea4\u6613\u662f\u201c\u611a\u8822\u7684\u884c\u4e3a\u201d\uff0c\u5176\u8ba4\u4e3a\u76ee\u524d\u5e02\u573a\u8fd8\u6ca1\u6709\u6d88\u5316\u8fd9\u79cd\u60c5\u666f\uff0c\u5224\u65ad\u8c01\u662f\u8d62\u5bb6\u662f\u5f92\u52b3\u7684\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255708393", "pub_date": "2024-10-24 20:06:00"}, {"id": 255706971, "title": "IBM Corp(IBM)\u76d8\u524d\u8dcc\u8d854% Q3\u7531\u76c8\u8f6c\u4e8f3.3\u4ebf\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | IBM Corp(IBM)\u76d8\u524d\u8dcc\u8d854%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a5222.2\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u516c\u53f8\u516c\u5e032024\u8d22\u5e74Q3\u4e1a\u7ee9\u3002\u671f\u5185\uff0c\u51c0\u4e8f\u635f3.3\u4ebf\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u51c0\u5229\u6da6\u4e3a17.04\u4ebf\u7f8e\u5143\u3002\u8c03\u6574\u540e\u6bcf\u80a1\u6536\u76ca\u4e3a2.3\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u4e3a2.2\u7f8e\u5143\u3002<br/><br/>\u671f\u5185\uff0c\u8425\u4e1a\u6536\u5165\u4e3a149.68\u4ebf\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u4e3a147.52\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u4e0a\u53471.5%\u3002\u5176\u4e2d\uff1a\u8f6f\u4ef6\u4e1a\u52a1\u8425\u6536\u4e3a65.24\u4ebf\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u4e3a59.47\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u4e0a\u53479.7%\uff1b\u54a8\u8be2\u4e1a\u52a1\u8425\u6536\u4e3a51.52\u4ebf\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u4e3a51.78\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u4e0b\u964d0.5%\uff1b\u57fa\u7840\u8bbe\u65bd\u90e8\u95e8\u8425\u6536\u4e3a30.42\u4ebf\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u4e3a32.72\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u4e0b\u964d7%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255706971", "pub_date": "2024-10-24 19:56:12"}, {"id": 255704616, "title": "\u7279\u65af\u62c9(TSLA)\u65992024\u5e74\u8d44\u672c\u652f\u51fa\u5c06\u8d85\u8fc7110\u4ebf\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7279\u65af\u62c9(TSLA)\u9884\u8ba12024\u5e74\u8d44\u672c\u652f\u51fa\u5c06\u8d85\u8fc7110\u4ebf\u7f8e\u5143\uff0c\u6b64\u524d\u9884\u8ba1\u8d85\u8fc7100\u4ebf\u7f8e\u5143\uff0c\u5e02\u573a\u9884\u4f30102.3\u4ebf\u7f8e\u5143\uff1b\u9884\u8ba12025\u5e74\u548c2026\u5e74\u7684\u8d44\u672c\u652f\u51fa\u5c06\u572880\u4ebf\u81f3100\u4ebf\u7f8e\u5143\u4e4b\u95f4\u3002\u6b64\u5916\uff0c\u7279\u65af\u62c9\u5728\u7b2c\u4e09\u5b63\u5ea6\u786e\u8ba4\u4e863.26\u4ebf\u7f8e\u5143\u7684FSD\u6536\u5165\uff0c\u4e3b\u8981\u6765\u81ea\u4e8e\u7535\u52a8\u76ae\u5361Cybertruck\u53ca\u67d0\u4e9b\u529f\u80fd\uff0c\u5982\u667a\u80fd\u53ec\u5524\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255704616", "pub_date": "2024-10-24 19:41:34"}, {"id": 255701340, "title": "IBM Corp(IBM)Q3\u7531\u76c8\u8f6c\u4e8f3.3\u4ebf\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | IBM Corp(IBM)\u516c\u5e032024\u8d22\u5e74Q3\u4e1a\u7ee9\u3002\u671f\u5185\uff0c\u51c0\u4e8f\u635f3.3\u4ebf\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u51c0\u5229\u6da6\u4e3a17.04\u4ebf\u7f8e\u5143\u3002\u8c03\u6574\u540e\u6bcf\u80a1\u6536\u76ca\u4e3a2.3\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u4e3a2.2\u7f8e\u5143\u3002<br/><br/>\u671f\u5185\uff0c\u8425\u4e1a\u6536\u5165\u4e3a149.68\u4ebf\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u4e3a147.52\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u4e0a\u53471.5%\u3002\u5176\u4e2d\uff1a\u8f6f\u4ef6\u4e1a\u52a1\u8425\u6536\u4e3a65.24\u4ebf\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u4e3a59.47\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u4e0a\u53479.7%\uff1b\u54a8\u8be2\u4e1a\u52a1\u8425\u6536\u4e3a51.52\u4ebf\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u4e3a51.78\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u4e0b\u964d0.5%\uff1b\u57fa\u7840\u8bbe\u65bd\u90e8\u95e8\u8425\u6536\u4e3a30.42\u4ebf\u7f8e\u5143\uff0c\u53bb\u5e74\u540c\u671f\u4e3a32.72\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u4e0b\u964d7%\u3002</p><p>\u6307\u5f15\u65b9\u9762\uff0c\u516c\u53f8\u9884\u8ba1\u56fa\u5b9a\u6c47\u7387\u4e0b\u7b2c\u56db\u5b63\u5ea6\u7684\u8425\u4e1a\u6536\u5165\u589e\u957f\u901f\u5ea6\u5c06\u4e0e\u7b2c\u4e09\u5b63\u5ea6\u4fdd\u6301\u4e00\u81f4\u3002\u516c\u53f8\u9884\u8ba1\u5168\u5e74\u81ea\u7531\u73b0\u91d1\u6d41\u5c06\u8d85\u8fc7120\u4ebf\u7f8e\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255701340", "pub_date": "2024-10-24 19:20:12"}, {"id": 255700101, "title": "T-Mobile US(TMUS)\u76d8\u524d\u6da8\u8d852% Q3\u51c0\u5229\u6da6\u540c\u6bd4\u589e\u957f43%\u81f331\u4ebf\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u7535\u4fe1\u8425\u8fd0\u5546T-Mobile US(TMUS)\u76d8\u524d\u6da8\u8d852%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a5225.8\u7f8e\u5143\u3002</p><p>\u6d88\u606f\u9762\u4e0a\uff0cT-Mobile US\u7b2c\u4e09\u5b63\u5ea6\u8425\u6536201.6\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f4.7%\uff0c\u8d85\u51fa\u5e02\u573a\u9884\u671f\u7684200\u4ebf\u7f8e\u5143\uff1b\u51c0\u5229\u6da631\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f43%\uff1b\u8c03\u6574\u540e\u6bcf\u80a1\u76c8\u52292.61\u7f8e\u5143\uff0c\u8d85\u51fa\u5e02\u573a\u9884\u671f\u76842.43\u7f8e\u5143\u3002\u671f\u5185\u51c0\u589e\u540e\u4ed8\u8d39\u7528\u623786.5\u4e07\uff0c\u8d85\u51fa\u5e02\u573a\u9884\u671f\u768473.29\u4e07\uff0c\u4ea6\u4f18\u4e8e\u5176\u7ade\u4e89\u5bf9\u624bAT&amp;T\u768440.3\u4e07\u548cVerizon\u768423.9\u4e07\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255700101", "pub_date": "2024-10-24 19:12:59"}, {"id": 255700255, "title": "\u82f1\u56fd10\u6708CBI\u5de5\u4e1a\u8ba2\u5355\u5dee\u503c-27 \u9884\u671f-28 \u524d\u503c-35", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u82f1\u56fd10\u6708CBI\u5de5\u4e1a\u8ba2\u5355\u5dee\u503c-27\uff0c\u9884\u671f-28\uff0c\u524d\u503c-35\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255700255", "pub_date": "2024-10-24 19:13:17"}, {"id": 255697194, "title": "\u597d\u672a\u6765(TAL)\u76d8\u524d\u6da8\u8d857% Q2\u51c0\u5229\u6da6\u540c\u6bd4\u589e\u957f51.5%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u597d\u672a\u6765(TAL)\u76d8\u524d\u6da8\u8d857%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a511\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u516c\u53f8\u53d1\u5e032025\u8d22\u5e74\u7b2c\u4e8c\u5b63\u5ea6\u8d22\u52a1\u4e1a\u7ee9\u3002\u671f\u5185\uff0c\u5f52\u5c5e\u4e8e\u597d\u672a\u6765\u7684\u51c0\u5229\u6da6\u4e3a5743\u4e07\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f51.5%\u3002\u671f\u5185\uff0c\u51c0\u8425\u6536\u4e3a6.194\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f50.4%\u3002\u6bcf\u80a1\u6536\u76ca0.1\u7f8e\u5143\uff0c\u8f83\u53bb\u5e74\u540c\u671f\u6301\u5e73\u3002<br/><br/>2025\u8d22\u5e74\u4e0a\u534a\u8d22\u5e74\uff0c\u51c0\u8425\u6536\u4e3a10.335\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f50.4%\u3002\u5f52\u5c5e\u4e8e\u597d\u672a\u6765\u7684\u51c0\u5229\u6da6\u4e3a6880\u4e07\u7f8e\u5143\uff0c\u4e0a\u5e74\u540c\u671f\u5f52\u5c5e\u4e8e\u597d\u672a\u6765\u7684\u51c0\u4e8f\u635f\u4e3a710\u4e07\u7f8e\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255697194", "pub_date": "2024-10-24 18:53:46"}, {"id": 255695826, "title": "\u970d\u5c3c\u97e6\u5c14(HON)Q3\u9500\u552e\u989d\u540c\u6bd4\u589e\u957f6%\u81f397\u4ebf\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u970d\u5c3c\u97e6\u5c14(HON)\u516c\u5e03\u7b2c\u4e09\u5b63\u5ea6\u4e1a\u7ee9\u3002\u671f\u5185\uff0c\u9500\u552e\u989d97\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f6%\uff1b\u8425\u4e1a\u5229\u6da6\u7387\u4e3a19.1%\u3002<br/><br/>\u671f\u5185\uff0c\u6bcf\u80a1\u6536\u76ca\u4e3a2.16\u7f8e\u5143\uff0c\u540c\u6bd4\u4e0b\u964d5%\uff1b\u8c03\u6574\u540e\u6bcf\u80a1\u6536\u76ca\u4e3a2.58\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f8%\uff0c\u9ad8\u4e8e\u5148\u524d\u6307\u5bfc\u7684\u9ad8\u7aef\u3002\u7ecf\u8425\u73b0\u91d1\u6d41\u4e3a20\u4ebf\u7f8e\u5143\uff0c\u81ea\u7531\u73b0\u91d1\u6d41\u4e3a17\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f10%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255695826", "pub_date": "2024-10-24 18:44:26"}]}