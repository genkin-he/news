82cf\u9ece\u4e16\u662f\u56e0\u4e3a\u8fd9\u5ea7\u57ce\u5e02\u5df2\u6210\u4e3a\u4e00\u4e2a\u91cd\u8981\u7684\u79d1\u6280\u4e2d\u5fc3\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259628502", "pub_date": "2024-12-05 09:51:52"}, {"id": 259628571, "title": "\u3010\u4f1a\u8bae\u7eaa\u8981\u3011\u745e\u94f6\uff1a\u6234\u5c14(DELL)AI\u670d\u52a1\u5668\u589e\u957f\u5f3a\u52b2 \u5b58\u50a8\u4e1a\u52a1\u671f\u5f85\u590d\u82cf", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5728\u745e\u94f6\u5168\u7403\u79d1\u6280\u4e0eAI\u4f1a\u8bae\u4e0a\uff0c\u6234\u5c14\u79d1\u6280\uff08Dell Technologies Inc.\uff0c\u4ee5\u4e0b\u7b80\u79f0DELL\uff09\u5c55\u793a\u4e86\u5176\u7b2c\u4e09\u5b63\u5ea6\u7684\u8d22\u52a1\u6982\u51b5\u3002\u516c\u53f8\u7b2c\u4e09\u5b63\u5ea6\u6bcf\u80a1\u6536\u76ca\uff08EPS\uff09\u8fbe\u52302.15\u7f8e\u5143\uff0c\u8d85\u51fa\u5e02\u573a\u9884\u671f0.09\u7f8e\u5143\uff1b\u8425\u6536\u4e3a243.7\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f9.51%\uff0c\u4f46\u7565\u4f4e\u4e8e\u5e02\u573a\u9884\u671f\u7684355.53\u767e\u4e07\u7f8e\u5143\u3002\u7279\u522b\u503c\u5f97\u4e00\u63d0\u7684\u662f\uff0c\u516c\u53f8\u5728AI\u4f18\u5316\u670d\u52a1\u5668\u9886\u57df\u8868\u73b0\u7a81\u51fa\uff0c\u8ba2\u5355\u6536\u5165\u589e\u957f36\u4ebf\u7f8e\u5143\uff0c\u73af\u6bd4\u589e\u957f11%\uff0c\u51fa\u8d27\u91cf\u8fbe\u523029\u4ebf\u7f8e\u5143\uff0c\u663e\u793a\u51fa\u5e02\u573a\u9700\u6c42\u7684\u5f3a\u52b2\u3002<br/><br/>\u673a\u6784\u5206\u6790\u5e08David Vogt\u5bf9DELL\u7684ISG\u90e8\u95e8\u8fdb\u884c\u4e86\u6df1\u5165\u5206\u6790\u3002\u8be5\u90e8\u95e8\u7531Arthur Lewis\u9886\u5bfc\uff0c\u6db5\u76d6\u670d\u52a1\u5668\u3001\u7f51\u7edc\u3001\u5b58\u50a8\u53ca\u76f8\u5173\u89e3\u51b3\u65b9\u6848\u3002\u5206\u6790\u5e08\u8ba4\u4e3a\uff0cDELL\u5728AI\u670d\u52a1\u5668\u5e02\u573a\u7684\u5f3a\u52b2\u8868\u73b0\u662f\u5176\u8d22\u52a1\u589e\u957f\u7684\u4e3b\u8981\u9a71\u52a8\u529b\u3002\u516c\u53f8\u5728\u4ea7\u54c1\u7ec4\u5408\u7684\u5e7f\u5ea6\u548c\u521b\u65b0\u901f\u5ea6\u4e0a\u5177\u6709\u660e\u663e\u4f18\u52bf\uff0c\u5c24\u5176\u5728\u6db2\u4f53\u51b7\u5374\u6280\u672f\u3001PowerScale\u5b58\u50a8\u89e3\u51b3\u65b9\u6848\u548cProject Lightning\u5e76\u884c\u6587\u4ef6\u7cfb\u7edf\u7b49\u65b9\u9762\u3002DELL\u7684\u751f\u6001\u7cfb\u7edf\u5408\u4f5c\u4f19\u4f34\u5173\u7cfb\uff0c\u5982\u4e0eHuggingFace\u548cMeta\u7684\u5408\u4f5c\uff0c\u8fdb\u4e00\u6b65\u589e\u5f3a\u4e86\u5176\u5e02\u573a\u7ade\u4e89\u529b\u3002<br/><br/>\u5c55\u671b\u672a\u6765\uff0cDELL\u5bf9\u5b58\u50a8\u4e1a\u52a1\u7684\u590d\u82cf\u5145\u6ee1\u671f\u5f85\u3002\u516c\u53f8\u9884\u8ba1\uff0c\u968f\u7740\u670d\u52a1\u5668\u5e02\u573a\u7684\u589e\u957f\uff0c\u5b58\u50a8\u4e1a\u52a1\u5c06\u968f\u4e4b\u590d\u82cf\uff0c\u9884\u8ba1\u660e\u5e74\u5e02\u573a\u589e\u957f\u7387\u4e3a4%\uff0c\u800cDELL\u8ba1\u5212\u4ee5\u9ad8\u4e8e\u5e02\u573a\u7684\u901f\u5ea6\u589e\u957f\u5e76\u593a\u56de\u5e02\u573a\u4efd\u989d\u3002Arthur Lewis\u5f3a\u8c03\uff0c\u516c\u53f8\u4e13\u6ce8\u4e8e\u5ba2\u6237\u7528\u4f8b\u548c\u73b0\u4ee3\u6570\u636e\u4e2d\u5fc3\u7684\u9700\u6c42\uff0c\u7279\u522b\u662f\u5728\u79c1\u6709\u6df7\u5408\u4e91\u3001\u6570\u636e\u5e73\u53f0\u548c\u5b89\u5168\u5e73\u53f0\u7684\u5efa\u8bbe\u4e0a\u3002DELL\u7684\u5b58\u50a8\u4ea7\u54c1\u7ec4\u5408\uff0c\u5305\u62ecPowerMax\u3001PowerStore\u3001PowerFlex\u548cPowerScale\uff0c\u4ee5\u53ca\u5373\u5c06\u63a8\u51fa\u7684Project Lightning\uff0c\u90fd\u663e\u793a\u51fa\u516c\u53f8\u5728\u6ee1\u8db3\u5ba2\u6237\u9700\u6c42\u65b9\u9762\u7684\u5dee\u5f02\u5316\u4f18\u52bf\u3002\u6b64\u5916\uff0c\u516c\u53f8\u8fd8\u8ba1\u5212\u5728\u672a\u67658\u523012\u4e2a\u6708\u5185\u5b9e\u73b0\u51b7\u5374\u5355\u5143\u548c\u51b7\u677f\u7684\u5782\u76f4\u6574\u5408\uff0c\u8fd9\u5c06\u8fdb\u4e00\u6b65\u589e\u5f3a\u5176\u7ade\u4e89\u4f18\u52bf\u3002<br/><br/>\u603b\u4f53\u800c\u8a00\uff0cDELL\u5bf9\u672a\u6765\u7684\u589e\u957f\u5145\u6ee1\u4fe1\u5fc3\uff0c\u7279\u522b\u662f\u5728AI\u670d\u52a1\u5668\u548c\u5b58\u50a8\u4e1a\u52a1\u65b9\u9762\u3002\u516c\u53f8\u5c06\u7ee7\u7eed\u901a\u8fc7\u521b\u65b0\u548c\u5f3a\u5316\u5ba2\u6237\u5173\u7cfb\u6765\u63a8\u52a8\u589e\u957f\uff0c\u5e76\u5728AI\u548c\u6570\u636e\u4e2d\u5fc3\u9886\u57df\u4fdd\u6301\u9886\u5148\u5730\u4f4d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259628571", "pub_date": "2024-12-05 09:52:13"}, {"id": 259628570, "title": "\u3010\u4f1a\u8bae\u7eaa\u8981\u3011Credo Technology(CRDO)\u4e1a\u7ee9\u589e\u957f\u5f3a\u52b2 AI\u9a71\u52a8\u672a\u6765\u53d1\u5c55", "description": "<p>\u91d1\u543e\u8d22\u8baf | Credo Technology Group Holding Ltd(CRDO)\u57282025\u8d22\u5e74\u7b2c\u4e8c\u5b63\u5ea6\u7684\u8d22\u62a5\u7535\u8bdd\u4f1a\u8bae\u4e0a\u516c\u5e03\u4e86\u5f3a\u52b2\u7684\u8d22\u52a1\u4e1a\u7ee9\u3002\u516c\u53f8\u7b2c\u4e8c\u5b63\u5ea6\u6536\u5165\u8fbe\u52307200\u4e07\u7f8e\u5143\uff0c\u73af\u6bd4\u589e\u957f21%\uff0c\u540c\u6bd4\u589e\u957f64%\u3002Non-GAAP\u6bdb\u5229\u7387\u4e3a63.6%\uff0c\u521b\u4e0b\u516c\u53f8\u5386\u53f2\u4e0a\u6700\u6210\u529f\u7684\u5b63\u5ea6\u4e4b\u4e00\u3002Credo\u5728\u4e09\u6761\u4e3b\u8981\u4ea7\u54c1\u7ebf\u4e0a\u5747\u5b9e\u73b0\u4e86\u521b\u7eaa\u5f55\u7684\u6536\u5165\uff0c\u5e76\u5f00\u59cb\u770b\u5230\u51fa\u8d27\u91cf\u7684\u589e\u957f\uff0c\u8fd9\u6807\u5fd7\u7740\u516c\u53f8\u6536\u5165\u62d0\u70b9\u7684\u5f00\u59cb\u3002<br/><br/>\u673a\u6784\u5206\u6790\u4eba\u58eb\u5bf9Credo\u7684\u8868\u73b0\u7ed9\u4e88\u4e86\u79ef\u6781\u8bc4\u4ef7\u3002\u4ed6\u4eec\u8ba4\u4e3a\uff0cCredo\u63d0\u4f9b\u7684\u4ee5\u592a\u7f51\u8fde\u63a5\u89e3\u51b3\u65b9\u6848\uff0c\u5305\u62ec\u4e3b\u52a8\u7535\u5b50\u7535\u7f06\uff08AEC\uff09\u3001\u5149\u57df\u4fe1\u53f7\u5904\u7406\u5668\uff08optical DSPs\uff09\u3001\u7ebf\u5361\u91cd\u5b9a\u65f6\u5668\u3001SerDes\u82af\u7247\u548cSerDes IP\u8bb8\u53ef\u8bc1\u7b49\uff0c\u6b63\u8fce\u5408\u4e86AI\u96c6\u7fa4\u67b6\u6784\u5feb\u901f\u53d1\u5c55\u7684\u9700\u6c42\u3002\u8fd9\u4e9b\u89e3\u51b3\u65b9\u6848\u5728\u5904\u7406\u3001\u51b7\u5374\u548c\u7535\u6e90\u65b9\u9762\u7684\u521b\u65b0\u4f7f\u5f97\u96c6\u7fa4\u66f4\u52a0\u5bc6\u96c6\u548c\u53ef\u6269\u5c55\uff0c\u800cCredo\u7684\u6280\u672f\u5728\u7ef4\u62a4\u4fe1\u53f7\u5b8c\u6574\u6027\u3001\u4f18\u5316\u80fd\u6548\u548c\u63d0\u4f9b\u65e0\u4e0e\u4f26\u6bd4\u7684\u53ef\u9760\u6027\u65b9\u9762\u8868\u73b0\u51fa\u8272\u3002\u7279\u522b\u662fAEC\u4ea7\u54c1\uff0c\u56e0\u5176\u5728\u964d\u4f4e\u529f\u8017\u3001\u964d\u4f4e\u6210\u672c\u548c\u63d0\u9ad8\u53ef\u9760\u6027\u65b9\u9762\u7684\u4f18\u52bf\uff0c\u6b63\u9010\u6e10\u53d6\u4ee3\u57fa\u4e8e\u6fc0\u5149\u7684\u5149\u901a\u4fe1\u4ea7\u54c1\u3002<br/><br/>\u5c55\u671b\u672a\u6765\uff0cCredo\u5bf9\u81ea\u8eab\u7684\u589e\u957f\u548c\u76c8\u5229\u80fd\u529b\u5145\u6ee1\u4fe1\u5fc3\u3002\u516c\u53f8\u9884\u8ba1\uff0c\u968f\u7740AI\u90e8\u7f72\u7684\u9700\u6c42\u589e\u52a0\u548c\u5ba2\u6237\u5173\u7cfb\u7684\u52a0\u6df1\uff0cCredo\u5c06\u7ee7\u7eed\u4fdd\u6301\u589e\u957f\u52bf\u5934\u3002Credo\u7684AEC\u4ea7\u54c1\u7ebf\u5728\u7b2c\u4e8c\u5b63\u5ea6\u5b9e\u73b0\u4e86\u521b\u7eaa\u5f55\u7684\u6536\u5165\uff0c\u5f97\u76ca\u4e8e\u524d\u4e24\u5927\u5ba2\u6237\u548c\u4e00\u4e2a\u65b0\u5174\u8d85\u5927\u89c4\u6a21\u8ba1\u7b97\u5ba2\u6237\u7684\u5f3a\u52b2\u9700\u6c42\u3002\u516c\u53f8\u8fd8\u63a8\u51fa\u4e86800\u5409\u6bd4\u7279ZeroFlap AEC\u4ea7\u54c1\uff0c\u652f\u6301\u957f\u8fbe7\u7c73\u7684AI\u540e\u7aef\u7f51\u7edc\u8fde\u63a5\u3002\u6b64\u5916\uff0cCredo\u5728\u5149\u5b66DSP\u4e1a\u52a1\u4e0a\u4e5f\u53d6\u5f97\u4e86\u521b\u7eaa\u5f55\u7684\u6536\u5165\uff0c\u9884\u8ba1200\u5409\u6bd4\u7279\u6bcf\u901a\u9053\u89e3\u51b3\u65b9\u6848\u5c06\u5728\u672a\u6765\u51e0\u4e2a\u5b63\u5ea6\u63a8\u52a8\u589e\u957f\u3002\u516c\u53f8\u8fd8\u8ba1\u5212\u57282025\u5e74\u65e5\u5386\u5e74\u5411\u5ba2\u6237\u63a8\u51faPCIe\u4ea7\u54c1\u6837\u54c1\uff0c\u5e76\u9884\u8ba1\u57282026\u5e74\u5b9e\u73b0\u751f\u4ea7\u6536\u5165\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259628570", "pub_date": "2024-12-05 09:52:23"}, {"id": 259628290, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u91d1\u5c71\u8f6f\u4ef6(03888)\u9006\u5e02\u53472.67% \u8fd1\u65e5\u83b7\u8d1d\u83b1\u5fb7\u589e\u6301\u8d85800\u4e07\u80a1", "description": "<p>\u91d1\u543e\u8d22\u8baf |  \u91d1\u5c71\u8f6f\u4ef6(03888)\u80a1\u4ef7\u9006\u5e02\u8d70\u9ad8\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da82.67%\uff0c\u62a532.65\u6e2f\u5143\uff0c\u6210\u4ea4\u989d5529.8\u4e07\u6e2f\u5143\u3002<br/><br/>\u636e\u9999\u6e2f\u8054\u4ea4\u624011\u670828\u65e5\u62ab\u9732\u7684\u6587\u4ef6\uff0c\u8d1d\u83b1\u5fb7(BlackRock, Inc.)\u4e8e11\u670825\u65e5\u4ee5\u6bcf\u80a1\u5747\u4ef731.9045\u6e2f\u5143\u589e\u6301\u91d1\u5c71\u8f6f\u4ef6805.84\u4e07\u80a1\u666e\u901a\u80a1\u80a1\u4efd\uff0c\u4ef7\u503c\u7ea62.57\u4ebf\u6e2f\u5143\u3002<br/><br/>\u589e\u6301\u540e\uff0c\u8d1d\u83b1\u5fb7\u6700\u65b0\u6301\u80a1\u6570\u76ee\u4e3a6,907.23\u4e07\u80a1\u80a1\u4efd\uff0c\u597d\u4ed3\u6bd4\u4f8b\u75314.57%\u5347\u81f35.17%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259628290", "pub_date": "2024-12-05 09:48:02"}, {"id": 259628371, "title": "TikTok\u201c\u9ed1\u8272\u661f\u671f\u4e94\u201d\u7684\u7f8e\u56fd\u5e97\u94fa\u9500\u552e\u989d\u589e\u957f\u4e24\u500d \u7a81\u78341\u4ebf\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u5a92\u4f53\u62a5\u9053\uff0cTikTok\u201c\u9ed1\u8272\u661f\u671f\u4e94\u201d\u7684\u7f8e\u56fd\u5e97\u94fa\u9500\u552e\u989d\u589e\u957f\u4e24\u500d\uff0c\u8d85\u8fc7\u4e861\u4ebf\u7f8e\u5143\u3002\u8be5\u516c\u53f8\u8868\u793a\uff0c\u201cTikTok\u5546\u5e97\u201d \u2014\u2014 TikTok\u7684\u7535\u5546\u529f\u80fd \u2014\u2014 \u5728\u201c\u9ed1\u8272\u661f\u671f\u4e94\u201d\u548c\u201c\u7f51\u7edc\u661f\u671f\u4e00\u201d\u4e4b\u95f4\u4e24\u5929\u5438\u5f15\u7684\u8d2d\u7269\u8005\u4e5f\u540c\u6bd4\u589e\u957f\u4e86165%\u3002TikTok\u8868\u793a\uff0c\u5e26\u6709#tiktokshopblackfriday\u6216#tiktokshopcybermonday\u6807\u7b7e\u7684\u5e16\u5b50\u88ab\u6d4f\u89c8\u4e86\u8d85\u8fc770\u4ebf\u6b21\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259628371", "pub_date": "2024-12-05 09:49:20"}, {"id": 259628370, "title": "\u7a7a\u4e2d\u5ba2\u8f66\u96c6\u56e2(EADSY)\u5ba3\u5e03\u5728\u9632\u52a1\u548c\u822a\u5929\u9886\u57df\u88c1\u5458\u8d852000\u4eba", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7a7a\u4e2d\u5ba2\u8f66\u96c6\u56e2(EADSY)\u5ba3\u5e03\u5728\u9632\u52a1\u548c\u822a\u5929\u9886\u57df\u88c1\u54582,000\u591a\u4eba\uff0c\u7ea6\u5360\u5176\u7b2c\u4e8c\u5927\u90e8\u95e8\u76845%\uff0c\u8fd9\u4e00\u51b3\u5b9a\u4e3b\u8981\u662f\u7531\u4e8e\u8be5\u516c\u53f8\u5728\u536b\u661f\u4e1a\u52a1\u4e0a\u9762\u4e34\u6765\u81ea\u7f8e\u56fd\u7684\u7ade\u4e89\u538b\u529b\u3002\u4e0d\u8fc7\uff0c\u5b9e\u9645\u7684\u88c1\u5458\u89c4\u6a21\u5e76\u6ca1\u6709\u8fbe\u5230\u516c\u53f8\u6700\u521d\u6240\u8b66\u544a\u7684\u7a0b\u5ea6\u3002\u5728\u8ba1\u5212\u88c1\u64a4\u76842043\u4e2a\u5c97\u4f4d\u4e2d\uff0c\u8d85\u8fc7\u534a\u6570\uff08\u5177\u4f53\u4e3a1128\u4e2a\u5c97\u4f4d\uff09\u5c06\u5f71\u54cd\u5230\u592a\u7a7a\u7cfb\u7edf\u4e1a\u52a1\u90e8\u95e8\uff0c\u56e0\u4e3a\u8be5\u90e8\u95e8\u7684\u536b\u661f\u4e1a\u52a1\u906d\u53d7\u4e86\u91cd\u5927\u635f\u5931\u3002\u5c3d\u7ba1\u5982\u6b64\uff0c\u7a7a\u4e2d\u5ba2\u8f66\u5f3a\u8c03\u5c06\u907f\u514d\u5f3a\u5236\u89e3\u96c7\u5458\u5de5\u3002\u8be5\u516c\u53f8\u4e0d\u4ec5\u751f\u4ea7\u536b\u661f\u548c\u8fd0\u8f93\u673a\uff0c\u8fd8\u5728\u6b27\u6d32\u7684\u5bfc\u5f39\u3001\u6218\u6597\u673a\u4ee5\u53ca\u592a\u7a7a\u53d1\u5c04\u9879\u76ee\u4e2d\u626e\u6f14\u7740\u5173\u952e\u89d2\u8272\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259628370", "pub_date": "2024-12-05 09:49:55"}, {"id": 259627912, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u6bd4\u4e9a\u8fea\u7535\u5b50(00285)\u4e00\u5ea6\u5347\u8fd13% \u90ed\u660e\u9324\u79f0\u516c\u53f8\u4e3a\u82f9\u679c\u667a\u80fd\u5bb6\u5c45\u5173\u952e\u4f9b\u5e94\u5546", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6bd4\u4e9a\u8fea\u7535\u5b50(00285)\u76d8\u521d\u9006\u5e02\u4e0a\u884c\uff0c\u4e00\u5ea6\u53472.93%\uff0c\u9ad8\u89c138.7\u6e2f\u5143\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u4ecd\u6da81.99%\uff0c\u62a538.35\u6e2f\u5143\uff0c\u6210\u4ea4\u989d8663.09\u4e07\u6e2f\u5143\u3002<br/><br/>\u5206\u6790\u5e08\u90ed\u660e\u9324\u53d1\u6587\u8868\u793a\uff0c\u82f9\u679c\u5c06\u8fdb\u519b\u667a\u80fd\u5bb6\u5c45\u9886\u57df\uff0c\u5e26\u6709\u5c4f\u5e55\u7684HomePod\u5c06\u4e8e\u660e\u5e74\u4eae\u76f8\u3002\u90ed\u660e\u9324\u5728\u62a5\u544a\u4e2d\u6307\u51fa\uff0c\u5e26\u5c4fHomePod\u91cf\u4ea7\u65f6\u95f4\u5ef6\u540e\u8fc7\u6570\u6b21\uff0c\u91cf\u4ea7\u5ef6\u540e\u7684\u4e3b\u8981\u539f\u56e0\u662f\u8f6f\u4ef6\u5f00\u53d1\uff0c\u5e26\u5c4fHomePod\u9884\u8ba1\u4f1a\u91c7\u7528A18\u5904\u7406\u5668\uff0c\u5c4f\u5e55\u57286-7\u82f1\u5bf8\u4e4b\u95f4\uff0c\u652f\u6301Apple Intelligence\u3002<br/><br/>\u4ed6\u5728\u62a5\u544a\u4e2d\u63d0\u5230\u6bd4\u4e9a\u8fea\u7535\u5b50\u4e0e\u5929\u9a6c\u5fae\u7535\u5b50\u4e3aApple\u667a\u80fd\u5bb6\u5c45\u5173\u952e\u4f9b\u5e94\u5546\uff0c\u5176\u4e2d\u6bd4\u4e9a\u8fea\u7535\u5b50\u4e3a\u914d\u5907\u5c4f\u5e55HomePod\u7684\u72ec\u5bb6\u7ec4\u88c5\u5382\u5546\uff0c\u914d\u5907M5\u5904\u7406\u5668\u7684iPadPro\u9884\u8ba1\u57282H25\u91cf\u4ea7\uff0c\u9884\u671f\u8be5\u516c\u53f82H25\u8425\u8fd0\u52a8\u80fd\u5c06\u663e\u8457\u53d7\u76ca\u4e8eApple\u65b0\u4ea7\u54c1\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259627912", "pub_date": "2024-12-05 09:42:09"}]}