\uff09\u4ee5\u65e7\u6362\u65b0\u653f\u7b56\u7684\u5b9e\u65bd\u4e3a\u533b\u9662\u63d0\u4f9b\u4e86\u989d\u5916\u8d44\u91d1\uff1b\u4ec5\u572811\u6708\uff0c\u5c31\u6709\u4eba\u6c11\u5e0125.5\u4ebf\u5143\u7684\u91c7\u8d2d\u8bbe\u5907\u662f\u901a\u8fc7\u4ee5\u65e7\u6362\u65b0\u8ba1\u5212\u8d44\u52a9\u7684\u30022\uff09\u8bb8\u591a\u533b\u9662\u539f\u672c\u9884\u671f\u4f1a\u4ece\u523a\u6fc0\u8ba1\u5212\u4e2d\u83b7\u5f97\u8d44\u91d1\uff0c\u4f46\u6700\u7ec8\u4e0d\u7b26\u5408\u8d44\u683c\u3002\u56e0\u6b64\uff0c\u8fd9\u4e9b\u533b\u9662\u4e0d\u5f97\u4e0d\u4f7f\u7528\u81ea\u5df1\u7684\u73b0\u91d1\u8d44\u6e90\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u968f\u7740\u4ee5\u65e7\u6362\u65b0\u653f\u7b56\u7684\u6301\u7eed\u8fdb\u884c\u548c\u5ef6\u8fdf\u8ba2\u5355\u7684\u5c65\u884c\uff0c\u8be5\u884c\u9884\u8ba1\u533b\u9662\u8d44\u672c\u652f\u51fa\u8bbe\u5907\u7684\u6062\u590d\u5c06\u572812\u6708\u7ee7\u7eed\uff0c\u8fd9\u901a\u5e38\u662f\u4e2d\u56fd\u6700\u7e41\u5fd9\u7684\u4e00\u4e2a\u6708\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260391121", "pub_date": "2024-12-12 11:30:50"}, {"id": 260391223, "title": "\u3010AH\u4e92\u52a8\u3011A\u80a1\u4e09\u5927\u6307\u6570\u4f4e\u5f00\u9ad8\u8d70 \u6caa\u6307\u534a\u65e5\u6da80.64% \u767d\u9152\u3001\u8bc1\u5238\u7b49\u677f\u5757\u6982\u5ff5\u6da8\u5e45\u5c45\u524d", "description": "<p>\u91d1\u543e\u8d22\u8baf | A\u80a1\u4e09\u5927\u6307\u6570\u4f4e\u5f00\u9ad8\u8d70\uff0c\u622a\u81f3\u5348\u95f4\u6536\u76d8\uff0c\u6caa\u6307\u6da80.64%\uff0c\u6df1\u8bc1\u6210\u6307\u6da80.79%\uff0c\u521b\u4e1a\u677f\u6307\u6da81.47%\u3002<br/><br/>\u677f\u5757\u65b9\u9762\uff0c\u96f6\u552e\u3001\u767d\u9152\u3001\u8bc1\u5238\u7b49\u677f\u5757\u6982\u5ff5\u6da8\u5e45\u5c45\u524d\uff1b\u6d88\u8d39\u7535\u5b50\u3001\u534a\u5bfc\u4f53\u3001\u81ea\u52a8\u5316\u8bbe\u5907\u7b49\u677f\u5757\u6982\u5ff5\u8dcc\u5e45\u5c45\u524d\u3002<br/><br/>\u5149\u5927\u8bc1\u5238\u8868\u793a\uff0c\u653f\u6cbb\u5c40\u63d0\u51fa\u8981\u5b9e\u65bd\u66f4\u52a0\u5bbd\u677e\u7684\u653f\u7b56\u3001\u5927\u529b\u63d0\u632f\u6d88\u8d39\u548c\u5f15\u9886\u65b0\u8d28\u751f\u4ea7\u529b\u53d1\u5c55\uff0c\u6c7d\u8f66\u884c\u4e1a\u667a\u80fd\u5316\u65b9\u5411\u4e0d\u4ec5\u7b26\u5408\u8be5\u53d1\u5c55\u5b9a\u8c03\uff0c\u5bf9\u6d88\u8d39\u63d0\u632f\u4e5f\u8d77\u5230\u91cd\u8981\u4f5c\u7528\uff0c\u540c\u65f6\u884c\u4e1a\u6d89\u53ca\u5230\u5927\u89c4\u6a21\u8bbe\u5907\u66f4\u65b0\u548c\u6d88\u8d39\u54c1\u4ee5\u65e7\u6362\u65b0\u7684\u201c\u4e24\u65b0\u201d\u4e3b\u9898\uff0c\u8be5\u884c\u6301\u7eed\u770b\u597d\u653f\u7b56\u5229\u597d\u9a71\u52a8\u4e0b\u7684\u6c7d\u8f66\u677f\u5757\u6295\u8d44\u673a\u4f1a\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260391223", "pub_date": "2024-12-12 11:31:55"}, {"id": 260390923, "title": "\u6e2f\u5143\u62c6\u606f\u591a\u6570\u4e0a\u6da8 \u9694\u591c\u62c6\u606f\u8dcc\u81f33.91036\u5398", "description": "<p>\u91d1\u543e\u8d22\u8baf | 2024\u5e7412\u670811\u65e5\uff0c\u6e2f\u5143\u62c6\u606f\u591a\u6570\u4e0a\u6da8\uff0c\u9694\u591c\u62c6\u606f\u8dcc\u81f33.91036\u5398\uff1b1\u661f\u671f\u62c6\u606f\u8dcc\u81f34.08119\u5398\uff1b2\u661f\u671f\u62c6\u606f\u5347\u81f34.13524\u5398\u3002<br/><br/>\u53e6\u5916\uff0c\u4e0e\u697c\u6309\u76f8\u5173\u76841\u4e2a\u6708\u62c6\u606f\u5347\u81f34.48125\u5398\uff1b\u53cd\u6620\u94f6\u884c\u8d44\u91d1\u6210\u672c\u76843\u4e2a\u6708\u62c6\u606f\u5347\u81f34.38315\u5398\u3002<br/><br/>\u957f\u606f\u65b9\u9762\uff0c6\u4e2a\u6708\u62c6\u606f\u5347\u81f34.16089\u5398\uff1b1\u5e74\u671f\u62c6\u606f\u7ef4\u63014.10000\u5398\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260390923", "pub_date": "2024-12-12 11:28:02"}, {"id": 260389750, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u9ad8\u76db\u4e88\u6bd4\u4e9a\u8fea(01211)\u201c\u4e70\u5165\u201d\u8bc4\u7ea7 \u6599\u6708\u5ea6\u4ea4\u4ed8\u91cf\u548c\u5e73\u5747\u552e\u4ef7\u5c06\u7ee7\u7eed\u589e\u52a0", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9ad8\u76db\u8868\u793a\uff0c\u6bd4\u4e9a\u8fea(01211)\u572811\u6708\u7684\u540c\u6bd4\u9500\u91cf\u589e\u957f\u4e8659%\uff0c\u5e02\u573a\u4efd\u989d\u540c\u6bd4\u589e\u957f\u6700\u9ad8\uff0c\u8fbe\u5230\u4e861.7\u4e2a\u767e\u5206\u70b9\u3002\u5e73\u5747\u4ea4\u6613\u4ef7\u683c\u4e5f\u4fdd\u6301\u7a33\u5b9a\uff0c\u73af\u6bd4\u589e\u957f1%\u3002\u6bd4\u4e9a\u8fea\u4e8e2024\u5e7411\u6708\u5f00\u59cb\u4e86\u4e24\u6b3e\u9ad8\u7aef\u8f66\u578b\u7684\u4ea4\u4ed8\u2014\u2014\u817e\u52bfZ9 GT\uff08711\u8f86\uff09\u548c\u65b9\u7a0b\u8c79\u8c7908\uff082,500\u8f86\uff09\u3002<br/><br/>\u5c55\u671b\u672a\u6765\uff0c\u8be5\u884c\u9884\u8ba1\u968f\u77401\uff09\u817e\u52bfZ9 GT\u548c\u65b9\u7a0b\u8c79\u8c7908\u4ea7\u91cf\u7684\u6301\u7eed\u63d0\u5347\uff1b2\uff09\u53e6\u4e00\u6b3e\u9ad8\u7aef\u8f66\u578b\u817e\u52bfZ9\u4e8e12\u67086\u65e5\u5f00\u59cb\u4ea4\u4ed8\uff1b3\uff09\u516c\u53f8\u7ee7\u7eed\u8c03\u6574\u751f\u4ea7\u80fd\u529b\u4ee5\u6ee1\u8db3\u4e0d\u65ad\u589e\u957f\u7684\u9700\u6c42\uff0c\u6708\u5ea6\u4ea4\u4ed8\u91cf\u548c\u5e73\u5747\u552e\u4ef7\u5c06\u589e\u52a0\u3002<br/><br/>\u8be5\u884c\u4e88\u6bd4\u4e9a\u8fea\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0c\u76ee\u6807\u4ef7376\u5143\u4eba\u6c11\u5e01/359\u6e2f\u5143\u3002\u98ce\u9669\u5305\u62ec\uff1a(1) \u7535\u52a8\u6c7d\u8f66\u5e02\u573a\u7ade\u4e89\u52a0\u5267\uff1b(2) \u6d77\u5916\u6269\u5c55\u8fdb\u5ea6\u6162\u4e8e\u9884\u671f\uff1b(3) \u5916\u90e8\u7535\u6c60\u9500\u552e\u4f4e\u4e8e\u9884\u671f\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/260389750", "pub_date": "2024-12-12 11:16:56"}, {"id": 260390041, "title": "\u4e2d\u8d44\u5238\u5546\u80a1\u77ed\u7ebf\u6025\u5347 \u56fd\u8054\u8bc1\u5238(01456)\u6da85.58% \u6469\u6839\u5927\u901a\u6307\u653f\u6cbb\u5c40\u4f1a\u8bae\u5bf9\u4e2d\u56fd\u91d1\u878d\u80a1\u6709\u6b63\u9762\u53cd\u5e94", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u8d44\u5238\u5546\u80a1\u77ed\u7ebf\u6025\u5347\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u56fd\u8054\u8bc1\u5238(01456)\u6da85.58%\uff0c\u4e2d\u5dde\u8bc1\u5238(01375)\u6da83.78%\uff0c\u62db\u5546\u8bc1\u5238(06099)\u6da83.31%\uff0c\u5174\u8bc1\u56fd\u9645(06058)\u6da82.65%\uff0c\u4e2d\u56fd\u94f6\u6cb3(06881)\u6da82.15%\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u6469\u6839\u5927\u901a\u53d1\u7814\u62a5\u6307\uff0c\u4e2d\u592e\u653f\u6cbb\u5c40\u6700\u8fd1\u91ca\u51fa\u652f\u6301\u5b8f\u89c2\u7ecf\u6d4e\u548c\u80a1\u5e02\u7684\u5f3a\u800c\u6709\u529b\u57fa\u8c03\uff0c\u6599\u5bf9\u4e2d\u56fd\u91d1\u878d\u80a1\u6709\u6b63\u9762\u53cd\u5e94\uff0c\u76f8\u4fe1\u77ed\u671f\u5238\u5546\u80a1\u7684\u8868\u73b0\u5c06\u8dd1\u8d62\u5185\u94f6\u80a1\uff0c\u66f4\u4e3a\u770b\u597d\u4e2d\u56fd\u94f6\u6cb3\u3002\u8be5\u884c\u9884\u671f\uff0c\u53d7\u8d38\u6613\u7d27\u5f20\u5c40\u52bf\u7684\u5f71\u54cd\uff0c\u660e\u5e74\u9996\u5b63\u80a1\u7968\u5e02\u573a\u6ce2\u52a8\uff0c\u4f46\u6765\u81ea\u4e2d\u56fd\u8fdb\u4e00\u6b65\u653f\u7b56\u652f\u6301\u7684\u9884\u671f\uff0c\u5e94\u4f1a\u9650\u5236\u4e2d\u56fd\u91d1\u878d\u80a1\u7684\u4e0b\u884c\u98ce\u9669\u3002<br/><br/>\u56fd\u91d1\u8bc1\u5238\u53d1\u5e03\u7814\u62a5\u79f0\uff0c\u5c55\u671b25\u5e74\uff0c\u6d41\u52a8\u6027\u6709\u671b\u8fdb\u4e00\u6b65\u5bbd\u677e\uff0c\u63d0\u9ad8\u5e02\u573a\u7684\u7a33\u5b9a\u6027\uff0c\u5e76\u6784\u7b51\u575a\u5b9e\u5e02\u573a\u5e95\u90e8\uff0c\u7ecf\u6d4e\u57fa\u672c\u9762\u6539\u5584\u5f97\u5230\u786e\u8ba4\uff0c\u80a1\u5e02\u6709\u671b\u8fdb\u4e00\u6b65\u4e0a\u884c\uff0c\u5229\u597d\u5238\u5546\u677f\u5757\u4f30\u503c\u548c\u4e1a\u7ee9\u53cc\u63d0\u5347\u3002\u590d\u76d8\u5386\u6b21\u6d41\u52a8\u6027\u5bbd\u677e\u80cc\u666f\u4e0b\u5238\u5546\u4f30\u503c\u6269\u5f20\u81f31.9X\u4ee5\u4e0a\uff0c\u5f53\u524d\u5238\u5546\u4f30\u503c\u4ec5\u4e3a1.6X\uff0c\u7efc\u5408\u6765\u770b\u5177\u6709\u4e00\u5b9a\u7684\u4e0a\u6da8\u7a7a\u95f4\u3002\u63a8\u8350\u5f3a\u8d1d\u5854\u4e1a\u52a1\u4e3b\u7ebf(\u6743\u76ca\u6295\u8d44\u5f39\u6027+\u4ea4\u6295\u5f39\u6027)\u5238\u5546\u57fa\u672c\u9762\u66f4\u52a0\u53d7\u76ca\u6743\u76ca\u5e02\u573a\u56de\u6696\uff0c\u4ee5\u53ca\u5e76\u8d2d\u91cd\u7ec4\u4e3b\u7ebf\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/260390041", "pub_date": "2024-12-12 11:19:42"}, {"id": 260389366, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u9ad8\u76db\u4e88\u851a\u6765(09866)\u201c\u6cbd\u552e\u201d\u8bc4\u7ea7 \u6307\u4e50\u9053L60\u4ea4\u4ed8\u91cf\u900a\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9ad8\u76db\u8868\u793a\uff0c\u851a\u6765(09866)11\u6708\u7684\u9500\u91cf\u73af\u6bd4\u4e0b\u964d\u4e860.2%\uff0c\u5e73\u5747\u4ea4\u6613\u4ef7\u683c\u73af\u6bd4\u4e0b\u964d\u4e862%\uff0c\u8be5\u884c\u8ba4\u4e3a\u851a\u6765\u5728\u8fdb\u51652025\u5e74\u7684\u9884\u671f\u4e2d\u5904\u4e8e\u4e0d\u5229\u4f4d\u7f6e\uff0c\u56e0\u4e3a1\uff09\u851a\u6765\u4ea4\u4ed8\u4e865,000\u8f86\u4e50\u9053L60\uff0c\u8f83\u8be5\u884c\u9884\u671f\u76847000\u8f86\u5c1127%\u3002\u8be5\u884c\u8ba4\u4e3a\u7f13\u6162\u7684\u751f\u4ea7\u722c\u5761\u8fdb\u5ea6\u4f1a\u5bf9\u8be5\u8f66\u578b\u7684\u8ba2\u5355\u52bf\u5934\u4ea7\u751f\u8d1f\u9762\u5f71\u54cd\uff1b2\uff09\u851a\u6765\u54c1\u724c\u660e\u5e74\u5c06\u53ea\u6709\u4e00\u6b3e\u65b0\u8f66\u578b\u53d1\u5e03\uff0c\u5728\u5e94\u5bf9\u7ade\u4e89\u5bf9\u624b\u7684\u65b0\u4ea7\u54c1\u65f6\u5904\u4e8e\u88ab\u52a8\u5730\u4f4d\uff1b3\uff09\u968f\u7740\u4e50\u9053\u9500\u552e\u7f51\u7edc\u6269\u5f20\u5e26\u6765\u7684\u9500\u552e\u548c\u7ba1\u7406\u8d39\u7528\u7684\u589e\u957f\u4ee5\u53ca\u7814\u53d1\u8d39\u7528\u7684\u63d0\u9ad8\uff0c\u8fd9\u5c06\u62d6\u7d2f\u8fd0\u8425\u4e8f\u635f\u3002<br/><br/>\u8be5\u884c\u4e88\u851a\u6765\u201c\u6cbd\u552e\u201d\u8bc4\u7ea7\uff0c\u76ee\u6807\u4ef73.9\u7f8e\u5143/30\u6e2f\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260389366", "pub_date": "2024-12-12 11:12:51"}, {"id": 260388798, "title": "\u4eba\u793e\u90e8\u7b49\u4e94\u90e8\u95e8\uff1a\u4e2a\u4eba\u517b\u8001\u91d1\u5236\u5ea6\u5c06\u4ece36\u4e2a\u8bd5\u70b9\u57ce\u5e02\u63a8\u5411\u5168\u56fd", "description": "<p>\u91d1\u543e\u8d22\u8baf | 12\u670812\u65e5\uff0c\u4eba\u529b\u8d44\u6e90\u793e\u4f1a\u4fdd\u969c\u90e8\u7b49\u4e94\u90e8\u95e8\u53d1\u5e03\u901a\u77e5\uff0c\u81ea12\u670815\u65e5\u8d77\uff0c\u4e2a\u4eba\u517b\u8001\u91d1\u5236\u5ea6\u5c06\u4ece36\u4e2a\u8bd5\u70b9\u57ce\u5e02\u63a8\u5411\u5168\u56fd\u3002\u8be5\u5236\u5ea6\u4e3a\u4e2a\u4eba\u81ea\u613f\u53c2\u52a0\uff0c\u5e02\u573a\u5316\u8fd0\u8425\uff0c\u5e76\u63d0\u4f9b\u56fd\u5bb6\u653f\u7b56\u652f\u6301\u7684\u8865\u5145\u517b\u8001\u4fdd\u9669\u3002\u4e2a\u4eba\u517b\u8001\u91d1\u8d26\u6237\u6bcf\u5e74\u5b58\u6b3e\u4e0d\u8d85\u8fc71.2\u4e07\u5143\uff0c\u53ef\u7528\u4e8e\u8d2d\u4e70\u7b26\u5408\u89c4\u5b9a\u7684\u91d1\u878d\u4ea7\u54c1\uff0c\u5e76\u4eab\u53d7\u7f34\u8d39\u5ef6\u671f\u5f81\u7a0e\u4f18\u60e0\u3002\u901a\u77e5\u8fd8\u8981\u6c42\u4f18\u5316\u4ea7\u54c1\u4f9b\u7ed9\uff0c\u5c06\u7279\u5b9a\u517b\u8001\u50a8\u84c4\u548c\u6307\u6570\u57fa\u91d1\u7b49\u7eb3\u5165\u4ea7\u54c1\u76ee\u5f55\uff0c\u5e76\u589e\u52a0\u4e86\u91cd\u5927\u75be\u75c5\u7b49\u60c5\u51b5\u4e0b\u7684\u63d0\u524d\u9886\u53d6\u6761\u4ef6\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/260388798", "pub_date": "2024-12-12 11:06:16"}, {"id": 260388799, "title": "\u535a\u5f69\u80a1\u90e8\u5206\u8d70\u5f3a \u91d1\u6c99\u4e2d\u56fd(01928)\u6da83.56% \u6469\u6839\u5927\u901a\u6599Q4\u6fb3\u95e8\u535a\u5f69\u6536\u5165\u5c06\u6309\u5b63\u589e\u957f3%\u81f34%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u535a\u5f69\u80a1\u90e8\u5206\u8d70\u5f3a\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u91d1\u6c99\u4e2d\u56fd(01928)\u6da83.56%\uff0c\u7f8e\u9ad8\u6885\u4e2d\u56fd(02282)\u6da82.45%\uff0c\u94f6\u6cb3\u5a31\u4e50(00027)\u6da81.11%\uff0c\u6c38\u5229\u6fb3\u95e8(01128)\u8ddf\u6da8\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u6469\u6839\u5927\u901a\u53d1\u7814\u62a5\u6307\uff0c\u6fb3\u95e812\u6708\u9996\u516b\u65e5\u7684\u535a\u5f69\u6bdb\u6536\u5165\u4e3a45\u4ebf(\u6fb3\u95e8\u5143\uff0c\u4e0b\u540c)\uff0c\u76f8\u5f53\u4e8e\u6bcf\u65e55.62\u4ebf\u5143\uff0c\u8f8311\u6708\u65e5\u5747\u535a\u5f69\u6536\u5165\u4f4e\u51fa9%\uff0c\u4f46\u5c5e\u9884\u671f\u4e4b\u5185\u3002\u671f\u5185\uff0c\u4e2d\u573a\u4e1a\u52a1\u7684\u535a\u5f69\u6bdb\u6536\u5165\u7ea6\u4e3a\u75ab\u60c5\u524d\u6c34\u5e73\u7684105%\uff0c\u800c\u8d35\u5bbe\u5385\u5219\u6062\u590d\u81f3\u7ea620%\u81f323%\u3002\u867d\u7136\u9884\u8ba112\u6708\u535a\u5f69\u6536\u5165\u589e\u957f\u5c06\u4f1a\u653e\u7f13\uff0c\u4f46\u9884\u8ba1\u7b2c\u56db\u5b63\u4ecd\u5c06\u6309\u5b63\u589e\u957f3%\u81f34%\uff0c\u8fbe\u523020\u4e2a\u5b63\u5ea6\u4ee5\u6765\u7684\u6700\u9ad8\u6c34\u5e73\uff0c\u8ba4\u4e3a\u8fd9\u4e2a\u589e\u957f\u52bf\u5934\u5e94\u80fd\u652f\u6301\u884c\u4e1a\u8fbe\u5230\u7b2c\u56db\u5b63\u4ee5\u53ca\u4eca\u8d22\u5e74\u7684\u666e\u904d\u9884\u671f\u3002<br/><br/>\u9ad8\u76db\u53d1\u5e03\u7814\u62a5\u6307\u51fa\uff0c\u75ab\u540e\u4e24\u5e74\uff0c\u4e2d\u56fd\u65c5\u6e38\u9700\u6c42\u5df2\u5927\u81f4\u6062\u590d\u6b63\u5e38\uff0c\u9884\u671f\u5185\u5730\u660e\u5e74\u51fa\u5883\u6e38\u548c\u5165\u5883\u6e38\u5c06\u540c\u6b65\u589e\u957f\uff0c\u9664\u5bf9\u7ebf\u4e0a\u65c5\u6e38\u5e73\u53f0(OTA)\u6709\u5229\u5916\uff0c\u4ea6\u5c06\u63a8\u52a8\u9152\u5e97\u548c\u822a\u7a7a\u4e1a\u53d1\u5c55\uff0c\u76ee\u524d\u9884\u6d4b\u4e2d\u56fd\u65c5\u6e38\u3001\u4f11\u95f2\u4e0e\u4ea4\u901a\u677f\u5757\u80a1\u4ef7\u4f1a\u4e8e\u660e\u5e74\u9996\u5b63\u672b\u8d77\u4f01\u7a33\uff0c\u9152\u5e97\u53ca\u822a\u7a7a\u516c\u53f8\u4f30\u503c\u6599\u89c1\u4f4e\u56de\u5347\u3002\u8be5\u884c\u540c\u65f6\u4ea6\u770b\u597d\u6fb3\u95e8\u535a\u5f69\u884c\u4e1a\u53ef\u53d7\u60e0\u4e8e\u653f\u7b56\u652f\u6301\uff0c\u5e02\u573a\u60c5\u7eea\u53ef\u80fd\u6539\u5584\uff0c\u9884\u671f\u8be5\u884c\u4e1a\u5728\u5e02\u573a\u7ade\u4e89\u51cf\u7f13\u4e0b\u7684\u5229\u6da6\u538b\u529b\u5c06\u4f1a\u51cf\u5c11\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260388799", "pub_date": "2024-12-12 11:06:27"}]}