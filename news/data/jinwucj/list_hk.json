{"data": [{"id": 259304334, "title": "\u82f1\u56fd11\u6708\u5236\u9020\u4e1aPMI\u7ec8\u503c48 \u9884\u671f48.6 \u524d\u503c48.6", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u82f1\u56fd11\u6708\u5236\u9020\u4e1aPMI\u7ec8\u503c48\uff0c\u9884\u671f48.6\uff0c\u524d\u503c48.6\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259304334", "pub_date": "2024-12-02 20:32:22"}, {"id": 259303110, "title": "\u5fb7\u56fd11\u6708\u5236\u9020\u4e1aPMI\u7ec8\u503c43 \u9884\u671f43.2 \u524d\u503c43.2", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5fb7\u56fd11\u6708\u5236\u9020\u4e1aPMI\u7ec8\u503c43\uff0c\u9884\u671f43.2\uff0c\u524d\u503c43.2\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259303110", "pub_date": "2024-12-02 20:24:52"}, {"id": 259301439, "title": "\u6b27\u5143\u533a11\u6708\u5236\u9020\u4e1aPMI\u7ec8\u503c45.2 \u9884\u671f45.2 \u524d\u503c45.2", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6b27\u5143\u533a11\u6708\u5236\u9020\u4e1aPMI\u7ec8\u503c45.2\uff0c\u9884\u671f45.2\uff0c\u524d\u503c45.2\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259301439", "pub_date": "2024-12-02 20:13:22"}, {"id": 259301590, "title": "\u6cd5\u56fd11\u6708\u5236\u9020\u4e1aPMI\u7ec8\u503c43.1 \u9884\u671f43.2 \u524d\u503c43.2", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6cd5\u56fd11\u6708\u5236\u9020\u4e1aPMI\u7ec8\u503c43.1\uff0c\u9884\u671f43.2\uff0c\u524d\u503c43.2\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259301590", "pub_date": "2024-12-02 20:14:17"}, {"id": 259294433, "title": "\u4eac\u4e1c(JD)\u76d8\u524d\u6da8\u8d851% \u673a\u6784\u6307\u516c\u53f8Q3\u673a\u6784\u8d85\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4eac\u4e1c(JD)\u76d8\u524d\u6da8\u8d851%\uff0c\u622a\u6b62\u53d1\u7a3f\uff0c\u62a538.03\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u4ea4\u94f6\u56fd\u9645\u53d1\u62a5\u544a\u6307\uff0c\u4eac\u4e1c2024\u5e743\u5b63\u5ea6\u6536\u5165\u7b26\u5408\u9884\u671f\uff0c\u5229\u6da6\u8d85\u9884\u671f\u3002\u5c55\u671b4\u5b63\u5ea6\uff0c\u8be5\u884c\u9884\u8ba1\u6536\u5165\u540c\u6bd4\u589e5.7%\uff0c\u53cc\u5341\u4e00\u6570\u636e\u597d\u4e8e\u9884\u671f\u3002\u9884\u8ba12024\u5e74\u516c\u53f8\u6574\u4f53\u5229\u6da6\u540c\u6bd4\u589e28%\u81f3450\u4ebf\uff0c\u8f83\u8be5\u884c\u6b64\u524d\u9884\u671f\u4e0a\u8c035%\uff0c\u53cd\u6620\u7269\u6d41\u76c8\u5229\u80fd\u529b\u91ca\u653e\u5e26\u6765\u7684\u5229\u597d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259294433", "pub_date": "2024-12-02 19:26:56"}, {"id": 259296801, "title": "\u4e07\u4e8b\u8fbe(MA)\uff1a\u7f8e\u56fd\u201c\u9ed1\u4e94\u201d\u7ebf\u4e0b\u9500\u552e\u4f4e\u8ff7 \u7535\u5546\u6d88\u8d39\u540c\u6bd4\u5927\u5e45\u589e\u957f14.6%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e07\u4e8b\u8fbe(MA)\u548c\u5176\u4ed6\u6570\u636e\u63d0\u4f9b\u5546\u7684\u6570\u636e\u663e\u793a\uff0c\u4eca\u5e74\u201c\u9ed1\u8272\u661f\u671f\u4e94\u201d\uff0c\u7f8e\u56fd\u96f6\u552e\u5546\u5e97\u7684\u9500\u552e\u4f4e\u8ff7\uff0c\u76f8\u6bd4\u4e4b\u4e0b\uff0c\u5728\u7ebf\u6d88\u8d39\u589e\u957f\u5219\u66f4\u4e3a\u5f3a\u52b2\u3002\u636e\u4e07\u4e8b\u8fbe\u5361\u7684\u521d\u6b65\u4f30\u8ba1\uff0c\u201c\u9ed1\u8272\u661f\u671f\u4e94\u201d\u7f8e\u56fd\u96f6\u552e\u5b9e\u4f53\u5e97\u7684\u9500\u552e\u989d\u540c\u6bd4\u4ec5\u589e\u957f0.7%\uff0c\u7535\u5546\u5728\u7ebf\u9500\u552e\u989d\u5219\u5927\u5e45\u589e\u957f14.6%\uff0c\u8be5\u6307\u6807\u8861\u91cf\u7684\u662f\u4e07\u4e8b\u8fbe\u5361\u652f\u4ed8\u7f51\u7edc\u7684\u96f6\u552e\u9500\u552e\u989d\uff0c\u4ee5\u53ca\u5bf9\u73b0\u91d1\u548c\u652f\u7968\u652f\u4ed8\u7684\u4f30\u7b97\uff0c\u4f30\u7b97\u503c\u5e76\u672a\u6839\u636e\u901a\u80c0\u7387\u8fdb\u884c\u8c03\u6574\u3002<br/><br/>\u6839\u636e\u6570\u636e\u516c\u53f8Facteus\u7684\u6570\u636e\uff0c\u5b9e\u4f53\u5e97\u9500\u552e\u989d\u540c\u6bd4\u4e0b\u964d5.4%\uff0c\u7ebf\u4e0a\u9500\u552e\u989d\u5219\u540c\u6bd4\u589e\u957f11.1%\uff1b\u82e5\u8ba1\u5165\u901a\u80c0\uff0c\u5b9e\u4f53\u5e97\u9500\u552e\u989d\u540c\u6bd4\u4e0b\u964d8%\uff0c\u7ebf\u4e0a\u9500\u552e\u989d\u540c\u6bd4\u589e\u957f8.5%\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259296801", "pub_date": "2024-12-02 19:42:02"}, {"id": 259298589, "title": "\u6b27\u5143\u533a10\u6708\u5931\u4e1a\u73876.3%\uff0c\u9884\u671f6.3%\uff0c\u524d\u503c6.30%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6b27\u5143\u533a10\u6708\u5931\u4e1a\u73876.3%\uff0c\u9884\u671f6.3%\uff0c\u524d\u503c6.30%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259298589", "pub_date": "2024-12-02 19:54:55"}, {"id": 259290771, "title": "\u53f0\u79ef\u7535(TSM)\u76d8\u524d\u6da8\u8d851% \u4f20\u82f9\u679c(AAPL)\u5df2\u4ece\u53f0\u79ef\u7535\u8ba2\u8d2dM5\u82af\u7247", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u53f0\u79ef\u7535(TSM)\u76d8\u524d\u6da8\u8d851%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a5187.8\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u636e\u5e02\u573a\u5a92\u4f53\u62a5\u9053\uff0c\u82f9\u679c(AAPL)\u5df2\u7ecf\u4ece\u53f0\u79ef\u7535\u8ba2\u8d2d\u4e86M5\u82af\u7247\u3002\u62a5\u9053\u79f0\uff0cM5\u7cfb\u5217\u82af\u7247\u9884\u8ba1\u5c06\u91c7\u7528\u589e\u5f3a\u578bARM\u67b6\u6784\uff0c\u540c\u65f6\u51fa\u4e8e\u6210\u672c\u8003\u8651\uff0c\u82f9\u679c\u5c06\u4f7f\u7528\u53f0\u79ef\u75353nm\u5de5\u827a\u6280\u672f\u751f\u4ea7M5\u7cfb\u5217\u82af\u7247\u3002\u867d\u7136\u4ecd\u7136\u91c7\u75283nm\u5de5\u827a\u6280\u672f\uff0c\u4e0d\u8fc7M5\u7684\u6027\u80fd\u5bf9\u6bd4M4 \uff0c\u4ecd\u7136\u6709\u663e\u8457\u63d0\u5347\u3002\u56e0\u4e3aM5\u7cfb\u5217\u82af\u7247\u5c06\u91c7\u7528\u53f0\u79ef\u7535\u7684\u96c6\u6210\u82af\u7247\u7cfb\u7edf (SoIC) \u6280\u672f\u3002SoIC\u6280\u672f\u53ef\u4ee5\u5c06\u82af\u7247\u5806\u53e0\u6210\u4e09\u7ef4\u7684\u7ed3\u6784\uff0c\u4ece\u800c\u5b9e\u73b0\u66f4\u597d\u7684\u70ed\u7ba1\u7406\u4ee5\u53ca\u51cf\u5c11\u6f0f\u7535\u3002\u800c\u7b2c\u4e00\u6279\u914d\u5907M5\u7684\u8bbe\u5907\uff0c\u53ef\u80fd\u4f1a\u5728\u660e\u5e74\u5e95\u62162026\u5e74\u521d\u63a8\u51fa\u3002</p><p><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259290771", "pub_date": "2024-12-02 19:01:41"}, {"id": 259291496, "title": "\u7406\u60f3\u6c7d\u8f66(LI)\u76d8\u524d\u8dcc\u8d853% 11\u6708\u4ea4\u4ed8\u91cf\u73af\u6bd4\u4e0b\u6ed15.25%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7406\u60f3\u6c7d\u8f66(LI)\u76d8\u524d\u8dcc\u8d853%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a522.83\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u7406\u60f3\u6c7d\u8f66\u516c\u5e03\uff0c11\u6708\u4ea4\u4ed848740\u8f86\uff0c\u540c\u6bd4\u589e\u957f18.8%\uff0c\u73af\u6bd4\u5219\u4e0b\u6ed15.25%\uff0c\u8fd9\u662f\u7406\u60f3\u6c7d\u8f66\u8fde\u7eed\u4e24\u4e2a\u6708\u73af\u6bd4\u4e0b\u6ed1\u3002\u503c\u5f97\u6ce8\u610f\u7684\u662f\uff0c\u622a\u81f311\u6708\u5e95\uff0c\u7406\u60f3\u6c7d\u8f66\u4eca\u5e74\u7d2f\u8ba1\u4ea4\u4ed8441995\u8f86\uff0c\u82e5\u5b8c\u6210\u5168\u5e74\u9500\u91cf\u76ee\u6807\uff0c12\u6708\u9700\u4ea4\u4ed811.8\u4e07\u8f86\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259291496", "pub_date": "2024-12-02 19:06:38"}, {"id": 259291934, "title": "\u5df4\u514b\u83b1\uff1a\u73af\u7403\u80a1\u503a\u5e02\u573a\u6d3b\u529b\u53ef\u5ef6\u7eed\u52302025\u5e74 \u7f8e\u80a1\u548c\u4e9a\u80a1\u6709\u5f88\u5927\u673a\u4f1a\u8dd1\u8d62\u6b27\u80a1", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u603b\u7edf\u5373\u5c06\u6362\u5c4a\uff0c\u4e3a\u8d44\u672c\u5e02\u573a\u5e26\u6765\u66f4\u591a\u4e0d\u660e\u6717\u56e0\u7d20\uff0c\u60df\u5df4\u514b\u83b1\u96c6\u56e2\u6267\u884c\u59d4\u5458\u4f1a\u6210\u5458\u517c\u6295\u8d44\u94f6\u884c\u7ba1\u7406\u90e8\u4e3b\u7ba1Stephen Dainton\u770b\u6cd5\u76f8\u5bf9\u4e50\u89c2\uff0c\u4ed6\u8ba4\u4e3a\u73b0\u65f6\u73af\u7403\u80a1\u503a\u5e02\u573a\u7684\u6d3b\u529b\u53ef\u5ef6\u7eed\u52302025\u5e74\u3002\u8003\u8651\u5230\u7ecf\u6d4e\u548c\u6d41\u52a8\u6027\u7b49\u56e0\u7d20\uff0cDainton\u9884\u671f\uff0c\u7f8e\u80a1\u548c\u4e9a\u6d32\u80a1\u5e02\u57282025\u5e74\u5f88\u5927\u673a\u4f1a\u8dd1\u8d62\u6b27\u6d32\u80a1\u5e02\uff0c\u800c\u4e14\u5728\u4e9a\u6d32\u89c1\u5230\u5e9e\u5927\u7684\u6295\u8d44\u673a\u4f1a\uff0c\u5f53\u4e2d\uff0c\u79d1\u6280\u677f\u5757\u53ef\u671b\u7ee7\u7eed\u5438\u5f15\u5927\u91cf\u8d44\u91d1\uff0c\u592a\u9633\u80fd\u548c\u53ef\u6301\u7eed\u80fd\u6e90\u7684\u9ad8\u901f\u53d1\u5c55\uff0c\u4ea6\u5c06\u9700\u8981\u66f4\u591a\u878d\u8d44\u6d3b\u52a8\u652f\u6301\u3002\u4f46\u4ed6\u63d0\u5230\uff0c\u4e0e\u7f8e\u5143\u6302\u94a9\u7684\u5730\u533a\u53ef\u80fd\u8981\u627f\u53d7\u66f4\u957f\u65f6\u95f4\u7684\u9ad8\u606f\u73af\u5883\uff0c\u4e0d\u5229\u7ecf\u6d4e\u53d1\u5c55\uff0c\u8d44\u672c\u5e02\u573a\u6d3b\u52a8\u4ea6\u5c06\u8f83\u5176\u4ed6\u5730\u533a\u900a\u8272\u3002<br/><br/>\u5df4\u514b\u83b1\u8ba4\u4e3a\uff0c\u7279\u6717\u666e\u6f5c\u5728\u63a8\u51fa\u7684\u653f\u7b56\u5c06\u4f1a\u4ee4\u7f8e\u56fd\u901a\u80c0\u56de\u5347\uff0c\u9650\u5236\u7f8e\u8054\u50a8\u91cd\u56de\u504f\u5bbd\u677e\u8d27\u5e01\u653f\u7b56\u7684\u80fd\u529b\uff0c\u73b0\u65f6\u9884\u6d4b2025\u5e74\u7f8e\u56fd\u53ea\u4f1a\u51cf\u606f\u4e24\u6b21\u3002\u5728\u5229\u7387\u53ef\u80fd\u6301\u7eed\u504f\u9ad8\u7684\u60c5\u51b5\u4e0b\uff0c\u8f83\u591a\u6760\u6746\u7684\u4f01\u4e1a\u8981\u7ee7\u7eed\u9762\u5bf9\u8f83\u9ad8\u7684\u507f\u503a\u538b\u529b\uff0c\u9ad8\u589e\u957f\u516c\u53f8\u5e94\u8be5\u4e0d\u4f1a\u5728\u6b64\u65f6\u52a0\u5927\u878d\u8d44\uff0c\u6b64\u7c7b\u516c\u53f8\u6b63\u662f\u6295\u8d44\u7684\u7126\u70b9\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259291934", "pub_date": "2024-12-02 19:09:36"}]}