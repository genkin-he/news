{"data": [{"id": 255642823, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5174\u4e1a\u8bc1\u5238\u7ef4\u6301\u4e2d\u56fd\u5e73\u5b89(02318)\u201c\u4e70\u5165\u201d\u8bc4\u7ea7 \u516c\u53f8\u524d\u4e09\u5b63\u4e09\u5927\u6838\u5fc3\u4e1a\u52a1\u8425\u8fd0\u5229\u6da6\u7a33\u5065", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5174\u4e1a\u8bc1\u5238\u53d1\u7814\u6307\uff0c2024\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u4e2d\u56fd\u5e73\u5b89(02318)\u5b9e\u73b0\u5f52\u5c5e\u4e8e\u6bcd\u516c\u53f8\u80a1\u4e1c\u7684\u8425\u8fd0\u5229\u6da61,138.18\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f5.5%\uff1b\u5f52\u5c5e\u4e8e\u6bcd\u516c\u53f8\u80a1\u4e1c\u7684\u51c0\u5229\u6da61,191.82\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f36.1%\u3002\u5176\u4e2d\uff0c\u5bff\u9669\u53ca\u5065\u5eb7\u9669\u3001\u8d22\u4ea7\u4fdd\u9669\u4ee5\u53ca\u94f6\u884c\u4e09\u9879\u4e1a\u52a1\u5408\u8ba1\u5f52\u5c5e\u4e8e\u6bcd\u516c\u53f8\u80a1\u4e1c\u7684\u8425\u8fd0\u5229\u6da61,196.51\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f5.7%\u3002\u622a\u81f32024\u5e749\u670830\u65e5\u6b629\u4e2a\u6708\uff0c\u96c6\u56e2\u5e74\u5316\u8425\u8fd0ROE\u4e3a15.9%\uff0c\u540c\u6bd4\u4e0b\u964d0.1\u4e2a\u767e\u5206\u70b9\u3002</p><p>\u8be5\u884c\u6307\uff0c2024\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u516c\u53f8\u5bff\u9669\u53ca\u5065\u5eb7\u9669\u4e1a\u52a1\u65b0\u4e1a\u52a1\u4ef7\u503c351.60\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f34.1%\u3002\u5176\u4e2d\uff0c\u4ee3\u7406\u4eba\u6e20\u9053\u65b0\u4e1a\u52a1\u4ef7\u503c\u540c\u6bd4\u589e\u957f31.6%\uff0c\u4eba\u5747\u65b0\u4e1a\u52a1\u4ef7\u503c\u540c\u6bd4\u589e\u957f54.7%\uff1b\u94f6\u4fdd\u6e20\u9053\u65b0\u4e1a\u52a1\u4ef7\u503c\u540c\u6bd4\u589e\u957f68.5%\u30022024Q1-3\uff0c\u516c\u53f8\u6309\u6807\u51c6\u4fdd\u8d39\u8ba1\u53ca\u6309\u9996\u5e74\u4fdd\u8d39\u8ba1\u7684\u65b0\u4e1a\u52a1\u4ef7\u503c\u7387\u5206\u522b\u4e3a31.0%\u53ca25.4%\uff0c\u540c\u6bd4\u5206\u522b\u4e0a\u53475.7\u30017.3\u4e2a\u767e\u5206\u70b9\u3002</p><p>\u8be5\u884c\u8868\u793a\uff0c\u662f\u4e00\u5bb6\u7efc\u5408\u6027\u91d1\u878d\u516c\u53f8\u3002\u516c\u53f8\u6301\u7eed\u6df1\u5316\u201c\u4e00\u4e2a\u5ba2\u6237\u3001\u591a\u79cd\u4ea7\u54c1\u3001\u4e00\u7ad9\u5f0f\u670d\u52a1\u201d\u7684\u7efc\u5408\u91d1\u878d\u6a21\u5f0f\uff0c\u6ee1\u8db3\u4e0d\u540c\u5ba2\u6237\u7684\u7efc\u5408\u91d1\u878d\u9700\u6c42\u3002\u8be5\u884c\u7ef4\u6301\u516c\u53f8\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0c\u5efa\u8bae\u6295\u8d44\u8005\u5173\u6ce8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255642823", "pub_date": "2024-10-24 10:40:25"}, {"id": 255641474, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u62db\u94f6\u56fd\u9645\u5347\u4e2d\u56fd\u5e73\u5b89(02318)\u76ee\u6807\u4ef7\u81f365.1\u6e2f\u5143 \u6307Q3\u65b0\u4e1a\u52a1\u4ef7\u503c\u589e\u957f\u4f18\u4e8e\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u62db\u94f6\u56fd\u9645\u8868\u793a\uff0c\u4e2d\u56fd\u5e73\u5b89(02318)\u516c\u5e03\u524d\u4e09\u5b63\u5ea6\u4e1a\u7ee9\uff0c\u8ba4\u4e3a\u516c\u53f8\u76c8\u5229\u65b9\u9762\u8868\u73b0\u5927\u81f4\u7b26\u5408\u5e02\u573a\u9884\u671f\uff0c\u4f46Q3\u65b0\u4e1a\u52a1\u4ef7\u503c\u589e\u957f\u4f18\u4e8e\u9884\u671f\uff0c\u5f97\u76ca\u4e8eNBV\u4ef7\u503c\u7387(\u540c\u6bd4+7.3\u4e2a\u767e\u5206\u70b9)\u548c\u65b0\u5355\u4fdd\u8d39(3\u5b63\u5ea6\u540c\u6bd4+50.4%)\u5927\u5e45\u63d0\u632f\u7684\u5171\u540c\u5f71\u54cd\u3002\u6295\u8d44\u4e1a\u7ee9\u65b9\u9762\uff0c\u4e09\u5b63\u5ea6\u516c\u53f8\u51c0\u6295\u8d44\u6536\u76ca\u73873.8%\uff0c\u540c\u6bd4-0.2\u4e2a\u767e\u5206\u70b9\uff1b\u7efc\u5408\u6295\u8d44\u6536\u76ca\u73875.0%\uff0c\u540c\u6bd4+1.2\u4e2a\u767e\u5206\u70b9\uff0c\u4e3b\u8981\u53d7FVOCI\u8d44\u4ea7\u516c\u5141\u4ef7\u503c\u53d8\u52a8\u5e26\u6765\u6295\u8d44\u6536\u76ca\u5927\u5e45\u4e0a\u884c\u7684\u5f71\u54cd\u3002\u8003\u8651\u5230\u76ee\u524d\u5927\u90e8\u5206\u9669\u4f01\u4ee5\u7efc\u5408\u6295\u8d44\u6536\u76ca\u7387(CIY)\u4f5c\u4e3a\u4e0e\u5185\u542b\u4ef7\u503c\u8ba1\u7b97\u4e2d\u957f\u671f\u6295\u8d44\u6536\u76ca\u56de\u62a5\u5047\u8bbe(4.5%)\u7684\u6bd4\u5bf9\u76ee\u6807\uff0c\u9884\u8ba1CIY\u589e\u957f\u5c06\u5bf9\u5168\u5e74\u6295\u8d44\u7ecf\u9a8c\u5dee\u5f02\u6784\u6210\u6b63\u5411\u8d21\u732e\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u516c\u53f8\u5f53\u524d\u4ea4\u6613\u4e8e0.54\u500dFY24 P/EV\u548c0.81\u500dFY24 P/B, \u5206\u522b\u8f83\u51763\u5e74\u5386\u53f2\u5747\u503c\u9ad80.6/0.2\u4e2a\u6807\u51c6\u5dee\uff1b\u8be5\u884c\u8ba4\u4e3a\u516c\u53f8\u57fa\u672c\u9762\u7684\u5927\u5e45\u6539\u5584\u5c06\u652f\u6491\u4f30\u503c\u8fdb\u4e00\u6b65\u56de\u5347\u3002\u8be5\u884c\u4e0a\u8c03\u5bf9\u516c\u53f8FY24-26\u76c8\u5229\u9884\u6d4b14%/7%/3%\u81f3\u6bcf\u80a17.44/7.57/7.90\u5143\uff0c\u5e76\u4e0a\u8c03\u76ee\u6807\u4ef7\u81f365.1\u6e2f\u5143\uff0c\u5bf9\u5e941.09\u500dFY24 P/B\u548c0.73\u500dFY24 P/EV\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255641474", "pub_date": "2024-10-24 10:21:12"}, {"id": 255641196, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u62db\u94f6\u56fd\u9645\u4e0b\u8c03\u65b0\u4e1c\u65b9(09901)\u7f8e\u80a1\u76ee\u6807\u4ef7 \u6307\u6d88\u8d39\u75b2\u8f6f\u5f71\u54cd\u77ed\u671f\u9ad8\u5ba2\u5355\u4ef7\u4e1a\u52a1", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u62db\u94f6\u56fd\u9645\u53d1\u7814\u62a5\u6307\uff0c\u65b0\u4e1c\u65b9(09901)10\u670823\u65e5\u516c\u5e031QFY25\u4e1a\u7ee9\uff1a\u51c0\u6536\u5165\u540c\u6bd4\u589e\u957f30.5%\u81f314.35\u4ebf\u7f8e\u5143\uff08\u5254\u9664\u4e1c\u65b9\u7504\u9009\uff0c\u6536\u5165\u540c\u6bd4\u589e\u957f33.5%\uff09\uff0c\u7b26\u5408\u62db\u94f6\u56fd\u9645/\u4e00\u81f4\u9884\u671f\u768413.96\u4ebf/14.42\u4ebf\u7f8e\u5143\uff1b\u975eGAAP\u51c0\u5229\u6da6\u540c\u6bd4\u589e\u957f39.8%\u81f32.65\u4ebf\u7f8e\u5143\uff0c\u57fa\u672c\u7b26\u5408\u62db\u94f6\u56fd\u9645/\u4e00\u81f4\u9884\u671f\u76842.56/2.58\u4ebf\u7f8e\u5143\uff0c\u4e3b\u8981\u5f97\u76ca\u4e8e\u6838\u5fc3\u6559\u80b2\u4e1a\u52a1\u8425\u4e1a\u5229\u6da6\u7387\u7684\u63d0\u5347\u3002<br/><br/>\u5c55\u671b2QFY25\uff0c\u7ba1\u7406\u5c42\u9884\u8ba1\u603b\u6536\u5165\uff08\u4e0d\u542b\u4e1c\u65b9\u7504\u9009\u6536\u5165\uff09\u5c06\u540c\u6bd4\u589e\u957f25%-28%\u81f38.51\u4ebf-8.72\u4ebf\u7f8e\u5143\uff0c\u6536\u5165\u589e\u901f\u6709\u6240\u653e\u7f13\uff0c\u4e3b\u56e0\u5b63\u8282\u6027\u56e0\u7d20\u4ee5\u53ca\u5b8f\u89c2\u9006\u98ce\u5f71\u54cd\u90e8\u5206\u9ad8\u5ba2\u5355\u4ef7\u4e1a\u52a1\u3002\u4f46\u7ba1\u7406\u5c42\u4ecd\u7136\u9884\u8ba13Q/4Q\u6536\u5165\u589e\u957f\u5c06\u91cd\u65b0\u52a0\u901f\uff0cFY25\u5168\u5e74\u6536\u5165\u589e\u957f\u5c06\u4fdd\u6301\u5728\u7ea630%\u540c\u6bd4\u589e\u957f\uff08\u4e0d\u542b\u4e1c\u65b9\u7504\u9009\uff09\u3002<br/><br/>\u8be5\u884c\u5c06FY25\u6536\u5165/\u975eGAAP\u76c8\u5229\u9884\u6d4b\u4e0b\u8c03\u4e861.0/9.6%\uff0c\u4e3b\u8981\u53cd\u6620\u6d88\u8d39\u75b2\u8f6f\u5bf9\u4e8e\u6d77\u5916\u76f8\u5173\u4e1a\u52a1\u53ca\u9ad8\u7aef1v1\u4e1a\u52a1\u7684\u5f71\u54cd\u3002\u8be5\u884c\u5c06\u57fa\u4e8eSOTP\u7684\u76ee\u6807\u4ef7\u4e0b\u8c03\u81f387.0\u7f8e\u5143\uff08\u524d\u503c\uff1a95.0\u7f8e\u5143\uff09\u3002\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255641196", "pub_date": "2024-10-24 10:17:26"}, {"id": 255641334, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u9f99\u6e56\u96c6\u56e2(00960)\u8dcc\u8fd13%  \u60e0\u8a89\u5c06\u5176\u957f\u671f\u53d1\u884c\u4eba\u8fdd\u7ea6\u8bc4\u7ea7\u4e0b\u8c03\u81f3\u201cBB\u201d \u5c55\u671b\u4ecd\u4e3a\u201c\u8d1f\u9762\u201d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9f99\u6e56\u96c6\u56e2(00960)\u80a1\u4ef7\u53cd\u590d\u8d70\u4f4e\uff0c\u622a\u6b62\u53d1\u7a3f\uff0c\u8dcc2.83%\uff0c\u62a512.36\u6e2f\u5143\uff0c\u6210\u4ea4\u989d6594.17\u4e07\u6e2f\u5143\u3002<br/><br/>\u60e0\u8a89\u5c06\u9f99\u6e56\u96c6\u56e2\u957f\u671f\u53d1\u884c\u4eba\u8fdd\u7ea6\u8bc4\u7ea7\u7531\u201cBB+\u201d\u4e0b\u8c03\u81f3\u201cBB\u201d\uff0c\u5c55\u671b\u4ecd\u4e3a\u201c\u8d1f\u9762\u201d\u3002<br/><br/>\u60e0\u8a89\u8868\u793a\uff0c\u4e0b\u8c03\u8bc4\u7ea7\u53cd\u6620\u9f99\u6e56\u7684\u6d41\u52a8\u6027\u7f13\u51b2\u56e0\u9500\u552e\u53ca\u73b0\u91d1\u6d41\u751f\u6210\u51cf\u5f31\u800c\u51cf\u5c11\uff0c\u81f3\u4e8e\u8d1f\u9762\u5c55\u671b\u5219\u53cd\u6620\u5c3d\u7ba1\u4e2d\u592e\u8fd1\u671f\u63a8\u51fa\u652f\u6301\u6027\u653f\u7b56\uff0c\u60df\u9f99\u6e56\u53ca\u884c\u4e1a\u9500\u552e\u9762\u4e34\u987b\u66f4\u957f\u65f6\u95f4\u624d\u80fd\u4f01\u7a33\u7684\u98ce\u9669\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255641334", "pub_date": "2024-10-24 10:19:50"}, {"id": 255640789, "title": "\u5146\u79d1\u773c\u79d1(06622)\u9006\u5e02\u6da8\u903e8.8% \u6838\u5fc3\u4ea7\u54c1NVK002\u6cbb\u7597\u8fd1\u89c6\u52a0\u6df1\u8bd5\u9a8c\u6eb6\u6db2\u60a3\u8005\u4f7f\u7528\u4f9d\u4ece\u6027\u597d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5146\u79d1\u773c\u79d1(06622)\u65e9\u76d8\u80a1\u4ef7\u9006\u5e02\u8d70\u9ad8\uff0c\u6700\u9ad8\u66fe\u89c11.62\u6e2f\u5143\uff0c\u6da8\u8d8519%\uff0c\u6700\u65b0\u62a51.48\u6e2f\u5143\uff0c\u4ecd\u6da88.82%\uff0c\u6210\u4ea4\u989d422.65\u4e07\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u516c\u53f8\u53d1\u5e03NVK002\u4e3a\u671f\u4e24\u5e74\u7684\u7b2cIII\u671f\u4e34\u5e8a\u8bd5\u9a8c\uff08China CHAMP\uff09\u7684\u9876\u7ebf\u7ed3\u679c\u3002\u7ecf\u8fc7\u4e24\u5e74\u7684\u6cbb\u7597\uff0c\u8fd9\u9879\u7814\u7a76\u5206\u6790\u663e\u793a\uff0cNVK002\u6ef4\u773c\u6db2\u7ec4\uff080.01%\u548c0.02%\u5242\u91cf\uff09\u5bf9\u6bd4\u5b89\u6170\u5242\u7ec4\u5728\u4e3b\u8981\u7597\u6548\u6307\u6807\u4e0a\u6709\u7edf\u8ba1\u5b66\u610f\u4e49\u7684\u663e\u7740\u6027\u5dee\u5f02\uff0cNVK002\u6ef4\u773c\u6db2\u7ec4\u4f18\u4e8e\u5b89\u6170\u5242\u7ec4\uff0c\u4e14\u5177\u6709\u5242\u91cf\u4f9d\u8d56\u3002\u4e24\u79cd\u5242\u91cf\u7684NVK002\u5b89\u5168\u6027\u826f\u597d\uff0c\u60a3\u8005\u4f7f\u7528\u4f9d\u4ece\u6027\u597d\u3002<br/><br/>NVK002\u662f\u4e00\u79cd\u7528\u4e8e\u63a7\u5236\u513f\u7ae5\u53ca\u9752\u5c11\u5e74\u8fd1\u89c6\u52a0\u6df1\u7684\u8bd5\u9a8c\u6027\u65b0\u578b\u5916\u7528\u7