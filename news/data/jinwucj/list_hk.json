e5\u4f4e\u4f4d\u540e\u53cd\u5f39\uff0c\u5168\u65e5\u6ce2\u5e45806\u70b9\u3002</p><p>\u6052\u6307\u6536\u62a520079.1\u70b9\uff0c\u8dcc207.75\u70b9\uff0c\u8dcc1.02%\uff0c\u6210\u4ea4\u91d1\u989d1912.6\u4ebf\u5143\u3002\u56fd\u6307\u53ca\u6052\u79d1\u6307\u5206\u522b\u8dcc1.22%\u53ca1.19%\u3002\u4e09\u9879\u6307\u6570\u90fd\u4e0b\u8dcc\uff0c\u4ee5\u56fd\u6307\u8d70\u52bf\u8f83\u5dee\u3002\u9f99\u6e56\u96c6\u56e2(0960)\u3001\u4e2d\u56fd\u6d77\u5916\u53d1\u5c55(0688)\u53ca\u534e\u6da6\u7f6e\u5730(1109)\u5206\u522b\u8dcc13.748%\u30016.598%\u53ca5.794%\uff0c\u662f\u8868\u73b0\u8f83\u5dee\u7684\u56fd\u4f01\u6210\u4efd\u80a1\u3002\u53e6\u65b9\u9762\uff0c\u878d\u521b\u4e2d\u56fd(1918)\u62df\u4ee5\u5148\u65e7\u540e\u65b0\u65b9\u5f0f\u914d\u552e\u6700\u591a4.89\u4ebf\u80a1\uff0c\u6bcf\u80a1\u4f5c\u4ef72.465\u6e2f\u5143\uff0c\u8f8310\u670816\u65e5\u6536\u5e02\u4ef73.08\u6e2f\u5143\u6298\u8ba9\u7ea619.97%\uff0c\u96c6\u8d44\u603b\u989d\u7ea612.05\u4ebf\u5143\u3002\u878d\u521b\u80a1\u4ef7\u8dcc27.27%\uff0c\u662f\u8dcc\u5e45\u8f83\u5927\u7684\u5185\u623f\u3002</p><p>\u6052\u6307\u9ad8\u5f00\u4f4e\u8d70\uff0c\u5355\u65e5\u8f6c\u5411\uff0c\u66fe\u521b9\u670827\u65e5\u4ee5\u6765\u4f4e\u4f4d\uff0c\u6700\u7ec8\u4ee5\u9634\u70db\u6536\u5e02\u3002\u82e5\u914d\u5408\u524d\u4ea4\u6613\u65e5\u8d70\u52bf\u4e00\u5e76\u53c2\u8003\uff0c\u5219\u8c31\u6210\u300c\u7a7f\u5934\u7834\u811a\u300d\u7684\u5229\u6de1\u5f62\u6001\u3002MACD\u718a\u5dee\u6269\u9614\uff1b\u5168\u65e5\u4e0a\u5347\u80a1\u4efd551\u53ea\uff0c\u4e0b\u8dcc1237\u53ea\uff0c\u6574\u4f53\u5e02\u51b5\u504f\u5f31\u3002</p><p>\u7f8e\u56fd\u4e0a\u661f\u671f\u9996\u6b21\u7533\u9886\u5931\u4e1a\u6551\u6d4e\u4eba\u6570\u670924.1\u4e07\u4eba\uff0c\u6309\u661f\u671f\u51cf\u5c111.9\u4e07\u4eba\uff0c\u5c11\u8fc7\u5e02\u573a\u9884\u671f\u768426\u4e07\u4eba\uff1b\u800c\u524d\u661f\u671f\u4eba\u6570\u5411\u4e0a\u4fee\u8ba2\u81f326\u4e07\u4eba\u3002\u7f8e\u80a1\u4e09\u5927\u6307\u6570\u5411\u597d\uff0c\u5176\u4e2d\u9053\u6307\u518d\u521b\u6536\u5e02\u65b0\u9ad8\u3002</p><p>\u591c\u671f\u53caADR\u4e0b\u8dcc\uff0c\u6599\u6052\u6307\u8d70\u52bf\u504f\u8f6f\uff0c\u652f\u6301\u53c2\u800320000/19600\u6c34\u5e73\u3002<br/><br/>\u4fe1\u53f7\u80a1</p><p>\u4ee5\u4e0b\u80a1\u4efd\u5728\u91d1\u878d\u79d1\u6280\u7cfb\u7edf\u51fa\u73b0\u4fe1\u53f7\uff0c\u4ec5\u4f9b\u53c2\u8003\uff1a<br/>\u4e2d\u5e7f\u6838\u77ff\u4e1a(1164)<br/>\u4e2d\u70df\u9999\u6e2f(6055)<br/><br/>\u7b14\u8005\u4e3a\u9999\u6e2f\u8bc1\u76d1\u4f1a\u6301\u724c\u4eba\u58eb\uff0c\u6ca1\u6301\u6709\u4e0a\u8ff0\u80a1\u4efd\uff0c\u5e76\u4e3a\u4e2a\u4eba\u610f\u89c1\uff0c\u4e0d\u6784\u6210\u6295\u8d44\u5efa\u8bae\u3002</p><p>\u6587\uff1a\u68a7\u6850\u7814\u7a76\u9662\u5206\u6790\u5458\u5c91\u667a\u52c7<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255155006", "pub_date": "2024-10-18 09:20:52"}, {"id": 255154958, "title": "\u4eba\u6c11\u5e01\u5151\u7f8e\u5143\u4e2d\u95f4\u4ef7\u62a57.1274 \u4e0b\u8c0354\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf | 2024\u5e7410\u670818\u65e5\uff0c\u4eba\u6c11\u5e01\u5151\u7f8e\u5143\u4e2d\u95f4\u4ef7\u62a57.1274\uff0c\u4e0b\u8c0354\u70b9\uff0c\u4e0a\u4e00\u4ea4\u6613\u65e5\u4e2d\u95f4\u4ef7\u62a57.1220\u3002\u4e2d\u95f4\u4ef7\u8d2c\u503c\u81f32024\u5e748\u670829\u65e5\u4ee5\u6765\u6700\u4f4e\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255154958", "pub_date": "2024-10-18 09:19:16"}, {"id": 255154582, "title": "\u3010\u7279\u7ea6\u5927V\u3011\u9093\u58f0\u5174\uff1a\u5e02\u573a\u5173\u6ce8\u5185\u5730\u516c\u5e03\u7b2c\u4e09\u5b63GDP\uff0c\u4e2d\u6e2f\u80a1\u5e02\u518d\u5ea6\u53d7\u538b", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6052\u6307\u5468\u56db(17\u65e5)\u6536\u62a520079\uff0c\u8dcc207\u70b9\u62161%\uff1b\u5927\u5e02\u5168\u65e5\u6210\u4ea41912\u4ebf\u5143\u3002\u56fd\u6307\u8dcc1.2%\uff0c\u62a57179\uff1b\u79d1\u6307\u8dcc1.2%\uff0c\u62a54349\u3002\u4f4f\u5efa\u90e8\u6307\u5e74\u5e95\u524d\u767d\u540d\u5355\u9879\u76ee\u4fe1\u8d37\u89c4\u6a21\u589e\u81f34\u4e07\u4ebf\u4eba\u6c11\u5e01\uff0c\u4f46\u5185\u623f\u80a1\u4e0b\u632b\u3002\u4e2d\u8f6f\u56fd\u9645(00354)\u591a\u4e2a\u9e3f\u8499\u9879\u76ee\u4e0a\u67b6\uff0c\u80a1\u4ef7\u5168\u65e5\u53473.7%\u3002<br/><br/>\u9053\u6307\u5468\u56db(17\u65e5)\u6536\u5e02\u62a543239\u70b9\uff0c\u5347161\u70b9\u62160.37%\uff1b\u6807\u6307\u5012\u8dcc0.02%\uff0c\u62a55841\u70b9\uff1b\u7eb3\u6307\u53470.04%\uff0c\u62a518373\u70b9\uff1b\u53cd\u6620\u4e2d\u56fd\u6982\u5ff5\u80a1\u8868\u73b0\u7684\u91d1\u9f99\u6307\u6570\u6ed1\u843d3.61%\u3002\u91cd\u78c5\u80a1\u4e2d\uff0cNetflix\u5468\u56db\u6536\u5e02\u540e\u516c\u5e03\u4e1a\u7ee9\uff0c\u80a1\u4ef7\u56de\u843d2%\uff0c\u4f46\u81ea2022\u5e745\u6708\u4f4e\u4f4d\u5df2\u52b2\u5f39\u8fd1340%\uff0cAlphabet\u80a1\u4ef7\u8dcc1.4%\u3002\u53f0\u79ef\u7535\u7f8e\u56fdADR\u80a1\u4ef7\u62bd\u9ad89.8%\uff0c\u521b\u5386\u53f2\u6536\u5e02\u65b0\u9ad8\uff0c\u76d8\u4e2d\u66fe\u7834\u9876\u9ad8\u89c1212.6\u7f8e\u5143\uff1b\u5176\u4ed6\u534a\u5bfc\u4f53\u80a1\u8ddf\u968f\u5411\u4e0a\uff0c\u8f89\u8fbe(Nvidia)\u4e00\u5ea6\u4e0a\u626c3.8%\uff0c\u6536\u5e02\u4ecd\u6da80.9%\uff0cARM\u3001\u535a\u901a(Broadcom)\u53ca\u7f8e\u5149\u79d1\u6280(Micron)\u6da8\u5e45\u4ecb\u4e4e1.4%\u81f32.7%\u3002\u4e9a\u592a\u80a1\u5e02\u4eca\u65e9(18\u65e5)\u4e2a\u522b\u8d70\uff0c\u65e5\u7ecf225\u6307\u6570\u73b0\u65f6\u62a539035\u70b9\uff0c\u5347124\u70b9\u62160.32%\u3002\u5357\u97e9\u7efc\u5408\u6307\u6570\u73b0\u65f6\u62a52607\u70b9\uff0c\u8dcc2\u70b9\u62160.08%\u3002\u5e02\u573a\u5173\u6ce8\u5185\u5730\u516c\u5e03\u7b2c\u4e09\u5b63GDP\uff0c\u4e2d\u6e2f\u80a1\u5e02\u518d\u5ea6\u53d7\u538b\u3002<br/><br/>\u5e02\u573a\u7126\u70b9\uff1a\u4eac\u4e1c\u96c6\u56e2-SW(09618)<br/><br/>\u4e2d\u592e\u5bb6\u7535\u4ee5\u65e7\u6362\u65b0\u653f\u7b56\u7684\u63a8\u51fa\u4e0b\uff0c\u5185\u5730\u653f\u5e9c\u5b9e\u65bd\u4e86\u7535\u5b50\u4ea7\u54c1\u4ee5\u65e7\u6362\u65b0\u8865\u8d34\uff0c\u91cd\u70b9\u662f\u5bb6\u7535\u7c7b\u522b\u3002\u4f5c\u4e3a\u7535\u5b50\u4ea7\u54c1\u4e3b\u8981\u9500\u552e\u6e20\u9053\u4e4b\u4e00\uff0c\u4eac\u4e1c\u96c6\u56e2\u5c06\u4f1a\u53d7\u76ca\u3002\u96c6\u56e22024\u5e74\u7b2c2\u5b63\u5ea6\u5229\u6da6\u5927\u8d85\u9884\u671f\uff0c\u5b9e\u73b0\u8425\u65362914.0\u4ebf\u5143(\u4eba\u6c11\u5e01\uff0c\u4e0b\u540c)\uff0c\u540c\u6bd4\u4e0a\u53471.2%\uff1b\u7ecf\u8425\u5229\u6da6105.0\u4ebf\u5143\uff0c\u540c\u6bd4\u589e27.0%\uff0c\u7ecf\u8425\u5229\u6da6\u73873.6%\uff0c\u540c\u6bd4\u4e0a\u53470.7pct\uff0c\u5176\u4e2d\u4eac\u4e1c\u96f6\u552e\u7ecf\u8425\u5229\u6da6\u73873.9%\uff0c\u540c\u6bd4\u589e0.7pct\uff1b\u5b9e\u73b0Non-GAAP\u5f52\u6bcd\u51c0\u5229\u6da6144.6\u4ebf\u5143\uff0c\u540c\u6bd4\u4e0a\u534769.0%\uff1b\u53d7\u60e0\u4e8e3C\u6570\u7801\u300c\u4ee5\u65e7\u6362\u65b0\u300d\u653f\u7b56\uff0c\u96c6\u56e2\u65e5\u767e\u54c1\u7c7b\u5f3a\u52b2\u589e\u957f\u3002\u9884\u8ba1\u7b2c3\u5b63\u96c6\u56e2\u6536\u5165\u540c\u6bd4\u589e\u957f5%\u81f32601\u4ebf\u5143\uff0c\u4eac\u4e1c\u96f6\u552e\u6536\u5165\u540c\u6bd4\u589e\u957f5.1%\u81f32229\u4ebf\u5143\uff0c\u4eac\u4e1c\u96c6\u56e2Non-GAAP\u51c0\u5229\u6da6\u4e3a113\u4ebf\u5143\uff0c\u5bf9\u5e94\u51c0\u5229\u7387\u4e3a4.34%\uff0c\u524d\u4e00\u5e74\u540c\u671f\u4e3a4.29%\u3002\u53d7\u60e0\u4e8e\u653f\u5e9c\u523a\u6fc0\u63aa\u65bd\u548c\u4ee5\u65e7\u6362\u65b0\u653f\u7b56\uff0c\u53ca\u4e0b\u534a\u5e74\u6d88\u8d39\u9010\u6b65\u590d\u82cf\uff0c\u518d\u52a0\u4e0a\u4eca\u5e7410\u670814\u65e5\u542f\u52a8\u7684\u53cc11\u4fc3\u9500\u6d3b\u52a8\uff0c\u5c06\u8fdb\u4e00\u6b65\u523a\u6fc0\u6d88\u8d39\u9700\u6c42\uff0c\u5bf9\u96c6\u56e2\u6574\u4f53\u5229\u6da6\u611f\u4e50\u89c2\u3002<br/><br/>\u76ee\u6807\u4ef7$195\uff0c\u6b62\u8680\u4ef7$130<br/><br/>(\u7b14\u8005\u4e3a\u8bc1\u76d1\u4f1a\u6301\u724c\u4eba\u58eb\u53ca\u7b14\u8005\u672a\u6301\u6709\u4e0a\u8ff0\u80a1\u4efd)</p><p>\u4f5c\u8005\uff1a\u9999\u6e2f\u80a1\u7968\u5206\u6790\u5e08\u534f\u4f1a\u4e3b\u5e2d\u9093\u58f0\u5174\u535a\u58eb</p>", "link": "https://sky.szfiu.com/info/hk/details/255154582", "pub_date": "2024-10-18 09:11:12"}, {"id": 255154355, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u56fd\u6cf0\u541b\u5b89\uff1a\u76ee\u524d\u4ecd\u7136\u662f\u5730\u4ea7\u7684PB\u4f30\u503c\u4fee\u590d\u9636\u6bb5", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u56fd\u6cf0\u541b\u5b89\u8868\u793a\uff0c10\u670817\u65e5\u56fd\u65b0\u529e\u4e3e\u884c\u65b0\u95fb\u53d1\u5e03\u4f1a\u3002\u4f1a\u8bae\u5185\u5bb9\u6574\u4f53\u6765\u770b\u6d89\u53ca\u4e09\u5927\u90e8\u5206\uff0c\u548c\u8fd1\u671f\u4ee5\u6765\u4e00\u76f4\u5f3a\u8c03\u7684\u5185\u5bb9\u4e00\u81f4\uff0c\u5373\u4fdd\u4ea4\u4ed8\u3001\u6536\u50a8\u548c\u57ce\u5e02\u66f4\u65b0\u3002\u800c\u5f53\u524d\u6b62\u8dcc\u56de\u7a33\uff0c\u901a\u80c0\u4e3a\u5148\uff0c\u5f53\u524d\u7684\u6b62\u8dcc\u653f\u7b56\u4ecd\u7136\u662f\u5f15\u5bfc\u5229\u7387\u4e0b\u884c\u5e26\u6765\u7684\u8d44\u4ea7\u4ef7\u683c\u5bb9\u5fcd\u5ea6\u63d0\u9ad8\uff0c\u800c\u8981\u56de\u7a33\uff0c\u4ecd\u7136\u4f9d\u8d56\u4e8e\u4fe1\u7528\u5de5\u5177\u548c\u6295\u8d44\u9879\u76ee\u5e26\u6765\u7684\u901a\u80c0\u3002\u76ee\u524d\u4ecd\u7136\u662f\u5730\u4ea7\u7684PB\u4f30\u503c\u4fee\u590d\u9636\u6bb5\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255154355", "pub_date": "2024-10-18 09:06:44"}]}