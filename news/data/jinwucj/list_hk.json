0881)\u8dcc2.04%\uff0c\u6052\u9686\u5730\u4ea7(00101)\u8dcc1.38%\uff0c\u53cb\u90a6\u4fdd\u9669(01299)\u8dcc1.38%\uff0c\u521b\u79d1\u5b9e\u4e1a(00669)\u8dcc1.37%\u3002<br/><br/>\u8054\u6613\u878d\u79d1\u6280(09959)\u9ad8\u5f003.8%\uff0c\u6839\u636e\u9999\u6e2f\u8054\u4ea4\u624012\u670811\u65e5\u62ab\u9732\u7684\u6587\u4ef6\uff0c\u6469\u6839\u5927\u901a(JPMorgan Chase &amp; Co.)\u4e8e12\u67086\u65e5\u4ee5\u573a\u5185\u6bcf\u80a1\u5747\u4ef71.7608\u6e2f\u5143\uff0c\u573a\u5916\u6bcf\u80a1\u5747\u4ef71.7517\u6e2f\u5143\u5408\u8ba1\u589e\u6301\u8054\u6613\u878d\u79d1\u62801,154.85\u4e07\u80a1\u5176\u4ed6\u80a1\u80a1\u4efd\uff0c\u4ef7\u503c\u7ea62,033.46\u4e07\u6e2f\u5143\u3002\u589e\u6301\u540e\uff0c\u6469\u6839\u5927\u901a\u6700\u65b0\u6301\u80a1\u6570\u76ee\u4e3a1.08\u4ebf\u80a1\u80a1\u4efd\uff0c\u597d\u4ed3\u6bd4\u4f8b\u75314.79%\u5347\u81f35.36%\u3002<br/><br/>\u5409\u5229\u6c7d\u8f66(00175)\u4f4e\u5f000.25%\uff0c\u65d7\u4e0b\u65b0\u80fd\u6e90\u5546\u7528\u8f66\u54c1\u724c\u8fdc\u7a0b\u6c7d\u8f66\u5ba3\u5e03\uff0c\u4e0e\u6c7d\u8f66\u7ecf\u9500\u5546\u5b89\u5229\u6377\u6c7d\u8f66(Jameel Motors)\u5408\u4f5c\uff0c\u5728\u82f1\u56fd\u5e02\u573a\u63a8\u51fa\u7535\u52a8\u8f66\uff0c\u9996\u6b3e\u4e3a\u8fdc\u7a0bSV\u5927\u578b\u53a2\u5f0f\u8d27\u8f66\uff0c\u5c06\u4e8e\u660e\u5e74\u4e0a\u534a\u5e74\u8d77\u9500\u552e\u3002\u6c99\u7279\u963f\u62c9\u4f2f\u5b89\u5229\u6377\u96c6\u56e2(Abdul Latif Jameel Group)\u65d7\u4e0b\u7684\u5b89\u5229\u6377\u6c7d\u8f66\u5c06\u8d1f\u8d23\u8fdc\u7a0b\u6c7d\u8f66\u5728\u82f1\u56fd\u7684\u5206\u9500\u3002\u8be5\u516c\u53f8\u8fd8\u5c06\u5728\u5176\u4ed6\u56fd\u5bb6\u5f15\u8fdb\u8fdc\u7a0b\u3002<br/><br/>\u6e2f\u6e7e\u5bb6\u65cf\u529e\u516c\u5ba4\u4e1a\u52a1\u53d1\u5c55\u603b\u76d1 \u90ed\u5bb6\u8000\u8868\u793a\uff0c\u7f8e\u80a1\u5468\u4e09\u4e2a\u522b\u53d1\u5c55\uff0c\u7f8e\u56fd\u6700\u65b0\u901a\u80c0\u6570\u636e\u7b26\u5408\u9884\u671f\uff0c\u5e02\u573a\u7ef4\u6301\u5bf9\u8054\u50a8\u5c40\u51cf\u606f\u671f\u671b\uff0c\u79d1\u6280\u80a1\u8868\u73b0\u51fa\u8272\uff0c\u7eb3\u6307\u518d\u5ea6\u7834\u9876\uff0c\u4f20\u7edf\u7c7b\u80a1\u4efd\u8f83\u4e3a\u5931\u8272\uff0c\u4e09\u5927\u6307\u6570\u6536\u5e02\u5347\u8dcc\u4e0d\u4e00\u3002\u7f8e\u5143\u8d70\u52bf\u9760\u7a33\uff0c\u7f8e\u56fd\u5341\u5e74\u671f\u503a\u606f\u56de\u5347\u81f34.26\u5398\u6c34\u5e73\uff0c\u91d1\u4ef7\u8868\u73b0\u5411\u597d\uff0c\u6cb9\u4ef7\u8d70\u52bf\u4ea6\u5411\u4e0a\u3002\u6e2f\u80a1\u9884\u6258\u8bc1\u5238\u53d8\u52a8\u4e0d\u5927\uff0c\u9884\u6599\u5927\u5e02\u65e9\u6bb5\u7f3a\u4e4f\u65b9\u5411\u3002\u5185\u5730\u80a1\u5e02\u6628\u65e5\u5411\u597d\uff0c\u6caa\u7efc\u6307\u4f4e\u5f00\u9ad8\u8d70\uff0c\u6536\u5e02\u4e0a\u53470.3%\uff0c\u6caa\u6df1\u4e24\u5e02\u6210\u4ea4\u989d\u7565\u4e3a\u7f29\u51cf\u3002\u6e2f\u80a1\u8d70\u52bf\u56de\u843d\uff0c\u6307\u6570\u9ad8\u5f00\u540e\u4e00\u5ea6\u903c\u8fd120,500\u70b9\u6c34\u5e73\uff0c\u5176\u540e\u5927\u5e02\u6cbd\u538b\u589e\u52a0\uff0c\u5e76\u4ee5\u63a5\u8fd1\u4f4e\u4f4d\u6536\u5e02\uff0c\u6574\u4f53\u6210\u4ea4\u4ea6\u6709\u6240\u51cf\u5c11\u3002\u5e02\u573a\u89c2\u671b\u6c14\u6c1b\u8f83\u4e3a\u6d53\u539a\uff0c\u653f\u7b56\u523a\u6fc0\u61a7\u61ac\u672a\u80fd\u8fdb\u4e00\u6b65\u5e26\u52a8\u5e02\u51b5\u5411\u4e0a\uff0c\u9884\u6599\u6307\u6570\u7ee7\u7eed\u7ef4\u630120,000\u81f321000\u70b9\u6c34\u5e73\u5f98\u5f8a\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260380768", "pub_date": "2024-12-12 09:26:42"}]}