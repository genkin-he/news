u4ee5\u63d0\u5347\u516c\u53f8\u54c1\u724c\u77e5\u540d\u5ea6\u4ee5\u53ca\u6301\u7eed\u83b7\u53d6\u4f18\u8d28\u6d41\u91cf\u4ee5\u63d0\u9ad8\u8f6c\u5316\u6548\u7387\u3002\u8be5\u884c\u8ba4\u4e3a\uff0c\u516c\u53f8\u51c0\u5229\u6da6\u53d7\u9500\u552e\u4e0e\u8425\u9500\u5f00\u652f\u800c\u4e0b\u964d\u662f\u9636\u6bb5\u6027\u7684\uff0c\u672a\u6765\u53d7\u76ca\u4e8e\u516c\u53f8\u5728\u5ba3\u4f20\u4e0e\u4f18\u8d28\u6d41\u91cf\u83b7\u53d6\u4e0a\u7684\u6295\u5165\uff0c\u4e0b\u534a\u5e74\u6536\u5165\u4e0e\u51c0\u5229\u6da6\u6709\u671b\u73af\u6bd4\u589e\u957f\u3002<br/><br/>2024H1\uff0cBaaS\u91d1\u878d\u884c\u4e1a\u4e91\u6536\u5165\u4e3a5.89\u4ebf\u5143\uff0c\u540c\u6bd4+20%\uff0c\u4e3b\u8981\u5f97\u76ca\u4e8e\u4fc3\u6210\u7684\u4ea4\u6613\u89c4\u6a21\u5feb\u901f\u4e0a\u5347\uff1a\u4eca\u5e74\u4e0a\u534a\u5e74\u8d44\u4ea7\u4ea4\u6613\u89c4\u6a21\u540c\u6bd4+23%\u81f3261.50\u4ebf\u5143\u30022024H1\uff0c\u516c\u53f8\u548c\u5ba2\u6237\u7684\u5408\u4f5c\u52a0\u6df1\uff0c\u8054\u5408\u5f00\u62d3\u5404\u79cd\u8425\u9500\u6d3b\u52a8\uff0c\u4fc3\u6210\u8d44\u4ea7\u4ea4\u6613\u89c4\u6a21\u7684\u5feb\u901f\u62d3\u5c55\uff1b\u6b64\u5916\uff0c\u968f\u7740\u66f4\u591a\u81ea\u6709\u7528\u6237\u8d21\u732e\u6536\u5165\uff0c\u7ed3\u5408\u516c\u53f8\u5728\u751f\u6210\u5f0fAI\u4e0a\u7684\u83b7\u5ba2\u4f18\u52bf\uff0c\u6301\u7eed\u63d0\u5347\u83b7\u5ba2\u6548\u7387\uff0c\u5e76\u5e26\u6765\u66f4\u9ad8\u7684ROI\u6c34\u5e73\u3002\u8be5\u884c\u8ba4\u4e3a\uff0c\u516c\u53f8\u5728\u6838\u5fc3\u4e1a\u52a1BaaS\u91d1\u878d\u884c\u4e1a\u4e91\u4e0a\u7684\u4eae\u773c\u6570\u636e\u6216\u5c06\u5728\u672a\u6765\u5e26\u52a8\u516c\u53f8\u4e1a\u7ee9\u6301\u7eed\u5411\u4e0a\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u8003\u8651\u52302024H1\u51c0\u5229\u6da6\u540c\u6bd4\u4e0b\u964d\uff0cMaaS\u4e1a\u52a1\u4e0eBaaS\u4fdd\u9669\u884c\u4e1a\u4e91\u4e1a\u52a1\u9636\u6bb5\u6027\u627f\u538b\uff0c\u56e0\u6b64\u8be5\u884c\u5c06FY2024-FY2026\u516c\u53f8\u603b\u6536\u516530.8/37.0/43.4\u4ebf\u5143\u8c03\u6574\u4e3a30.0/34.3/40.5\u4ebf\u5143\uff0c\u5c06\u5f52\u6bcd\u51c0\u5229\u6da63.9/5.3/5.8\u4ebf\u5143\u8c03\u6574\u4e3a3.19/3.81/4.38\u4ebf\u5143\uff0c\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255307608", "pub_date": "2024-10-21 10:48:57"}, {"id": 255306950, "title": "\u3010\u76c8\u8b66\u80a1\u3011\u4e0a\u6d77\u590d\u65e6(01385)\u8dcc3.6% \u6599\u99969\u6708\u51c0\u5229\u6da6\u4e0b\u6ed1\u81f3\u591a38.48%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e0a\u6d77\u590d\u65e6(01385)\u53d1\u76c8\u8b66\uff0c\u62d6\u7d2f\u80a1\u4ef7\u8868\u73b0\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a517.16\u6e2f\u5143\uff0c\u8dcc3.6%\uff0c\u6210\u4ea4\u989d2.99\u4ebf\u6e2f\u5143\u3002<br/><br/>\u636e\u76c8\u8b66\u516c\u544a\uff0c\u6599\u622a\u81f32024\u5e749\u670830\u65e5\u6b62\u4e5d\u4e2a\u6708\uff0c\u8425\u4e1a\u6536\u516526.6\u4ebf\u5143\u4eba\u81f327\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u8f83\u53bb\u5e74\u540c\u671f27.38\u4ebf\u5143\u4eba\u6c11\u5e01\u51cf\u5c11\u7ea6\u4e3a2.85%\u81f31.39%\uff1b\u671f\u5185\u5f52\u5c5e\u4e8e\u6bcd\u516c\u53f8\u6240\u6709\u8005\u7684\u51c0\u5229\u6da6\u7ea6\u4ecb\u4e4e4\u4ebf\u81f34.5\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u8f83\u53bb\u5e74\u540c\u671f6.5\u4ebf\u5143\u4eba\u6c11\u5e01\u51cf\u5c1138.48%\u81f330.78%\u3002<br/><br/>\u6536\u5165\u53ca\u51c0\u5229\u6da6\u51cf\u5c11\u7684\u4e3b\u8981\u539f\u56e0\u4e3ai)\u671f\u5185\uff0c\u96c6\u56e2\u5404\u4ea7\u54c1\u7ebf\u6240\u9762\u5bf9\u7684\u5b58\u91cf\u5e02\u573a\u7ade\u4e89\u6fc0\u70c8\u3002\u4e3a\u5de9\u56fa\u548c\u62d3\u5c55\u5e02\u573a\u4efd\u989d\uff0c\u96c6\u56e2\u8c03\u6574\u4e86\u90e8\u5206\u4ea7\u54c1\u7684\u9500\u552e\u4ef7\u683c\uff0c\u9500\u552e\u91cf\u6709\u6240\u63d0\u5347\u3002\u53d7\u4ea7\u54c1\u9500\u552e\u4ef7\u683c\u4e0b\u964d\u548c\u4ea7\u54c1\u7ed3\u6784\u8c03\u6574\u5f71\u54cd\uff0c\u62a5\u544a\u671f\u5185\u672c\u96c6\u56e2\u7684\u7efc\u5408\u6bdb\u5229\u7387\u4e0b\u964d\uff0c\u8425\u4e1a\u6536\u5165\u540c\u6bd4\u5c0f\u5e45\u51cf\u5c11\uff0c\u56e0\u6b64\u62a5\u544a\u671f\u5f52\u5c5e\u4e8e\u6bcd\u516c\u53f8\u6240\u6709\u8005\u7684\u51c0\u5229\u6da6\u4e0b\u964d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255306950", "pub_date": "2024-10-21 10:30:44"}, {"id": 255307091, "title": "\u3010AH\u4e92\u52a8\u3011\u4e0a\u6d77\u7535\u6c14(02727)\u5347\u903e25% A\u80a1\u903c\u8fd1\u6da8\u505c \u5168\u8d44\u9644\u5c5e\u65a5\u8d44\u8fd131\u4ebf\u5411\u6bcd\u516c\u53f8\u6536\u8d2d\u5b81\u7b19\u5b9e\u4e1a", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e0a\u6d77\u7535\u6c14(02727)\u80a1\u4ef7\u9707\u8361\u8d70\u9ad8\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da825.27%\uff0c\u62a52.28\u6e2f\u5143\uff0c\u6210\u4ea4\u989d3.09\u4ebf\u6e2f\u5143\u3002<br/><br/>A\u80a1\u4e0a\u6d77\u7535\u6c14(601727)\u63a5\u8fd1\u6da8\u505c\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da89.96%\uff0c\u62a54.97\u5143\u4eba\u6c11\u5e01\uff0c\u6210\u4ea4\u989d3.1\u4ebf\u5143\u4eba\u6c11\u5e01\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u516c\u53f8\u516c\u544a\uff0c\u81ea\u52a8\u5316\u96c6\u56e2(\u516c\u53f8\u7684\u4e00\u95f4\u5168\u8d44\u9644\u5c5e\u516c\u53f8)\uff0c\u4ee5\u73b0\u91d1\u65b9\u5f0f]\u5411\u516c\u53f8\u63a7\u80a1\u80a1\u4e1c\u7535\u6c14\u63a7\u80a1\u6536\u8d2d\u5b81\u7b19\u5b9e\u4e1a100%\u80a1\u6743\uff0c\u540e\u8005\u4e3a\u5de5\u4e1a\u673a\u5668\u4eba\u76f8\u5173\u4e1a\u52a1\u7684\u6301\u80a1\u7ba1\u7406\u5e73\u53f0\uff0c\u6301\u6709\u53d1\u90a3\u79d1\u673a\u5668\u4eba50%\u80a1\u6743\u548c\u53d1\u90a3\u79d1\u56fd\u8d3825%\u80a1\u6743\uff0c\u73b0\u91d1\u4ee3\u4ef730.82\u4ebf\u4eba\u6c11\u5e01\uff0c\u5c06\u4ee5\u81ea\u6709\u8d44\u91d1\u53ca\u5e76\u8d2d\u8d37\u6b3e\u652f\u4ed8\u3002<br/><br/>\u53e6\u5916\uff0c\u516c\u53f8\u62df\u56de\u8d2dA\u80a1\u6216H\u80a1\uff08\u4e24\u8005\u9009\u5176\u4e00\uff09\uff0c\u63d0\u8bf7\u80a1\u4e1c\u5927\u4f1a\u3001A\u80a1\u7c7b\u522b\u80a1\u4e1c\u4f1a\u8bae\u548cH\u80a1\u7c7b\u522b\u80a1\u4e1c\u4f1a\u8bae\u6388\u4e88\u8463\u4e8b\u4f1a\u6839\u636e\u5e02\u573a\u60c5\u51b5\u548c\u516c\u53f8\u9700\u8981\uff0c\u51b3\u5b9a\u56de\u8d2d\u516c\u53f8\u5df2\u53d1\u884c\u7684A\u80a1\u6216H\u80a1\u80a1\u4efd\u7684\u4e00\u822c\u6027\u6388\u6743\u3002\u6388\u6743\u5185\u5bb9\u5305\u62ec\u56de\u8d2d\u4e0d\u8d85\u8fc7\u516c\u53f8\u5df2\u53d1\u884cA\u80a1\u6570\u91cf10%\u7684A\u80a1\u80a1\u4efd\u6216\u4e0d\u8d85\u8fc7\u516c\u53f8\u5df2\u53d1\u884cH\u80a1\u6570\u91cf10%\u7684H\u80a1\u80a1\u4efd\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255307091", "pub_date": "2024-10-21 10:34:14"}, {"id": 255307090, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5efa\u94f6\u56fd\u9645\u63079\u6708\u53ca\u4e09\u5b63\u5ea6\u5b8f\u89c2\u6570\u636e\u5c0f\u5e45\u6539\u5584 \u653f\u7b56\u5982\u671f\u843d\u5b9e\u5c06\u6301\u7eed\u589e\u957f\u52a8\u80fd", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5efa\u94f6\u56fd\u9645\u8868\u793a\uff0c9\u6708\u4ee5\u53ca\u4e09\u5b63\u5ea6\u7684\u5b8f\u89c2\u6570\u636e\u5c0f\u5e45\u6539\u5584\uff0c\u4e3b\u8981\u53d7\u76ca\u4e8e\u8d38\u6613\u4ee5\u53ca\u4ea7\u4e1a\u5347\u7ea7\u5e26\u6765\u7684\u5236\u9020\u4e1a\u5229\u597d\u4e0e\u653f\u7b56\u5bf9\u5546\u54c1\u6d88\u8d39\u7684\u5c0f\u5e45\u63d0\u632f\u3002\u7136\u800c\uff0c\u603b\u4f53\u56fd\u5185\u9700\u6c42\u4ecd\u8f83\u4e3a\u75b2\u8f6f\uff0c\u5c24\u5176\u662f\u6d88\u8d39\u548c\u653f\u5e9c\u76f8\u5173\u7684\u652f\u51fa\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u8fd1\u671f\u653f\u7b56\u6709\u52a9\u63d0\u632f\u5e74\u5e95\u524d\u589e\u957f\uff0c\u8d22\u653f\u63aa\u65bd\u82e5\u5982\u671f\u843d\u5730\u5c06\u6709\u52a9\u626d\u8f6c\u4eca\u5e74\u8fc4\u4eca\u4e3a\u6b62\u7684\u8d22\u653f\u7d27\u7f29\u3002\u8be5\u884c\u4f30\u7b97\uff0c\u8d22\u653f\u63d0\u9ad8\u56db\u5b63\u5ea6\u652f\u6301\u5c06\u7f13\u89e3\u5730\u65b9\u653f\u5e9c\u7684\u652f\u51fa\u9650\u5236\uff0c\u5bf9\u7b2c\u56db\u5b63\u5ea6GDP\u589e\u957f\u53ef\u67091\u4e2a\u767e\u5206\u70b9\u6216\u4ee5\u4e0a\u7684\u8d21\u732e\uff0c\u5c06\u6709\u52a9\u4e8e\u5b9e\u73b0\u4eca\u5e745%\u7684\u5e74\u5ea6\u589e\u957f\u76ee\u6807\u3002<br/><br/>\u5173\u6ce8\u8d22\u653f\u6539\u9769\u7684\u63a8\u8fdb\u3002\u8fd1\u671f\u5ba3\u5e03\u7684\u623f\u5730\u4ea7\u653f\u7b56\u5c06\u6709\u52a9\u4e8e\u8be5\u884c\u4e1a\u51cf\u5c11\u4f9b\u5e94\u8fc7\u5269\uff0c\u52a0\u5feb\u884c\u4e1a\u8c03\u6574\u3002\u4f46\u8d22\u653f\u6539\u9769\u5bf9\u4e8e\u5efa\u7acb\u516c\u5171\u8d22\u653f\u957f\u6548\u673a\u5236\uff0c\u51cf\u5c11\u5730\u4ea7\u4e0b\u884c\u7684\u8d1f\u9762\u6ea2\u51fa\u6548\u5e94\u81f3\u5173\u91cd\u8981\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255307090", "pub_date": "2024-10-21 10:34:51"}, {"id": 255306588, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5174\u4e1a\u8bc1\u5238\u7ef4\u6301\u7396\u9f99\u7eb8\u4e1a(02689)\u201c\u589e\u6301\u201d\u8bc4\u7ea7 \u6307\u4e0b\u534a\u5e74\u8fdb\u5165\u4f20\u7edf\u65fa\u5b63 \u7eb8\u4ef7\u6709\u671b\u4f01\u7a33\u56de\u5347", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5174\u4e1a\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u7396\u9f99\u7eb8\u4e1a(02689)\u5168\u8d22\u5e74\u9500\u91cf\u540c\u6bd4\u589e\u957f18.3%\u81f3\u7ea61960\u4e07\u5428\uff0c\u4e3b\u8981\u7cfb\u5361\u7eb8\u8d21\u732e\u589e\u91cf\uff0c\u5361\u7eb8/\u9ad8\u5f3a\u74e6\u695e\u82af\u7eb8/\u767d\u677f\u7eb8\u9500\u91cf\u540c\u6bd4\u5206\u522b+32.9%/+3.1%/+4.3%\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u622a\u81f36\u670830\u65e5\uff0c\u9020\u7eb8\u4ea7\u80fd\u589e\u52a0165\u4e07\u5428\u81f32167\u4e07\u5428\uff0c\u516c\u53f8\u5206\u522b\u5728\u5e7f\u897f\u5317\u6d77\u548c\u6e56\u5317\u8346\u5dde\u6269\u5efa240\u4e07\u5428\u767d\u5361\u7eb8\u548c130\u4e07\u5428\u6587\u5316\u7eb8\u4ea7\u80fd\uff0c\u9884\u8ba1FY25\u5c06\u5168\u90e8\u6295\u4ea7\uff0c\u5c4a\u65f6\u603b\u8bbe\u8ba1\u4ea7\u80fd\u5c06\u589e\u52a0370\u4e07\u5428\u81f32537\u4e07\u5428\u3002\u4e3a\u652f\u6301\u6269\u5efa\u9879\u76ee\u8d44\u91d1\u9700\u8981\uff0cFY24\u6709\u606f\u8d1f\u503a\u51c0\u589e133\u4ebf\u5143\u81f3700\u4ebf\u5143\uff0cFY25\u5728\u5efa\u9879\u76ee\u9884\u8ba1\u5c06\u5168\u90e8\u5b8c\u5de5\uff0cFY2026\u8d44\u672c\u5f00\u652f\u6709\u671b\u5927\u5e45\u6536\u7f29\uff0c\u5e76\u5f00\u542f\u6301\u7eed\u8fd8\u503a\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u884c\u4e1a\u53d7\u5236\u4e8e\u4f9b\u9700\u77db\u76fe\uff0c\u76c8\u5229\u5904\u4e8e\u78e8\u5e95\u9636\u6bb5\uff1b\u968f\u7740Suzano\u6295\u4ea7\uff0c\u6d77\u5916\u9614\u53f6\u6d46\u5916\u76d8\u62a5\u4ef7\u8fde\u7eed\u5927\u5e45\u4e0b\u8c03\uff0c\u516c\u53f8\u6210\u672c\u538b\u529b\u7ee7\u7eed\u7f13\uff1b\u653f\u7b56\u52a0\u529b\u6269\u5927\u5185\u9700\uff0c\u9759\u5f85\u7ecf\u6d4e\u666f\u6c14\u56de\u6696\uff0c\u53e0\u52a0\u4e0b\u534a\u5e74\u8fdb\u5165\u4f20\u7edf\u65fa\u5b63\uff0c\u7eb8\u4ef7\u6709\u671b\u4f01\u7a33\u56de\u5347\u3002\u8be5\u884c\u9884\u8ba1\u516c\u53f8FY25/26/27\u6536\u5165\u5206\u522b\u4e3a648.96/693.46/739.48\u4ebf\u5143\uff0c\u540c\u6bd4\u5206\u522b+9.1%/+6.9%/+6.6%\uff0c\u5f52\u6bcd\u51c0\u5229\u6da6\u5206\u522b\u4e3a12.58/16.61/20.84\u4ebf\u5143\uff0c\u540c\u6bd4\u5206\u522b+66.7%/+30.4%/+24.6%\uff0c10\u670817\u65e5\u6536\u76d8\u4ef7\u5bf9\u5e94FY2025\u9884\u6d4bBPS\u7684PB\u4e3a0.31x\uff0c\u7ef4\u6301\u201c\u589e\u6301\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255306588", "pub_date": "2024-10-21 10:19:34"}, {"id": 255306587, "title": "\u9ec4\u91d1\u80a1\u5168\u7ebf\u98d8\u7ea2 \u7d2b\u91d1\u77ff\u4e1a(02899)\u6da84.53% \u5e02\u573a\u9884\u671f\u7f8e\u8054\u50a8\u964d\u606f\u53ca\u5730\u7f18\u5c40\u52bf\u52a9\u63a8\u91d1\u4ef7\u4e0a\u884c", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9ec4\u91d1\u80a1\u5168\u7ebf\u98d8\u7ea2\uff0c\u4e2d\u56fd\u767d\u94f6\u96c6\u56e2(00815)\u6da811.11%\uff0c\u7075\u5b9d\u9ec4\u91d1(03330)\u6da85.33%\uff0c\u7d2b\u91d1\u77ff\u4e1a(02899)\u6da84.53%\uff0c\u4e2d\u56fd\u9ec4\u91d1\u56fd\u9645(02099)\u6da84.4%\uff0c\u96c6\u6d77\u8d44\u6e90(02489)\u6da83.85%\uff0c\u5c71\u4e1c\u9ec4\u91d1(01787)\u6da82.62%\u3002<br/><br/>\u4e1c\u5434\u8bc1\u5238\u8868\u793a\uff0c\u968f\u7740\u6b27\u592e\u884c\u964d\u606f\u843d\u5730\uff0c\u5e02\u573a\u52a0\u7801\u7f8e\u8054\u50a811\u6708\u7ee7\u7eed\u964d\u606f25bp\uff0c\u8d27\u5e01\u5bbd\u677e\u80cc\u666f\u4e0b\u7684\u518d\u901a\u80c0\u60c5\u666f\u6b63\u5728\u52a0\u901f\u52a9\u63a8\u9ec4\u91d1\u4e0a\u6da8\uff1b\u5730\u7f18\u653f\u6cbb\u65b9\u9762\uff0c\u671d\u9c9c\u534a\u5c9b\u548c\u4e2d\u4e1c\u51b2\u7a81\u4ecd\u6709\u8fdb\u4e00\u6b65\u5347\u7ea7\u7684\u8d8b\u52bf\uff0c\u6295\u8d44\u8005\u56e0\u907f\u9669\u9700\u6c42\u6d8c\u5165\u9ec4\u91d1\u5e02\u573a\u3002\u4e0a\u5468\u6d77\u5185\u5916\u9ec4\u91d1\u4ef7\u683c\u53d7\u6b64\u63d0\u632f\u53cc\u53cc\u4e0a\u6da8\uff0c\u9884\u8ba1\u77ed\u671f\u9ec4\u91d1\u4ef7\u683c\u4ecd\u6709\u4e0a\u884c\u52a8\u80fd\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255306587", "pub_date": "2024-10-21 10:20:00"}]}