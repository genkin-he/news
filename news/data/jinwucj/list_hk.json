c\u5c06\u8c28\u614e\u5730\u6269\u5f20\u548c\u62db\u8058\uff0c\u4ee5\u652f\u6491\u6559\u80b2\u4e1a\u52a1\u53d1\u5c55\u3002\u516c\u53f8\u9884\u8ba12025\u8d22\u5e74\u7b2c\u4e8c\u5b63\u5ea6(2024\u5e749\u67081\u65e5\u81f32024\u5e7411\u670830\u65e5)\u7684\u51c0\u8425\u6536(\u4e0d\u5305\u62ec\u4e1c\u65b9\u7504\u9009\u81ea\u8425\u4ea7\u54c1\u53ca\u76f4\u64ad\u7535\u5546\u4e1a\u52a1\u5b9e\u73b0\u7684\u8425\u6536)\u5c06\u4e3a8.514\u4ebf\u7f8e\u5143\u81f38.718\u4ebf\u7f8e\u5143\u4e4b\u95f4\uff0c\u540c\u6bd4\u4e0a\u534725%\u81f328%\u3002\u800c\u6b64\u524d\uff0c\u516c\u53f8\u7ed9\u5e02\u573a\u7684\u4e00\u81f4\u662f2025\u5e7430%\u4ee5\u4e0a\u7684\u589e\u957f\u9884\u671f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255640327", "pub_date": "2024-10-24 10:04:03"}, {"id": 255639942, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4e1c\u5434\u8bc1\u5238\u7ef4\u6301\u6ce1\u6ce1\u739b\u7279(09992)\u4e70\u5165\u8bc4\u7ea7 \u770b\u597d\u4f18\u8d28IP\u9a71\u52a8\u516c\u53f8\u5168\u6e20\u9053\u6536\u5165\u5feb\u901f\u589e\u957f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e1c\u5434\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u6ce1\u6ce1\u739b\u7279(09992)\u53d1\u5e032024Q3\u4e1a\u52a1\u60c5\u51b5\uff0c\u6574\u4f53\u6536\u5165\uff08\u672a\u7ecf\u5ba1\u6838\uff09\u540c\u6bd4\u589e\u957f120%-125%\uff0c\u5176\u4e2d\u4e2d\u56fd\u5185\u5730\u6536\u5165\u540c\u6bd4\u589e\u957f55%-60%\uff0c\u4e2d\u56fd\u6e2f\u6fb3\u53f0\u53ca\u6d77\u5916\u6536\u5165\u540c\u6bd4\u589e\u957f440%-445%\u3002\u516c\u53f8\u4e1a\u7ee9\u5927\u8d85\u5e02\u573a\u9884\u671f\u3002<br/><br/>\u8be5\u884c\u6307\uff0cQ3\u516c\u53f8\u5728\u4e2d\u56fd\u5185\u5730\u6536\u5165\u540c\u6bd4\u589e\u901f\u73af\u6bd4\u52a0\u5feb\uff0c\u5176\u4e2d\u7ebf\u4e0b\u7684\u96f6\u552e\u5e97\u6536\u5165yoy+30%~35%\uff08\u8be5\u884c\u9884\u8ba1\u4e3b\u8981\u9760\u540c\u5e97\u589e\u957f\u9a71\u52a8\uff09\uff0c\u673a\u5668\u4eba\u5546\u5e97\u6536\u5165yoy+20%~25%\uff0c\u6279\u53d1\u53ca\u5176\u5b83\u6e20\u9053\uff08\u542b\u4e50\u56ed\uff09\u6536\u5165yoy+45%~50%\u3002\u7ebf\u4e0a\u65b9\u9762\uff0c\u62bd\u76d2\u673a\u6536\u5165yoy+55%~60%\uff0c\u5929\u732b\u65d7\u8230\u5e97\u6536\u5165yoy+155%~160%\uff0c\u6296\u97f3\u65d7\u8230\u5e97\u6536\u5165yoy+115%~120%\u3002\u53e6\u5916\uff0c\u516c\u53f8\u5728\u4e2d\u56fd\u6e2f\u6fb3\u53f0\u53ca\u6d77\u5916\u6536\u5165yoy+440%~445%\u3002labubu\u5728\u6cf0\u56fd\u52a0\u901f\u51fa\u5708\u63a8\u52a8\u6d77\u5916\u5e02\u573a\u589e\u957f\u63d0\u901f\u3002<br/><br/>\u8be5\u884c\u7ee7\u7eed\u770b\u597d\u4f18\u8d28IP\u9a71\u52a8\u516c\u53f8\u5168\u6e20\u9053\u6536\u5165\u5feb\u901f\u589e\u957f\uff0c\u5c062024-2026\u5e74\u7ecf\u8c03\u6574\u51c0\u5229\u6da6\u9884\u6d4b\u4ece23.02/30.28/36.79\u4ebf\u5143\u4e0a\u8c03\u81f329.37/38.18/47.07\u4ebf\u5143\uff0c\u5bf9\u5e94PE\u7ea631/24/20\u500d\uff0c\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002\uff08\u4eba\u6c11\u5e01\u5151\u6e2f\u5143\u6c47\u7387\u53d62024/10/231\u6e2f\u5e01=0.92\u4eba\u6c11\u5e01\uff09\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255639942", "pub_date": "2024-10-24 09:58:47"}, {"id": 255640004, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4e2d\u5174\u901a\u8baf(00763)\u9006\u5e02\u5347\u903e2.3% \u673a\u6784\u770b\u597d\u5176\u5176\u5ef6\u5c55\u7b97\u529b\u7b2c\u4e8c\u66f2\u7ebf", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u5174\u901a\u8baf(00763)\u9006\u5e02\u4e0a\u626c\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a519.98\u6e2f\u5143\uff0c\u6da82.36%\uff0c\u6210\u4ea4\u989d1.9\u4ebf\u6e2f\u5143\u3002</p><p>\u534e\u6cf0\u8bc1\u5238\u53d1\u8868\u62a5\u544a\uff0c\u6307\u4e2d\u5174\u7b2c\u4e09\u5b63\u4e1a\u7ee9\u77ed\u671f\u627f\u538b\uff0c\u6536\u5165\u6309\u5e74\u8dcc4%\uff0c\u7eaf\u5229\u6309\u5e74\u8dcc8%\u81f321.7\u4ebf\u5143\u4eba\u6c11\u5e01(\u4e0b\u540c)\uff0c\u900a\u8be5\u884c\u9884\u671f\u768424.4\u4ebf\u5143\u3002\u8be5\u884c\u6599\u4e3b\u56e0\u8425\u8fd0\u5546\u677f\u5757\u6536\u5165\u627f\u538b\uff0c\u53e0\u52a0\u76c8\u5229\u80fd\u529b\u6709\u6240\u6ce2\u52a8\u3002</p><p>\u8be5\u884c\u770b\u597d\u4e2d\u5174\u5ef6\u5c55\u7b97\u529b\u7b2c\u4e8c\u66f2\u7ebf\uff0c\u5176\u6301\u7eed\u5411\u201c\u8fde\u63a5+\u7b97\u529b\u201d\u62d3\u5c55\uff0c\u6316\u6398\u667a\u7b97\u57fa\u7840\u8bbe\u65bd(AI\u670d\u52a1\u5668+\u96c6\u7fa4\u7ec4\u7f51\u4e92\u8054\uff09\u30015G-A\u5546\u7528\u957f\u671f\u4ef7\u503c\u3002</p><p>\u8be5\u884c\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0cH\u80a1\u76ee\u6807\u4ef725.51\u6e2f\u5143\uff0c\u76f8\u5f53\u4e8e\u660e\u5e74\u9884\u6d4b\u5e02\u76c8\u738710\u500d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255640004", "pub_date": "2024-10-24 09:59:46"}, {"id": 255639637, "title": "\u5149\u4f0f\u592a\u9633\u80fd\u968f\u5e02\u56de\u8c03 \u987a\u98ce\u6e05\u6d01\u80fd\u6e90(01165)\u8dcc\u903e12% \u673a\u6784\u6307\u884c\u4e1a\u534f\u4f1a\u201c\u6210\u672c\u6cd5\u201d\u6709\u5229\u7ec4\u4ef6\u73af\u8282\u5229\u6da6\u4fee\u590d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5149\u4f0f\u592a\u9633\u80fd\u968f\u5e02\u56de\u8c03\uff0c\u987a\u98ce\u6e05\u6d01\u80fd\u6e90(01165)\u8dcc12.5%\uff0c\u9633\u5149\u80fd\u6e90(00757)\u8dcc14.29%\uff0c\u6c34\u53d1\u5174\u4e1a\u80fd\u6e90(00750)\u8dcc5.13%\uff0c\u51ef\u76db\u65b0\u80fd(01108)\u8dcc3.9%\uff0c\u4fe1\u4e49\u73bb\u7483(00868)\u8dcc1.99%\uff0c\u4fe1\u4e49\u5149\u80fd(00968)\u8dcc1.32%\u3002<br/><br/>\u7f8e\u56fd\u5546\u52a1\u90e810\u670821\u65e5\u8d77\u542f\u52a8\u53d8\u66f4\u60c5\u51b5\u5ba1\u67e5(CCR)\uff0c\u8003\u8651\u90e8\u5206\u64a4\u9500\u4e2d\u56fd\u6676\u4f53\u7845\u5149\u4f0f\u7535\u6c60\u7684\u53cd\u503e\u9500\u7a0e\u548c\u53cd\u8865\u8d34\u7a0e\uff08AD/CVD\uff09\uff0c\u5e76\u9080\u8bf7\u76f8\u5173\u5404\u65b9\u53d1\u8868\u610f\u89c1\uff0c\u6240\u6d89\u4ea7\u54c1\u4e3a\u67d0\u4e9b\u5c0f\u578b\u3001\u4f4e\u74e6\u6570\u3001\u79bb\u7f51\u6676\u7845\u5149\u4f0f\uff08CSPV\uff09\u7535\u6c60\u3002\u5206\u6790\u6307\u51fa\u6b64\u4e3e\u610f\u5473\u7740\u7f8e\u56fd\u5bf9\u4e2d\u56fd\u5149\u4f0f\u7ec4\u4ef6\u4ea7\u54c1\u5173\u7a0e\u653f\u7b56\u51fa\u73b0\u4e86\u677e\u52a8\uff0c\u662f\u4e2d\u7f8e\u5173\u7cfb\u7f13\u548c\u7684\u5f81\u5146\uff0c\u540e\u7eed\u4e0d\u6392\u9664\u5149\u4f0f\u4ea7\u54c1\u8c41\u514d\u8303\u56f4\u8fdb\u2014\u6b65\u6269\u5927\u7684\u53ef\u80fd\u6027\u3002<br/><br/>\u4e2d\u94f6\u56fd\u9645\u8868\u793a\uff0c\u4e2d\u56fd\u5149\u4f0f\u884c\u4e1a\u534f\u4f1a\u62ab\u9732\u5149\u4f0f\u4ea7\u4e1a\u94fe\u6210\u672c\u6570\u636e\uff0c\u82e5\u51fa\u73b0\u7ec4\u4ef6\u4f4e\u4e8e\u6210\u672c\u4e2d\u6807\uff0c\u4ee5\u53ca\u4f4e\u4e8e\u6210\u672c\u4e2d\u6807\u540e\u53ef\u80fd\u51fa\u73b0\u7684\u4ee5\u6b21\u5145\u597d\u3001\u4e0d\u80fd\u5c65\u7ea6\u7684\u884c\u4e3a\uff0c\u534f\u4f1a\u5c06\u8003\u8651\u91c7\u53d6\u5168\u884c\u4e1a\u901a\u62a5\u3001\u5411\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u4e3e\u62a5\u7b49\u65b9\u5f0f\uff0c\u52a0\u5f3a\u884c\u4e1a\u81ea\u5f8b\u3002\u7531\u4e8e\u7ec4\u4ef6\u5382\u9700\u8981\u516c\u5f00\u53c2\u4e0e\u7ec8\u7aef\u7535\u7ad9\u9879\u76ee\u62db\u6295\u6807\uff0c\u6295\u6807\u4ef7\u683c\u5177\u5907\u5f3a\u900f\u660e\u5ea6\uff0c\u76f8\u5bf9\u6613\u4e8e\u53d7\u7b2c\u4e09\u65b9\u76d1\u7ba1\uff0c\u56e0\u6b64\u534f\u4f1a\u901a\u8fc7\u201c\u6210\u672c\u6cd5\u201d\u6307\u5bfc\u5e02\u573a\u4ef7\u683c\u5c06\u7387\u5148\u63a8\u52a8\u7ec4\u4ef6\u4ef7\u683c\u63d0\u5347\uff0c\u6709\u5229\u4e8e\u7ec4\u4ef6\u73af\u8282\u5229\u6da6\u4fee\u590d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255639637", "pub_date": "2024-10-24 09:53:27"}, {"id": 255639218, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u91d1\u6c99\u4e2d\u56fd(01928)\u76d8\u521d\u5347\u8fd13% \u7b2c\u4e09\u5b63\u5ea6\u51c0\u6536\u5165\u6309\u5e74\u5347\u903e16%\u81f32.68\u4ebf\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u91d1\u6c99\u4e2d\u56fd(01928)\u76d8\u521d\u9006\u5e02\u626c\u5347\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da82.68%\uff0c\u62a519.16\u6e2f\u5143\uff0c\u6210\u4ea4\u989d477.61\u4e07\u6e2f\u5143\u3002</p><p>\u516c\u53f8\u6668\u95f4\u516c\u544a\uff0c\u6839\u636e\u7f8e\u56fd\u516c\u8ba4\u4f1a\u8ba1\u539f\u5219\uff0c\u7b2c\u4e09\u5b63\u5ea6\uff0c\u516c\u53f8\u51c0\u6536\u51652.68\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f16.02%\uff1b\u51c0\u6536\u76ca\u603b\u989d\u4e3a17.7\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u51cf\u5c111%\uff1b\u7ecf\u8c03\u6574\u7269\u4e1aEBITDA\u540c\u6bd4\u51cf\u5c117.29\u81f35.85\u4ebf\u7f8e\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255639218", "pub_date": "2024-10-24 09:46:30"}, {"id": 255639277, "title": "\u3010\u884c\u4e1a\u98ce\u5411\u3011\u964d\u4ef7\u6f6e\u5e2d\u5377\u75ab\u82d7\u884c\u4e1a\uff1b\u9e4f\u57ce\u4f4e\u7a7a\u7ecf\u6d4e\u53c8\u6dfb\u201c\u7a7a\u6295\u201d\u573a\u666f", "description": "<p><b>OpenAI\u53d1\u5e03\u5168\u65b0\u6a21\u578bsCM</b><br/><br/>sCM\u5c06\u5f00\u542f\u89c6\u9891\uff0c\u56fe\u50cf\u3001\u4e09\u7ef4\u6a21\u578b\u3001\u97f3\u9891\u7b49\u5b9e\u65f6\u3001\u9ad8\u8d28\u91cf\u3001\u8de8\u9886\u57df\u7684\u751f\u6210\u5f0f\u4eba\u5de5\u667a\u80fd\u65b0\u9636\u6bb5\uff0c\u53ea\u9700\u4e24\u6b65\u91c7\u6837\uff0c\u901f\u5ea6\u63d0\u5347 50 \u500d\uff0c\u6027\u80fd\u76f4\u903c\u751a\u81f3\u8d85\u8d8a\u6269\u6563\u6a21\u578b\u3002\u5982\u679c\u518d\u8fdb\u884c\u7cfb\u7edf\u4f18\u5316\uff0c\u901f\u5ea6\u8fd8\u80fd\u66f4\u5feb\u3002<br/><br/>sCM\u4f5c\u4e3a\u5176\u524d\u671f\u4e00\u81f4\u6027\u6a21\u578b\u7814\u7a76\u7684\u5ef6\u7eed\u548c\u6539\u8fdb\uff0c\u7b80\u5316\u4e86\u7406\u8bba\u6846\u67b6\uff0c\u5b9e\u73b0\u4e86\u5927\u89c4\u6a21\u6570\u636e\u96c6\u7684\u7a33\u5b9a\u8bad\u7ec3\uff0c\u540c\u65f6\u4fdd\u6301\u4e86\u4e0e\u9886\u5148\u6269\u6563\u6a21\u578bDiffusion models \u76f8\u5f53\u7684\u6837\u672c\u8d28\u91cf\uff0c\u4f46\u4ec5\u9700\u4e24\u6b65\u91c7\u6837\u5373\u53ef\u5b8c\u6210\u751f\u6210\u8fc7\u7a0b\u3002<br/><br/>\u6765\u6e90\uff1a\u534e\u5c14\u8857\u89c1\u95fb<br/><br/><b>\u964d\u4ef7\u6f6e\u5e2d\u5377\u75ab\u82d7\u884c\u4e1a</b><br/><br/>10\u670823\u65e5\uff0c\"\u5409\u6797\u53d1\u5e03\"\u4fe1\u606f\u663e\u793a\uff0c\u4e0b\u8c03\u90e8\u5206\u975e\u514d\u75ab\u89c4\u5212\u75ab\u82d7\u6302\u7f51\u4ef7\u683c\uff0c\u4e3b\u8981\u6d89\u53ca\u7834\u4f24\u98ce\u3001\u6d41\u611f\u300123\u4ef7\u80ba\u708e\u3001\u9ebb\u816e\u98ce\u3001\u4e59\u809d\u7b49\u90e8\u5206\u578b\u53f7\u75ab\u82d7\u3002<br/><br/>\u4eca\u5e74\u4ee5\u6765\uff0c\u964d\u4ef7\u6f6e\u5e2d\u5377\u75ab\u82d7\u884c\u4e1a\uff0c\u591a\u5bb6\u75ab\u82d7\u4f01\u4e1a\u7eb7\u7eb7\u8ddf\u8fdb\uff0c\u4e00\u4e9b\u75ab\u82d7\u4ea7\u54c1\u4ef7\u683c\u8fde\u7eed\u521b\u51fa\u5386\u53f2\u65b0\u4f4e\u3002<br/><br/>\u6765\u6e90\uff1a\u7b2c\u4e00\u8d22\u7ecf<br/><br/><b>\u9e4f\u57ce\u4f4e\u7a7a\u7ecf\u6d4e\u53c8\u6dfb\u201c\u7a7a\u6295\u201d\u573a\u666f</b><br/><br/>10\u670823\u65e5\uff0c\u7f8e\u56e2\u65e0\u4eba\u673a\u798f\u7530\u53e3\u5cb8\u822a\u7ebf\u6b63\u5f0f\u5f00\u822a\uff0c\u8fd9\u662f\u56fd\u5185\u9996\u6761\u8bbe\u5728\u53e3\u5cb8\u533a\u57df\u7684\u5e38\u6001\u5316\u65e0\u4eba\u673a\u914d\u9001\u822a\u7ebf\u3002\u822a\u7ebf\u5f00\u901a\u540e\uff0c\u6bcf\u65e5\u5728\u6e2f\u6df1\u4e4b\u95f4\u5f80\u8fd4\u7684\u5e02\u6c11\uff0c\u5728\u53e3\u5cb8\u9644\u8fd1\u70b9\u5916\u5356\u5c06\u53ef\u4eab\u53d7\u201c\u7a7a\u6295\u201d\u670d\u52a1\uff0c\u4e0b\u5355\u540e\u6700\u5feb10\u5206\u949f\u5373\u53ef\u5728\u6307\u5b9a\u964d\u843d\u70b9\u53d6\u8d27\u3002<br/><br/>\u8fd1\u5e74\u6765\uff0c\u7f8e\u56e2\u65e0\u4eba\u673a\u4e5f\u5728\u6301\u7eed\u52a0\u7801\u57ce\u5e02\u573a\u666f\u7684\u5e94\u7528\u843d\u5730\uff0c\u5b8c\u6210\u4e86\u529e\u516c\u3001\u793e\u533a\u3001\u666f\u533a\u7b49\u591a\u573a\u666f\u5e03\u5c40\u3002\u622a\u81f32024\u5e749\u6708\u5e95\uff0c\u7f8e\u56e2\u65e0\u4eba\u673a\u5728\u6df1\u5733\u7b49\u57ce\u5e02\u5f00\u901a43\u6761\u822a\u7ebf\uff0c\u7d2f\u8ba1\u5b8c\u6210\u8ba2\u5355\u8d8536\u4e07\u5355\uff0c\u53ef\u4e3a\u7528\u6237\u914d\u90019\u4e07\u4f59\u79cd\u5546\u54c1\u3002<br/><br/>\u6765\u6e90\uff1a\u6df1\u5733\u5546\u62a5<br/><br/>\u5238\u5546\u79ef\u6781\u53c2\u4e0e\u4e92\u6362\u4fbf\u5229\u64cd\u4f5c \u201c\u9996\u7b14\u201d\u201c\u9996\u5355\u201d\u201c\u9996\u6279\u201d\u5747\u843d\u5730<br/><br/>10\u670821\u65e5\uff0c\u4e2d\u56fd\u4eba\u6c11\u94f6\u884c\u5f00\u5c55\u4e86\u8bc1\u5238\u3001\u57fa\u91d1\u3001\u4fdd\u9669\u516c\u53f8\u4e92\u6362\u4fbf\u5229\uff08SFISF\uff09\u9996\u6b21\u64cd\u4f5c\uff0c\u968f\u540e\uff0c\u5238\u5546\u5feb\u901f\u54cd\u5e94\uff0c\u79ef\u6781\u63a8\u8fdbSFISF\u4e1a\u52a1\u843d\u5730\u3002\u300a\u8bc1\u5238\u65e5\u62a5\u300b\u8bb0\u8005\u4e86\u89e3\u5230\uff0c\u4e2d\u91d1\u516c\u53f8\u7387\u5148\u8fbe\u6210SFISF\u4e0b\u9996\u7b14\u8d28\u62bc\u5f0f\u56de\u8d2d\u4ea4\u6613\uff0c\u5e76\u9996\u6b21\u4e70\u5165\u80a1\u7968\uff1b\u56fd\u6cf0\u541b\u5b89\u5df2\u5b8c\u6210SFISF\u4e0b\u5168\u5e02\u573a\u9996\u5355\u56fd\u503a\u6362\u5165\u4ea4\u6613\u4ee5\u53ca\u9996\u6279\u56fd\u503a\u8d28\u62bc\u5f0f\u56de\u8d2d\u4ea4\u6613\u3002<br/><br/>\u534e\u6cf0\u8bc1\u5238\u94f6\u884c\u8bc1\u5238\u9996\u5e2d\u5206\u6790\u5e08\u6c88\u5a1f\u8868\u793a\uff1a\u201c\u4e92\u6362\u4fbf\u5229\u673a\u5236\u8bbe\u8ba1\u5177\u6709\u9006\u5468\u671f\u8c03\u8282\u4f5c\u7528\uff0c\u5f15\u5bfc\u53c2\u4e0e\u673a\u6784\u5728\u5e02\u573a\u6ce2\u52a8\u4e2d\u5145\u5206\u53d1\u6325\u2018\u538b\u8231\u77f3\u2019\u4f5c\u7528\uff0c\u6709\u6548\u4fc3\u8fdb\u673a\u6784\u6295\u8d44\u8005\u53d1\u6325\u7a33\u5b9a\u5668\u4f5c\u7528\u3001\u589e\u5f3a\u8d44\u672c\u5e02\u573a\u5185\u5728\u7a33\u5b9a\u6027\u3002\u201d</p>", "link": "https://sky.szfiu.com/info/hk/details/255639277", "pub_date": "2024-10-24 09:47:18"}, {"id": 255638696, "title": "\u9694\u665a\u91d1\u4ef7\u4e0b\u6ed1 \u62d6\u7d2f\u9ec4\u91d1\u80a1\u8868\u73b0 \u5c71\u4e1c\u9ec4\u91d1(01787)\u8dcc4.23% ", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9ec4\u91d1\u80a1\u666e\u8dcc\uff0c\u5c71\u4e1c\u9ec4\u91d1(01787)\u8dcc4.23%\uff0c\u62db\u91d1\u77ff\u4e1a(01818)\u8dcc2.74%\uff0c\u4e2d\u56fd\u9ec4\u91d1\u56fd\u9645(02099)\u8dcc2.78%\uff0c\u7d2b\u91d1\u77ff\u4e1a(02899)\u8dcc2.65%\uff0c\u7075\u5b9d\u9ec4\u91d1(03330)\u8dcc2.18%\u3002<br/><br/>\u56e0\u7f8e\u5143\u53ca\u7f8e\u503a\u606f\u4e0a\u5347\uff0c\u9694\u665a\u56fd\u9645\u91d1\u4ef7\u4e0b\u8dcc\u3002\u7ebd\u7ea6\u671f\u91d1\u6bcf\u76ce\u53f8\u6536\u62a52729.4\u7f8e\u5143\uff0c\u8dcc1.1%\u3002<br/><br/>\u9650\u5236\u8d35\u91d1\u5c5e\u6da8\u5e45\u7684\u539f\u56e0\u5728\u4e8e\u5168\u7403\u503a\u5238\u66b4\u8dcc\uff0c\u9053\u660e\u8bc1\u5238\uff08TD Securities\uff09\u4e9a\u592a\u533a\u9ad8\u7ea7\u5229\u7387\u7b56\u7565\u5e08\u666e\u62c9\u6851\u7279\u00b7\u7ebd\u7eb3\u54c8\uff08Prashant Newnaha\uff09\u8868\u793a\uff0c\u201c\u672c\u5468\u7f8e\u56fd\u56fd\u503a\u629b\u552e\u52a0\u5267\uff0c\u56e0\u4e3a\u5e02\u573a\u62c5\u5fc3\uff0c\u5982\u679c\u7f8e\u8054\u50a8\u5728\u7ecf\u6d4e\u5f3a\u52b2\u7684\u80cc\u666f\u4e0b\u653e\u677e\u653f\u7b56\uff0c\u5c31\u6709\u53ef\u80fd\u91cd\u65b0\u70b9\u71c3\u901a\u80c0\u3002\u201d</p>", "link": "https://sky.szfiu.com/info/hk/details/255638696", "pub_date": "2024-10-24 09:37:43"}, {"id": 255638359, "title": "\u4eba\u6c11\u5e01\u5151\u7f8e\u5143\u4e2d\u95f4\u4ef7\u62a57.1286 \u8c03\u8d2c41\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf | 2024\u5e7410\u670824\u65e5\uff0c\u4eba\u6c11\u5e01\u5151\u7f8e\u5143\u4e2d\u95f4\u4ef7\u62a57.1286\uff0c\u8c03\u8d2c41\u70b9\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255638359", "pub_date": "2024-10-24 09:31:10"}]}