4e07\u3002\u8fd8\u9884\u8ba1\u52b3\u52a8\u529b\u53c2\u4e0e\u7387\u5c06\u53cd\u5f39\uff0c\u4f7f\u5931\u4e1a\u7387\u4ece4.1%\u5347\u81f34.2%\uff0c\u4e0e\u300a\u534e\u5c14\u8857\u65e5\u62a5\u300b\u7684\u9884\u671f\u4e00\u81f4\u3002\u7f8e\u56fd\u94f6\u884c\u8868\u793a\uff0c\u5728\u98d3\u98ce\u5f71\u54cd\u4e0b\uff0c\u7533\u8bf7\u5931\u4e1a\u91d1\u4eba\u6570\u6709\u6240\u589e\u52a0\uff0c\u4f46\u6b64\u540e\u6709\u6240\u4e0b\u964d\uff0c\u8868\u660e\u7ecf\u6d4e\u8fc5\u901f\u590d\u82cf\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259451271", "pub_date": "2024-12-03 23:11:45"}, {"id": 259450077, "title": "\u7f8e\u56fd10\u6708JOLTs\u804c\u4f4d\u7a7a\u7f3a774.4\u4e07\u4eba \u9884\u671f747.5\u4e07\u4eba", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd10\u6708JOLTs\u804c\u4f4d\u7a7a\u7f3a 774.4\u4e07\u4eba\uff0c\u9884\u671f747.5\u4e07\u4eba\uff0c\u524d\u503c\u7531744.3\u4e07\u4eba\u4fee\u6b63\u4e3a737.2\u4e07\u4eba\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259450077", "pub_date": "2024-12-03 23:05:35"}, {"id": 259448097, "title": "\u65b0\u4e1c\u65b9(EDU)\u76d8\u521d\u6da8\u8d854% \u516c\u53f8\u6e2f\u80a1\u83b7\u7eb3\u6052\u751f\u6307\u6570", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u65b0\u4e1c\u65b9(EDU)\u76d8\u521d\u6da8\u8d854%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a562.75\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c11\u670822\u65e5\uff0c\u6052\u751f\u6307\u6570\u6709\u9650\u516c\u53f8\u53d1\u5e03\u4e86\u622a\u81f32024\u5e749\u670830\u65e5\u6052\u751f\u6307\u6570\u7cfb\u5217\u5b63\u5ea6\u68c0\u8ba8\u7ed3\u679c\uff0c\u65b0\u4e1c\u65b9\u6b63\u5f0f\u83b7\u7eb3\u5165\u4e3a\u6052\u751f\u6307\u6570\u6210\u5206\u80a1\uff0c\u53d8\u52a8\u5c06\u4e8e12\u67089\u65e5(\u4e0b\u5468\u4e00)\u8d77\u751f\u6548\u3002\u4e2d\u91d1\u8868\u793a\uff0c\u9884\u8ba1\u8fdb\u5165\u6052\u751f\u6307\u6570\u5c06\u4e3a\u65b0\u4e1c\u65b9-S\u5e26\u67656355\u4e07\u7f8e\u5143\u88ab\u52a8\u8d44\u91d1\u6d41\u5165\uff0c\u6d41\u5165\u65f6\u95f4\u7ea6\u4e3a1.6\u5929\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259448097", "pub_date": "2024-12-03 22:55:09"}, {"id": 259446915, "title": "Zscaler(ZS)\u7b2c\u4e8c\u8d22\u5b63\u4e1a\u7ee9\u6307\u5f15\u57fa\u672c\u7b26\u5408\u5e02\u573a\u9884\u671f \u60df\u80a1\u4ef7\u76d8\u521d\u8dcc\u903e5% ", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f51\u7edc\u5b89\u5168\u63d0\u4f9b\u5546Zscaler(ZS)\u76d8\u521d\u8dcc\u903e5%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a5198.55\u7f8e\u5143\u3002</p><p>\u6d88\u606f\u9762\u4e0a\uff0cZscaler\u516c\u5e032025\u8d22\u5e74\u7b2c\u4e00\u5b63\u5ea6\u4e1a\u7ee9\uff0c\u8425\u6536\u4e3a6.2796\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f26%\uff0c\u9ad8\u4e8e\u5206\u6790\u5e08\u9884\u671f\u76846.062\u4ebf\u7f8e\u5143\uff1b\u8c03\u6574\u540e\u6bcf\u80a1\u76c8\u5229\u4e3a77\u7f8e\u5206\uff0c\u8d85\u8fc7\u5206\u6790\u5e08\u9884\u671f\u768463\u7f8e\u5206\u3002\u9012\u5ef6\u6536\u5165\u540c\u6bd4\u589e\u957f27%\uff0c\u81f31.7837\u4ebf\u7f8e\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259446915", "pub_date": "2024-12-03 22:49:30"}, {"id": 259444563, "title": " \u97e9\u56fd\u6df1\u591c\u7a81\u53d1 \u907f\u9669\u8d44\u4ea7\u9f50\u4e0a\u6da8", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u97e9\u56fd\u5728\u91ce\u515a\u6210\u5458\u8868\u793a\uff0c\u56fd\u4f1a\u5165\u53e3\u88ab\u5c01\u9501\uff0c\u4ed6\u4eec\u8bd5\u56fe\u63a8\u7ffb\u97e9\u56fd\u603b\u7edf\u5c39\u9521\u60a6\u53d1\u5e03\u7684\u6212\u4e25\u4ee4\u3002\u5728\u91ce\u515a\u9886\u8896\u674e\u5728\u660e\u8868\u793a\uff0c\u5c39\u9521\u60a6\u5ba3\u5e03\u6212\u4e25\u4ee4\u662f\u975e\u6cd5\u7684\uff0c\u662f\u8fdd\u53cd\u5baa\u6cd5\u7684\u3002\u4ed6\u8bf4\uff0c\u519b\u65b9\u6210\u5458\u53ef\u80fd\u4f1a\u8bd5\u56fe\u902e\u6355\u8bae\u5458\u3002<br/><br/>\u97e9\u5143\u5151\u7f8e\u5143\u4e0b\u8dcc\u7ea61%\uff0c\u5904\u4e8e\u4e24\u5e74\u6765\u7684\u4f4e\u70b9\u3002\u7f8e\u5143\u5151\u65e5\u5143USD/JPY\u5931\u5b88149\uff0c\u7eed\u523710\u6708\u65b0\u4f4e\u3002\u8fd9\u4e00\u6d88\u606f\u4ee4\u5e02\u573a\u63aa\u624b\u4e0d\u53ca\uff0c\u5f15\u53d1\u4e86\u5bf9\u503a\u5238\u548c\u65e5\u5143\u7684\u4e70\u76d8\u3002\u5e02\u573a\u53c2\u4e0e\u8005\u60f3\u77e5\u9053\uff0c\u8fd9\u7a76\u7adf\u662f\u9884\u7b97\u63aa\u65bd\u7684\u95ee\u9898\uff0c\u8fd8\u662f\u66f4\u7cdf\u7cd5\u7684\u4e8b\u60c5\u3002\u5728\u7f8e\u503a\u6536\u76ca\u7387\u8d70\u4f4e\u4e4b\u540e\uff0c\u51fa\u73b0\u4e86\u5c0f\u5e45\u56de\u8c03\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259444563", "pub_date": "2024-12-03 22:37:16"}, {"id": 259443978, "title": "\u7f8e\u80a1\u4e09\u5927\u6307\u6570\u5f00\u76d8\u6da8\u8dcc\u4e0d\u4e00 \u7eb3\u6307\u8dcc0.23%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u80a1\u4e09\u5927\u6307\u6570\u5f00\u76d8\u6da8\u8dcc\u4e0d\u4e00\uff0c\u9053\u6307\u6da80.22%\uff0c\u6807\u666e500\u6307\u6570\u5e73\u5f00\uff0c\u7eb3\u6307\u8dcc0.23%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259443978", "pub_date": "2024-12-03 22:34:20"}]}