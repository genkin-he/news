\u4e8e\u94a2\u4ef7\u5c06\u5f62\u6210\u652f\u6491\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254519992", "pub_date": "2024-10-10 14:00:00"}, {"id": 254518731, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u82b1\u65d7\uff1a\u6d77\u901a\u8bc1\u5238(06837)\u4e0a\u6da8\u7a7a\u95f4\u53ef\u80fd\u8f83\u5927 \u5e76\u8d2d\u6216\u5c06\u63d0\u632f\u884c\u4e1a\u60c5\u7eea", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u82b1\u65d7\u53d1\u7814\u6307\uff0c\u6d77\u901a\u8bc1\u5238(06837)\u4e0e\u56fd\u6cf0\u541b\u5b89(02611)\u5408\u5e76\u65f6\u7684\u6362\u80a1\u6bd4\u4f8b\u9884\u793a\u7740\u6d77\u901a\u8bc1\u5238\u7684H\u80a1\u53ef\u80fd\u6709\u5927\u7ea630%\u7684\u589e\u957f\u6f5c\u529b\uff0c\u800c\u5176A\u80a1\u5219\u9762\u4e34\u7ea62.2%\u7684\u4e0b\u884c\u98ce\u9669\u3002\u5c3d\u7ba1\u5982\u6b64\uff0c\u82b1\u65d7\u8ba4\u4e3a\u5b9e\u9645\u4e0a\u6d77\u901a\u8bc1\u5238H\u80a1\u548cA\u80a1\u7684\u589e\u957f\u6f5c\u529b\u53ef\u80fd\u4f1a\u8d85\u51fa\u9759\u6001\u9884\u6d4b\uff0c\u8fd9\u4e3b\u8981\u662f\u56e0\u4e3a\u5728\u6d77\u901a\u8bc1\u5238\u4ece9\u67086\u65e5\u81f310\u67089\u65e5\u505c\u724c\u671f\u95f4\uff0c\u6574\u4e2a\u5238\u5546\u884c\u4e1a\u7684\u8bc4\u4ef7\u6709\u4e86\u663e\u8457\u63d0\u9ad8\uff0c\u9884\u8ba1\u6d77\u901a\u8bc1\u5238\u7684A\u80a1\u548cH\u80a1\u5c06\u80fd\u591f\u8d76\u4e0a\u8fd9\u4e00\u8d8b\u52bf\u3002\u8fd9\u79cd\u589e\u957f\u4e0d\u4ec5\u6709\u671b\u589e\u5f3a\u5e02\u573a\u5bf9\u4e8e\u6f5c\u5728\u5e76\u8d2d\u6d3b\u52a8\u7684\u79ef\u6781\u6027\uff0c\u8fd8\u53ef\u80fd\u60e0\u53ca\u4e2d\u56fd\u94f6\u6cb3\u3001\u4e2d\u91d1\u516c\u53f8\u4ee5\u53ca\u5e7f\u53d1\u8bc1\u5238\u7b49\u5176\u4ed6\u540c\u884c\u3002</p><p>\u7136\u800c\uff0c\u9664\u4e86\u77ed\u671f\u5185\u5bf9\u60c5\u7eea\u7684\u79ef\u6781\u5f71\u54cd\u5916\uff0c\u82b1\u65d7\u4e5f\u6307\u51fa\u968f\u7740\u5238\u5546\u80a1\u7968\u4ef7\u503c\u7684\u63d0\u5347\uff0c\u5e76\u8d2d\u8c08\u5224\u53ef\u80fd\u4f1a\u53d8\u5f97\u66f4\u52a0\u590d\u6742\uff0c\u5bfc\u81f4\u672a\u6765\u7c7b\u4f3c\u4ea4\u6613\u7684\u53ef\u80fd\u6027\u964d\u4f4e\u3002\u62a5\u544a\u8fdb\u4e00\u6b65\u63d0\u5230\uff0c\u6b64\u6b21\u4ea4\u6613\u7ed3\u6784\u6bd4\u539f\u5148\u9884\u671f\u63d0\u524d\u4e868\u4e2a\u4ea4\u6613\u65e5\u516c\u5e03\uff0c\u63a5\u4e0b\u6765\u7684\u5173\u952e\u6b65\u9aa4\u5305\u62ec\u83b7\u5f97\u80a1\u4e1c\u6279\u51c6\u4ee5\u53ca\u5185\u5730\u76d1\u7ba1\u673a\u6784\u7684\u8ba4\u53ef\uff0c\u4ee5\u4fbf\u6700\u7ec8\u5b8c\u6210\u79c1\u6709\u5316\u6d77\u901a\u8bc1\u5238\u5e76\u5c06\u5176\u6574\u5408\u8fdb\u56fd\u6cf0\u541b\u5b89\u7684\u8fc7\u7a0b\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/254518731", "pub_date": "2024-10-10 13:46:43"}, {"id": 254518732, "title": "\u77f3\u6cb9\u80a1\u96c6\u4f53\u56de\u5347 \u4e2d\u6d77\u6cb9(00883)\u6da85.7% \u9ad8\u76db\u6599\u5e03\u4f26\u7279\u539f\u6cb9\u4ef7\u683c\u672a\u6765\u63d0\u9ad8\u6bcf\u687610\u81f320\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u77f3\u6cb9\u80a1\u96c6\u4f53\u56de\u5347\uff0c\u5ef6\u957f\u77f3\u6cb9\u56fd\u9645(00346)\u6da814.29%\uff0c\u4e2d\u6d77\u6cb9\u670d(02883)\u6da87.64%\uff0c\u4e2d\u6d77\u6cb9(00883)\u6da85.7%\uff0c\u6606\u4ed1\u80fd\u6e90(00135)\u6da84.43%\uff0c\u4e2d\u56fd\u77f3\u6cb9(00857)\u6da84.06%\uff0c\u4e2d\u77f3\u5316(00386)\u6da83.75%\u3002<br/><br/>\u9ad8\u76db\u53d1\u5e03\u62a5\u544a\u6307\u51fa\uff0c\u77f3\u6cb9\u5e02\u573a\u7684\u5730\u7f18\u653f\u6cbb\u98ce\u9669\u6ea2\u4ef7\u6307\u6807\u672c\u5468\u5c0f\u5e45\u56de\u843d\u3002\u8be5\u884c\u8ba4\u4e3a\uff0c\u5728\u6ca1\u6709\u91cd\u5927\u5e72\u6270\u7684\u60c5\u51b5\u4e0b\uff0c\u672c\u5b63\u5ea6\u6cb9\u4ef7\u53ef\u80fd\u4f1a\u7a33\u5b9a\u5728\u5f53\u524d\u6c34\u5e73\u9644\u8fd1\uff1b\u4e0d\u8fc7\u9ad8\u76db\u4ecd\u9884\u8ba1\uff0c\u5e03\u4f26\u7279\u539f\u6cb9\u4ef7\u683c\u672a\u6765\u5c06\u8f83\u76ee\u524d\u6c34\u5e73\u63d0\u9ad8\u6bcf\u687610\u81f320\u7f8e\u5143\u3002<br/><br/>\u752c\u5174\u8bc1\u5238\u53d1\u6587\u6307\uff0c\u5728\u56fd\u9645\u6cb9\u4ef7\u9ad8\u4f4d\u8fd0\u884c\u7684\u80cc\u666f\u4e0b\uff0c\u8be5\u884c\u8ba4\u4e3a\u77f3\u6cb9\u5316\u5de5\u677f\u5757\u4e3b\u8981\u6709\u56db\u5927\u6295\u8d44\u4e3b\u7ebf\uff1a1\uff09\u80fd\u6e90\u592e\u4f01\u5927\u529b\u63a8\u52a8\u6cb9\u6c14\u589e\u50a8\u4e0a\u4ea7\uff0c\u6301\u7eed\u6df1\u5316\u70bc\u5316\u8f6c\u578b\u5347\u7ea7\uff0c\u7a33\u6b65\u63a8\u8fdb\u7eff\u8272\u4f4e\u78b3\u8f6c\u578b\uff0c\u5efa\u8bae\u5173\u6ce8\u4e2d\u77f3\u6cb9\u3001\u4e2d\u6d77\u6cb9\u3001\u4e2d\u77f3\u5316\u7b49\u30022\uff09\u5168\u7403\u4e0a\u6e38\u8d44\u672c\u5f00\u652f\u6574\u4f53\u589e\u957f\uff0c\u63a8\u52a8\u6cb9\u670d\u677f\u5757\u666f\u6c14\u5ea6\u6301\u7eed\u63d0\u5347\uff0c\u5efa\u8bae\u5173\u6ce8\u4e2d\u6d77\u6cb9\u670d\u7b49\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254518732", "pub_date": "2024-10-10 13:46:55"}]}