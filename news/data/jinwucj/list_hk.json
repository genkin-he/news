{"data": [{"id": 260486037, "title": "\u56e0\u7535\u5b50\u63a7\u5236\u5355\u5143\u5b58\u5728\u95ee\u9898 \u5361\u8f66\u5236\u9020\u5546\u5e15\u5361(PCAR)\u5728\u7f8e\u56fd\u53ec\u56de\u903e22\u4e07\u8f86\u6c7d\u8f66", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u56fd\u5bb6\u516c\u8def\u4ea4\u901a\u5b89\u5168\u7ba1\u7406\u5c40(NHTSA)\u5468\u56db\u8868\u793a\uff0c\u5361\u8f66\u5236\u9020\u5546\u5e15\u5361(PCAR)\u5728\u7f8e\u56fd\u53ec\u56de220,972\u8f86\u6c7d\u8f66\uff0c\u539f\u56e0\u662f\u7535\u5b50\u63a7\u5236\u5355\u5143(ECU)\u5b58\u5728\u95ee\u9898\uff0c\u53ef\u80fd\u4f1a\u5f71\u54cd\u4e0e\u5236\u52a8\u548c\u7a33\u5b9a\u6027\u63a7\u5236\u76f8\u5173\u7684\u7cfb\u7edf\u3002NHTSA\u8868\u793a\uff0c\u6b64\u6b21\u53ec\u56de\u7684\u8f66\u8f86\u5305\u62ec2021-2025\u5e74\u751f\u4ea7\u7684\u90e8\u5206Peterbilt\u548cKenworth\u6c7d\u8f66\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260486037", "pub_date": "2024-12-12 21:52:14"}, {"id": 260482160, "title": "\u7f8e\u56fd\u81f312\u67087\u65e5\u5f53\u5468\u521d\u8bf7\u5931\u4e1a\u91d1\u4eba\u6570\u5f55\u5f9724.2\u4e07\u4eba", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u81f312\u67087\u65e5\u5f53\u5468\u521d\u8bf7\u5931\u4e1a\u91d1\u4eba\u6570\u5f55\u5f9724.2\u4e07\u4eba\u3002\u524d\u503c\u753122.4\u4e07\u4eba\u4fee\u6b63\u4e3a22.5\u4e07\u4eba\uff0c\u9884\u671f22\u4e07\u4eba\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260482160", "pub_date": "2024-12-12 21:32:25"}, {"id": 260482352, "title": "\u7f8e\u56fd11\u6708PPI\u5e74\u7387\u5f55\u5f973% \u524d\u503c2.6%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd11\u6708PPI\u5e74\u7387\u5f55\u5f973%\u3002\u524d\u503c\u75312.4%\u4fee\u6b63\u4e3a2.6%\uff0c\u9884\u671f2.6%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260482352", "pub_date": "2024-12-12 21:33:30"}, {"id": 260482545, "title": "\u7f8e\u56fd11\u6708PPI\u6708\u7387\u5f55\u5f970.4% \u524d\u503c0.3%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd11\u6708PPI\u6708\u7387\u5f55\u5f970.4%\u3002\u524d\u503c\u75310.20%\u4fee\u6b63\u4e3a0.3%\uff0c\u9884\u671f0.2%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260482545", "pub_date": "2024-12-12 21:34:38"}, {"id": 260480059, "title": "\u6b27\u5143\u533a\u81f312\u670812\u65e5\u6b27\u6d32\u592e\u884c\u4e3b\u8981\u518d\u878d\u8d44\u5229\u7387\u5f55\u5f973.15% \u7b26\u5408\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6b27\u5143\u533a\u81f312\u670812\u65e5\u6b27\u6d32\u592e\u884c\u4e3b\u8981\u518d\u878d\u8d44\u5229\u7387\u5f55\u5f973.15%\u3002\u524d\u503c3.40%\uff0c\u9884\u671f3.15%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260480059", "pub_date": "2024-12-12 21:21:11"}, {"id": 260479679, "title": "\u6b27\u6d32\u592e\u884c\u5c06\u5b58\u6b3e\u673a\u5236\u5229\u7387\u4e0b\u8c0325\u4e2a\u57fa\u70b9\u81f33% \u7b26\u5408\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6b27\u6d32\u592e\u884c\u5c06\u5b58\u6b3e\u673a\u5236\u5229\u7387\u4e0b\u8c0325\u4e2a\u57fa\u70b9\u81f33.00%\uff0c\u4e3a\u8fde\u7eed\u7b2c\u4e09\u6b21\u4f1a\u8bae\u964d\u606f25\u4e2a\u57fa\u70b9\uff0c\u7b26\u5408\u5e02\u573a\u9884\u671f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260479679", "pub_date": "2024-12-12 21:19:09"}, {"id": 260475899, "title": "\u8bed\u97f3AI\u521d\u521b\u516c\u53f8Vapi\u5728\u65e9\u671f\u878d\u8d44\u8f6e\u4e2d\u7b79\u5f972000\u4e07\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u81f4\u529b\u4e8e\u5e2e\u52a9\u4f01\u4e1a\u90e8\u7f72\u4eba\u5de5\u667a\u80fd\u8bed\u97f3\u4ee3\u7406\u7684\u521d\u521b\u516c\u53f8 Vapi \u8868\u793a\uff0c\u5b83\u5728\u65e9\u671f\u878d\u8d44\u4e2d\u4ece Bessemer Venture Partners \u548c Y Combinator \u7b49\u6295\u8d44\u8005\u90a3\u91cc\u7b79\u96c6\u4e86 2000 \u4e07\u7f8e\u5143\u3002\u672c\u8f6e\u878d\u8d44\u7684\u5176\u4ed6\u6295\u8d44\u8005\u5305\u62ec Abstract Ventures\u3001AI Grant\u3001Saga Ventures \u548c\u9887\u5177\u5f71\u54cd\u529b\u7684 Creative Artists Agency \u8054\u5408\u521b\u59cb\u4eba Michael Ovitz\u3002<br/><br/>Bessemer Venture \u5408\u4f19\u4eba Mike Droesch \u8868\u793a\uff1a\u201c\u4eba\u5de5\u667a\u80fd\u5c06\u4ece\u6839\u672c\u4e0a\u5f71\u54cd\u7ecf\u6d4e\u7684\u6bcf\u4e00\u4e2a\u5782\u76f4\u9886\u57df\uff0c\u8bed\u97f3\u4ee3\u7406\u5c06\u6210\u4e3a\u8bb8\u591a\u6b64\u7c7b\u5e94\u7528\u7a0b\u5e8f\u7684\u6838\u5fc3\u754c\u9762\u3002\u201d\u8be5\u516c\u53f8\u5df2\u6295\u8d44 Pinterest \u548c Shopify \u7b49\u516c\u53f8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260475899", "pub_date": "2024-12-12 20:59:54"}, {"id": 260474395, "title": "\u5fb7\u5546\u94f6\u884c\uff1a\u745e\u58eb\u6cd5\u90ce\u8d2c\u503c\u8d8b\u52bf\u4e0d\u786e\u5b9a \u6599\u745e\u58eb\u592e\u884c\u964d\u606f\u7a7a\u95f4\u6709\u9650", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u745e\u58eb\u592e\u884c\u5468\u56db\u610f\u5916\u964d\u606f\u534a\u4e2a\u767e\u5206\u70b9\uff0c\u65e8\u5728\u6291\u5236\u745e\u90ce\u8fd1\u671f\u7684\u5f3a\u52bf\uff0c\u4ee4\u5e02\u573a\u611f\u5230\u610f\u5916\uff0c\u745e\u90ce\u5151\u6b27\u5143\u4e00\u5ea6\u8dcc\u81f3\u4e24\u5468\u6765\u7684\u6700\u4f4e\u70b9\u3002\u4f46\u745e\u90ce\u5f88\u5feb\u53cd\u5f39\uff0c\u5373\u4f7f\u745e\u58eb\u592e\u884c\u884c\u957f\u9a6c\u4e01\u00b7\u65bd\u83b1\u683c\u5c14\u91cd\u7533\u5fc5\u8981\u65f6\u5c06\u5229\u7387\u964d\u81f3\u8d1f\u503c\uff0c\u745e\u90ce\u4ecd\u672a\u53d7\u5230\u5f71\u54cd\u3002\u4eca\u5e74\uff0c\u745e\u58eb\u592e\u884c\u8fc5\u901f\u4e0b\u8c03\u5229\u7387\uff0c\u4f7f\u5176\u4ec5\u6bd4\u96f6\u9ad8\u51fa\u534a\u4e2a\u767e\u5206\u70b9\u3002\u7136\u800c\uff0c\u745e\u90ce\u5374\u8868\u73b0\u51fa\u8272\uff0c\u6700\u8fd1\u8fbe\u5230\u4e86 2015 \u5e74\u4ee5\u6765\u7684\u6700\u9ad8\u6c34\u5e73\u3002\u745e\u90ce\u7684\u4e0a\u6da8\u4e3b\u8981\u53cd\u6620\u4e86\u6b27\u5143\u8d70\u5f31\u4ee5\u53ca\u5730\u7f18\u653f\u6cbb\u4e0d\u786e\u5b9a\u6027\u52a0\u5267\u5bfc\u81f4\u907f\u9669\u8d44\u4ea7\u9700\u6c42\u5f3a\u52b2\u2014\u2014\u8fd9\u5bf9\u51fa\u53e3\u5bfc\u5411\u578b\u7684\u745e\u58eb\u7ecf\u6d4e\u6765\u8bf4\u662f\u4e00\u4e2a\u8d1f\u62c5\uff0c\u6709\u53ef\u80fd\u5bfc\u81f4\u901a\u80c0\u4f4e\u4e8e\u592e\u884c 0-2% \u7684\u76ee\u6807\u533a\u95f4\u3002<br/>\u5fb7\u56fd\u5546\u4e1a\u94f6\u884c\u9a7b\u6cd5\u5170\u514b\u798f\u5916\u6c47\u7b56\u7565\u5e08\u8fc8\u514b\u5c14\u00b7\u83f2\u65af\u7279 (Michael Pfister) \u8868\u793a\uff1a\u201c\u6211\u4eec\u4e0d\u592a\u786e\u5b9a\u745e\u58eb\u6cd5\u90ce\u76ee\u524d\u7684\u8d2c\u503c\u8d8b\u52bf\u662f\u5426\u4f1a\u6301\u7eed\u4e0b\u53bb\u3002\u8fdb\u4e00\u6b65\u964d\u606f\u7684\u7a7a\u95f4\u73b0\u5728\u66f4\u52a0\u6709\u9650\u4e86\u3002\u6b64\u5916\uff0c\u4e2d\u671f\u5185\u6b27\u5143\u8d70\u5f3a\u7684\u53ef\u80fd\u6027\u4e0d\u5927\u3002\u201d</p>", "link": "https://sky.szfiu.com/info/hk/details/260474395", "pub_date": "2024-12-12 20:51:21"}, {"id": 260470094, "title": "\u8fbe\u7f8e\u4e50\u6bd4\u8428(DPZ)\u5c06\u4ece\u7ebd\u7ea6\u8bc1\u5238\u4ea4\u6613\u6240\u8f6c\u81f3\u7eb3\u65af\u8fbe\u514b\u8bc1\u5238\u4ea4\u6613\u6240\u4e0a\u5e02", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u8fbe\u7f8e\u4e50\u6bd4\u8428(DPZ)\u5c06\u4ece\u7ebd\u7ea6\u8bc1\u5238\u4ea4\u6613\u6240\u8f6c\u81f3\u7eb3\u65af\u8fbe\u514b\u8bc1\u5238\u4ea4\u6613\u6240\u4e0a\u5e02\uff0c\u516c\u53f8\u666e\u901a\u80a1\u9884\u8ba1\u5c06\u4e8e2025 \u5e741\u67082\u65e5\u5f00\u59cb\u4f5c\u4e3a\u7eb3\u65af\u8fbe\u514b\u4e0a\u5e02\u8bc1\u5238\u8fdb\u884c\u4ea4\u6613\u3002</p><p>\u516c\u53f8\u5c06\u4fdd\u7559\u5176\u5f53\u524d\u7684\u80a1\u7968\u4ee3\u7801\u201cDPZ\u201d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260470094", "pub_date": "2024-12-12 20:28:42"}, {"id": 260469164, "title": "\u7f8e\u56fd\u8d22\u653f\u90e8\u957f\u8036\u4f26\uff1a\u7279\u6717\u666e\u6536\u9ad8\u5173\u7a0e\u8ba1\u5212\u5c06\u5bf9\u7f8e\u56fd\u7ecf\u6d4e\u589e\u957f\u4ea7\u751f\u4e0d\u5229\u5f71\u54cd", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u65b0\u534e\u793e\u62a5\u9053\uff0c\u7f8e\u56fd\u8d22\u653f\u90e8\u957f\u8036\u4f26\u65e5\u524d\u8b66\u544a\uff0c\u7f8e\u56fd\u5f53\u9009\u603b\u7edf\u7279\u6717\u666e\u5bf9\u8fdb\u53e3\u5546\u54c1\u5e7f\u6cdb\u5f81\u6536\u9ad8\u5173\u7a0e\u7684\u8ba1\u5212\u5c06\u589e\u52a0\u7f8e\u56fd\u5bb6\u5ead\u548c\u4f01\u4e1a\u6210\u672c\uff0c\u7834\u574f\u6291\u5236\u901a\u80c0\u7684\u8fdb\u5c55\uff0c\u5bf9\u7ecf\u6d4e\u589e\u957f\u4ea7\u751f\u4e0d\u5229\u5f71\u54cd\u3002\u8036\u4f26\u5728\u7f8e\u56fd\u300a\u534e\u5c14\u8857\u65e5\u62a5\u300b\u4e3b\u529e\u7684\u4e00\u573a\u6d3b\u52a8\u4e2d\u8bf4\uff0c\u7279\u6717\u666e\u52a0\u5f81\u5173\u7a0e\u8ba1\u5212\u5c06\u5927\u5e45\u63d0\u9ad8\u7f8e\u56fd\u6d88\u8d39\u8005\u8d2d\u4e70\u5546\u54c1\u7684\u4ef7\u683c\uff0c\u5e76\u7ed9\u4f01\u4e1a\u5e26\u6765\u6210\u672c\u538b\u529b\u3002</p><p>\u8036\u4f26\u8ba4\u4e3a\uff0c\u5bf9\u8f93\u7f8e\u5546\u54c1\u52a0\u5f81\u5173\u7a0e\u7684\u884c\u4e3a\u201c\u5c06\u5bf9\u7f8e\u56fd\u7ecf\u6d4e\u67d0\u4e9b\u9886\u57df\u7684\u7ade\u4e89\u529b\u4ea7\u751f\u4e0d\u5229\u5f71\u54cd\uff0c\u5e76\u53ef\u80fd\u5927\u5e45\u589e\u52a0\u5bb6\u5ead\u6210\u672c\u201d\uff0c\u8fdb\u800c\u53ef\u80fd\u201c\u7834\u574f\u201d\u653f\u5e9c\u5728\u6291\u5236\u901a\u80c0\u65b9\u9762\u53d6\u5f97\u7684\u8fdb\u5c55\uff0c\u5bf9\u7ecf\u6d4e\u589e\u957f\u4ea7\u751f\u4e0d\u5229\u5f71\u54cd\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260469164", "pub_date": "2024-12-12 20:23:52"}]}