fc3\u4f18\u52bf\u3002\u968f\u7740\u5168\u7403\u4fe1\u8d37\u9700\u6c42\u590d\u82cf\u548c\u4ea7\u4e1a\u8f6c\u79fb\u8fdb\u7a0b\u63a8\u8fdb\uff0c\u6301\u7eed\u63d0\u5347\u7684\u8d38\u6613\u548c\u6295\u8d44\u89c4\u6a21\u80fd\u6709\u6548\u5bf9\u51b2\u5229\u7387\u6ce2\u52a8\u3002\u9884\u8ba1\u6c47\u4e30\u63a7\u80a1\u5c06\u5e73\u7a33\u7a7f\u8d8a\u5f53\u524d\u7684\u6b27\u7f8e\u964d\u606f\u5468\u671f\uff0c\u5728\u8425\u6536\u589e\u957f\u3001ROTE\u3001\u5206\u7ea2\u56de\u62a5\u7b49\u65b9\u9762\u663e\u73b0\u51fa\u6781\u5f3a\u7684\u7a33\u5065\u6027\uff0c\u6709\u6548\u6446\u8131\u5229\u7387\u5468\u671f\u54c1\u79cd\u7684\u957f\u671f\u7ea6\u675f\uff0c\u5b9e\u73b0\u6301\u7eed\u548c\u7a33\u5b9a\u7684\u4f30\u503c\u63d0\u5347\u3002<br/><br/>\u8be5\u884c\u9884\u8ba12024-26\u5e74\u8425\u6536\u589e\u901f\u5206\u522b\u4e3a-0.5%\u30011.1%\u30011.6%\uff0c\u5229\u6da6\u589e\u901f4.6%\u30010.4%\u30010.3%\u30022024\u5e74\u73b0\u91d1\u5206\u7ea2\u738767%\uff08\u5176\u4e2d\u4e00\u6b21\u6027\u7279\u522b\u5206\u7ea217%\uff09\u3001\u82e5\u80a1\u7968\u56de\u8d2d\u89c4\u6a2190\u4ebf\u7f8e\u5143\uff0c\u5219\u5408\u8ba1\u80a1\u4e1c\u73b0\u91d1\u56de\u62a5\u7387106%\uff0c\u5f53\u524d\u80a1\u4ef7\u5bf9\u5e94\u5408\u8ba1\u80a1\u606f\u738715.9%\uff0c\u9ad8\u80a1\u606f\u7279\u5f81\u663e\u7740\u3002\u9884\u8ba12024-26\u5e74ROTE\u4fdd\u6301\u572815%\u4e0a\u4e0b\uff0c\u5728\u4e1a\u7ee9\u7684\u6709\u529b\u652f\u6491\u4e0b\uff0c\u5206\u7ea2\u6c34\u5e73\u7a33\u5065\u53ef\u6301\u7eed\u3002\u5f53\u524d\u4f30\u503c1.02\u500d24\u5e74P/TB\uff080.96\u500d24\u5e74P/B\uff09\uff0c\u7ef4\u6301\u4e70\u5165\u8bc4\u7ea7\u548c\u94f6\u884c\u677f\u5757\u9996\u63a8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255540937", "pub_date": "2024-10-23 14:26:09"}, {"id": 255541246, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u77e5\u884c\u6c7d\u8f66\u79d1\u6280(01274)\u6da812.61% \u8fd1\u65e5\u6210\u7acb\u6db5\u76d6\u591a\u9879AI\u4e1a\u52a1\u7684\u65b0\u516c\u53f8", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u77e5\u884c\u6c7d\u8f66\u79d1\u6280(01274)\u5348\u540e\u77ed\u7ebf\u62c9\u5347\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da812.61%\uff0c\u62a526.35\u6e2f\u5143\uff0c\u6210\u4ea4\u989d5389.4\u4e07\u6e2f\u5143\u3002<br/><br/>\u516c\u53f8\u5168\u8d44\u6301\u80a1\u827e\u6469\u661f\u6c7d\u8f66\u79d1\u6280\uff08\u5317\u4eac\uff09\u6709\u9650\u516c\u53f8\u4e8e\u8fd1\u65e5\u6210\u7acb\uff0c\u6ce8\u518c\u8d44\u672c1000\u4e07\u4eba\u6c11\u5e01\uff0c\u7ecf\u8425\u8303\u56f4\u542b\u6c7d\u8f66\u96f6\u90e8\u4ef6\u7814\u53d1\u3001\u4eba\u5de5\u667a\u80fd\u57fa\u7840\u8f6f\u4ef6\u5f00\u53d1\u3001\u4eba\u5de5\u667a\u80fd\u5e94\u7528\u8f6f\u4ef6\u5f00\u53d1\u3001\u4eba\u5de5\u667a\u80fd\u516c\u5171\u670d\u52a1\u5e73\u53f0\u6280\u672f\u54a8\u8be2\u670d\u52a1\u7b49\u3002<br/><br/>\u8d22\u901a\u8bc1\u5238\u8868\u793a\uff0c\u516c\u53f8\u662f\u4e2d\u56fd\u81ea\u52a8\u9a7e\u9a76\u57df\u63a7\u5236\u5668\u9886\u57df\u7684\u5934\u90e8\u4f01\u4e1a\uff0c\u672a\u6765\u968f\u7740\u81ea\u7814\u4ea7\u54c1\u91cf\u4ea7\u548c\u5e02\u573a\u6e17\u900f\u7387\u63d0\u5347\uff0c\u4e1a\u7ee9\u6709\u671b\u8fce\u6765\u62d0\u70b9\u3002\u8be5\u884c\u9884\u8ba1\u516c\u53f82024-2026\u5e74\u5b9e\u73b0\u8425\u4e1a\u6536\u516517.59/23.95/26.42\u4ebf\u5143\uff0c\u5f52\u6bcd\u51c0\u5229\u6da6-1.03/-0.06/0.59\u4ebf\u5143\u3002\u5bf9\u5e942024-2026\u5e74\u7684PS\u4f30\u503c\u5206\u522b\u4e3a2.82/2.07/1.88\u500d\uff0c\u5bf9\u5e942026\u5e74PE\u4e3a85.31\u500d\uff0c\u9996\u6b21\u8986\u76d6\uff0c\u7ed9\u4e88\u201c\u589e\u6301\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255541246", "pub_date": "2024-10-23 14:29:47"}, {"id": 255540631, "title": "\u65e5\u7ecf225\u6307\u6570\u6536\u62a538104.86\u70b9 \u8dcc0.8%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u65e5\u7ecf225\u6307\u6570\u6536\u62a538104.86\u70b9\uff0c\u8dcc0.8%\u3002</p><p>\u56fd\u9645\u8d27\u5e01\u57fa\u91d1\u7ec4\u7ec7\uff08IMF\uff09\u53d1\u5e03\u300a\u4e16\u754c\u7ecf\u6d4e\u5c55\u671b\u62a5\u544a\u300b\uff0c\u5c062024\u5e74\u65e5\u672c\u7ecf\u6d4e\u589e\u957f\u9884\u671f\u4e0b\u8c03\u81f30.3%\uff0c\u4e0e\u4eca\u5e747\u6708\u53d1\u5e03\u7684\u9884\u671f\u76f8\u6bd4\u4e0b\u8c03\u4e860.4\u4e2a\u767e\u5206\u70b9\u3002\u65e5\u672c\u8f66\u4f01\u666e\u904d\u53d1\u751f\u7684\u8ba4\u8bc1\u6d4b\u8bd5\u9020\u5047\u95ee\u9898\uff0c\u5bfc\u81f4\u5de5\u5382\u5927\u89c4\u6a21\u505c\u5de5\uff0c\u7ed9\u7ecf\u6d4e\u589e\u957f\u5e26\u6765\u5f71\u54cd\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255540631", "pub_date": "2024-10-23 14:23:09"}, {"id": 255539521, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u7f8e\u56e2(03690)\u6da8\u903e5% \u4f4e\u7a7a\u7ecf\u6d4e\u6982\u5ff5\u706b\u70ed \u7f8e\u56e2\u65e0\u4eba\u673a\u798f\u7530\u53e3\u5cb8\u822a\u7ebf\u6b63\u5f0f\u5f00\u822a", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56e2(03690)\u80a1\u4ef7\u5411\u597d\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a5194\u6e2f\u5143\uff0c\u6da8\u5e455.03%\uff0c\u6210\u4ea4\u989d66.39\u4ebf\u6e2f\u5143\u3002<br/><br/>\u8fd1\u671f\u4f4e\u7a7a\u7ecf\u6d4e\u6982\u5ff5\u706b\u70ed\uff0c10\u670823\u65e5\uff0c\u7f8e\u56e2\u65e0\u4eba\u673a\u798f\u7530\u53e3\u5cb8\u822a\u7ebf\u6b63\u5f0f\u5f00\u822a\u3002\u636e\u4ecb\u7ecd\uff0c\u8fd9\u662f\u56fd\u5185\u9996\u6761\u8bbe\u5728\u53e3\u5cb8\u533a\u57df\u7684\u5e38\u6001\u5316\u65e0\u4eba\u673a\u914d\u9001\u822a\u7ebf\u3002\u822a\u7ebf\u5f00\u901a\u540e\uff0c\u6bcf\u65e5\u5728\u6e2f\u6df1\u4e4b\u95f4\u5f80\u8fd4\u7684\u5e02\u6c11\uff0c\u5728\u53e3\u5cb8\u9644\u8fd1\u70b9\u5916\u5356\u6216\u53ef\u4eab\u53d7\u201c\u7a7a\u6295\u201d\u670d\u52a1\uff0c\u4e0b\u5355\u540e\u6700\u5feb10\u5206\u949f\u5373\u53ef\u5728\u964d\u843d\u70b9\u53d6\u8d27\u3002</p><p>\u4e2d\u4fe1\u8bc1\u5238\u8868\u793a\uff0c\u4f4e\u7a7a\u7ecf\u6d4e\u7684\u53d1\u5c55\u8fdb\u5165\u653f\u7b56\u5bc6\u96c6\u51fa\u53f0\u671f\uff0c\u884c\u4e1a\u53d1\u5c55\u6709\u671b\u52a0\u901f\uff0c\u8be5\u884c\u8ba4\u4e3a\u8fd9\u5c06\u5927\u5e45\u589e\u5f3a\u6211\u56fd\u5728\u4f4e\u7a7a\u7ecf\u6d4e\u9886\u57df\u7684\u6838\u5fc3\u7ade\u4e89\u529b\uff0c\u6709\u671b\u7387\u5148\u5f62\u6210\u5b8c\u6574\u7684\u4f4e\u7a7a\u53d1\u5c55\u4f53\u7cfb\uff0c\u8fbe\u5230\u5168\u7403\u9886\u5148\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255539521", "pub_date": "2024-10-23 14:12:01"}, {"id": 255539520, "title": "\u3010\u6e2f\u80a1\u901a\u3011TCL\u7535\u5b50(01070)\u5348\u540e\u6da8\u8d857% \u673a\u6784\u6307\u5176Mini LED\u53d1\u8d27\u91cf\u6fc0\u589e \u5229\u6da6\u7a7a\u95f4\u6709\u671b\u6269\u5927", "description": "<p>\u91d1\u543e\u8d22\u8baf | TCL\u7535\u5b50(01070)\u5348\u540e\u7ef4\u6301\u9ad8\u4f4d\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da87.45%\uff0c\u62a55.91\u6e2f\u5143\uff0c\u6210\u4ea4\u989d6244.72\u4e07\u6e2f\u5143\u3002<br/><br/>\u6d77\u901a\u8bc1\u5238\u53d1\u62a5\u6307\u51fa\uff0c\u516c\u53f8\u901a\u8fc7\u4e2d\u9ad8\u7aef\u4ea7\u54c1\u4e0e\u5168\u7403\u5316\u5e03\u5c40\u53d6\u5f97\u663e\u8457\u6210\u679c\uff0cMini LED\u53d1\u8d27\u91cf\u5f3a\u52b2\u589e\u957f\uff0c\u56fd\u9645\u4e1a\u52a1\u9500\u91cf\u4e0e\u9500\u552e\u989d\u53cc\u5347\uff0c\u9884\u8ba1\u5c06\u8fdb\u4e00\u6b65\u6269\u5927\u5229\u6da6\u7a7a\u95f4\u30022024\u5e74\u4e0a\u534a\u5e74\uff0c\u5168\u7403Mini LED\u7535\u89c6\u51fa\u8d27\u91cf\u540c\u6bd4\u589e\u957f74.3%\uff0c\u663e\u793a\u6280\u672f\u5347\u7ea7\u6210\u4e3b\u8981\u8d8b\u52bf\uff0c\u5c24\u5176\u662f\u5927\u5c3a\u5bf8\u53caMini LED\u7535\u89c6\u9700\u6c42\u589e\u52a0\u660e\u663e\u3002\u540c\u671f\uff0cTCL Mini LED\u7535\u89c6\u51fa\u8d27\u91cf\u540c\u6bd4\u589e\u957f122.4%\uff0c\u4fdd\u6301\u9886\u5148\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255539520", "pub_date": "2024-10-23 14:12:40"}]}