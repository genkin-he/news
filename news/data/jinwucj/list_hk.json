5e02\u4eca\u65e9(12\u65e5)\u4e2a\u522b\u8d70\uff0c\u65e5\u7ecf225\u6307\u6570\u73b0\u65f6\u62a540003\u70b9\uff0c\u5347631\u70b9\u62161.6%\u3002\u5357\u97e9\u7efc\u5408\u6307\u6570\u73b0\u65f6\u62a52451\u70b9\uff0c\u53479\u70b9\u62160.38%\u3002\u5e02\u573a\u61a7\u61ac\u4e2d\u592e\u63a8\u51fa\u653f\u7b56\u652f\u6301\u6d88\u8d39\uff0c\u6d88\u8d39\u80a1\u8dd1\u51fa\u3002<br/><br/>\u5e02\u573a\u7126\u70b9\uff1a\u4eac\u4e1c\u5065\u5eb7(06618\uff09<br/><br/>\u4eac\u4e1c\u5065\u5eb7\u516c\u5e032024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u4e1a\u7ee9\u516c\u544a\uff0c\u516c\u53f8\u6536\u5165\u548c\u5229\u6da6\u5747\u5b9e\u73b0\u7a33\u6b65\u589e\u957f\u3002\u7b2c\u4e09\u5b63\u5ea6\u6536\u5165\u8fbe\u5230133.0\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f14.8%\uff0c\u7ecf\u8425\u5229\u6da6\u548c\u7ecf\u8c03\u6574\u7ecf\u8425\u5229\u6da6\u5206\u522b\u589e\u957f216.0%\u548c15.7%\u3002\u51c0\u5229\u6da6\u548c\u7ecf\u8c03\u6574\u51c0\u5229\u6da6\u5206\u522b\u589e\u957f212.2%\u548c40.6%\u3002\u524d\u4e09\u5b63\u5ea6\u603b\u6536\u5165416.5\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f7.6%\uff0c\u51c0\u5229\u6da6\u548c\u7ecf\u8c03\u6574\u51c0\u5229\u6da6\u5206\u522b\u589e\u957f59.4%\u548c17.5%\u3002\u516c\u53f8\u5728\u533b\u4fdd\u4e2a\u8d26\u7ebf\u4e0a\u652f\u4ed8\u670d\u52a1\u65b9\u9762\u53d6\u5f97\u8fdb\u5c55\uff0c\u5df2\u572812\u4e2a\u57ce\u5e02\u63d0\u4f9b\u670d\u52a1\uff0c\u63a5\u5165\u8fd12000\u5bb6\u533b\u4fdd\u5b9a\u70b9\u96f6\u552e\u836f\u5e97\uff0c\u8986\u76d6\u8fc7\u4ebf\u4eba\u53e3\u3002\u4eac\u4e1c\u5065\u5eb7\u7ebf\u4e0a\u7ebf\u4e0b\u4e00\u4f53\u5316\u6301\u7eed\u63a8\u8fdb\uff0c\u516c\u53f8\u843d\u5730\u9996\u4e2a\u4eac\u4e1c\u5927\u836f\u623f\u65b0\u578b\u95e8\u5e97\u30022024 \u5e74\u7b2c\u4e09\u5b63\u5ea6\u671f\u5185\uff0c\u4eac\u4e1c\u5065\u5eb7\u7ee7\u7eed\u5b8c\u5584\u7ebf\u4e0a\u533b\u7597\u670d\u52a1\u4f53\u9a8c\uff0c\u5168\u65b0\u63a8\u51fa\u591a\u6b3e\u5feb\u901f\u68c0\u6d4b\u670d\u52a1\uff0c\u5b9e\u73b0\u300c\u95ee\u8bca+\u68c0\u9a8c+\u533b\u836f\u53ca\u5065\u5eb7\u5546\u54c1\