x 0;\">休闲设备与用品</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">5.1</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">泡泡玛特</span><span style=\"display: inline-block; vertical-align:middle;\">(09992)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">159.2（6.5%）</td></tr><tr><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">制药与生物科技</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">4.4</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">百济神州</span><span style=\"display: inline-block; vertical-align:middle;\">(06160)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">149.4（9.3%）</td></tr><tr><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">特专科技</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">4.3</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">晶泰控股</span><span style=\"display: inline-block; vertical-align:middle;\">(02228)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">4.85（4.3%）</td></tr></table></div>",
