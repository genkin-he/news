{"data": [{"id": 259419022, "title": "\u4f20\u9053\u8fbe\u5c14(TTE)\u6536\u8d2d\u53ef\u518d\u751f\u80fd\u6e90\u516c\u53f8VSB Group \u6d89\u8d4420\u4ebf\u6b27\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u77e5\u60c5\u4eba\u58eb\u900f\u9732\uff0c\u9053\u8fbe\u5c14(TTE)\u5373\u5c06\u4ece\u79c1\u52df\u80a1\u6743\u516c\u53f8Partners Group Holding AG\u624b\u4e2d\u6536\u8d2dVSB Group\uff0c\u8be5\u4ea4\u6613\u5bf9\u8fd9\u5bb6\u5fb7\u56fd\u53ef\u518d\u751f\u80fd\u6e90\u9879\u76ee\u5f00\u53d1\u5546\u7684\u4f30\u503c\u7ea6\u4e3a20\u4ebf\u6b27\u5143(\u540821\u4ebf\u7f8e\u5143)\u3002<br/><br/>\u77e5\u60c5\u4eba\u58eb\u8868\u793a\uff0c\u9053\u8fbe\u5c14\u548cPartners Group\u6b63\u5728\u8fdb\u884c\u6df1\u5165\u8c08\u5224\uff0c\u53ef\u80fd\u6700\u5feb\u5728\u672a\u6765\u51e0\u5929\u5ba3\u5e03\u8fd9\u7b14\u4ea4\u6613\u3002\u6700\u7ec8\u534f\u8bae\u4ecd\u6709\u53ef\u80fd\u88ab\u63a8\u8fdf\u3002<br/><br/>VSB Group\u5728\u53ef\u518d\u751f\u80fd\u6e90\u9886\u57df\u63d0\u4f9b\u9879\u76ee\u7ba1\u7406\u548c\u73af\u5883\u89c4\u5212\u7b49\u670d\u52a1\u3002\u8be5\u516c\u53f8\u5728\u6cd5\u56fd\u3001\u5fb7\u56fd\u3001\u6ce2\u5170\u548c\u610f\u5927\u5229\u7684\u9879\u76ee\u6d89\u53ca\u592a\u9633\u80fd\u3001\u6c34\u7535\u548c\u98ce\u80fd\u3002\u8be5\u516c\u53f8\u5728\u5168\u7403\u62e5\u6709500\u591a\u540d\u5458\u5de5\u548c21\u4e2a\u5206\u652f\u673a\u6784\u3002Partners Group\u4e8e2020\u5e74\u6536\u8d2d\u4e86VSB Group 80%\u7684\u80a1\u4efd\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259419022", "pub_date": "2024-12-03 20:15:55"}, {"id": 259419366, "title": "\u4e2d\u91d1\u5916\u6c47\uff1a\u4eba\u6c11\u5e01\u6c47\u7387\u7684\u8d70\u52bf\u4ecd\u5c06\u53d6\u51b3\u4e8e\u201c\u7279\u6717\u666e\u4ea4\u6613\u201d\u5982\u4f55\u63a8\u8fdb", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u91d1\u5916\u6c47\u8ba4\u4e3a\uff0c\u4eba\u6c11\u5e01\u6c47\u7387\u7684\u8d70\u52bf\u4ecd\u5c06\u53d6\u51b3\u4e8e\u201c\u7279\u6717\u666e\u4ea4\u6613\u201d\u5982\u4f55\u63a8\u8fdb\uff0c\u82e5\u5bf9\u7f8e\u5143\u6307\u6570\u7684\u652f\u6491\u6709\u6240\u653e\u7f13\uff0c\u4e14\u4f34\u968f\u7740\u7f8e\u8054\u50a8\u964d\u606f\u5468\u671f\u7684\u63a8\u8fdb\uff0c\u4eba\u6c11\u5e01\u6c47\u7387\u5e74\u672b\u504f\u5f3a\u7684\u5b63\u8282\u6027\u4ecd\u6709\u51fa\u73b0\u53ef\u80fd\u3002\u5177\u4f53\u6765\u770b\uff0c\u76ee\u524d\u7279\u6717\u666e\u653f\u5e9c\u7684\u5185\u9601\u6210\u5458\u57fa\u672c\u786e\u5b9a\uff0c\u4ecd\u9700\u5173\u6ce812\u6708\u76f8\u5173\u5916\u90e8\u653f\u7b56\u9884\u671f\u7684\u53d8\u5316\uff0c\u4ee5\u53ca\u4fc4\u4e4c\u51b2\u7a81\u7b49\u98ce\u9669\u4e8b\u4ef6\u7684\u6f14\u53d8\u3002\u5185\u90e8\u56e0\u7d20\u65b9\u9762\uff0c\u9700\u5173\u6ce812\u6708\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\u7b49\u91cd\u8981\u4f1a\u8bae\u7684\u589e\u91cf\u4fe1\u606f\u53ca\u5bf9\u5e02\u573a\u9884\u671f\u7684\u63d0\u632f\u4f5c\u7528\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259419366", "pub_date": "2024-12-03 20:17:31"}, {"id": 259415773, "title": "\u8bfa\u548c\u8bfa\u5fb7(NVO)\u76d8\u524d\u6da8\u903e2% \u5370\u5ea6\u56e2\u961f\u6566\u4fc3\u5c3d\u65e9\u63a8\u51faWegovy", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u8bfa\u548c\u8bfa\u5fb7(NVO)\u76d8\u524d\u6da8\u903e2%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a5110.76\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u7531\u4e8e\u62c5\u5fc3\u5728\u5370\u5ea6\u8fd9\u4e00\u6f5c\u529b\u5de8\u5927\u7684\u5e02\u573a\u4e0a\u843d\u540e\u4e8e\u7ade\u4e89\u5bf9\u624b\u793c\u6765\uff0c\u4e39\u9ea6\u5236\u836f\u5de8\u5934\u8bfa\u548c\u8bfa\u5fb7\u7684\u5370\u5ea6\u56e2\u961f\u4e00\u76f4\u5728\u63a8\u52a8\u8be5\u516c\u53f8\u5728\u5370\u5ea6\u66f4\u65e9\u63a8\u51fa\u5176\u5e7f\u53d7\u6b22\u8fce\u7684\u51cf\u80a5\u836fWegovy\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259415773", "pub_date": "2024-12-03 19:56:21"}, {"id": 259413393, "title": "\u5bcc\u9014\u63a7\u80a1(FUTU)\u76d8\u524d\u6da8\u8d851% \u534e\u5174\u8d44\u672c\u5347\u5176\u76ee\u6807\u4ef75.73%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5bcc\u9014\u63a7\u80a1(FUTU)\u76d8\u524d\u6da8\u8d851%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a586.25\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u534e\u5174\u8d44\u672c\u7ef4\u6301\u5bf9\u5bcc\u9014\u63a7\u80a1\u7684\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0c\u5e76\u5c06\u76ee\u6807\u4ef7\u4ece127.50\u7f8e\u5143\u4e0a\u8c03\u81f3134.80\u7f8e\u5143\u3002\u8be5\u884c\u8ba4\u4e3a\u5bcc\u9014\u5f3a\u52b2\u7684\u5ba2\u6237\u83b7\u53d6\u3001\u66f4\u9ad8\u7684\u5ba2\u6237\u8d44\u4ea7\u4ee5\u53ca\u5e02\u573a\u5bf9\u52a0\u5bc6\u4ea4\u6613\u65e5\u76ca\u589e\u957f\u7684\u5174\u8da3\u5c06\u4e3a\u5bcc\u9014\u5e26\u6765\u66f4\u597d\u7684\u76c8\u5229\u524d\u666f\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259413393", "pub_date": "2024-12-03 19:42:32"}, {"id": 259412379, "title": "\u5546\u52a1\u90e8\uff1a\u52a0\u5f3a\u9553\u9517\u9511\u7b49\u76f8\u5173\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u51fa\u53e3\u7ba1\u5236", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5546\u52a1\u90e8\u53d1\u5e03\u5173\u4e8e\u52a0\u5f3a\u76f8\u5173\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u51fa\u53e3\u7ba1\u5236\u7684\u516c\u544a\uff0c\u81ea\u516c\u5e03\u4e4b\u65e5\u8d77\u6b63\u5f0f\u5b9e\u65bd\u3002\u516c\u544a\u79f0\uff0c\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u51fa\u53e3\u7ba1\u5236\u6cd5\u300b\u7b49\u6cd5\u5f8b\u6cd5\u89c4\u6709\u5173\u89c4\u5b9a\uff0c\u4e3a\u7ef4\u62a4\u56fd\u5bb6\u5b89\u5168\u548c\u5229\u76ca\u3001\u5c65\u884c\u9632\u6269\u6563\u7b49\u56fd\u9645\u4e49\u52a1\uff0c\u51b3\u5b9a\u52a0\u5f3a\u76f8\u5173\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u51fa\u53e3\u7ba1\u5236\u3002\u73b0\u5c06\u6709\u5173\u4e8b\u9879\u516c\u544a\u5982\u4e0b\uff1a<br/><br/>1)\u7981\u6b62\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u519b\u4e8b\u7528\u6237\u6216\u519b\u4e8b\u7528\u9014\u51fa\u53e3\u3002<br/><br/>2)\u539f\u5219\u4e0a\u4e0d\u4e88\u8bb8\u53ef\u9553\u3001\u9517\u3001\u9511\u3001\u8d85\u786c\u6750\u6599\u76f8\u5173\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u51fa\u53e3\uff1b\u5bf9\u77f3\u58a8\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u51fa\u53e3\uff0c\u5b9e\u65bd\u66f4\u4e25\u683c\u7684\u6700\u7ec8\u7528\u6237\u548c\u6700\u7ec8\u7528\u9014\u5ba1\u67e5\u3002<br/><br/>\u4e3a\u7ef4\u62a4\u56fd\u5bb6\u5b89\u5168\u548c\u5229\u76ca\u3001\u5c65\u884c\u9632\u6269\u6563\u7b49\u56fd\u9645\u4e49\u52a1\uff0c\u6839\u636e\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u51fa\u53e3\u7ba1\u5236\u6cd5\u300b\u7b49\u6cd5\u5f8b\u89c4\u5b9a\uff0c\u4e2d\u65b9\u51b3\u5b9a\u52a0\u5f3a\u6709\u5173\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u51fa\u53e3\u7ba1\u5236\uff0c\u5305\u62ec\u7981\u6b62\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u519b\u4e8b\u7528\u6237\u6216\u519b\u4e8b\u7528\u9014\u51fa\u53e3\uff0c\u4e25\u63a7\u9553\u3001\u9517\u3001\u9511\u3001\u8d85\u786c\u6750\u6599\u3001\u77f3\u58a8\u76f8\u5173\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u51fa\u53e3\u7b49\u3002\u4efb\u4f55\u56fd\u5bb6\u548c\u5730\u533a\u7684\u7ec4\u7ec7\u548c\u4e2a\u4eba\u8fdd\u53cd\u76f8\u5173\u89c4\u5b9a\uff0c\u5c06\u4f9d\u6cd5\u8ffd\u7a76\u8d23\u4efb\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259412379", "pub_date": "2024-12-03 19:36:09"}, {"id": 259410195, "title": "\u643a\u7a0b\u7f51(TCOM)\u76d8\u524d\u6da8\u8d851% \u8fd1\u671f\u8fd1\u671f\u97e9\u56fd\u6e38\u5ba2\u5165\u5883\u6e38\u8ba2\u5355\u540c\u6bd4\u589e\u957f\u8d85150%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u643a\u7a0b\u7f51(TCOM)\u76d8\u524d\u6da8\u8d851%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a566.16\u7f8e\u5143\u3002</p><p><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u4ece\u643a\u7a0b\u5e73\u53f0\u83b7\u6089\uff0c\u81ea11\u67088\u65e5\u5bf9\u97e9\u56fd\u5355\u65b9\u9762\u514d\u7b7e\u653f\u7b56\u5b9e\u65bd\u4ee5\u6765\uff0c11\u67088\u65e5\u81f312\u67082\u65e5\uff0c\u643a\u7a0b\u5e73\u53f0\u97e9\u56fd\u6e38\u5ba2\u5165\u5883\u6e38\u8ba2\u5355\u73af\u6bd4\u4e0a\u6708(10\u67088\u65e5\u81f311\u67082\u65e5)\u589e\u957f\u7ea615%\uff0c\u540c\u6bd4\u589e\u957f\u8d85150%\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259410195", "pub_date": "2024-12-03 19:23:53"}, {"id": 259409360, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5149\u5927\u8bc1\u5238\u56fd\u9645\u6599\u660e\u5e74\u5168\u7403\u4e3b\u8981\u592e\u884c\u5c06\u7ef4\u6301\u5bbd\u677e\u8d27\u5e01\u653f\u7b56 \u4e3a\u73af\u7403\u7ecf\u6d4e\u5e26\u6765\u5951\u673a", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5149\u5927\u8bc1\u5238\u56fd\u9645\u53d1\u7814\u62a5\u6307\uff0c\u6599\u660e\u5e74\u4e0a\u534a\u5e74\u73af\u7403\u7ecf\u6d4e\u901a\u80c0\u653e\u7f13\uff0c\u9884\u8ba1\u5168\u7403\u4e3b\u8981\u592e\u884c\u5c06\u7ef4\u6301\u5bbd\u677e\u8d27\u5e01\u653f\u7b56\uff0c\u4e3a\u73af\u7403\u7ecf\u6d4e\u5e26\u6765\u5951\u673a\u3002\u7279\u6717\u666e\u518d\u6b21\u4e0a\u53f0\u5c06\u5bf9\u7f8e\u56fd\u7684\u7ecf\u6d4e\u653f\u7b56\u4ea7\u751f\u91cd\u5927\u5f71\u54cd\u3002\u6700\u4e3a\u91cd\u8981\u662f\u7279\u6717\u666e\u5bf9\u8d38\u6613\u653f\u7b56\u548c\u5173\u7a0e\u7684\u4f7f\u7528\uff0c\u7531\u4e8e\u4e2d\u56fd\u3001\u6b27\u6d32\u548c\u58a8\u897f\u54e5\u5bf9\u7f8e\u56fd\u6709\u8f83\u5927\u7684\u8d38\u6613\u9006\u5dee\uff0c\u56e0\u6b64\u6700\u6613\u53d7\u5230\u5f71\u54cd\u3002<br/><br/>\u5149\u5927\u8bc1\u5238\u56fd\u9645\u73af\u7403\u5e02\u573a\u53ca\u5916\u6c47\u7b56\u7565\u5e08\u6c64\u4e3d\u9e3f\u8ba4\u4e3a\uff0c\u7f8e\u56fd\u901a\u80c0\u6301\u7eed\u653e\u7f13\uff0c\u4f46\u5176\u5c31\u4e1a\u6570\u636e\u8868\u73b0\u8f6c\u5dee\uff0c\u7f8e\u56fd\u8f83\u5927\u673a\u4f1a\u660e\u5e74\u4e0a\u534a\u5e74\u51cf\u606f\u4e24\u6b21\u3002\u968f\u7740\u7f8e\u56fd\u5faa\u5e8f\u6e10\u8fdb\u51cf\u606f\uff0c\u53ef\u8003\u8651\u9002\u65f6\u4e8e\u8d44\u4ea7\u914d\u7f6e\u52a0\u5165\u4f30\u503c\u5438\u5f15\u7684\u5e02\u573a\uff0c\u5305\u62ec\u5185\u5730\u3001\u9999\u6e2f\u3001\u6b27\u6d32\u80a1\u7968\u5e02\u573a\uff0c\u4ea6\u53ef\u8003\u8651\u9ec4\u91d1\u3001\u7f8e\u56fd\u4eba\u5de5\u667a\u80fd\u6280\u672f\u3001\u623f\u5730\u4ea7\u4fe1\u6258\u548c\u6c99\u7279\u6982\u5ff5\u7b49\u53e6\u7c7b\u6295\u8d44\u677f\u5757\u3001\u4ee5\u53ca\u4e9a\u6d32\u503a\u5238\u6295\u8d44\uff0c\u653b\u5b88\u517c\u5907\u3002<br/><br/>\u867d\u7136\u7f8e\u56fd\u6574\u4f53\u901a\u80c0\u8d70\u52bf\u7b26\u5408\u9884\u671f\u5411\u4e0b\uff0c\u4f46\u8ddd\u79bb\u8054\u50a8\u5c402%\u7684\u901a\u80c0\u76ee\u6807\u4ecd\u6709\u4e00\u6bb5\u8ddd\u79bb\uff0c\u52a0\u4e0a\u5e02\u573a\u9700\u8981\u89c2\u5bdf\u7f8e\u56fd\u5019\u4efb\u603b\u7edf\u7279\u6717\u666e\u201c\u5bf9\u5185\u4f01\u4e1a\u51cf\u7a0e\u3001\u5bf9\u5916\u5b9e\u65bd\u5173\u7a0e\u201d\u7684\u653f\u7b56\uff0c\u56e0\u6b64\u7f8e\u56fd\u672a\u6765\u7684\u901a\u80c0\u6c34\u5e73\u8868\u73b0\u8f83\u53cd\u8986\uff0c\u5e76\u9700\u5bc6\u5207\u89c2\u5bdf\u7f8e\u56fd\u5c31\u4e1a\u548c\u56fd\u5185\u751f\u4ea7\u603b\u503c\u6570\u636e\u60c5\u51b5\u3002\u53e6\u5916\uff0c\u82e5\u7f8e\u6c47\u6307\u6570\u7ef4\u6301\u5728105.5\u6c34\u5e73\u4ee5\u4e0b\uff0c\u6216\u6709\u673a\u4f1a\u8fdb\u4e00\u6b65\u56de\u843d\u81f3101\u6c34\u5e73\uff0c\u4f46\u8981\u7559\u610f\u56fd\u9645\u5c40\u52bf\u7b49\u56e0\u7d20\u5f71\u54cd\u7f8e\u6c47\u6307\u6570\u6ce2\u52a8\u3002<br/><br/>\u7531\u4e8e\u7f8e\u8054\u50a8\u5f00\u542f\u51cf\u606f\u5468\u671f\uff0c\u7f8e\u6c47\u6307\u6570\u6210\u4efd\u8d27\u5e01\u5e94\u8f83\u4e3a\u53d7\u60e0\uff0c\u6545\u6b64\u660e\u5e74\u53ef\u7559\u610f\u82f1\u9551\uff0c\u4ee5\u6355\u6349\u4e2d\u77ed\u7ebf\u5347\u503c\u673a\u4f1a\uff1b\u6b64\u5916\uff0c\u5979\u770b\u597d\u91d1\u4ef7\u8d70\u52bf\uff0c\u800c\u6cb9\u4ef7\u4e8e\u660e\u5e74\u4e0a\u534a\u5e74\u4ecd\u7ef4\u6301\u4e2d\u6027\u504f\u6de1\u7684\u770b\u6cd5\uff0c\u9884\u6599WTI\u7ebd\u7ea6\u671f\u6cb9\u5728\u6bcf\u687663\u81f378\u7f8e\u5143\u5f98\u5f8a\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259409360", "pub_date": "2024-12-03 19:18:17"}, {"id": 259408032, "title": "\u8bfa\u548c\u8bfa\u5fb7(NVO)\u5370\u5ea6\u56e2\u961f\u6025\u63a8Wegovy\u4e0a\u5e02", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u5185\u90e8\u6d88\u606f\u4eba\u58eb\u900f\u9732\uff0c\u4e39\u9ea6\u5236\u836f\u516c\u53f8\u8bfa\u548c\u8bfa\u5fb7(NVO)\u7684\u5370\u5ea6\u56e2\u961f\u56e0\u62c5\u5fc3\u5728\u5370\u5ea6\u5e02\u573a\u4e0a\u843d\u540e\u4e8e\u7ade\u4e89\u5bf9\u624b\u793c\u6765\u516c\u53f8(LLY)\uff0c\u6b63\u79ef\u6781\u63a8\u52a8\u516c\u53f8\u63d0\u524d\u5728\u5370\u5ea6\u63a8\u51fa\u5176\u7545\u9500\u51cf\u80a5\u836fWegovy\uff0c\u4ee5\u7ef4\u6301\u5728\u5168\u7403\u51cf\u80a5\u836f\u5e02\u573a\u7684\u9886\u5148\u5730\u4f4d\u3002<br/><br/>\u539f\u672c\u8bfa\u548c\u8bfa\u5fb7\u8ba1\u5212\u5728\u83b7\u5f97\u76d1\u7ba1\u6279\u51c6\u548c\u5145\u8db3\u4f9b\u5e94\u540e\uff0c\u53ef\u80fd\u57282026\u5e74\u5c06Wegovy\u5f15\u5165\u5370\u5ea6\u5e02\u573a\u3002\u4f46\u6700\u8fd1\uff0c\u5370\u5ea6\u56e2\u961f\u5efa\u8bae\u5c06\u4e0a\u5e02\u65f6\u95f4\u63d0\u524d\u81f3\u660e\u5e74\uff0c\u4e0e\u6b64\u540c\u65f6\uff0c\u793c\u6765\u516c\u53f8\u4e5f\u9884\u8ba1\u5728\u540c\u4e00\u65f6\u671f\u5728\u5370\u5ea6\u63a8\u51fa\u5176\u51cf\u80a5\u836fMounjaro\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259408032", "pub_date": "2024-12-03 19:10:51"}, {"id": 259405392, "title": "\u7f8e\u56fd\u540c\u610f\u5411Stellantis(STLA)\u5408\u8425\u7535\u6c60\u5382\u63d0\u4f9b75.4\u4ebf\u7f8e\u5143\u8d37\u6b3e\u8d44\u91d1", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u653f\u5e9c\u540c\u610f\u5411\u7531Samsung SDI\u4e0eStellantis(STLA)\u5408\u8425\u4f01\u4e1a\uff0c\u63d0\u4f9b\u91d1\u989d\u4e3a75.4\u4ebf\u7f8e\u5143\u7684\u8d37\u6b3e\u8d44\u91d1\uff0c\u4ee5\u63a8\u52a8\u8be5\u5408\u8425\u4f01\u4e1a\u5728\u7f8e\u56fd\u5370\u5f1f\u5b89\u90a3\u5dde\u5174\u5efa\u4e00\u95f4\u7535\u52a8\u8f66\u7535\u6c60\u5382\u3002\u6839\u636e\u7f8e\u56fd\u80fd\u6e90\u90e8\u5468\u4e00\u7684\u58f0\u660e\uff0c\u63f4\u52a9\u8d44\u91d1\u5c06\u4ee5\u8d37\u6b3e\u65b9\u5f0f\u63d0\u4f9b\uff0c\u5176\u4e2d68.5\u4ebf\u7f8e\u5143\u4e3a\u672c\u91d1\uff0c6.88\u4ebf\u7f8e\u5143\u4e3a\u8d44\u672c\u5316\u5229\u606f\uff0c\u91d1\u989d\u662f\u653f\u5e9c\u5411\u540c\u5dde\u53e6\u4e00\u95f4\u7535\u52a8\u8f66\u7535\u6c60\u5382\u63d0\u4f9b\u540c\u7c7b\u8ba1\u5212\u7684\u4e24\u500d\u3002\u80fd\u6e90\u90e8\u79f0\uff0c\u6709\u5173\u9879\u76ee\u6709\u52a9\u6269\u5927\u7f8e\u56fd\u7535\u52a8\u8f66\u7535\u6c60\u751f\u4ea7\uff0c\u4ee5\u6ee1\u8db3\u5e02\u573a\u9700\u6c42\u53ca\u51cf\u5c11\u5bf9\u5305\u62ec\u4e2d\u56fd\u5728\u5185\u7684\u5916\u56fd\u4f9d\u8d56\u3002\u6709\u5173\u63f4\u52a9\u8ba1\u5212\u53ef\u80fd\u5728\u7f8e\u56fd\u5019\u4efb\u603b\u7edf\u7279\u6717\u666e\u4e0a\u4efb\u540e\u53d6\u6d88\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259405392", "pub_date": "2024-12-03 18:54:03"}, {"id": 259403752, "title": "\u7f8e\u56fd\u94a2\u94c1(X)\u76d8\u524d\u8dcc\u8d857% \u7279\u6717\u666e\u53d1\u6587\u53cd\u5bf9\u516c\u53f8\u88ab\u88ab\u65b0\u65e5\u94c1\u516c\u53f8\u6536\u8d2d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u94a2\u94c1(X)\u76d8\u524d\u8dcc\u8d857%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a538.02\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u7279\u6717\u666e\u5728\u5468\u4e00\u8868\u793a\uff0c\u4ed6\u5c06\u901a\u8fc7\u7a0e\u6536\u4f18\u60e0\u548c\u5173\u7a0e\u653f\u7b56\u6765\u632f\u5174\u7f8e\u56fd\u94a2\u94c1\u884c\u4e1a\uff0c\u5e76\u91cd\u7533\u4ed6\u53cd\u5bf9\u65e5\u672c\u65b0\u65e5\u94c1\u516c\u53f8\u6536\u8d2d\u7f8e\u56fd\u94a2\u94c1\u7684\u7acb\u573a\u3002\u7279\u6717\u666e\u5728\u793e\u4ea4\u5a92\u4f53\u4e0a\u53d1\u6587\u8868\u793a\uff0c\u4ed6\u5b8c\u5168\u53cd\u5bf9\u7f8e\u56fd\u94a2\u94c1\u88ab\u5916\u56fd\u516c\u53f8\uff0c\u7279\u522b\u662f\u65e5\u672c\u65b0\u65e5\u94c1\u6536\u8d2d\uff0c\u5e76\u627f\u8bfa\u5c06\u963b\u6b62\u8fd9\u4e00\u4ea4\u6613\u3002<br/><br/>\u65b0\u65e5\u94c1\u5728\u7279\u6717\u666e\u53d1\u8868\u8a00\u8bba\u540e\u4e8e\u5468\u4e8c\u53d1\u8868\u58f0\u660e\uff0c\u627f\u8bfa\u5c06\u5411\u7f8e\u56fd\u94a2\u94c1\u7684\u5de5\u4f1a\u5316\u8bbe\u65bd\u6295\u8d44\u81f3\u5c1127\u4ebf\u7f8e\u5143\uff0c\u4ee5\u786e\u4fdd\u5de5\u4f1a\u5de5\u4f5c\u5c97\u4f4d\u5e76\u5206\u4eab\u6280\u672f\u521b\u65b0\u3002\u65b0\u65e5\u94c1\u8868\u793a\uff0c\u4ed6\u4eec\u51b3\u5fc3\u4ee5\u52a0\u5f3a\u7f8e\u56fd\u5de5\u4e1a\u3001\u56fd\u5185\u4f9b\u5e94\u94fe\u5f39\u6027\u548c\u56fd\u5bb6\u5b89\u5168\u7684\u65b9\u5f0f\u6765\u4fdd\u62a4\u548c\u53d1\u5c55\u7f8e\u56fd\u94a2\u94c1\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259403752", "pub_date": "2024-12-03 18:44:49"}]}