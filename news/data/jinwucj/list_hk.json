px solid#999; padding: 10px 0; vertical-align:middle;\">25.85</td><td style=\"border: 1px solid#999; padding: 10px 0; vertical-align:middle;\">-2.08</td></tr></tbody></table></div>", "link": "https://sky.szfiu.com/info/hk/details/259349288", "pub_date": "2024-12-03 11:00:00"}, {"id": 259348724, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u745e\u94f6\u4e88\u7f8e\u56e2(03690)\u201c\u4e70\u5165\u201d\u8bc4\u7ea7 \u6307\u5176\u7b2c\u4e09\u5b63\u5ea6\u4e1a\u7ee9\u8d85\u9884\u671f ", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u745e\u94f6\u5168\u7403\u7814\u7a76\u90e8\u95e8\u53d1\u5e03\u7814\u62a5\uff0c\u5bf9\u7f8e\u56e2(03690)2024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u7684\u4e1a\u7ee9\u8868\u73b0\u7ed9\u4e88\u4e86\u79ef\u6781\u8bc4\u4ef7\uff0c\u8ba4\u4e3a\u516c\u53f8\u4e1a\u7ee9\u8d85\u51fa\u9884\u671f\u3002\u7814\u62a5\u6307\u51fa\uff0c\u7f8e\u56e2\u7b2c\u4e09\u5b63\u5ea6\u7684\u8425\u6536\u8d85\u51fa\u9884\u671f2%\uff0c\u8c03\u6574\u540e\u7684\u8425\u4e1a\u5229\u6da6\u540c\u6bd4\u589e\u957f14%\uff0c\u4e3b\u8981\u5f97\u76ca\u4e8e\u6210\u672c\u4f18\u5316\u548c\u8fd0\u8425\u6760\u6746\u4f5c\u7528\uff0c\u4ee5\u53ca\u65b0\u4e1a\u52a1\u4e8f\u635f\u7684\u5feb\u901f\u6536\u7a84\u3002</p><p>\u7814\u62a5\u5206\u6790\u8ba4\u4e3a\uff0c\u7f8e\u56e2\u4f5c\u4e3a\u4e2d\u56fd\u4e92\u8054\u7f51\u670d\u52a1\u884c\u4e1a\u7684\u9886\u5934\u7f8a\uff0c\u5176\u5728\u98df\u54c1\u914d\u9001\u3001\u5230\u5e97\u4e1a\u52a1\u548c\u65b0\u4e1a\u52a1\u7b49\u591a\u4e2a\u9886\u57df\u7684\u589e\u957f\u6f5c\u529b\u4f9d\u7136\u5f3a\u52b2\u3002\u745e\u94f6\u9884\u8ba1\uff0c\u7f8e\u56e2\u7684\u8ba2\u5355\u91cf\u589e\u957f\u5c06\u4ece\u7b2c\u4e09\u5b63\u5ea6\u768412%\u9002\u5ea6\u653e\u7f13\u81f3\u7b2c\u56db\u5b63\u5ea6\u768410%\uff0c\u53cd\u6620\u51fa\u5728\u5b8f\u89c2\u7ecf\u6d4e\u653e\u7f13\u548c\u884c\u4e1a\u8fdb\u5165\u6210\u719f\u4f46\u9ad8\u8d28\u91cf\u589e\u957f\u9636\u6bb5\u7684\u80cc\u666f\u4e0b\uff0c\u516c\u53f8\u589e\u957f\u52bf\u5934\u7a33\u5065\u3002\u540c\u65f6\uff0c\u745e\u94f6\u9884\u8ba1\u7f8e\u56e2\u5728\u5e97\u5185\u4e1a\u52a1\u7684\u6536\u5165\u589e\u957f\u5728\u7b2c\u56db\u5b63\u5ea6\u5c06\u8fbe\u523025%\uff0c\u8425\u4e1a\u5229\u6da6\u589e\u957f\u5c06\u8fbe\u523040%\uff0c\u8fd9\u90e8\u5206\u5f97\u76ca\u4e8e\u53bb\u5e74\u8f83\u4f4e\u7684\u57fa\u6570\u3002\u7f8e\u56e2\u7684\u65b0\u4e1a\u52a1\u677f\u5757\u4e8f\u635f\u8fdb\u4e00\u6b65\u6536\u7a84\u81f310\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u663e\u793a\u51fa\u516c\u53f8\u5728\u65b0\u4e1a\u52a1\u9886\u57df\u7684\u76c8\u5229\u80fd\u529b\u6b63\u5728\u6539\u5584\u3002</p><p>\u745e\u94f6\u8ba4\u4e3a\uff0c\u7f8e\u56e2\u7684\u6295\u8d44\u903b\u8f91\u4fdd\u6301\u4e0d\u53d8\uff0c\u4f5c\u4e3a\u672c\u5730\u670d\u52a1\u884c\u4e1a\u7684\u9886\u5bfc\u8005\uff0c\u7f8e\u56e2\u5728\u672a\u5145\u5206\u6e17\u900f\u7684\u5e02\u573a\u4e2d\u5177\u6709\u663e\u8457\u7684\u6536\u76ca\u6f5c\u529b\u3002\u968f\u7740\u516c\u53f8\u6700\u8fd1\u63a8\u51fa\u7684\u201c\u7f8e\u56e2\u9009\u201d\u8ba1\u5212\u3001\u98df\u54c1\u914d\u9001\u7528\u6237\u4f53\u9a8c\u7684\u63d0\u5347\u3001\u5feb\u901f\u589e\u957f\u7684\u5373\u65f6\u8d2d\u7269\u4e1a\u52a1\u4ee5\u53ca\u66f4\u597d\u7684\u7ade\u4e89\u683c\u5c40\u548c\u65b0\u4e1a\u52a1\u7684\u589e\u957f\uff0c\u745e\u94f6\u9884\u8ba1\u7f8e\u56e2\u7684\u5e02\u573a\u4efd\u989d\u5c06\u57282026\u5e74\u63d0\u5347\u81f35.4%\u3002\u5c3d\u7ba1\u7f8e\u56e2\u7684\u80a1\u4ef7\u5728\u5e74\u521d\u81f3\u4eca\u5df2\u7ecf\u5b9e\u73b0\u4e86110%\u7684\u53cd\u5f39\uff0c\u4f46\u745e\u94f6\u8ba4\u4e3a\u5e02\u573a\u5bf9\u4e8e\u7f8e\u56e2\u7684\u9884\u671f\u8fc7\u9ad8\uff0c\u80a1\u4ef7\u53ef\u80fd\u4f1a\u51fa\u73b0\u8c03\u6574\u3002\u745e\u94f6\u5bf9\u7f8e\u56e2\u768412\u4e2a\u6708\u8bc4\u7ea7\u4e3a\u201c\u4e70\u5165\u201d\uff0c\u76ee\u6807\u4ef7\u5b9a\u4e3a270\u6e2f\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259348724", "pub_date": "2024-12-03 10:52:12"}, {"id": 259348723, "title": "\u534a\u5bfc\u4f53\u968f\u5e02\u8d70\u4f4e \u4e2d\u82af\u56fd\u9645(00981)\u8dcc\u8d852% \u7f8e\u56fd\u5546\u52a1\u90e8\u53d1\u5e03\u5bf9\u534e\u534a\u5bfc\u4f53\u51fa\u53e3\u7ba1\u5236\u63aa\u65bd", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u534a\u5bfc\u4f53\u968f\u5e02\u8d70\u4f4e\uff0c\u786c\u86cb\u521b\u65b0(00400)\u8dcc2.96%\uff0c\u4e2d\u82af\u56fd\u9645(00981)\u8dcc2.08%\uff0c\u6676\u95e8\u534a\u5bfc\u4f53(02878)\u8dcc2.04%\uff0c\u4e2d\u7535\u534e\u5927\u79d1\u6280(00085)\u8dcc1.55%<br/><br/>\u7f8e\u56fd\u5546\u52a1\u90e812\u67082\u65e5\u53d1\u5e03\u5bf9\u534e\u534a\u5bfc\u4f53\u51fa\u53e3\u7ba1\u5236\u63aa\u65bd\uff0c\u52a0\u4e25\u5bf9\u534a\u5bfc\u4f53\u5236\u9020\u8bbe\u5907\u3001\u5b58\u50a8\u82af\u7247\u7b49\u7269\u9879\u7684\u5bf9\u534e\u51fa\u53e3\u7ba1\u5236\uff0c\u5c06136\u5bb6\u4e2d\u56fd\u5b9e\u4f53\u589e\u5217\u81f3\u51fa\u53e3\u7ba1\u5236\u5b9e\u4f53\u6e05\u5355\uff0c\u5e76\u62d3\u5c55\u957f\u81c2\u7ba1\u8f96\u3002<br/><br/>\u4e2d\u4fe1\u8bc1\u5238\u8868\u793a\uff0c\u7f8e\u56fd\u5546\u52a1\u90e8\u4e8e2024\u5e7412\u67082\u65e5\u66f4\u65b0\u4e86\u534a\u5bfc\u4f53\u51fa\u53e3\u7ba1\u5236\u653f\u7b56\u548c\u5b9e\u4f53\u6e05\u5355\uff0c\u4e3b\u8981\u9488\u5bf9\u4e2d\u56fd\u5927\u9646\u534a\u5bfc\u4f53\u4f01\u4e1a\u3002\u672c\u6b21\u5236\u88c1\u4ecd\u7136\u662f\u4e3b\u8981\u56f4\u7ed5\u5148\u8fdb\u5236\u7a0b\u7684\u201c\u5c0f\u9662\u9ad8\u5899\u201d\u5f0f\u7b56\u7565\uff0c\u610f\u5728\u5361\u4f4f\u4e2d\u56fd\u5148\u8fdb\u534a\u5bfc\u4f53\u53d1\u5c55\u8fdb\u7a0b\uff0c\u76f8\u5173\u5185\u5bb9\u4e0e\u6b64\u524d\u5a92\u4f53\u62a5\u9053\u5185\u5bb9\u5dee\u522b\u4e0d\u5927\uff0c\u5e02\u573a\u5df2\u6709\u6240\u9884\u671f\uff0c\u7531\u4e8e\u76f8\u5173\u4f01\u4e1a\u5df2\u6709\u63d0\u524d\u51c6\u5907\uff0c\u4e2d\u4fe1\u8bc1\u5238\u8ba4\u4e3a\u77ed\u671f\u5b9e\u9645\u5f71\u54cd\u6709\u9650\uff0c\u957f\u671f\u800c\u8a00\u5219\u9700\u653e\u5f03\u5e7b\u60f3\uff0c\u81ea\u7acb\u81ea\u5f3a\uff0c\u6709\u671b\u8fdb\u4e00\u6b65\u52a0\u901f\u5168\u4ea7\u4e1a\u94fe\u56fd\u4ea7\u5316\u8fdb\u7a0b\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259348723", "pub_date": "2024-12-03 10:52:51"}, {"id": 259348504, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6469\u6839\u5927\u901a\uff1a\u4e2d\u56fd11\u6708\u5b98\u65b9\u5236\u9020\u4e1aPMI\u7b26\u9884\u671f \u6599\u660e\u5e74\u9996\u5b63\u7ecf\u6d4e\u589e\u957f\u4fdd\u6301\u7a33\u5065", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6469\u6839\u5927\u901a\u53d1\u5e03\u7684\u7814\u7a76\u62a5\u544a\u6307\u51fa\uff0c\u4e2d\u56fd11\u6708\u5b98\u65b9\u5236\u9020\u4e1aPMI\u7b26\u5408\u9884\u671f\uff0c\u4e0a\u53470.2\u4e2a\u767e\u5206\u70b9\u81f350.3\uff0c\u521b\u4e0b\u4e03\u4e2a\u6708\u65b0\u9ad8\u3002\u5176\u4e2d\uff0c\u4ea7\u51fa\u6307\u6570\u8fdb\u4e00\u6b65\u4e0a\u53470.4\u4e2a\u767e\u5206\u70b9\u81f352.4\uff0c\u65b0\u8ba2\u5355\u6307\u6570\u4e0a\u53470.8\u4e2a\u767e\u5206\u70b9\u81f350.8\uff0c\u800c\u51fa\u53e3\u8ba2\u5355\u6307\u6570\u4e5f\u4e0a\u53470.8\u4e2a\u767e\u5206\u70b9\u81f348.1\u3002\u975e\u5236\u9020\u4e1aPMI\u572811\u6708\u4e0b\u964d0.2\u4e2a\u767e\u5206\u70b9\u81f350.0\uff0c\u4e3a\u75ab\u60c5\u91cd\u65b0\u5f00\u653e\u4ee5\u6765\u7684\u6700\u4f4e\u6c34\u5e73\u3002\u5efa\u7b51\u6d3b\u52a8\u6307\u6570\u8fdb\u4e00\u6b65\u4e0b\u964d0.7\u4e2a\u767e\u5206\u70b9\u81f349.7\uff0c\u4e3a\u5386\u53f2\u6700\u4f4e\u6c34\u5e73\uff0c\u9664\u4e86\u75ab\u60c5\u9ad8\u5cf0\u671f\u3002\u603b\u4f53\u800c\u8a00\uff0c\u5b98\u65b9\u7efc\u5408PMI\u4ea7\u51fa\u4fdd\u6301\u572850.8\u4e0d\u53d8\uff0c\u4e3a5\u6708\u4ee5\u6765\u7684\u6700\u9ad8\u6c34\u5e73\uff0c\u652f\u6301\u4e86\u5bf9\u56db\u5b63\u5ea6GDP\u589e\u957f6.9%\u7684\u9884\u6d4b\uff0c\u9884\u8ba12024\u5e74\u5168\u5e74\u589e\u957f4.8%\u3002<br/><br/>\u6469\u6839\u5927\u901a\u5206\u6790\u8ba4\u4e3a\uff0c11\u6708\u5236\u9020\u4e1aPMI\u7684\u8fdb\u4e00\u6b65\u4e0a\u5347\uff0c\u5c24\u5176\u662f\u4ea7\u51fa\u6307\u6570\u7684\u589e\u957f\uff0c\u8868\u660e\u5de5\u4e1a\u751f\u4ea7\u6d3b\u52a8\u52bf\u5934\u53ef\u80fd\u5728\u8fd1\u671f\u4fdd\u6301\u7a33\u5065\uff0c\u653f\u7b56\u652f\u6301\u6548\u679c\u6b63\u5728\u663e\u73b0\u3002\u65b0\u8ba2\u5355\u6307\u6570\u7684\u663e\u8457\u4e0a\u5347\u4e5f\u8868\u660e\u5de5\u4e1a\u90e8\u95e8\u7684\u77ed\u671f\u9700\u6c42\u72b6\u51b5\u6709\u6240\u6539\u5584\u3002\u6b64\u5916\uff0c\u51fa\u53e3\u8ba2\u5355\u6307\u6570\u7684\u4e0a\u5347\u53ef\u80fd\u652f\u6301\u4e86\u5bf9\u51fa\u53e3\u90e8\u95e8\u9700\u6c42\u7684\u77ed\u671f\u524d\u7f6e\u9884\u671f\uff0c\u5c24\u5176\u662f\u5728\u5bf9\u7f8e\u56fd\u5173\u7a0e\u63d0\u9ad8\u7684\u62c5\u5fe7\u52a0\u5267\u7684\u60c5\u51b5\u4e0b\u3002\u5c3d\u7ba1\u5982\u6b64\uff0c\u670d\u52a1\u4e1a\u6d3b\u52a8PMI\u4fdd\u6301\u572850.1\uff0c\u8868\u660e\u6d88\u8d39\u548c\u670d\u52a1\u90e8\u95e8\u6d3b\u52a8\u9700\u8981\u65f6\u95f4\u624d\u80fd\u663e\u793a\u51fa\u6301\u7eed\u6539\u5584\u3002\u5efa\u7b51\u6d3b\u52a8\u6307\u6570\u7684\u8fdb\u4e00\u6b65\u4e0b\u964d\u4ee4\u4eba\u5173\u6ce8\uff0c\u8868\u660e\u6574\u4f53\u5efa\u7b51\u6d3b\u52a8\u53ef\u80fd\u4fdd\u6301\u75b2\u8f6f\uff0c\u623f\u5730\u4ea7\u6295\u8d44\u6301\u7eed\u4f4e\u8ff7\uff0c\u5c3d\u7ba1\u57fa\u7840\u8bbe\u65bd\u5efa\u8bbe\u6d3b\u52a8\u53ef\u80fd\u6709\u6240\u56de\u5347\u3002<br/><br/>\u6469\u6839\u5927\u901a\u9884\u8ba1\uff0c2025\u5e74\u4e00\u5b63\u5ea6\u4e2d\u56fd\u7ecf\u6d4e\u589e\u957f\u5c06\u4fdd\u6301\u7a33\u5065\uff0c\u9884\u8ba1\u589e\u957f5.7%\uff0c\u90e8\u5206\u53d7\u5230\u51fa\u53e3\u524d\u7f6e\u7684\u63a8\u52a8\uff0c\u968f\u540e\u5728\u4e8c\u5b63\u5ea6\u548c\u4e09\u5b63\u5ea6\u5c06\u663e\u8457\u653e\u7f13\uff0c\u9884\u8ba1\u5206\u522b\u4e3a1.2%\u548c2.0%\u7684\u589e\u957f\uff0c\u5168\u5e74\u589e\u957f\u9884\u6d4b\u4e3a3.9%\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259348504", "pub_date": "2024-12-03 10:50:05"}, {"id": 259348144, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6469\u6839\u5927\u901a\uff1a\u4e2d\u56fd11\u6708\u8d22\u65b0\u5236\u9020\u4e1aPMI\u518d\u6b21\u8d85\u51fa\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6469\u6839\u5927\u901a\u6700\u65b0\u7814\u62a5\u6307\u51fa\uff0c\u4e2d\u56fd11\u6708\u8d22\u65b0\u5236\u9020\u4e1aPMI\uff08\u91c7\u8d2d\u7ecf\u7406\u6307\u6570\uff09\u518d\u6b21\u8d85\u51fa\u9884\u671f\uff0c\u4e0a\u53471.2\u4e2a\u767e\u5206\u70b9\u81f351.5\uff08\u6469\u6839\u5927\u901a\u9884\u671f\u4e3a50.5\uff1b\u5e02\u573a\u5171\u8bc6\u4e3a50.6\uff09\u3002\u8fd9\u4e00\u589e\u957f\u662f\u572810\u6708\u4efd\u589e\u957f1.0\u4e2a\u767e\u5206\u70b9\u7684\u57fa\u7840\u4e0a\u5b9e\u73b0\u7684\u3002\u5206\u9879\u6570\u636e\u663e\u793a\uff0c\u4ea7\u51fa\u6307\u6570\u663e\u8457\u4e0a\u53471.4\u4e2a\u767e\u5206\u70b9\u81f353.2\uff0c\u65b0\u8ba2\u5355\u6307\u6570\u4e5f\u663e\u8457\u589e\u957f2.2\u4e2a\u767e\u5206\u70b9\u81f352.9\u3002\u6b64\u5916\uff0c\u65b0\u51fa\u53e3\u8ba2\u5355\u6307\u6570\u4e0a\u53472.0\u4e2a\u767e\u5206\u70b9\u81f351.5\uff0c\u4e3a\u8fd1\u4e03\u4e2a\u6708\u6765\u7684\u6700\u9ad8\u6c34\u5e73\u3002\u6295\u5165\u548c\u4ea7\u51fa\u4ef7\u683c\u6307\u6570\u572811\u6708\u4e5f\u6709\u6240\u4e0a\u5347\uff0c\u5206\u522b\u4e0a\u53472.2\u4e2a\u767e\u5206\u70b9\u548c1.1\u4e2a\u767e\u5206\u70b9\u3002\u540c\u65f6\uff0c\u5c31\u4e1a\u6307\u6570\u4e0a\u53470.7\u4e2a\u767e\u5206\u70b9\u81f348.3\u3002</p><p>\u6469\u6839\u5927\u901a\u5206\u6790\u8ba4\u4e3a\uff0c\u8d22\u65b0\u548c\u5b98\u65b9\u5236\u9020\u4e1aPMI\u7684\u4e0a\u5347\u53cd\u6620\u4e86\u56fd\u5185\u653f\u7b56\u652f\u6301\u548c\u51fa\u53e3\u8ba2\u5355\u524d\u7f6e\u7684\u5f71\u54cd\u3002\u4e24\u4e2a\u5236\u9020\u4e1aPMI\u5747\u663e\u793a\u51fa\u4ea7\u51fa\u6210\u5206\u7684\u663e\u8457\u589e\u957f\uff0c\u8868\u660e\u5728\u653f\u7b56\u652f\u6301\u4e0b\uff0c\u5de5\u4e1a\u751f\u4ea7\u6d3b\u52a8\u7684\u52bf\u5934\u53ef\u80fd\u4fdd\u6301\u7a33\u5065\uff0c\u800c\u51fa\u53e3\u6d3b\u52a8\u53ef\u80fd\u56e0\u9884\u671f\u7684\u7f8e\u56fd\u5173\u7a0e\u63d0\u9ad8\u800c\u663e\u793a\u51fa\u5f3a\u52b2\u7684\u77ed\u671f\u52bf\u5934\u3002\u6b64\u5916\uff0c\u4e24\u4e2a\u5236\u9020\u4e1aPMI\u7684\u65b0\u8ba2\u5355\u548c\u51fa\u53e3\u8ba2\u5355\u6210\u5206\u5747\u6709\u6240\u4e0a\u5347\uff0c\u6697\u793a\u7740\u5236\u9020\u5546\u7684\u56fd\u5185\u5916\u9700\u6c42\u524d\u666f\u5728\u77ed\u671f\u5185\u6709\u6240\u6539\u5584\u3002\u7279\u522b\u662f\u65b0\u51fa\u53e3\u8ba2\u5355\u7684\u663e\u8457\u589e\u957f\uff0c\u53ef\u80fd\u4e0e\u5bf9\u7f8e\u56fd\u5173\u7a0e\u63d0\u9ad8\u7684\u62c5\u5fe7\u6709\u5173\uff0c\u63a8\u52a8\u4e86\u51fa\u53e3\u8ba2\u5355\u7684\u524d\u7f6e\u3002\u8be5\u884c\u8ba4\u4e3a\uff0c\u8fd9\u4e9b\u6570\u636e\u5bf9\u4e8e\u9884\u6d4b\u4e2d\u56fd\u56db\u5b63\u5ea6GDP\u589e\u957f\u81f36.9%\uff08\u73af\u6bd4\u5e74\u5316\u589e\u957f\u7387\uff09\u63d0\u4f9b\u4e86\u652f\u6301\uff0c\u9884\u8ba12024\u5e74\u5168\u5e74GDP\u589e\u957f\u4e3a4.8%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259348144", "pub_date": "2024-12-03 10:44:09"}, {"id": 259348177, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u745e\u94f6\uff1a\u7f8e\u56fd\u80a1\u5e0212\u6708\u7b56\u7565\u4e0e11\u6708\u56de\u62a5\u5206\u89e3", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u745e\u94f6\u5168\u7403\u7814\u7a76\u90e8\u95e8\u8fd1\u65e5\u53d1\u5e03\u4e86\u4e24\u4efd\u5173\u4e8e\u7f8e\u56fd\u80a1\u5e02\u7684\u7814\u7a76\u62a5\u544a\uff0c\u4e00\u4efd\u805a\u7126\u4e8e2024\u5e7412\u6708\u7684\u7f8e\u56fd\u80a1\u7968\u7b56\u7565\u8def\u7ebf\u56fe\uff0c\u53e6\u4e00\u4efd\u5219\u8be6\u7ec6\u5206\u6790\u4e86\u7f8e\u56fd\u80a1\u5e02\u7684\u56de\u62a5\u5206\u89e3\u3002<br/></p><p>\u572812\u6708\u6295\u8d44\u8def\u7ebf\u56fe\u7684\u7814\u62a5\u4e2d\uff0c\u745e\u94f6\u6307\u51fa\uff0c\u968f\u7740\u7279\u6717\u666e\u5f53\u9009\u7f8e\u56fd\u603b\u7edf\uff0c11\u6708\u4efd\u6807\u666e500\u6307\u6570\u4e0a\u6da8\u4e865.9%\u3002\u7136\u800c\uff0c\u7531\u4e8e\u5173\u7a0e\u3001\u79fb\u6c11\u653f\u7b56\u548c\u5176\u4ed6\u653f\u7b56\u62c5\u5fe7\uff0c\u975e\u7f8e\u56fd\u5e02\u573a\u53d7\u5230\u5f71\u54cd\uff0cEAFE\u548c\u65b0\u5174\u5e02\u573a\u5206\u522b\u4ee5\u672c\u5730\u8d27\u5e01\u8ba1\u7b97\u4e0a\u6da8\u4e860.6%\u548c\u4e0b\u8dcc\u4e862.7%\uff0c\u4ee5\u7f8e\u5143\u8ba1\u7b97\u5219\u4e0b\u8dcc\u4e860.6%\u548c3.6%\u3002\u62a5\u544a\u8fd8\u5f3a\u8c03\uff0c\u8bb8\u591a\u6295\u8d44\u8005\u8ba4\u4e3a\u7279\u6717\u666e\u7684\u653f\u7b56\u5177\u6709\u901a\u80c0\u6027\u5e76\u53ef\u80fd\u7834\u574f\u7a33\u5b9a\uff0c\u9884\u8ba1\u503a\u5238\u6536\u76ca\u7387\u548c\u98ce\u9669\u6ea2\u4ef7\u5c06\u4e0a\u5347\u3002\u5c3d\u7ba1\u9009\u4e3e\u540e\u5373\u671f\u7684\u76c8\u4e8f\u5e73\u8861\u901a\u80c0\u7387\u548c\u56fd\u503a\u6536\u76ca\u7387\u98d9\u5347\uff0c\u4f46\u5b83\u4eec\u5df2\u56de\u523011\u6708\u521d\u7684\u6c34\u5e73\u3002\u4fe1\u7528\u5229\u5dee\u548cVIX\u7b49\u5173\u952e\u98ce\u9669\u6307\u6807\u5728\u9009\u4e3e\u540e\u5747\u6709\u6240\u4e0b\u964d\uff0c\u5bfc\u81f4\u5c0f\u76d8\u80a1\u8868\u73b0\u4f18\u4e8e\u5927\u76d8\u80a1\uff0c\u5e76\u63d0\u9ad8\u4e86\u4f30\u503c\u3002<br/>\u5728\u6709\u5173\u56de\u62a5\u5206\u89e3\u7684\u62a5\u544a\u4e2d\u5219\u8be6\u7ec6\u5206\u6790\u4e8611\u6708\u4efd\u7684\u5e02\u573a\u8868\u73b0\u3002\u62a5\u544a\u6307\u51fa\uff0c\u5c0f\u76d8\u80a1\u572811\u6708\u4efd\u7684\u8868\u73b0\u8d85\u8fc7\u4e86\u5927\u76d8\u80a1\uff0811.0%\u5bf9\u6bd45.9%\uff09\uff0c\u800c\u4ef7\u503c\u80a1\u548c\u6210\u957f\u80a1\u7684\u56de\u62a5\u76f8\u4f3c\uff086.4%\u5bf9\u6bd46.5%\uff09\u3002\u6240\u6709\u4e3b\u8981\u7684\u7f8e\u56fd\u57fa\u51c6\u6307\u6570\u572811\u6708\u4efd\u90fd\u5448\u73b0\u6b63\u589e\u957f\uff0c\u800cEAFE\u5728\u672c\u5730\u8d27\u5e01\uff080.6%\uff09\u548c\u7f8e\u5143\u8ba1\u4ef7\uff08-0.6%\uff09\u65b9\u9762\u5747\u843d\u540e\u3002\u62a5\u544a\u8fd8\u63d0\u5230\uff0c\u6240\u6709\u6807\u666e500\u677f\u5757\u572811\u6708\u4efd\u90fd\u5b9e\u73b0\u4e86\u6b63\u56de\u62a5\uff0c\u5176\u4e2d\u5468\u671f\u6027\u677f\u5757\u8868\u73b0\u6700\u4f73\uff0c\u7279\u522b\u662f\u6d88\u8d39\u81ea\u7531\u652f\u914d\u3001\u91d1\u878d\u3001\u5de5\u4e1a\u548c\u80fd\u6e90\u677f\u5757\u3002\u5728\u677f\u5757\u5185\u90e8\uff0c\u6700\u7ecf\u6d4e\u654f\u611f\u7684\u80a1\u7968\u548c\u90a3\u4e9b\u6700\u66b4\u9732\u4e8e\u5c3e\u90e8\u98ce\u9669\u7684\u80a1\u7968\u8868\u73b0\u6700\u4f73\u3002<br/>\u745e\u94f6\u7684\u5206\u6790\u5e08\u5bf9\u8fd9\u4e9b\u6570\u636e\u8fdb\u884c\u4e86\u6df1\u5165\u5206\u6790\uff0c\u5e76\u5bf9\u672a\u6765\u7684\u5e02\u573a\u8d8b\u52bf\u7ed9\u51fa\u4e86\u5c55\u671b\u3002\u4ed6\u4eec\u8ba4\u4e3a\uff0c\u5c3d\u7ba1\u5e02\u573a\u5728\u77ed\u671f\u5185\u53ef\u80fd\u4f1a\u53d7\u5230\u653f\u7b56\u53d8\u52a8\u548c\u5168\u7403\u7ecf\u6d4e\u4e0d\u786e\u5b9a\u6027\u7684\u5f71\u54cd\uff0c\u4f46\u4ece\u957f\u671f\u6765\u770b\uff0c\u7f8e\u56fd\u80a1\u5e02\u7684\u57fa\u672c\u9762\u5411\u597d\uff0c\u7279\u522b\u662f\u5728\u6280\u672f\u548c\u91d1\u878d\u677f\u5757\u3002\u745e\u94f6\u9884\u8ba1\uff0cTECH+\u677f\u5757\u57282025\u5e74\u7684\u589e\u957f\u5c06\u8fbe\u523019.8%\uff0c\u8fdc\u8d85\u5e02\u573a\u5176\u4ed6\u90e8\u5206\u76849.4%\u3002\u91d1\u878d\u677f\u5757\u9884\u8ba1\u5c06\u6210\u4e3a\u7279\u6717\u666e\u603b\u7edf\u4efb\u671f\u5185\u7684\u6700\u5927\u53d7\u76ca\u8005\uff0c\u800c\u5de5\u4e1a\u677f\u5757\u5728\u76c8\u5229\u524d\u666f\u548c\u4f30\u503c\u65b9\u9762\u6bd4\u6d88\u8d39\u677f\u5757\u66f4\u5177\u5438\u5f15\u529b\u3002\u516c\u7528\u4e8b\u4e1a\u677f\u5757\u5219\u662f\u6700\u5177\u5438\u5f15\u529b\u7684\u9632\u5fa1\u6027\u677f\u5757\uff0c\u5f97\u76ca\u4e8e\u5f3a\u52b2\u7684A\u80a1\u548c\u7535\u52a8\u8f66\u9700\u6c42\u3002\u745e\u94f6\u5efa\u8bae\u6295\u8d44\u8005\u8d85\u914dTECH+\u3001\u91d1\u878d\u3001\u5de5\u4e1a\u548c\u516c\u7528\u4e8b\u4e1a\u677f\u5757\uff0c\u5e76\u5728\u5176\u90e8\u95e8\u8def\u7ebf\u56fe\u4e2d\u63d0\u4f9b\u4e86\u66f4\u8be6\u7ec6\u7684\u4fe1\u606f\u548c\u6700\u8fd1\u7684\u53d8\u5316\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259348177", "pub_date": "2024-12-03 10:44:35"}, {"id": 259347724, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u745e\u94f6\u4e88\u534e\u6da6\u996e\u6599(02460)\u201c\u4e70\u5165\u201d\u8bc4\u7ea7 \u6307\u5176\u5728\u6e20\u9053\u6269\u5f20\u65b9\u9762\u5177\u6709\u6f5c\u529b", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u745e\u94f6\u5168\u7403\u7814\u7a76\u90e8\u95e8\u8fd1\u65e5\u53d1\u5e03\u7814\u62a5\uff0c\u5bf9\u534e\u6da6\u996e\u6599(02460)\u7684\u4e1a\u7ee9\u548c\u5e02\u573a\u8868\u73b0\u8fdb\u884c\u4e86\u6df1\u5165\u5206\u6790\u3002\u534e\u6da6\u996e\u6599\u4f5c\u4e3a\u4e2d\u56fd\u5305\u88c5\u6c34\u5e02\u573a\u7b2c\u4e8c\u5927\u548c\u5373\u996e\u8f6f\u996e\u6599\u5e02\u573a\u7b2c\u4e94\u5927\u7684\u516c\u53f8\uff0c2023\u5e74\u96f6\u552e\u4ef7\u503c\u4efd\u989d\u5206\u522b\u4e3a18.4%\u548c4.7%\u3002\u516c\u53f82014-2023\u5e74\u7684\u6536\u5165\u548cEBITDA\u590d\u5408\u5e74\u589e\u957f\u7387\u5206\u522b\u4e3a6%\u548c17%\u30022025\u8d22\u5e74\u7b2c\u4e00\u5b63\u5ea6\uff0c\u516c\u53f8\u8425\u6536\u4e3a26\u4ebf\u6e2f\u5143\uff0c\u540c\u6bd4\u4e0b\u964d6%\uff0c\u51c0\u5229\u6da6\u4e3a1.48\u4ebf\u6e2f\u5143\uff0c\u540c\u6bd4\u4e0b\u964d28%\uff0c\u6bdb\u5229\u7387\u8fbe\u523029%\uff0c\u540c\u6bd4\u589e\u957f3\u4e2a\u767e\u5206\u70b9\u3002\u745e\u94f6\u9884\u8ba1\u534e\u6da6\u996e\u65992023-2026\u5e74\u7684\u51c0\u5229\u6da6\u590d\u5408\u5e74\u589e\u957f\u7387\u4e3a17%\uff0c\u652f\u6301\u8fd9\u4e00\u589e\u957f\u7684\u662f6%\u7684\u6536\u5165\u590d\u5408\u5e74\u589e\u957f\u7387\u548c3.3\u4e2a\u767e\u5206\u70b9\u7684\u51c0\u5229\u6da6\u7387\u589e\u957f\u3002<br/><br/>\u745e\u94f6\u8ba4\u4e3a\uff0c\u534e\u6da6\u996e\u6599\u672a\u6765\u7684\u589e\u957f\u52a8\u529b\u5c06\u6765\u81ea\u5176\u81ea\u6709\u4ea7\u80fd\u7684\u6269\u5f20\u3001\u6e20\u9053\u548c\u54c1\u7c7b\u7684\u6269\u5c55\u3002\u516c\u53f8\u81ea2022\u5e74\u4ee5\u6765\u52a0\u901f\u81ea\u6709\u4ea7\u80fd\u6269\u5f20\uff0c\u9884\u8ba1\u52302026\u5e74\u81ea\u6709\u4ea7\u80fd\u5c06\u5360\u603b\u4ea7\u91cf\u768465%\uff0c\u9ad8\u4e8e2023\u5e74\u768433%\u3002\u6b64\u5916\uff0c\u534e\u6da6\u996e\u6599\u7684\u603b\u9500\u552e\u70b9\u8986\u76d6\u7387\u7ea6\u4e3a\u519c\u592b\u5c71\u6cc9\u7684\u4e00\u534a\uff0c\u4f46\u5176\u96f6\u552e\u4ef7\u503c\u4ec5\u4f4e25%\uff0c\u8868\u660e\u516c\u53f8\u5728\u6e20\u9053\u6269\u5f20\u65b9\u9762\u5177\u6709\u6f5c\u529b\u3002\u745e\u94f6\u8ba4\u4e3a\uff0c\u534e\u6da6\u996e\u6599\u5728\u5305\u88c5\u6c34\u9886\u57df\u7684\u9886\u5bfc\u5730\u4f4d\uff0c\u8fd9\u4e00\u5373\u996e\u996e\u6599\u96f6\u552e\u9500\u552e\u4ef7\u503c\u6700\u5927\u7684\u54c1\u7c7b\uff0c\u5c06\u6709\u52a9\u4e8e\u516c\u53f8\u5728\u54c1\u7c7b\u6269\u5c55\u4e0a\u53d6\u5f97\u8fdb\u5c55\uff0c\u7279\u522b\u662f\u5728\u6d88\u8d39\u8005\u5bf9\u5065\u5eb7\u996e\u54c1\u9700\u6c42\u4e0a\u5347\u7684\u80cc\u666f\u4e0b\uff0c\u9884\u8ba1\u5176\u4e2d\u8349\u836f\u8336\u54c1\u724c\u201c\u81f3\u672c\u6e05\u6da6\u201d\u5c06\u6210\u4e3a2024-2026\u5e74\u7684\u4e3b\u8981\u6536\u5165\u589e\u957f\u8d21\u732e\u8005\u3002\u745e\u94f6\u4e88\u534e\u6da6\u996e\u6599\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0c\u672a\u676512\u4e2a\u6708\u7684\u76ee\u6807\u4ef716.00\u6e2f\u5143\u3002</p><p><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259347724", "pub_date": "2024-12-03 10:38:58"}, {"id": 259346283, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6469\u6839\u58eb\u4e39\u5229\uff1a\u529b\u52b2\u79d1\u6280(00558)\u4e1a\u7ee9\u672a\u8fbe\u9884\u671f \u538b\u94f8\u4e1a\u52a1\u4e0b\u6ed1", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6469\u6839\u58eb\u4e39\u5229\u53d1\u5e03\u7684\u7814\u7a76\u62a5\u544a\u6307\u51fa\uff0c\u529b\u52b2\u79d1\u6280(00558)2025\u8d22\u5e74\u7b2c\u4e00\u5b63\u5ea6\u4e1a\u7ee9\u672a\u8fbe\u9884\u671f\uff0c\u4e3b\u8981\u7531\u4e8e\u538b\u94f8\u673a\u68b0\u4e1a\u52a1\u7684\u4e0b\u6ed1\u3002\u62a5\u544a\u4e2d\u63d0\u5230\uff0c\u529b\u52b2\u79d1\u62802025\u8d22\u5e74\u7b2c\u4e00\u5b63\u5ea6\u8425\u6536\u4e3a26\u4ebf\u6e2f\u5143\uff0c\u540c\u6bd4\u4e0b\u964d6%\uff0c\u73af\u6bd4\u4e0b\u964d16%\uff0c\u4f4e\u4e8e\u6469\u6839\u58eb\u4e39\u5229\u548c\u5e02\u573a\u5171\u8bc6\u9884\u671f\u3002\u5176\u4e2d\uff0c\u538b\u94f8\u673a\u68b0\u4e1a\u52a1\u6536\u5165\u540c\u6bd4\u4e0b\u964d19%\uff0c\u800cPIMM\u548cCNC\u4e2d\u5fc3\u4e1a\u52a1\u5206\u522b\u540c\u6bd4\u589e\u957f30%\u548c14%\u3002\u6bdb\u5229\u7387\u8fbe\u523029%\uff0c\u540c\u6bd4\u589e\u957f3\u4e2a\u767e\u5206\u70b9\uff0c\u73af\u6bd4\u589e\u957f1\u4e2a\u767e\u5206\u70b9\uff0c\u9ad8\u4e8e\u9884\u671f\u768427%\u3002\u51c0\u5229\u6da6\u4e3a1.48\u4ebf\u6e2f\u5143\uff0c\u540c\u6bd4\u4e0b\u964d28%\uff0c\u73af\u6bd4\u4e0b\u964d47%\uff0c\u4ea6\u4f4e\u4e8e\u9884\u671f\u3002<br/><br/>\u62a5\u544a\u5206\u6790\u8ba4\u4e3a\uff0c\u529b\u52b2\u79d1\u6280\u7684\u8425\u6536\u672a\u8fbe\u9884\u671f\u4e3b\u8981\u662f\u7531\u4e8e\u538b\u94f8\u4e1a\u52a1\u7684\u6076\u5316\uff0c\u800c\u51c0\u5229\u6da6\u53d7\u5230\u7814\u53d1\u6210\u672c\u4e0a\u5347\uff08\u540c\u6bd4\u589e\u957f206%\uff09\u548c\u5e94\u6536\u8d26\u6b3e\u51c6\u5907\u91d1\u589e\u52a0\u7684\u62d6\u7d2f\u3002\u62a5\u544a\u8fd8\u6307\u51fa\uff0c\u529b\u52b2\u79d1\u6280\u7684\u81ea\u7531\u73b0\u91d1\u6d41\u4e3a\u8d1f1.668\u4ebf\u6e2f\u5143\uff0c\u540c\u6bd4\u4e0b\u964d195%\uff0c\u73af\u6bd4\u4e0b\u964d52%\uff0c2025\u8d22\u5e74\u7b2c\u4e00\u5b63\u5ea6\u7684\u80a1\u606f\u652f\u4ed8\u6bd4\u7387\u4e3a28%\uff0c\u540c\u6bd4\u4e0b\u964d2\u4e2a\u767e\u5206\u70b9\u3002\u6469\u6839\u58eb\u4e39\u5229\u8ba4\u4e3a\uff0c\u529b\u52b2\u79d1\u6280\u7684\u4e1a\u7ee9\u4e0b\u6ed1\u524a\u5f31\u4e86\u5176\u6295\u8d44\u8bba\u70b9\uff0c\u4e88\u5176\u201c\u4e0e\u5927\u5e02\u540c\u6b65\u201d\u8bc4\u7ea7\uff0c\u76ee\u6807\u4ef73.90\u6e2f\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259346283", "pub_date": "2024-12-03 10:17:55"}, {"id": 259346350, "title": "\u3010\u884c\u4e1a\u98ce\u5411\u3011\u6559\u80b2\u90e8\u90e8\u7f72\u52a0\u5f3a\u4e2d\u5c0f\u5b66\u4eba\u5de5\u667a\u80fd\u6559\u80b2\uff1b11\u6708\u91cd\u5361\u9500\u91cf\u7a81\u78347\u4e07\u8f86", "description": "<p><b>\u6559\u80b2\u90e8\u90e8\u7f72\u52a0\u5f3a\u4e2d\u5c0f\u5b66\u4eba\u5de5\u667a\u80fd\u6559\u80b2</b><br/><br/>\u6559\u80b2\u90e8\u529e\u516c\u5385\u8fd1\u65e5\u5370\u53d1\u901a\u77e5\uff0c\u63a2\u7d22\u4e2d\u5c0f\u5b66\u4eba\u5de5\u667a\u80fd\u6559\u80b2\u5b9e\u65bd\u9014\u5f84\uff0c\u52a0\u5f3a\u4e2d\u5c0f\u5b66\u4eba\u5de5\u667a\u80fd\u6559\u80b2\u3002<br/><br/>\u901a\u77e5\u660e\u786e\uff0c\u8981\u6784\u5efa\u7cfb\u7edf\u5316\u8bfe\u7a0b\u4f53\u7cfb\uff0c\u5b9e\u65bd\u5e38\u6001\u5316\u6559\u5b66\u4e0e\u8bc4\u4ef7\u3002\u8fdb\u4e00\u6b65\u5b8c\u5584\u76f8\u5173\u8bfe\u7a0b\u4e2d\u4eba\u5de5\u667a\u80fd\u6559\u80b2\u8981\u6c42\uff0c\u5c0f\u5b66\u4f4e\u5e74\u7ea7\u6bb5\u4fa7\u91cd\u611f\u77e5\u548c\u4f53\u9a8c\u4eba\u5de5\u667a\u80fd\u6280\u672f\uff0c\u5c0f\u5b66\u9ad8\u5e74\u7ea7\u6bb5\u548c\u521d\u4e2d\u9636\u6bb5\u4fa7\u91cd\u7406\u89e3\u548c\u5e94\u7528\u4eba\u5de5\u667a\u80fd\u6280\u672f\uff0c\u9ad8\u4e2d\u9636\u6bb5\u4fa7\u91cd\u9879\u76ee\u521b\u4f5c\u548c\u524d\u6cbf\u5e94\u7528\u3002<br/><br/>\u901a\u77e5\u63d0\u51fa\uff0c\u5206\u6279\u8bbe\u7acb\u4e2d\u5c0f\u5b66\u4eba\u5de5\u667a\u80fd\u6559\u80b2\u57fa\u5730\uff0c\u63a8\u52a8\u9ad8\u6821\u3001\u79d1\u7814\u9662\u6240\u548c\u9ad8\u79d1\u6280\u4f01\u4e1a\u7684\u4eba\u5de5\u667a\u80fd\u5b9e\u9a8c\u5ba4\u3001\u5c55\u5385\u7b49\u573a\u9986\u5411\u4e2d\u5c0f\u5b66\u6821\u5f00\u653e\uff0c\u5f00\u53d1\u9002\u5408\u4e2d\u5c0f\u5b66\u751f\u7684\u4eba\u5de5\u667a\u80fd\u6559\u80b2\u8d44\u6e90\u3002<br/><br/>\u6765\u6e90\uff1a\u5317\u4eac\u9752\u5e74\u62a5<br/><br/><b>\u4e2d\u4fc4\u4e1c\u7ebf\u5929\u7136\u6c14\u7ba1\u9053\u5168\u7ebf\u8d2f\u901a\u3000\u5e74\u8f93\u6c14\u80fd\u529b\u589e\u81f3380\u4ebf\u7acb\u65b9\u7c73</b><br/><br/>12\u67082\u65e5\uff0c\u6211\u56fd\u5355\u7ba1\u8f93\u6c14\u91cf\u6700\u5927\u7684\u5929\u7136\u6c14\u7ba1\u9053\u2014\u2014\u4e2d\u4fc4\u4e1c\u7ebf\u5929\u7136\u6c14\u7ba1\u9053\u5168\u7ebf\u8d2f\u901a\uff0c\u5e74\u8f93\u6c14\u80fd\u529b\u589e\u81f3380\u4ebf\u7acb\u65b9\u7c73\uff0c\u8fbe\u5230\u6700\u9ad8\u6c34\u5e73\u3002<br/><br/>\u4e2d\u4fc4\u4e1c\u7ebf\u5929\u7136\u6c14\u5e02\u573a\u8986\u76d6\u6211\u56fd\u4e1c\u4e09\u7701\u3001\u73af\u6e24\u6d77\u3001\u957f\u4e09\u89d2\u7b49\u5730\u533a\u3002\u81ea2019\u5e7412\u6708\u5317\u6bb5\u6295\u4ea7\u901a\u6c14\u4ee5\u6765\uff0c\u4e2d\u4fc4\u4e1c\u7ebf\u7d2f\u8ba1\u8f93\u6c14\u91cf\u7a81\u7834800\u4ebf\u7acb\u65b9\u7c73\uff0c\u4e0d\u4ec5\u5f62\u6210\u4e86\u65b0\u7684\u5168\u56fd\u4f9b\u6c14\u683c\u5c40\uff0c\u4f7f\u5929\u7136\u6c14\u4f9b\u5e94\u6e20\u9053\u66f4\u52a0\u591a\u5143\uff0c\u8fd8\u5e26\u52a8\u4e86\u6cbf\u7ebf\u4ea7\u4e1a\u8f6c\u578b\u5347\u7ea7\uff0c\u4e3a\u6211\u56fd\u4e1c\u90e8\u5730\u533a\u9ad8\u8d28\u91cf\u53d1\u5c55\u6ce8\u5165\u5f3a\u52b2\u52a8\u529b\u3002<br/><br/>\u6765\u6e90\uff1a\u7ecf\u6d4e\u53c2\u8003\u62a5<br/><br/><b>11\u6708\u91cd\u5361\u9500\u91cf\u7a81\u78347\u4e07\u8f86</b><br/><br/>\u65b9\u5f97\u7f512\u65e5\u53d1\u5e03\u6570\u636e\uff0c11\u6708\uff0c\u6211\u56fd\u91cd\u5361\u884c\u4e1a\u6574\u4f53\u9500\u91cf\u4e3a7.1\u4e07\u8f86\uff08\u6279\u53d1\u53e3\u5f84\uff0c\u5305\u542b\u51fa\u53e3\u548c\u65b0\u80fd\u6e90\uff09\uff0c\u73af\u6bd4\u589e\u957f7%\uff0c\u4e0e\u4e0a\u5e74\u540c\u671f\u57fa\u672c\u6301\u5e73\uff1b1\u523011\u6708\uff0c\u91cd\u5361\u884c\u4e1a\u6574\u4f53\u9500\u91cf\u7ea682\u4e07\u8f86\uff0c\u540c\u6bd4\u964d\u5e45\u7ea6\u4e3a5%\u3002<br/><br/>11\u6708\uff0c\u91cd\u5361\u884c\u4e1a\u6536\u83b77.1\u4e07\u8f86\u7684\u9500\u91cf\u3002\u4e0e\u5386\u5e74\u540c\u671f\u76f8\u6bd4\uff0c\u4eca\u5e7411\u6708\u7684\u91cd\u5361\u9500\u91cf\u9ad8\u4e8e2022\u5e74\u548c2021\u5e74\u540c\u671f\uff0c\u4e0e2023\u5e74\u540c\u671f\u6301\u5e73\uff0c\u4f46\u4f4e\u4e8e\u5176\u4ed6\u5e74\u4efd\u7684\u540c\u671f\u9500\u91cf\u3002<br/><br/>\u6765\u6e90\uff1a\u4e0a\u6d77\u8bc1\u5238\u62a5<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259346350", "pub_date": "2024-12-03 10:18:43"}, {"id": 259346758, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6469\u6839\u58eb\u4e39\u5229\u5347\u6ce1\u6ce1\u739b\u7279(09992)\u76ee\u6807\u4ef7\u8fd140% \u770b\u597d\u5176\u5168\u7403\u6269\u5f20\u52a9\u529bIP\u70ed\u5ea6", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6469\u6839\u58eb\u4e39\u5229\u53d1\u5e03\u7684\u7814\u7a76\u62a5\u544a\u4e2d\uff0c\u5bf9\u6ce1\u6ce1\u739b\u7279\u56fd\u9645\u96c6\u56e2(09992)\u7684\u4e1a\u7ee9\u548c\u8d22\u52a1\u6570\u636e\u7ed9\u4e88\u4e86\u79ef\u6781\u8bc4\u4ef7\u3002\u7814\u62a5\u663e\u793a\uff0c\u6ce1\u6ce1\u739b\u72792024\u5e74\u81f32026\u5e74\u7684\u9884\u671f\u6bcf\u80a1\u6536\u76ca\uff08EPS\uff09\u5206\u522b\u4e3a2.23\u5143\u4eba\u6c11\u5e01\u30013.06\u5143\u4eba\u6c11\u5e01\u548c3.74\u5143\u4eba\u6c11\u5e01\uff0c\u5448\u73b0\u51fa\u7a33\u5065\u7684\u589e\u957f\u8d8b\u52bf\u3002\u540c\u65f6\uff0c\u516c\u53f8\u8425\u6536\u548c\u51c0\u5229\u6da6\u4e5f\u5448\u73b0\u51fa\u5f3a\u52b2\u7684\u589e\u957f\u52bf\u5934\uff0c\u9884\u8ba12024\u5e74\u8425\u6536\u4e3a12.33\u4ebf\u4eba\u6c11\u5e01\uff0c2025\u5e74\u548c2026\u5e74\u5206\u522b\u8fbe\u523016.637\u4ebf\u4eba\u6c11\u5e01\u548c20.483\u4ebf\u4eba\u6c11\u5e01\u3002\u6b64\u5916\uff0c\u6ce1\u6ce1\u739b\u7279\u7684\u5168\u7403\u6269\u5f20\u7b56\u7565\u6b63\u5728\u5ef6\u957f\u5176\u5feb\u901f\u589e\u957f\u7684\u6301\u7eed\u65f6\u95f4\uff0c\u6d77\u5916\u5e97\u94fa\u751f\u4ea7\u529b\u6301\u7eed\u4e0a\u5347\uff0c\u5373\u4f7f\u5728\u5feb\u901f\u5f00\u5e97\u548c\u4ea7\u54c1\u4e25\u91cd\u77ed\u7f3a\u7684\u60c5\u51b5\u4e0b\uff0c\u8fd9\u8868\u660e\u589e\u957f\u7684\u5929\u82b1\u677f\u8fd8\u5f88\u8fdc\u3002<br/><br/>\u6469\u6839\u58eb\u4e39\u5229\u5bf9\u6ce1\u6ce1\u739b\u7279\u6240\u5728\u7684\u76f2\u76d2\u53ca\u6f6e\u6d41\u73a9\u5177\u884c\u4e1a\u6301\u4e50\u89c2\u6001\u5ea6\uff0c\u5e76\u8ba4\u4e3a\u6ce1\u6ce1\u739b\u7279\u7684\u5168\u7403\u6269\u5f20\u7b56\u7565\u5c06\u8fdb\u4e00\u6b65\u63a8\u52a8\u5176IP\u70ed\u5ea6\u3002\u7814\u62a5\u4e2d\u63d0\u5230\uff0c\u6ce1\u6ce1\u739b\u7279\u53ef\u80fd\u662f\u7b2c\u4e00\u4e2a\u901a\u8fc7\u5438\u5f15\u6d88\u8d39\u8005\u5bf9IP\u3001\u8bbe\u8ba1\u548c\u4ea7\u54c1\u7684\u5174\u8da3\uff0c\u800c\u975e\u5b9a\u4ef7\uff0c\u5b9e\u73b0\u5168\u7403\u91cd\u5927\u6210\u529f\u7684\u672c\u571f\u4e2d\u56fd\u6d88\u8d39\u54c1\u724c\u3002\u6469\u6839\u58eb\u4e39\u5229\u9884\u8ba1\uff0c\u52302025\u5e74\uff0c\u6ce1\u6ce1\u739b\u7279\u8d85\u8fc750%\u7684\u9500\u552e\u548c\u76c8\u5229\u5c06\u6765\u81ea\u56fd\u9645\u5e02\u573a\uff0c\u5e76\u4e14\u8fd9\u4e00\u6bd4\u4f8b\u5c06\u6301\u7eed\u589e\u957f\u3002\u56e0\u6b64\uff0c\u6ce1\u6ce1\u739b\u7279\u7684\u5168\u7403\u6269\u5f20\u548c\u5e02\u573a\u591a\u6837\u6027\u7684\u589e\u52a0\u5e94\u8be5\u662f\u5176\u4f30\u503c\u91cd\u4f30\u7684\u9a71\u52a8\u529b\u3002<br/><br/>\u6469\u6839\u58eb\u4e39\u5229\u5c06\u6ce1\u6ce1\u739b\u7279\u7684\u8bc4\u7ea7\u4e0a\u8c03\u81f3\u201c\u8dd1\u8d62\u5927\u5e02\u201d\uff0c\u76ee\u6807\u4ef7\u4ece81.00\u6e2f\u5143\u4e0a\u8c03\u81f3113.00\u6e2f\u5143\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259346758", "pub_date": "2024-12-03 10:24:43"}]}