1\u5728\u610f\u6599\u4e4b\u4e2d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u82b1\u65d7\u53d1\u62a5\u6307\uff0c\u534e\u6da6\u7535\u529b(00836)\u62df\u914d\u552e1.99\u4ebf\u80a1\u65b0\u80a1\u4efd\u4e88\u4e0d\u5c11\u4e8e6\u540d\u627f\u914d\u4eba\uff0c\u5360\u901a\u8fc7\u914d\u53d1\u53ca\u53d1\u884c\u914d\u552e\u80a1\u4efd\u7ecf\u6269\u5927\u540e\u7684\u5df2\u53d1\u884c\u80a1\u672c\u76843.96%\uff0c\u6bcf\u80a1\u914d\u552e\u4ef7\u4e3a19.7\u6e2f\u5143\u3002\u8be5\u884c\u6307\u51fa\uff0c\u6da6\u7535\u6b64\u6b21\u914d\u80a1\u5728\u610f\u6599\u4e4b\u4e2d\uff0c\u56e0\u4e3a\u516c\u53f8\u57282024\u52302025\u5e74\u95f4\u9884\u671f\u7684\u8d44\u672c\u652f\u51fa\u9ad8\u8fbe\u6bcf\u5e74600\u4ebf\u5143\uff0c\u4e3b\u8981\u7528\u4e8e\u6269\u5927\u53ef\u518d\u751f\u80fd\u6e90\u53d1\u7535\u80fd\u529b\u3002\u6b64\u5916\uff0c\u7531\u4e8e\u4eca\u5e74\u4e0a\u534a\u5e74\u516c\u53f8\u51fa\u73b0\u4e86\u8d1f\u81ea\u7531\u73b0\u91d1\u6d41\uff0c\u5e76\u4e14\u7531\u4e8e\u80a1\u5e02\u72b6\u51b5\u4e0d\u4f73\uff0c\u5bfc\u81f4\u5176\u5728A\u80a1\u5e02\u573a\u62c6\u5206\u53ef\u518d\u751f\u80fd\u6e90\u4e1a\u52a1\u7684\u8ba1\u5212\u5ef6\u671f\u3002<br/><br/>\u82b1\u65d7\u9884\u8ba1\uff0c\u6b64\u6b21\u80a1\u4efd\u914d\u552e\u540e\uff0c\u6da6\u7535\u5c06\u5728\u5e74\u5e95\u5b9e\u73b0\u51c0\u8d1f\u503a\u6743\u76ca\u6bd4\u7387\u964d\u4f4e\u4e24\u4e2a\u767e\u5206\u70b9\u81f3166%\u3002\u5982\u679c\u96c6\u56e2\u5728\u672a\u6765\u7ee7\u7eed\u8fdb\u884c\u80a1\u4efd\u914d\u552e\uff0c\u82b1\u65d7\u8868\u793a\u8fd9\u4e5f\u5728\u9884\u6599\u4e4b\u4e2d\u3002\u8003\u8651\u5230\u8be5\u80a1\u76ee\u524d\u7684\u4f30\u503c\u6c34\u5e73\u8f83\u4f4e\uff0c\u82b1\u65d7\u7ed9\u4e88\u6da6\u7535\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0c\u76ee\u6807\u4ef7\u683c\u4e3a27\u6e2f\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255550695", "pub_date": "2024-10-23 15:53:42"}, {"id": 255550105, "title": "\u519c\u4e1a\u519c\u6751\u90e8\uff1a\u56fd\u519c\u4ea7\u54c1\u6279\u53d1\u5e02\u573a\u732a\u8089\u5e73\u5747\u4ef7\u683c\u4e3a24.70\u5143/\u516c\u65a4 \u8f83\u6628\u65e5\u53470.5%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u519c\u4e1a\u519c\u6751\u90e8\u76d1\u6d4b\uff0c10\u670823\u65e5\u201c\u519c\u4ea7\u54c1\u6279\u53d1\u4ef7\u683c200\u6307\u6570\u201d\u4e3a127.80\uff0c\u6bd4\u6628\u5929\u4e0b\u964d0.07\u4e2a\u70b9\uff0c\u201c\u83dc\u7bee\u5b50\u201d\u4ea7\u54c1\u6279\u53d1\u4ef7\u683c\u6307\u6570\u4e3a129.97\uff0c\u6bd4\u6628\u5929\u4e0b\u964d0.13\u4e2a\u70b9\u3002\u622a\u81f3\u4eca\u65e514:00\u65f6\uff0c\u5168\u56fd\u519c\u4ea7\u54c1\u6279\u53d1\u5e02\u573a\u732a\u8089\u5e73\u5747\u4ef7\u683c\u4e3a24.70\u5143/\u516c\u65a4\uff0c\u6bd4\u6628\u5929\u4e0a\u53470.5%\uff1b\u725b\u808961.19\u5143/\u516c\u65a4\uff0c\u6bd4\u6628\u5929\u4e0a\u53470.5%\uff1b\u7f8a\u808958.69\u5143/\u516c\u65a4\uff0c\u6bd4\u6628\u5929\u4e0a\u53470.1%\uff1b\u9e21\u86cb10.52\u5143/\u516c\u65a4\uff0c\u6bd4\u6628\u5929\u4e0b\u964d0.7%\uff1b\u767d\u6761\u9e2117.95\u5143/\u516c\u65a4\uff0c\u6bd4\u6628\u5929\u4e0a\u53470.4%\u3002\u91cd\u70b9\u76d1\u6d4b\u768428\u79cd\u852c\u83dc\u5e73\u5747\u4ef7\u683c\u4e3a5.52\u5143/\u516c\u65a4\uff0c\u6bd4\u6628\u5929\u4e0b\u964d1.8%\uff1b\u91cd\u70b9\u76d1\u6d4b\u76846\u79cd\u6c34\u679c\u5e73\u5747\u4ef7\u683c\u4e3a7.18\u5143/\u516c\u65a4\uff0c\u6bd4\u6628\u5929\u4e0b\u964d2.0%\u3002\u9cab\u9c7c20.65\u5143/\u516c\u65a4\uff0c\u6bd4\u6628\u5929\u4e0b\u964d0.4%\uff1b\u9ca4\u9c7c14.21\u5143/\u516c\u65a4\uff0c\u6bd4\u6628\u5929\u4e0b\u964d0.8%\uff1b\u767d\u9ca2\u9c7c10.05\u5143/\u516c\u65a4\uff0c\u6bd4\u6628\u5929\u4e0b\u964d1.0%\uff1b\u5927\u5e26\u9c7c39.98\u5143/\u516c\u65a4\uff0c\u6bd4\u6628\u5929\u4e0b\u964d3.5%\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255550105", "pub_date": "2024-10-23 15:48:33"}, {"id": 255549404, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5149\u5927\u8bc1\u5238\u7ef4\u6301\u4e2d\u77f3\u5316\u70bc\u5316\u5de5\u7a0b(02386)\u4e70\u5165\u8bc4\u7ea7 \u6307\u5176\u6df1\u5316\u5f00\u62d3\u6d77\u5185\u5916\u5e02\u573a \u4e1a\u7ee9\u6709\u671b\u5feb\u901f\u589e\u957f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5149\u5927\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u4e2d\u77f3\u5316\u70bc\u5316\u5de5\u7a0b(02386)2024\u5e74\u524d\u4e09\u5b63\u5ea6\u65b0\u7b7e\u8ba2\u5408\u540c\u603b\u503c\u4e3a734.57\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f65.6%\u3002\u622a\u81f32024\u5e749\u670830\u65e5\uff0c\u516c\u53f8\u672a\u5b8c\u6210\u5408\u540c\u91cf\u4e3a1657.73\u4ebf\u5143\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u5206\u884c\u4e1a\u6765\u770b\uff0c2024\u5e74\u524d\u4e09\u5b63\u5ea6\u516c\u53f8\u65b0\u7b7e\u5408\u540c\u6d89\u53ca\u7684\u884c\u4e1a\u5448\u73b0\u591a\u5143\u5316\u8d8b\u52bf\uff0c\u70bc\u6cb9\u3001\u65b0\u578b\u7164\u5316\u5de5\u3001\u50a8\u8fd0\u53ca\u5176\u4ed6\u884c\u4e1a\u7684\u65b0\u7b7e\u5408\u540c\u989d\u5feb\u901f\u589e\u957f\uff0c\u5206\u522b\u540c\u6bd4+95%\u3001+1850%\u3001+256%\uff0c\u800c\u77f3\u6cb9\u5316\u5de5\u884c\u4e1a\u65b0\u7b7e\u5408\u540c\u989d\u540c\u6bd4+20%\uff0c\u77f3\u6cb9\u5316\u5de5\u884c\u4e1a\u65b0\u7b7e\u5408\u540c\u5360\u6bd4\u4ece2023\u5e74\u524d\u4e09\u5b63\u5ea6\u768480%\u4e0b\u964d\u81f358%\u30022024\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u4e2d\u56fd\u77f3\u5316\u5185\u90e8\u5408\u540c\u989d\u5360\u6bd4\u4ece2023\u5e74\u524d\u4e09\u5b63\u5ea6\u768430.3%\u5c0f\u5e45\u589e\u81f341.7%\uff0c\u516c\u53f8\u5bf9\u5916\u90e8\u5e02\u573a\u7684\u62d3\u5c55\u9010\u6b65\u7a33\u56fa\u3002\u622a\u81f32024\u5e749\u670830\u65e5\uff0c\u516c\u53f8\u5728\u624b\u8ba2\u5355\u4e3a1658\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f40%\uff0c\u8fbe\u5230\u5386\u53f2\u9ad8\u4f4d\uff0c\u4e3a\u516c\u53f8\u672a\u6765\u4e1a\u52a1\u6301\u7eed\u53d1\u5c55\u63d0\u4f9b\u6709\u529b\u652f\u6491\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u516c\u53f8\u80cc\u9760\u4e2d\u77f3\u5316\u96c6\u56e2\u8d44\u6e90\u4f18\u52bf\uff0c\u6301\u7eed\u5f00\u62d3\u6d77\u5185\u5916\u5e02\u573a\uff0c\u4e1a\u7ee9\u6709\u671b\u8fce\u6765\u5feb\u901f\u589e\u957f\uff0c\u56fd\u4f01\u6539\u9769\u80cc\u666f\u4e0b\u516c\u53f8\u4f4e\u4f30\u503c+\u9ad8\u5206\u7ea2\u4ef7\u503c\u51f8\u663e\u3002\u8be5\u884c\u7ef4\u6301\u516c\u53f8\u76c8\u5229\u9884\u6d4b\uff0c\u9884\u8ba1\u516c\u53f82024-2026\u5e74\u5f52\u6bcd\u51c0\u5229\u6da6\u5206\u522b\u4e3a26.38\u300129.15\u300131.82\u4ebf\u5143\uff0c\u5bf9\u5e94\u7684EPS\u5206\u522b\u4e3a0.60\u30010.66\u30010.72\u5143/\u80a1\uff0c\u7ef4\u6301\u5bf9\u516c\u53f8\u7684\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255549404", "pub_date": "2024-10-23 15:42:31"}]}