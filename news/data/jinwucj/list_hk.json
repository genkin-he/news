{"data": [{"id": 259857648, "title": " \u793c\u6765(LLY)\u62df\u65a5\u8d4430\u4ebf\u7f8e\u5143\u6269\u5927\u7f8e\u56fd\u751f\u4ea7\u57fa\u5730", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u793c\u6765(LLY)\u5c06\u518d\u6295\u8d4430\u4ebf\u7f8e\u5143\u6269\u5927\u5176\u5728\u7f8e\u56fd\u7684\u751f\u4ea7\u57fa\u5730\uff0c\u4ee5\u52a0\u5927\u5176\u91cd\u78c5\u7cd6\u5c3f\u75c5\u548c\u51cf\u80a5\u836f\u7269\u7684\u4ea7\u91cf\u3002<br/><br/>\u636e\u5468\u56db\u7684\u4e00\u4efd\u58f0\u660e\u79f0\uff0c\u6700\u65b0\u6295\u8d44\u662f\u8be5\u516c\u53f8\u603b\u90e8\u6240\u5728\u5730\u5370\u7b2c\u5b89\u7eb3\u5dde\u4ee5\u5916\u6700\u5927\u7684\u4e00\u7b14\u6295\u8d44\uff0c\u5c06\u6269\u5efa\u4f4d\u4e8e\u5a01\u65af\u5eb7\u661f\u5dde\u7684\u65b0\u751f\u4ea7\u5de5\u5382\uff0c\u9884\u8ba1\u660e\u5e74\u5f00\u5de5\u3002\u6b64\u4e3e\u5c06\u6709\u52a9\u4e8e\u6ee1\u8db3\u5bf9Mounjaro\u548cZepbound\u7b49\u6ce8\u5c04\u836f\u7269\u65e5\u76ca\u589e\u957f\u7684\u9700\u6c42\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259857648", "pub_date": "2024-12-06 19:56:38"}, {"id": 259856001, "title": "\u6b27\u5143\u533a\u7b2c\u4e09\u5b63\u5ea6\u5b63\u8c03\u540e\u5c31\u4e1a\u4eba\u6570\u5b63\u7387\u7ec8\u503c0.2% \u9884\u671f0.2% \u524d\u503c0.20%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6b27\u5143\u533a\u7b2c\u4e09\u5b63\u5ea6\u5b63\u8c03\u540e\u5c31\u4e1a\u4eba\u6570\u5b63\u7387\u7ec8\u503c0.2%\uff0c\u9884\u671f0.2%\uff0c\u524d\u503c0.20%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259856001", "pub_date": "2024-12-06 19:47:37"}, {"id": 259854363, "title": "\u6b27\u5143\u533a\u7b2c\u4e09\u5b63\u5ea6GDP\u5e74\u7387\u4fee\u6b63\u503c0.9% \u9884\u671f0.90% \u524d\u503c0.90%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6b27\u5143\u533a\u7b2c\u4e09\u5b63\u5ea6GDP\u5e74\u7387\u4fee\u6b63\u503c0.9%\uff0c\u9884\u671f0.90%\uff0c\u524d\u503c0.90%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259854363", "pub_date": "2024-12-06 19:38:30"}, {"id": 259851648, "title": " \u5370\u5ea6\u592e\u884c\u7ef4\u6301\u57fa\u51c6\u5229\u7387\u57286.5%\u4e0d\u53d8 \u8d85\u9884\u671f\u964d\u51c6", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5370\u5ea6\u592e\u884c\u5ba3\u5e03\uff0c\u7ef4\u6301\u57fa\u51c6\u5229\u7387\u57286.5%\u4e0d\u53d8\uff0c\u7b26\u5408\u5e02\u573a\u9884\u671f\uff1b\u4e0b\u8c03\u5b58\u6b3e\u51c6\u5907\u91d1\u738750\u4e2a\u57fa\u70b9\u81f34%\uff0c\u5e02\u573a\u9884\u671f\u4e3a4.5%\u3002\u5206\u6790\u4eba\u58eb\u79f0\uff0c\u7ecf\u6d4e\u589e\u957f\u627f\u538b\u53e0\u52a0\u901a\u80c0\u98ce\u9669\u4e0a\u5347\uff0c\u4f7f\u5f97\u5370\u5ea6\u592e\u884c\u5728\u5173\u952e\u5229\u7387\u51b3\u5b9a\u4e0a\u6309\u5175\u4e0d\u52a8\uff0c\u5e76\u8fdb\u884c\u8d85\u9884\u671f\u964d\u51c6\u4ee5\u589e\u5f3a\u7ecf\u6d4e\u6d41\u52a8\u6027\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259851648", "pub_date": "2024-12-06 19:23:57"}, {"id": 259850388, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u7f8e\u94f6\u8bc1\u5238\u5347\u7279\u65af\u62c9(TSLA)\u76ee\u6807\u4ef7\u81f3400\u7f8e\u5143 \u6599\u5373\u5c06\u63a8\u51fa\u7684\u4f4e\u4ef7\u7535\u8f66\u662f\u516c\u53f8\u589e\u957f\u7684\u91cd\u8981\u63a8\u52a8\u529b", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u94f6\u884c\u8bc1\u5238\u9996\u5e2d\u5206\u6790\u5e08\u7ea6\u7ff0\u00b7\u58a8\u83f2\u5728\u8bbf\u95ee\u4e86\u5965\u65af\u6c40\u7684Giga\u5de5\u5382\u540e\uff0c\u4e0a\u8c03\u4e86\u5bf9\u7279\u65af\u62c9(TSLA)\u7684\u76ee\u6807\u4ef7\u81f3400\u7f8e\u5143\uff0c\u5e76\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002\u58a8\u83f2\u5728\u62a5\u544a\u4e2d\u8868\u793a\uff0c\u6b64\u6b21\u8bbf\u95ee\u589e\u5f3a\u4e86\u4ed6\u5bf9\u7279\u65af\u62c9\u7684\u4fe1\u5fc3\uff0c\u9884\u8ba1\u516c\u53f8\u5c06\u901a\u8fc7\u5176\u6838\u5fc3\u7535\u52a8\u6c7d\u8f66\u4e1a\u52a1\u3001\u81ea\u52a8\u9a7e\u9a76\u51fa\u79df\u8f66\u4ea7\u54c1\u7684\u63a8\u51fa\u4ee5\u53ca\u5bf9Optimus\u7684\u957f\u671f\u6295\u8d44\uff0c\u57282025\u5e74\u4ee5\u540e\u5b9e\u73b0\u589e\u957f\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u7279\u65af\u62c9\u5373\u5c06\u63a8\u51fa\u7684\u4f4e\u6210\u672c\u7535\u52a8\u6c7d\u8f66\u5c06\u662f\u516c\u53f8\u589e\u957f\u7684\u7b2c\u4e00\u4e2a\u91cd\u8981\u63a8\u52a8\u529b\uff0c\u9884\u8ba1\u8fd9\u6b3e\u552e\u4ef7\u4f4e\u4e8e30,000\u7f8e\u5143\u7684\u7535\u52a8\u6c7d\u8f66\u5c06\u4e8e2025\u5e74\u4e0a\u534a\u5e74\u4e0a\u5e02\u3002\u4ed6\u8ba4\u4e3a\uff0c\u65b0\u8f66\u5c06\u6269\u5927\u7279\u65af\u62c9\u7684\u603b\u6f5c\u5728\u5e02\u573a(TAM)\uff0c\u5f97\u76ca\u4e8e\u6210\u672c\u964d\u4f4e\u7684\u63aa\u65bd\uff0c\u5982\u51cf\u5c11\u5185\u5bb9\u3001\u63d0\u9ad8\u53d1\u52a8\u673a\u6548\u7387\u548c\u6539\u53d8\u5185\u9970\u3002\u58a8\u83f2\u8fd8\u9884\u8ba1\uff0c\u4f4e\u6210\u672c\u8f66\u578b\u4e0d\u4f1a\u662f\u7279\u65af\u62c92025\u5e74\u7684\u552f\u4e00\u65b0\u8f66\u578b\u3002<br/><br/>\u7f8e\u56fd\u94f6\u884c\u56e2\u961f\u5bf9\u7279\u65af\u62c9\u7684FSD(\u5168\u81ea\u52a8\u9a7e\u9a76)\u8f6f\u4ef6\u6d4b\u8bd5\u9636\u6bb5\u8868\u793a\u4e50\u89c2\u3002\u58a8\u83f2\u63cf\u8ff0\u4e86\u4ed6\u4eec\u4e58\u5750\u7684Cybertruck\u548cModel Y\u5728\u590d\u6742\u8def\u51b5\u4e0b\u7684\u8868\u73b0\uff0c\u6307\u51fa\u4eba\u7c7b\u9a7e\u9a76\u5458\u6240\u9700\u7684\u6700\u4f4e\u9650\u5ea6\u5e72\u9884\u663e\u793a\u7279\u65af\u62c9\u7684\u81ea\u52a8\u9a7e\u9a76\u51fa\u79df\u8f66\u4e1a\u52a1\u5373\u5c06\u5728\u76d1\u7763\u4e0b\u542f\u52a8\u3002\u8f6c\u5411\u57fa\u4e8e\u8f6f\u4ef6\u7684\u4ea7\u54c1\u5982FSD\u4e5f\u5c06\u63d0\u9ad8\u5229\u6da6\u7387\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259850388", "pub_date": "2024-12-06 19:16:42"}, {"id": 259848419, "title": "\u6587\u8fdc\u77e5\u884c(WRD)\u76d8\u524d\u6da8\u8d856% \u4e0eUber\u5408\u4f5c\u7684\u81ea\u52a8\u9a7e\u9a76\u51fa\u884c\u670d\u52a1\u843d\u5730\u963f\u8054\u914b\u9996\u90fd\u963f\u5e03\u624e\u6bd4", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6587\u8fdc\u77e5\u884c(WRD)\u76d8\u524d\u6da8\u8d856%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a516.99\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u636e\u6587\u8fdc\u77e5\u884cWeRide\u5b98\u5fae\uff0c\u6587\u8fdc\u77e5\u884cWeRide\u4e0e\u79fb\u52a8\u51fa\u884c\u53ca\u914d\u9001\u79d1\u6280\u516c\u53f8\u4f18\u6b65Uber\u5ba3\u5e03\uff0c\u53cc\u65b9\u5408\u4f5c\u7684\u81ea\u52a8\u9a7e\u9a76\u51fa\u884c\u670d\u52a1\u6b63\u5f0f\u843d\u5730\u963f\u8054\u914b\u9996\u90fd\u963f\u5e03\u624e\u6bd4\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259848419", "pub_date": "2024-12-06 19:05:32"}, {"id": 259845571, "title": "\u4e9a\u9a6c\u900a(AMZN)\u5728\u610f\u5927\u5229\u6210\u529f\u6d4b\u8bd5\u65e0\u4eba\u673a\u9001\u8d27\u670d\u52a1", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e9a\u9a6c\u900a(AMZN)\u8868\u793a\uff0c\u5df2\u7ecf\u5728\u610f\u5927\u5229\u6210\u529f\u5b8c\u6210\u4e86\u4f7f\u7528\u65e0\u4eba\u673a\u9001\u8d27\u7684\u521d\u6b65\u6d4b\u8bd5\uff0c\u8fd9\u662f\u8fd9\u5bb6\u7535\u5546\u5de8\u5934\u8ba1\u5212\u5f15\u5165\u8fd9\u9879\u670d\u52a1\u7684\u7b2c\u4e00\u4e2a\u6b27\u6d32\u56fd\u5bb6\u3002\u4e9a\u9a6c\u900a\u8868\u793a\uff1a\u201c\u516c\u53f8\u5c06\u7ee7\u7eed\u4e0e\u610f\u5927\u5229\u5f53\u5c40\u5408\u4f5c\uff0c\u4ee5\u6ee1\u8db3\u660e\u5e74\u63a8\u51fa\u8fd9\u9879\u670d\u52a1\u6240\u9700\u7684\u6240\u6709\u8981\u6c42\u3002\u201d<br/><br/>\u4e9a\u9a6c\u900a\u5728\u610f\u5927\u5229\u7684\u6d4b\u8bd5\u58f0\u660e\u4e2d\u79f0\uff0c2024\u5e7412\u67084\u65e5\uff0c\u4e9a\u9a6c\u900a\u9001\u8d27\u65e0\u4eba\u673a\u9996\u6b21\u5728\u610f\u5927\u5229\u98de\u884c\u3002\u8fd9\u6b21\u8bd5\u98de\u4f7f\u7528\u65b0\u7684MK-30\u65e0\u4eba\u673a\uff0c\u8fd9\u662f\u4e00\u79cd\u9ad8\u5ea6\u81ea\u52a8\u5316\u7684\u65e0\u4eba\u673a\u7cfb\u7edf\uff0c\u4f7f\u7528\u4e86\u884c\u4e1a\u9886\u5148\u7684\u4e9a\u9a6c\u900a\u8ba1\u7b97\u673a\u89c6\u89c9\u7a0b\u5e8f\uff0c\u8fd9\u4f7f\u5f97\u65e0\u4eba\u673a\u80fd\u591f\u5b89\u5168\u5730\u8fdc\u79bb\u969c\u788d\u7269\uff0c\u786e\u4fdd\u4eba\u5458\u3001\u52a8\u7269\u548c\u8d22\u4ea7\u7684\u5b89\u5168\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259845571", "pub_date": "2024-12-06 18:49:37"}, {"id": 259843093, "title": "\u82f1\u4f1f\u8fbe(NVDA)Rubin\u6709\u671b\u63d0\u524d\u534a\u5e74\u95ee\u4e16", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6709\u5a92\u4f53\u63f4\u5f15\u77e5\u60c5\u4eba\u58eb\u900f\u9732\u7684\u6d88\u606f\u62a5\u9053\u79f0\uff0c\u5168\u7403AI\u884c\u4e1a\u65e0\u6bd4\u671f\u5f85\u7684\u82f1\u4f1f\u8fbe(NVDA)\u4e0b\u4e00\u4ee3AI GPU\u67b6\u6784\u2014\u2014\u201cRubin\u201d\u67b6\u6784\uff0c\u53ef\u80fd\u5c06\u63d0\u524d\u516d\u4e2a\u6708\uff0c\u53732025\u5e74\u4e0b\u534a\u5e74\u6b63\u5f0f\u53d1\u5e03\u3002\u867d\u7136Blackwell\u67b6\u6784AI GPU\u4ecd\u672a\u5927\u89c4\u6a21\u53d1\u8d27\u4e14\u88ab\u7206\u51fa\u9762\u4e34\u6563\u70ed\u95ee\u9898\uff0c\u4f46\u82f1\u4f1f\u8fbe\u4f3c\u4e4e\u575a\u5b9a\u52a0\u901f\u5176AI GPU\u53d1\u5c55\u8def\u7ebf\u56fe\uff0c\u9762\u5bf9AMD\u3001\u4e9a\u9a6c\u900a\u4ee5\u53ca\u535a\u901a\u7b49AI\u82af\u7247\u7ade\u4e89\u5bf9\u624b\u53d1\u8d77\u7684\u731b\u70c8\u653b\u52bf\uff0c\u8fd9\u5bb6\u201c\u7eff\u8272\u5de8\u4eba\u201d\u8bd5\u56fe\u5f3a\u5316\u5b83\u5728\u6570\u636e\u4e2d\u5fc3AI\u82af\u7247\u5e02\u573a\u7684\u7edd\u5bf9\u4e3b\u5bfc\u5730\u4f4d\u3002\u82f1\u4f1f\u8fbe\u5f53\u524d\u5728\u8be5\u5e02\u573a\u582a\u79f0\u201c\u5784\u65ad\u201d\uff0c\u5360\u636e80%-90%\u4efd\u989d\u3002<br/><br/>\u6839\u636e\u4ea7\u4e1a\u94fe\u77e5\u60c5\u4eba\u58eb\u900f\u9732\u7684\u6d88\u606f\uff0c\u82f1\u4f1f\u8fbeRubin\u67b6\u6784\u7684\u4ea7\u54c1\u7ebf\u539f\u5b9a\u4e8e2026\u5e74\u4e0a\u534a\u5e74\u63a8\u51fa\uff0c\u73b0\u5df2\u8981\u6c42\u4f9b\u5e94\u94fe\u5f00\u542f\u63d0\u524d\u6d4b\u8bd5\u5de5\u4f5c\uff0c\u529b\u4e89\u63d0\u524d\u81f32025\u5e74\u4e0b\u534a\u5e74\u6b63\u5f0f\u63a8\u51fa\u3002\u7531\u4e8eOpenAI\u3001Anthropic\u3001xAI\u4ee5\u53caMeta\u7b49\u4eba\u5de5\u667a\u80fd\u3001\u4e91\u8ba1\u7b97\u4ee5\u53ca\u4e92\u8054\u7f51\u5927\u5382\u4eec\u5bf9\u4e8eAI\u8bad\u7ec3/\u63a8\u7406\u7b97\u529b\u51e0\u4e4e\u65e0\u6b62\u5883\u7684\u201c\u4e95\u55b7\u5f0f\u9700\u6c42\u201d\uff0c\u8feb\u4f7f\u82f1\u4f1f\u8fbe\u4ee5\u66f4\u5feb\u901f\u5ea6\u63a8\u51fa\u6027\u80fd\u66f4\u9ad8\u3001\u5b58\u50a8\u5bb9\u91cf\u66f4\u5e9e\u5927\u3001\u63a8\u7406\u6548\u7387\u66f4\u5f3a\u5927\u4e14\u66f4\u52a0\u8282\u80fd\u7684\u4e0b\u4e00\u4ee3AI GPU\u7684\u7814\u53d1\u8fdb\u7a0b\u3002\u8fd9\u5bb6\u7eff\u8272\u5de8\u4eba\u8bd5\u56fe\u52a0\u5feb\u4e0d\u540cAI GPU\u67b6\u6784\u4e4b\u95f4\u7684\u66f4\u65b0\u8282\u594f\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259843093", "pub_date": "2024-12-06 18:35:50"}, {"id": 259841157, "title": "\u95fd\u4e1c\u7ea2(ORIS)\u76d8\u524d\u8dcc\u8d8581% \u6628\u65e5\u6536\u6da8\u903e600%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u95fd\u4e1c\u7ea2(ORIS)\u76d8\u524d\u8dcc\u8d8581%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a510.5\u7f8e\u5143\u3002\u9700\u8981\u6ce8\u610f\u7684\u662f\uff0c\u8be5\u80a1\u6628\u65e5\u6536\u6da8\u903e600%\u3002<br/><br/>\u636e\u6089\uff0c\u4eca\u5e743\u6708\uff0c\u95fd\u4e1c\u7ea2\u8ba1\u5212\u4ee5\u6bcf\u80a14\u7f8e\u5143\u7684\u4ef7\u683c\u53d1\u884c200\u4e07\u80a1\u80a1\u7968\uff0c\u7b79\u96c6800\u4e07\u7f8e\u5143\u8d44\u91d1\u3002\u8be5\u516c\u53f8\u6b64\u524d\u66fe\u7533\u8bf7\u4ee5\u76f8\u540c\u4ef7\u683c\u53d1\u884c300\u4e07\u80a1\u80a1\u7968\u3002<br/><br/>\u8d44\u6599\u663e\u793a\uff0c\u8be5\u516c\u53f8\u5728\u4e2d\u56fd\u798f\u5efa\u7701\u79cd\u690d\u3001\u52a0\u5de5\u548c\u7cbe\u70bc\u767d\u8336\u4e0e\u7ea2\u8336\u3002\u95fd\u4e1c\u7ea2\u96c6\u56e2\u5c06\u5176\u8336\u53f6\u9500\u552e\u7ed9\u4e2d\u56fd\u7684\u5206\u9500\u5546\u548c\u7ec8\u7aef\u6d88\u8d39\u8005\u3002\u95fd\u4e1c\u7ea2\u7ecf\u8425\u7684\u8336\u56ed\u4f4d\u4e8e\u798f\u5efa\u7701\u5b81\u5fb7\u5e02\u62d3\u8363\u53bf\uff0c\u622a\u81f3\u76ee\u524d\uff0c\u516c\u53f8\u5df2\u7ecf\u4e0e\u798f\u5efa\u7701\u7ea6721.2\u4e07\u5e73\u65b9\u7c73\u7684\u8336\u56ed\u7b7e\u8ba2\u4e86\u5408\u540c\u7ba1\u7406\u548c\u79cd\u690d\u6743\u534f\u8bae\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259841157", "pub_date": "2024-12-06 18:24:43"}, {"id": 259839757, "title": "Ulta\u7f8e\u5bb9(ULTA)\u76d8\u524d\u6da8\u8d8511% \u4e09\u5b63\u5ea6\u4e1a\u7ee9\u8d85\u51fa\u5e02\u573a\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | Ulta\u7f8e\u5bb9(ULTA)\u76d8\u524d\u6da8\u8d8511%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a5436.8\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u516c\u53f8\u516c\u5e03\u7b2c\u4e09\u5b63\u5ea6\u4e1a\u7ee9\uff0c\u8425\u6536\u540c\u6bd4\u589e\u957f\u4e861.7%\uff0c\u8fbe\u5230\u4e8625.3\u4ebf\u7f8e\u5143\uff0c\u8d85\u51fa\u4e86\u5e02\u573a\u9884\u671f\uff1b\u516c\u53f8\u7684\u51c0\u5229\u6da6\u4e3a2.4\u4ebf\u7f8e\u5143\uff0c\u8f83\u53bb\u5e74\u540c\u671f\u4e0b\u964d\u4e86\u7ea63%\uff1b\u6bcf\u80a1\u6536\u76ca\u4e3a5.14\u7f8e\u5143\uff0c\u8d85\u8fc7\u4e86\u5206\u6790\u5e08\u9884\u671f\u76844.53\u7f8e\u5143\u3002\u540c\u5e97\u9500\u552e\u589e\u957f\u4e860.6%\uff0c\u800c\u5e02\u573a\u9884\u8ba1\u4e0b\u964d1.9%\u3002<br/><br/>\u5c55\u671b\u672a\u6765\uff0cUlta Beauty\u9884\u8ba1\u5168\u5e74\u7684\u9500\u552e\u989d\u5c06\u5728111\u4ebf\u81f3112\u4ebf\u7f8e\u5143\u4e4b\u95f4\uff0c\u7565\u9ad8\u4e8e\u4e4b\u524d\u7684\u9884\u6d4b\u8303\u56f4110\u4ebf\u81f3112\u4ebf\u7f8e\u5143\uff1b\u8c03\u6574\u540e\u7684\u6bcf\u80a1\u6536\u76ca\u9884\u8ba1\u572823.2\u81f323.75\u7f8e\u5143\u4e4b\u95f4\uff0c\u4e4b\u524d\u7684\u9884\u6d4b\u662f22.6\u81f323.5\u7f8e\u5143\u3002\u5bf9\u4e8e\u540c\u5e97\u9500\u552e\uff0c\u516c\u53f8\u9884\u8ba1\u4f1a\u4e0b\u964d1%\u6216\u4fdd\u6301\u4e0d\u53d8\uff0c\u800c\u4e4b\u524d\u7684\u9884\u6d4b\u662f\u4e0b\u964d2%\u6216\u4fdd\u6301\u4e0d\u53d8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259839757", "pub_date": "2024-12-06 18:16:38"}]}