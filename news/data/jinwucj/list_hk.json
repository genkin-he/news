e50\u89c2\uff0c\u5206\u5316\u5c06\u6301\u7eed\u3002\u65b0\u80fd\u6e90\u6c7d\u8f66\u666f\u6c14\u4e0a\u5347\u63a8\u52a8\u9502\u7535\u6c60\u677f\u5757\u4e1a\u7ee9\u6539\u5584\uff0c\u7ef4\u6301\u884c\u4e1a\u201c\u5f3a\u4e8e\u5927\u5e02\u201d\u6295\u8d44\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259632045", "pub_date": "2024-12-05 10:38:13"}, {"id": 259631643, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u4ebf\u534e\u901a(02402)\u65e9\u76d8\u9006\u5e02\u534725% \u999610\u4e2a\u6708\u71c3\u6599\u7535\u6c60\u7cfb\u7edf\u7d2f\u8ba1\u88c5\u673a\u91cf\u5c45\u9996", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4ebf\u534e\u901a(02402)\u65e9\u76d8\u9006\u5e02\u51b2\u9ad8\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da825%\uff0c\u62a523.3\u6e2f\u5143\uff0c\u6210\u4ea4\u989d4171.2\u4e07\u6e2f\u5143\u3002<br/><br/>\u56fd\u91d1\u8bc1\u5238\u7684\u62a5\u544a\u6307\u51fa\uff0c2024\u5e7410\u6708\uff0c\u71c3\u6599\u7535\u6c60\u7cfb\u7edf\u7684\u5b89\u88c5\u5bb9\u91cf\u8fbe\u5230\u4e86114.9\u5146\u74e6\uff08MW\uff09\uff0c\u76f8\u8f83\u4e8e\u53bb\u5e74\u540c\u671f\u589e\u957f\u4e86195.6%\uff0c\u4e3b\u8981\u4e3a\u5546\u7528\u8f66\uff0c\u5176\u4e2d\u5305\u542b6\u8f86\u4e58\u7528\u8f66\u3002\u5728\u4f17\u591a\u4f01\u4e1a\u4e2d\uff0c\u4ebf\u534e\u901a\u7684\u8868\u73b0\u5c24\u4e3a\u7a81\u51fa\uff0c\u5728\u535510\u67081\u4e2a\u6708\u548c\u5e74\u521d\u81f310\u6708\u7684\u7d2f\u8ba1\u88c5\u673a\u91cf\u4e0a\u5747\u5360\u636e\u9996\u4f4d\u3002\u5177\u4f53\u6765\u8bf4\uff0c\u4ebf\u534e\u901a\u572810\u6708\u4efd\u7684\u88c5\u673a\u91cf\u4e3a65MW\uff0c\u5360\u6bd457%\uff1b\u800c\u57281\u6708\u81f310\u6708\u671f\u95f4\uff0c\u5176\u7d2f\u8ba1\u88c5\u673a\u91cf\u66f4\u662f\u8fbe\u5230\u4e86182MW\uff0c\u5360\u6bd429%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259631643", "pub_date": "2024-12-05 10:33:44"}, {"id": 259630381, "title": "\u5185\u623f\u80a1\u5168\u7ebf\u4e0b\u884c \u8d8a\u79c0\u5730\u4ea7(00123)\u8dcc3.33% \u767e\u5f3a\u623f\u4f01\u9500\u552e\u73af\u6bd4\u