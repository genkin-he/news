02\u573a\u4e0a\u7684\u4ea4\u6613\u7ed3\u679c\u663e\u793a\uff0c11\u6708FOMC\u4f1a\u8bae\u4e0a\u964d\u606f0.25%\u7684\u6982\u7387\u5347\u81f379%\uff0c\u540c\u65f6\u7ef4\u6301\u4e0d\u53d8\u7684\u6982\u7387\u4e3a21%\u3002\u53e6\u4e00\u65b9\u9762\uff0c\u4e2d\u4e1c\u5c40\u52bf\u4f9d\u7136\u7d27\u5f20\uff0c\u5e02\u573a\u5173\u6ce8\u4ee5\u8272\u5217\u4f55\u65f6\u4f1a\u5bf9\u4f0a\u6717\u5b9e\u65bd\u62a5\u590d\u884c\u52a8\uff0c\u4ee5\u53ca\u62a5\u590d\u7684\u7a0b\u5ea6\u3002\u540c\u65f6\uff0c\u6295\u8d44\u8005\u4e5f\u5728\u5173\u6ce8\u4eca\u665a\u5373\u5c06\u516c\u5e03\u7684\u7f8e\u56fd\u6d88\u8d39\u8005\u7269\u4ef7\u6307\u6570\uff08CPI\uff09\u3002\u4e0d\u8fc7\uff0c\u9664\u975e\u8be5\u6570\u636e\u5927\u5e45\u4f4e\u4e8e\u9884\u671f\uff0c\u5426\u5219\u4e0d\u592a\u53ef\u80fd\u6539\u53d8\u7f8e\u5143\u5f3a\u52bf\u7684\u8d70\u52bf\u3002<br/><br/>\u6280\u672f\u65b9\u9762\u6765\u770b\uff0c\u7f8e\u5143\u5151\u65e5\u5143\u6c47\u7387\u5728\u7a81\u7834\u4e86\u6b64\u524d140-145\u65e5\u5143\u533a\u95f4\u7684\u4e0a\u9650\u540e\uff0c\u6765\u52308\u6708\u4efd\u9ad8\u70b9\u7684149\u65e5\u5143\u4e00\u7ebf\u7684\u963b\u529b\u9644\u8fd1\u3002\u8003\u8651\u5230\u7f8e\u56fd\u5927\u9009\u5373\u5c06\u5230\u6765\uff0c\u5916\u6c47\u5e02\u573a\u4e0a\u663e\u793a\u51fa\u8f83\u5f3a\u7684\u4e0d\u786e\u5b9a\u6027\u3002\u4ea4\u6613\u7b56\u7565\u4e0a\u5efa\u8bae\u79bb\u573a\u89c2\u671b\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254524714", "pub_date": "2024-10-10 14:45:29"}, {"id": 254524606, "title": "\u519c\u4e1a\u519c\u6751\u90e8\uff1a\u5168\u56fd\u519c\u4ea7\u54c1\u6279\u53d1\u5e02\u573a\u732a\u8089\u5e73\u5747\u4ef7\u683c\u4e3a25.04\u5143/\u516c\u65a4 \u8f83\u6628\u65e5\u53470.8%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u519c\u4e1a\u519c\u6751\u90e8\u76d1\u6d4b\uff0c10\u670810\u65e5\u201c\u519c\u4ea7\u54c1\u6279\u53d1\u4ef7\u683c200\u6307\u6570\u201d\u4e3a133.29\uff0c\u6bd4\u6628\u5929\u4e0b\u964d0.31\u4e2a\u70b9\uff0c\u201c\u83dc\u7bee\u5b50\u201d\u4ea7\u54c1\u6279\u53d1\u4e