91d1\u4ef7\u4e0b\u6ed1\uff0c\u7ebd\u7ea6\u671f\u91d1\u6bcf\u76ce\u53f8\u6536\u62a52648.4\u7f8e\u5143\uff0c\u8dcc1%\u3002</p><p>\u7f8e\u56fd\u4e0a\u5468\u9996\u6b21\u7533\u8bf7\u5931\u4e1a\u6551\u6d4e\u4eba\u6570\u589e\u5e45\u8d85\u51fa\u9884\u671f\u3002\u6295\u8d44\u8005\u5c06\u5173\u6ce8\u7126\u70b9\u8f6c\u5411\u5468\u4e94\u768411\u6708\u975e\u519c\u5c31\u4e1a\u6570\u636e\uff0c\u4ee5\u5173\u6ce8\u7f8e\u8054\u50a8\u964d\u606f\u524d\u666f\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259771500", "pub_date": "2024-12-06 08:52:58"}, {"id": 259771548, "title": "\u5e02\u573a\u5173\u6ce8\u660e\u5e74\u4f9b\u5e94\u524d\u666f \u56fd\u9645\u6cb9\u4ef7\u7eed\u8dcc \u7ebd\u7ea6\u671f\u6cb9\u8dcc0.35%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u56fd\u9645\u6cb9\u4ef7\u7eed\u8dcc\uff0c\u7ebd\u7ea6\u671f\u6cb9\u6bcf\u6876\u6536\u62a568.3\u7f8e\u5143\uff0c\u8dcc0.35%\u3002\u4f26\u6566\u5e03\u4f26\u7279\u671f\u6cb9\u6bcf\u6876\u6536\u62a572.09\u7f8e\u5143\uff0c\u8dcc0.3%\u3002</p><p>OPEC+\u5c06\u589e\u4ea7\u8ba1\u5212\u63a8\u8fdf\u81f3\u660e\u5e744\u6708\uff0c\u5e76\u5c06\u5b8c\u5168\u7ed3\u675f\u51cf\u4ea7\u63aa\u65bd\u7684\u65f6\u95f4\u8c03\u6574\u4e3a2026\u5e74\u5e95\uff0c\u5e02\u573a\u5173\u6ce8\u660e\u5e74\u4f9b\u5e94\u524d\u666f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259771548", "pub_date": "2024-12-06 08:53:11"}, {"id": 259771592, "title": "\u3010\u9694\u591c\u5e02\u573a\u56de\u987e\u3011\u6628\u65e5\u6e2f\u80a1\u9707\u8361\u6536\u8dcc \u7f8e\u80a1\u6307\u6570\u4ea6\u5c0f\u5e45\u56de\u8c03", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u80a1\u4e09\u5927\u6307\u6570\u5c0f\u5e45\u6536\u8dcc\u3002\u7f8e\u56fd\u4e0a\u661f\u671f\u65b0\u7533\u9886\u5931\u4e1a\u6551\u6d4e\u4eba\u6570\u589e\u81f322.4\u4e07\u4eba\uff0c\u591a\u4e8e\u9884\u671f\u3002\u5e02\u573a\u89c2\u671b\u5468\u4e94\u516c\u5e03\u768411\u6708\u975e\u519c\u4e1a\u5c31\u4e1a\u6570\u636e\uff0c\u9884\u6599\u975e\u519c\u4e1a\u65b0\u589e\u804c\u4f4d20\u4e07\u4e2a\uff0c\u8fdc\u591a\u4e8e10\u6708\u76841.2\u4e07\u4e2a\u3002<br/><br/>\u56fd\u5185\u65b9\u9762\uff0cA\u80a1\u5c0f\u5e45\u6536\u6da8\uff0c\u6caa\u6df1\u4e24\u5e02\u5168\u5929\u6210\u4ea4\u989d1.5\u4e07\u4ebf\uff0c\u8f83\u4e0a\u4e2a\u4ea4\u6613\u65e5\u7f29\u91cf1645\u4ebf\u3002\u4e2a\u80a1\u6da8\u591a\u8dcc\u5c11\uff0c\u6e38\u620f\u3001\u6559\u80b2\u7b49\u677f\u5757\u6da8\u5e45\u5c45\u524d\u3002\u56fd\u5f00\u8bc1\u5238\u8868\u793a\uff0c\u77ed\u671f\u800c\u8a00\uff0c\u7a33\u5b57\u5f53\u5148\u3001\u7a33\u4e2d\u6c42\u8fdb\u800c\u975e\u5927\u6c34\u6f2b\u704c\u662f\u4f18\u5148\u9009\u62e9\uff0c\u5404\u65b9\u594b\u696b\u7b03\u884c\u624d\u80fd\u4ee5\u65f6\u95f4\u6362\u7a7a\u95f4\uff0c\u4e3a\u8f6c\u578b\u4e89\u53d6\u66f4\u591a\u673a\u4f1a\u3002\u4e2d\u957f\u671f\u6765\u770b\uff0c\u5219\u9700\u8981\u5c06\u6df1\u5316\u6539\u9769\u4e0e\u52a0\u901f\u8f6c\u578b\u843d\u5b9e\u5230\u4f4d\u3002<br/><br/>\u6e2f\u80a1\u5219\u9707\u8361\u53d7\u538b\uff0c\u6d77\u901a\u56fd\u9645\u8868\u793a\uff0c\u4ece\u4f30\u503c\u770b\uff0c\u6e2f\u80a1\u4f30\u503c\u5df2\u964d\u81f3\u5386\u53f2\u8f83\u4f4e\u4f4d\u7f6e\uff0c\u56fd\u9645\u5bf9\u6bd4\u89c6\u89d2\u4e0b\u6e2f\u80a1\u4f30\u503c\u4e5f\u5904\u4e8e\u4f4e\u4f4d\u3002\u4ece\u6210\u4ea4\u989d\u770b\uff0c\u56fd\u5e86\u8282\u540e\u6e2f\u80a1\u6210\u4ea4\u91cf\u660e\u663e\u840e\u7f29\uff0c\u6e2f\u80a1/A\u80a1\u7684\u6210\u4ea4\u7f29\u91cf\u5e45\u5ea6\u663e\u7740\u3002\u5f80\u540e\u770b\uff0c\u968f\u7740\u589e\u91cf\u653f\u7b56\u53d1\u529b\u52a9\u529b\u56fd\u5185\u57fa\u672c\u9762\u4fee\u590d\uff0c\u6e2f\u80a1\u6709\u8f83\u5927\u4e0a\u884c\u7a7a\u95f4\u3002<br/><br/>1\u3001\u6628\u65e5\u6caa\u6df1\u6e2f\uff1a<br/><br/>\u6caa\u6df1\u80a1\u5e02\uff1a\u5468\u56db\uff0c\u622a\u81f3\u6536\u76d8\uff0c\u6caa\u6307\u6da80.12%\uff0c\u6df1\u8bc1\u6210\u6307\u6da80.29%\uff0c\u521b\u4e1a\u677f\u6307\u6da80.36%\u3002<br/><br/>\u6e2f\u80a1\uff1a\u5468\u56db\uff0c\u622a\u81f3\u6536\u76d8\uff0c\u6052\u6307\u8dcc0.92%\uff0c\u56fd\u4f01\u6307\u8dcc1%\uff0c\u6052\u79d1\u6307\u8dcc0.77%\u3002<br/><br/>2\u3001\u9694\u591c\u5916\u76d8\uff1a<br/><br/>\u7f8e\u56fd\u80a1\u5e02\uff1a\u5468\u56db\uff0c\u7f8e\u56fd\u4e09\u5927\u80a1\u6307\u5c0f\u5e45\u6536\u8dcc\uff0c\u9053\u6307\u8dcc0.55%\u62a544765.71\u70b9\uff0c\u6807\u666e500\u6307\u6570\u8dcc0.19%\u62a56075.11\u70b9\uff0c\u7eb3\u6307\u8dcc0.18%\u62a519700.26\u70b9\u3002<br/><br/>\u6b27\u6d32\u80a1\u5e02\uff1a\u5468\u56db\uff0c\u6b27\u6d32\u4e09\u5927\u80a1\u6307\u6536\u76d8\u5c0f\u5e45\u4e0a\u6da8\uff0c\u5fb7\u56fdDAX\u6307\u6570\u6da80.63%\u62a520358.8\u70b9\uff0c\u6cd5\u56fdCAC40\u6307\u6570\u6da80.37%\u62a57330.54\u70b9\uff0c\u82f1\u56fd\u5bcc\u65f6100\u6307\u6570\u6da80.16%\u62a58349.38\u70b9\u3002<br/><br/>\u65e5\u97e9\u80a1\u5e02\uff1a\u5468\u56db\uff0c\u65e5\u7ecf225\u6307\u6570\u6da80.3%\u62a539395.60\u70b9\uff0c\u97e9\u56fd\u7efc\u5408\u6307\u6570\u8dcc0.9%\u62a52441.85\u70b9\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259771592", "pub_date": "2024-12-06 08:54:48"}, {"id": 259770989, "title": "\u3010\u6e7e\u533a\u65e9\u53c2\u3011\u9999\u6e2f\u91d1\u7ba1\u5c40\u5c31\u4f18\u5316\u300a\u94f6\u884c\u4e1a\u6761\u4f8b\u300b\u5efa\u8bae\u54a8\u8be2\u516c\u4f17\uff1b\u5e7f\u5dde\u65e5\u5747\u6d3b\u8dc3\u7f51\u7ea6\u8f66\u7ea68.78\u4e07\u8f86", "description": "<p><b>\u4e00\u3001\u5e02\u573a\u8981\u95fb<br/><br/>1\u3001\u9999\u6e2f\u91d1\u7ba1\u5c40\u5c31\u4f18\u5316\u300a\u94f6\u884c\u4e1a\u6761\u4f8b\u300b\u5efa\u8bae\u54a8\u8be2\u516c\u4f17<br/></b><br/>\u9999\u6e2f\u91d1\u7ba1\u5c40\u5c31\u4f18\u5316\u300a\u94f6\u884c\u4e1a\u6761\u4f8b\u300b\u5efa\u8bae\u54a8\u8be2\u516c\u4f17\uff0c2025\u5e741\u670828\u65e5\u7ed3\u675f\u3002\u4eca\u6b21\u300a\u94f6\u884c\u4e1a\u6761\u4f8b\u300b\u7684\u68c0\u8ba8\uff0c\u805a\u71266\u4e2a\u9700\u8981\u9002\u65f6\u4fee\u8ba2\u548c\u4f18\u5316\u7684\u91cd\u70b9\u8303\u7574\uff0c\u91d1\u7ba1\u5c40\u8f83\u65e9\u524d\u5df2\u7ecf\u5c31\u4e24\u9879\u4f18\u5316\u5efa\u8bae\u5b8c\u6210\u516c\u4f17\u8c18\u8be2\uff0c\u5373\u7b80\u5316\u94f6\u884c\u4e09\u7ea7\u5236\u81f3\u4e8c\u7ea7\u5236\uff0c\u53ca\u5bb9\u8bb8\u8ba4\u53ef\u673a\u6784\u4e3a\u9632\u8303\u53ca\u4fa6\u6d4b\u91d1\u878d\u7f6a\u6848\u800c\u4ea4\u6362\u5ba2\u6237\u3001\u8d26\u6237\u53ca\u4ea4\u6613\u7684\u8baf\u606f\u76f8\u5173\u7684\u8c18\u8be2\u3002\u53e6\u5916\uff0c\u91d1\u7ba1\u5c40\u4ea6\u6b63\u5728\u68c0\u8ba8\u91d1\u878d\u7ba1\u7406\u4e13\u5458\u7684\u6267\u6cd5\u6743\u529b\u5e76\u6b63\u8c18\u8be2\u4e1a\u754c\u3002<br/><br/>\u53d1\u51fa\u7684\u54a8\u8be2\u6587\u4ef6\u6db5\u76d6\u53e6\u59163\u4e2a\u300a\u94f6\u884c\u4e1a\u6761\u4f8b\u300b\u68c0\u8ba8\u8303\u7574\u7684\u4f18\u5316\u5efa\u8bae\uff0c\u5305\u62ec\u5efa\u7acb\u6cd5\u5b9a\u5236\u5ea6\u89c4\u7ba1\uff0c\u4e0e\u76d1\u7ba1\u672c\u5730\u6ce8\u518c\u8ba4\u53ef\u673a\u6784\u7684\u6307\u5b9a\u672c\u5730\u6ce8\u518c\u63a7\u6743\u516c\u53f8\uff1b\u7ed9\u4e88\u91d1\u878d\u7ba1\u7406\u4e13\u5458\u5f39\u6027\u8058\u7528\u5177\u76f8\u5173\u6280\u80fd\u7684\u4eba\u58eb\uff0c\u534f\u52a9\u91d1\u878d\u7ba1\u7406\u4e13\u5458\u5c65\u884c\u5176\u5728\u300a\u94f6\u884c\u4e1a\u6761\u4f8b\u300b\u4e0b\u7684\u804c\u80fd\uff1b\u4ee5\u53ca\u5f15\u5165\u591a\u9879\u6280\u672f\u4fee\u8ba2\u3002\u8c18\u8be2\u6587\u4ef6\u4ea6\u5305\u62ec\u300a\u91d1\u878d\u673a\u6784\uff08\u5904\u7f6e\u673a\u5236\uff09\u6761\u4f8b\u300b\u53ca\u300a\u9999\u6e2f\u94f6\u884c\u516c\u4f1a\u6761\u4f8b\u300b\uff0c\u4e24\u9879\u4e0e\u94f6\u884c\u4e1a\u76f8\u5173\u6761\u4f8b\u7684\u4fee\u8ba2\u5efa\u8bae\u3002<br/><b><br/>2\u3001\u7f8e\u9ad8\u6885\u4e2d\u56fd\uff1a\u6fb3\u95e8\u535a\u5f69\u4f01\u4e1a\u660e\u5e74\u7ade\u4e89\u5c06\u66f4\u52a0\u6fc0\u70c8</b><br/><br/>\u7f8e\u9ad8\u6885\u4e2d\u56fd\u8d22\u52a1\u9ad8\u7ea7\u526f\u603b\u88c1\u53ca\u5019\u4efb\u9996\u5e2d\u8d22\u52a1\u5b98\u9648\u9896\u6b23\u5728\u7f8e\u56fd\u51fa\u5e2d\u6d3b\u52a8\u65f6\u8868\u793a\uff0c\u968f\u7740\u667a\u80fd\u8d4c\u53f0\u6280\u672f\u7684\u666e\u53ca\u548c\u9ad8\u6863\u9152\u5e97\u5957\u623f\u4ea7\u54c1\u7684\u63a8\u51fa\uff0c\u6fb3\u95e8\u535a\u5f69\u4f01\u4e1a\u660e\u5e74\u7684\u7ade\u4e89\u5c06\u66f4\u52a0\u6fc0\u70c8\u3002<br/><br/>\u9648\u9896\u6b23\u5f3a\u8c03\uff0c\u516c\u53f8\u5bf9\u5185\u5730\u5ba2\u6237\u9700\u6c42\u7684\u6df1\u5165\u4e86\u89e3\u662f\u4eca\u5e74\u8868\u73b0\u826f\u597d\u7684\u5173\u952e\u56e0\u7d20\u3002\u57fa\u4e8e\u8fd9\u4e9b\u9700\u6c42\uff0c\u516c\u53f8\u5236\u5b9a\u4e86\u4ea7\u54c1\u8bbe\u8ba1\u548c\u9152\u5e97\u8bbe\u65bd\uff0c\u4f7f\u5f97\u5e02\u5360\u7387\u4ece2019\u5e74\u76849.5%\u63d0\u5347\u81f3\u76ee\u524d\u7684\u903e15%\u3002<br/><br/><b>3\u3001\u5e7f\u5dde\u65e5\u5747\u6d3b\u8dc3\u7f51\u7ea6\u8f66\u7ea68.78\u4e07\u8f86</b><br/><br/>\u5e7f\u5dde\u5e02\u4ea4\u901a\u8fd0\u8f93\u90e8\u95e8\u53d1\u5e032024\u5e7410\u6708\u4efd\u5e7f\u5dde\u5e02\u7f51\u7ea6\u8f66\u5e02\u573a\u8fd0\u884c\u7ba1\u7406\u76d1\u6d4b\u4fe1\u606f\u3002\u5e02\u573a\u89c4\u6a21\u65b9\u9762\uff0c\u622a\u81f32024\u5e7410\u670831\u65e5\uff0c\u5728\u7a57\u5f00\u5c55\u7ecf\u8425\u670d\u52a1\u7684\u7f51\u7ea6\u8f66\u5e73\u53f0\u516c\u53f876\u5bb6\uff1b\u6ce8\u518c\u62a5\u5907\u7f51\u7ea6\u8f66\u7ea613.80\u4e07\u8f86\uff0c\u65e5\u5747\u6d3b\u8dc3\u7f51\u7ea6\u8f66\u7ea68.78\u4e07\u8f86\uff1b\u6ce8\u518c\u7f51\u7ea6\u8f66\u9a7e\u9a76\u5458\u7ea616.68\u4e07\u4eba\uff0c\u65e5\u5747\u6d3b\u8dc3\u7f51\u7ea6\u8f66\u9a7e\u9a76\u5458\u7ea68.90\u4e07\u4eba\u3002<br/><br/>\u5e02\u573a\u8fd0\u8425\u65b9\u9762\uff0c2024\u5e7410\u6708\uff0c\u5168\u5e02\u7f51\u7ea6\u8f66\u5355\u8f66\u65e5\u5747\u8ba2\u5355\u91cf\u7ea612.99\u5355\uff0c\u5355\u8f66\u65e5\u5747\u8fd0\u8425\u91cc\u7a0b\u7ea6111.49\u516c\u91cc\uff0c\u5355\u8f66\u65e5\u5747\u8425\u6536\u7ea6363.89\u5143\u3002<br/><br/><b>4\u3001\u6df1\u5733\u524d\u4e09\u5b63\u91d1\u878d\u4e1a\u589e\u52a0\u503c3771.75\u4ebf\u5143<br/></b><br/>\u636e\u6df1\u5733\u7279\u533a\u62a5\uff0c2024\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u6df1\u5733\u91d1\u878d\u4e1a\u589e\u52a0\u503c3771.75\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f2.4%\u3002\u5728\u6700\u65b0\u4e00\u671f\u56fd\u9645\u91d1\u878d\u4e2d\u5fc3\u6307\u6570\uff08GFCI 36\uff09\u6392\u540d\u4e2d\uff0c\u6df1\u5733\u4f4d\u5217\u5168\u7403\u7b2c9\u540d\uff0c\u5176\u4e2d\u91d1\u878d\u79d1\u6280\u4f4d\u5217\u5168\u7403\u7b2c3\u540d\u3002<br/><br/><b>\u4e8c\u3001\u516c\u53f8\u65b0\u95fb</b><br/><br/>1\u3001\u767e\u80dc\u4e2d\u56fd(09987)\u516c\u5e03\uff0c\u5468\u56db\uff085\u65e5\uff09\u4e0e\u9ad8\u76db\u8ba2\u7acb\u80a1\u4efd\u56de\u8d2d\u534f\u8bae\uff0c\u5c06\u900f\u8fc7\u516c\u5f00\u5e02\u573a\u53ca\u8054\u4ea4\u6240\u7684\u8bbe\u65bd\u6839\u636e\u9884\u8bbe\u53c2\u6570\u56de\u8d2d\u6e2f\u80a1\uff1b\u540c\u65e5\u516c\u53f8\u8fd8\u5c31\u5176\u5728\u7f8e\u4e0a\u5e02\u80a1\u4efd\u8ba2\u7acb\u56de\u8d2d\u534f\u8bae\u3002\u767e\u80dc\u4e2d\u56fd\u8868\u793a\uff0c\u534f\u8bae\u6240\u8ba2\u622a\u81f32025\u5e74\u4e0a\u534a\u5e74\u4e4b\u603b\u56de\u8d2d\u91d1\u989d\u4e3a3.6\u4ebf\u7f8e\u5143\uff0c\u5176\u4e2d2.9\u4ebf\u7f8e\u5143\u7528\u4f5c\u56de\u8d2d\u5176\u7f8e\u80a1\uff0c\u5176\u4f595.5\u4ebf\u6e2f\u5143\u7528\u4e8e\u56de\u8d2d\u5176\u6e2f\u80a1\u3002\u516c\u53f8\u6307\uff0c\u56de\u8d2d\u534f\u8bae\u662f\u5176\u56de\u8d2d\u8ba1\u5212\u7684\u4e00\u4e2a\u7ec4\u6210\u90e8\u5206\uff0c\u4e5f\u662f\u66f4\u5e7f\u6cdb\u7684\u8d44\u672c\u5206\u914d\u8ba1\u5212\u7684\u4e00\u90e8\u5206\uff0c\u5373\u4ece2024\u5e74\u52302026\u5e74\u901a\u8fc7\u80a1\u606f\u548c\u80a1\u4efd\u56de\u8d2d\u5411\u80a1\u4e1c\u8fd4\u8fd845\u4ebf\u7f8e\u5143\uff0c\u5176\u4e2d\u5305\u62ec2024\u5e74\u5168\u5e74\u768415\u4ebf\u7f8e\u5143\u3002<br/><br/>2\u3001\u534f\u5408\u65b0\u80fd\u6e90(00182)\u516c\u5e03\uff0c\u4eca\u5e7411\u6708\u6743\u76ca\u53d1\u7535\u91cf646.97 GWh\uff0c\u6309\u5e74\u8dcc9.66%\uff1b\u4eca\u5e741-11\u6708\u7d2f\u8ba1\u6743\u76ca\u53d1\u7535\u91cf7813.89 GWh\uff0c\u6309\u5e74\u589e\u957f10.52%\u3002<br/><br/>3\u3001\u4e1c\u98ce\u96c6\u56e2\u80a1\u4efd(00489)\u516c\u5e03\uff0c2024\u5e741\u81f311\u6708\u7d2f\u8ba1\u6c7d\u8f66\u9500\u91cf\u4e3a1,704,507\u8f86\uff0c\u540c\u6bd4\u4e0b\u964d\u7ea611.1%\u3002<br/><br/>4\u3001\u4e2d\u56fd\u6d77\u5916\u53d1\u5c55(00688)\u53d1\u65b0\u95fb\u79f0,\u65bc2024\u5e7411\u6708\uff0c\u4e2d\u56fd\u6d77\u5916\u7cfb\u5217\u516c\u53f8\u7684\u5408\u7ea6\u7269\u4e1a\u9500\u552e\u91d1\u989d\u7ea6300.28\u4ebf\u5143\u4eba\u6c11\u5e01(\u4e0b\u540c)\uff0c\u6309\u5e74\u4e0a\u534730.9%\uff1b\u800c\u76f8\u5e94\u7684\u9500\u552e\u9762\u79ef\u7ea6\u4e3a110.3\u4e07\u5e73\u65b9\u7c73\uff0c\u6309\u5e74\u4e0a\u534714%\u30022024\u5e741\u6708\u81f311\u6708\uff0c\u4e2d\u56fd\u6d77\u5916\u7cfb\u5217\u516c\u53f8\u7d2f\u8ba1\u5408\u7ea6\u7269\u4e1a\u9500\u552e\u91d1\u989d\u7ea62704.66\u4ebf\u5143\uff0c\u76f8\u5e94\u7684\u7d2f\u8ba1\u9500\u552e\u9762\u79ef\u7ea61018.6\u4e07\u5e73\u65b9\u7c73\uff0c\u5206\u522b\u6309\u5e74\u4e0b\u964d5.8%\u53ca17.7%\u3002<br/><br/>5\u3001\u8054\u60f3\u96c6\u56e2(00992)\u8fd1\u65e5\u4e0e\u5f18\u4fe1\u7535\u5b50\u5728\u5317\u4eac\u8054\u60f3\u603b\u90e8\u4e3e\u884c\u4e86\u6218\u7565\u5408\u4f5c\u534f\u8bae\u7b7e\u7f72\u4eea\u5f0f\u3002\u53cc\u65b9\u5ba3\u5e03\u5c06\u5728AI\u7b97\u529b\u5efa\u8bbe\u548c\u667a\u80fd\u5316\u8f6c\u578b\u9886\u57df\u8fbe\u6210\u5408\u4f5c\uff0c\u5171\u540c\u63a8\u52a8AI\u57ce\u5e02\u5927\u8111\u3001\u667a\u80fd\u4e91\u89e3\u51b3\u65b9\u6848\u53ca\u667a\u80fd\u8f6c\u578b\u5168\u5468\u671f\u670d\u52a1\uff0c\u4e3a\u6570\u4f4d\u7ecf\u6d4e\u53d1\u5c55\u589e\u6dfb\u65b0\u52a8\u529b\u3002<br/><br/>6\u3001\u4e2d\u56fd\u6d77\u5916\u5b8f\u6d0b\u96c6\u56e2(00081)\u53d1\u62a5\u544a\u6307,\u57282024\u5e7411\u6708\u4efd\uff0c\u4e2d\u6d77\u5b8f\u6d0b\u7cfb\u5217\u516c\u53f8\u5b9e\u73b0\u5408\u7ea6\u9500\u552e\u989d40.69\u4ebf\u5143\u4eba\u6c11\u5e01(\u4e0b\u540c)\u53ca\u5408\u7ea6\u9500\u552e\u9762\u79ef33.93\u4e07\u5e73\u65b9\u7c73\uff0c\u5206\u522b\u6309\u5e74\u4e0a\u534752.9%\u53ca72.8%\u3002\u57282024\u5e741\u81f311\u6708\u4efd\uff0c\u7d2f\u8ba1\u5408\u7ea6\u9500\u552e\u989d355.26\u4ebf\u5143\u53ca\u5408\u7ea6\u9500\u552e\u9762\u79ef309.79\u4e07\u5e73\u65b9\u7c73\uff0c\u5206\u522b\u6309\u5e74\u4e0b\u8dcc11.9%\u53ca7%\u3002\u622a\u81f32024\u5e7411\u6708\u5e95\uff0c\u7d2f\u8ba1\u8ba4\u8d2d\u672a\u7b7e\u7ea6\u989d7.74\u4ebf\u5143\u53ca\u8ba4\u8d2d\u672a\u7b7e\u7ea6\u9762\u79ef70100\u5e73\u65b9\u7c73\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259770989", "pub_date": "2024-12-06 08:41:49"}, {"id": 259770584, "title": "\u3010\u65b0\u80a1IPO\u3011\u636e\u62a5\u4e1c\u9e4f\u996e\u6599(605499)\u6700\u5feb\u660e\u5e74\u8d74\u6e2f\u4e0a\u5e02 \u7b79\u96c6\u6700\u591a10\u4ebf\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6709\u62a5\u9053\u5f15\u8ff0\u77e5\u60c5\u4eba\u58eb\u6307\uff0c\u80fd\u91cf\u996e\u54c1\u5236\u9020\u5546\u4e1c\u9e4f\u996e\u6599(605499)\u6b63\u8003\u8651\u5728\u6e2f\u4e0a\u5e02\uff0c\u5e76\u6b63\u7269\u8272\u8d22\u52a1\u987e\u95ee\u8d1f\u8d23\u6709\u5173\u4e8b\u5b9c\uff0c\u9884\u8ba1\u6700\u5feb\u660e\u5e74\u53ef\u6b63\u5f0f\u4e0a\u5e02\uff0c\u7b79\u96c6\u6700\u591a10\u4ebf\u7f8e\u5143(\u5373\u7ea678\u4ebf\u6e2f\u5143)\u8d44\u91d1\u3002<br/><br/>\u77e5\u60c5\u4eba\u58eb\u4ea6\u900f\u9732\uff0c\u76f8\u5173\u5728\u6e2f\u4e0a\u5e02\u8ba1\u5212\u4ecd\u5728\u5ba1\u8bae\u5f53\u4e2d\uff0c\u5305\u62ec\u89c4\u6a21\u5728\u5185\u7684\u7ec6\u8282\u4ecd\u53ef\u80fd\u51fa\u73b0\u53d8\u6570\u3002<br/><br/>\u4e1c\u9e4f\u996e\u6599\u66fe\u7ea6\u4e24\u5e74\u524d\u8ba1\u5212\u5728\u745e\u58eb\u4e0a\u5e02\uff0c\u4e0d\u8fc7\u516c\u53f8\u53ca\u540e\u53d1\u516c\u544a\u6307\uff0c\u76d1\u4e8e\u5185\u5916\u90e8\u73af\u5883\u7b49\u5ba2\u89c2\u56e0\u7d20\u53d1\u751f\u53d8\u5316\u7b49\uff0c\u51b3\u5b9a\u7ec8\u6b62\u8be5\u6b21\u5883\u5916\u53d1\u884c\u5168\u7403\u5b58\u6258\u51ed\u8bc1(GDR)\u4e8b\u9879\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259770584", "pub_date": "2024-12-06 08:32:55"}, {"id": 259770321, "title": "\u3010\u65b0\u80a1IPO\u3011\u91cd\u5851\u80fd\u6e90(02570)\u5b9a\u4ef7147\u6e2f\u5143 \u4e00\u624b\u4e2d\u7b7e\u738756.81%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u91cd\u5851\u80fd\u6e90(02570)\u516c\u5e03\u62db\u80a1\u7ed3\u679c\uff0c\u6bcf\u80a1\u5b9a\u4ef7147\u6e2f\u5143\uff0c\u96c6\u8d447.097\u4ebf\u6e2f\u5143\uff0c\u51c0\u989d\u7ea66.29\u4ebf\u6e2f\u5143\u3002\u6bcf\u624b20\u80a1\uff0c \u4e00\u624b\u4e2d\u7b7e\u738756.81%\uff0c\u8ba4\u8d2d2\u624b\u53ef\u7a33\u83b7\u4e00\u624b\u3002<br/><br/>\u80a1\u4efd\u4e8e\u9999\u6e2f\u516c\u5f00\u53d1\u552e\u9636\u6bb5\u63a5\u83b72411\u4efd\u6709\u6548\u7533\u8bf7\uff0c\u8ba4\u8d2d\u989d1.55\u500d\uff1b\u56fd\u9645\u53d1\u552e\u8ba4\u8d2d\u989d1.33\u500d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259770321", "pub_date": "2024-12-06 08:26:37"}, {"id": 259770320, "title": "\u3010\u65b0\u80a1IPO\u3011\u591a\u70b9\u6570\u667a(02586)\u5b9a\u4ef730.21\u6e2f\u5143 \u4e00\u624b\u4e2d\u7b7e\u7387100%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u591a\u70b9\u6570\u667a(02586)\u516c\u5e03\u62db\u80a1\u7ed3\u679c\uff0c\u6bcf\u80a1\u5b9a\u4ef730.21\u6e2f\u5143\uff0c\u96c6\u8d447.79\u4ebf\u6e2f\u5143\uff0c\u51c0\u989d\u7ea66.24\u4ebf\u6e2f\u5143\u3002\u6bcf\u624b100\u80a1\uff0c\u4e00\u624b\u4e2d\u7b7e\u7387100%\uff0c\u4eba\u4eba\u6709\u4efd\u3002<br/><br/>\u80a1\u4efd\u4e8e\u9999\u6e2f\u516c\u5f00\u53d1\u552e\u9636\u6bb5\u63a5\u83b72988\u4efd\u6709\u6548\u7533\u8bf7\uff0c\u8ba4\u8d2d\u989d1.94\u500d\uff1b\u56fd\u9645\u53d1\u552e\u8ba4\u8d2d\u989d1.36\u500d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259770320", "pub_date": "2024-12-06 08:26:42"}, {"id": 259769816, "title": "\u3010\u7279\u7ea6\u5927V\u3011\u90ed\u5bb6\u8000\uff1a\u6295\u8d44\u8005\u7ee7\u7eed\u89c2\u671b\u653f\u7b56\u6d88\u606f\u4ee5\u53ca\u4eba\u6c11\u5e01\u8d70\u52bf\u8868\u73b0 \u6599\u5e02\u51b5\u7ef4\u6301\u4e0a\u843d\u5f62\u6001", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u80a1\u5468\u56db\u8868\u73b0\u56de\u843d\uff0c\u5e02\u573a\u89c2\u671b\u5373\u5c06\u516c\u5e03\u7684\u5c31\u4e1a\u6570\u636e\u8868\u73b0\uff0c\u5927\u5e02\u5728\u9ad8\u4f4d\u5f98\u5f8a\uff0c\u4e09\u5927\u6307\u6570\u5747\u5f55\u5f97\u8dcc\u5e45\u6536\u5e02\u3002\u7f8e\u5143\u8d70\u52bf\u56de\u843d\uff0c\u7f8e\u56fd\u5341\u5e74\u671f\u503a\u606f\u4ea6\u4e0b\u6ed1\u81f34.17\u5398\u6c34\u5e73\uff0c\u91d1\u4ef7\u8868\u73b0\u5411\u4e0b\uff0c\u6cb9\u4ef7\u8d70\u52bf\u53d7\u538b\u3002\u6e2f\u80a1\u9884\u6258\u8bc1\u5238\u5927\u81f4\u9760\u7a33\uff0c\u9884\u6599\u5927\u5e02\u65e9\u6bb5\u53d8\u52a8\u4e0d\u5927\u3002\u5185\u5730\u80a1\u5e02\u6628\u65e5\u4e0a\u5347\uff0c\u6caa\u7efc\u6307\u4f4e\u5f00\u9ad8\u8d70\uff0c\u6536\u5e02\u4e0a\u53470.1%\uff0c\u6caa\u6df1\u4e24\u5e02\u6210\u4ea4\u989d\u6709\u6240\u7f29\u51cf\u3002\u6e2f\u80a1\u6628\u65e5\u53cd\u8986\u504f\u8f6f\uff0c\u5e02\u573a\u89c2\u671b\u6c14\u6c1b\u6d53\u539a\uff0c\u5927\u5e02\u6210\u4ea4\u8fdb\u4e00\u6b65\u51cf\u5c11\u3002\u6295\u8d44\u8005\u7ee7\u7eed\u89c2\u671b\u653f\u7b56\u6d88\u606f\u4ee5\u53ca\u4eba\u6c11\u5e01\u8d70\u52bf\u8868\u73b0\uff0c\u9884\u6599\u5e02\u51b5\u7ef4\u6301\u4e0a\u843d\u5f62\u6001\uff0c\u6307\u6570\u7ee7\u7eed\u4e8e19,000\u81f319,800\u70b9\u6c34\u5e73\u5f98\u5f8a\u3002<br/><br/>\u884c\u4e1a\u6d88\u606f<br/>\u7f8e\u56e2(03690)\u65e9\u524d\u516c\u5e03\u7b2c\u4e09\u5b63\u7ecf\u8c03\u6574\u76c8\u5229128.29\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u6309\u5e74\u589e\u957f1.24\u500d\u3002\u671f\u5185\u603b\u6536\u5165935.77\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u4e0a\u534722.4%\u3002\u7b2c\u4e09\u5b63\u6838\u5fc3\u672c\u5730\u5546\u4e1a\u5206\u90e8\u7684\u6536\u5165694\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u6309\u5e74\u589e\u957f20.2%\uff1b\u7ecf\u8425\u6ea2\u5229146\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u6309\u5e74\u589e\u957f44.4%\uff1b\u7ecf\u8425\u5229\u6da6\u7387\u63d0\u53473.5\u4e2a\u767e\u5206\u70b9\u81f321%\u3002\u5373\u65f6\u914d\u9001\u4e1a\u52a1\u7ee7\u7eed\u7a33\u5065\u589e\u957f\uff0c\u8ba2\u5355\u91cf\u6309\u5e74\u589e\u957f14.5%\u3002\u5230\u5e97\u9152\u65c5\u4e1a\u52a1\u5f55\u5f97\u5f3a\u52b2\u589e\u957f\uff0c\u8ba2\u5355\u91cf\u589e\u957f\u8d85\u8fc750%\u3002\u65b0\u4e1a\u52a1\u5206\u90e8\u7684\u6536\u5165242\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u6309\u5e74\u589e\u957f28.9%\uff0c\u4e3b\u8981\u7531\u4e8e\u5546\u54c1\u96f6\u552e\u4e1a\u52a1\u7684\u6536\u5165\u589e\u957f\uff1b\u7ecf\u8425\u4e8f\u635f\u6536\u7a84\u81f310\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u53bb\u5e74\u540c\u671f\u4e3a\u4e8f\u635f51\u4ebf\u5143\u4eba\u6c11\u5e01\uff1b\u7ecf\u8425\u4e8f\u635f\u7387\u6309\u5b63\u6539\u55841.9\u4e2a\u767e\u5206\u70b9\u81f34.2%\u3002\u7b2c\u4e09\u5b63\u5b9e\u73b0\u7ecf\u8425\u73b0\u91d1\u6d41\u5165152\u4ebf\u5143\u4eba\u6c11\u5e01\u3002\u622a\u81f39\u6708\u5e95\u6b62\uff0c\u6301\u6709\u7684\u73b0\u91d1\u53ca\u73b0\u91d1\u7b49\u4ef7\u7269\u548c\u77ed\u671f\u7406\u8d22\u6295\u8d44\u5206\u522b\u4e3a425\u4ebf\u548c917\u4ebf\u5143\u4eba\u6c11\u5e01\u3002\u7f8e\u56e2\u914d\u9001\u4e1a\u52a1\u4fdd\u6301\u9886\u5148\u5730\u4f4d\uff0c\u7ade\u4e89\u683c\u5c40\u7a33\u5b9a\uff0c\u5230\u5e97\u672c\u5730\u670d\u52a1\u4ea6\u5feb\u901f\u589e\u957f\uff0c\u65b0\u4e1a\u52a1\u8425\u8fd0\u6548\u7387\u6539\u5584\uff0c\u4e8f\u635f\u6709\u6240\u6536\u7a84\uff0c\u8d44\u4ea7\u8d1f\u503a\u8868\u5f3a\u52b2\u3002\u7f8e\u56e2\u7ba1\u7406\u5c42\u7684\u6267\u884c\u80fd\u529b\u5f3a\u52b2\uff0c\u7ade\u4e89\u7b56\u7565\u6e05\u6670\uff0c\u524d\u666f\u4ecd\u7136\u503c\u5f97\u4e50\u89c2\u3002<br/><br/>(\u7b14\u8005\u4e3a\u8bc1\u76d1\u4f1a\u6301\u724c\u4eba\u4ed5\uff0c\u672c\u4eba\u53ca\u76f8\u5173\u4eba\u58eb\u6ca1\u6301\u6709\u4e0a\u8ff0\u80a1\u4efd)</p><p>\u4f5c\u8005\uff1a\u6e2f\u6e7e\u5bb6\u65cf\u529e\u516c\u5ba4\u4e1a\u52a1\u53d1\u5c55\u603b\u76d1 \u90ed\u5bb6\u8000</p>", "link": "https://sky.szfiu.com/info/hk/details/259769816", "pub_date": "2024-12-06 08:15:00"}]}