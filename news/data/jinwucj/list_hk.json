u4ea4\u989d\u7565\u4e3a\u589e\u52a0\u3002\u6e2f\u80a1\u8ddf\u968f\u5916\u56f4\u53cd\u8986\u504f\u8f6f\uff0c\u5927\u5e02\u4f4e\u5f00\u540e\u8dcc\u5e45\u4e00\u5ea6\u6536\u7a84\uff0c\u5c3e\u5e02\u518d\u5ea6\u56de\u843d\uff0c\u6574\u4f53\u6210\u4ea4\u4ea6\u6709\u6240\u589e\u52a0\u3002\u5916\u56f4\u51cf\u606f\u6b65\u4f10\u653e\u7f13\uff0c\u5e02\u573a\u5fe7\u8651\u5f71\u54cd\u7ecf\u6d4e\u590d\u82cf\u8868\u73b0\uff0c\u4eba\u6c11\u5e01\u8d70\u52bf\u8f6c\u5f31\uff0c\u4ea6\u4e0d\u5229\u4e2d\u8d44\u80a1\u8868\u73b0\uff0c\u9884\u6599\u6307\u6570\u7ee7\u7eed\u7ef4\u6301\u4e8e19,000\u81f320,000\u70b9\u6c34\u5e73\u5f98\u5f8a\u3002<br/><br/>\u884c\u4e1a\u6d88\u606f<br/>\u6ed4\u640f(06110)\u516c\u5e03\u622a\u81f311\u6708\u5e95\u7b2c\u4e09\u8d22\u5b63\u96f6\u552e\u53ca\u6279\u53d1\u4e1a\u52a1\u603b\u9500\u552e\u989d\u6309\u5e74\u5f55\u5f97\u4e2d\u5355\u4f4d\u6570\u4e0b\u8dcc\u3002\u622a\u81f311\u670830\u65e5\uff0c\u76f4\u8425\u95e8\u5e97\u6bdb\u9500\u552e\u9762\u79ef\u8f83\u4e0a\u5b63\u672b\u964d2.1%\uff0c\u6309\u5e74\u5219\u51cf4.4%\u3002\u516c\u53f8\u7b2c\u4e09\u5b63\u5ea6\u9500\u552e\u6301\u7eed\u4e0b\u8dcc\uff0c\u800c\u7b2c\u4e8c\u8d22\u653f\u5b63\u5ea6\u96f6\u552e\u53ca\u6279\u53d1\u4e1a\u52a1\u603b\u9500\u552e\u989d\u6309\u5e74\u5f55\u5f9710%\u81f320%\u4f4e\u6bb5\u8dcc\u5e45\u3002\u516c\u53f8\u8868\u793a\uff0c\u53d7\u5b8f\u89c2\u6d88\u8d39\u75b2\u8f6f\u5bf9\u884c\u4e1a\u96f6\u552e\u73af\u5883\u7684\u62d6\u7d2f\uff0c\u4ee5\u53ca\u7ebf\u4e0b\u5ba2\u6d41\u4e0b\u6ed1\u7684\u5f71\u54cd\uff0c\u4ee5\u81f4\u4e0a\u534a\u5e74\u5ea6\u6536\u5165\u4e0b\u964d7.9%\u3002\u516c\u53f8\u6307\u51fa\uff0c\u671f\u5185\u968f\u7740\u5ba2\u6d41\u4e0e\u6d88\u8d39\u573a\u666f\u53d8\u5316\uff0c\u8fdb\u4e00\u6b65\u4e30\u5bcc\u5168\u57df\u573a\u666f\u5e03\u5c40\uff0c\u5e76\u4ee5\u6548\u7387\u4e3a\u6838\u5fc3\uff0c\u7ed3\u5408\u54c1\u724c\u5c5e\u6027\u91c7\u53d6\u4e00\u7cfb\u5217\u63aa\u65bd\uff0c\u8c03\u6574\u7ebf\u4e0b\u95e8\u5e97\u7f51\u7edc\u5e03\u5c40\u3002\u65b0\u5f00\u5e97\u4e3b\u8981\u805a\u7126\u4e8