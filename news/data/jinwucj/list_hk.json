2</p>", "link": "https://sky.szfiu.com/info/hk/details/260242515", "pub_date": "2024-12-11 11:20:23"}, {"id": 260242418, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5df4\u514b\u83b1\u94f6\u884c\uff1a\u4e2d\u7f8e\u8d38\u6613\u7d27\u5f20\u5347\u7ea7\u4e0e\u4e2d\u56fd\u7ecf\u6d4e\u653f\u7b56\u524d\u77bb", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5df4\u514b\u83b1\u94f6\u884c\u7684\u4e2d\u56fd\u5c55\u671b\u62a5\u544a\u6307\u51fa\uff0c\u4e2d\u7f8e\u4e4b\u95f4\u7684\u201c\u82af\u7247\u6218\u201d\u6301\u7eed\u5347\u7ea7\uff0c\u4e2d\u56fd\u5bf9\u7f8e\u56fd\u91c7\u53d6\u4e86\u62a5\u590d\u6027\u63aa\u65bd\uff0c\u5305\u62ec\u7981\u6b62\u5411\u7f8e\u56fd\u51fa\u53e3\u5173\u952e\u77ff\u7269\uff0c\u5e76\u5728\u653f\u5e9c\u91c7\u8d2d\u4e2d\u504f\u597d\u56fd\u4ea7\u4ea7\u54c1\u3002\u62a5\u544a\u9884\u8ba1\uff0c\u4e2d\u56fd\u5c06\u66f4\u591a\u4f7f\u7528\u975e\u5173\u7a0e\u624b\u6bb5\u8fdb\u884c\u8d38\u6613\u6218\u53cd\u51fb\uff0c\u5982\u9650\u5236\u5173\u952e\u8d44\u6e90\u51fa\u53e3\u3001\u9650\u5236\u7f8e\u56fd\u4ea7\u54c1\u548c\u670d\u52a1\u5728\u4e2d\u56fd\u7684\u9500\u552e\u7b49\u3002<br/><br/>\u62a5\u544a\u8fd8\u63d0\u5230\uff0c\u4e2d\u56fd\u653f\u5e9c\u91c7\u8d2d\u653f\u7b56\u7684\u53d8\u5316\uff0c\u5305\u62ec\u9010\u6b65\u6dd8\u6c70\u7f8e\u56fd\u5904\u7406\u5668\u3001\u64cd\u4f5c\u7cfb\u7edf\u548c\u5916\u56fd\u6570\u636e\u5e93\u8f6f\u4ef6\uff0c\u4ee5\u53ca\u7ed9\u4e88\u56fd\u4ea7\u4ea7\u54c1\u5728\u653f\u5e9c\u91c7\u8d2d\u4e2d\u7684\u4f18\u60e0\u5f85\u9047\u3002\u8fd9\u4e9b\u63aa\u65bd\u65e8\u5728\u652f\u6301\u56fd\u5185\u5236\u9020\u5546\uff0c\u5e76\u6fc0\u52b1\u5916\u56fd\u516c\u53f8\u5c06\u751f\u4ea7\u4fdd\u7559\u5728\u4e2d\u56fd\u3002<br/><br/>\u5728\u7ecf\u6d4e\u653f\u7b56\u65b9\u9762\uff0c\u62a5\u544a\u9884\u8ba1\u4e2d\u56fd\u5c06\u5728\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\uff08CEWC\uff09\u4e0a\u786e\u8ba4\u63a8\u52a8\u7ecf\u6d4e\u589e\u957f\u7684\u65b0\u52a8\u529b\uff0c\u5982\u9ad8\u79d1\u6280\u548c\u6570\u5b57\u7ecf\u6d4e\uff0c\u5e76\u5f3a\u8c03\u63d0\u9ad8\u6d88\u8d39\u548c\u6269\u5927\u8d38\u6613\u3002\u5c3d\u7ba1\u7f8e\u56fd\u603b\u7edf\u7279\u6717\u666e\u5a01\u80c1\u5bf9\u4e2d\u56fd\u51fa\u53e3\u589e\u52a0\u989d\u5916\u5173\u7a0e\uff0c\u4e2d\u56fd\u53ef\u80fd\u4f1a\u5728CEWC\u4e0a\u8868\u793a\u52a0\u5927\u8d27\u5e01\u548c\u8d22\u653f\u652f\u6301\u529b\u5ea6\u3002\u4e0d\u8fc7\uff0c\u5177\u4f53\u7684\u653f\u7b56\u6307\u5bfc\u9884\u8ba1\u5c06\u5728\u660e\u5e743\u6708\u7684\u5168\u56fd\u4eba\u5927\u4f1a\u8bae\u4e0a\u516c\u5e03\u3002<br/><br/>\u5df4\u514b\u83b1\u94f6\u884c\u9884\u8ba12024\u5e74\u5b9e\u9645GDP\u589e\u957f\u7387\u4e3a5.3%\uff0c2025\u5e74\u548c2026\u5e74\u5206\u522b\u4e3a4.0%\uff1bCPI\u901a\u80c0\u73872024\u5e74\u9884\u8ba1\u4e3a0.2%\uff0c2025\u5e74\u4e3a0.6%\uff0c2026\u5e74\u4e3a1.0%\uff1b\u5de5\u4e1a\u751f\u4ea7\u589e\u957f\u73872024\u5e74\u4e3a5.8%\uff0c\u9010\u5e74\u4e0b\u964d\u81f32026\u5e74\u76844.0%\uff1b\u540d\u4e49GDP\u589e\u957f\u73872024\u5e74\u4e3a4.2%\uff0c\u9010\u5e74\u4e0b\u964d\u81f32026\u5e74\u76844.0%\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/260242418", "pub_date": "2024-12-11 11:19:08"}, {"id": 260241842, "title": "\u9694\u591cshibor\u62a51.5280% \u4e0a\u6da85.8\u4e2a\u57fa\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c12\u670811\u65e5\uff0c\u9694\u591cshibor\u62a51.5280%\uff0c\u4e0a\u6da85.8\u4e2a\u57fa\u70b9\uff1b7\u5929shibor\u62a51.7220%\uff0c\u4e0b\u8dcc6.2\u4e2a\u57fa\u70b9\uff1b3\u4e2a\u6708shibor\u62a51.7440%\uff0c\u4e0b\u8dcc0.4\u4e2a\u57fa\u70b9\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260241842", "pub_date": "2024-12-11 11:13:14"}, {"id": 260240987, "title": "\u98df\u54c1\u996e\u6599\u677f\u5757\u666e\u904d\u4e0a\u884c \u7edf\u4e00\u4f01\u4e1a\u4e2d\u56fd(00220)\u6da85.36% \u673a\u6784\u6599\u660e\u5e74\u4e2d\u56fd\u6d88\u8d39\u5c06\u6301\u7eed\u6539\u5584", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u98df\u54c1\u996e\u6599\u677f\u5757\u666e\u904d\u4e0a\u884c\uff0c\u7edf\u4e00\u4f01\u4e1a\u4e2d\u56fd(00220)\u6da85.36%\uff0c\u534e\u6da6\u996e\u6599(02460)\u6da85.06%\uff0c\u519c\u592b\u5c71\u6cc9(09633)\u6da84.04%\uff0c\u9752\u5c9b\u5564\u9152\u80a1\u4efd(00168)\u6da82.64%\uff0c\u8499\u725b\u4e73\u4e1a(02319)\u6da83.47%\uff0c\u534e\u6da6\u5564\u9152(00291)\u6da82.06%\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u534e\u6cf0\u8bc1\u5238\u8868\u793a\uff0c\u4e2d\u5171\u4e2d\u592e\u653f\u6cbb\u5c4012\u67089\u65e5\u53ec\u5f00\u4f1a\u8bae\uff0c\u5206\u6790\u7814\u7a762025\u5e74\u7ecf\u6d4e\u5de5\u4f5c\uff0c\u63d0\u51fa\u201c\u5b9e\u65bd\u66f4\u52a0\u79ef\u6781\u6709\u4e3a\u7684\u5b8f\u89c2\u653f\u7b56\u201d\u3001\u201c\u8981\u5927\u529b\u63d0\u632f\u6d88\u8d39\uff0c\u5168\u65b9\u4f4d\u6269\u5927\u56fd\u5185\u9700\u6c42\u201d\u3001\u201c\u52a0\u5927\u4fdd\u969c\u548c\u6539\u5584\u6c11\u751f\u529b\u5ea6\uff0c\u589e\u5f3a\u4eba\u6c11\u7fa4\u4f17\u83b7\u5f97\u611f\u5e78\u798f\u611f\u5b89\u5168\u611f\u201d\u7b49\u3002\u8be5\u884c\u8ba4\u4e3a\u672c\u6b21\u653f\u6cbb\u5c40\u4f1a\u8bae\u5b9a\u8c03\u79ef\u6781\uff0c\u6269\u5927\u5185\u9700\u517c\u987e\u63d0\u632f\u6d88\u8d39\u548c\u6539\u5584\u6c11\u751f\uff0c\u6709\u52a9\u4e8e\u63d0\u5347\u5c45\u6c11\u7684\u6d88\u8d39\u610f\u613f\u548c\u6d88\u8d39\u80fd\u529b\u3002<br/><br/>\u91cc\u6602\u53d1\u5e03\u7814\u7a76\u62a5\u544a\u79f0\uff0c\u9884\u8ba1\u660e\u5e74\u4e2d\u56fd\u6d88\u8d39\u5c06\u6301\u7eed\u6539\u5584\uff0c\u5c24\u5176\u662f\u660e\u5e74\u4e0b\u534a\u5e74\u5047\u8bbe\u652f\u6301\u653f\u7b56\u7a33\u6b65\u63a8\u51fa\uff0c\u800c\u5927\u90e8\u5206\u7684\u80a1\u7968\u4f30\u503c\u4ecd\u7136\u4fbf\u5b9c\u3002\u8be5\u884c\u6599\u767d\u9152\u4e1a\u5c06\u662f\u6700\u65e9\u56de\u6696\u7684\u677f\u5757\uff0c\u56e0\u5176\u5bf9\u5b8f\u89c2\u73af\u5883\u548c\u5546\u4e1a\u9700\u6c42\u7684\u53d8\u5316\u8f83\u4e3a\u654f\u611f\u3002\u540c\u65f6\uff0c\u8be5\u884c\u5efa\u8bae\u6295\u8d44\u8005\u53ef\u5173\u6ce8\u5177\u76c8\u5229\u8f6c\u52bf\u6f5c\u529b\u7684\u516c\u53f8\uff0c\u5982\u679c\u5b8f\u89c2\u60c5\u51b5\u6062\u590d\u987a\u5229\uff0c\u9ad8\u6536\u76ca\u4e3b\u9898\u53ef\u80fd\u4f1a\u9762\u4e34\u8d44\u672c\u5916\u6d41\u7684\u98ce\u9669\u3002\u8be5\u884c\u5efa\u8bae\u5728\u590d\u82cf\u521d\u671f\uff0c\u53ef\u9009\u62e9\u4f18\u8d28\u7684\u5927\u578b\u516c\u53f8\u3002\u8be5\u884c\u9996\u9009\u80a1\u5305\u62ec\uff0c\u8f6c\u52bf\u6f5c\u529b\u80a1\u9752\u5c9b\u5564\u9152\u80a1\u4efd\u53ca\u519c\u592b\u5c71\u6cc9\uff0c\u4ee5\u53ca\u4e73\u5236\u54c1\u80a1\u8499\u725b\u4e73\u4e1a\uff0c\u53d7\u60e0\u9700\u6c42\u9010\u6e10\u590d\u82cf\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260240987", "pub_date": "2024-12-11 11:04:40"}, {"id": 260240331, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6469\u6839\u5927\u901a\u6599Q4\u6fb3\u95e8\u535a\u5f69\u6536\u5165\u5c06\u6309\u5b63\u589e\u957f3%\u81f34% \u9996\u9009\u94f6\u6cb3\u5a31\u4e50(00027)", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u6469\u6839\u5927\u901a\u53d1\u7814\u62a5\u6307\uff0c\u6fb3\u95e812\u6708\u9996\u516b\u65e5\u7684\u535a\u5f69\u6bdb\u6536\u5165\u4e3a45\u4ebf(\u6fb3\u95e8\u5143\uff0c\u4e0b\u540c)\uff0c\u76f8\u5f53\u4e8e\u6bcf\u65e55.62\u4ebf\u5143\uff0c\u8f8311\u6708\u65e5\u5747\u535a\u5f69\u6536\u5165\u4f4e\u51fa9%\uff0c\u4f46\u5c5e\u9884\u671f\u4e4b\u5185\u3002\u671f\u5185\uff0c\u4e2d\u573a\u4e1a\u52a1\u7684\u535a\u5f69\u6bdb\u6536\u5165\u7ea6\u4e3a\u75ab\u60c5\u524d\u6c34\u5e73\u7684105%\uff0c\u800c\u8d35\u5bbe\u5385\u5219\u6062\u590d\u81f3\u7ea620%\u81f323%\u3002\u867d\u7136\u9884\u8ba112\u6708\u535a\u5f69\u6536\u5165\u589e\u957f\u5c06\u4f1a\u653e\u7f13\uff0c\u4f46\u9884\u8ba1\u7b2c\u56db\u5b63\u4ecd\u5c06\u6309\u5b63\u589e\u957f3%\u81f34%\uff0c\u8fbe\u523020\u4e2a\u5b63\u5ea6\u4ee5\u6765\u7684\u6700\u9ad8\u6c34\u5e73\uff0c\u8ba4\u4e3a\u8fd9\u4e2a\u589e\u957f\u52bf\u5934\u5e94\u80fd\u652f\u6301\u884c\u4e1a\u8fbe\u5230\u7b2c\u56db\u5b63\u4ee5\u53ca\u4eca\u8d22\u5e74\u7684\u666e\u904d\u9884\u671f\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u660e\u5e74\u6fb3\u95e8\u535a\u5f69\u80a1\u4e2d\u9996\u9009\u4e3a\u94f6\u6cb3\u5a31\u4e50(00027)\uff0c\u7ed9\u4e88\u201c\u589e\u6301\u201d\u8bc4\u7ea7\uff0c\u76ee\u6807\u4ef748\u6e2f\u5143\uff0c\u4ee5\u53cd\u6620\u5176\u72ec\u7279\u7684\u76c8\u5229\u52a8\u529b\u4ee5\u53ca\u8f83\u4f4e\u76849\u500d\u4f01\u4e1a\u4ef7\u503c\u500d\u6570(EV/EBITDA)\uff0c\u4e4b\u540e\u4e5f\u770b\u597d\u6c38\u5229\u6fb3\u95e8(01128)\u3001\u91d1\u6c99\u4e2d\u56fd(01928)\u53ca\u7f8e\u9ad8\u6885\u4e2d\u56fd(02282)\uff0c\u5176\u540e\u9009\u80a1\u987a\u5e8f\u4e3a\u6fb3\u535a\u63a7\u80a1(00880)\uff0c\u6700\u540e\u4e3a\u65b0\u6fe0\u56fd\u9645\u53d1\u5c55(00200)\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260240331", "pub_date": "2024-12-11 10:57:21"}]}