 vertical-align:middle;\">29.25</td><td style=\"border: 1px solid#999; padding: 10px 0; vertical-align:middle;\">-1.18</td></tr></tbody></table></div>", "link": "https://sky.szfiu.com/info/hk/details/255399490", "pub_date": "2024-10-22 11:00:04"}, {"id": 255398906, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u4eba\u5f62\u673a\u5668\u4eba\u6982\u5ff5\u518d\u83b7\u8ffd\u6367 \u4f18\u5fc5\u9009(09880)\u65e9\u76d8\u6da813.94%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4eba\u5f62\u673a\u5668\u4eba\u6982\u5ff5\u518d\u83b7\u8ffd\u6367\uff0c\u4f18\u5fc5\u9009(09880)\u65e9\u76d8\u6da813.94%\uff0c\u62a5102.2\u6e2f\u5143\uff0c\u6210\u4ea4\u989d2.32\u4ebf\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u8fd1\u65e5\uff0c\u4f18\u5fc5\u9009\u6b63\u5f0f\u53d1\u5e03\u5168\u65b0\u4e00\u4ee3\u5de5\u4e1a\u4eba\u5f62\u673a\u5668\u4ebaWalker S1\uff0c\u5e76\u5df2\u8fdb\u5165\u6c7d\u8f66\u5de5\u5382\u5b9e\u8bad\u3002\u76ee\u524d\uff0c\u4f18\u5fc5\u9009Walker S1\u5df2\u8fdb\u5165\u6bd4\u4e9a\u8fea\u5de5\u5382\u6267\u884c\u642c\u8fd0\u4efb\u52a1\u5b9e\u8bad\uff0c\u5e76\u5df2\u5b9e\u73b0\u5168\u7403\u9996\u6b21\u4eba\u5f62\u673a\u5668\u4eba\u4e0e\u65e0\u4eba\u7269\u6d41\u8f66\u3001\u65e0\u4eba\u53c9\u8f66\u3001\u5de5\u4e1a\u79fb\u52a8\u673a\u5668\u4eba\u548c\u667a\u80fd\u5236\u9020\u7ba1\u7406\u7cfb\u7edf\u7684\u534f\u540c\u4f5c\u4e1a\uff0c\u52a9\u529b\u5b9e\u73b0\u5ba4\u5185\u5916\u7269\u6d41\u573a\u666f\u7684\u65e0\u4eba\u5316\u548c\u89c4\u6a21\u5316\u5546\u4e1a\u843d\u5730\u3002<br/><br/>\u6b64\u5916\uff0c\u7279\u65af\u62c9\u8fd1\u65e5\u53d1\u5e03\u6700\u65b0Optimus\u66f4\u65b0\uff0c\u5c55\u793a\u5176\u81ea\u4e3b\u7a33\u5065\u884c\u8d70\u53ca\u4eba\u7c7b\u4ea4\u4e92\u7b49\u6700\u65b0\u6210\u679c\u89c6\u9891\u3002<br/><br/>\u4e2d\u4fe1\u8bc1\u5238\u53d1\u8868\u7814\u62a5\u79f0\uff0c\u5de5\u5382\u5e94\u7528\u5c06\u662f\u673a\u5668\u4eba\u5e94\u7528\u7684\u7b2c\u4e00\u7ad9\uff0c\u5728\u5de5\u5382\u4e2d\u6536\u96c6\u6570\u636e\u3001\u8bad\u7ec3\u7684\u57fa\u7840\u4e0a\uff0c\u4eba\u5f62\u673a\u5668\u4eba\u5c06\u9010\u6e10\u8d70\u5165\u751f\u6d3b\u573a\u666f\uff0c\u5b9e\u73b0\u66f4\u590d\u6742\u7684\u4efb\u52a1\u3002<br/><br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255398906", "pub_date": "2024-10-22 10:52:19"}, {"id": 255398905, "title": "\u4f53\u80b2\u7528\u54c1\u80a1\u591a\u6570\u4e0a\u884c \u7279\u6b65\u56fd\u9645(01368)\u8fd13% \u5929\u732b\u53cc\u5341\u4e00\u8fd0\u52a8\u6237\u591612\u5bb6\u54c1\u724c\u6210\u4ea4\u7834\u4ebf", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4f53\u80b2\u7528\u54c1\u80a1\u591a\u6570\u4e0a\u884c\uff0c\u7279\u6b65\u56fd\u9645(01368)\u6da82.85%\uff0c\u674e\u5b81(02331)\u6da82.27%\uff0c\u5b89\u8e0f\u4f53\u80b2(02020)\u6da81.05%\uff0c\u6ed4\u640f(06110)\u3001\u88d5\u5143\u96c6\u56e2(00551)\u8ddf\u6da8\u3002<br/><br/>\u6628\u665a8\u70b9\uff0c\u5929\u732b\u53cc11\u6b63\u5f0f\u73b0\u8d27\u5f00\u5356\uff0c\u8fd0\u52a8\u6237\u5916\u884c\u4e1a\u5934\u90e8\u54c1\u724c\u6590\u4e50\u3001\u8010\u514b\u3001\u963f\u8fea\u8fbe\u65af\u3001\u5317\u9762\u3001\u5b89\u8e0f\u3001\u9a86\u9a7c\u3001lululemon\u3001jordan\u3001\u8fea\u6851\u7279\u3001\u674e\u5b81\u3001\u65af\u51ef\u5947\u3001NEW BALANCE\uff0c12\u5bb6\u54c1\u724c\u6210\u4ea4\u7834\u4ebf\u3002\u6b64\u524d\u5728\u8fd0\u52a8\u6237\u5916\u884c\u4e1a\u9884\u552e\u7684\u9996\u5c0f\u65f6\u5185\uff0c\u516d\u4e2a\u54c1\u724c\u6210\u4ea4\u989d\u7a81\u78341\u4ebf\u5143\u4eba\u6c11\u5e01(\u4e0b\u540c)\uff0c32\u6b3e\u70ed\u9500\u5355\u54c1\u6210\u4ea4\u989d\u8d85\u8fc71,000\u4e07\u5143\u3002\u8fd0\u52a8\u6237\u5916\u54c1\u724c\u8fce\u6765\u7206\u53d1\u5f0f\u589e\u957f\uff0c\u5176\u4e2d\u660e\u661f\u5355\u54c1Adidas\u963f\u8fea\u8fbe\u65af600\u84ec\u7fbd\u7ed2\u670d\u5f00\u552e\u5373\u7a81\u7834\u4ebf\u5143\u5927\u5173\u3002<br/><br/>\u4e0a\u6d77\u8bc1\u5238\u7814\u62a5\u6307\u51fa\uff0c\u4f53\u80b2\u4ea7\u4e1a\u5df2\u6210\u4e3a\u52a9\u529b\u7ecf\u6d4e\u589e\u957f\u3001\u63a8\u52a8\u7ecf\u6d4e\u793e\u4f1a\u8f6c\u578b\u5347\u7ea7\u7684\u91cd\u8981\u529b\u91cf\uff0c\u5728\u57f9\u80b2\u7ecf\u6d4e\u53d1\u5c55\u65b0\u52a8\u80fd\u4e0a\u4f5c\u51fa\u91cd\u8981\u8d21\u732e\u3002\u56fd\u5bb6\u5927\u529b\u50ac\u52a8\u6539\u9769\u521b\u65b0\u8d4b\u80fd\u4f53\u80b2\u9ad8\u8d28\u91cf\u53d1\u5c55\uff0c\u770b\u597d\u8fd0\u52a8\u670d\u9970\u9ad8\u666f\u6c14\u6301\u7eed\u3002\u8bae\u5173\u6ce8\uff1a\u5b89\u8e0f\u3001\u674e\u5b81\u3001361\u5ea6\u7b49</p>", "link": "https://sky.szfiu.com/info/hk/details/255398905", "pub_date": "2024-10-22 10:52:32"}, {"id": 255399059, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5efa\u94f6\u56fd\u9645\u6307\u5e02\u573a\u4f4e\u4f30\u4e86\u5185\u623f\u653f\u7b56\u7684\u5f71\u54cd \u770b\u597d\u4e2d\u56fd\u6d77\u5916\u53d1\u5c55(00688)\u7b49", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5efa\u94f6\u56fd\u9645\u8868\u793a\uff0c\u6839\u636e\u56fd\u5bb6\u7edf\u8ba1\u5c40\u7684\u6570\u636e\uff0c\u4e2d\u56fd\u7684\u623f\u5730\u4ea7\u5e02\u573a\u6301\u7eed\u6539\u5584\u3002\u623f\u5730\u4ea7\u9500\u552e\u989d\u5728\u88ab\u79f0\u4e3a\u201c\u91d1\u4e5d\u201d\u76849\u6708\u73af\u6bd4\u6fc0\u589e43.2%\u3002\u540c\u6bd4\u6765\u770b\uff0c\u623f\u5730\u4ea7\u9500\u552e\u989d\u7684\u4e0b\u964d\u5e45\u5ea6\u4ece8\u6708\u768417.2%\u6536\u7a84\u81f39\u6708\u768416.3%\uff0c\u4e3b\u8981\u662f\u7531\u4e8e\u9500\u552e\u9762\u79ef\u4e0b\u964d11.0%\u548c\u5747\u4ef7\u4e0b\u964d5.9%\u3002\u57282024\u5e74\u524d9\u4e2a\u6708\uff0c\u623f\u5730\u4ea7\u9500\u552e\u989d\u4e0b\u964d22.7%\uff0c\u5176\u4e2d\u9500\u552e\u9762\u79ef\u4e0b\u964d17.1%\uff0c\u5747\u4ef7\u4e0b\u964d6.8%\u30029\u6708\u4efd\u5168\u56fd\u9500\u552e\u7684\u6539\u5584\u4e0e\u4e3b\u8981\u5f00\u53d1\u5546\u516c\u5e03\u7684\u4ee4\u4eba\u5931\u671b\u7684\u9500\u552e\u5f62\u6210\u5de8\u5927\u53cd\u5dee\uff0c\u540e\u8005\u5408\u7ea6\u9500\u552e\u4ece8\u6708\u4e0b\u964d28%\u6076\u5316\u81f39\u6708\u4e0b\u964d42%\u3002\u6545\u6b64\uff0c\u8be5\u884c\u8ba4\u4e3a\u9700\u8981\u6301\u7eed\u89c2\u5bdf\u4e24\u7ec4\u6570\u5b57\u66f4\u957f\u65f6\u95f4\u624d\u80fd\u786e\u8ba4\u9500\u552e\u4e0b\u884c\u8d8b\u52bf\u662f\u5426\u6709\u6240\u6539\u53d8\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u572810\u670817\u65e5\u4e3e\u884c\u7684\u201c\u4fc3\u8fdb\u623f\u5730\u4ea7\u5e02\u573a\u5e73\u7a33\u5065\u5eb7\u53d1\u5c55\u56fd\u65b0\u529e\u65b0\u95fb\u53d1\u5e03\u4f1a\u201d\u4e0a\uff0c\u8054\u5408\u90e8\u95e8\u7684\u53d1\u8a00\u4eba\u63d0\u51fa\u4e86\u91cd\u542f\u8d27\u5e01\u5316\u5b89\u7f6e\u623f\u548c\u767d\u540d\u5355\u9879\u76ee\u4fe1\u8d37\u89c4\u6a21\u6269\u5bb9\u81f34\u4e07\u4ebf\u7684\u653f\u7b56\u3002\u6682\u65f6\u6765\u8bf4\uff0c\u8be5\u884c\u8ba4\u4e3a\u5e02\u573a\u4f4e\u4f30\u4e86\u8fd9\u4e9b\u653f\u7b56\u7684\u5f71\u54cd\u3002\u81ea10\u6708\u521d\u5e02\u573a\u6574\u5408\u4ee5\u6765\uff0c\u9ad8\u8d28\u91cf\u5f00\u53d1\u5546\u7684\u4f30\u503c\u6c34\u5e73\u76f8\u8f83\u4e8e\u9ad8\u8d1d\u5854\u5f00\u53d1\u5546\u800c\u8a00\u66f4\u4e3a\u5438\u5f15\u3002\u4e58\u7740\u8fd9\u6ce2\u653f\u7b56\u4e1c\u98ce\uff0c\u8be5\u884c\u5efa\u8bae\u9010\u6b65\u589e\u6301\u4e2d\u56fd\u6d77\u5916\u53d1\u5c55(00688)\u3001\u9f99\u6e56\u96c6\u56e2(00960)\u548c\u7eff\u57ce\u4e2d\u56fd(03900)\uff0c\u5747\u4e88\u8dd1\u8d62\u5927\u5e02\u8bc4\u7ea7\u3002\u8be5\u884c\u9884\u8ba1\uff0c\u968f\u7740\u5e02\u573a\u590d\u82cf\uff0c\u8fd9\u4e9b\u516c\u53f8\u7684\u57fa\u672c\u9762\u5c06\u5728\u672a\u6765\u4e5d\u4e2a\u6708\u5185\u6539\u5584\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255399059", "pub_date": "2024-10-22 10:54:11"}, {"id": 255398455, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u4e2d\u56fd\u6d77\u5916\u5b8f\u6d0b\u96c6\u56e2(00081)\u8dcc\u8d853% \u99969\u6708\u6536\u5165\u540c\u6bd4\u4e0b\u6ed131%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u56fd\u6d77\u5916\u5b8f\u6d0b\u96c6\u56e2(00081)\u65e9\u76d8\u80a1\u4ef7\u53d7\u538b\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a52.11\u6e2f\u5143\uff0c\u8dcc3.21%\uff0c\u6210\u4ea4\u989d1322.92\u4e07\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u516c\u53f8\u516c\u5e03\uff0c\u622a\u81f32024\u5e749\u670830\u65e5\u6b62\u4e5d\u4e2a\u6708\uff0c\u96c6\u56e2\u6536\u5165\u7ea6\u4e3a\u4eba\u6c11\u5e01269.55\u4ebf\u5143\uff0c\u76f8\u6bd4\u53bb\u5e74\u540c\u671f\u4e0b\u8dcc31.0%\uff0c\u800c\u7ecf\u8425\u6ea2\u5229\u7ea6\u4e3a\u4eba\u6c11\u5e0114.50\u4ebf\u5143\uff0c\u76f8\u6bd4\u53bb\u5e74\u540c\u671f\u4e0b\u8dcc66.2%\u3002</p><p>\u96c6\u56e2\u4e8e2024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u7684\u6536\u5165\u53ca\u7ecf\u8425\u6ea2\u5229\u5206\u522b\u7ea6\u4e3a\u4eba\u6c11\u5e0151.03\u4ebf\u5143\u53ca\u4eba\u6c11\u5e011.31\u4ebf\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255398455", "pub_date": "2024-10-22 10:46:26"}, {"id": 255397349, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u91ce\u6751\u524a\u77f3\u836f\u96c6\u56e2(01093)\u76ee\u6807\u4ef78.9% \u6599\u7b2c\u4e09\u5b63\u5ea6\u76c8\u5229\u540c\u6bd4\u4e0b\u6ed14.3%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u91ce\u6751\u53d1\u7814\u62a5\u6307\uff0c\u9884\u8ba1\u77f3\u836f\u96c6\u56e2(01093)2024\u5e74\u7b2c\u4e09\u5b63\u76c8\u5229\u540c\u6bd4\u4e0b\u964d4.3%\u3002\u9884\u8ba1\u6536\u5165\u589e\u957f0.3%\u523078\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u4f4e\u4e8e\u5e02\u573a\u9884\u671f3%\uff0c\u53cd\u6620\u6210\u54c1\u53ca\u539f\u6599\u836f\u7684\u6539\u5584\uff0c\u4ee5\u53ca2023\u5e74\u7b2c\u4e09\u5b63\u5ea6\u57fa\u6570\u8f83\u4f4e\u3002<br/><br/>\u8be5\u884c\u4e0a\u8c03\u516c\u53f82024\u8d22\u5e74\u6536\u5165\u53ca\u76c8\u5229\u9884\u6d4b0.9%\u548c1.8%\uff0c\u4e3b\u8981\u8003\u86511\u4ebf\u7f8e\u5143\u7684\u5bf9\u5916\u6388\u6743\u534f\u8bae\u6536\u5165\uff0c\u88ab\u8be5\u884c\u5bf9\u8be5\u516c\u53f8\u836f\u54c1\u9500\u552e\u9884\u671f\u4e0b\u964d\u6240\u62b5\u6d88\u3002\u540c\u65f6\u5c062025\u8d22\u5e74\u6536\u5165\u548c\u76c8\u5229\u9884\u6d4b\u4e0b\u8c033.3%\u548c4%\u3002\u5c06\u516c\u53f8\u76ee\u6807\u4ef7\u75319.29\u6e2f\u5143\u4e0b\u8c038.9%\u81f38.46\u6e2f\u5143\u3002\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255397349", "pub_date": "2024-10-22 10:31:57"}, {"id": 255397453, "title": "\u7f57\u6280(LOGI)\u7b2c\u4e8c\u8d22\u5b63\u9500\u552e\u6536\u5165\u540c\u6bd4\u589e\u957f6%\u81f311.2\u4ebf\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f57\u6280(LOGI)\u516c\u5e032025\u8d22\u5e74\u7684\u7b2c\u4e8c\u5b63\u5ea6\u8d22\u62a5\uff0c\u516c\u53f8\u7b2c\u4e8c\u8d22\u5b63\u9500\u552e\u6536\u5165\u8fbe\u523011.2\u4ebf\u7f8e\u5143\uff0c\u76f8\u6bd4\u53bb\u5e74\u540c\u671f\u589e\u957f6%\uff0c\u8fd9\u4e00\u6210\u7ee9\u4e0e\u5e02\u573a\u9884\u671f\u76f8\u7b26\uff1b\u6bcf\u80a1\u6536\u76ca\u8fbe\u5230\u4e860.95\u7f8e\u5143\uff0c\u8f83\u4e0a\u4e00\u5e74\u540c\u671f\u589e\u957f\u4e8610%\uff0c\u8d85\u8fc7\u4e86\u5e02\u573a\u9884\u671f\u76840.93\u7f8e\u5143\uff1b\u540c\u65f6\uff0c\u6bdb\u5229\u7387\u4e0a\u5347\u81f343.6%\uff0c\u6bd4\u53bb\u5e74\u540c\u671f\u589e\u52a0\u4e86210\u4e2a\u57fa\u70b9\u3002\u6b64\u5916\uff0c\u5728\u8be5\u5b63\u5ea6\u5185\uff0c\u516c\u53f8\u8fd8\u901a\u8fc7\u56de\u8d2d\u80a1\u7968\u53ca\u53d1\u653e\u80a1\u606f\u7684\u65b9\u5f0f\u5411\u80a1\u4e1c\u8fd4\u8fd8\u4e86\u603b\u8ba13.4\u4ebf\u7f8e\u5143\u7684\u73b0\u91d1\u3002<br/><br/>\u5c55\u671b\u672a\u6765\uff0c\u516c\u53f8\u9884\u8ba1\u5168\u5e74\u7684\u9500\u552e\u603b\u989d\u5c06\u572843.9\u4ebf\u7f8e\u5143\u81f344.7\u4ebf\u7f8e\u5143\u4e4b\u95f4\uff0c\u8fd9\u610f\u5473\u7740\u5e74\u5ea6\u589e\u957f\u7387\u57282%\u52304%\u4e4b\u95f4\uff0c\u65e9\u524d\u7684\u9884\u6d4b\u8303\u56f4\u662f43.4\u4ebf\u7f8e\u5143\u81f344.3\u4ebf\u7f8e\u5143\uff1b\u5bf9\u4e8e\u5168\u5e74\u7684\u975eGAAP\u51c6\u5219\u4e0b\u7684\u8425\u4e1a\u5229\u6da6\uff0c\u7f57\u6280\u9884\u8ba1\u5c06\u57287.2\u4ebf\u7f8e\u5143\u81f37.5\u4ebf\u7f8e\u5143\u4e4b\u95f4\uff0c\u8fd9\u8868\u793a\u540c\u6bd4\u589e\u957f\u7387\u57283%\u81f37%\u4e4b\u95f4\uff0c\u800c\u4e4b\u524d\u7684\u9884\u4f30\u533a\u95f4\u4e3a7\u4ebf\u7f8e\u5143\u81f37.3\u4ebf\u7f8e\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255397453", "pub_date": "2024-10-22 10:32:02"}]}