7164\uff09\u8fdb\u53e3\u91cf\u5bf9\u4e8e\u79c1\u8425\u94a2\u94c1\u5236\u9020\u5546JSW\u94a2\u94c1\u3001\u5854\u5854\u94a2\u94c1\u548c\u4eac\u5fb7\u52d2\u897f\u5357\u94a2\u94c1\u516c\u53f8\uff08JSP\uff09\u800c\u8a00\u4f3c\u4e4e\u6b63\u5728\u5feb\u901f\u589e\u52a0\u3002\u8be5\u884c\u5206\u6790\u663e\u793a\uff0c\u8fd9\u4e09\u5bb6\u4f01\u4e1a\u572810\u6708\u81f311\u6708\u671f\u95f4\u7684\u8fdb\u53e3\u91cf\u540c\u6bd4\u589e\u957f\u4e86\u7ea625%\uff0c\u7136\u800c\uff0cSAIL\uff08\u5370\u5ea6\u94a2\u94c1\u7ba1\u7406\u5c40\uff09\u4ecd\u7136\u8868\u73b0\u4e0d\u4f73\uff08\u540c\u6bd4\u51cf\u5c115%\uff09\uff0c\u56e0\u6b64\u6574\u4f53\u8fdb\u53e3\u91cf\u589e\u957f\u8f83\u4e3a\u6e29\u548c\uff08\u540c\u6bd4\u589e\u52a06%\uff09\u3002\u5370\u5ea6\u524d\u4e03\u5927\u94a2\u94c1\u5236\u9020\u5546\u7684\u6210\u54c1\u94a2\u4ea7\u91cf\u5728\u4eca\u5e74\u8fc4\u4eca\u4e3a\u6b62\u7684\u589e\u957f\u4e5f\u8f83\u4e3a\u7f13\u6162\uff08\u540c\u6bd4\u589e\u957f1%\uff09\uff0c\u800c\u5341\u4e00\u6708\u4efd\u7684\u9700\u6c42\u4f3c\u4e4e\u53d7\u5230\u4e86NCR\u5730\u533a\uff08\u56fd\u5bb6\u9996\u90fd\u533a\uff09\u5efa\u7b51\u6d3b\u52a8\u7981\u4ee4\u4ee5\u5e94\u5bf9\u6c61\u67d3\u95ee\u9898\u7684\u5f71\u54cd\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0c\u6700\u8fd1\u51e0\u5468\uff0c\u5370\u5ea6\u56fd\u5185\u7684\u70ed\u8f67\u5377\uff08HRC\uff09\u548c\u87ba\u7eb9\u94a2\u4ef7\u683c\u4e5f\u6709\u6240\u4e0b\u964d\uff08-2%\uff09\uff0c\u7b2c\u4e09\u5b63\u5ea6\u7684\u6536\u76ca\u53ef\u80fd\u4f4e\u4e8e\u9884\u671f\u3002\u7136\u800c\uff0c\u7531\u4e8eHRC\u4ef7\u683c\u73b0\u5728\u6bd4\u8fdb\u53e3\u5e73\u4ef7\u4f4e2-3%\u7684\u6298\u6263\uff0c\u4e0b\u884c\u7a7a\u95f4\u4f3c\u4e4e\u6709\u9650\u3002\u6211\u4eec\u8ba4\u4e3a\uff0c\u968f\u7740\u9009\u4e3e\u548c\u5b63\u98ce\u5b63\u8282\u7684\u7ed3\u675f\uff0c\u94a2\u94c1\u9700\u6c42\u589e\u957f\u7684\u901f\u5ea6\u5e94\u8be5\u4f1a\u52a0\u5feb\u3002\u6b64\u5916\uff0c\u884c\u4e1a\u7684\u5e73\u5747\u51b6\u91d1\u7164\u5e93\u5b58\u7565\u4f4e\u4e8e\u56db\u5e74\u5e73\u5747\u6c34\u5e73\uff0c\u672a\u6765\u51e0\u4e2a\u6708\u53ef\u80fd\u9700\u8981\u589e\u52a0\u91c7\u8d2d\u3002\u6709\u5173\u4e2d\u56fd\u523a\u6fc0\u63aa\u65bd\u7684\u6d88\u606f\u589e\u591a\u4ee5\u53ca\u5370\u5ea6\u94a2\u94c1\u90e8\u53ef\u80fd\u8003\u8651\u5bf9\u94a2\u94c1\u8fdb\u53e3\u5f81\u6536\u4fdd\u62a4\u6027\u5173\u7a0e\u662f\u79ef\u6781\u7684\u50ac\u5316\u5242\uff0c\u800c\u94a2\u94c1\u5236\u9020\u5546\u4e13\u6ce8\u4e8e\u4f18\u5316\u51b6\u91d1\u7164\u6df7\u5408\u7269\u4ee5\u8282\u7701\u6210\u672c\u7684\u52aa\u529b\u4e5f\u53ef\u80fd\u63a8\u52a8\u6210\u672c\u8282\u7ea6\u3002<br/><br/>\u5728\u8be5\u884c\u8986\u76d6\u8303\u56f4\u5185\uff0c\u8be5\u884c\u504f\u597dJSW\u94a2\u94c1\u548c\u5854\u5854\u94a2\u94c1\uff08\u589e\u6301\uff09\uff0c\u800c\u5bf9\u4e8eSAIL\u5219\u4fdd\u6301\u89c2\u671b\uff08\u4e2d\u6027\uff09\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260382783", "pub_date": "2024-12-12 09:54:43"}, {"id": 260382782, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u91ce\u6751\u6599\u65e5\u672c\u673a\u5e8a\u8ba2\u5355\u660e\u5e74\u5bfbL\u578b\u5e95\u90e8 \u504f\u597d\u7ee7\u7eed\u5173\u6ce8\u4e0e\u56fd\u9632\u76f8\u5173\u80a1\u7968", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u91ce\u6751\u7814\u62a5\u6307\uff0c\u636e\u65e5\u672c\u673a\u5e8a\u5efa\u9020\u5546\u534f\u4f1a\u4e8e12\u670810\u65e5\u53d1\u5e03\u7684\u521d\u6b65\u6570\u636e\uff0c2024\u5e7411\u6708\u7684\u8ba2\u5355\u63a5\u6536\u603b\u989d\u4e3a1193\u4ebf\u65e5\u5143\uff08\u540c\u6bd4\u4e0a\u53473%\uff0c\u73af\u6bd4\u4e0b\u964d3%\uff1b\u7565\u9ad8\u4e8e\u8be5\u884c\u9884\u6d4b\u76841165\u4ebf\u65e5\u5143\uff09\u3002\u5c3d\u7ba1\u5728\u65e5\u672c\u4e3e\u529e\u4e86\u4e00\u573a\u91cd\u8981\u7684\u8d38\u6613\u5c55\uff0c\u4f46\u4f3c\u4e4e\u6ca1\u6709\u8db3\u591f\u7684\u5373\u65f6\u5f71\u54cd\u6765\u63d0\u5347\u8ba2\u5355\u6c34\u5e73\u3002\u7531\u4e8e\u524d\u4e00\u4e2a\u6708\u6765\u81ea\u7535\u5b50/\u7cbe\u5bc6\u5de5\u4e1a\u7684\u5927\u89c4\u6a21\u8ba2\u5355\uff0c\u6d77\u5916\u5e02\u573a\u8ba2\u5355\u73af\u6bd4\u4e0b\u964d\uff0c\u4f46\u4ece\u7edd\u5bf9\u6570\u503c\u6765\u770b\uff0c\u8ba2\u5355\u91cf\u4f3c\u4e4e\u662f\u7a33\u56fa\u7684\u3002\u533a\u57df\u548c\u884c\u4e1a\u7ec6\u5206\u7684\u8ba2\u5355\u6570\u636e\u5c06\u5305\u542b\u5728\u9884\u5b9a\u4e8e12\u670825\u65e5\u53d1\u5e03\u7684\u786e\u8ba4\u6570\u636e\u4e2d\u3002<br/><br/>\u8be5\u884c\u8ba4\u4e3a\uff0c2025\u5e74\u5c06\u662f\u5bfb\u627e\u7ed3\u675fL\u578b\u5e95\u90e8\u5e76\u8fce\u6765\u673a\u68b0\u8bbe\u5907\u5168\u9762\u5468\u671f\u6027\u56de\u5347\u7684\u4e00\u5e74\u3002\u4e0d\u8fc7\uff0c\u673a\u68b0\u7528\u6237\u53ef\u80fd\u5728\u4e0a\u534a\u5e74\u5bf9\u8d44\u672c\u652f\u51fa\u91c7\u53d6\u89c2\u671b\u6001\u5ea6\uff0c\u4ee5\u7b49\u5f85\u65b0\u4e00\u5c4a\u7f8e\u56fd\u653f\u5e9c\u653f\u7b56\u3001\u901a\u8d27\u81a8\u80c0\u548c\u5229\u7387\u7684\u660e\u786e\u6027\u3002<br/><br/>\u8be5\u884c\u9884\u8ba1\u6295\u8d44\u8005\u5c06\u7ee7\u7eed\u504f\u597d\u7a33\u5b9a\u589e\u957f\u7684\u80a1\u7968\uff0c\u5e76\u7ee7\u7eed\u5173\u6ce8\u4e0e\u56fd\u9632\u76f8\u5173\u7684\u80a1\u7968\u3002\u504f\u597d\u6295\u8d44\u4e0e\u91cd\u578b\u5de5\u4e1a\u76f8\u5173\u7684\u5b50\u884c\u4e1a\u3002\u4e88\u5ddd\u5d0e\u91cd\u5de5(7012)\u3001\u4e09\u83f1\u91cd\u5de5(7011)\u4e70\u5165\u8bc4\u7ea7\uff0c\u6307\u4e24\u5bb6\u516c\u53f8\u9ad8\u5ea6\u66b4\u9732\u4e8e\u56fd\u9632\u4e1a\u52a1\uff0c\u5e76\u5f3a\u8c03\u4e09\u83f1\u91cd\u5de5\u56e0\u5176\u5728GTCC\u7cfb\u7edf\u65b9\u9762\u7684\u6536\u76ca\u7a33\u5b9a\u6027\uff0c\u4ee5\u53ca\u5ddd\u5d0e\u91cd\u5de5\u56e0\u4e3a\u5728\u52a8\u529b\u8fd0\u52a8\u90e8\u95e8\u6700\u7cdf\u7cd5\u7684\u60c5\u51b5\u5df2\u7ecf\u8fc7\u53bb\u7684\u9884\u671f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260382782", "pub_date": "2024-12-12 09:54:45"}, {"id": 260382103, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u96c5\u8fea\u63a7\u80a1(01585)\u76d8\u521d\u6da84.81% \u745e\u94f6\u79f0\u5176\u53d7\u76ca\u4e8e\u4ee5\u65e7\u6362\u65b0\u653f\u7b56\u548c\u884c\u4e1a\u96c6\u4e2d\u5ea6\u7684\u63d0\u9ad8", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u96c5\u8fea\u63a7\u80a1(01585)\u76d8\u521d\u8d70\u5f3a\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da84.81%\uff0c\u62a513.5\u6e2f\u5143\uff0c\u6210\u4ea4\u989d7252\u4e07\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u4e2d\u4fe1\u5efa\u6295\u8bc1\u5238\u6307\u51fa\uff0c\u4f34\u968f4\u6708\u4ee5\u6765\u7684\u7cfb\u5217\u653f\u7b56\u53d1\u5e03\uff0c2024\u5e74\u4e24\u8f6e\u8f66\u677f\u5757\u5373\u8fdb\u5165\u4e86\u653f\u7b56\u9884\u671f\u4e0e\u73b0\u5b9e\u57fa\u672c\u9762\u4ea4\u7ec7\u5f71\u54cd\u80a1\u4ef7\u7684\u9636\u6bb5\u3002\u8fdb\u51652025\u5e74\uff0c\u5728\u884c\u4e1a\u6027\u653f\u7b56\u53d8\u5316\u4e0e\u6807\u51c6\u5207\u6362\u7684\u5927\u80cc\u666f\u4e0b\uff0c\u8fd9\u4e00\u7279\u5f81\u5927\u6982\u7387\u4ecd\u4f1a\u5ef6\u7eed\u3002\u56e0\u800c\uff0c\u57fa\u4e8e\u73b0\u6709\u653f\u7b56\u6846\u67b6\u53bb\u5408\u7406\u63a8\u6f14\u660e\u5e74\u884c\u4e1a\u57fa\u672c\u9762\u73b0\u5b9e\u4e0e\u5e02\u573a\u9884\u671f\u7684\u53d8\u5316\u8282\u594f\u5c06\u53d8\u5f97\u5c24\u4e3a\u91cd\u8981\u3002\u6574\u4f53\u6765\u770b\uff0c\u660e\u5e74\u4e24\u8f6e\u8f66\u884c\u4e1a\u201c\u8001\u201d\u4ea7\u54c1\u51b3\u5b9a\u57fa\u672c\u9762\uff0c\u201c\u65b0\u201d\u4ea7\u54c1\u672c\u8eab\u5c06\u51b3\u5b9a\u5e02\u573a\u9884\u671f\uff0c\u4e0a\u534a\u5e74\u6216\u8bb8\u662f\u4e00\u4e2a\u5f3a\u73b0\u5b9e\u548c\u9ad8\u9884\u671f\u76f8\u7ed3\u5408\u7684\u8f83\u597d\u65f6\u70b9\uff0c\u6807\u7684\u9009\u62e9\u4e0a\u4f20\u7edf\u9f99\u5934\u4ecd\u662f\u9996\u9009\u3002<br/><br/>\u745e\u94f6\u8868\u793a\uff0c\u96c5\u8fea\u5c06\u4ece2025\u5e74\u7684\u7535\u52a8\u4e24\u8f6e\u8f66\u56fd\u5bb6\u6807\u51c6\u5347\u7ea7\u3001\u4ee5\u65e7\u6362\u65b0\u653f\u7b56\u4ee5\u53ca\u884c\u4e1a\u96c6\u4e2d\u5ea6\u7684\u63d0\u9ad8\u4e2d\u53d7\u76ca\u3002\u66f4\u591a\u7684\u589e\u957f\u673a\u4f1a\u53d6\u51b3\u4e8e\u5176\u5728\u6d77\u5916\u5e02\u573a\u7a81\u7834\u7684\u80fd\u529b\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260382103", "pub_date": "2024-12-12 09:45:53"}, {"id": 260381455, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u821c\u5b87\u5149\u5b66\u79d1\u6280(02382)\u76d8\u521d\u6da84.38% \u8fd1\u65e5\u83b7\u6469\u6839\u5927\u901a\u589e\u63011.36\u4ebf\u6e2f\u5143\u80a1\u4efd", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u821c\u5b87\u5149\u5b66\u79d1\u6280(02382)\u76d8\u521d\u8d70\u5f3a\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da84.38%\uff0c\u62a567.9\u6e2f\u5143\uff0c\u6210\u4ea4\u989d6467\u4e07\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u6839\u636e\u8054\u4ea4\u6240\u6700\u65b0\u6743\u76ca\u62ab\u9732\u8d44\u6599\u663e\u793a\uff0c2024\u5e7412\u67086\u65e5\uff0c\u821c\u5b87\u5149\u5b66\u79d1\u6280\u83b7JPMorgan Chase &amp; Co.\u4ee5\u6bcf\u80a1\u5747\u4ef762.6187\u6e2f\u5143\u589e\u6301\u597d\u4ed3217\u4e07\u80a1\uff0c\u6d89\u8d44\u7ea61.36\u4ebf\u6e2f\u5143\u3002\u589e\u6301\u540e\uff0cJPMorgan Chase &amp; Co.\u6700\u65b0\u6301\u597d\u4ed3\u6570\u76ee\u4e3a56,174,480\u80a1\uff0c\u6301\u4ed3\u6bd4\u4f8b\u75314.93%\u4e0a\u5347\u81f35.13%\u3002<br/><br/>\u65e5\u524d\uff0c\u6469\u6839\u58eb\u4e39\u5229\u6307\uff0c\u821c\u5b87\u5149\u5b66\u79d1\u6280\u524d\u516c\u5e03\u4eca\u5e7411\u6708\u7ecf\u8425\u6570\u636e\uff0c\u6444\u50cf\u6a21\u7ec4(CCM)\u51fa\u8d27\u91cf\u8868\u73b0\u4ecd\u7136\u75b2\u5f31\uff0c\u624b\u673a\u6444\u50cf\u6a21\u7ec4\u540c\u6bd4\u4e0b\u8dcc\u8d85\u8fc728%\uff0c\u516c\u53f8\u89e3\u91ca\u662f\u7531\u4e8e\u671f\u5185\u4e13\u6ce8\u4e8e\u4e2d\u9ad8\u7aef\u9879\u76ee\uff0c\u4ee5\u53ca\u4ea7\u54c1\u7ed3\u6784\u8f83\u53bb\u5e74\u540c\u671f\u663e\u8457\u6539\u5584\u6240\u81f4\u3002\u5927\u6469\u6307\uff0c\u4ea7\u54c1\u5747\u4ef7(ASP)\u7684\u63d0\u5347\u5bf9\u5229\u6da6\u590d\u82cf\u81f3\u5173\u91cd\u8981\uff0c\u56e0\u6b64\u8c03\u6574\u4ea7\u54c1\u7ec4\u5408\u5c06\u4ecd\u662f\u821c\u5b87\u7684\u9996\u8981\u4efb\u52a1\uff0c\u76f8\u4fe1ASP\u53ca\u6574\u4f53\u5229\u6da6\u7387\u5c06\u9010\u6b65\u6539\u5584\u300211\u6708\u821c\u5b87\u624b\u673a\u955c\u5934\u51fa\u8d27\u91cf\u540c\u6bd4\u8dcc5.6%\uff0c\u5927\u6469\u5f62\u5bb9\u8868\u73b0\u4ecd\u5177\u97e7\u6027\uff0c\u6709\u4fe1\u5fc3\u53ef\u8d85\u8d8a\u516c\u53f8\u5168\u5e74\u76ee\u6807\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260381455", "pub_date": "2024-12-12 09:36:14"}, {"id": 260381457, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u9a6c\u53ef\u6570\u5b57\u79d1\u6280(01942)\u6298\u8ba9\u903e15%\u914d\u80a1 \u60df\u80a1\u4ef7\u53cd\u5411\u9ad8\u5f00\u8fd16%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9a6c\u53ef\u6570\u5b57\u79d1\u6280(01942)\u6298\u8ba9\u903e15%\u914d\u80a1\uff0c\u60df\u65e9\u76d8\u53cd\u5411\u9ad8\u5f005.98%\uff0c\u62a51.24\u6e2f\u5143\uff0c\u76d8\u524d\u6210\u4ea4\u989d266.6\u4e07\u6e2f\u5143\u3002<br/><br/>\u516c\u53f8\u516c\u5e03\uff0c\u4e8e2024\u5e7412\u670811\u65e5\uff0c\u8be5\u516c\u53f8\u62df\u5411Valiant Warrior Limited\u53d1\u884c\u7ea62.12\u4ebf\u80a1\u8ba4\u8d2d\u80a1\u4efd\uff0c\u8ba4\u8d2d\u4ef7\u4e3a\u6bcf\u80a1\u8ba4\u8d2d\u80a1\u4efd0.99\u6e2f\u5143\uff0c\u8ba4\u8d2d\u4ef7\u8f83\u4e0a\u4ea4\u6613\u65e5\u6536\u5e02\u4ef7\u6bcf\u80a11.17\u6e2f\u5143\u6298\u8ba9\u7ea615.38%\u3002<br/><br/>\u8ba4\u8d2d\u4e8b\u9879\u51c0\u7b79\u7ea62.1\u4ebf\u6e2f\u5143\uff0c\u7ea671.47%\u7528\u4e8e\u5411\u96c6\u56e2\u73b0\u6709\u878d\u8d44\u670d\u52a1\u4e1a\u52a1\u6ce8\u8d44\uff1b\u7ea623.82%\u7528\u4e8e\u5411\u96c6\u56e2\u8fd1\u671f\u6536\u8d2d\u7684\u653e\u503a\u4e1a\u52a1\u6ce8\u8d44\uff1b\u7ea64.71%\u7528\u4f5c\u4e00\u822c\u8425\u8fd0\u8d44\u91d1\u53ca\u4e00\u822c\u4f01\u4e1a\u7528\u9014\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260381457", "pub_date": "2024-12-12 09:36:47"}]}