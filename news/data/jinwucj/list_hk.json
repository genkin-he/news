27\u6d32\u4e3b\u8981\u80a1\u6307\u6089\u6570\u4f4e\u5f00\uff0c\u6b27\u6d32\u65af\u6258\u514b50\u6307\u6570\u8dcc0.11%\uff0c\u62a54913.55\u70b9\uff1b\u897f\u73ed\u7259IBEX35\u6307\u6570\u6da80.17%\uff0c\u62a511951.91\u70b9\uff1b\u6cd5\u56fdCAC40\u6307\u6570\u8dcc0.19%\uff0c\u62a57289.67\u70b9\uff1b\u610f\u5927\u5229\u5bcc\u65f6MIB\u6307\u6570\u6da80.20%\uff0c\u62a534153\u70b9\uff1b\u5fb7\u56fdDAX30\u6307\u6570\u6da80.17%\uff0c\u62a520250.05\u70b9\uff1b\u82f1\u56fd\u5bcc\u65f6100\u6307\u6570\u8dcc0.04%\uff0c\u62a58332.5\u70b9\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259670693", "pub_date": "2024-12-05 16:09:29"}, {"id": 259669586, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5c71\u897f\u8bc1\u5238\u9996\u4e88\u88d5\u5143\u96c6\u56e2(00551)\u201c\u4e70\u5165-B\u201d\u8bc4\u7ea7 \u9884\u8ba1\u5176\u5168\u5e74\u978b\u5c65\u51fa\u8d27\u91cf\u6309\u5e74\u589e\u4e2d\u53cc\u4f4d\u6570\u4ee5\u4e0a", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5c71\u897f\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u88d5\u5143\u96c6\u56e2(00551)\u4e3a\u5168\u7403\u6700\u5177\u89c4\u6a21\u7684\u54c1\u724c\u8fd0\u52a8\u978b\u548c\u4f11\u95f2\u978b\u5236\u9020\u5546\uff0c\u51ed\u501f\u6574\u5408\u4ea7\u4e1a\u94fe\u4e0a\u6e38\u978b\u6750\u539f\u6750\u6599\u73af\u8282\u3001\u9886\u5148\u7684\u4ea7\u54c1\u7814\u53d1\u80fd\u529b\uff0c\u4fdd\u6301\u884c\u4e1a\u978b\u5c65\u51fa\u8d27\u91cf\u7b2c\u4e00\u3002\u6839\u636e\u8be5\u884c\u4f30\u7b97\uff0c\u516c\u53f8\u5728\u8010\u514b\u548c\u963f\u8fea\u8fbe\u65af\u7684\u978b\u5c65\u91c7\u8d2d\u4efd\u989d\u5206\u522b\u4e3a 11%\u300114%\uff0c\u4e3a\u4e24\u5927\u54c1\u724c\u7684\u6838\u5fc3\u4f9b\u5e94\u5546\u3002\u4e14\u5ba2\u6237\u96c6\u4e2d\u5ea6\u5904\u4e8e\u884c\u4e1a\u9002\u4e2d\u6c34\u5e73\uff0c\u5bf9\u5355\u4e00\u5ba2\u6237\u4f9d\u8d56\u6709\u9650\u30022024 \u5e74\u884c\u4e1a\u8ba2\u5355\u6062\u590d\uff0c\u9884\u8ba1\u5168\u5e74\u978b\u5c65\u51fa\u8d27\u91cf\u6709\u671b\u8fbe\u5230 2.5 \u4ebf\u53cc\uff0c\u540c\u6bd4\u589e\u957f\u4e2d\u53cc\u4f4d\u6570\u4ee5\u4e0a\uff0c\u5458\u5de5\u4eba\u6570\u81ea2023\u5e74\u672b\u89e6\u5e95\u540e\uff0c\u8fde\u7eed\u4e09\u4e2a\u5b63\u5ea6\u56de\u5347\uff0c\u978b\u5c65\u51fa\u8d27\u91cf\u6709\u671b\u4f34\u968f\u8ba2\u5355\u9700\u6c42\u65fa\u76db\u3001\u65b0\u4ea7\u80fd\u6295\u4ea7\uff0c\u5b9e\u73b0\u53cc\u4f4d\u6570\u7a33\u5065\u589e\u957f\u3002\u4f34\u968f\u4e0d\u65ad\u7cbe\u8fdb\u751f\u4ea7\u6280\u672f\u3001\u4f18\u5316\u751f\u4ea7\u6548\u80fd\uff0c\u5bf9\u6bd4\u53cb\u5546\uff0c\u516c\u53f8\u5229\u6da6\u7387\u6709\u8fdb\u4e00\u6b65\u63d0\u5347\u7a7a\u95f4\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u9884\u8ba1\u516c\u53f82024-2026 \u5e74\u8425\u4e1a\u6536\u5165\u4e3a81.29\u300188.15\u300195.64 \u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f 3.0%/8.4%/8.5%\uff1b\u5f52\u6bcd\u51c0\u5229\u6da6\u4e3a4.50\u30015.17\u30015.75 \u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f 63.6%/14.8%/11.2%\u3002\u53c2\u8003\u6e2f\u80a1\u8fd0\u52a8\u670d\u9970\u5236\u9020\u5546\u9f99\u5934\u7533\u6d32\u56fd\u9645\u3001\u8fd0\u52a8\u7528\u54c1\u96f6\u552e\u5546\u6ed4\u640f\uff0c\u5206\u522b\u7ed9\u4e88\u516c\u53f8\u5236\u9020\u4e1a\u52a112 \u500d\u4f30\u503c\uff0c\u96f6\u552e\u4e1a\u52a17 \u500d\u4f30\u503c\uff0c\u5408\u7406\u5e02\u503c\u4e3a 418 \u4ebf\u6e2f\u5143\uff0c\u8f83 12 \u67083 \u65e5\u76f8\u6bd4\uff0c\u5177\u590748%\u7684\u4e0a\u6da8\u7a7a\u95f4\u3002\u516c\u53f8\u540c\u65f6\u5e03\u5c40\u8fd0\u52a8\u978b\u5c65\u4ea7\u4e1a\u94fe\u4e0a\u6e38\u5236\u9020\u3001\u4e0b\u6e38\u96f6\u552e\u73af\u8282\uff0c\u770b\u597d\u516c\u53f8\u5236\u9020\u4e1a\u52a1\u65b0\u4ea7\u80fd\u6301\u7eed\u6269\u5f20\u3001\u8ba2\u5355\u6062\u590d\u7a33\u5065\u589e\u957f\u3001\u5229\u6da6\u7387\u8fdb\u4e00\u6b65\u4fee\u590d\uff0c\u671f\u5f85\u516c\u53f8\u96f6\u552e\u4e1a\u52a1\u5728\u7ebf\u4e0b\u5ba2\u6d41\u56de\u6696\u540e\uff0c\u5229\u6da6\u7387\u5f39\u6027\u3002\u9996\u6b21\u8986\u76d6\uff0c\u7ed9\u4e88\u201c\u4e70\u5165-B\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259669586", "pub_date": "2024-12-05 16:02:27"}, {"id": 259668704, "title": "\u822a\u7a7a\u80a1\u5c3e\u76d8\u666e\u904d\u626c\u5347 \u4e2d\u56fd\u56fd\u822a(00753)\u6da83.53% \u6d77\u901a\u56fd\u9645\u770b\u597d\u672a\u6765\u822a\u7a7a\u884c\u4e1a\u957f\u671f\u6295\u8d44\u903b\u8f91\u4e0d\u53d8", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u822a\u7a7a\u80a1\u5c3e\u76d8\u666e\u904d\u626c\u5347\uff0c\u4e2d\u56fd\u98de\u673a\u79df\u8d41(01848)\u6da84.64%\uff0c\u4e2d\u56fd\u56fd\u822a(00753)\u6da83.53%\uff0c\u4e2d\u56fd\u5357\u822a(01055)\u6da83.04%\uff0c\u4e2d\u56fd\u4e1c\u822a(00670)\u6da82.55%\u3002</p><p>\u6d77\u901a\u56fd\u9645\u8868\u793a\uff0c\u6625\u8fd0\u3001\u6691\u8fd0\u65fa\u5b63\u56fd\u5185\u4f9b\u7ed9\u3001\u9700\u6c42\u540c\u6bd419\u5e74\u5747\u5927\u5e45\u589e\u957f\uff0c\u521a\u6027\u7684\u51fa\u884c\u9700\u6c42\u5e26\u52a8\u822a\u53f8\u91cf\u7aef\u7a33\u5b9a\u589e\u957f\u3002\u4eca\u5e74\u4ee5\u6765\u56fd\u9645\u822a\u73ed\u8fdb\u4e00\u6b65\u4fee\u590d\uff0c\u968f\u7740\u56fd\u9645\u5173\u7cfb\u7f13\u548c\u3001\u51fa\u5165\u5883\u7b7e\u8bc1\u7b49\u653f\u7b56\u9010\u6b65\u53cb\u597d\uff0c\u8be5\u884c\u9884\u8ba124\u5e74\u56fd\u9645\u822a\u7a7a\u51fa\u884c\u9700\u6c42\u5c06\u8fdb\u4e00\u6b65\u56de\u6696\u3002\u77ed\u671f\uff0c\u8be5\u884c\u8ba4\u4e3a\u56fd\u5e86\u5047\u671f\u7b49\u56e0\u79c1\u51fa\u884c\u9700\u6c42\u65fa\u76db\uff0c\u56fd\u9645\u7ebf\u4f9b\u9700\u52a0\u901f\u4fee\u590d\uff0c\u4f46\u6de1\u5b63\u5546\u52a1\u51fa\u884c\u5e73\u6de1\u6216\u62d6\u7d2f\u6574\u4f53\u6062\u590d\u8fdb\u5ea6\uff0c\u6574\u4f53\u53d7\u5236\u4e8e\u7ecf\u6d4e\uff0c\u4ef7\u683c\u8868\u73b0\u6216\u53d7\u5f71\u54cd\u3002\u957f\u671f\u770b\u6211\u56fd\u822a\u7a7a\u516c\u53f8\u8fd0\u529b\u5f15\u8fdb\u589e\u901f\u653e\u7f13\u786e\u5b9a\u6027\u8f83\u9ad8\uff1b\u51fa\u884c\u4fe1\u5fc3\u6301\u7eed\u4fee\u590d\uff0c\u770b\u597d\u672a\u6765\u822a\u7a7a\u884c\u4e1a\u957f\u671f\u6295\u8d44\u903b\u8f91\u4e0d\u53d8\uff08\u5373\u4f9b\u9700\u683c\u5c40\u6539\u5584\u3001\u7968\u4ef7\u5e02\u573a\u5316\uff09\uff0c\u9759\u5f85\u7ecf\u6d4e\u56de\u6696\u3002\u8be5\u884c\u9884\u8ba124\u5e74\u822a\u53f8\u76c8\u5229\u4e2d\u67a2\u6709\u671b\u62ac\u5347\uff0c\u5173\u6ce8\u822a\u7a7a\u677f\u5757\u6295\u8d44\u673a\u4f1a\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259668704", "pub_date": "2024-12-05 15:56:10"}, {"id": 259668266, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4e2d\u4fe1\u5efa\u6295\u7ef4\u6301\u6e23\u6253\u96c6\u56e2(02888)\u4e70\u5165\u8bc4\u7ea7 \u6307\u5176\u517c\u5177\u6781\u5f3a\u7684\u57fa\u672c\u9762\u6210\u957f\u6027\u548c\u6301\u7eed\u589e\u957f\u7684\u7ea2\u5229\u5c5e\u6027", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u4fe1\u5efa\u6295\u53d1\u7814\u62a5\u6307\uff0c\u6e23\u6253\u96c6\u56e2(02888)\u5bf9\u8d22\u5bcc\u7ba1\u7406\u4e1a\u52a1\u7684\u4e2d\u957f\u671f\u76ee\u6807\u8bbe\u5b9a\u96c4\u5fc3\u52c3\u52c3\uff1a2025-2029\u5e74\u51c0\u65b0\u589e\u8d44\u91d1\u8fbe2000\u4ebf\u7f8e\u5143\u3001\u8d22\u5bcc\u7ba1\u7406\u6536\u5165CAGR\u4fdd\u6301\u53cc\u4f4d\u6570\u589e\u957f\u3002\u51ed\u501f\u957f\u5468\u671f\u7684\u5ba2\u6237\u670d\u52a1\u3001\u5168\u7403\u5316\u7f51\u7edc\u53ca\u4e13\u4e1a\u7684\u8d22\u5bcc\u7ba1\u7406\u80fd\u529b\uff0c\u6e23\u6253\u4e3b\u8981\u805a\u7126\u5bcc\u88d5\u5ba2\u7fa4\uff0c\u7279\u522b\u662f\u8de8\u5883\u5ba2\u6237\u7684\u589e\u957f\u3002\u5bcc\u88d5\u5ba2\u7fa4\u662f\u5178\u578b\u7684\u4f4e\u6210\u672c\u3001\u9ad8\u56de\u62a5\u4e1a\u52a1\u3002\u5728\u5168\u7403\u5316\u7ecf\u8425\u7f51\u7edc\u7684\u57fa\u7840\u4e0a\uff0c\u53d7\u76ca\u4e8e\u4e2d\u56fd\u201c\u8d22\u5bcc\u51fa\u6d77\u201d\u548c\u65fa\u76db\u589e\u957f\u7684\u5370\u5ea6\u5e02\u573a\u4e24\u5927\u6838\u5fc3\u589e\u91cf\uff0c\u6e23\u6253\u5bcc\u88d5\u5ba2\u7fa4\u7684\u53ef\u6301\u7eed\u589e\u957f\u6709\u4fdd\u969c\u3002\u8d22\u5bcc\u5168\u7403\u5316\u914d\u7f6e\u8d8b\u52bf\u4e0b\uff0c\u6e23\u6253\u8d22\u5bcc\u7ba1\u7406\u4e1a\u52a1\u8d8b\u52bf\u5f3a\u52b2\uff0c\u524d\u666f\u5149\u660e\u3002\u53e0\u52a0\u4ea4\u6613\u94f6\u884c\u7b49\u4e1a\u52a1\u5bf9\u51b2\u5229\u7387\u4e0b\u884c\u5f71\u54cd\uff0c\u6e23\u6253\u6709\u671b\u5728\u672c\u8f6e\u964d\u606f\u5468\u671f\u5185\u5b9e\u73b0ROTE\u7684\u9006\u52bf\u63d0\u5347\uff0c\u517c\u5177\u6781\u5f3a\u7684\u57fa\u672c\u9762\u6210\u957f\u6027\u548c\u6301\u7eed\u589e\u957f\u7684\u7ea2\u5229\u5c5e\u6027\uff0c\u914d\u7f6e\u4ef7\u503c\u7a81\u51fa\u3002<br/><br/>\u8be5\u884c\u9884\u8ba12024-26\u5e74\u8425\u6536\u589e\u901f\u5206\u522b\u4e3a10%\u30014.8%\u30016.1%\uff0c\u5229\u6da6\u589e\u901f21.0%\u30016.8%\u300116.9%\u3002\u9884\u8ba12024-26\u5e74ROTE\u5c06\u9010\u6b65\u63d0\u5347\u81f313%\u7684\u6c34\u5e73\uff0c\u5f53\u524d\u4f30\u503c0.8\u500d24\u5e74P/TB\uff080.69\u500d24\u5e74P/B\uff09\uff0c\u7ef4\u6301\u4e70\u5165\u8bc4\u7ea7\u548c\u94f6\u884c\u677f\u5757\u9996\u63a8\u3002&nbsp;</p>", "link": "https://sky.szfiu.com/info/hk/details/259668266", "pub_date": "2024-12-05 15:54:01"}, {"id": 259667106, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6d77\u901a\u8bc1\u5238\u7ef4\u6301\u963f\u91cc\u5df4\u5df4(09988)\u4f18\u5927\u4e8e\u5e02\u8bc4\u7ea7 \u6307\u5176\u7b2c\u4e8c\u8d22\u5b63\u672c\u5730\u751f\u6d3b\u96c6\u56e2\u4e8f\u635f\u540c\u6bd4\u663e\u8457\u6536\u7a84", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6d77\u901a\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u963f\u91cc\u5df4\u5df4(09988)2025\u8d22\u5e74\u4e8c\u5b63\u5ea6\u5b9e\u73b0\u6536\u51652365.03\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f5%\u3002\u7ecf\u8425\u5229\u6da6352.46\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f5%\uff0c\u7ecf\u8c03\u6574EBITA405.61\u4ebf\u5143\uff0c\u540c\u6bd4\u4e0b\u964d5%\uff0cNon-GAAP\u51c0\u5229365.18\u4ebf\u5143\uff0c\u540c\u6bd4\u4e0b\u964d9%\u3002<br/><br/>\u8be5\u884c\u6307\uff0c2Q25FY\u6dd8\u5929\u96c6\u56e2\u5408\u8ba1\u6536\u5165989.94\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f1%\uff1b\u5176\u4e2d\u5ba2\u6237\u7ba1\u7406\u6536\u5165703.64\u4ebf\u5143\uff0c\u540c\u6bd4\u589e2%\u3002\u5206\u90e8\u770b\uff0c\u4e2d\u56fd\u96f6\u552e\u5546\u4e1a\u6536\u5165930.08\u4ebf\u5143\uff0c\u8f832Q24FY\u65e0\u53d8\u5316\uff1b\u4e2d\u56fd\u6279\u53d1\u5546\u4e1a\u6536\u516559.86\u4ebf\u5143\uff0c\u540c\u6bd4\u589e18%\u3002\u6dd8\u5929\u96c6\u56e2\u7ecf\u8c03\u6574EBITA\u5408\u8ba1445.90\u4ebf\u5143\uff0c\u540c\u6bd4\u4e0b\u964d5%\uff0c\u7ecf\u8c03\u6574EBITA\u5229\u6da6\u738745.04%\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0c2Q25FY\u672c\u5730\u751f\u6d3b\u96c6\u56e2\u6536\u5165177.25\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f14%\uff0c\u4e3b\u8981\u662f\u7531\u4e8e\u9ad8\u5fb7\u548c\u997f\u4e86\u4e48\u7684\u8ba2\u5355\u589e\u957f\uff0c\u4ee5\u53ca\u5e02\u573a\u8425\u9500\u670d\u52a1\u6536\u5165\u589e\u957f\u6240\u5e26\u52a8\u3002\u672c\u5b63\u5ea6\uff0c\u53d7\u60e0\u4e8e\u8fd0\u8425\u6548\u7387\u6539\u5584\u548c\u4e1a\u52a1\u89c4\u6a21\u63d0\u5347\uff0c\u672c\u5730\u751f\u6d3b\u96c6\u56e2\u4e8f\u635f\u540c\u6bd4\u663e\u8457\u6536\u7a84\u3002\u7ecf\u8c03\u6574EBITA\u4e8f\u635f3.91\u4ebf\u5143\u3002\u7ecf\u8c03\u6574EBITA\u5229\u6da6\u7387\u4e3a-2.21%\uff0c\u8f832Q24FY\u4e0a\u534714.27pct\u3002<br/><br/>\u8be5\u884c\u9884\u8ba12025FY-2027FY\u5f52\u5c5e\u4e8e\u666e\u901a\u80a1\u80a1\u4e1c\u7684Non-GAAP\u51c0\u5229\u6da6\u54041576\u30011684\u30011770\u4ebf\u5143\uff0c\u7ed9\u4ee5\u516c\u53f82025FY\u6574\u4f53\u5408\u7406\u5e02\u503c\u533a\u95f42.09\u4e07\u4ebf-2.40\u4e07\u4ebf\u6e2f\u5143\uff0c\u5408\u7406\u4ef7\u503c\u533a\u95f4H\u80a1110-126\u6e2f\u5143/\u80a1\u3002\u8be5\u884c\u7ef4\u6301\u516c\u53f8\u4f18\u5927\u4e8e\u5e02\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259667106", "pub_date": "2024-12-05 15:45:04"}, {"id": 259666818, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6d77\u901a\u56fd\u9645\u6599\u4eca\u5e74\u822a\u53f8\u76c8\u5229\u4e2d\u67a2\u6709\u671b\u62ac\u5347", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6d77\u901a\u56fd\u9645\u8868\u793a\uff0c\u6625\u8fd0\u3001\u6691\u8fd0\u65fa\u5b63\u56fd\u5185\u4f9b\u7ed9\u3001\u9700\u6c42\u540c\u6bd419\u5e74\u5747\u5927\u5e45\u589e\u957f\uff0c\u521a\u6027\u7684\u51fa\u884c\u9700\u6c42\u5e26\u52a8\u822a\u53f8\u91cf\u7aef\u7a33\u5b9a\u589e\u957f\u3002\u4eca\u5e74\u4ee5\u6765\u56fd\u9645\u822a\u73ed\u8fdb\u4e00\u6b65\u4fee\u590d\uff0c\u968f\u7740\u56fd\u9645\u5173\u7cfb\u7f13\u548c\u3001\u51fa\u5165\u5883\u7b7e\u8bc1\u7b49\u653f\u7b56\u9010\u6b65\u53cb\u597d\uff0c\u8be5\u884c\u9884\u8ba124\u5e74\u56fd\u9645\u822a\u7a7a\u51fa\u884c\u9700\u6c42\u5c06\u8fdb\u4e00\u6b65\u56de\u6696\u3002</p><p>\u77ed\u671f\uff0c\u8be5\u884c\u8ba4\u4e3a\u56fd\u5e86\u5047\u671f\u7b49\u56e0\u79c1\u51fa\u884c\u9700\u6c42\u65fa\u76db\uff0c\u56fd\u9645\u7ebf\u4f9b\u9700\u52a0\u901f\u4fee\u590d\uff0c\u4f46\u6de1\u5b63\u5546\u52a1\u51fa\u884c\u5e73\u6de1\u6216\u62d6\u7d2f\u6574\u4f53\u6062\u590d\u8fdb\u5ea6\uff0c\u6574\u4f53\u53d7\u5236\u4e8e\u7ecf\u6d4e\uff0c\u4ef7\u683c\u8868\u73b0\u6216\u53d7\u5f71\u54cd\u3002\u957f\u671f\u770b\u6211\u56fd\u822a\u7a7a\u516c\u53f8\u8fd0\u529b\u5f15\u8fdb\u589e\u901f\u653e\u7f13\u786e\u5b9a\u6027\u8f83\u9ad8\uff1b\u51fa\u884c\u4fe1\u5fc3\u6301\u7eed\u4fee\u590d\uff0c\u770b\u597d\u672a\u6765\u822a\u7a7a\u884c\u4e1a\u957f\u671f\u6295\u8d44\u903b\u8f91\u4e0d\u53d8\uff08\u5373\u4f9b\u9700\u683c\u5c40\u6539\u5584\u3001\u7968\u4ef7\u5e02\u573a\u5316\uff09\uff0c\u9759\u5f85\u7ecf\u6d4e\u56de\u6696\u3002\u8be5\u884c\u9884\u8ba124\u5e74\u822a\u53f8\u76c8\u5229\u4e2d\u67a2\u6709\u671b\u62ac\u5347\uff0c\u5173\u6ce8\u822a\u7a7a\u677f\u5757\u6295\u8d44\u673a\u4f1a\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259666818", "pub_date": "2024-12-05 15:43:26"}, {"id": 259665027, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6469\u6839\u58eb\u4e39\u5229\uff1a\u97e9\u56fd\u653f\u6cbb\u98ce\u6ce2\u5bf9\u8d27\u5e01\u653f\u7b56\u5f71\u54cd\u6709\u9650", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6469\u6839\u58eb\u4e39\u5229\u5728\u5176\u6700\u65b0\u7684\u7814\u7a76\u62a5\u544a\u4e2d\u5206\u6790\u4e86\u97e9\u56fd\u653f\u6cbb\u98ce\u6ce2\u5bf9\u8d27\u5e01\u653f\u7b56\u7684\u5f71\u54cd\u3002\u62a5\u544a\u6307\u51fa\uff0c\u5c3d\u7ba1\u97e9\u56fd\u7ecf\u5386\u4e86\u77ed\u6682\u7684\u653f\u6cbb\u52a8\u8361\uff0c\u4f46\u97e9\u56fd\u592e\u884c\uff08BoK\uff09\u884c\u957fRhee\u8ba4\u4e3a\u8fd9\u4e00\u4e8b\u4ef6\u5bf9\u57fa\u672c\u9762\u7ecf\u6d4e\u7684\u5f71\u54cd\u6709\u9650\u3002\u4ed6\u5f3a\u8c03\u97e9\u56fd\u7684\u7ecf\u6d4e\u52a8\u6001\u53ef\u4ee5\u4e0e\u653f\u6cbb\u52a8\u6001\u5206\u79bb\uff0c\u5e76\u8bc4\u4f30\u4e86\u4e8b\u4ef6\u53d1\u751f\u540e\u91d1\u878d\u5e02\u573a\u7684\u53cd\u5e94\u662f\u53d7\u5230\u826f\u597d\u63a7\u5236\u7684\uff0c\u5e02\u573a\u7a33\u5b9a\u63aa\u65bd\u8fc5\u901f\u5230\u4f4d\u3002<br/>\u6469\u6839\u58eb\u4e39\u5229\u7ef4\u6301\u5176\u89c2\u70b9\uff0c\u5373BoK\u5728\u660e\u5e74\u7684\u964d\u606f\u6b65\u4f10\u5c06\u662f\u9002\u5ea6\u7684\u3002\u8003\u8651\u5230\u5f53\u5730\u653f\u6cbb\u4e0d\u786e\u5b9a\u6027\u589e\u52a0\uff0cBoK\u53ef\u80fd\u4f1a\u91c7\u53d6\u66f4\u52a0\u8c28\u614e\u7684\u7acb\u573a\uff0c\u7279\u522b\u662f\u5728\u5916\u90e8\u98ce\u9669\uff08EX risks\uff09\u4e0a\u5347\u7684\u60c5\u51b5\u4e0b\u3002\u62a5\u544a\u4e2d\u63d0\u5230\u7684\u6570\u636e\u663e\u793a\uff0cBoK\u5bf9\u7ecf\u6d4e\u7684\u6700\u65b0\u5b8f\u89c2\u9884\u6d4b\u5e76\u672a\u53d7\u5230\u97e9\u56fd\u6700\u65b0\u653f\u6cbb\u4e8b\u4ef6\u7684\u5f71\u54cd\u3002\u5177\u4f53\u6765\u770b\uff0cBoK\u5bf92024\u5e74\u81f32026\u5e74\u7684\u7ecf\u6d4e\u589e\u957f\u9884\u6d4b\u3001CPI\u901a\u80c0\u9884\u6d4b\u548c\u6838\u5fc3\u901a\u80c0\u9884\u6d4b\u5747\u672a\u6709\u663e\u8457\u53d8\u5316\u3002</p><p>\u6b64\u5916\uff0c\u6469\u6839\u58eb\u4e39\u5229\u9884\u8ba1\uff0c\u97e9\u56fd\u4e0e\u7f8e\u56fd\u4e4b\u95f4\u7684\u653f\u7b56\u5229\u7387\u5dee\u5f02\u5c06\u4fdd\u6301\u7a33\u5b9a\uff0cBoK\u7684\u653f\u7b56\u5229\u7387\u9884\u8ba1\u5c06\u4ee5\u4e00\u4e2a\u9002\u5ea6\u7684\u6b65\u4f10\u4e0b\u964d\u3002\u8fd9\u4e9b\u5206\u6790\u8868\u660e\uff0c\u5c3d\u7ba1\u653f\u6cbb\u98ce\u6ce2\u5e26\u6765\u4e86\u4e00\u5b9a\u7684\u4e0d\u786e\u5b9a\u6027\uff0c\u4f46\u6469\u6839\u58eb\u4e39\u5229\u8ba4\u4e3a\u5176\u5bf9\u97e9\u56fd\u8d27\u5e01\u653f\u7b56\u7684\u5f71\u54cd\u6709\u9650\uff0cBoK\u5c06\u7ee7\u7eed\u6309\u7167\u65e2\u5b9a\u7684\u8def\u5f84\u8fdb\u884c\u653f\u7b56\u8c03\u6574\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259665027", "pub_date": "2024-12-05 15:31:00"}]}