77\u590d\u65e6(01385)\u8ddf\u6da80.94%\u3002\u4e2d\u4fe1\u8bc1\u5238\u8868\u793a\uff0c2024\u5e7412\u67083\u65e5\uff0c\u4e2d\u56fd\u534a\u5bfc\u4f53/\u6c7d\u8f66\u5de5\u4e1a/\u4e92\u8054\u7f51/\u901a\u4fe1\u4f01\u4e1a\u56db\u5927\u884c\u4e1a\u534f\u4f1a\u96c6\u4f53\u53d1\u5e03\u58f0\u660e\uff0c\u9488\u5bf9\u7f8e\u56fd\u5bf9\u534e\u91c7\u53d6\u51fa\u53e3\u9650\u5236\u8868\u793a\u575a\u51b3\u53cd\u5bf9\uff0c\u8ba4\u4e3a\u7f8e\u56fd\u76f8\u5173\u82af\u7247\u4ea7\u54c1\u4e0d\u518d\u5b89\u5168\u3001\u4e0d\u518d\u53ef\u9760\uff0c\u547c\u5401\u79ef\u6781\u4f7f\u7528\u5185\u5916\u8d44\u4f01\u4e1a\u5728\u534e\u751f\u4ea7\u5236\u9020\u7684\u82af\u7247\u3002\u8be5\u884c\u8ba4\u4e3a\uff0c\u56db\u5927\u884c\u4e1a\u534f\u4f1a\u7684\u547c\u5401\u5177\u6709\u98ce\u5411\u5f15\u9886\u4f5c\u7528\uff0c\u540e\u7eed\u5176\u4ed6\u884c\u4e1a\u4e5f\u6709\u671b\u8ddf\u8fdb\uff0c\u56fd\u5185\u534a\u5bfc\u4f53\u4ea7\u4e1a\u6574\u4f53\u56fd\u4ea7\u5316\u8282\u594f\u6709\u671b\u8fdb\u4e00\u6b65\u52a0\u5feb\uff0c\u6b64\u5916\u5236\u9020\u73af\u8282\u4e5f\u6709\u671b\u53d7\u76ca\u3002<br/><br/>\u7164\u70ad\u80a1\u591a\u6570\u9006\u5e02\u4e0a\u884c\uff0c\u4e2d\u7164\u80fd\u6e90(01898)\u6da84.3%\uff0c\u4e2d\u56fd\u795e\u534e(01088)\u6da82.,91%\uff0c\u4e2d\u56fd\u79e6\u53d1(00866)\u6da82.9%\uff0c\u529b\u91cf\u53d1\u5c55(01277)\u6da82.88%\uff0c\u5156\u77ff\u80fd\u6e90(01171)\u6da81.86%\u3002\u5efa\u94f6\u56fd\u9645\u53d1\u7814\u62a5\u6307\uff0c\u53d7\u5230\u5b63\u8282\u6027\u53d6\u6696\u9700\u6c42\u589e\u52a0\u4ee5\u53ca\u4e2d\u56fd\u7535\u529b\u516c\u53f8\u5e93\u5b58\u5929\u6570\u51cf\u5c11\u7684\u63a8\u52a8\uff0c\u8be5\u884c\u9884\u8ba1\u7b2c\u56db\u5b63\u5ea6\u70ed\u7164\u4ef7\u683c\u5c06\u5728\u5e74\u5e95\u9010\u6e10\u6062\u590d\u3002\u5bf9\u4e8e\u660e\u5e74\uff0c\u57fa\u4e8e\u6539\u5584\u7684\u7ecf\u6d4e\u72b6\u51b5\u548c\u5168\u56fd\u8303\u56f4\u5185\u7684\u7164\u70ad\u751f\u4ea7\u63a7\u5236\uff0c\u8be5\u884c\u9884\u671f\u70ed\u7164\u4ef7\u683c\u5c06\u6e29\u548c\u4e0a\u6da85%\uff0c\u8fbe\u5230\u6bcf\u5428\u4eba\u6c11\u5e01905\u5143\u3002\u8003\u8651\u5230\u8fd1\u671f\u7164\u70ad\u4ef7\u683c\u7684\u8868\u73b0\u4f4e\u4e8e\u9884\u671f\uff0c\u5c062024F\u548c2025F\u7684\u70ed\u7164\u4ef7\u683c\u9884\u6d4b\u5206\u522b\u4e0b\u8c03\u81f3865\u5143/\u5428\u548c905\u5143/\u5428\uff0c\u6bd4\u4e4b\u524d\u7684\u9884\u6d4b\u4f4e21%\u548c25%\u3002\u5047\u8bbe\u4e2d\u56fd\u5bf9\u7164\u70ad\u751f\u4ea7\u7684\u9650\u5236\u4ecd\u7136\u5b58\u5728\uff0c\u8be5\u884c\u9884\u8ba1\u4e2d\u56fd\u70ed\u7164\u4f9b\u5e94\u5c06\u540c\u6bd4\u589e\u957f3.4%\uff0c\u4e3b\u8981\u7531\u8fdb\u53e3\u91cf\u540c\u6bd4\u589e\u957f10%\u6240\u9a71\u52a8\u3002\u9274\u4e8e\u76ee\u524d\u70ed\u7164\u4f9b\u4e0d\u5e94\u6c42\uff0c\u8ba1\u7b97\u51fa\u7ea61.4\u4ebf\u5428\u7684\u4f9b\u5e94\u7f3a\u53e3\uff0c\u8fd9\u5c06\u9ad8\u4e8e2024\u5e74\u76847700\u4e07\u5428\u7f3a\u53e3\u3002<br/><br/>\u4e2a\u80a1\u65b9\u9762\uff0c\u201c\u8c37\u5b50\u201d\u7ecf\u6d4e\u7206\u706b\uff0c\u540d\u521b\u4f18\u54c1(09896)\u7eed\u53476.12%\uff0c\u8be5\u80a1\u8fd18\u4e2a\u4ea4\u6613\u65e5\u7d2f\u8ba1\u6da8\u5e45\u8d8550%\u3002\u6709\u673a\u6784\u79f0\uff0c2019\u5e74\u4e2d\u56fd\u6cdb\u4e8c\u6b21\u5143\u53ca\u5468\u8fb9\u5e02\u573a\u89c4\u6a21\u8fbe2983\u4ebf\u5143\uff0c\u9884\u8ba12024\u5e74\u63d0\u5347\u81f35977\u4ebf\u5143\uff0c2029\u5e74\u5219\u6709\u671b\u8fbe\u52308344\u4ebf\u5143\u3002\u82b1\u65d7\u8fd1\u65e5\u7814\u62a5\u6307\uff0c\u4e88\u540d\u521b\u4f18\u54c1\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0c\u76ee\u6807\u4ef752.5\u6e2f\u5143\u3002\u7ba1\u7406\u5c42\u9884\u8ba1\uff0c\u968f\u7740\u6d77\u5916\u5e02\u573a\u7684\u9ad8\u9500\u552e\u589e\u957f\u548c\u5229\u6da6\u6269\u5f20\uff0c2025\u5e74\u7684\u9500\u552e\u548c\u51c0\u5229\u6da6\u540c\u6bd4\u589e\u957f\u5c06\u52a0\u901f\u3002\u7ba1\u7406\u5c42\u9884\u8ba1\u96c6\u56e2\u6536\u5165\u57282024\u5e74\u7b2c\u56db\u5b63\u5ea6\u540c\u6bd4\u589e\u957f25-30%\uff0c\u5f53\u4e2d\u5305\u62ec\u9884\u8ba1\u6d77\u5916\u9500\u552e\u5c06\u540c\u6bd4\u589e\u957f45-50%;\u9884\u8ba1\u4e2d\u56fdMiniso\u7684\u9500\u552e\u5c06\u540c\u6bd4\u589e\u957f\u4f4e\u4e2a\u4f4d\u6570\u767e\u5206\u6bd4\uff0c\u5e76\u5728\u7b2c\u56db\u5b63\u5ea6\u65b0\u589e76\u5bb6\u95e8\u5e97;\u9884\u8ba1Top Toy\u9500\u552e\u5c06\u540c\u6bd4\u589e\u957f50-55%\uff0c\u5e76\u5728\u7b2c\u56db\u5b63\u65b0\u589e14\u5bb6\u95e8\u5e97\u3002<br/><br/>\u4e2d\u56fd\u77f3\u58a8(02237)\u65e9\u76d8\u80a1\u4ef7\u5927\u5e45\u8d70\u9ad8\uff0c\u534a\u65e5\u6da8\u5e4528.77%\u3002\u5546\u52a1\u90e83\u65e5\u53d1\u5e03\u516c\u544a\uff0c\u51b3\u5b9a\u52a0\u5f3a\u76f8\u5173\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u51fa\u53e3\u7ba1\u5236\u3002\u6839\u636e\u516c\u544a\uff0c\u7981\u6b62\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u519b\u4e8b\u7528\u6237\u6216\u519b\u4e8b\u7528\u9014\u51fa\u53e3\u3002\u539f\u5219\u4e0a\u4e0d\u4e88\u8bb8\u53ef\u9553\u3001\u9517\u3001\u9511\u3001\u8d85\u786c\u6750\u6599\u76f8\u5173\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u51fa\u53e3\uff1b\u5bf9\u77f3\u58a8\u4e24\u7528\u7269\u9879\u5bf9\u7f8e\u56fd\u51fa\u53e3\uff0c\u5b9e\u65bd\u66f4\u4e25\u683c\u7684\u6700\u7ec8\u7528\u6237\u548c\u6700\u7ec8\u7528\u9014\u5ba1\u67e5\u3002<br/><br/>\u5e73\u8bc1\u8bc1\u5238\u8868\u793a\uff0c\u6e2f\u80a1\u53cd\u5f39\u4ecd\u6709\u671b\u5ef6\u7eed\uff0c\u5efa\u8bae\u7ee7\u7eed\u5173\u6ce8\uff1a1)\u534a\u5bfc\u4f53\u3001\u4eba\u5de5\u667a\u80fd\u3001\u6570\u636e\u8981\u7d20\u7b49\u65b0\u8d28\u751f\u4ea7\u529b\u7b49\u79d1\u6280\u677f\u5757\u53ca\u9ad8\u7aef\u667a\u9020\u677f\u5757\uff1b2)\u201c\u4ee5\u65e7\u6362\u65b0\u201d\u4fc3\u4f7f\u6d88\u8d39\u56de\u6696\u7684\u6c7d\u8f66\u5bb6\u7535\u53ca\u4f30\u503c\u4ecd\u5904\u4e8e\u4f4e\u4f4d\u7684\u4e2d\u533b\u836f\u548c\u533b\u7597\u670d\u52a1\u677f\u5757\uff1b3)\u4f30\u503c\u4ecd\u5904\u4f4e\u4f4d\u7684\u201c\u4f4e\u4f30\u7ea2\u5229\u201d\u7535\u4fe1\u7164\u70ad\u6cb9\u6c14\u677f\u5757\uff1b4\uff09\u53d7\u76ca\u653f\u7b56\u521d\u89c1\u6210\u6548\u7684\u5730\u4ea7\u3001\u5efa\u7b51\u53ca\u7269\u7ba1\u592e\u4f01\u56fd\u9f99\u5934\u516c\u53f8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259491105", "pub_date": "2024-12-04 12:14:48"}, {"id": 259490589, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u51ef\u6295\u5b8f\u89c2\uff1a\u97e9\u56fd\u7ecf\u6d4e\u6574\u4f53\u4e0a\u4ecd\u65e7\u9762\u4e34\u7740\u4e0d\u5c0f\u7684\u98ce\u9669", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u51ef\u6295\u5b8f\u89c2\u7684\u5206\u6790\u5e08\u9a6c\u514b\u00b7\u5a01\u5ec9\u59c6\u65af\u548c\u52a0\u96f7\u65af\u00b7\u83b1\u745f\u6307\u51fa\uff1a\u5c3d\u7ba1\u97e9\u56fd\u7684\u5e02\u573a\u548c\u8d27\u5e01\u53ef\u80fd\u5df2\u7ecf\u6709\u6240\u56de\u6696\uff0c\u4f46\u97e9\u56fd\u7ecf\u6d4e\u6574\u4f53\u4e0a\u4ecd\u65e7\u9762\u4e34\u7740\u4e0d\u5c0f\u7684\u98ce\u9669\u3002\u8fd9\u6b21\uff08\u5ba3\u5e03\u6212\u4e25\u4ee4\uff09\u7684\u884c\u52a8\u51fa\u4eba\u610f\u6599\uff0c\u5176\u5f71\u54cd\u53ef\u80fd\u4f1a\u6301\u7eed\u7b3c\u7f69\u5728\u97e9\u56fd\u7ecf\u6d4e\u524d\u666f\u4e4b\u4e0a\uff0c\u76f4\u81f3\u653f\u6cbb\u5c40\u52bf\u91cd\u65b0\u7a33\u5b9a\u3002\u8fd9\u573a\u52a8\u8361\u8fd8\u8fdb\u4e00\u6b65\u52a0\u5267\u4e86\u533a\u57df\u7d27\u5f20\u5173\u7cfb\u3002\u5c39\u9521\u60a6\u603b\u7edf\u7684\u8fd9\u4e00\u51b3\u5b9a\u7684\u60ca\u4eba\u7a0b\u5ea6\u65e0\u8bba\u5982\u4f55\u5f3a\u8c03\u90fd\u4e0d\u8fc7\u5206\u2026\u2026\u8fd9\u4e9b\u4e8b\u4ef6\u5c06\u4e25\u91cd\u524a\u5f31\u6295\u8d44\u8005\u5bf9\u97e9\u56fd\u7ecf\u6d4e\u53ca\u5176\u91d1\u878d\u5e02\u573a\u7684\u4fe1\u5fc3\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259490589", "pub_date": "2024-12-04 12:10:01"}, {"id": 259490701, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6469\u6839\u58eb\u4e39\u5229\uff1a11\u6708\u4f4e\u6210\u672c\u822a\u7a7a\u516c\u53f8\u5ba2\u6d41\u91cf\u5f3a\u52b2", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6469\u6839\u58eb\u4e39\u52293\u65e5\u53d1\u5e03\u7684\u7814\u62a5\u630711\u6708\u4f4e\u6210\u672c\u822a\u7a7a\u516c\u53f8\u7684\u5ba2\u6d41\u91cf\u8868\u73b0\u5f3a\u52b2\u3002\u62a5\u544a\u4e2d\u63d0\u5230\uff0c\u745e\u5b89\u822a\u7a7a\uff08Ryanair\uff09\u7684\u4e58\u5ba2\u589e\u957f\u7387\u8fbe\u5230\u4e8611%\uff0c\u73af\u6bd4\u589e\u957f\u4e864\u4e2a\u767e\u5206\u70b9\uff0c\u800c\u7ef4\u5179\u822a\u7a7a\uff08Wizz Air\uff09\u7684\u589e\u957f\u7387\u4e3a1.7%\uff0c\u73af\u6bd4\u4e0b\u964d\u4e862.4\u4e2a\u767e\u5206\u70b9\u3002\u5728\u5ba2\u5ea7\u7387\u65b9\u9762\uff0c\u745e\u5b89\u822a\u7a7a\u4fdd\u6301\u7a33\u5b9a\uff0c\u4e0e\u53bb\u5e74\u540c\u671f\u6301\u5e73\uff0c\u4e3a92%\uff0c\u7ef4\u5179\u822a\u7a7a\u7684\u5ba2\u5ea7\u7387\u5219\u540c\u6bd4\u589e\u957f\u4e863.1\u4e2a\u767e\u5206\u70b9\uff0c\u8fbe\u523091.5%\u3002<br/><br/>\u6469\u6839\u58eb\u4e39\u5229\u5bf9\u884c\u4e1a\u6570\u636e\u7684\u5206\u6790\u53ca\u672a\u6765\u5c55\u671b\u8868\u660e\uff0c11\u6708\u7684\u6574\u4f53\u6570\u636e\u5f3a\u52b2\uff0c\u5ba2\u5ea7\u7387\u4fdd\u6301\u5f3a\u52bf\uff0c\u745e\u5b89\u822a\u7a7a\u7684\u5ba2\u6d41\u91cf\u589e\u957f\u5c24\u4e3a\u663e\u8457\u3002\u7ef4\u5179\u822a\u7a7a\u7684\u5ba2\u6d41\u91cf\u589e\u957f\u8f83\u5c0f\uff0c\u4f46\u8fd9\u53d7\u5230\u4e86\u5176\u673a\u961f\u5bb9\u91cf\u9650\u5236\u7684\u5f71\u54cd\u3002\u745e\u5b89\u822a\u7a7a\u572811\u6708\u7684\u5ba2\u6d41\u91cf\u52a0\u901f\u589e\u957f\uff0c\u4e0e2019\u5e74\u540c\u671f\u76f8\u6bd4\uff0c\u5176\u5ba2\u6d41\u91cf\u8fbe\u5230\u4e86119%\uff0c\u800c10\u6708\u4e3a133%\u3002\u7ef4\u5179\u822a\u7a7a\u572811\u6708\u7684\u5ba2\u5ea7\u7387\u6709\u6240\u63d0\u9ad8\uff0c\u5c3d\u7ba1\u5176\u5ea7\u4f4d\u5bb9\u91cf\u540c\u6bd4\u51cf\u5c11\u4e861.7%\uff0c\u4f46\u4e0e2019\u5e74\u540c\u671f\u76f8\u6bd4\uff0c\u5176\u5ba2\u6d41\u91cf\u8fbe\u5230\u4e86163%\uff0c\u800c10\u6708\u4e3a152%\u3002\u6b64\u5916\uff0c\u7ef4\u5179\u822a\u7a7a\u8fd8\u8868\u793a\uff0c\u572811\u6708\u548c12\u6708\u770b\u5230\u4e86\u79ef\u6781\u7684\u6536\u76ca\u548c\u9884\u8ba2\u73af\u5883\uff0c\u4e0e\u5176\u8fd1\u671f\u7684\u4e1a\u7ee9\u8bc4\u8bba\u4e00\u81f4\u3002<br/><br/>\u6469\u6839\u58eb\u4e39\u5229\u7ef4\u6301\u5bf9\u822a\u7a7a\u884c\u4e1a\u7b26\u5408\u9884\u671f\u7684\u770b\u6cd5\uff0c\u8ba4\u4e3a\u4f4e\u6210\u672c\u822a\u7a7a\u516c\u53f8\u7684\u5ba2\u6d41\u91cf\u548c\u5ba2\u5ea7\u7387\u7684\u5f3a\u52b2\u8868\u73b0\u5c06\u7ee7\u7eed\u652f\u6491\u884c\u4e1a\u7684\u590d\u82cf\u8d8b\u52bf\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259490701", "pub_date": "2024-12-04 12:10:26"}]}