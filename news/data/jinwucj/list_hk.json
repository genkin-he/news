5448\u73b0\u7b51\u5e95\u8ff9\u8c61\u3002<br/><br/>\u8be5\u884c\u6307\u51fa\uff0c\u57fa\u4e8e\u5bf9\u516c\u53f8\u5e73\u53f0\u578b\u4f01\u4e1a\u903b\u8f91\u7684\u770b\u597d\uff0c\u8be5\u884c\u5e74\u521d\u5bf9\u4e8e\u516c\u53f8\u7684\u76c8\u5229\u9884\u6d4b\u4e3a2024-2026\u5e74\u6536\u5165\u4e3a70.93/83.20/97.18\u4ebf\u5143\uff0c\u5bf9\u5e94\u5f52\u6bcd\u51c0\u5229\u6da6\u4e3a6.16/7.67/9.40\u4ebf\u5143\uff0c\u4f462024\u5e74\u4ee5\u6765\u5916\u90e8\u7ecf\u8425\u73af\u5883\u9762\u4e34\u8f83\u5927\u538b\u529b\uff0c\u516c\u53f8\u540c\u5e97\u9500\u552e\u4e0e\u76c8\u5229\u8ddf\u968f\u540c\u6bd4\u5927\u5e45\u4e0b\u6ed1\uff0c\u8be5\u884c\u4ece\u6700\u65b0\u504f\u4e2d\u6027\u5047\u8bbe\u51fa\u53d1\u4e0b\u8c03\u516c\u53f82024-26\u5e74\u8425\u4e1a\u6536\u5165\u81f363.15/72.81/87.38\u5143\uff0c\u5f52\u6bcd\u51c0\u5229\u6da6\u81f32.19/2.92/3.84\u4ebf\u5143\uff08\u5229\u6da6\u4e0b\u8c03\u5e45\u5ea6\u66f4\u5927\u7cfb\u6210\u672c\u7684\u8d1f\u6760\u6746\u6548\u5e94\uff09\uff0c\u5bf9\u5e94PE20/15/12x\u3002\u4f34\u968f\u7ecf\u8425\u7aef\u7684\u627f\u538b\uff0c\u516c\u53f8\u80a1\u4ef7\u5e74\u521d\u4ee5\u6765\u56de\u64a4\u4e5f\u8d8540%\uff0c\u4f46\u8be5\u884c\u540c\u6837\u4e5f\u89c2\u6d4b\u5230\u516c\u53f8\u8c03\u6574\u83dc\u5355\u63a8\u51fa\u9ad8\u6027\u4ef7\u6bd4\u4ea7\u54c1\uff0c\u4f18\u5316\u95e8\u5e97\u4e0e\u603b\u90e8\u5c42\u9762\u6210\u672c\u7b49\u52aa\u529b\uff0c\u6b64\u5916\u516c\u53f8\u62d3\u5c55\u7684\u52a0\u76df\u5e97\u548c\u536b\u661f\u5e97\u65b0\u6a21\u578b\uff0c\u6210\u719f\u540e\u4e5f\u6709\u671b\u8d21\u732e\u65b0\u589e\u957f\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u8003\u8651\u5230\u516c\u53f82024\u5e74PE\u52a8\u6001\u4f30\u503c\u7ea620x\uff0c\u5df2\u5904\u4e8e\u4e0a\u5e02\u4ee5\u6765\u5e95\u90e8\u4f4d\u7f6e\uff0c\u8fd1\u671f\u56fd\u5185\u4fc3\u6d88\u8d39\u653f\u7b56\u7ec4\u5408\u62f3\u63a5\u8fde\u51fa\u53f0\uff0c\u82e5\u540e\u7eed\u7ffb\u53f0\u7387\u5b9e\u8d28\u6027\u6539\u5584\u540e\uff0c\u6760\u6746\u6548\u5e94\u4e0b\u516c\u53f8\u6709\u671b\u5c55\u73b0\u51fa\u5f3a\u5229\u6da6\u5f39\u6027\uff0c\u4e14\u516c\u53f8\u591a\u54c1\u724c\u5b75\u5316\u6218\u7565\u6301\u7eed\u63a8\u8fdb\uff0c\u7efc\u4e0a\u8be5\u884c\u7ef4\u6301\u516c\u53f8\u4e2d\u7ebf\u201c\u4f18\u4e8e\u5927\u5e02\u201d\u8bc4\u7ea7\uff0c\u9759\u5f85\u76c8\u5229\u62d0\u70b9\u5230\u6765\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255320309", "pub_date": "2024-10-21 14:48:08"}, {"id": 255320379, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6d77\u901a\u56fd\u9645\u6307\u56de\u8d2d\u589e\u6301\u8d37\u6b3e\u53ef\u589e\u539a\u94f6\u884c\u5229\u6da6", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6d77\u901a\u56fd\u9645\u8868\u793a\uff0c2024\u5e7410\u670820\u65e5\uff0c\u62db\u5546\u86c7\u53e3\u3001\u4e2d\u56fd\u77f3\u5316\u3001\u4e2d\u8fdc\u6d77\u80fd\u3001\u4e2d\u8fdc\u6d77\u53d1\u3001\u62db\u5546\u8f6e\u8239\u3001\u4e1c\u82af\u80a1\u4efd\u7b4923\u5bb6\u516c\u53f8\u516c\u544a\u79f0\uff0c\u83b7\u5f97\u94f6\u884c\u8d37\u6b3e\u989d\u5ea6\uff0c\u6388\u4fe1\u7528\u4e8e\u516c\u53f8\u80a1\u7968\u56de\u8d2d\u3001\u589e\u6301\u8ba1\u5212\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u5bf9\u4e8e\u94f6\u884c\u800c\u8a00\uff0c\u5728\u8d44\u4ea7\u6295\u653e\u6709\u538b\u529b\u7684\u60c5\u51b5\u4e0b\uff0c\u5bf9\u4e8e\u8d44\u672c\u91d1\u5145\u8db3\u3001\u4f18\u8d28\u5ba2\u6237\u4f17\u591a\u3001\u98ce\u63a7\u4e25\u683c\u7684\u94f6\u884c\u800c\u8a00\uff0c\u53ef\u4ee5\u589e\u539a\u5176\u5229\u6da6\u300223\u5bb6\u4e0a\u5e02\u516c\u53f8\u4e2d\uff0c\u6309WIND\u5206\u7c7b\u7684\u516c\u53f8\u5c5e\u6027\uff0c\u4e2d\u592e\u56fd\u6709\u4f01\u4e1a\u548c\u6c11\u8425\u4f01\u4e1a\u5bf9\u5e94\u6388\u4fe1\u91d1\u989d\u7ea6\u540450\u4ebf\uff0c\u5730\u65b9\u56fd\u6709\u4f01\u4e1a\u6700\u5c11\u3002<br/><br/>\u8be5\u884c\u8ba4\u4e3a\uff0c\u90e8\u5206\u4e2d\u8d44\u4e0a\u5e02\u94f6\u884c\u5728\u6ee1\u8db3\u8d44\u672c\u5145\u8db3\u7387\u76d1\u7ba1\u8981\u6c42\u3001\u4ee5\u53ca\u80a1\u4e1c\u6301\u80a1\u4e0a\u9650\u9650\u5236\u7684\u60c5\u51b5\u4e0b\uff0c\u8003\u8651\u5230\u8d28\u62bc\u6bd4\u4f8b\u76f8\u5bf9\u8f83\u4f4e\uff0c\u80a1\u4ef7\u6ce2\u52a8\u6027\u76f8\u5bf9\u8f83\u5c0f\uff0c\u94f6\u884cPB\u4f30\u503c\u4f4e\u4e8e1\u7684\u60c5\u51b5\u4e0b\uff0c\u7406\u8bba\u4e0a\u53ef\u4ee5\u4f5c\u4e3a\u56de\u8d2d\u7684\u4e3b\u4f53\u3002\u540e\u7eed\u5982\u679c\u80fd\u6709\u540c\u4e1a\u4e4b\u95f4\u5dee\u5f02\u5316\u7684\u64cd\u4f5c\uff0c\u5c06\u5728\u5b50\u677f\u5757\u5185\u62c9\u5f00\u4f30\u503c\u6c34\u5e73\u3002\u4e8b\u5b9e\u4e0a\uff0c\u5728\u6838\u5fc3\u4e00\u7ea7\u8d44\u672c\u6ce8\u8d44\u7684\u65b0\u95fb\u53d1\u8a00\u4e2d\uff0c\u4e5f\u63d0\u5230\u4e86\u201c\u4e00\u884c\u4e00\u7b56\u201d\uff0c\u7531\u4e0a\u5e02\u94f6\u884c\u81ea\u5df1\u4e0a\u62a5\u65b9\u6848\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255320379", "pub_date": "2024-10-21 14:49:36"}, {"id": 255319551, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u8d22\u901a\u8bc1\u5238\u7ef4\u6301\u96f6\u8dd1\u6c7d\u8f66(09863)\u201c\u589e\u6301\u201d\u8bc4\u7ea7 \u96f6\u8dd1B10\u4e8e\u660e\u5e74\u5168\u7403\u4e0a\u5e02", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u8d22\u901a\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u96f6\u8dd1\u6c7d\u8f66(09863)\u4e3b\u9898\u4e3a\u201cA Leap Forward\u201d\u7684\u96f6\u8dd1\u5168\u7403\u6218\u7565\u53d1\u5e03\u4f1a\u4e8e\u5df4\u9ece\u65f6\u95f410\u670814\u65e5\u5728\u5df4\u9ece\u8f66\u5c55\u5f00\u5e55\u5f53\u5929\u4e3e\u884c\uff0c\u96f6\u8dd1\u6c7d\u8f66\u5168\u65b0B\u7cfb\u5217\u53caB\u7cfb\u5217\u9996\u6b3e\u5168\u7403\u5316\u8f66\u578bB10\u5f00\u542f\u5168\u7403\u9996\u79c0\uff0c\u96f6\u8dd1\u6c7d\u8f66\u65d7\u4e0bC16\u3001C10\u3001T03\u4e0e\u5168\u65b0B10\u4e00\u8d77\u4eae\u76f8\u96f6\u8dd1\u5c55\u53f0\u3002\u96f6\u8dd1B10\u5b9a\u4f4d\u7d27\u51d1\u578bSUV\uff0c\u57fa\u4e8eLEAP3.5\u67b6\u6784B\u5e73\u53f0\u6253\u9020\uff0c\u5c06\u805a\u712610-15\u4e07\u5143\u5e02\u573a\uff0c\u4e8e\u660e\u5e74\u5168\u7403\u4e0a\u5e02\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u5728\u667a\u80fd\u5316\u65b9\u9762\uff0c\u96f6\u8dd1B10\u642d\u8f7d\u4e86\u540c\u7ea7\u552f\u4e00\u7684\u6fc0\u5149\u96f7\u8fbe\u548c8650\u82af\u7247\u7684\u667a\u80fd\u9a7e\u9a76\u65b9\u6848\uff0c\u5177\u5907\u9ad8\u901f\u53ca\u57ce\u533a\u81ea\u52a8\u9886\u822a\u8f85\u52a9\u529f\u80fd\u3002\u540c\u65f6\u96f6\u8dd1\u6c7d\u8f66\u4e0eStellantis\u96c6\u56e2\u7684\u739b\u838e\u62c9\u8482\u56e2\u961f\u5408\u4f5c\u8fdb\u884c\u4e86\u5e95\u76d8\u8c03\u6821\uff0c\u5168\u8f66\u91c7\u7528\u6b27\u6d32\u9886\u5148\u6807\u51c6\u8bbe\u8ba1\u5f00\u53d1\uff0c\u65e8\u5728\u5168\u9762\u6ee1\u8db3\u5168\u7403\u5e74\u8f7b\u7fa4\u4f53\u5bf9\u667a\u80fd\u3001\u65f6\u5c1a\u3001\u4e50\u8da3\u53ca\u54c1\u8d28\u7684\u9700\u6c42\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0c\u96f6\u8dd1B\u7cfb\u5217\u57fa\u4e8e\u96f6\u8dd1\u6700\u65b0LEAP3.5\u6280\u672f\u67b6\u6784\uff0c\u91c7\u75288295\u82af\u7247\u667a\u80fd\u5ea7\u8231\u30018650\u667a\u9a7e\u82af\u7247+\u6fc0\u5149\u96f7\u8fbe\u9ad8\u9636\u667a\u80fd\u9a7e\u9a76\u3002\u540c\u65f6LEAP3.5\u642d\u8f7d\u4e86\u884c\u4e1a\u9996\u4e2a\u56db\u57df\u5408\u4e00\u4e2d\u592e\u96c6\u6210\u63a7\u5236\u5668\u300127\u54081\u8d85\u7ea7\u96c6\u6210\u70ed\u7ba1\u7406\u3001\u591a\u5408\u4e00\u667a\u80fd\u7535\u9a71\u7cfb\u7edf\u3001CTC\u7535\u6c60\u5e95\u76d8\u4e00\u4f53\u5316\u6280\u672f\uff0c\u7ed9\u5e74\u8f7b\u7fa4\u4f53\u5e26\u6765\u66f4\u597d\u7684\u9a7e\u9a76\u4f53\u9a8c\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u9884\u8ba1\u516c\u53f82024-2026\u5e74\u5b9e\u73b0\u5f52\u6bcd\u51c0\u5229\u6da6-37.03/-10.86/10.52\u4ebf\u5143\uff0c\u5bf9\u5e942026\u5e74PE\u4e3a32.97\u500d\uff0c\u7ef4\u6301\u201c\u589e\u6301\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255319551", "pub_date": "2024-10-21 14:37:44"}, {"id": 255319550, "title": "\u97e9\u56fd\u7efc\u5408\u6307\u6570\u6536\u62a52604.92\u70b9 \u6da80.43%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u97e9\u56fd\u7efc\u5408\u6307\u6570\u6536\u62a52604.92\u70b9\uff0c\u6da80.43%\u3002<br/><br/>\u97e9\u56fd10\u6708\u524d20\u5929\u51fa\u53e3\u540c\u6bd4\u4e0b\u964d2.9%\u3002\u97e9\u56fd\u65e9