9ef\u6781\u7684\u653f\u7b56\u53cd\u5e94\u4e0b\u8fc5\u901f\u7f13\u548c\u3002\u4f8b\u5982\u97e9\u56fd\u592e\u884c\u5b98\u5458\u627f\u8bfa\u5728\u5fc5\u8981\u65f6\u63d0\u4f9b\u65e0\u9650\u6d41\u52a8\u8d44\u91d1\u4ee5\u7a33\u5b9a\u91d1\u878d\u5e02\u573a\uff0c\u5305\u62ec\u572812\u67084\u65e5\u53ec\u5f00\u7684\u97e9\u56fd\u592e\u884c\u7d27\u6025\u4f1a\u8bae\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259510056", "pub_date": "2024-12-04 14:49:14"}, {"id": 259510055, "title": "\u636e\u62a5\u65e5\u672c\u653f\u5e9c\u6b63\u8ba1\u5212\u653e\u5bbd\u5bf9\u8bbf\u65e5\u4e2d\u56fd\u516c\u6c11\u7684\u7b7e\u8bc1\u8981\u6c42", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u65e5\u5a92\u62a5\u9053\uff0c\u65e5\u672c\u653f\u5e9c\u6b63\u8ba1\u5212\u653e\u5bbd\u5bf9\u8bbf\u65e5\u4e2d\u56fd\u516c\u6c11\u7684\u7b7e\u8bc1\u8981\u6c42\u3002\u65e5\u672c\u5916\u76f8\u5ca9\u5c4b\u6bc5\u6b63\u8003\u8651\u5e74\u5185\u8bbf\u95ee\u4e2d\u56fd\uff0c\u5e76\u51c6\u5907\u5728\u6b64\u884c\u4e0e\u4e2d\u56fd\u65b9\u9762\u5c31\u7b7e\u8bc1\u95ee\u9898\u5c55\u5f00\u8ba8\u8bba\u3002<br/><br/>\u62a5\u9053\u6307\uff0c\u65e5\u672c\u8ba1\u5212\u91cd\u65b0\u542f\u52a8\u66fe\u57282019\u5e74\u95f4\u6b47\u5b9e\u65bd\u7684\u9488\u5bf9\u4e2d\u56fd\u7684\u7b7e\u8bc1\u653e\u5bbd\u63aa\u65bd\u3002\u65e5\u672c\u5916\u52a1\u7701\u3001\u6cd5\u52a1\u7701\u3001\u8b66\u5bdf\u5385\u7b49\u76f8\u5173\u653f\u5e9c\u90e8\u95e8\u5c06\u5f88\u5feb\u5c31\u8c03\u6574\u4e2d\u56fd\u516c\u6c11\u8bbf\u65e5\u7b7e\u8bc1\u53d1\u653e\u6761\u4ef6\u5c55\u5f00\u8ba8\u8bba\uff0c\u90e8\u5206\u7533\u8bf7\u624b\u7eed\u5c06\u4f1a\u7b80\u5316\u3002<br/><br/>\u62a5\u9053\u63d0\u5230\uff0c\u65e5\u672c\u653f\u5e9c\u4ee5\u4e2d\u56fd\u7684\u4eba\u53e3\u8fbe\u5230\u65e5\u672c\u768410\u500d\u4ee5\u4e0a\uff0c\u4ee5\u53ca\u5b58\u5728\u8d85\u51fa\u7b7e\u8bc1\u505c\u7559\u671f\u9650\u4e5f\u4e0d\u56de\u56fd\u7684\u201c\u8d85\u671f\u505c\u7559\u201d\u95ee\u9898\u7b49\u4e3a\u7531\uff0c\u4e0d\u6253\u7b97\u5b9e\u65bd\u4e92\u514d\u7b7e\u8bc1\uff1b\u540c\u65f6\u8003\u8651\u5230\u6cbb\u5b89\u95ee\u9898\uff0c\u5c06\u4fdd\u7559\u4e00\u5b9a\u6761\u4ef6\uff0c\u907f\u514d\u5165\u5883\u65e5\u672c\u7684\u4eba\u6570\u6025\u5267\u589e\u52a0\u3002<br/><br/>\u65e5\u672c\u66fe\u57282019\u5e741\u6708\u5bf9\u4e2d\u56fd\u653e\u5bbd\u7b7e\u8bc1\u7533\u8bf7\uff0c\u5bf9\u6709\u4e00\u5b9a\u8bbf\u65e5\u7ecf\u5386\u7684\u4eba\u514d\u4e8e\u63d0\u4ea4\u76f8\u5173\u8bc1\u660e\uff0c\u9762\u5411\u7559\u5b66\u751f\u8fd8\u589e\u52a0\u4e86\u53ef\u9002\u7528\u7b80\u5316\u7533\u8bf7\u624b\u7eed\u7684\u5927\u5b66\u540d\u5355\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259510055", "pub_date": "2024-12-04 14:49:49"}, {"id": 259509173, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u9ad8\u76db\uff1a\u7f8e\u58a8\u52a0\u534f\u5b9a\u53c2\u4e0e\u8005\u9762\u4e34\u5173\u7a0e\u63d0\u6848 \u7ecf\u6d4e\u5f71\u54cd\u6df1\u8fdc", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u5f53\u9009\u603b\u7edf\u7279\u6717\u666e\u4e0a\u5468\u5ba3\u5e03\uff0c\u4ed6\u6253\u7b97\u5bf9\u6765\u81ea\u58a8\u897f\u54e5\u548c\u52a0\u62ff\u5927\u7684\u6240\u6709\u8fdb\u53e3\u5546\u54c1\u5f81\u653625%\u7684\u5173\u7a0e\uff08\u4ee5\u53ca\u5bf9\u6765\u81ea\u4e2d\u56fd\u7684\u8fdb\u53e3\u5546\u54c1\u989d\u5916\u5f81\u653610%\u7684\u5173\u7a0e\uff09\uff0c\u76f4\u81f3\u201c\u6bd2\u54c1\u6d41\u52a8\uff0c\u7279\u522b\u662f\u82ac\u592a\u5c3c\uff0c\u4ee5\u53ca\u6240\u6709\u5408\u6cd5\u5916\u56fd\u4eba\u505c\u6b62\u201d\u3002\u8fd9\u4e00\u5a01\u80c1\u8d85\u51fa\u4e86\u4e4b\u524d\u7684\u58f0\u660e\uff0c\u5c24\u5176\u662f\u5bf9\u52a0\u62ff\u5927\u7684\u5173\u7a0e\u5a01\u80c1\u662f\u65b0\u7684\uff0c\u56e0\u6b64\u6709\u4e9b\u4ee4\u4eba\u610f\u5916\u3002<br/><br/>\u9ad8\u76db\u7684\u5206\u6790\u4eec\u57282\u65e5\u7684\u7814\u62a5\u4e2d\u6307\uff0c\u867d\u7136\u4e0d\u9884\u671f\u8fd9\u4e9b\u5173\u7a0e\u4f1a\u57282025\u5e74\u521d\u751f\u6548\uff0c\u4f46\u7279\u6717\u666e\u53ef\u80fd\u4f1a\u5229\u7528\u8fd9\u4e00\u65e9\u671f\u5a01\u80c1\u6765\u4e3a\u8fb9\u5883\u653f\u7b56\u7684\u6539\u5584\u83b7\u5f97\u8d5e\u8a89\u3002\u5c3d\u7ba1\u5982\u6b64\uff0c\u62a5\u544a\u6307\u51fa\uff0c\u4e0e\u52a0\u62ff\u5927\u548c\u58a8\u897f\u54e5\u7684\u8d38\u6613\u653f\u7b56\u4e0d\u786e\u5b9a\u6027\u53ef\u80fd\u4f1a\u6301\u7eed\u5b58\u5728\uff0c\u7279\u522b\u662f\u57282026\u5e747\u67081\u65e5\uff0c\u5373\u7f8e\u58a8\u52a0\u534f\u5b9a\u516d\u5e74\u5ba1\u67e5\u671f\u9650\u5230\u6765\u4e4b\u524d\u3002\u5c4a\u65f6\uff0c\u9884\u8ba1\u6c7d\u8f66\u8fdb\u53e3\u5c06\u6210\u4e3a\u7279\u6717\u666e\u653f\u5e9c\u7684\u4e3b\u8981\u5173\u6ce8\u70b9\u3002\u6b64\u5916\uff0c\u62a5\u544a\u8fd8\u63d0\u5230\uff0c\u5982\u679c\u5b9e\u65bd\u8fd9\u4e9b\u5173\u7a0e\uff0c\u5c06\u5bf9\u52a0\u62ff\u5927\u548c\u58a8\u897f\u54e5\u7684\u7ecf\u6d4e\u4ea7\u751f\u91cd\u5927\u5f71\u54cd\uff0c\u9884\u8ba1\u4f1a\u4f7f\u4e24\u56fd\u7684GDP\u964d\u4f4e1-4%\uff0c\u5e76\u53ef\u80fd\u5bfc\u81f4\u7269\u4ef7\u4e0a\u6da8\u9ad8\u8fbe2%\u3002\u8fd9\u4e9b\u4f30\u8ba1\u5b58\u5728\u5f88\u5927\u7684\u4e0d\u786e\u5b9a\u6027\uff0c\u5e76\u5c06\u6700\u7ec8\u53d6\u51b3\u4e8e\u5b9e\u9645\u4ea4\u4ed8\u7684\u653f\u7b56\u53d8\u5316\uff0c\u4f46\u5b83\u4eec\u63d0\u9192\u6211\u4eec\u7279\u6717\u666e\u8d38\u6613\u63d0\u6848\u6240\u5e26\u6765\u7684\u7ecf\u6d4e\u548c\u5e02\u573a\u98ce\u9669\u3002<br/><br/>\u9ad8\u76db\u7684\u5206\u6790\u5e08\u4eec\u8fd8\u5f3a\u8c03\uff0c\u5c3d\u7ba1\u4ed6\u4eec\u7684\u57fa\u672c\u5047\u8bbe\u662f\u8fd9\u4e9b\u5f71\u54cd\u6700\u7ec8\u4e0d\u4f1a\u5b9e\u73b0\uff0c\u4f46\u4e0a\u5468\u7684\u58f0\u660e\u63d0\u9192\u6211\u4eec\uff0c\u66f4\u5e7f\u6cdb\u7684\u8d38\u6613\u6218\u53ef\u80fd\u5e26\u6765\u7684\u6f5c\u5728\u5c3e\u90e8\u98ce\u9669\uff0c\u5e76\u652f\u6301\u4ed6\u4eec\u5916\u6c47\u56e2\u961f\u7684\u89c2\u70b9\uff0c\u5373\u5e02\u573a\u9700\u8981\u5d4c\u5165\u66f4\u6301\u4e45\u3001\u66f4\u5e7f\u6cdb\u7684\u5173\u7a0e\u6ea2\u4ef7\u3002\u62a5\u544a\u6700\u540e\u6307\u51fa\uff0c\u5c3d\u7ba1\u5b58\u5728\u4e0d\u786e\u5b9a\u6027\uff0c\u4f46\u5206\u6790\u8868\u660e\uff0c\u5982\u679c\u6309\u7167\u7279\u6717\u666e\u7684\u63d0\u8bae\u884c\u4e8b\uff0c\u53ef\u80fd\u4f1a\u5bf9\u52a0\u62ff\u5927\u548c\u58a8\u897f\u54e5\u7ecf\u6d4e\u4ea7\u751f\u91cd\u5927\u5f71\u54cd\uff0c\u5bf9\u7f8e\u56fd\u4e5f\u6709\u9002\u5ea6\u5f71\u54cd\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259509173", "pub_date": "2024-12-04 14:42:37"}, {"id": 259507587, "title": "<\u677f\u5757\u68c0\u6d4b> \u5927\u5e02\u6700\u65b05\u5927\u8dcc\u5e45\u677f\u5757", "description": "<div><p>\u6052\u6307\u6307\u6570\u6700\u65b0\u62a519710.41\u70b9\uff0c\u8dcc-0.2%;\u56fd\u4f01\u6307\u6570\u6700\u65b0\u62a57076.75\u70b9\uff0c\u53470.1%\u3002\u5f53\u524d\u6700\u65b05\u5927\u8dcc\u5e45\u677f\u5757\u540d\u5355\uff1a</p><table style=\"width: 100%; border-collapse: collapse; text-align: center; background-color: #fff; color: #333; font-size: 12px;\"><tr><th style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0; width: 25%;\"><span style=\"display: inline-block; vertical-align:middle;\">\u677f\u5757\u540d\u79f0</span></th><th style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0; width: 25%;\"><span style=\"display: inline-block; vertical-align:middle;\">\u677f\u5757\u6da8\u8dcc\u5e45</span><span style=\"display: inline-block; vertical-align:middle;\">(%)</span></th><th style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0; width: 25%;\">\u540d\u79f0\u4ee3\u7801</th><th style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0; width: 25%;\"><span style=\"display: inline-block; vertical-align:middle;\">\u4e2a\u80a1\u6da8\u8dcc</span></th></tr><tr><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">\u533b\u7597\u4fdd\u5065\u8bbe\u5907\u4e0e\u670d\u52a1</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">-1.2</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">\u4eac\u4e1c\u5065\u5eb7</span>