u8ba1\u5212\u7684\u533b\u7597\u5668\u68b0\u201d\uff0c\u7b26\u5408\u4f18\u5148\u5ba1\u6279\u60c5\u5f62\u7684\u9879\u76ee\uff0c\u62df\u5b9a\u4e88\u4ee5\u4f18\u5148\u5ba1\u6279\u3002<br/><br/>\u534e\u5b89\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u5de8\u5b50\u751f\u7269(02367)\u4e8e11\u670812\u65e5\u53d1\u5e03\u6d88\u606f\uff0c\u6838\u5fc3\u54c1\u724c\u53ef\u590d\u7f8e/\u53ef\u4e3d\u91d1\u5728\u53cc11\u671f\u95f4\u7ebf\u4e0a\u5168\u6e20\u9053\u5168\u5468\u671fGMV\u540c\u6bd4\u589e\u957f\u5206\u522b\u8fbe\u523080+%/150+%\uff1b\u7531\u5de8\u5b50\u751f\u7269\u4e3b\u5bfc\u5236\u5b9a\u7684\u300a\u53d1\u9175\u4eba\u53c2\u7c89\u300b\u56e2\u4f53\u6807\u51c6\u6b63\u5f0f\u53d1\u5e03\uff0c\u4e3a\u8be5\u9886\u57df\u9996\u4e2a\u56e2\u4f53\u6807\u51c6\u3002\u8be5\u884c\u8868\u793a\uff0c\u516c\u53f8\u4f5c\u4e3a\u91cd\u7ec4\u80f6\u539f\u86cb\u767d\u9f99\u5934\uff0c\u51ed\u501f\u591a\u5143\u5316\u4ea7\u54c1\u77e9\u9635\u548c\u6e20\u9053\u4f18\u52bf\uff0c\u4e1a\u7ee9\u6709\u671b\u6301\u7eed\u9ad8\u589e\u3002\u636e\u516c\u53f82024\u534a\u5e74\u5ea6\u62a5\u544a\uff0c\u8be5\u884c\u8c03\u6574\u516c\u53f8\u7684\u4e1a\u7ee9\u9884\u6d4b\uff0c\u9884\u8ba1\u516c\u53f82024-2026\u5e74\u5f52\u6bcd\u51c0\u5229\u6da6\u5206\u522b\u4e3a20.82\u300127.33\u300135.30\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u901f\u4e3a43%\u300131%\u300129%\uff082024-2026\u5e74\u524d\u503c\u4e3a19.22\u300124.21\u300130.16\u4ebf\u5143\uff09\u3002\u5bf9\u5e94PE\u5206\u522b\u4e3a23\u300118\u300114\u500d\u3002\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259775449", "pub_date": "2024-12-06 09:54:27"}, {"id": 259774417, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u767e\u80dc\u4e2d\u56fd(09987)\u6da83.34% \u4e0e\u9ad8\u76db\u8ba2\u7acb\u80a1\u4efd\u56de\u8d2d\u534f\u8bae 5.5\u4ebf\u6e2f\u5143\u7528\u4e8e\u56de\u8d2d\u6e2f\u80a1", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u767e\u80dc\u4e2d\u56fd(09987)\u76d8\u521d\u80a1\u4ef7\u8d70\u9ad8\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da83.34%\uff0c\u62a5377\u6e2f\u5143\uff0c\u6210\u4ea4\u989d1372.86\u4e07\u6e2f\u5143\u3002</p><p>\u516c\u53f8\u65e5\u524d\u4e0e\u9ad8\u76db\u8ba2\u7acb\u80a1\u4efd\u56de\u8d2d\u534f\u8bae\uff0c\u5c06\u900f\u8fc7\u516c\u5f00\u5e02\u573a\u53ca\u8054\u4ea4\u6240\u7684\u8bbe\u65bd\u6839\u636e\u9884\u8bbe\u53c2\u6570\u56de\u8d2d\u6e2f\u80a1\uff1b\u540c\u65e5\u516c\u53f8\u8fd8\u5c31\u5176\u5728\u7f8e\u4e0a\u5e02\u80a1\u4efd\u8ba2\u7acb\u56de\u8d2d\u534f\u8bae\u3002</p><p>\u767e\u80dc\u4e2d\u56fd\u8868\u793a\uff0c\u534f\u8bae\u6240\u8ba2\u622a\u81f32025\u5e74\u4e0a\u534a\u5e74\u4e4b\u603b\u56de\u8d2d\u91d1\u989d\u4e3a3.6\u4ebf\u7f8e\u5143\uff0c\u5176\u4e2d2.9\u4ebf\u7f8e\u5143\u7528\u4f5c\u56de\u8d2d\u5176\u7f8e\u80a1\uff0c\u5176\u4f595.5\u4ebf\u6e2f\u5143\u7528\u4e8e\u56de\u8d2d\u5176\u6e2f\u80a1\u3002</p><p>\u516c\u53f8\u6307\uff0c\u56de\u8d2d\u534f\u8bae\u662f\u5176\u56de\u8d2d\u8ba1\u5212\u7684\u4e00\u4e2a\u7ec4\u6210\u90e8\u5206\uff0c\u4e5f\u662f\u66f4\u5e7f\u6cdb\u7684\u8d44\u672c\u5206\u914d\u8ba1\u5212\u7684\u4e00\u90e8\u5206\uff0c\u5373\u4ece2024\u5e74\u52302026\u5e74\u901a\u8fc7\u80a1\u606f\u548c\u80a1\u4efd\u56de\u8d2d\u5411\u80a1\u4e1c\u8fd4\u8fd845\u4ebf\u7f8e\u5143\uff0c\u5176\u4e2d\u5305\u62ec2024\u5e74\u5168\u5e74\u768415\u4ebf\u7f8e\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259774417", "pub_date": "2024-12-06 09:40:12"}, {"id": 259774709, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u77e5\u884c\u6c7d\u8f66\u79d1\u6280(01274)\u5927\u6da8\u903e10% \u5ba3\u5e03\u4e0e\u5730\u5e73\u7ebf\u673a\u5668\u4eba(09660)\u8fbe\u6210\u6218\u7565\u5408\u4f5c", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u77e5\u884c\u6c7d\u8f66\u79d1\u6280(01274)\u65e9\u76d8\u80a1\u4ef7\u5f3a\u52bf\uff0c\u6682\u6da810.58%\uff0c\u62a519.86\u6e2f\u5143\uff0c\u6210\u4ea4\u989d5100\u4e07\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u77e5\u884c\u6c7d\u8f66\u79d1\u6280\u5c06\u4e0e\u5730\u5e73\u7ebf\u673a\u5668\u4eba-W(09660)\u8fbe\u6210\u6218\u7565\u5408\u4f5c\uff0c\u53cc\u65b9\u5c06\u57fa\u4e8e\u5730\u5e73\u7ebf\u5f81\u7a0b\u7cfb\u52176E\u82af\u7247(\u7b80\u79f0J6E)\u5f00\u53d1\u667a\u9a7e\u65b9\u6848\uff0c\u76ee\u6807\u5e02\u573a\u4e3a10\u4e07\u81f315\u4e07\u4e2d\u9636\u667a\u9a7e\u5e02\u573a\u3002<br/><br/>\u636e\u6089\uff0c\u5730\u5e73\u7ebfJ6E\u82af\u7247\u5355\u9897\u7b97\u529b80TOPS\uff0c\u53ef\u652f\u6301\u9ad8\u901f\u9886\u822a\u3001\u81ea\u52a8\u6cca\u8f66\u53ca\u57ce\u5e02\u8bb0\u5fc6\u9886\u822a\u7b49\u529f\u80fd\u3002\u57fa\u4e8eJ6E\u6253\u9020\u7684\u6574\u5957\u65b9\u6848\u4ef7\u683c\u57285,000\u5143\u4eba\u6c11\u5e01\u4ee5\u4e0b\uff0c\u652f\u6301\u88ab\u52a8\u6563\u70ed\uff0c\u53ef\u5728\u71c3\u6cb9\u8f66\u4e2d\u4f7f\u7528\uff0c\u4e3a\u6781\u5177\u6027\u4ef7\u6bd4\u7684\u65b9\u6848\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259774709", "pub_date": "2024-12-06 09:44:12"}, {"id": 259774154, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4ea4\u94f6\u56fd\u9645\u7ef4\u6301\u9ad8\u9014(GOTU)\u4e70\u5165\u8bc4\u7ea7 \u65992026\u5e74\u6216\u5c06\u770b\u5230\u516c\u53f8\u6574\u4f53\u626d\u4e8f\u4e3a\u76c8", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4ea4\u94f6\u56fd\u9645\u53d1\u7814\u62a5\u6307\uff0c\u7565\u5fae\u8c03\u6574\u9ad8\u9014(GOTU)\u8d22\u52a1\u9884\u6d4b\uff0c\u9884\u8ba12024/25\u5e74\u516c\u53f8\u6574\u4f53\u6536\u516544.7\u4ebf\u5143/56\u4ebf\u5143\uff0c\u76f8\u6bd4\u6b64\u524d\u9884\u6d4b\u53d8\u52a8\u57281%\u4ee5\u5185\uff0c\u5bf9\u6bd4\u5e02\u573a\u4e00\u81f4\u9884\u671f\uff08VA\uff09\u768444.4\u4ebf\u5143/61.5\u4ebf\u5143\uff0c\u5e02\u573a\u9884\u671f\u6216\u4f1a\u6839\u636e\u516c\u53f8\u8f6c\u5411\u6536\u5165\u589e\u901f\u53ca\u6295\u5165\u5747\u8861\u6218\u7565\uff0c\u4e0b\u8c032025\u5e74\u6536\u5165\u589e\u901f\uff0c\u4f46\u4e5f\u5c06\u8c03\u6574\u4e8f\u635f\u6536\u7a84\u901f\u5ea6\uff0c\u9884\u8ba12026\u5e74\u6216\u5c06\u770b\u5230\u516c\u53f8\u6574\u4f53\u626d\u4e8f\u4e3a\u76c8\u3002\u6839\u636e\u8be5\u884c\u76ee\u524d\u5bf9\u516c\u53f8\u7ebf\u4e0a\u6559\u80b2\u6536\u5165\u9884\u671f\u53ca\u76c8\u5229\u80fd\u529b\u7684\u91ca\u653e\uff0c\u5bf9\u5e94\u7ebf\u4e0a\u6559\u80b215\u500d\u5e02\u76c8\u7387\uff0c\u80a1\u4ef7\u672a\u6765\u6709\u53cd\u5f39\u673a\u4f1a\u3002\u7ef4\u6301\u76ee\u6807\u4ef74.6\u7f8e\u5143\u53ca\u4e70\u5165\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259774154", "pub_date": "2024-12-06 09:36:57"}, {"id": 259773709, "title": "\u3010\u65b0\u80a1IPO\u3011\u591a\u70b9\u6570\u667a(02586)\u9996\u6302\u5f00\u62a521.7\u6e2f\u5143 \u8f83\u62db\u80a1\u4ef7\u4f4e28.17%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u591a\u70b9\u6570\u667a(02586)\u9996\u6302\u5f00\u62a521.7\u6e2f\u5143\uff0c\u8f83\u62db\u80a1\u4ef7\u4f4e28.17%\uff0c\u76d8\u524d\u6210\u4ea4\u989d677.47\u4e07\u6e2f\u5143\uff0c\u4e0d\u8ba1\u624b\u7eed\u8d39\uff0c\u6bcf\u624b100\u80a1\uff0c\u8d26\u9762\u4e8f851\u6e2f\u5143\u3002</p><p>\u6839\u636e\u62db\u80a1\u7ed3\u679c\u663e\u793a\uff0c\u6700\u7ec8\u53d1\u552e\u4ef7\u5b9a\u4e3a\u6bcf\u80a130.21\u6e2f\u5143\uff0c\u96c6\u8d44\u603b\u989d7.79\u4ebf\u6e2f\u5143\uff0c\u51c0\u989d\u7ea66.24\u4ebf\u6e2f\u5143\u3002\u4e00\u624b\u4e2d\u7b7e\u7387100%\uff0c\u4eba\u4eba\u6709\u4efd\u3002\u80a1\u4efd\u4e8e\u516c\u5f00\u53d1\u552e\u90e8\u4efd\u8ba4\u8d2d\u989d1.94\u500d\uff1b\u56fd\u9645\u53d1\u552e\u8ba4\u8d2d\u989d1.36\u500d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259773709", "pub_date": "2024-12-06 09:30:19"}, {"id": 259773708, "title": "\u592e\u884c\u4eca\u65e5\u8fdb\u884c1909\u4ebf\u51437\u5929\u671f\u9006\u56de\u8d2d\u64cd\u4f5c \u4e2d\u6807\u5229\u73871.5%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u592e\u884c\u4eca\u65e5\u8fdb\u884c1909\u4ebf\u51437\u5929\u671f\u9006\u56de\u8d2d\u64cd\u4f5c\uff0c\u4e2d\u6807\u5229\u7387\u4e3a1.50%\uff0c\u4e0e\u6b64\u524d\u6301\u5e73\u3002\u56e0\u4eca\u65e5\u67094790\u4ebf\u51437\u5929\u671f\u9006\u56de\u8d2d\u5230\u671f\uff0c\u5f53\u65e5\u5b9e\u73b0\u51c0\u56de\u7b3c2881\u4ebf\u5143\u3002\u592e\u884c\u672c\u5468\u5171\u5f00\u5c553541