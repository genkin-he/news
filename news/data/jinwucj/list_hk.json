ce8\u610f\u7684\u662f\uff0c\u7f8e\u5143\u66fe\u4e00\u5ea6\u5347\u903e\u4e24\u4e2a\u534a\u6708\u9ad8\u4f4d\uff0c\u7f8e\u56fd10\u5e74\u671f\u56fd\u503a\u6536\u76ca\u7387\u4ea6\u8d70\u9ad8\u3002<br/><br/>\u6469\u6839\u5927\u901a\u8d22\u5bcc\u7ba1\u7406\u5168\u7403\u591a\u5143\u8d44\u4ea7\u7ec4\u5408\u73af\u7403\u4e3b\u7ba1Monica Issar\u6307\uff0c\u672a\u676510\u81f315\u5e74\uff0c\u7f8e\u56fd\u5927\u578b\u4f01\u4e1a\u80a1\u7968\u53ef\u671b\u5f55\u5f976.7%\u5e74\u5ea6\u56de\u62a5\u7387\uff0c\u5c5e\u5177\u5438\u5f15\u529b\u7684\u6295\u8d44\u5de5\u5177\u3002\u7136\u800c\uff0c\u9ad8\u76db\u65e5\u524d\u53d1\u8868\u62a5\u544a\uff0c\u8ba4\u4e3a\u7f8e\u80a1\u957f\u8fdc\u56de\u62a5\u7387\u4ec53%\uff0c\u8b66\u544a\u5176\u6295\u8d44\u5438\u5f15\u529b\u8f83\u5f31\u3002<br/><br/>\u56fd\u5185\u65b9\u9762\uff0c\u6628\u65e5A\u80a1\u5448\u4f4e\u5f00\u9ad8\u8d70\u6001\u52bf\uff0c\u4f46\u76d8\u4e2d\u9047\u963b\uff0c\u6c7d\u8f66\u3001\u4f20\u5a92\u3001\u7535\u529b\u8bbe\u5907\u7b49\u677f\u5757\u8868\u73b0\u5f3a\u52bf\uff0c\u534a\u5bfc\u4f53\u3001\u4e92\u8054\u7f51\u670d\u52a1\u7b49\u677f\u5757\u53d7\u538b\u5c45\u524d\u3002\u56fd\u91d1\u8bc1\u5238\u8868\u793a\uff0c\u9884\u8ba1\u672a\u6765\u4e00\u4e2a\u5b63\u5ea6\u56fd\u5185\u5b8f\u89c2\u3001\u4e2d\u89c2\u5230\u5fae\u89c2\u5c42\u9762\u5747\u6709\u671b\u8fce\u6765\u8fb9\u9645\u6539\u5584\uff0c\u5404\u8def\u8d44\u91d1\u84c4\u52bf\u5f85\u53d1\uff0c\u6545\u7ef4\u6301\u5bf9\u672c\u8f6e\u201c\u53cd\u5f39\u201d\u884c\u60c5\u504f\u4e50\u89c2\u7684\u6001\u5ea6\uff0c\u5efa\u8bae\u9022\u4f4e\u914d\u7f6e\u201c\u79d1\u6280&gt;\u6d88\u8d39\u201d\u65b9\u5411\u3002<br/><br/>\u6e2f\u80a1\u5219\u9707\u8361\u5fae\u5347\u3002\u534e\u6cf0\u8bc1\u5238\u6307\uff0c\u4e0a\u5468\u6e2f\u80a1\u9707\u8361\u4f01\u7a33\uff0c\u5357\u5411\u548c\u9006\u52bf\u8d44\u91d1\u662f\u6d41\u5165\u4e3b\u529b\uff0c\u4e3b\u52a8\u5916\u8d44\u8d8b\u52bf\u6027\u62d0\u70b9\u4ecd\u9700\u7b49\u5f85\u3002<br/><br/>1\u3001\u6628\u65e5\u6caa\u6df1\u6e2f\uff1a<br/><br/>\u6caa\u6df1\u80a1\u5e02\uff1a\u5468\u4e8c\uff0c\u622a\u81f3\u6536\u76d8\uff0c\u6caa\u6307\u6da80.54%\uff0c\u6df1\u8bc1\u6210\u6307\u6da80.85%\uff0c\u521b\u4e1a\u677f\u6307\u6da80.3%\u3002<br/><br/>\u6e2f\u80a1\uff1a\u5468\u4e8c\uff0c\u622a\u81f3\u6536\u76d8\uff0c\u6052\u6307\u6da80.10%\uff0c\u56fd\u4f01\u6307\u6570\u6da80.31%\uff0c\u6052\u751f\u79d1\u6280\u6307\u6570\u6da80.66%\u3002<br/><br/>2\u3001\u9694\u591c\u5916\u76d8\uff1a<br/><br/>\u7f8e\u56fd\u80a1\u5e02\uff1a\u5468\u4e8c\uff0c\u7f8e\u56fd\u4e09\u5927\u80a1\u6307\u6536\u76d8\u6da8\u8dcc\u4e0d\u4e00\uff0c\u9053\u6307\u8dcc0.02%\u62a542924.89\u70b9\uff0c\u6807\u666e500\u6307\u6570\u8dcc0.05%\u62a55851.2\u70b9\uff0c\u7eb3\u6307\u6da80.18%\u62a518573.13\u70b9\u3002<br/><br/>\u6b27\u6d32\u80a1\u5e02\uff1a\u5468\u4e8c\uff0c\u6b27\u6d32\u4e09\u5927\u80a1\u6307\u6536\u76d8\u5c0f\u5e45\u4e0b\u8dcc\uff0c\u5fb7\u56fdDAX\u6307\u6570\u8dcc0.2%\u62a519421.91\u70b9\uff0c\u6cd5\u56fdCAC40\u6307\u6570\u8dcc0.01%\u62a57535.1\u70b9\uff0c\u82f1\u56fd\u5bcc\u65f6100\u6307\u6570\u8dcc0.14%\u62a58306.54\u70b9\u3002<br/><br/>\u65e5\u97e9\u80a1\u5e02\uff1a\u5468\u4e8c\uff0c\u97e9\u56fd\u7efc\u5408\u6307\u6570\u8dcc1.31%\u62a52570.7\u70b9\uff0c\u65e5\u7ecf225\u6307\u6570\u8dcc1.39%\u62a538411.96\u70b9\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255513898", "pub_date": "2024-10-23 08:48:36"}, {"id": 255513556, "title": "\u3010\u65b0\u80a1IPO\u3011\u534e\u660a\u4e2d\u5929\u533b\u836f-B(02563)\u4eca\u65e5\u8d77\u62db\u80a1 \u5165\u573a\u8d394,444.38\u6e2f\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u534e\u660a\u4e2d\u5929\u533b\u836f-B(02563)\u4eca\u65e5\u8d77\u62db\u80a1\uff0c\u62df\u53d1\u884c1458.8\u4e07\u80a1H\u80a1\uff0c\u5176\u4e2d10%\u4e3a\u9999\u6e2f\u516c\u5f00\u53d1\u552e\uff0c90%\u4e3a\u56fd\u9645\u914d\u552e\u3002\u6bcf\u80a1\u62db\u80a1\u4ef7\u4ecb\u4e8e16-22\u6e2f\u5143\uff0c\u6bcf\u624b200\u80a1\uff0c\u5165\u573a\u8d394,444.38\u6e2f\u5143\u3002\u80a1\u4efd\u9884\u671f\u5c06\u4e8e10\u670831\u65e5\u6302\u724c\u4e0a\u5e02\u3002\u5efa\u94f6\u56fd\u9645\u3001\u4e2d\u4fe1\u5efa\u6295\u56fd\u9645\u4e3a\u8054\u5e2d\u4fdd\u8350\u4eba\u3002<br/><br/>\u4ee5\u62db\u80a1\u4ef7\u4e2d\u4f4d\u6570\u8ba1\u7b97\uff0c\u516c\u53f8\u4f30\u8ba1\u5c06\u83b7\u5f97\u5168\u7403\u53d1\u552e\u7684\u6240\u5f97\u6b3e\u9879\u51c0\u989d\u7ea6\u4e3a2.34\u4ebf\u6e2f\u5143\u3002\u516c\u53f8\u62df\u5c06\u51c0\u989d\u7ea644.9%\u7528\u4e8e\u8d44\u52a9\u6838\u5fc3\u4ea7\u54c1\u7684\u8fdb\u884c\u4e2d\u53ca\u8ba1\u5212\u8fdb\u884c\u7684\u4e34\u5e8a\u8bd5\u9a8c\uff1b\u7ea638.9%\u7528\u4e8e\u8d44\u52a9\u6838\u5fc3\u4ea7\u54c1\u4ee5\u5916\u7684\u8fdb\u884c\u4e2d\u53ca\u8ba1\u5212\u8fdb\u884c\u7684\u4e34\u5e8a\u8bd5\u9a8c\uff0c\u53ca\u4ea7\u54c1\u4e34\u5e8a\u524d\u7814\u7a76\u4ee5\u53ca\u6838\u5fc3\u4ea7\u54c1\u7814\u7a76\u8005\u53d1\u8d77\u8bd5\u9a8c(\u4e3b\u8981\u5305\u62ec\u59d4\u6258\u4e34\u5e8a\u7814\u7a76\u4e2d\u5fc3\u5f00\u5c55\u4e34\u5e8a\u8bd5\u9a8c\u7684\u8d39\u7528\u3001\u652f\u4ed8\u4e88CRO\u548cSMO\u516c\u53f8\u7b49\u4f9b\u5e94\u5546\u7684\u7814\u53d1\u8d39\u7528\u3001\u4e34\u5e8a\u8bd5\u9a8c\u6240\u7528\u539f\u6750\u6599\u53ca\u8017\u6750\u7684\u6210\u672c\u3001\u76f8\u5173\u4e34\u5e8a\u56e2\u961f\u7684\u85aa\u916c\u53ca\u798f\u5229\uff0c\u4ee5\u53ca\u62db\u52df\u60a3\u8005\u53ca\u8058\u7528\u5916\u90e8\u987e\u95ee\u7684\u76f8\u5173\u6210\u672c)\uff1b\u7ea63%\u5c06\u7528\u4e8e\u52a0\u5f3a\u516c\u53f8\u7684\u56fd\u5185\u5546\u4e1a\u5316\u80fd\u529b\u53ca\u5efa\u7acb\u516c\u53f8\u7684\u5168\u7403\u8425\u9500\u7f51\u7edc\uff1b\u7ea63.2%\u5c06\u7528\u4e8e\u6269\u5927\u4ea7\u80fd\u3002\u5177\u4f53\u800c\u8a00\uff0c\u516c\u53f8\u8ba1\u5212\u6539\u8fdb\u516c\u53f8\u5728\u4e2d\u56fd\u6210\u90fd\u7684\u751f\u4ea7\u8bbe\u65bd\u7684\u751f\u4ea7\u5de5\u827a\u53ca\u751f\u4ea7\u8d28\u91cf\uff0c\u5e76\u4e3a\u4f18\u66ff\u5fb7\u9686\u7684\u65b0\u9002\u5e94\u75c7\u5efa\u7acb\u751f\u4ea7\u80fd\u529b\uff1b\u53e6\u7ea610%\u5c06\u7528\u4f5c\u8425\u8fd0\u8d44\u91d1\u53ca\u4e00\u822c\u516c\u53f8\u7528\u9014\u3002</p>", "link": "https:/