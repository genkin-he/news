8e\u5143\uff0c\u8dcc1.1%\u3002\u9650\u5236\u8d35\u91d1\u5c5e\u6da8\u5e45\u7684\u539f\u56e0\u5728\u4e8e\u5168\u7403\u503a\u5238\u66b4\u8dcc\uff0c\u9053\u660e\u8bc1\u5238\uff08TD Securities\uff09\u4e9a\u592a\u533a\u9ad8\u7ea7\u5229\u7387\u7b56\u7565\u5e08\u666e\u62c9\u6851\u7279\u00b7\u7ebd\u7eb3\u54c8\uff08Prashant Newnaha\uff09\u8868\u793a\uff0c\u201c\u672c\u5468\u7f8e\u56fd\u56fd\u503a\u629b\u552e\u52a0\u5267\uff0c\u56e0\u4e3a\u5e02\u573a\u62c5\u5fc3\uff0c\u5982\u679c\u7f8e\u8054\u50a8\u5728\u7ecf\u6d4e\u5f3a\u52b2\u7684\u80cc\u666f\u4e0b\u653e\u677e\u653f\u7b56\uff0c\u5c31\u6709\u53ef\u80fd\u91cd\u65b0\u70b9\u71c3\u901a\u80c0\u3002\u201d<br/><br/>\u5149\u4f0f\u592a\u9633\u80fd\u968f\u5e02\u56de\u8c03\uff0c\u987a\u98ce\u6e05\u6d01\u80fd\u6e90(01165)\u8dcc19.64%\uff0c\u9633\u5149\u80fd\u6e90(00757)\u8dcc7.14%\uff0c\u6c34\u53d1\u5174\u4e1a\u80fd\u6e90(00750)\u8dcc5.62%\uff0c\u51ef\u76db\u65b0\u80fd(01108)\u8dcc4.34%\uff0c\u4fe1\u4e49\u5149\u80fd(00968)\u8dcc2.89%\uff0c\u4fe1\u4e49\u73bb\u7483(00868)\u8dcc1.75%\u3002\u7f8e\u56fd\u5546\u52a1\u90e810\u670821\u65e5\u8d77\u542f\u52a8\u53d8\u66f4\u60c5\u51b5\u5ba1\u67e5(CCR)\uff0c\u8003\u8651\u90e8\u5206\u64a4\u9500\u4e2d\u56fd\u6676\u4f53\u7845\u5149\u4f0f\u7535\u6c60\u7684\u53cd\u503e\u9500\u7a0e\u548c\u53cd\u8865\u8d34\u7a0e\uff08AD/CVD\uff09\uff0c\u5e76\u9080\u8bf7\u76f8\u5173\u5404\u65b9\u53d1\u8868\u610f\u89c1\uff0c\u6240\u6d89\u4ea7\u54c1\u4e3a\u67d0\u4e9b\u5c0f\u578b\u3001\u4f4e\u74e6\u6570\u3001\u79bb\u7f51\u6676\u7845\u5149\u4f0f\uff08CSPV\uff09\u7535\u6c60\u3002\u5206\u6790\u6307\u51fa\u6b64\u4e3e\u610f\u5473\u7740\u7f8e\u56fd\u5bf9\u4e2d\u56fd\u5149\u4f0f\u7ec4\u4ef6\u4ea7\u54c1\u5173\u7a0e\u653f\u7b56\u51fa\u73b0\u4e86\u677e\u52a8\uff0c\u662f\u4e2d\u7f8e\u5173\u7cfb\u7f13\u548c\u7684\u5f81\u5146\uff0c\u540e\u7eed\u4e0d\u6392\u9664\u5149\u4f0f\u4ea7\u54c1\u8c41\u514d\u8303\u56f4\u8fdb\u2014\u6b65\u6269\u5927\u7684\u53ef\u80fd\u6027\u3002\u4e2d\u94f6\u56fd\u9645\u8868\u793a\uff0c\u4e2d\u56fd\u5149\u4f0f\u884c\u4e1a\u534f\u4f1a\u62ab\u9732\u5149\u4f0f\u4ea7\u4e1a\u94fe\u6210\u672c\u6570\u636e\uff0c\u82e5\u51fa\u73b0\u7ec4\u4ef6\u4f4e\u4e8e\u6210\u672c\u4e2d\u6807\uff0c\u4ee5\u53ca\u4f4e\u4e8e\u6210\u672c\u4e2d\u6807\u540e\u53ef\u80fd\u51fa\u73b0\u7684\u4ee5\u6b21\u5145\u597d\u3001\u4e0d\u80fd\u5c65\u7ea6\u7684\u884c\u4e3a\uff0c\u534f\u4f1a\u5c06\u8003\u8651\u91c7\u53d6\u5168\u884c\u4e1a\u901a\u62a5\u3001\u5411\u5e02\u573a\u76d1\u7ba1\u90e8\u95e8\u4e3e\u62a5\u7b49\u65b9\u5f0f\uff0c\u52a0\u5f3a\u884c\u4e1a\u81ea\u5f8b\u3002\u7531\u4e8e\u7ec4\u4ef6\u5382\u9700\u8981\u516c\u5f00\u53c2\u4e0e\u7ec8\u7aef\u7535\u7ad9\u9879\u76ee\u62db\u6295\u6807\uff0c\u6295\u6807\u4ef7\u683c\u5177\u5907\u5f3a\u900f\u660e\u5ea6\uff0c\u76f8\u5bf9\u6613\u4e8e\u53d7\u7b2c\u4e09\u65b9\u76d1\u7ba1\uff0c\u56e0\u6b64\u534f\u4f1a\u901a\u8fc7\u201c\u6210\u672c\u6cd5\u201d\u6307\u5bfc\u5e02\u573a\u4ef7\u683c\u5c06\u7387\u5148\u63a8\u52a8\u7ec4\u4ef6\u4ef7\u683c\u63d0\u5347\uff0c\u6709\u5229\u4e8e\u7ec4\u4ef6\u73af\u8282\u5229\u6da6\u4fee\u590d\u3002<br/><br/>\u4e2a\u80a1\u65b9\u9762\uff0c\u5146\u79d1\u773c\u79d1(06622)\u65e9\u76d8\u80a1\u4ef7\u9006\u5e02\u8d70\u9ad8\uff0c\u6700\u9ad8\u66fe\u89c11.62\u6e2f\u5143\uff0c\u6da8\u8d8519%\uff0c\u534a\u65e5\u53475.88%\uff0c\u62a51.44\u6e2f\u5143\uff0c\u6210\u4ea4\u989d568.15\u4e07\u6e2f\u5143\u3002\u6d88\u606f\u9762\u4e0a\uff0c\u516c\u53f8\u53d1\u5e03NVK002\u4e3a\u671f\u4e24\u5e74\u7684\u7b2cIII\u671f\u4e34\u5e8a\u8bd5\u9a8c\uff08China CHAMP\uff09\u7684\u9876\u7ebf\u7ed3\u679c\u3002\u7ecf\u8fc7\u4e24\u5e74\u7684\u6cbb\u7597\uff0c\u8fd9\u9879\u7814\u7a76\u5206\u6790\u663e\u793a\uff0cNVK002\u6ef4\u773c\u6db2\u7ec4\uff080.01%\u548c0.02%\u5242\u91cf\uff09\u5bf9\u6bd4\u5b89\u6170\u5242\u7ec4\u5728\u4e3b\u8981\u7597\u6548\u6307\u6807\u4e0a\u6709\u7edf\u8ba1\u5b66\u610f\u4e49\u7684\u663e\u7740\u6027\u5dee\u5f02\uff0cNVK002\u6ef4\u773c\u6db2\u7ec4\u4f18\u4e8e\u5b89\u6170\u5242\u7ec4\uff0c\u4e14\u5177\u6709\u5242\u91cf\u4f9d\u8d56\u3002\u4e24\u79cd\u5242\u91cf\u7684NVK002\u5b89\u5168\u6027\u826f\u597d\uff0c\u60a3\u8005\u4f7f\u7528\u4f9d\u4ece\u6027\u597d\u3002NVK002\u662f\u4e00\u79cd\u7528\u4e8e\u63a7\u5236\u513f\u7ae5\u53ca\u9752\u5c11\u5e74\u8fd1\u89c6\u52a0\u6df1\u7684\u8bd5\u9a8c\u6027\u65b0\u578b\u5916\u7528\u773c\u90e8\u6eb6\u6db2\u3002<br/><br/>\u65b0\u4e1c\u65b9(09901)\u7ee9\u540e\u8dcc7.39%\uff0c\u62a546.35\u6e2f\u5143\uff0c\u6210\u4ea4\u989d3.78\u4ebf\u6e2f\u5143\u3002\u516c\u53f8\u65e5\u524d\u516c\u544a\uff0c\u622a\u81f32024\u5e748\u670831\u65e5\u6b62\u4e4b2025\u8d22\u5e74\u7b2c\u4e00\u5b63\u5ea6\uff0c\u51c0\u5229\u6da6\u540c\u6bd4\u534748.40%\u81f32.45\u4ebf\u5143\uff08\u7f8e\u5143\uff0c\u4e0b\u540c\uff09\uff0c\u6bcf\u80a1\u57fa\u672c\u51c0\u52291.49\u5143\u3002\u516c\u53f8\u4e8e2025\u8d22\u5e74\u7b2c\u4e00\u5b63\u5ea6\uff0c\u51c0\u8425\u6536\u540c\u6bd4\u4e0a\u534730.5%\u81f314.35\u4ebf\u5143\uff0c\u51c0\u8425\u6536\uff08\u4e0d\u5305\u62ec\u4e1c\u65b9\u7504\u9009\u81ea\u8425\u4ea7\u54c1\u53ca\u76f4\u64ad\u7535\u5546\u4e1a\u52a1\u5b9e\u73b0\u7684\u8425\u6536\uff09\u5219\u540c\u6bd4\u4e0a\u534733.5%\u81f312.78\u4ebf\u5143\uff1b\u7ecf\u8425\u5229\u6da6\u540c\u6bd4\u4e0a\u534742.9%\u81f32.93\u4ebf\u5143\uff0c\u7ecf\u8425\u5229\u6da6\uff08\u4e0d\u5305\u62ec\u4e1c\u65b9\u7504\u9009\u81ea\u8425\u4ea7\u54c1\u53ca\u76f4\u64ad\u7535\u5546\u4e1a\u52a1\u4ea7\u751f\u7684\u7ecf\u8425\u4e8f\u635f\uff09\u5219\u540c\u6bd4\u4e0a\u534758.4%\u81f33.03\u4ebf\u5143\u3002\u65b0\u4e1c\u65b9\u7ba1\u7406\u5c42\u8868\u793a\uff0c\u5c06\u8c28\u614e\u5730\u6269\u5f20\u548c\u62db\u8058\uff0c\u4ee5\u652f\u6491\u6559\u80b2\u4e1a\u52a1\u53d1\u5c55\u3002\u516c\u53f8\u9884\u8ba12025\u8d22\u5e74\u7b2c\u4e8c\u5b63\u5ea6(2024\u5e749\u67081\u65e5\u81f32024\u5e7411\u670830\u65e5)\u7684\u51c0\u8425\u6536(\u4e0d\u5305\u62ec\u4e1c\u65b9\u7504\u9009\u81ea\u8425\u4ea7\u54c1\u53ca\u76f4\u64ad\u7535\u5546\u4e1a\u52a1\u5b9e\u73b0\u7684\u8425\u6536)\u5c06\u4e3a8.514\u4ebf\u7f8e\u5143\u81f38.718\u4ebf\u7f8e\u5143\u4e4b\u95f4\uff0c\u540c\u6bd4\u4e0a\u534725%\u81f328%\u3002