13\u7684\u6210\u529f\u7ecf\u9a8c\uff0c\u5373\u65e5\u8d77\uff0c\u8fdb\u53e3\u4ef7200\u6e2f\u5143\u4ee5\u4e0a\u7684\u70c8\u9152\uff0c200\u6e2f\u5143\u4ee5\u4e0a\u90e8\u5206\u7684\u7a0e\u7387\u7531100%\u51cf\u81f310%\uff0c\u800c200\u6e2f\u5143\u53ca\u4ee5\u4e0b\u90e8\u5206\uff0c\u53ca\u8fdb\u53e3\u4ef7\u5728200\u6e2f\u5143\u6216\u4ee5\u4e0b\u7684\u70c8\u9152\uff0c\u7a0e\u7387\u5219\u7ef4\u6301\u4e0d\u53d8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254934182", "pub_date": "2024-10-16 12:30:26"}, {"id": 254933754, "title": "\u674e\u5bb6\u8d85\uff1a\u8bbe\u7acb100\u4ebf\u6e2f\u5143\u201c\u521b\u79d1\u4ea7\u4e1a\u5f15\u5bfc\u57fa\u91d1\u201d ", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9999\u6e2f\u884c\u653f\u957f\u5b98\u674e\u5bb6\u8d85\u53d1\u8868\u4efb\u5185\u7b2c3\u4efd\u65bd\u653f\u62a5\u544a\u3002\u4ed6\u8868\u793a\uff0c\u8bbe\u7acb100\u4ebf\u6e2f\u5143\u201c\u521b\u79d1\u4ea7\u4e1a\u5f15\u5bfc\u57fa\u91d1\u201d\uff0c\u4f18\u5316\u201c\u521b\u79d1\u521b\u6295\u57fa\u91d1\u201d\uff0c\u8c03\u62e815\u4ebf\u6e2f\u5143\u4e0e\u4e1a\u754c\u914d\u5bf9\u6210\u7acb\u8054\u5408\u57fa\u91d1\uff0c\u6295\u8d44\u7b56\u7565\u6027\u4ea7\u4e1a\u7684\u521d\u521b\u4f01\u4e1a\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254933754", "pub_date": "2024-10-16 12:25:56"}, {"id": 254933924, "title": "\u674e\u5bb6\u8d85\uff1a\u8fdb\u4e00\u6b65\u4f18\u5316\u8bc1\u5238\u5e02\u573a \u4e89\u53d6\u77ed\u671f\u5185\u5b9e\u73b0\u66f4\u591a\u6807\u5fd7\u6027IPO", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9999\u6e2f\u884c\u653f\u957f\u5b98\u674e\u5bb6\u8d85\u53d1\u8868\u4efb\u5185\u7b2c3\u4efd\u65bd\u653f\u62a5\u544a\u3002\u4ed6\u8868\u793a\uff0c\u653f\u5e9c\u4f1a\u7ee7\u7eed\u79ef\u6781\u62d3\u5c55\u548c\u6df1\u5316\u6d77\u5916\u7f51\u7edc\uff0c\u5305\u62ec\u4e0e\u4e2d\u4e1c\u3001\u4e1c\u76df\u5730\u533a\u7684\u91d1\u878d\u5408\u4f5c\uff0c\u4e3e\u529e\u66f4\u591a\u56fd\u9645\u91d1\u878d\u76db\u4e8b\uff0c\u5e76\u5728\u91d1\u878d\u9886\u57df\u4e0a\u5bfb\u6c42\u8fdb\u4e00\u6b65\u4e0e\u4f0a\u65af\u5170\u5e02\u573a\u5408\u4f5c\u3002<br/><br/>\u674e\u5bb6\u8d85\u6307\u51fa\uff0c\u8fdb\u4e00\u6b65\u4f18\u5316\u8bc1\u5238\u5e02\u573a\u76844\u9879\u63aa\u65bd\u5305\u62ec\uff0c\u5f00\u62d3\u6d77\u5916\u65b0\u8d44\u91d1\uff0c\u843d\u5b9e\u8ffd\u8e2a\u9999\u6e2f\u80a1\u7968\u6307\u6570\u7684\u4ea4\u6613\u6240\u4e70\u5356\u57fa\u91d1(ETF)\u5728\u4e2d\u4e1c\u4e0a\u5e02\uff0c\u5438\u7eb3\u5f53\u5730\u8d44\u91d1\u914d\u7f6e\u6e2f\u80a1\uff1b\u4e89\u53d6\u4f01\u4e1a\u4e0a\u5e02\uff0c\u5584\u7528\u4e0e\u5185\u5730\u5e02\u573a\u201c\u4e92\u8054\u4e92\u901a\u201d\u7684\u4f18\u52bf\uff0c\u5438\u5f15\u56fd\u9645\u4f01\u4e1a\u6765\u6e2f\u4e0a\u5e02\uff0c\u540c\u65f6\u63a8\u52a8\u5185\u5730\u5927\u578b\u4f01\u4e1a\u8d74\u6e2f\u4e0a\u5e02\uff0c\u4e89\u53d6\u77ed\u671f\u5185\u5b9e\u73b0\u66f4\u591a\u6807\u5fd7\u6027\u7684\u516c\u5f00\u62db\u80a1(IPO)\u3002<br/><br/>\u6b64\u5916\uff0c\u4f18\u5316\u4e0a\u5e02\u5ba1\u6279\uff0c\u8bc1\u76d1\u4f1a\u548c\u6e2f\u4ea4\u6240(00388)\u5c06\u516c\u5e03\u8fdb\u4e00\u6b65\u4f18\u5316\u4e0a\u5e02\u6279\u6838\u6d41\u7a0b\u7684\u5177\u4f53\u63aa\u65bd\uff0c\u4ee4\u4e0a\u5e02\u7533\u8bf7\u5ba1\u6279\u65f6\u95f4\u66f4\u6709\u786e\u5b9a\u6027\uff1b\u53ca\u63d0\u5347\u5e02\u573a\u6548\u7387\uff0c\u8bc1\u76d1\u4f1a\u548c\u6e2f\u4ea4\u6240\u4f1a\u63d0\u5347\u5e02\u573a\u6548\u7387\u53ca\u964d\u4f4e\u4ea4\u6613\u6210\u672c\uff0c\u5305\u62ec\u68c0\u89c6\u4fdd\u8bc1\u91d1\u7684\u5b58\u5165\u5b89\u6392\u3001\u4f18\u5316\u4fdd\u8bc1\u91d1\u548c\u62b5\u62bc\u54c1\u8981\u6c42\u7b49\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254933924", "pub_date": "2024-10-16 12:28:05"}]}