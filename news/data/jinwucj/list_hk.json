f\u9ad8\u79fb\u6c11\u6c34\u5e73\u3002\u7b2c\u4e09\u5b63\u5ea6GDP\u589e\u957f\u4f4e\u4e8e\u52a0\u62ff\u5927\u592e\u884c10\u6708\u7684\u9884\u6d4b\uff0c\u5bb6\u5ead\u652f\u51fa\u5728\u6c7d\u8f66\u548c\u91d1\u878d\u670d\u52a1\u4e0a\u6709\u6240\u589e\u957f\uff0c\u4f46\u5546\u4e1a\u6295\u8d44\u75b2\u8f6f\u3002<br/><br/>\u53e6\u5916\uff0c\u9884\u8ba1\u52a0\u62ff\u5927\u592e\u884c\u5c06\u7ee7\u7eed\u5176\u8d44\u4ea7\u8d1f\u503a\u8868\u7f29\u51cf\u8ba1\u5212\uff0c\u9884\u8ba1\u8fd9\u4e00\u8ba1\u5212\u5c06\u57282025\u5e747\u6708\u7ed3\u675f\u3002<br/><br/>\u62a5\u544a\u8fd8\u63d0\u5230\uff0c\u7f8e\u56fd\u53ef\u80fd\u5bf9\u52a0\u62ff\u5927\u5546\u54c1\u5f81\u653625%\u5173\u7a0e\u7684\u98ce\u9669\uff0c\u8fd9\u53ef\u80fd\u4f1a\u5bf9\u52a0\u62ff\u5927\u7ecf\u6d4e\u589e\u957f\u9884\u671f\u4ea7\u751f\u91cd\u5927\u5f71\u54cd\u3002\u52a0\u62ff\u5927\u592e\u884c\u8868\u793a\uff0c\u9664\u975e\u5b9e\u9645\u5b9e\u65bd\uff0c\u5426\u5219\u4e0d\u4f1a\u5c06\u5173\u7a0e\u53ef\u80fd\u6027\u7eb3\u5165\u8d27\u5e01\u653f\u7b56\u51b3\u7b56\u4e2d\u3002<br/><br/>\u8be5\u884c\u5efa\u8bae\u6295\u8d44\u8005\u5173\u6ce8\u52a0\u62ff\u5927\u592e\u884c\u7684\u524d\u77bb\u6027\u6307\u5f15\uff0c\u7279\u522b\u662f\u5173\u4e8e\u5229\u7387\u4e0b\u9650\u3001\u6f5c\u5728\u8d38\u6613\u7d27\u5f20\u5173\u7cfb\u7684\u8d27\u5e01\u653f\u7b56\u5f71\u54cd\u4ee5\u53ca\u4e0e\u7f8e\u8054\u50a8\u7684\u653f\u7b56\u5206\u6b67\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260278464", "pub_date": "2024-12-11 16:13:39"}, {"id": 260276991, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5927\u6469\u6599\u660e\u5e74\u9996\u5b63\u4e2d\u56fd\u51fa\u53e3\u589e\u957f\u4fdd\u6301\u6e29\u548c \u6b21\u5b63\u5c06\u653e\u7f13", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6469\u6839\u58eb\u4e39\u5229\u7814\u62a5\u6307\uff0c\u5c3d\u7ba1\u5168\u7403\u8d38\u6613\u5468\u671f\u53ef\u80fd\u57282024\u5e74\u4e2d\u671f\u8fbe\u5230\u9876\u5cf0\uff0c\u4e2d\u56fd\u7684\u51fa\u53e3\u8868\u73b0\u4f9d\u7136\u5f3a\u52b2\uff0c\u540c\u6bd4\u589e\u957f6.7%\uff0c\u8d85\u51fa\u4e86\u97e9\u56fd\u548c\u8d8a\u5357\u3002\u5bf9\u7f8e\u51fa\u53e3\u65b9\u9762\uff0c11\u6708\u4efd\u5bf9\u7f8e\u56fd\u7684\u51fa\u53e3\u540c\u6bd4\u589e\u957f1%\uff0c\u663e\u793a\u51fa\u5728\u6f5c\u5728\u5173\u7a0e\u5b9e\u65bd\u524d\u201c\u62a2\u51fa\u53e3\u201d\u8ff9\u8c61\u3002\u8fdb\u53e3\u540c\u6bd4\u4e0b\u964d3.9%\uff0c\u4e3b\u8981\u53d7\u9ad8\u79d1\u6280\u4ea7\u54c1\u548c\u5927\u8c46\u8fdb\u53e3\u51cf\u5c11\u7684\u5f71\u54cd\uff0c\u800c\u56fd\u5185\u9700\u6c42\u4fdd\u6301\u7a33\u5b9a\u4f46\u7f3a\u4e4f\u6d3b\u529b\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u6c7d\u8f66\u51fa\u53e3\u8fde\u7eed\u4e09\u4e2a\u6708\u653e\u7f13\uff0c\u800c\u52b3\u52a8\u5bc6\u96c6\u578b\u6d88\u8d39\u54c1\u51fa\u53e3\u572811\u6708\u589e\u957f1.5%\uff0c10\u6708\u589e\u957f4%\u3002\u9ad8\u79d1\u6280\u4ea7\u54c1\u548c\u5927\u8c46\u5206\u522b\u5bfc\u81f4\u8fdb\u53e3\u589e\u957f\u540c\u6bd4\u4e0b\u964d1.8\u4e2a\u767e\u5206\u70b9\u548c0.9\u4e2a\u767e\u5206\u70b9\u3002\u5c3d\u7ba1\u8fd9\u4e9b\u5173\u952e\u62d6\u7d2f\u53ef\u80fd\u4e0d\u53cd\u6620\u56fd\u5185\u9700\u6c42\uff0c\u4f46\u603b\u4f53\u8fdb\u53e3\u589e\u957f\u4ecd\u7136\u75b2\u8f6f\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0c\u5982\u679c\u5386\u53f2\u6a21\u5f0f\u91cd\u590d\uff0c\u51fa\u53e3\u589e\u957f\u53ef\u80fd\u4f1a\u57282025\u5e74\u7b2c\u4e00\u5b63\u5ea6\u4fdd\u6301\u6e29\u548c\uff0c\u7136\u540e\u57282025\u5e74\u7b2c\u4e8c\u5b63\u5ea6\u66f4\u660e\u663e\u5730\u653e\u7f13\uff0c\u5168\u5e74\u5e73\u5747\u589e\u957f\u7387\u4e3a0-1%\uff082024\u5e74\u7ea6\u4e3a5.5%\uff09\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260276991", "pub_date": "2024-12-11 16:04:31"}, {"id": 260276380, "title": "\u4e2d\u56fd\u5145\u7535\u8054\u76df\uff1a\u999611\u6708\u5145\u7535\u57fa\u7840\u8bbe\u65bd\u589e\u91cf\u540c\u6bd4\u4e0a\u534723%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u201c\u4e2d\u56fd\u5145\u7535\u8054\u76df\u201d\u516c\u4f17\u53f7\u6d88\u606f\uff0c2024\u5e741-11\u6708\uff0c\u5145\u7535\u57fa\u7840\u8bbe\u65bd\u589e\u91cf\u4e3a375.6\u4e07\u53f0\uff0c\u540c\u6bd4\u4e0a\u534723.0%\u3002\u5176\u4e2d\u516c\u5171\u5145\u7535\u6869\u589e\u91cf\u4e3a73.4\u4e07\u53f0\uff0c\u540c\u6bd4\u4e0b\u964d11.3%\uff0c\u968f\u8f66\u914d\u5efa\u79c1\u4eba\u5145\u7535\u6869\u589e\u91cf\u4e3a302.2\u4e07\u53f0\uff0c\u540c\u6bd4\u4e0a\u534735.7%\u3002\u622a\u6b622024\u5e7411\u6708\uff0c\u5168\u56fd\u5145\u7535\u57fa\u7840\u8bbe\u65bd\u7d2f\u8ba1\u6570\u91cf\u4e3a1235.2\u4e07\u53f0\uff0c\u540c\u6bd4\u4e0a\u534749.5%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260276380", "pub_date": "2024-12-11 16:00:09"}, {"id": 260276381, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u56fd\u5143\u56fd\u9645\u6307\u5149\u4f0f\u73bb\u7483\u884c\u4e1a\u5e95\u90e8\u5468\u671f\u660e\u786e \u770b\u597d2025Q2\u9700\u6c42\u590d\u82cf\u540e\u884c\u4e1a\u5f00\u542f\u65b0\u5468\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u56fd\u5143\u56fd\u9645\u53d1\u7814\u62a5\u6307\uff0c2024\u5e7410\u670830\u65e5\uff0c\u5de5\u4fe1\u90e8\u5370\u53d1\u300a\u6c34\u6ce5\u73bb\u7483\u884c\u4e1a\u4ea7\u80fd\u7f6e\u6362\u5b9e\u65bd\u529e\u6cd5(2024\u5e74\u672c)\u300b\uff0c\u5220\u9664\u4e0a\u4e00\u7248\u5149\u4f0f\u73bb\u7483\u4ea7\u7ebf\u53ef\u4e0d\u5236\u5b9a\u4ea7\u80fd\u7f6e\u6362\u65b9\u6848\uff0c\u589e\u52a0\u9f13\u52b1\u5149\u4f0f\u538b\u5ef6\u73bb\u7483\u9879\u76ee\u901a\u8fc7\u4ea7\u80fd\u7f6e\u6362\u4e88\u4ee5\u5efa\u8bbe\uff0c\u9884\u8ba1\u5728\u4e00\u5b9a\u7a0b\u5ea6\u4e0a\u6709\u52a9\u7f13\u89e3\u5149\u4f0f\u73bb\u7483\u7684\u4f9b\u7ed9\u538b\u529b\u3002\u6839\u636e\u5de5\u4fe1\u90e8\u6700\u65b0\u653f\u7b56\uff0c\u5149\u4f0f\u73bb\u7483\u751f\u4ea7\u7ebf\u7684\u5efa\u8bbe\u53ef\u4ee5\u901a\u8fc7\u4ea7\u80fd\u7f6e\u6362\u6216\u98ce\u9669\u9884\u8b66\u673a\u5236\u8fdb\u884c\u3002\u81ea2022\u5e74\u542c\u8bc1\u4f1a\u6d41\u7a0b\u5f00\u59cb\u540e\uff0c\u4e09\u6279\u9879\u76ee\u83b7\u6279\uff0c\u5df2\u83b7\u6279\u7684\u9879\u76ee\u6574\u4f53\u6295\u4ea7\u7387\u8f83\u4f4e\uff0c90%\u6279\u590d\u9879\u76ee\u5c1a\u672a\u5f00\u5de5\uff0c\u9884\u671f\u540e\u7eed\u65b0\u6279\u590d\u9879\u76ee\u6982\u7387\u8f83\u5c0f\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0c\u6839\u636eSMM\u7edf\u8ba1\uff0c\u4ea7\u7ebf\u5f00\u5de5\u7387\u53ef\u4ee5\u6839\u636e\u4e0b\u6e38\u9700\u6c42\u7075\u6d3b\u8c03\u6574\uff0c\u56fd\u5185\u5149\u4f0f\u7ec4\u4ef6\u884c\u4e1a\u5f00\u5de5\u7387\u957f\u671f\u5904\u4e8e40-80%\u533a\u95f4\u5185\u6ce2\u52a8\u3002\u7531\u4e8e\u4f9b\u9700\u9519\u914d\uff0c24\u5e74\u4ee5\u6765\u7ec4\u4ef6\u4ef7\u683c\u6301\u7eed\u4e0b\u8dcc\uff0c\u56fd\u5185\u7ec4\u4ef6\u5382\u5168\u9762\u4e8f\u635f\uff0c\u4f01\u4e1a\u5f00\u5de5\u7387\u5206\u5316\u52a0\u5267\uff0c\u6839\u636ePVInfoLink\u7edf\u8ba1\uff0c24\u5e7410\u6708\u56fd\u5185TOP10\u7ec4\u4ef6\u4f01\u4e1a\u5f00\u5de5\u7387\u4e3a66%\uff0c\u800c\u5176\u4ed6\u4f01\u4e1a\u5f00\u5de5\u7387\u4ec5\u4e3a27%\u3002\u6700\u65b0SMM\u7edf\u8ba1\uff0c11\u6708\u4e2d\u56fd\u5149\u4f0f\u7ec4\u4ef6\u4ea7\u91cf\u8f8310\u6708\u73af\u6bd4\u4e0b\u964d\u7ea61.6%\uff0c\u884c\u4e1a\u5f00\u5de5\u7387\u7ea649.6%\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u4eca\u5e74\u4ee5\u6765\u7531\u4e8e\u5149\u4f0f\u73bb\u7483\u4ef7\u683c\u8d70\u5f31\uff0c\u884c\u4e1a\u6bdb\u5229\u7387\u57fa\u672c\u6301\u7eed\u4e0b\u964d\uff0c\u76ee\u524d\u5728-7.6%\u9644\u8fd1\u3002\u53d7\u4ea7\u54c1\u4ef7\u683c\u4f4e\u8ff7\uff0c\u5e02\u573a\u9700\u6c42\u75b2\u8f6f\uff0c\u505c\u7a91\u51b7\u4fee\u5bfc\u81f4\u7684\u5355\u4f4d\u56fa\u5b9a\u8d44\u4ea7\u5206\u644a\u6210\u672c\u63d0\u5347\u4ee5\u53ca\u8d44\u4ea7\u51cf\u503c\u8ba1\u63d0\u7b49\u591a\u79cd\u56e0\u7d20\u5f71\u54cd\uff0c\u76ee\u524d\u4ef7\u683c\u6c34\u5e73\u4e0b\uff0c\u5149\u4f0f\u73bb\u7483\u4f01\u4e1a\u4e09\u5b63\u62a5\u666e\u904d\u4e8f\u635f\uff0c\u5305\u62ec\u798f\u83b1\u7279\u7b49\u5934\u90e8\u4f01\u4e1a\u3002\u9884\u8ba1Q4\u5149\u4f0f\u73bb\u7483\u76c8\u5229\u6301\u7eed\u627f\u538b\uff0c2025\u5e74Q1\u968f\u7740\u4ef7\u683c\u5411\u4e0a\u56de\u5f52\u7406\u6027\u533a\u95f4\uff0c\u4f01\u4e1a\u76c8\u5229\u6709\u671b\u5f00\u59cb\u8fb9\u9645\u6539\u5584\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u5149\u4f0f\u73bb\u7483\u884c\u4e1a\u5e95\u90e8\u5468\u671f\u660e\u786e\uff0c\u4ea7\u80fd\u6b63\u52a0\u901f\u51fa\u6e05\uff0c\u8be5\u884c\u521d\u6b65\u5224\u65ad2025Q1\u5373\u5c06\u8fce\u6765\u53bb\u5e93\u5b58\u548c\u4f9b\u9700\u9010\u6e10\u5e73\u8861\u9636\u6bb5\uff0c\u770b\u597d2025Q2\u9700\u6c42\u590d\u82cf\u540e\u884c\u4e1a\u5f00\u542f\u65b0\u5468\u671f\u3002\u5efa\u8bae\u91cd\u70b9\u5173\u6ce8\uff1a\u798f\u83b1\u7279\u73bb\u7483(06865)\u548c\u4fe1\u4e49\u5149\u80fd(00968)\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260276381", "pub_date": "2024-12-11 16:00:17"}, {"id": 260276382, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6d77\u901a\u8bc1\u5238\u9996\u4e88\u9996\u94a2\u8d44\u6e90(00639)\u201c\u4f18\u4e8e\u5927\u5e02\u201d\u8bc4\u7ea7 \u6307\u7126\u7164\u4e3b\u4e1a\u6709\u671b\u7ef4\u6301\u9ad8\u76c8\u5229", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6d77\u901a\u8bc1\u5238\u53d1\u7814\u62a5\u6307\uff0c\u9996\u94a2\u8d44\u6e90(00639)\u4e3b\u8981\u4ece\u4e8b\u7126\u7164\u5f00\u91c7\u4ee5\u53ca\u539f\u7126\u7164\u53ca\u7cbe\u7126\u7164\u751f\u4ea7\u548c\u9500\u552e\uff0c\u5730\u5904\u4f18\u8d28\u7126\u7164\u77ff\u6838\u5fc3\u4ea7\u533a\u3002\u516c\u53f8\u6210\u7acb\u4e8e1985\u5e74\uff0c2009\u5e74\uff0c\u9999\u6e2f\u9996\u63a7\u5f00\u5c55\u8d44\u672c\u8fd0\u4f5c\u6536\u8d2d\u4e86\u798f\u5c71\u56fd\u9645\u80fd\u6e90\u96c6\u56e2\u6709\u9650\u516c\u53f8\uff0c\u5e76\u4e8e2011\u5e74\u66f4\u540d\u4e3a\u9996\u94a2\u8d44\u6e90\u30022021\u5e74\u80a1\u4e1c\u8fdb\u4e00\u6b65\u6ea2\u4ef7\u6536\u8d2d\u3001\u5f70\u663e\u53d1\u5c55\u4fe1\u5fc3\u3002\u516c\u53f8\u63a7\u80a1\u80a1\u4e1c\u548c\u5b9e\u9645\u63a7\u5236\u4eba\u4e3a\u9996\u94a2\u96c6\u56e2(\u622a\u81f32024\u5e74\u4e2d\u62a5\u5408\u8ba1\u6301\u80a133.3%)\uff0c\u540c\u65f6\u4e5f\u662f\u516c\u53f8\u7684\u6218\u7565\u5ba2\u6237\uff0c\u81f4\u529b\u4e8e\u6210\u4e3a\u4e2d\u56fd\u4e3b\u8981\u7684\u4e00\u4f53\u5316\u7126\u7164\u751f\u4ea7\u5546\u4e4b\u4e00\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u516c\u53f8\u4e09\u5ea7\u77ff\u4e95\u5174\u65e0\u7164\u77ff\u3001\u91d1\u5bb6\u5e84\u77ff\u3001\u5be8\u5d16\u5e95\u7164\u77ff(\u4ea7\u80fd\u5404175\u4e07\u5428/\u5e74)\u5747\u4f4d\u4e8e\u56fd\u5185\u4f18\u8d28\u7126\u7164\u77ff\u6838\u5fc3\u4ea7\u533a\u5c71\u897f\u67f3\u6797\u53bf\uff0c\u51fa\u4ea7\u7684\u7126\u7164\u7531\u4e8e\u5176\u7a00\u7f3a\u6027\u53ca\u9ad8\u7ecf\u6d4e\u4ef7\u503c\uff0c\u88ab\u8a89\u4e3a\u201c\u718a\u732b\u7164\u201d\u3002\u516c\u53f8\u8fd1\u4e94\u5e74\u539f\u7164\u548c\u7cbe\u7164\u4ea7\u91cf\u7a33\u6b65\u63d0\u5347\uff0c24\u5e74\u5174\u65e0\u7164\u77ff\u4e0a\u4e0b\u7ec4\u7164\u63a5\u66ff\u5c06\u5b8c\u6210\u8054\u5408\u8bd5\u8fd0\u8f6c\uff0c\u4ea7\u91cf\u6709\u671b\u7a33\u4e2d\u6709\u5347\u3002\u516c\u53f8\u751f\u4ea7\u7cbe\u7164\u7684\u826f\u597d\u54c1\u8d28\u6784\u7b51\u4f18\u8d28\u5927\u5ba2\u6237\u57fa\u7840\uff0c\u8fd1\u4e09\u5e74\u6700\u5927\u5ba2\u6237\u9996\u94a2\u96c6\u56e2\u53ca\u5176\u63a7\u80a1\u516c\u53f8\u5360\u6bd4\u5747\u572840%\u4ee5\u4e0a(2023\u5e74\u4e3a43%)\uff0c\u6709\u5229\u4e8e\u7ef4\u6301\u9ad8\u552e\u4ef7\u3002\u516c\u53f8\u6210\u672c\u7ba1\u63a7\u6210\u679c\u663e\u7740\uff0c\u4ece\u4ee5\u539f\u7164\u8ba1\u7684\u5428\u7164\u6210\u672c\u6765\u770b\uff0c2023\u5e74\u516c\u53f8\u5b9e\u73b0\u5428\u7164\u6210\u672c419\u5143/\u5428\uff0c\u540c\u6bd4-16%\u3002<br/><br/>\u8be5\u884c\u8ba4\u4e3a\uff0c\u516c\u53f8\u4f5c\u4e3a\u9996\u94a2\u96c6\u56e2\u65d7\u4e0b\u4f18\u8d28\u786c\u7126\u7164\u751f\u4ea7\u5546\uff0c\u4ea7\u54c1\u54c1\u8d28\u548c\u80a1\u4e1c\u8d44\u6e90\u4f18\u52bf\u663e\u7740\uff0c\u7126\u7164\u4e3b\u4e1a\u6709\u671b\u7ef4\u6301\u9ad8\u76c8\u5229\u3002\u8be5\u884c\u9884\u8ba124-26\u5e74\u516c\u53f8\u5f52\u6bcd\u51c0\u5229\u6da6\u4e3a16.7/17.7/18.2\u4ebf\u6e2f\u5143\uff0c\u5bf9\u5e94EPS\u4e3a0.33/0.35/0.36\u6e2f\u5143\uff0c\u53c2\u8003\u7164\u70ad\u677f\u5757\u53ef\u6bd4\u516c\u53f8\uff0c\u7ed9\u4e882024\u5e7410~12\u500dPE\uff0c\u5bf9\u5e94\u5408\u7406\u4ef7\u503c\u533a\u95f43.27~3.93\u6e2f\u5143\uff0c\u9996\u6b21\u8986\u76d6\uff0c\u7ed9\u4e88\u201c\u4f18\u4e8e\u5927\u5e02\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260276382", "pub_date": "2024-12-11 16:00:23"}]}