\uff0c\u968f\u7740\u6295\u8d44\u8005\u8f6c\u5411\u5305\u62ec\u503a\u5238\u5728\u5185\u7684\u5176\u4ed6\u8d44\u4ea7\u5bfb\u6c42\u66f4\u597d\u7684\u56de\u62a5\uff0c\u7f8e\u80a1\u4e0d\u592a\u53ef\u80fd\u4fdd\u6301\u4f4f\u8fc7\u53bb\u5341\u5e74\u9ad8\u4e8e\u5e73\u5747\u6c34\u5e73\u7684\u8868\u73b0\u3002David Kostin\u7b49\u7b56\u7565\u5e08\u5206\u6790\u79f0\uff0c\u9884\u8ba1\u6807\u666e500\u6307\u6570\u672a\u6765\u5341\u5e74\u7684\u5e74\u5316\u540d\u4e49\u603b\u56de\u62a5\u7387\u5c06\u4ec5\u7565\u9ad8\u4e8e3%\u3002\u8fc7\u53bb\u5341\u5e74\u8fd9\u4e2a\u6570\u503c\u4e3a13%\uff0c\u957f\u671f\u5e73\u5747\u6c34\u5e73\u4e3a11%\u3002\u4ed6\u4eec\u8fd8\u8ba4\u4e3a\uff0c\u8be5\u57fa\u51c6\u6307\u6570\u56de\u62a5\u7387\u5c06\u6709\u5927\u7ea672%\u7684\u6982\u7387\u843d\u540e\u4e8e\u7f8e\u56fd\u56fd\u503a\uff0c\u57282034\u5e74\u5e95\u524d\u670933%\u7684\u6982\u7387\u5c06\u843d\u540e\u4e8e\u901a\u80c0\u3002\u8be5\u56e2\u961f\u572810\u670818\u65e5\u7684\u4e00\u4efd\u62a5\u544a\u4e2d\u5199\u9053\uff0c\u201c\u6295\u8d44\u8005\u5e94\u8be5\u4e3a\u672a\u6765\u5341\u5e74\u7684\u80a1\u7968\u56de\u62a5\u7387\u63a5\u8fd1\u5176\u5178\u578b\u4e1a\u7ee9\u5206\u5e03\u7684\u4f4e\u7aef\u505a\u597d\u51c6\u5907\u3002\u201d<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255360178", "pub_date": "2024-10-21 21:26:31"}, {"id": 255357658, "title": "\u58f3\u724c(SHEL)\u7ea630\u5428\u6cb9\u6c34\u6df7\u5408\u7269\u6cc4\u6f0f\u81f3\u65b0\u52a0\u5761\u6d77\u57df", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u58f3\u724c(SHEL)\u53d1\u8868\u58f0\u660e\u79f0\uff0c\u8be5\u516c\u53f8\u5728\u65b0\u52a0\u5761\u6bdb\u5e7f\u5c9b\u7684\u9646\u4e0a\u8f93\u6cb9\u7ba1\u53d1\u751f\u6ea2\u6f0f\uff0c\u7ea630\u5428\u81f340\u5428\u6cb9\u6c34\u6df7\u5408\u7269\u6cc4\u6f0f\u5165\u6d77\uff0c\u516c\u53f8\u6b63\u5728\u4e0e\u65b0\u52a0\u5761\u5f53\u5c40\u5408\u4f5c\u8fdb\u884c\u6e05\u7406\u5de5\u4f5c\u3002\u65b0\u52a0\u5761\u56fd\u5bb6\u516c\u56ed\u5c40\u3001\u73af\u5883\u5c40\u548c\u516c\u7528\u4e8b\u4e1a\u5c40\u7b49\u90e8\u95e821\u65e5\u8868\u793a\uff0c\u6b64\u6b21\u6f0f\u6cb9\u4e8b\u4ef6\u76ee\u524d\u672a\u5bf9\u65b0\u52a0\u5761\u6c34\u4f9b\u5e94\u548c\u6d77\u6ee9\u9020\u6210\u5f71\u54cd\u3002\u4e3a\u9884\u9632\u6cb9\u6c61\u6269\u6563\uff0c\u65b0\u52a0\u5761\u6709\u5173\u90e8\u95e8\u5728\u5168\u5c9b\u591a\u5904\u6c34\u57df\u90e8\u7f72\u9632\u6cb9\u6d6e\u6805\uff0c\u5e76\u5efa\u8bae\u516c\u4f17\u6682\u65f6\u907f\u514d\u5230\u4e1c\u6d77\u5cb8\u516c\u56ed\u548c\u5357\u90e8\u5c9b\u5c7f\u620f\u6c34\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255357658", "pub_date": "2024-10-21 21:05:02"}, {"id": 255356587, "title": "\u5fae\u8f6f(MSFT)\u5141\u8bb8\u5ba2\u6237\u81ea\u4e0b\u6708\u8d77\u4e3a\u65e5\u5e38\u4efb\u52a1\u6784\u5efaAI\u4ee3\u7406", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4ece\u4e0b\u4e2a\u6708\u5f00\u59cb\uff0c\u5fae\u8f6f(MSFT)\u5c06\u5141\u8bb8\u5176\u5ba2\u6237\u5efa\u7acb\u81ea\u4e3b\u4eba\u5de5\u667a\u80fd\u4ee3\u7406\uff0c\u5728\u6295\u8d44\u8005\u5bf9\u5176\u5de8\u989d\u4eba\u5de5\u667a\u80fd\u6295\u8d44\u7684\u5ba1\u67e5\u65e5\u76ca\u4e25\u683c\u4e4b\u9645\uff0c\u8fd9\u662f\u8be5\u516c\u53f8\u5229\u7528AI\u6280\u672f\u7684\u6700\u65b0\u4e3e\u63aa\u3002\u636e\u4e86\u89e3\uff0c\u5fae\u8f6f\u6b63\u5c06\u81ea\u4e3b\u4ee3\u7406\uff0c\u5373\u4e0d\u540c\u4e8e\u804a\u5929\u673a\u5668\u4eba\u9700\u8981\u4eba\u5de5\u5e72\u9884\u7684\u7a0b\u5e8f\uff0c\u5b9a\u4f4d\u4e3a\u201c\u4eba\u5de5\u667a\u80fd\u9a71\u52a8\u4e16\u754c\u7684\u5e94\u7528\u7a0b\u5e8f\u201d\uff0c\u8fd9\u4e9b\u7a0b\u5e8f\u53ef\u7528\u4e8e\u5904\u7406\u5ba2\u6237\u67e5\u8be2\u3001\u8bc6\u522b\u9500\u552e\u7ebf\u7d22\u548c\u7ba1\u7406\u5e93\u5b58\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255356587", "pub_date": "2024-10-21 20:56:23"}, {"id": 255355525, "title": "\u5fc5\u548c\u5fc5\u62d3(BHP)\u56e0\u5df4\u897f\u5927\u575d\u57ae\u584c\u5728\u82f1\u56fd\u9762\u4e34\u8bc9\u8bbc \u7d22\u8d54\u91d1\u989d\u9ad8\u8fbe470\u4ebf\u7f8e\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9488\u5bf9\u77ff\u4e1a\u5de8\u5934\u5fc5\u548c\u5fc5\u62d3(BHP)\u6709\u51732015\u5e74\u5df4\u897f\u9a6c\u91cc\u4e9a\u7eb3\u5927\u575d\u57ae\u584c\u4e8b\u4ef6\u7684\u8bc9\u8bbc\u5c06\u4e8e\u5468\u4e00\u4f26\u6566\u9ad8\u7b49\u6cd5\u9662\u5f00\u5ead\u5ba1\u7406\u3002\u6b64\u6b21\u8bc9\u8bbc\u7684\u7d22\u8d54\u91d1\u989d\u9ad8\u8fbe360\u4ebf\u82f1\u9551(\u7ea6\u5408470\u4ebf\u7f8e\u5143)\uff0c\u662f\u82f1\u56fd\u53f8\u6cd5\u53f2\u4e0a\u6700\u5927\u7684\u8bc9\u8bbc\u4e4b\u4e00\u3002\u8d85\u8fc760\u4e07\u5df4\u897f\u4e2a\u4eba\u300146\u4e2a\u5730\u65b9\u653f\u5e9c\u4ee5\u53ca\u7ea62000\u5bb6\u4f01\u4e1a\u5171\u540c\u5bf9\u5fc5\u548c\u5fc5\u62d3\u63d0\u8d77\u8bc9\u8bbc\u3002<br/><br/>\u636e\u6089\uff0c2015\u5e7411\u67085\u65e5\uff0c\u5fc5\u548c\u5fc5\u62d3\u3001\u6de1\u6c34\u6cb3\u8c37(VALE)\u5408\u8d44\u6210\u7acb\u7684\u77ff\u4e1a\u516c\u53f8Samarco\u6240\u7ecf\u8425\u7684\u9a6c\u91cc\u4e9a\u7eb3\u94c1\u77ff\u533a\u5c3e\u77ff\u5e93\u53d1\u751f\u6e83\u575d\u4e8b\u6545\u3002\u5927\u575d\u57ae\u584c\u5bfc\u81f4\u4e86\u5927\u91cf\u5c3e\u77ff\u6cc4\u6f0f\uff0c\u91ca\u653e\u51fa\u7684\u6709\u6bd2\u6c14\u4f53\u9020\u621019\u4eba\u6b7b\u4ea1\uff0c\u6570\u5343\u4eba\u65e0\u5bb6\u53ef\u5f52\uff0c\u540c\u65f6\u68ee\u6797\u88ab\u6df9\u6ca1\uff0c\u591a\u897f\u6cb3\u4e5f\u53d7\u5230\u4e25\u91cd\u6c61\u67d3\u2014\u2014\u8be5\u6cb3\u6d41\u5bf9\u514b\u96f7\u7eb3\u514b\u571f\u8457\u90e8\u843d\u5177\u6709\u7279\u6b8a\u7684\u610f\u4e49\u3002\u5fc5\u548c\u5fc5\u62d3\u5bf9\u6b64\u6b21\u4e8b\u4ef6\u7684\u8d23\u4efb\u63d0\u51fa\u4e86\u5f02\u8bae\u3002\u5fc5\u548c\u5fc5\u62d3\u8868\u793a\uff0c\u8fd9\u8d77\u8bc9\u8bbc\u4e0e\u5df4\u897f\u5f53\u5730\u5df2\u7ecf\u8fdb\u884c\u7684\u6cd5\u5f8b\u7a0b\u5e8f\u3001\u8d54\u507f\u53ca\u4fee\u590d\u8ba1\u5212\u5b58\u5728\u91cd\u590d\u3002\u8be5\u516c\u53f8\u8868\u793a\uff0c\u5df2\u7ecf\u901a\u8fc72016\u5e74\u4e0e\u6de1\u6c34\u6cb3\u8c37\u6210\u7acb\u7684\u96f7\u8bfa\u74e6\u57fa\u91d1\u4f1a\u5411\u53d7\u707e\u6c11\u4f17\u652f\u4ed8\u4e86\u63a5\u8fd180\u4ebf\u7f8e\u5143\u7684\u8d44\u91d1\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255355525", "pub_date": "2024-10-21 20:47:02"}, {"id": 255353536, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u82b1\u65d7\u5347\u54d4\u54e9\u54d4\u54e9(BILI)\u76ee\u6807\u4ef737.5% \u6599\u4e09\u5b63\u4e1a\u7ee9\u7b26\u5408\u5e02\u573a\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u82b1\u65d7\u53d1\u8868\u7814\u7a76\u62a5\u544a\u6307\uff0c\u54d4\u54e9\u54d4\u54e9\u9884\u8ba1\u5c06\u4e8e\u4e0b\u6708\u4e2d\u65ec\u516c\u5e03\u7b2c\u4e09\u5b63\u4e1a\u7ee9\uff0c\u9884\u671f\u96c6\u56e2\u7684\u6536\u5165\u53ca\u7ecf\u8c03\u6574\u76c8\u5229\u5747\u7b26\u5408\u5e02\u573a\u9884\u671f\u3002\u7531\u4e8e\u6e38\u620f\u300a\u4e09\u56fd\uff1a\u8c0b\u5b9a\u5929\u4e0b\u300b\u7b2c\u4e8c\u53ca\u7b2c\u4e09\u5b63\u53d6\u5f97\u6210\u529f\uff0c\u9884\u8ba1\u7b2c\u4e09\u5b63\u7684\u6e38\u620f\u6536\u5165\u5c06\u6309\u5e74\u589e\u957f67%\u3002\u5e7f\u544a\u7684\u52a8\u529b\u6216\u4f1a\u968f\u7740\u57fa\u7840\u6539\u5584\u800c\u6301\u7eed\u81f3\u7b2c\u4e09\u5b63\uff0c\u5e76\u5728\u7b2c\u56db\u5b63\u7ee7\u7eed\u4f18\u4e8e\u540c\u4e1a\u3002</p><p>\u8be5\u884c\u8868\u793a\uff0c\u968f\u7740\u8425\u4e1a\u989d\u7ec4\u5408\u8f6c\u5411\u6e38\u620f\u53ca\u5e7f\u544a\u4e1a\u52a1\uff0c\u867d\u7136\u5728\u65b0\u6e38\u620f\u9700\u6295\u653e\u66f4\u591a\u5e02\u573a\u63a8\u5e7f\u5f00\u652f\uff0c\u4f46\u9884\u8ba1\u96c6\u56e2\u7684\u975e\u901a\u7528\u4f1a\u8ba1\u51c6\u5219\u8425\u8fd0\u5229\u6da6\u5c06\u5f55\u5f97\u4e8f\u8f6c\u76c8\uff0c\u5e76\u5c062025\u53ca26\u5e74\u76c8\u6d4b\u5206\u522b\u4e0a\u8c033%\u548c1%\uff0c\u4ee5\u53cd\u6620\u300a\u4e09\u56fd\uff1a\u8c0b\u5b9a\u5929\u4e0b\u300b\u7684\u8868\u73b0\u7565\u4f18\u4e8e\u9884\u671f\uff0c\u5e76\u5c06\u76ee\u6807\u4ef7\u753116\u7f8e\u5143\u4e0a\u8c03\u81f322\u7f8e\u5143\uff0c\u7ef4\u6301\u201c\u4e2d\u6027\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255353536", "pub_date": "2024-10-21 20:30:45"}, {"id": 255352840, "title": "\u4f20\u5409\u5229\u65d7\u4e0b\u76db\u5b9d\u94f6\u884c\u6216\u88ab\u76c8\u900f\u8bc1\u5238(IBKR)\u53caAltor\u6536\u8d2d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u77e5\u60c5\u4eba\u58eb\u900f\u9732\uff0c\u76c8\u900f\u8bc1\u5238(IBKR)\u548c\u7531 Altor Equity Partners\u548cCenterbridge Partners \u7ec4\u6210\u7684\u8d22\u56e2\u5bf9\u6536\u8d2d\u4e39\u9ea6\u76db\u5b9d\u94f6\u884c\uff08Saxo Bank A/S\uff09\u8868\u73b0\u51fa\u4e86\u521d\u6b65\u5174\u8da3\u3002\u8fd9\u4e9b\u4eba\u58eb\u8868\u793a\uff0c\u7531 Altor \u548c Centerbridge \u9886\u5bfc\u7684\u6295\u8d44\u8005\u5df2\u7ecf\u5411\u8fd9\u5bb6\u4e39\u9ea6\u7ecf\u7eaa\u516c\u53f8\u63d0\u4ea4\u4e86\u4e00\u4efd\u975e\u7ea6\u675f\u6027\u62a5\u4ef7\u3002\u4ed6\u4eec\u8fd8\u8868\u793a\uff0c\u76ee\u524d\u8fd8\u5728\u8ba8\u8bba\u4e2d\uff0c\u8fd8\u6709\u5176\u4ed6\u6f5c\u5728\u7684\u7ade\u6807\u8005\u5bf9\u76db\u5b9d\u94f6\u884c\u611f\u5174\u8da3\u3002\u4ed6\u4eec\u8865\u5145\u8bf4\uff0c\u76db\u5b9d\u94f6\u884c\u4ecd\u53ef\u80fd\u51b3\u5b9a\u4e0d\u8fdb\u884c\u4ea4\u6613\u3002<br/><br/>\u636e\u6089\uff0c\u76db\u5b9d\u94f6\u884c\u662f\u62e5\u6709\u7ea61200\u4ebf\u7f8e\u5143\u5ba2\u6237\u8d44\u4ea7\u7684\u4ea4\u6613\u5e73\u53f0\uff0c\u8be5\u516c\u53f8\u57287\u6708\u4efd\u8868\u793a\uff0c\u5df2\u8058\u8bf7\u9ad8\u76db\u96c6\u56e2(GS)\u5e2e\u52a9\u5bfb\u627e\u65b0\u6240\u6709\u8005\u3002\u76db\u5b9d\u94f6\u884c\u7684\u80a1\u4e1c\u2014\u2014\u6d59\u6c5f\u5409\u5229\u63a7\u80a1\u96c6\u56e2\u3001\u82ac\u5170 Mandatum Oyj \u548c\u521b\u59cb\u4eba Kim Fournais\u2014\u2014\u5c06\u542f\u52a8\u5bf9\u6218\u7565\u673a\u4f1a\u7684\u5ba1\u67e5\uff0c\u76f4\u63a5\u51fa\u552e\u662f\u4e3b\u8981\u76ee\u6807\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255352840", "pub_date": "2024-10-21 20:24:53"}, {"id": 255351460, "title": "\u4e2d\u4fe1\u8d44\u672c\u5ba3\u5e03\u52a0\u7801\u9ea6\u5f53\u52b3(MCD)\u4e2d\u56fd", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u4fe1\u8d44\u672c\u63a7\u80a1\u6709\u9650\u516c\u53f8\u5ba3\u5e03\uff0c\u65d7\u4e0b\u79c1\u52df\u80a1\u6743\u6295\u8d44\u4e1a\u52a1\u4fe1\u5bb8\u8d44\u672c\u4e0e\u4e2d\u4fe1\u80a1\u4efd\u7b7e\u8ba2\u534f\u8bae\uff0c\u6536\u8d2d\u5176\u6301\u6709\u7684\u9ea6\u5f53\u52b3(MCD)\u4e2d\u56fd\u5185\u5730\u3001\u9999\u6e2f\u53ca\u6fb3\u95e8\u4e1a\u52a1\uff08\u7b80\u79f0\u201c\u9ea6\u5f53\u52b3\u4e2d\u56fd\u201d\uff09\u80a1\u4efd\uff0c\u4ea4\u6613\u540e\uff0c\u4e2d\u4fe1\u8d44\u672c\u8054\u5408\u4f53\uff08\u5305\u62ec\u4e2d\u4fe1\u8d44\u672c\u53ca\u5176\u65d7\u4e0b\u79c1\u52df\u80a1\u6743\u6295\u8d44\u4e1a\u52a1\u4fe1\u5bb8\u8d44\u672c\uff09\u4ecd\u4e3a\u9ea6\u5f53\u52b3\u4e2d\u56fd\u7684\u63a7\u80a1\u80a1\u4e1c\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255351460", "pub_date": "2024-10-21 20:12:52"}]}