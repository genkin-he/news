u8dcc\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62db\u5546\u8bc1\u5238(06099)\u8dcc5.23%\uff0c\u4e2d\u4fe1\u8bc1\u5238(06030)\u8dcc4.11%\uff0c\u4e2d\u4fe1\u5efa\u6295\u8bc1\u5238(06066)\u8dcc3.5%\uff0c\u5149\u5927\u8bc1\u5238(06178)\u6da83.41%\uff0c\u4e2d\u91d1\u516c\u53f8(03908)\u8dcc2.76%\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u4e2d\u5171\u4e2d\u592e\u653f\u6cbb\u5c4012\u67089\u65e5\u53ec\u5f00\u4f1a\u8bae\uff0c\u5206\u6790\u7814\u7a762025\u5e74\u7ecf\u6d4e\u5de5\u4f5c\u3002\u62db\u5546\u8bc1\u5238\u6307\u51fa\uff0c\u7ee7\u201c\u8d44\u672c\u5e02\u573a\u201d\u4e00\u8bcd\u51fa\u73b0\u5728\u653f\u6cbb\u5c40\u4f1a\u8bae\u901a\u7a3f\u4e2d\uff0c\u672c\u6b21\u653f\u6cbb\u5c40\u4f1a\u8bae\u8fdb\u4e00\u6b65\u660e\u786e\u201c\u7a33\u5b9a\u80a1\u5e02\u201d\uff0c\u8db3\u89c1\u51b3\u7b56\u5c42\u5bf9\u4e8e\u80a1\u5e02\u7684\u9ad8\u5ea6\u91cd\u89c6\uff0c\u4ea6\u53cd\u5e94\u51b3\u7b56\u5c42\u5bf9\u80a1\u5e02\u5728\u7ecf\u6d4e\u793e\u4f1a\u751f\u6d3b\u91cd\u8981\u4f5c\u7528\u7684\u9ad8\u5ea6\u8ba4\u540c\u3002\u6392\u5e8f\u4e0a\u770b\uff0c\u201c\u7a33\u4f4f\u697c\u5e02\u80a1\u5e02\u201d\u8868\u8ff0\u4f4d\u7f6e\u9760\u524d\uff0c\u53cd\u5e94\u51b3\u7b56\u5c42\u5bf9\u4e8e\u80a1\u5e02\u91cd\u89c6\u7a0b\u5ea6\u63d0\u9ad8\uff0c\u201c\u7a33\u4f4f\u201d\u53cd\u5e94\u51b3\u7b56\u5c42\u671f\u5f85\u66f4\u4e3a\u660e\u786e\u3002\u6b64\u5916\uff0c\u4f1a\u8bae\u7279\u522b\u6307\u51fa\u201c\u52a0\u5f3a\u8d85\u5e38\u89c4\u9006\u5468\u671f\u8c03\u8282\u201d\u3001\u201c\u66f4\u52a0\u79ef\u6781\u7684\u8d22\u653f\u653f\u7b56\u548c\u9002\u5ea6\u5bbd\u677e\u7684\u8d27\u5e01\u653f\u7b56\u201d\uff0c\u5c06\u76f4\u63a5\u5f71\u54cd\u80a1\u5e02\u5206\u5b50\u7aef\u548c\u5206\u6bcd\u7aef\u8868\u73b0\u3002\u671f\u5f85\u540e\u7eed\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\u66f4\u591a\u5b9e\u8d28\u6027\u653f\u7b56\u63a5\u6b21\u51fa\u53f0\u3002<br/><br/>\u53d7\u6b64\u5f71\u54cd\uff0c\u6628\u65e5\u6e2f\u80a1\u5c3e\u76d8\u5238\u5546\u80a1\u5168\u7ebf\u4e0a\u626c\uff0c\u62db\u5546\u8bc1\u5238\u6628\u65e5\u6536\u6da813.65%\uff0c\u4e2d\u4fe1\u8bc1\u5238\u6536\u6da87.93%\uff0c\u4e2d\u4fe1\u5efa\u6295\u8bc1\u5238\u6536\u6da86.33%\u3002\u4eca\u65e5\u5238\u5546\u677f\u5757\u5168\u7ebf\u9ad8\u5f00\uff0c\u5176\u4e2d\u62db\u5546\u8bc1\u5238\u9ad8\u5f005.78%\uff0c\u5b58\u5728\u77ed\u671f\u83b7\u5229\u4e86\u7ed3\u53ef\u80fd\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260112375", "pub_date": "2024-12-10 13:50:11"}, {"id": 260112376, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u91ce\u6751\u7ef4\u6301\u4eac\u4e1c\u7269\u6d41(02618)\u201c\u4e70\u5165\u201d\u8bc4\u7ea7 \u6307\u8d2d\u8de8\u8d8a\u901f\u8fd0\u4f59\u4e0b\u6743\u76ca\u4f30\u503c\u5408\u7406", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u91ce\u6751\u53d1\u7814\u62a5\u6307\uff0c\u4eac\u4e1c\u7269\u6d41(02618)\u6536\u8d2d\u8de8\u8d8a\u901f\u8fd0\u4f59\u4e0b\u6743\u76ca\u7684\u4ea4\u6613\u4f30\u503c\u5408\u7406\uff0c\u534f\u8bae\u8bbe\u4e0e\u4e1a\u7ee9\u6302\u94a9\u7684\u5bf9\u4ef7\u8c03\u6574\u673a\u5236\uff0c\u4ee5\u6700\u9ad8\u4ee3\u4ef7\u8ba1\u662f\u6b21\u6536\u8d2d\u8de8\u8d8a\u901f\u8fd0\u7684\u4ea4\u6613\u4f30\u503c\u4e3a\u540e\u8005\u53bb\u5e74\u53ca\u9884\u6d4b\u4eca\u5e74\u5e02\u76c8\u7387\u768412\u500d\u53ca8\u500d\uff0c\u4f4e\u4e8e\u884c\u4e1a\u5e73\u5747\u6c34\u5e73\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0c\u622a\u81f3\u4eca\u5e74\u4e0a\u534a\u5e74\u4eac\u4e1c\u7269\u6d41\u624b\u5934\u51c0\u73b0\u91d1\u8fbe173\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u6709\u80fd\u529b\u652f\u4ed8\u6b64\u6b21\u4ea4\u6613\u4f5c\u4ef7\uff0c\u534f\u8bae\u6240\u8bbe\u7684\u5206\u671f\u4ed8\u6b3e\u65b9\u5f0f\u4ea6\u53ef\u8fdb\u4e00\u6b65\u7ebe\u7f13\u516c\u53f8\u7684\u538b\u529b\u3002\u91ce\u6751\u76f8\u4fe1\u8de8\u8d8a\u901f\u8fd0\u662f\u4e00\u9879\u6709\u4ef7\u503c\u7684\u8d44\u4ea7\uff0c\u9884\u6599\u5b8c\u6210\u6536\u8d2d\u540e\u4eac\u4e1c\u7269\u6d41\u53ef\u66f4\u597d\u5730\u6574\u5408\u4e24\u8005\u8d44\u6e90\uff0c\u589e\u5f3a\u5176\u81ea\u8eab\u7ade\u4e89\u529b\uff0c\u63d0\u5347\u8425\u8fd0\u6548\u7387\uff0c\u53d1\u6325\u534f\u540c\u6548\u5e94\u3002\u91ce\u6751\u7ef4\u6301\u5bf9\u4eac\u4e1c\u7269\u6d41\u7684\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0c\u76ee\u6807\u4ef717.8\u6e2f\u5143\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/260112376", "pub_date": "2024-12-10 13:50:17"}, {"id": 260111452, "title": "\u7279\u65af\u62c9(TSLA)\u56e0\u65d7\u4e0b\u6c7d\u8f66\u53d1\u751f\u81f4\u547d\u8f66\u7978\u800c\u906d\u5230\u8d77\u8bc9", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u7279\u65af\u62c9(TSLA)\u518d\u56e0\u65d7\u4e0b\u6c7d\u8f66\u53d1\u751f\u81f4\u547d\u8f66\u7978\u800c\u906d\u5230\u8d77\u8bc9\uff0c\u7f8e\u56fd\u4e00\u540d\u53f8\u673aGenesis Giovanni Mendoza-Martinez\u4e8e2023\u5e74\u5728\u52a0\u5dde\u9a7e\u9a76\u4e00\u8f86Model S\uff0c\u5728\u5f00\u542f\u6c7d\u8f66\u81ea\u52a8\u8f85\u52a9\u9a7e\u9a76\u7cfb\u7edfAutopilot\u65f6\u649e\u4e0a\u4e00\u8f86\u505c\u653e\u5728\u8def\u4e0a\u7684\u6d88\u9632\u8f66\uff0c\u53f8\u673a\u4e8e\u4e8b\u6545\u4e2d\u4e27\u751f\uff0c\u540c\u8f66\u4e58\u5ba2\u3001\u5373\u8be5\u53f8\u673a\u7684\u5144\u5f1f\u5219\u53d7\u91cd\u4f24\u3002\u4e24\u4eba\u5bb6\u5c5e\u4eca\u5e7410\u6708\u5165\u7980\u8d77\u8bc9\u7279\u65af\u62c9\uff0c\u6307\u8be5\u516c\u53f8\u5bf9Autopilot\u7cfb\u7edf\u7684\u5b89\u5168\u6027\u4f5c\u51fa\u6b3a\u8bc8\u6027\u4e0d\u5b9e\u9648\u8ff0\uff0c\u81f4\u4f7f\u8f66\u7978\u53d1\u751f\uff0c\u6848\u4ef6\u5df2\u79fb\u4ea4\u81f3\u52a0\u5dde\u5317\u90e8\u8054\u90a6\u6cd5\u9662\u5ba1\u7406\u3002<br/><br/>\u7279\u65af\u62c9\u516c\u53f8\u5f8b\u5e08\u56de\u5e94\u6307\uff0c\u9a7e\u9a76\u8005\u7684\u758f\u5ffd\u884c\u4e3a\u6216\u4e0d\u4f5c\u4e3a\u624d\u662f\u9020\u6210\u4e8b\u6545\u7684\u539f\u56e0\uff0c\u5f3a\u8c03\u7279\u65af\u62c9\u7684\u6c7d\u8f66\u548c\u7cfb\u7edf\u5177\u6709\u76f8\u5f53\u5b89\u5168\u7684\u8bbe\u8ba1\uff0c\u7b26\u5408\u5dde\u53ca\u8054\u90a6\u6cd5\u5f8b\u89c4\u5b9a\u3002\u636e\u7edf\u8ba1\uff0c\u76ee\u524d\u7279\u65af\u62c9\u6b63\u9762\u4e34\u81f3\u5c1115\u4e2a\u5176\u4ed6\u7c7b\u4f3c\u8bc9\u8bbc\uff0c\u6d89\u53caAutopilot\u6216\u5168\u81ea\u52a8\u9a7e\u9a76(Full Self-Driving)\u7684\u76f8\u5173\u610f\u5916\uff0c\u5f53\u4e2d\u67093\u5b97\u5df2\u79fb\u4ea4\u81f3\u7f8e\u56fd\u8054\u90a6\u6cd5\u9662\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260111452", "pub_date": "2024-12-10 13:42:33"}, {"id": 260111451, "title": "\u53f0\u79ef\u7535(TSM)\u524d11\u4e2a\u6708\u7d2f\u8ba1\u9500\u552e\u989d\u540c\u6bd4\u589e\u957f31.8%", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u53f0\u79ef\u7535(TSM)11\u6708\u9500\u552e\u989d2760.6\u4ebf\u65b0\u53f0\u5e01\uff0c\u540c\u6bd4\u589e\u957f34%\uff1b\u4eca\u5e74\u524d11\u4e2a\u6708\u7d2f\u8ba1\u9500\u552e\u989d\u7ea62.62\u4e07\u4ebf\u65b0\u53f0\u5e01\uff0c\u540c\u6bd4\u589e\u957f31.8%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260111451", "pub_date": "2024-12-10 13:42:36"}]}