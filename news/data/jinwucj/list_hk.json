{"data": [{"id": 260085535, "title": "\u4eba\u6c11\u5e01\u5151\u7f8e\u5143\u4e2d\u95f4\u4ef7\u62a57.1896 \u4e0b\u8c0326\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf |&nbsp;12\u670810\u65e5\uff0c\u4eba\u6c11\u5e01\u5151\u7f8e\u5143\u4e2d\u95f4\u4ef7\u62a57.1896\uff0c\u4e0b\u8c0326\u70b9\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260085535", "pub_date": "2024-12-10 09:24:52"}, {"id": 260085534, "title": "\u4e2d\u56fd\u592e\u884c\u4eca\u65e5\u8fdb\u884c1416\u4ebf\u51437\u5929\u671f\u9006\u56de\u8d2d\u64cd\u4f5c", "description": "<p>\u91d1\u543e\u8d22\u8baf | 12\u670810\u65e5\uff0c\u4e2d\u56fd\u592e\u884c\u4eca\u65e5\u8fdb\u884c1416\u4ebf\u51437\u5929\u671f\u9006\u56de\u8d2d\u64cd\u4f5c\uff0c\u4e2d\u6807\u5229\u7387\u4e3a1.50%\uff0c\u4e0e\u6b64\u524d\u6301\u5e73</p>", "link": "https://sky.szfiu.com/info/hk/details/260085534", "pub_date": "2024-12-10 09:24:59"}, {"id": 260085023, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u534e\u897f\u8bc1\u5238\u65992025\u5e74\u964d\u51c6\u3001\u964d\u606f\u5e45\u5ea6\u53ef\u80fd\u4e0d\u4f1a\u4f4e\u4e8e50bp\u300120bp", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u534e\u897f\u8bc1\u5238\u7814\u62a5\u6307\u51fa\uff0c\u672c\u6b21\u653f\u6cbb\u5c40\u4f1a\u8bae\u91cd\u63d0\u201c\u9002\u5ea6\u5bbd\u677e\u7684\u8d27\u5e01\u653f\u7b56\u201d\uff0c\u5e02\u573a\u4e0d\u514d\u8054\u60f3\u52302008-2010\u5e74\u6ce2\u6f9c\u58ee\u9614\u7684\u8d27\u5e01\u4e0e\u8d22\u653f\u653f\u7b56\u7ec4\u5408\u62f3\u3002\u5177\u4f53\u5230\u672c\u8f6e\u8d27\u5e01\u653f\u7b56\uff0c\u53ef\u80fd\u4e0e\u4e4b\u795e\u4f3c\uff0c\u4e0d\u4ec5\u57fa\u8c03\u53d1\u751f\u53d8\u5316\uff0c\u6846\u67b6\u4e5f\u4ece\u6b64\u524d\u7684\u8de8\u5468\u671f\uff08\u6216\u8de8\u5468\u671f\u4e0e\u9006\u5468\u671f\u5e76\u91cd\uff09\u8f6c\u5411\u9006\u5468\u671f\u8c03\u8282\uff0c\u8fd9\u5927\u6982\u7387\u6307\u5411\u51c6\u5907\u91d1\u7387\u3001\u653f\u7b56\u5229\u7387\u7684\u8c03\u6574\u5e45\u5ea6\u52a0\u5927\u3002</p><p>\u5c55\u671b2025\u5e74\uff0c\u8d27\u5e01\u653f\u7b56\u5355\u6b21\u964d\u51c6\u3001\u964d\u606f\u7684\u5e45\u5ea6\u53ef\u80fd\u4e0d\u4f1a\u4f4e\u4e8e50bp\u300120bp\uff082024\u5e74\u7684\u5e45\u5ea6\uff09\uff0c\u540c\u65f6\u4e5f\u4e0d\u6392\u9664\u9762\u4e34\u6781\u7aef\u60c5\u51b5\u8fdb\u4e00\u6b65\u52a0\u5927\u5e45\u5ea6\u7684\u53ef\u80fd\u6027\u3002\u5177\u4f53\u7684\u5bbd\u677e\u7a0b\u5ea6\u548c\u6301\u7eed\u65f6\u95f4\u53ef\u80fd\u53d6\u51b3\u4e8e\u7ecf\u6d4e\u72b6\u6001\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/260085023", "pub_date": "2024-12-10 09:16:47"}, {"id": 260085022, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u77f3\u836f\u96c6\u56e2(01093)SYHX2011\u4e0a\u5e02\u7533\u8bf7\u83b7\u5f97\u53d7\u7406 \u62df\u7528\u4e8e\u6cbb\u7597\u665a\u671f\u4e73\u817a\u764c", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u77f3\u836f\u96c6\u56e2(01093)\u516c\u5e03\uff0c\u516c\u53f8\u9644\u5c5e\u516c\u53f8\u77f3\u836f\u96c6\u56e2\u6b27\u610f\u836f\u4e1a\u6709\u9650\u516c\u53f8\u7814\u53d1\u7684SYHX2011\u4e0a\u5e02\u7533\u8bf7\u5df2\u83b7\u5f97\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u56fd\u5bb6\u836f\u54c1\u76d1\u7763\u7ba1\u7406\u5c40\u6b63\u5f0f\u53d7\u7406\u3002<br/><br/>\u636e\u6089\uff0c\u4e73\u817a\u764c\u662f\u5973\u6027\u5e38\u89c1\u7684\u6076\u6027\u80bf\u7624\uff0c\u7d2b\u6749\u70f7\u7c7b\u836f\u7269\u662f\u665a\u671f\u4e73\u817a\u764c\u6700\u6709\u6548\u7684\u7ec6\u80de\u6bd2\u6027\u5316\u7597\u836f\u7269\uff0c\u65e0\u8bba\u662f\u5355\u72ec\u6cbb\u7597\u8fd8\u662f\u8054\u5408\u6cbb\u7597\uff0c\u90fd\u88ab\u8bc1\u660e\u6bd4\u5176\u4ed6\u7c7b\u578b\u7684\u5316\u7597\u836f\u7269\u6709\u66f4\u5927\u7684\u751f\u5b58\u76ca\u5904\u3002\u8be5\u4ea7\u54c1\u662f\u4ee5\u51ef\u7d20(\u6ce8\u5c04\u7528\u7d2b\u6749\u9187(\u767d\u86cb\u767d\u7ed3\u5408\u578b))\u4e3a\u57fa\u7840\uff0c\u91c7\u7528\u4e13\u5229\u6280\u672f\u5f00\u53d1\u7684\u521b\u65b0\u578b\u7eb3\u7c73\u5236\u5242\uff0c\u5177\u6709\u81ea\u4e3b\u77e5\u8bc6\u4ea7\u6743\u3002\u8be5\u4ea7\u54c1\u6309\u7167\u5316\u5b66\u836f\u54c12.2\u7c7b\u8fdb\u884c\u7533\u62a5\uff0c\u9002\u5e94\u75c7\u4e3a\u7528\u4e8e\u8054\u5408\u5316\u7597\u5931\u8d25\u7684\u8f6c\u79fb\u6027\u4e73\u817a\u764c\u6216\u8f85\u52a9\u5316\u7597\u540e6\u4e2a\u6708\u5185\u590d\u53d1\u7684\u4e73\u817a\u764c(\u9664\u975e\u6709\u4e34\u5e8a\u7981\u5fcc\u75c7\uff0c\u65e2\u5f80\u5316\u7597\u4e2d\u5e94\u5305\u62ec\u4e00\u79cd\u84bd\u73af\u7c7b\u6297\u764c\u836f)\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260085022", "pub_date": "2024-12-10 09:16:57"}, {"id": 260084714, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u62db\u5546\u8bc1\u5238\uff1a12\u6708\u653f\u6cbb\u5c40\u4f1a\u8bae\u5bf9\u5b8f\u89c2\u7ecf\u6d4e\u653f\u7b56\u7684\u5b9a\u8c03\u6bd4926\u653f\u6cbb\u5c40\u4f1a\u8bae\u66f4\u52a0\u79ef\u6781", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u62db\u5546\u8bc1\u5238\u8868\u793a\uff0c\u6bcf\u5e7412\u6708\u53ec\u5f00\u7684\u4e2d\u592e\u653f\u6cbb\u5c40\u4f1a\u8bae\u90fd\u4f1a\u8ba8\u8bba\u6b21\u5e74\u7ecf\u6d4e\u5de5\u4f5c\uff0c\u7531\u6b64\u53ef\u80fd\u5bf9\u6b21\u5e74\u5b8f\u89c2\u7ecf\u6d4e\u653f\u7b56\u7b49\u8bae\u9898\u6709\u4e2a\u521d\u6b65\u7684\u5224\u65ad\u3002\u8fd9\u6b21\u4f1a\u8bae\u7684\u65b0\u95fb\u901a\u7a3f\u4e2d\u6700\u503c\u5f97\u5173\u6ce8\u7684\u6587\u5b57\u662f\u201c\u52a0\u5f3a\u8d85\u5e38\u89c4\u9006\u5468\u671f\u8c03\u8282\u201d\u3002\u76f8\u8f83\u4e0b\u534a\u5e74\u7684\u4e24\u6b21\u653f\u6cbb\u5c40\u4f1a\u8bae\uff0c\u8fd9\u6b21\u4f1a\u8bae\u5bf9\u52a0\u5f3a\u9006\u5468\u671f\u51a0\u4ee5\u201c\u8d85\u5e38\u89c4\u201d\u4e00\u8bcd\uff0c\u7406\u89e3\u8d85\u5e38\u89c4\u662f\u524d\u77bb\u660e\u5e74\u653f\u7b56\u8d70\u5411\u7684\u725b\u9f3b\u5b50\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u672c\u6b21\u653f\u6cbb\u5c40\u4f1a\u8bae\u5bf9\u5b8f\u89c2\u7ecf\u6d4e\u653f\u7b56\u7684\u5b9a\u8c03\u6bd4926\u653f\u6cbb\u5c40\u4f1a\u8bae\u66f4\u52a0\u79ef\u6781\uff0c\u653f\u7b56\u7684\u53d1\u529b\u70b9\u4ee5\u7ec8\u7aef\u9700\u6c42\u4e3a\u4e3b\uff0c\u697c\u5e02\u3001\u6d88\u8d39\u5c06\u5f97\u5230\u66f4\u5f3a\u7684\u653f\u7b56\u652f\u6301\u3002\u5e76\u4e14\uff0c\u5728\u8d85\u5e38\u89c4\u9006\u5468\u671f\u8c03\u8282\u7684\u603b\u4f53\u8981\u6c42\u4e0b\uff0c\u53ef\u4ee5\u9884\u671f\u660e\u5e74\u5b8f\u89c2\u7ecf\u6d4e\u653f\u7b56\u7684\u5b9a\u91cf\u76ee\u6807\u7a81\u7834\u4f20\u7edf\u89c4\u5219\u7684\u53ef\u80fd\u6027\u4e0a\u5347\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260084714", "pub_date": "2024-12-10 09:11:54"}, {"id": 260084774, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u4e18\u949b\u79d1\u6280(01478)11\u6708\u624b\u673a\u6444\u50cf\u5934\u6a21\u7ec4\u9500\u91cf\u540c\u6bd4\u589e\u957f8.7%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e18\u949b\u79d1\u6280(01478)\u516c\u5e03\uff0c\u4e8e2024\u5e7411\u6708\uff0c\u624b\u673a\u6444\u50cf\u5934\u6a21\u7ec4\u9500\u91cf\u7ea64030.6\u4e07\u4ef6\uff0c\u73af\u6bd4\u589e\u52a05.4%\uff0c\u540c\u6bd4\u589e\u957f8.7%\u3002\u6444\u50cf\u5934\u6a21\u7ec4\u9500\u552e\u6570\u91cf\u5408\u8ba14160.7\u4e07\u4ef6\uff0c\u73af\u6bd4\u589e\u52a05.6%\uff0c\u540c\u6bd4\u589e\u957f9.6%\u3002\u6307\u7eb9\u8bc6\u522b\u6a21\u7ec4\u9500\u552e\u6570\u91cf\u5408\u8ba11952.1\u4e07\u4ef6\uff0c\u73af\u6bd4\u589e\u957f26.3%\uff0c\u540c\u6bd4\u589e\u957f79.8%\u3002<br/><br/>\u6444\u50cf\u5934\u6a21\u7ec4\u9500\u552e\u6570\u91cf\u540c\u6bd4\u589e\u52a0\uff0c\u96c6\u56e2\u7ee7\u7eed\u575a\u6301\u4ee5\u4e2d\u9ad8\u7aef\u6444\u50cf\u5934\u6a21\u7ec4\u4e3a\u4e3b\u7684\u7ecf\u8425\u7b56\u7565\u4e0d\u53d8\u3002\u5176\u4ed6\u9886\u57df\u6444\u50cf\u5934\u6a21\u7ec4\u9500\u552e\u6570\u91cf\u540c\u6bd4\u660e\u663e\u589e\u957f\u4e3b\u8981\u662f\u7531\u4e8e\u8f66\u8f7d\u6444\u50cf\u5934\u6a21\u7ec4\u9500\u552e\u6570\u91cf\u540c\u6bd4\u660e\u663e\u589e\u957f\u3002<br/><br/>\u6307\u7eb9\u8bc6\u522b\u6a21\u7ec4\u4ea7\u54c1\u9500\u552e\u6570\u91cf\u73af\u6bd4\u53ca\u540c\u6bd4\u589e\u52a0\uff0c\u4e3b\u8981\u662f\u7531\u4e8e\u5ba2\u6237\u9879\u76ee\u5468\u671f\uff0c\u4ee5\u53ca\u96c6\u56e2\u7684\u8d85\u58f0\u6ce2\u6307\u7eb9\u8bc6\u522b\u6a21\u7ec4\u9879\u76ee\u9646\u7eed\u8fdb\u5165\u5927\u89c4\u6a21\u91cf\u4ea7\u53ca\u4e8e\u6307\u7eb9\u8bc6\u522b\u6a21\u7ec4\u4e1a\u52a1\u7684\u5e02\u573a\u4efd\u989d\u4e0a\u5347\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260084774", "pub_date": "2024-12-10 09:12:52"}, {"id": 260084775, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u9f99\u6e56\u96c6\u56e2(00960)\u999611\u6708\u603b\u5408\u540c\u9500\u552e\u91d1\u989d930\u4ebf\u5143\u4eba\u6c11\u5e01", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9f99\u6e56\u96c6\u56e2(00960)\u516c\u5e03\uff0c\u622a\u6b622024\u5e7411\u6708\u672b\uff0c\u96c6\u56e2\u7d2f\u8ba1\u5b9e\u73b0\u603b\u5408\u540c\u9500\u552e\u91d1\u989d\u4eba\u6c11\u5e01930.0\u4ebf\u5143\uff0c\u5408\u540c\u9500\u552e\u9762\u79ef652.0\u4e07\u5e73\u65b9\u7c73\uff0c11\u6708\u5355\u6708\u5b9e\u73b0\u603b\u5408\u540c\u9500\u552e\u91d1\u989d\u4eba\u6c11\u5e0185.0\u4ebf\u5143\uff0c\u5408\u540c\u9500\u552e\u9762\u79ef55.2\u4e07\u5e73\u65b9\u7c73\uff1b11\u6708\u5355\u6708\u5b9e\u73b0\u5f52\u5c5e\u516c\u53f8\u80a1\u4e1c\u6743\u76ca\u7684\u5408\u540c\u9500\u552e\u91d1\u989d\u4eba\u6c11\u5e0157.1\u4ebf\u5143\uff0c\u5f52\u5c5e\u516c\u53f8\u80a1\u4e1c\u6743\u76ca\u7684\u5408\u540c\u9500\u552e\u9762\u79ef39.8\u4e07\u5e73\u65b9\u7c73\u3002<br/><br/>\u622a\u6b622024\u5e7411\u6708\u672b\uff0c\u96c6\u56e2\u5b9e\u73b0\u7ecf\u8425\u6027\u6536\u5165\u7ea6\u4eba\u6c11\u5e01243.6\u4ebf\u5143(\u542b\u7a0e\u91d1\u989d\u7ea6\u4eba\u6c11\u5e01259.5\u4ebf\u5143)\uff1b\u5176\u4e2d\u8fd0\u8425\u6536\u5165\u7ea6\u4eba\u6c11\u5e01123.4\u4ebf\u5143(\u542b\u7a0e\u91d1\u989d\u7ea6\u4eba\u6c11\u5e01132.1\u4ebf\u5143)\uff0c\u670d\u52a1\u6536\u5165\u7ea6\u4eba\u6c11\u5e01120.2\u4ebf\u5143(\u542b\u7a0e\u91d1\u989d\u7ea6\u4eba\u6c11\u5e01127.4\u4ebf\u5143)\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260084775", "pub_date": "2024-12-10 09:13:00"}, {"id": 260084184, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4e2d\u4fe1\u8bc1\u5238\u6307\u5b8f\u89c2\u653f\u7b56\u79ef\u6781\u53d8\u5316\u80cc\u666f\u4e0b \u4e92\u8054\u7f51\u677f\u5757\u4f30\u503c\u4e2d\u67a2\u3001\u4e1a\u7ee9\u3001\u6d41\u52a8\u6027\u5747\u5c06\u660e\u663e\u6539\u5584", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u4fe1\u8bc1\u5238\u8868\u793a\uff0c2024\u5e7412\u67089\u65e5\u4e2d\u5171\u4e2d\u592e\u653f\u6cbb\u5c40\u53ec\u5f00\u4f1a\u8bae\uff0c\u4f1a\u8bae\u6307\u51fa\uff0c\u660e\u5e74\u8981\u575a\u6301\u7a33\u4e2d\u6c42\u8fdb\u3001\u4ee5\u8fdb\u4fc3\u7a33\uff0c\u5b88\u6b63\u521b\u65b0\u3001\u5148\u7acb\u540e\u7834\uff0c\u7cfb\u7edf\u96c6\u6210\u3001\u534f\u540c\u914d\u5408\uff0c\u5b9e\u65bd\u66f4\u52a0\u79ef\u6781\u7684\u8d22\u653f\u653f\u7b56\u548c\u9002\u5ea6\u5bbd\u677e\u7684\u8d27\u5e01\u653f\u7b56\uff0c\u5145\u5b9e\u5b8c\u5584\u653f\u7b56\u5de5\u5177\u7bb1\uff0c\u52a0\u5f3a\u8d85\u5e38\u89c4\u9006\u5468\u671f\u8c03\u8282\uff0c\u6253\u597d\u653f\u7b56\u201c\u7ec4\u5408\u62f3\u201d\uff0c\u63d0\u9ad8\u5b8f\u89c2\u8c03\u63a7\u7684\u524d\u77bb\u6027\u3001\u9488\u5bf9\u6027\u3001\u6709\u6548\u6027\u3002\u8981\u5927\u529b\u63d0\u632f\u6d88\u8d39\u3001\u63d0\u9ad8\u6295\u8d44\u6548\u76ca\uff0c\u5168\u65b9\u4f4d\u6269\u5927\u56fd\u5185\u9700\u6c42\u3002\u8981\u4ee5\u79d1\u6280\u521b\u65b0\u5f15\u9886\u65b0\u8d28\u751f\u4ea7\u529b\u53d1\u5c55\uff0c\u5efa\u8bbe\u73b0\u4ee3\u5316\u4ea7\u4e1a\u4f53\u7cfb\u3002</p><p>\u8be5\u884c\u6307\uff0c\u77ed\u671f\u6765\u770b\uff0c\u5b8f\u89c2\u9884\u671f\u7684\u79ef\u6781\u53d8\u5316\u9884\u8ba1\u5c06\u63d0\u632f\u4e92\u8054\u7f51\u677f\u5757\u4f30\u503c\u4e2d\u67a2\uff0c\u5f3a\u52b2\u7684\u80a1\u4e1c\u56de\u62a5\u63d0\u4f9b\u8db3\u591f\u7684\u5b89\u5168\u8fb9\u9645\u3002\u4e2d\u671f\u6765\u770b\uff0c\u677f\u5757\u4e1a\u7ee9\u6709\u671b\u660e\u663e\u53d7\u76ca\u4e8e\u5b8f\u89c2\u6539\u5584\uff0c\u5e26\u6765\u4e1a\u7ee9\u4e0e\u4f30\u503c\u53cc\u51fb\u3002\u957f\u671f\u6765\u770b\uff0c\u4e92\u8054\u7f51\u4f01\u4e1a\u5f15\u9886\u56fd\u5185\u79d1\u6280\u521b\u65b0\uff0c\u4eba\u5de5\u667a\u80fd\u3001\u81ea\u52a8\u9a7e\u9a76\u7b49\u6709\u671b\u8d21\u732e\u589e\u91cf\u3002</p><p>\u8be5\u884c\u8ba4\u4e3a\uff0c\u5728\u5b8f\u89c2\u653f\u7b56\u79ef\u6781\u53d8\u5316\u80cc\u666f\u4e0b\uff0c\u4e92\u8054\u7f51\u677f\u5757\u7684\u4f30\u503c\u4e2d\u67a2\u3001\u4e1a\u7ee9\u3001\u6d41\u52a8\u6027\u5747\u5c06\u660e\u663e\u6539\u5584\u3002\u77ed\u4e2d\u671f\u6765\u770b\uff0c\u8be5\u884c\u5efa\u8bae\u91cd\u70b9\u5173\u6ce8\u987a\u5468\u671f\u7684\u76f8\u5173\u516c\u53f8\uff0c\u5305\u5934\u90e8\u79d1\u7f51\u516c\u53f8\u4ee5\u53ca\u5782\u7c7b\u9f99\u5934\u3002\u957f\u671f\u6765\u770b\uff0c\u8be5\u884c\u5efa\u8bae\u91cd\u70b9\u5173\u6ce8\u5728\u4eba\u5de5\u667a\u80fd\u3001\u81ea\u52a8\u9a7e\u9a76\u7b49\u79d1\u6280\u521b\u65b0\u9886\u57df\u6301\u7eed\u6295\u5165\u5e03\u5c40\u7684\u4e92\u8054\u7f51\u5927\u5382\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260084184", "pub_date": "2024-12-10 09:02:11"}, {"id": 260084183, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4ea4\u94f6\u56fd\u9645\u5bf912\u6708\u653f\u6cbb\u5c40\u4f1a\u8bae\u70b9\u8bc4\uff1a\u4ece\u201c\u79ef\u6781\u201d\u5230\u201c\u66f4\u52a0\u79ef\u6781\u201d\u7684\u653f\u7b56\u65b0\u610f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4ea4\u94f6\u56fd\u9645\u8868\u793a\uff0c12\u6708\u4e2d\u592e\u653f\u6cbb\u5c40\u4f1a\u8bae\u610f\u4e49\u975e\u51e1\uff0c\u65e2\u662f9\u6708\u653f\u6cbb\u5c40\u4f1a\u8bae\u91ca\u653e\u79ef\u6781\u4fe1\u53f7\u4ee5\u6765\u7684\u5ef6\u7eed\uff0c\u53c8\u662f\u5bf92025\u5e74\u7ecf\u6d4e\u7684\u5b9a\u8c03\uff0c\u76f4\u63a5\u51b3\u5b9a\u774012\u6708\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\u7684\u65b9\u5411\uff0c\u4ee5\u53ca2025\u5e74\u5168\u56fd\u4e24\u4f1a\u5177\u4f53\u7ecf\u6d4e\u5de5\u4f5c\u76ee\u6807\u7684\u5236\u5b9a\u3002\u603b\u4f53\u4e0a\uff0c\u8be5\u884c\u8ba4\u4e3a12\u6708\u4e2d\u592e\u653f\u6cbb\u5c40\u4f1a\u8bae\u5b9a\u8c03\u66f4\u52a0\u79ef\u6781\uff0c\u63d0\u51fa\u8981\u5b9e\u65bd\u66f4\u52a0\u79ef\u6781\u6709\u4e3a\u7684\u5b8f\u89c2\u653f\u7b56\uff0c\u5e76\u9996\u63d0\u8d85\u5e38\u89c4\u7684\u9006\u5468\u671f\u8c03\u8282\u529b\u5ea6\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u8d22\u653f\u3001\u8d27\u5e01\u653f\u7b56\u7684\u8fb9\u9645\u8868\u8ff0\u53d8\u5316\u66f4\u662f\u529b\u5ea6\u7a7a\u524d\uff0c\u66f4\u52a0\u79ef\u6781\u7684\u8d22\u653f\u653f\u7b56\u548c\u9002\u5ea6\u5bbd\u677e\u7684\u8d27\u5e01\u653f\u7b56\u57fa\u8c03\u4f20\u9012\u51fa\u4e86\u66f4\u52a0\u79ef\u6781\u7684\u653f\u7b56\u4fe1\u53f7\uff0c\u6709\u5229\u4e8e\u7ee7\u7eed\u6539\u5584\u5e02\u573a\u9884\u671f\uff0c\u4e5f\u4e3a2025\u5e74\u603b\u4f53\u653f\u7b56\u652f\u6301\u63d0\u4f9b\u4e86\u8f83\u5927\u7684\u60f3\u8c61\u7a7a\u95f4\u3002\u540c\u65f6\uff0c\u4f1a\u8bae\u4e5f\u5927\u5e45\u63d0\u9ad8\u4e86\u5185\u9700\u7684\u9ad8\u5ea6\u548c\u7ad9\u4f4d\uff0c\u5f3a\u8c03\u8981\u5168\u65b9\u4f4d\u7684\u6269\u5927\u5185\u9700\uff0c\u5e76\u63d0\u51fa\u8981\u7a33\u80a1\u5e02\u3001\u7a33\u697c\u5e02\u3001\u7a33\u5916\u8d44\u7b49\u7cfb\u5217\u65b9\u5411\u3002\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\u9884\u8ba1\u5c06\u7d27\u968f\u5176\u540e\u4e8e12\u670811-12\u53f7\u53ec\u5f00\uff0c\u4f1a\u8bae\u4e5f\u5c06\u8d2f\u5f7b\u843d\u5b9e\u672c\u6b21\u653f\u6cbb\u5c40\u4f1a\u8bae\u5b9a\u8c03\uff0c\u7ed9\u51fa\u66f4\u52a0\u5177\u4f53\u8be6\u5b9e\u7684\u7ecf\u6d4e\u5de5\u4f5c\u76ee\u6807\u548c\u65b9\u5411\uff0c\u4ece\u800c\u4e3a2025\u5e74\u7684\u7ecf\u6d4e\u53d1\u5c55\u548c\u5e02\u573a\u65b9\u5411\u63d0\u4f9b\u66f4\u591a\u6307\u5f15\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/260084183", "pub_date": "2024-12-10 09:02:20"}, {"id": 260084198, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u56fd\u6cf0\u541b\u5b89\u5bf9\u4e8e\u539f\u6cb9\u4ecd\u7ef4\u6301\u6218\u672f\u6027\u4f4e\u914d\u89c2\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u56fd\u6cf0\u541b\u5b89\u5bf9\u4e8e\u539f\u6cb9\u4ecd\u7ef4\u6301\u6218\u672f\u6027\u4f4e\u914d\u89c2\u70b9\u3002\u4ece\u5e93\u5b58\u548c\u9700\u6c42\u89d2\u5ea6\u770b\uff0c\u7f8e\u56fd\u539f\u6cb9\u5e93\u5b58\u76f8\u5bf9\u5e73\u7a33\uff0c\u4e14\u9010\u6e10\u4e0a\u884c\uff0c\u6216\u5bfc\u81f4\u5168\u7403\u539f\u6cb9\u4ef7\u683c\u627f\u538b\u3002\u4ece\u4f9b\u7ed9\u89d2\u5ea6\u770b\uff0c\u5e02\u573a\u6216\u5c06\u53cd\u590d\u535a\u5f08OPEC+\u51cf\u4ea7\u548c\u7f8e\u56fd\u53ef\u80fd\u7684\u589e\u4ea7\uff0c\u6216\u5bfc\u81f4\u5e02\u573a\u4ee5\u9707\u8361\u4e3a\u4e3b\u3002\u4e2d\u4e1c\u5730\u7f18\u653f\u6cbb\u4e8b\u4ef6\u53d1\u5c55\u6001\u52bf\u5c1a\u4e0d\u786e\u5b9a\uff0c\u6709\u8f83\u9ad8\u6982\u7387\u4f7f\u5f97\u539f\u6cb9\u77ed\u671f\u5b9a\u4ef7\u7684\u535a\u5f08\u6027\u4e0e\u6ce2\u52a8\u6027\u5927\u5e45\u4e0a\u5347\uff0c\u5e76\u964d\u4f4e\u8be5\u5927\u7c7b\u8d44\u4ea7\u7684\u98ce\u9669\u56de\u62a5\u6bd4\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260084198", "pub_date": "2024-12-10 09:02:56"}]}