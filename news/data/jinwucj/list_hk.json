2a5\u6307\uff0c\u4e2d\u56fd\u6709\u8272\u77ff\u4e1a(01258)\u524d\u4e09\u5b63\u5ea6\u7d2f\u8ba1\u751f\u4ea7\u9634\u6781\u94dc(\u542b\u94dc\u4ea7\u54c1\u4ee3\u52a0\u5de5\u670d\u52a1)\u7ea69.59\u4e07\u5428\uff0c\u540c\u6bd4\u51cf\u5c11\u7ea613%\u3002\u516c\u53f8\u524d\u4e09\u5b63\u5ea6\u9884\u4f30\u5b9e\u73b0\u5f52\u6bcd\u51c0\u5229\u6da6\u7ea63.14\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f\u7ea623%\uff0c\u5176\u4e2d\uff0c24Q1/Q2/Q3\u5206\u522b\u5b9e\u73b0\u5f52\u6bcd\u51c0\u5229\u6da6\u7ea60.84/1.35/0.95\u4ebf\u7f8e\u5143\u3002<br/><br/>\u8be5\u884c\u63d0\u5230\uff0c\u516c\u53f8\u4e8e2023\u5e74\u81ea\u6709\u77ff\u5c71\u751f\u4ea7\u7c97\u94dc\u53ca\u9633\u6781\u94dc\u7ea68.77\u4e07\u5428\uff0c\u81ea\u6709\u77ff\u5c71\u751f\u4ea7\u9634\u6781\u94dc\u7ea68.17\u4e07\u5428\uff0c\u5408\u8ba1\u7ea616.93\u4e07\u5428\uff1b\u81ea\u6709\u77ff\u5c71\u4ea7\u94dc\u6210\u672c\u76f8\u5bf9\u7a33\u5b9a\uff0c\u94dc\u4ef7\u4e0a\u6da8\u80fd\u591f\u7ed9\u516c\u53f8\u5e26\u6765\u8f83\u5927\u7684\u5229\u6da6\u5f39\u6027\u3002\u53e6\u5916\uff0c\u516c\u53f8\u76ee\u524d\u5728\u5efa\u548c\u7b79\u5efa\u77ff\u5c71\u9879\u76ee\u5171\u67094\u4e2a\uff0c\u5305\u62ec\u4e2d\u8272\u5362\u5b89\u590f28\u53f7\u7ad6\u4e95\u9879\u76ee\u3001\u521a\u6ce2\u592b\u95e8\u8d5b\u8428\u77ff\u4f53\u9879\u76ee\u3001\u521a\u6ce2\u592b\u897f\u77ff\u4f53\u9879\u76ee\u3001\u8c26\u6bd4\u5e0c\u4e1c\u5357\u77ff\u4f53\u4e8c\u671f\u9879\u76ee\uff0c\u5f85\u4ee5\u4e0a4\u4e2a\u9879\u76ee\u5168\u90e8\u6295\u4ea7\u4e14\u8fbe\u4ea7\u4e4b\u540e\uff0c\u9884\u8ba1\u516c\u53f8\u5c06\u65b0\u589e\u5e74\u4ea713\u4e07\u5428\u94dc\u4ea7\u80fd\uff0c\u57282023\u5e74\u81ea\u6709\u77ff\u5c71\u5e74\u4ea7\u94dc\u7ea617\u4e07\u5428\u57fa\u7840\u4e0a\uff0c\u9884\u8ba12030\u5e74\u81ea\u6709\u77ff\u5c71\u5e74\u4ea7\u94dc\u91d1\u5c5e\u91cf\u5c06\u8fbe\u5230\u7ea630\u4e07\u5428\uff0c\u5e74\u5747\u590d\u5408\u589e\u901f\u8fbe\u5230\u7ea68%\u3002<br/><br/>\u8be5\u884c\u9884\u8ba1\u516c\u53f82024-2026\u5e74\u8425\u6536\u5206\u522b\u4e3a41.77/43.94/46.14(\u539f\u9884\u6d4b41.14/43.15/45.16)\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u901f15.8%/5.2%/5.0%\uff1b\u5f52\u6bcd\u51c0\u5229\u6da6\u5206\u522b\u4e3a4.21/4.87/5.29(\u539f\u9884\u6d4b4.04/4.50/4.86)\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u901f51.5%/15.9%/8.5%\uff1b\u644a\u8584EPS\u4e3a0.11/0.12/0.14\u7f8e\u5143\uff0c\u5f53\u524d\u80a1\u4ef7\u5bf9\u5e94PE\u4e3a6.9/5.9/5.5X\u3002\u8003\u8651\u5230\u516c\u53f8\u94dc\u77ff\u4ea7\u91cf\u6709\u671b\u6301\u7eed\u63d0\u5347\uff0c\u4e14\u6709\u671b\u5145\u5206\u4eab\u53d7\u94dc\u4ef7\u4e0a\u6da8\u6240\u5e26\u6765\u7684\u5229\u6da6\u5f39\u6027\uff0c\u7ef4\u6301\u201c\u4f18\u4e8e\u5927\u5e02\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255667585", "pub_date": "2024-10-24 15:14:03"}, {"id": 255667584, "title": "\u3010AH\u4e92\u52a8\u3011A\u80a1\u5168\u5929\u4f4e\u5f00\u4f4e\u8d70 \u6caa\u6307\u5168\u65e5\u8dcc0.68% \u98ce\u7535\u8bbe\u5907\u3001\u5149\u4f0f\u8bbe\u5907\u7b49\u677f\u5757\u8dcc\u5e45\u5c45\u524d", "description": "<p>\u91d1\u543e\u8d22\u8baf | A\u80a1\u5168\u5929\u4f4e\u5f00\u4f4e\u8d70\uff0c\u4e09\u5927\u6307\u6570\u5348\u540e\u9707\u8361\u4e0b\u884c\uff0c\u622a\u81f3\u6536\u76d8\uff0c\u6caa\u6307\u8dcc0.68%\uff0c\u6df1\u8bc1\u6210\u6307\u8dcc1.27%\uff0c\u521b\u4e1a\u677f\u6307\u8dcc1.37%\u3002\u6caa\u6df1\u4e24\u5e02\u5168\u5929\u6210\u4ea4\u989d1.52\u4e07\u4ebf\uff0c\u8f83\u4e0a\u4e2a\u4ea4\u6613\u65e5\u7f29\u91cf4063\u4ebf\u3002<br/><br/>\u603b\u4f53\u4e0a\u770b\uff0c\u4e2a\u80a1\u8dcc\u591a\u6da8\u5c11\uff0c\u5168\u5e02\u573a\u8d853000\u53ea\u4e2a\u80a1\u4e0b\u8dcc\u3002\u76d8\u9762\u4e0a\u770b\uff0c\u98ce\u7535\u8bbe\u5907\u3001\u5149\u4f0f\u8bbe\u5907\u3001\u8239\u8236\u5236\u9020\u7b49\u677f\u5757\u8dcc\u5e45\u5c45\u524d\uff1b\u6a61\u80f6\u5236\u54c1\u3001\u751f\u7269\u5236\u54c1\u3001\u519c\u836f\u517d\u836f\u7b49\u677f\u5757\u6da8\u5e45\u5c45\u524d\u3002<br/><br/>\u56fd\u6cf0\u541b\u5b89\u7814\u62a5\u8868\u793a\uff0c\u8fd1\u671f\u7684\u653f\u7b56\u7ec4\u5408\u62f3\u6709\u529b\u5730\u9006\u8f6c\u4e86\u6b64\u524d\u5e02\u573a\u6781\u5ea6\u60b2\u89c2\u7684\u9884\u671f\uff0c\u5e02\u573a\u98ce\u9669\u504f\u597d\u5f97\u4ee5\u5927\u5e45\u63d0\u632f\uff0c\u77ed\u671f\u5e02\u573a\u8868\u73b0\u4e3b\u8981\u7531\u8d44\u91d1\u6d41\u52a8\u6027\u3001\u5e02\u573a\u60c5\u7eea\u4ee5\u53ca\u5fae\u89c2\u4ea4\u6613\u7ed3\u6784\u51b3\u5b9a\u3002\u5e02\u573a\u7684\u9ad8\u6ce2\u52a8\u8fd0\u884c\u4f7f\u5f97\u6b64\u524d\u6781\u5ea6\u4e50\u89c2\u7684\u60c5\u7eea\u4ee5\u53ca\u9884\u671f\u7a0d\u6709\u964d\u6e29\u3002\u524d\u671f\u53d1\u5e03\u4f1a\u5f3a\u5316\u4e86\u8d22\u653f\u653f\u7b56\u53d1\u529b\u7684\u786e\u5b9a\u6027\uff0c\u4f46\u7531\u4e8e\u5e02\u573a\u5bf9\u8d22\u653f\u653f\u7b56\u5177\u4f53\u5185\u5bb9\u7f3a\u4e4f\u660e\u786e\u7684\u9884\u671f\u5171\u8bc6\uff0c\u77ed\u671f\u5c1a\u5b58\u4e00\u5b9a\u5206\u6b67\uff0c\u6216\u63a8\u9ad8\u8d44\u4ea7\u5b9a\u4ef7\u7684\u535a\u5f08\u6027\u3002\u5728\u8d22\u653f\u653f\u7b56\u53d1\u529b\u4ee5\u53ca\u8d27\u5e01\u653f\u7b56\u652f\u6301\u7684\u80cc\u666f\u4e0b\uff0c\u6743\u76ca\u8d44\u4ea7\u7684\u8fd0\u884c\u4e2d\u67a2\u6216\u6709\u671b\u8f83\u663e\u8457\u63d0\u5347\uff0c\u56e0\u6b64\uff0c\u8be5\u884c\u5bf9\u4e8eA\u80a1\u4ecd\u7ef4\u6301\u6807\u914d\u89c2\u70b9\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255667584", "pub_date": "2024-10-24 15:14:52"}, {"id": 255666254, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4e0a\u6d77\u8bc1\u5238\uff1a\u653f\u7b56\u652f\u6301\u53ca\u7f8e\u8054\u50a8\u964d\u606f\u6709\u671b\u4fc3\u8fdb\u56fd\u4ea7\u6c7d\u8f66\u54c1\u724c\u6d77\u5185\u5916\u9500\u91cf\u56de\u6696", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e0a\u6d77\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u6839\u636e\u4e58\u8054\u5206\u4f1a\u6570\u636e\uff0c10\u67081-13\u65e5\uff0c\u4e58\u7528\u8f66\u5e02\u573a\u96f6\u552e\u91cf82.3\u4e07\u8f86\uff0c\u540c\u73af\u6bd4\u5206\u522b+20%/+17%\uff1b\u540c\u671f\uff0c\u4e58\u7528\u8f66\u65b0\u80fd\u6e90\u5e02\u573a\u96f6\u552e40.8\u4e07\u8f86\uff0c\u540c\u73af\u6bd4\u5206\u522b\u4e3a+64%/+8%\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u4e2d\u592e\u653f\u6cbb\u5c40\u5de5\u4f5c\u4f1a\u8bae\u660e\u786e\u63d0\u51fa\uff1a\u8981\u628a\u4fc3\u6d88\u8d39\u548c\u60e0\u6c11\u751f\u7ed3\u5408\u8d77\u6765\uff0c\u4fc3\u8fdb\u4e2d\u4f4e\u6536\u5165\u7fa4\u4f53\u589e\u6536\uff0c\u63d0\u5347\u6d88\u8d39\u7ed3\u6784\u3002\u8f66\u5e02\u6d88\u8d39\u662f\u76ee\u524d\u552f\u4e00\u672a\u88ab\u5145\u5206\u666e\u53ca\u7684\u6d88\u8d39\uff0c\u63d0\u5347\u4e2d\u4f4e\u6536\u5165\u8005\u6536\u5165\u4fc3\u8fdb\u79c1\u8f66\u6d88\u8d39\u662f\u63d0\u5347\u6d88\u8d39\u7ed3\u6784\u7684\u6838\u5fc3\u3002\u8be5\u884c\u8ba4\u4e3a\uff0c\u5728\u62a5\u5e9f\u66f4\u65b0\u548c\u4ee5\u65e7\u6362\u65b0\u8865\u8d34\u653f\u7b56\u652f\u6301\u4e0b\uff0c\u6211\u56fd\u6c7d\u8f66\u9500\u91cf\u6709\u671b\u6301\u7eed\u56de\u6696\u3002\u6b64\u5916\uff0c\u8003\u8651\u7f8e\u8054\u50a8\u964d\u606f\uff0c\u5168\u7403\u6d88\u8d39\u6709\u671b\u56de\u6696\uff0c\u6709\u5229\u4e8e\u56fd\u4ea7\u6c7d\u8f66\u54c1\u724c\u6d77\u5916\u9500\u91cf\u589e\u957f\u3002<br/><br/>\u8be5\u884c\u5efa\u8bae\u5173\u6ce8\u53d1\u529b\u6df7\u52a8\u548c\u6d77\u5916\u5e02\u573a\u7684\u6807\u7684\uff1a\u957f\u5b89\u6c7d\u8f66\u3001\u957f\u57ce\u6c7d\u8f66(02333)\u3001\u6bd4\u4e9a\u8fea(01211)\u3001\u6c5f\u6dee\u6c7d\u8f66\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255666254", "pub_date": "2024-10-24 15:02:06"}, {"id": 255666253, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4e1c\u6d77\u8bc1\u5238\uff1a\u9884\u8ba1\u56db\u5b63\u5ea6\u732a\u4ef7\u5c06\u7ef4\u6301\u666f\u6c14 \u732a\u4f01\u4e1a\u7ee9\u5c06\u9010\u5b63\u5411\u597d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e1c\u6d77\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u80fd\u7e41\u6bcd\u732a\u5b58\u680f\u4ece2023\u5e741\u6708\u5f00\u59cb\u4e0b\u964d\uff0c\u4f20\u5bfc\u81f3\u5f53\u524d\u4f9b\u7ed9\u538b\u529b\u9010\u5b63\u51cf\u5c0f\uff0c\u77ed\u671f\u4f9b\u7ed9\u7aef\u589e\u91cf\u6709\u9650\uff0c\u53e0\u52a0\u6d88\u8d39\u9700\u6c42\u7684\u5b63\u8282\u6027\u6539\u5584\uff0c\u9884\u8ba1\u56db\u5b63\u5ea6\u732a\u4ef7\u5c06\u7ef4\u6301\u666f\u6c14\uff0c\u732a\u4f01\u4e1a\u7ee9\u5c06\u9010\u5b63\u5411\u597d\uff0c\u884c\u4e1a\u8fdb\u5165\u76c8\u5229\u5151\u73b0\u9636\u6bb5\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255666253", "pub_date": "2024-10-24 15:02:15"}, {"id": 255666473, "title": "\u97e9\u56fd\u7efc\u5408\u6307\u6570\u6536\u8dcc0.72% \u62a52581.03\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u97e9\u56fd\u7efc\u5408\u6307\u6570\u6536\u8dcc0.72%\uff0c\u62a52581.03\u70b9\u3002<br/><br/>\u56fd\u9645\u8d27\u5e01\u57fa\u91d1\u7ec4\u7ec7\uff08IMF\uff09\u8fd1\u65e5\u9884\u6d4b\u97e9\u56fd\u4eca\u5e74\u4eba\u5747\u56fd\u5185\u751f\u4ea7\u603b\u503c\uff08GDP\uff09\u540c\u6bd4\u589e\u957f1.6%\uff0c\u4e3a3.6132\u4e07\u7f8e\u5143\uff0c\u9886\u5148\u4e8e\u65e5\u672c\u3002</p><p>IMF\u4e8e22\u65e5\u53d1\u5e03\u5305\u542b\u4e0a\u8ff0\u5185\u5bb9\u7684\u300a\u4e16\u754c\u7ecf\u6d4e\u5c55\u671b\u62a5\u544a\u300b\u3002\u4ee5IMF\u6570\u636e\u4e3a\u51c6\uff0c\u97e9\u56fd\u4eba\u5747GDP\u4ece2021\u5e74\u76843.7518\u4e07\u7f8e\u5143\u51cf\u5c11\u81f32022\u5e74\u76843.4822\u4e07\u7f8e\u5143\u540e\uff0c\u53bb\u5e74\u56de\u5347\u81f33.5563\u4e07\u7f8e\u5143\u3002IMF\u9884\u6d4b\u4eca\u5e74\u65e5\u672c\u4eba\u5747GDP\u4e3a3.2859\u4e07\u7f8e\u5143\uff0c\u540c\u6bd4\u51cf\u5c113.1%\u3002IMF\u8fd8\u9884\u6d4b\u97e9\u56fd\u660e\u5e74\u4eba\u5747GDP\u5c06\u4e3a3.7675\u4e07\u7f8e\u5143\uff0c\u9ad8\u4e8e\u65e5\u672c\uff083.3234\u4e07\u7f8e\u5143\uff09\u3002IMF\u9884\u6d4b\uff0c\u97e9\u56fd\u4eba\u5747GDP\u5c06\u4e8e2027\u5e74\u9996\u78344\u4e07\u7f8e\u5143\u5927\u5173\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255666473", "pub_date": "2024-10-24 15:04:35"}]}