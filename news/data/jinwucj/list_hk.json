a\u6027\uff0c\u5c24\u5176\u662f\u5bf9\u4f0a\u6717\u7684\u7acb\u573a\u3002\u8be5\u884c\u4e0b\u8c03\u5bf9\u660e\u5e74\u53ca\u540e\u5e74\u6cb9\u4ef7\u9884\u6d4b8%\u53ca12%\uff0c\u5e76\u8c03\u6574\u660e\u5e74\u53ca\u5f80\u540e\u7f8e\u5143\u5151\u4eba\u6c11\u5e01\u6c47\u4ef7\u9884\u6d4b\uff0c\u75317.05\u8c03\u6574\u81f37.3\uff0c\u56e0\u800c\u4e0b\u8c03\u5bf9\u4e09\u5927\u4e2d\u8d44\u77f3\u6cb9\u80a1\u660e\u5e74\u53ca\u540e\u5e74\u76c8\u5229\u9884\u6d4b4%\u81f319%\u53ca10%\u81f319%\u3002<br/><br/>\u8be5\u884c\u8ba4\u4e3a\uff0c\u201c\u4e09\u6876\u6cb9\u201d\u76ee\u524d\u4f30\u503c\u4e0d\u9ad8\uff0c\u5728\u4eca\u5e74\u4e0b\u534a\u5e74\u8868\u73b0\u75b2\u5f31\u4e0b\uff0c\u80a1\u4ef7\u4ec5\u4e3a\u660e\u5e74\u9884\u6d4b\u5e02\u76c8\u73875.7\u81f39.3\u500d\uff0c\u660e\u5e74\u9884\u6d4b\u80a1\u606f\u7387\u8fbe6.5\u81f37.8\u5398\u3002\u8be5\u884c\u5c06\u4e2d\u6d77\u6cb9(00883)\u4e0b\u8c03\u81f324.97\u6e2f\u5143\uff0c\u5c06\u4e2d\u77f3\u6cb9(00857)\u4e0b\u8c03\u81f37.05\u6e2f\u5143\uff0c\u5c06\u4e2d\u77f3\u5316(00386)\u4e0b\u8c03\u81f34.9\u6e2f\u5143\u3002\u6cb9\u4f01\u4ea6\u53ef\u4e3a\u4eba\u6c11\u5e01\u5151\u7f8e\u5143\u8d2c\u503c\u63d0\u4f9b\u4fdd\u969c\uff0c\u56e0\u6b64\u91cd\u7533\u5bf9\u4e2d\u56fd\u77f3\u6cb9\u80a1\u201c\u589e\u6301\u201d\u8bc4\u7ea7\uff0c\u9996\u9009\u4e2d\u6d77\u6cb9\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260249588", "pub_date": "2024-12-11 12:30:56"}, {"id": 260249591, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u91ce\u6751\u6307\u5185\u623f\u5e76\u672a\u201c\u89c1\u5e95\u53cd\u5f39\u201d \u6599\u660e\u5e74\u5185\u623f\u5e02\u573a\u4ecd\u6709\u6311\u6218 \u9700\u8981\u653f\u7b56\u7ee7\u7eed\u652f\u6301", "description": "<p>\u91d1\u543e\u8d22\u8baf\uff5c\u91ce\u6751\u9996\u5e2d\u4e2d\u56fd\u7ecf\u6d4e\u5b66\u5bb6\u9646\u633a\u8868\u793a\uff0c\u5468\u4e00\u4e3e\u884c\u7684\u4e2d\u5171\u4e2d\u592e\u653f\u6cbb\u5c40\u4f1a\u8bae\u5df2\u660e\u786e\u653f\u7b56\u5927\u65b9\u5411\uff0c\u800c\u4e2d\u7ecf\u4f1a\u4e00\u822c\u4ea6\u4e0d\u4f1a\u7ed9\u51fa\u5177\u4f53\u7684\u653f\u7b56\u63aa\u65bd\uff0c\u4e3b\u8981\u805a\u7126\u6307\u5bfc\uff0c\u7ec6\u8282\u653f\u7b56\u5219\u7531\u56fd\u52a1\u9662\u548c\u4eba\u5927\u6279\u51c6\u3002\u4ed6\u8868\u793a\uff0c\u4eca\u6b21\u4e2d\u592e\u653f\u6cbb\u5c40\u4f1a\u8bae\u7528\u8bcd\u662f\u8fc7\u53bb\u5341\u51e0\u5e74\u6700\u5bbd\u677e\uff0c\u5e76\u9884\u671f\u5185\u5730\u653f\u5e9c\u5c06\u63a8\u51fa\u66f4\u591a\u79ef\u6781\u7684\u8d22\u653f\u653f\u7b56\u523a\u6fc0\u7ecf\u6d4e\uff0c\u4f30\u8ba1\u8d64\u5b57\u5360GDP\u6bd4\u7387\u7531\u4eca\u5e743%\u5347\u81f3\u660e\u5e744\uff05\u3002<br/><br/>\u800c\u5185\u623f\u65b9\u9762\uff0c\u4ed6\u8ba4\u4e3a\u73b0\u65f6\u5f62\u5bb9\u4e3a\u89c1\u5e95\u53cd\u5f39\u6709\u70b9\u65f6\u8fc7\u65e9\uff0c\u56e0\u4e3a\u653e\u5bbd\u5927\u57ce\u5e02\u9650\u8d2d\u7b49\u653f\u7b56\u540e\uff0c\u672a\u6765\u4e00\u6bb5\u65f6\u95f4\u53ef\u80fd\u51fa\u73b0\u201c\u8679\u5438\u6548\u5e94\u201d\uff0c\u5373\u5927\u57ce\u5e02\u623f\u5730\u4ea7\u4fdd\u6301\u7a33\u5b9a\uff0c\u4f46\u4e2d\u5c0f\u57ce\u5e02\u623f\u5730\u4ea7\u9700\u6c42\u88ab\u5438\u8d70\uff0c\u56e0\u6b64\u9884\u8ba1\u660e\u5e74\u5185\u5730\u623f\u5730\u4ea7\u5e02\u573a\u4ecd\u6709\u6311\u6218\uff0c\u9700\u8981\u653f\u7b56\u7ee7\u7eed\u652f\u6301\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260249591", "pub_date": "2024-12-11 12:31:05"}]}