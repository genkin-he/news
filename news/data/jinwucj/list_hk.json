4e2d\u6cf0\u671f\u8d27(01461)\u3001\u5f18\u4e1a\u671f\u8d27(03678)\u6da8\u903e5%\uff0c\u7533\u4e07\u5b8f\u6e90(06806)\u3001\u62db\u5546\u8bc1\u5238(06099)\u6da8\u8d854%\uff0c\u56fd\u6cf0\u541b\u5b89(02611)\u6da83.39%\u3002<br/><br/>\u5e73\u5b89\u8bc1\u5238\u7814\u62a5\u6307\u51fa\uff0c\u65b0\u4e00\u8f6e\u5e76\u8d2d\u91cd\u7ec4\u6d6a\u6f6e\u6216\u5c06\u6765\u4e34\uff0c\u8bc1\u5238\u884c\u4e1a\u4f9b\u7ed9\u4fa7\u683c\u5c40\u4f18\u5316\u5c06\u52a0\u901f\u3002\u4ece\u5386\u53f2\u6848\u4f8b\u6765\u770b\uff0c\u5238\u5546\u95f4\u5e76\u8d2d\u91cd\u7ec4\u6d41\u7a0b\u8f83\u957f\u3001\u6548\u679c\u6709\u6240\u5dee\u5f02\uff0c\u8003\u9a8c\u5e76\u8d2d\u53cc\u65b9\u4e1a\u52a1\u6574\u5408\u80fd\u529b\u548c\u7ba1\u7406\u80fd\u529b\uff0c\u4ee5\u53ca\u5408\u5e76\u540e\u5229\u7528\u53cc\u65b9\u4f18\u52bf\u3001\u63d0\u5347\u5e02\u573a\u4efd\u989d\u7684\u4e13\u4e1a\u80fd\u529b\u3002\u5efa\u8bae\u5173\u6ce8\u5177\u6709\u8f83\u5f3a\u6574\u5408\u80fd\u529b\u3001\u4e1a\u52a1\u4f18\u52bf\u7a81\u51fa\u3001\u6709\u671b\u7387\u5148\u53d7\u76ca\u4e8e\u884c\u4e1a\u5229\u597d\u653f\u7b56\u7684\u5238\u5546\uff0c\u5982\u4e2d\u4fe1\u8bc1\u5238\u3001\u4e2d\u56fd\u94f6\u6cb3\u3001\u4e2d\u91d1\u516c\u53f8\u7b49\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255521474", "pub_date": "2024-10-23 10:50:27"}, {"id": 255521778, "title": "\u3010\u884c\u4e1a\u98ce\u5411\u3011\u4e09\u5927\u8fd0\u8425\u5546\u99963\u5b63\u8425\u6536\u51c0\u5229\u53cc\u589e\u957f\uff1b\u4e2d\u836f\u6750\u5e02\u573a\u6574\u4f53\u4ef7\u683c\u6301\u7eed\u4e0b\u8dcc", "description": "<p><b>\u4e2d\u56fd\u8054\u901a\u7b49\u4e09\u5927\u8fd0\u8425\u5546\u524d\u4e09\u5b63\u5ea6\u8425\u6536\u51c0\u5229\u53cc\u589e\u957f</b><br/><br/>10\u670822\u65e5\u665a\u95f4\uff0c\u4e2d\u56fd\u7535\u4fe1\u4ee5\u53ca\u4e2d\u56fd\u8054\u901a\u62ab\u9732\u4e862024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u62a5\u544a\u3002\u81f3\u6b64\uff0c\u4e09\u5927\u901a\u4fe1\u8fd0\u8425\u5546\u4e09\u5b63\u62a5\u5747\u5df2\u62ab\u9732\u3002\u5177\u4f53\u6765\u770b\uff0c\u4eca\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u4e2d\u56fd\u79fb\u52a8\u5b9e\u73b0\u8425\u4e1a\u6536\u51657915\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f2%\uff1b\u5b9e\u73b0\u5f52\u5c5e\u4e8e\u6bcd\u516c\u53f8\u80a1\u4e1c\u7684\u51c0\u5229\u6da61109\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f5.1%\u3002\u4e2d\u56fd\u7535\u4fe1\u5b9e\u73b0\u8425\u4e1a\u6536\u51653919.68\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f2.9%\uff1b\u5b9e\u73b0\u5f52\u5c5e\u4e8e\u4e0a\u5e02\u516c\u53f8\u80a1\u4e1c\u7684\u51c0\u5229\u6da6\u4e3a292.99\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f8.1%\u3002\u4e2d\u56fd\u8054\u901a\u5b9e\u73b0\u8425\u4e1a\u6536\u51652901.2\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f3.0%\uff1b\u5229\u6da6\u603b\u989d\u4e3a234.2\u4ebf\u5143\uff0c\u5f52\u5c5e\u4e8e\u6bcd\u516c\u53f8\u51c0\u5229\u6da6\u4e3a83.4\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f10.0%\u3002<br/><br/>\u534e\u6cf0\u8bc1\u5238\u8868\u793a\uff0c\u4ece\u4e09\u5927\u8fd0\u8425\u5546\u62ab\u9732\u7684\u4e09\u5b63\u62a5\u6765\u770b\uff0c\u4e09\u5bb6\u4f01\u4e1a\u5728\u4eca\u5e74\u524d\u4e09\u5b63\u5ea6\u7684\u8868\u73b0\u5747\u7b26\u5408\u5e02\u573a\u9884\u671f\u3002\u957f\u671f\u6765\u770b\uff0c\u968f\u7740\u8d44\u672c\u5f00\u652f\u6b65\u5165\u4e0b\u964d\u5468\u671f\u4ee5\u53ca\u65b0\u5174\u4ea7\u4e1a\u5e02\u573a\u7a7a\u95f4\u9646\u7eed\u91ca\u653e\uff0c\u901a\u4fe1\u8fd0\u8425\u5546\u4e1a\u7ee9\u8868\u73b0\u6709\u671b\u6301\u7eed\u5411\u597d\u3002<br/><br/>\u6765\u6e90\uff1a\u8bc1\u5238\u65e5\u62a5<br/><br/><b>\u4e2d\u836f\u6750\u4ef7\u683c\u4ece7\u6708\u4ee5\u6765\u81f3\u4eca\u5448\u73b0\u6301\u7eed\u4e0b\u8dcc\u7684\u603b\u4f53\u8d8b\u52bf</b><br/><br/>\u67e5\u9605\u4e2d\u836f\u6750\u5929\u5730\u7f51\u7efc\u5408200\u4ef7\u683c\u6307\u6570\uff0c\u5e76\u4ece\u4ef7\u683c\u6307\u6570\u56fe\u6574\u4f53\u8d70\u52bf\u53ef\u4ee5\u770b\u51fa\uff0c\u4e2d\u836f\u6750\u5e02\u573a\u6574\u4f53\u4ef7\u683c\u4ece7\u6708\u4ee5\u6765\u81f3\u4eca\uff0c\u5448\u73b0\u6301\u7eed\u4e0b\u8dcc\u7684\u603b\u4f53\u8d8b\u52bf\uff0c\u4e14\u57289\u6708\u4e2d\u4e0b\u65ec\u5df2\u8dcc\u81f3\u5e74\u521d\u70b9\u4f4d\u4ee5\u4e0b\u3002\u5eb7\u7f8e\u00b7\u4e2d\u56fd\u4e2d\u836f\u6750\u4ef7\u683c\u6307\u6570\u4e5f\u663e\u793a\uff0c\u5728\u8fd1\u4e00\u4e2a\u5b63\u5ea6\u5185\uff0c\u7edd\u5927\u591a\u6570\u7684\u4e2d\u836f\u6750\u54c1\u79cd\u4ef7\u683c\u6307\u6570\u6301\u5e73\u6216\u4e0b\u8dcc\uff0c\u4ec5\u6709\u5c11\u6570\u54c1\u79cd\u4ef7\u683c\u6307\u6570\u4e0a\u6da8\u3002<br/><br/>\u5bf9\u4e8e\u4e2d\u836f\u6750\u4ef7\u683c\u7684\u5927\u5e45\u56de\u843d\uff0c\u5317\u4eac\u4e2d\u533b\u836f\u5927\u5b66\u536b\u751f\u5065\u5eb7\u6cd5\u6cbb\u7814\u7a76\u4e0e\u521b\u65b0\u8f6c\u5316\u4e2d\u5fc3\u4e3b\u4efb\u9093\u52c7\u6559\u6388\u8868\u793a\uff0c\u4e3b\u8981\u6709\u4f9b\u5e94\u589e\u52a0\u3001\u9700\u6c42\u8c03\u6574\u548c\u5e02\u573a\u8c03\u8282\u4e09\u65b9\u9762\u539f\u56e0\u3002\u533b\u836f\u884c\u4e1a\u8d44\u6df1\u8425\u9500\u4e13\u5bb6\u674e\u4f17\u5728\u63a5\u53d721\u4e16\u7eaa\u7ecf\u6d4e\u62a5\u9053\u8bb0\u8005\u91c7\u8bbf\u65f6\u4e5f\u8868\u793a\uff0c\u4f9b\u6c42\u5173\u7cfb\u662f\u5f15\u8d77\u4e2d\u836f\u6750\u4ef7\u683c\u6574\u4f53\u56de\u843d\u7684\u6838\u5fc3\u539f\u56e0\uff0c\u884c\u4e1a\u6574\u4f53\u4e1a\u7ee9\u627f\u538b\u4f7f\u5f97\u836f\u6750\u9700\u6c42\u91cf\u51cf\u5c11\u3002<br/><br/>\u6765\u6e90\uff1a21\u4e16\u7eaa\u7ecf\u6d4e\u62a5\u9053<br/><br/><b>\u4e2d\u6d88\u534f\u53d1\u5e03\u6d88\u8d39\u63d0\u793a \u8c28\u9632\u56fd\u4ea7\u6c34\u679c\u62ab\u4e0a\u201c\u6d0b\u5916\u8863\u201d\u540e\u4ef7\u683c\u66b4\u6da8</b><br/><br/>\u56fd\u4ea7\u6c34\u679c\u6447\u8eab\u4e00\u53d8\u6210\u4e3a\u9ad8\u7aef\u8fdb\u53e3\u6c34\u679c\uff0c\u4ef7\u683c\u751a\u81f3\u53ef\u4ee5\u76f4\u63a5\u4e0a\u6da8\u8fd1\u5341\u500d\u3002\u5bf9\u6b64\uff0c\u4e2d\u56fd\u6d88\u8d39\u8005\u534f\u4f1a\u4eca\u5929\u53d1\u5e03\u6d88\u8d39\u63d0\u793a\u79f0\uff0c\u6b64\u79cd\u901a\u8fc7\u865a\u5047\u5ba3\u4f20\u6b3a\u9a97\u8bf1\u5bfc\u6d88\u8d39\u8005\u7684\u6076\u52a3\u884c\u5f84\uff0c\u4e0d\u4ec5\u4e25\u91cd\u4fb5\u5bb3\u6d88\u8d39\u8005\u5408\u6cd5\u6743\u76ca\uff0c\u6d89\u5acc\u6784\u6210\u72af\u7f6a\uff0c\u8fd8\u6324\u538b\u6b63\u89c4\u5546\u5bb6\u7684\u751f\u4ea7\u9500\u552e\uff0c\u6270\u4e71\u5e02\u573a\u4ef7\u683c\u79e9\u5e8f\u3002<br/><br/>\u6765\u6e90\uff1a\u8bc1\u5238\u65f6\u62a5<br/><br/><b>\u7f8e\u56fdFAA\u51fa\u53f0\u7a7a\u4e2d\u51fa\u79df\u8f66\u6700\u7ec8\u5b89\u5168\u89c4\u5219</b><br/><br/>\u7f8e\u56fdFAA\u4e3a\u201c\u7a7a\u4e2d\u51fa\u79df\u8f66\u201d\u884c\u4e1a\u5236\u5b9a\u5b89\u5168\u89c4\u5b9a\uff0c\u5e2e\u52a9\u76f8\u5173\u516c\u53f8\u5982Joby Aviation\u548cArcher Aviation\u7b49\u51c6\u5907\u5e76\u65e9\u65e5\u5f00\u5c55\u5546\u4e1a\u670d\u52a1\u3002\u8fd9\u4e9b\u89c4\u5b9a\u5c06\u6d89\u53ca\u98de\u884c\u5458\u57f9\u8bad\u548c\u98de\u673a\u64cd\u4f5c\uff0c\u80fd\u4e3a\u4f01\u4e1a\u542f\u52a8\u5546\u4e1a\u822a\u73ed\u63d0\u4f9b\u660e\u786e\u6307\u5bfc\u3002\u53e6\u5916\uff0c\u4ed6\u4eec\u7684\u7535\u52a8\u98de\u673a\u9700\u83b7\u5f97FAA\u7684\u8ba4\u8bc1\u540e\u624d\u80fd\u6295\u5165\u8fd0\u8425\uff0c\u4ee5\u671f\u8ba9\u62e5\u5835\u57ce\u5e02\u91cc\u7684\u7528\u6237\u901a\u52e4\u65f6\u95f4\u66f4\u77ed\uff0c\u4ece\u800c\u98a0\u8986\u822a\u7a7a\u4e1a\u73b0\u72b6\u3002<br/><br/>\u6765\u6e90\uff1a\u534e\u5c14\u8857\u89c1\u95fb</p>", "link": "https://sky.szfiu.com/info/hk/details/255521778", "pub_date": "2024-10-23 10:54:52"}, {"id": 255521250, "title": "\u793e\u79d1\u9662\u91d1\u878d\u6240\u62a5\u544a\u5efa\u8bae\uff1a\u53d1\u884c2\u4e07\u4ebf\u5143\u7279\u522b\u56fd\u503a\u652f\u6301\u8bbe\u7acb\u80a1\u5e02\u5e73\u51c6\u57fa\u91d1", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u56fd\u793e\u4f1a\u79d1\u5b66\u9662\u91d1\u878d\u7814\u7a76\u6240\u53d1\u5e032024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u5b8f\u89c2\u91d1\u878d\u5206\u6790\u62a5\u544a\u300a\u5b58\u91cf\u4e0e\u589e\u91cf\u5e76\u91cd\uff1a\u5b8f\u89c2\u7ecf\u6d4e\u6cbb\u7406\u601d\u8def\u521b\u65b0\u300b\u3002<br/>\u62a5\u544a\u5efa\u8bae\u4e2d\u63d0\u5230\uff0c\u63d0\u5347\u8d44\u672c\u5e02\u573a\u5185\u5728\u7a33\u5b9a\u6027\u3002\u4e00\u662f\u52a0\u5feb\u63a8\u52a8\u4e2d\u957f\u671f\u8d44\u91d1\u5165\u5e02\uff0c\u4f8b\u5982\uff0c\u9002\u5ea6\u589e\u52a0\u4fdd\u9669\u516c\u53f8\u8d44\u91d1\u6295\u8d44\u80a1\u5e02\u7684\u6bd4\u4f8b\uff0c\u63d0\u9ad8\u5730\u65b9\u793e\u4fdd\u57fa\u91d1\u901a\u8fc7\u5168\u56fd\u793e\u4fdd\u7406\u4e8b\u4f1a\u4ee3\u7ba1\u4ece\u800c\u95f4\u63a5\u5165\u5e02\u7684\u8d44\u91d1\u6bd4\u4f8b\u3002\u4e8c\u662f\u52a0\u5f3a\u8bc1\u5238\u3001\u57fa\u91d1\u3001\u4fdd\u9669\u516c\u53f8\u4e92\u6362\u4fbf\u5229\u4e0e\u592e\u884c\u4e70\u5356\u56fd\u503a\u534f\u8c03\u914d\u5408\uff0c\u5b9e\u73b0\u8d27\u5e01\u5e02\u573a\u4e0e\u8d44\u672c\u5e02\u573a\u4e4b\u95f4\u6709\u6548\u8054\u52a8\uff0c\u592e\u884c\u53ef\u5728\u5fc5\u8981\u65f6\u5411\u80a1\u5e02\u63d0\u4f9b\u4f4e\u6210\u672c\u7684\u6d41\u52a8\u6027\u652f\u6301\u3002\u4e09\u662f\u53d1\u884c2\u4e07\u4ebf\u5143\u7279\u522b\u56fd\u503a\u652f\u6301\u8bbe\u7acb\u80a1\u5e02\u5e73\u51c6\u57fa\u91d1\uff0c\u901a\u8fc7\u5bf9\u84dd\u7b79\u9f99\u5934\u80a1\u4ee5\u53caETF\u7684\u4f4e\u4e70\u9ad8\u5356\u6765\u4fc3\u8fdb\u5e02\u573a\u7a33\u5b9a\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255521250", "pub_date": "2024-10-23 10:47:23"}, {"id": 255521249, "title": "\u98ce\u7535\u80a1\u518d\u5ea6\u8d70\u5f3a \u91d1\u98ce\u79d1\u6280(02208)\u6da86.45% 12\u5bb6\u98ce\u7535\u6574\u673a\u5546\u8fd1\u65e5\u7b7e\u8ba2\u884c\u4e1a\u81ea\u5f8b\u516c\u7ea6", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u98ce\u7535\u80a1\u518d\u5ea6\u8d70\u5f3a\uff0c\u91d1\u98ce\u79d1\u6280(02208)\u6da86.45%\uff0c\u9f99\u6e90\u7535\u529b(00916)\u6da8%\uff0c\u5927\u5510\u65b0\u80fd\u6e90(01798)\u6da82.2%\uff0c\u4e2d\u56fd\u9ad8\u901f\u4f20\u52a8(00658)\u6da81.87%\u3002<br/><br/>\u4e0a\u5468\uff0c12\u5bb6\u98ce\u7535\u6574\u673a\u5546\u7b7e\u8ba2\u300a\u4e2d\u56fd\u98ce\u7535\u884c\u4e1a\u7ef4\u62a4\u5e02\u573a\u516c\u5e73\u7ade\u4e89\u73af\u5883\u81ea\u5f8b\u516c\u7ea6\u300b\u3002\u516c\u7ea6\u7684\u5177\u4f53\u5185\u5bb9\u5305\u62ec\u9075\u5b88\u6cd5\u5f8b\u4e0d\u641e\u4ef7\u683c\u4e32\u901a\u3001\u63d0\u5021\u5b9a\u4ef7\u81ea\u5f8b\uff1b\u8fd0\u7528\u6cd5\u5f8b\u63d0\u9ad8\u884c\u4e1a\u7ea6\u675f\u529b\uff0c\u5f62\u6210\u4e00\u5b9a\u5a01\u6151\uff1b\u5236\u5b9a\u89c4\u5219\u4fdd\u8bc1\u53ef\u64cd\u4f5c\u6027\uff0c\u907f\u514d\u6210\u4e3a\u7a7a\u53e3\u53f7\uff1b\u4f01\u4e1a\u81ea\u4e3b\u81ea\u613f\u52a0\u5165\u516c\u7ea6\uff0c\u81ea\u89c9\u9075\u5b88\u7ea6\u5b9a\u3002\u8fd9\u4e9b\u63aa\u65bd\u65e8\u5728\u4fc3\u8fdb\u98ce\u7535\u884c\u4e1a\u7684\u5065\u5eb7\u548c\u53ef\u6301\u7eed\u53d1\u5c55\u3002\u4e0a\u8ff012\u5bb6\u7b7e\u7ea6\u4f01\u4e1a\u5305\u62ec\u8fdc\u666f\u80fd\u6e90\u3001\u91d1\u98ce\u79d1\u6280\u3001\u8fd0\u8fbe\u80a1\u4efd\u3001\u660e\u9633\u667a\u80fd\u3001\u4e09\u4e00\u91cd\u80fd\u3001\u4e1c\u65b9\u7535\u6c14\u3001\u7535\u6c14\u98ce\u7535\u3001\u4e2d\u56fd\u4e2d\u8f66\u3001\u4e2d\u8239\u6d77\u88c5\u3001\u8054\u5408\u52a8\u529b\u3001\u534e\u9510\u98ce\u7535\u3001\u5174\u84dd\u98ce\u7535\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/255521249", "pub_date": "2024-10-23 10:47:33"}, {"id": 255519059, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u4e2d\u56fd\u8054\u901a(00762)\u6da83.21% \u9996\u4e09\u5b63\u5ea6\u7eaf\u5229\u6309\u5e74\u589e10.3%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u56fd\u8054\u901a(00762)\u65e9\u76d8\u9707\u8361\u626c\u5347\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da83.21%\uff0c\u62a57.08\u6e2f\u5143\uff0c\u6210\u4ea4\u989d1.62\u4ebf\u6e2f\u5143\u3002</p><p>\u516c\u53f8\u65e5\u524d\u516c\u544a\uff0c2024\u5e74\u524d\u4e09\u5b63\u5ea6\u516c\u53f8\u6743\u76ca\u6301\u6709\u8005\u5e94\u5360\u76c8\u5229\u8fbe\u5230\u4eba\u6c11\u5e01190.3\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f10.3%\u3002<br/></p><p>\u671f\u5185\u8425\u4e1a\u6536\u5165\u8fbe\u5230\u4eba\u6c11\u5e012,901.2\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f3.0%\u3002EBITDA\u8fbe\u5230\u4eba\u6c11\u5e01804.0\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f2.0%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255519059", "pub_date": "2024-10-23 10:18:03"}, {"id": 255518555, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u62db\u94f6\u56fd\u9645\uff1a\u670d\u52a1\u5668\u76f8\u5173\u4ea7\u4e1a\u94fe\u5c06\u6301\u7eed\u53d7\u76caAI\u670d\u52a1\u5668\u5f3a\u52b2\u9700\u6c42\u548c\u901a\u7528\u670d\u52a1\u5668\u5e02\u573a\u56de\u6696", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u62db\u94f6\u56fd\u9645\u8868\u793a\uff0c\u7531\u4e8e\u5f3a\u52b2\u7684AI\u670d\u52a1\u5668\u9700\u6c42\u548c\u901a\u7528\u670d\u52a1\u5668\u5e02\u573a\u56de\u6696\uff0c\u5168\u7403\u4e3b\u8981\u670d\u52a1\u5668\u54c1\u724c/ODM\u57282024\u5e74\u7b2c\u4e8c\u5b63\u5ea6\u548c\u7b2c\u4e09\u5b63\u5ea6\u7684\u6536\u5165\u5f3a\u52b2\uff0c\u9884\u8ba1\u670d\u52a1\u5668\u6536\u5165\u57282024\u5e74\u4e0b\u534a\u5e74\u5c06\u7ef4\u6301\u5f3a\u52b2\u589e\u957f\u52bf\u5934\u3002\u636eCounterpoint\u6570\u636e\uff0c2024\u5e74\u7b2c\u4e8c\u5b63\u5ea6\u5168\u7403\u670d\u52a1\u5668\u6536\u5165\u540c\u6bd4\u589e\u957f35%\u8fbe\u52304,540\u4e07\u7f8e\u5143\uff1b\u5176\u4e2d\u4eba\u5de5\u667a\u80fd\u670d\u52a1\u5668\u5360\u6bd430%\u3002</p><p>\u5c55\u671b4Q24E\uff0c\u8be5\u884c\u9884\u8ba1\u5927\u591a\u6570AI\u670d\u52a1\u5668\u516c\u53f8\u5c06\u7ee7\u7eed\u53d7\u76ca\u4e8eCoWoS\u4f9b\u5e94\u6539\u5584\u548cHopper H200\u7684\u589e\u957f\uff0c\u800cBlackwell\uff08B200/GB200\uff09AI\u670d\u52a1\u5668\u5c06\u57284Q24\u665a\u4e9b\u65f6\u5019\u51fa\u73b0\u5c0f\u6279\u91cf\u51fa\u8d27\u800c\u57281Q25E\u5927\u5e45\u589e\u957f\u3002\u6b64\u5916\uff0c\u8be5\u884c\u770b\u5230\u6570\u636e\u4e2d\u5fc3\u5728\u70ed\u7ba1\u7406/\u51b7\u5374\u3001\u7535\u6e90\u548c\u9ad8\u901f\u8fde\u63a5\u7b49\u65b9\u9762\u673a\u4f1a\u8d8a\u6765\u8d8a\u591a\u3002</p><p>\u603b\u4f53\u800c\u8a00\uff0c\u8be5\u884c\u8ba4\u4e3a\u76f8\u5173\u4f9b\u5e94\u94fe\u5c06\u6301\u7eed\u53d7\u76caAI\u670d\u52a1\u5668\u5f3a\u52b2\u9700\u6c42\u548c\u901a\u7528\u670d\u52a1\u5668\u5e02\u573a\u56de\u6696\uff0c\u5982\u5de5\u4e1a\u5bcc\u8054\u4f5c\u4e3a\u7b2c\u4e00\u68af\u961f\u7684GB200\u670d\u52a1\u5668\u4f9b\u5e94\u5546\u3001\u6bd4\u4e9a\u8fea\u7535\u5b50(00285)\u7684H20/GB200\u670d\u52a1\u5668\u76f8\u5173\u4ea7\u54c1\u91cf\u4ea7\u51fa\u8d27\u3001\u9e3f\u817e\u7cbe\u5bc6(06088)\u7684GB200\u670d\u52a1\u5668\u4ea7\u54c1\u548c\u6db2\u51b7\u96f6\u90e8\u4ef6\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255518555", "pub_date": "2024-10-23 10:10:15"}, {"id": 255518274, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u674e\u5b81(02331)\u8dcc\u8fd13% \u7b2c\u4e09\u5b63\u5ea6\u96f6\u552e\u6d41\u6c34\u6309\u5e74\u5f55\u5f97\u4e2d\u5355\u4f4d\u6570\u4e0b\u964d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u674e\u5b81(02331)\u65e9\u76d8\u80a1\u4ef7\u4e0b\u884c\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u8dcc2.74%\uff0c\u62a515.62\u6e2f\u5143\uff0c\u6210\u4ea4\u989d1.83\u4ebf\u6e2f\u5143\u3002<br/><br/>\u516c\u53f8\u65e5\u524d\u516c\u544a\uff0c\u622a\u81f32024\u5e749\u670830\u65e5\u6b62\u7b2c\u4e09\u5b63\u5ea6\uff0c\u674e\u5b81\u9500\u552e\u70b9\uff08\u4e0d\u5305\u62ec\u674e\u5b81YOUNG\uff09\u4e8e\u6574\u4e2a\u5e73\u53f0\u4e4b\u96f6\u552e\u6d41\u6c34\u6309\u5e74\u5f55\u5f97\u4e2d\u5355\u4f4d\u6570\u4e0b\u964d\u3002\u5c31\u6e20\u9053\u800c\u8a00\uff0c\u7ebf\u4e0b\u6e20\u9053\uff08\u5305\u62ec\u96f6\u552e\u53ca\u6279\u53d1\uff09\u5f55\u5f97\u9ad8\u5355\u4f4d\u6570\u4e0b\u964d\uff0c\u5176\u4e2d\u96f6\u552e\uff08\u76f4\u63a5\u7ecf\u8425\uff09\u6e20\u9053\u5f55\u5f97\u4e2d\u5355\u4f4d\u6570\u4e0b\u964d\uff0c\u6279\u53d1\uff08\u7279\u8bb8\u7ecf\u9500\u5546\uff09\u6e20\u9053\u5f55\u5f97\u9ad8\u5355\u4f4d\u6570\u4e0b\u964d\uff1b\u7535\u5b50\u5546\u52a1\u865a\u62df\u5e97\u94fa\u4e1a\u52a1\u5f55\u5f97\u4e2d\u5355\u4f4d\u6570\u589e\u957f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255518274", "pub_date": "2024-10-23 10:06:06"}]}