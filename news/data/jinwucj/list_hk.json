8e\u5143\uff0c\u8d85\u51fa\u5e02\u573a\u9884\u671f0.09\u7f8e\u5143\uff1b\u8425\u6536\u4e3a243.7\u4ebf\u7f8e\u5143\uff0c\u540c\u6bd4\u589e\u957f9.51%\uff0c\u4f46\u7565\u4f4e\u4e8e\u5e02\u573a\u9884\u671f\u7684355.53\u767e\u4e07\u7f8e\u5143\u3002\u7279\u522b\u503c\u5f97\u4e00\u63d0\u7684\u662f\uff0c\u516c\u53f8\u5728AI\u4f18\u5316\u670d\u52a1\u5668\u9886\u57df\u8868\u73b0\u7a81\u51fa\uff0c\u8ba2\u5355\u6536\u5165\u589e\u957f36\u4ebf\u7f8e\u5143\uff0c\u73af\u6bd4\u589e\u957f11%\uff0c\u51fa\u8d27\u91cf\u8fbe\u523029\u4ebf\u7f8e\u5143\uff0c\u663e\u793a\u51fa\u5e02\u573a\u9700\u6c42\u7684\u5f3a\u52b2\u3002<br/><br/>\u673a\u6784\u5206\u6790\u5e08David Vogt\u5bf9DELL\u7684ISG\u90e8\u95e8\u8fdb\u884c\u4e86\u6df1\u5165\u5206\u6790\u3002\u8be5\u90e8\u95e8\u7531Arthur Lewis\u9886\u5bfc\uff0c\u6db5\u76d6\u670d\u52a1\u5668\u3001\u7f51\u7edc\u3001\u5b58\u50a8\u53ca\u76f8\u5173\u89e3\u51b3\u65b9\u6848\u3002\u5206\u6790\u5e08\u8ba4\u4e3a\uff0cDELL\u5728AI\u670d\u52a1\u5668\u5e02\u573a\u7684\u5f3a\u52b2\u8868\u73b0\u662f\u5176\u8d22\u52a1\u589e\u957f\u7684\u4e3b\u8981\u9a71\u52a8\u529b\u3002\u516c\u53f8\u5728\u4ea7\u54c1\u7ec4\u5408\u7684\u5e7f\u5ea6\u548c\u521b\u65b0\u901f\u5ea6\u4e0a\u5177\u6709\u660e\u663e\u4f18\u52bf\uff0c\u5c24\u5176\u5728\u6db2\u4f53\u51b7\u5374\u6280\u672f\u3001PowerScale\u5b58\u50a8\u89e3\u51b3\u65b9\u6848\u548cProject Lightning\u5e76\u884c\u6587\u4ef6\u7cfb\u7edf\u7b49\u65b9\u9762\u3002DELL\u7684\u751f\u6001\u7cfb\u7edf\u5408\u4f5c\u4f19\u4f34\u5173\u7cfb\uff0c\u5982\u4e0eHuggingFace\u548cMeta\u7684\u5408\u4f5c\uff0c\u8fdb\u4e00\u6b65\u589e\u5f3a\u4e86\u5176\u5e02\u573a\u7ade\u4e89\u529b\u3002<br/><br/>\u5c55\u671b\u672a\u6765\uff0cDELL\u5bf9\u5b58\u50a8\u4e1a\u52a1\u7684\u590d\u82cf\u5145\u6ee1\u671f\u5f85\u3002\u516c\u53f8\u9884\u8ba1\uff0c\u968f\u7740\u670d\u52a1\u5668\u5e02\u573a\u7684\u589e\u957f\uff0c\u5b58\u50a8\u4e1a\u52a1\u5c06\u968f\u4e4b\u590d\u82cf\uff0c\u9884\u8ba1\u660e\u5e74\u5e02\u573a\u589e\u957f\u7387\u4e3a4%\uff0c\u800cDELL\u8ba1\u5212\u4ee5\u9ad8\u4e8e\u5e02\u573a\u7684\u901f\u5ea6\u589e\u957f\u5e76\u593a\u56de\u5e02\u573a\u4efd\u989d\u3002Arthur Lewis\u5f3a\u8c03\uff0c\u516c\u53f8\u4e13\u6ce8\u4e8e\u5ba2\u6237\u7528\u4f8b\u548c\u73b0\u4ee3\u6570\u636e\u4e2d\u5fc3\u7684\u9700\u6c42\uff0c\u7279\u522b\u662f\u5728\u79c1\u6709\u6df7\u5408\u4e91\u3001\u6570\u636e\u5e73\u53f0\u548c\u5b89\u5168\u5e73\u53f0\u7684\u5efa\u8bbe\u4e0a\u3002DELL\u7684\u5b58\u50a8\u4ea7\u54c1\u7ec4\u5408\uff0c\u5305\u62ecPowerMax\u3001PowerStore\u3001PowerFlex\u548cPowerScale\uff0c\u4ee5\u53ca\u5373\u5c06\u63a8\u51fa\u7684Project Lightning\uff0c\u90fd\u663e\u793a\u51fa\u516c\u53f8\u5728\u6ee1\u8db3\u5ba2\u6237\u9700\u6c42\u65b9\u9762\u7684\u5dee\u5f02\u5316\u4f18\u52bf\u3002\u6b64\u5916\uff0c\u516c\u53f8\u8fd8\u8ba1\u5212\u5728\u672a\u67658\u523012\u4e2a\u6708\u5185\u5b9e\u73b0\u51b7\u5374\u5355\u5143\u548c\u51b7\u677f\u7684\u5782\u76f4\u6574\u5408\uff0c\u8fd9\u5c06\u8fdb\u4e00\u6b65\u589e\u5f3a\u5176\u7ade\u4e89\u4f18\u52bf\u3002<br/><br/>\u603b\u4f53\u800c\u8a00\uff0cDELL\u5bf9\u672a\u6765\u7684\u589e\u957f\u5145\u6ee1\u4fe1\u5fc3\uff0c\u7279\u522b\u662f\u5728AI\u670d\u52a1\u5668\u548c\u5b58\u50a8\u4e1a\u52a1\u65b9\u9762\u3002\u516c\u53f8\u5c06\u7ee7\u7eed\u901a\u8fc7\u521b\u65b0\u548c\u5f3a\u5316\u5ba2\u6237\u5173\u7cfb\u6765\u63a8\u52a8\u589e\u957f\uff0c\u5e76\u5728AI\u548c\u6570\u636e\u4e2d\u5fc3\u9886\u57df\u4fdd\u6301\u9886\u5148\u5730\u4f4d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259628571", "pub_date": "2024-12-05 09:52:13"}, {"id": 259628570, "title": "\u3010\u4f1a\u8bae\u7eaa\u8981\u3011Credo Technology(CRDO)\u4e1a\u7ee9\u589e\u957f\u5f3a\u52b2 AI\u9a71\u52a8\u672a\u6765\u53d1\u5c55", "description": "<p>\u91d1\u543e\u8d22\u8baf | Credo Technology Group Holding Ltd(CRDO)\u57282025\u8d22\u5e74\u7b2c\u4e8c\u5b63\u5ea6\u7684\u8d22\u62a5\u7535\u8bdd\u4f1a\u8bae\u4e0a\u516c\u5e03\u4e86\u5f3a\u52b2\u7684\u8d22\u52a1\u4e1a\u7ee9\u3002\u516c\u53f8\u7b2c\u4e8c\u5b63\u5ea6\u6536\u5165\u8fbe\u52307200\u4e07\u7f8e\u5143\uff0c\u73af\u6bd4\u589e\u957f21%\uff0c\u540c\u6bd4\u589e\u957f64%\u3002Non-GAAP\u6bdb\u5229\u7387\u4e3a63.6%\uff0c\u521b\u4e0b\u516c\u53f8\u5386\u53f2\u4e0a\u6700\u6210\u529f\u7684\u5b63\u5ea6\u4e4b\u4e00\u3002Credo\u5728\u4e09\u6761\u4e3b\u8981\u4ea7\u54c1\u7ebf\u4e0a\u5747\u5b9e\u73b0\u4e86\u521b\u7eaa\u5f55\u7684\u6536\u5165\uff0c\u5e76\u5f00\u59cb\u770b\u5230\u51fa\u8d27\u91cf\u7684\u589e\u957f\uff0c\u8fd9\u6807\u5fd7\u7740\u516c\u53f8\u6536\u5165\u62d0\u70b9\u7684\u5f00\u59cb\u3002<br/><br/>\u673a\u6784\u5206\u6790\u4eba\u58eb\u5bf9Credo\u7684\u8868\u73b0\u7ed9\u4e88\u4e86\u79ef\u6781\u8bc4\u4ef7\u3002\u4ed6\u4eec\u8ba4\u4e3a\uff0cCredo\u63d0\u4f9b\u7684\u4ee5\u592a\u7f51\u8fde\u63a5\u89e3\u51b3\u65b9\u6848\uff0c\u5305\u62ec\u4e3b\u52a8\u7535\u5b50\u7535\u7f06\uff08AEC\uff09\u3001\u5149\u57df\u4fe1\u53f7\u5904\u7406\u5668\uff08optical DSPs\uff09\u3001\u7ebf\u5361\u91cd\u5b9a\u65f6\u5668\u3001SerDes\u82af\u7247\u548cSerDes IP\u8bb8\u53ef\u8bc1\u7b49\uff0c\u6b63\u8fce\u5408\u4e86AI\u96c6\u7fa4\u67b6\u6784\u5feb\u901f\u53d1\u5c55\u7684\u9700\u6c42\u3002\u8fd9\u4e9b\u89e3\u51b3\u65b9\u6848\u5728\u5904\u7406\u3001\u51b7\u5374\u548c\u7535\u6e90\u65b9\u9762\u7684\u521b\u65b0\u4f7f\u5f97\u96c6\u7fa4\u66f4\u52a0\u5bc6\u96c6\u548c\u53ef\u6269\u5c55\uff0c\u800cCredo\u7684\u6280\u672f\u5728\u7ef4\u62a4\u4fe1\u53f7\u5b8c\u6574\u6027\u3001\u4f18\u5316\u80fd\u6548\u548c\u63d0\u4f9b\u65e0\u4e0e\u4f26\u6bd4\u7684\u53ef\u9760\u6027\u65b9\u9762\u8868\u73b0\u51fa\u8272\u3002\u7279\u522b\u662fAEC\u4ea7\u54c1\uff0c\u56e0\u5176\u5728\u964d\u4f4e\u529f\u8017\u3001\u964d\u4f4e\u6210\u672c\u548c\u63d0\u9ad8\u53ef\u9760\u6027\u65b9\u9762\u7684\u4f18\u52bf\uff0c\u6b63\u9010\u6e10\u53d6\u4ee3\u57fa\u4e8e\u6fc0\u5149\u7684\u5149\u901a\u4fe1\u4ea7\u54c1\u3002<br/><br/>\u5c55\u671b\u672a\u6765\uff0cCredo\u5bf9\u81ea\u8eab\u7684\u589e\u957f\u548c\u76c8\u5229\u80fd\u529b\u5145\u6ee1\u4fe1\u5fc3\u3002\u516c\u53f8\u9884\u8ba1\uff0c\u968f\u7740AI\u90e8\u7f72\u7684\u9700\u6c42\u589e\u52a0\u548c\u5ba2\u6237\u5173\u7cfb\u7684\u52a0\u6df1\uff0cCredo\u5c06\u7ee7\u7eed\u4fdd\u6301\u589e\u957f\u52bf\u5934\u3002Credo\u7684AEC\u4ea7\u54c1\u7ebf\u5728\u7b2c\u4e8c\u5b63\u5ea6\u5b9e\u73b0\u4e86\u521b\u7eaa\u5f55\u7684\u6536\u5165\uff0c\u5f97\u76ca\u4e8e\u524d\u4e24\u5927\u5ba2\u6237\u548c\u4e00\u4e2a\u65b0\u5174\u8d85\u5927\u89c4\u6a21\u8ba1\u7b97\u5ba2\u6237\u7684\u5f3a\u52b2\u9700\u6c42\u3002\u516c\u53f8\u8fd8\u63a8\u51fa\u4e86800\u5409\u6bd4\u7279ZeroFlap AEC\u4ea7\u54c1\uff0c\u652f\u6301\u957f\u8fbe7\u7c73\u7684AI\u540e\u7aef\u7f51\u7edc\u8fde\u63a5\u3002\u6b64\u5916\uff0cCredo\u5728\u5149\u5b66DSP\u4e1a\u52a1\u4e0a\u4e5f\u53d6\u5f97\u4e86\u521b\u7eaa\u5f55\u7684\u6536\u5165\uff0c\u9884\u8ba1200\u5409\u6bd4\u7279\u6bcf\u901a\u9053\u89e3\u51b3\u65b9\u6848\u5c06\u5728\u672a\u6765\u51e0\u4e2a\u5b63\u5ea6\u63a8\u52a8\u589e\u957f\u3002\u516c\u53f8\u8fd8\u8ba1\u5212\u57282025\u5e74\u65e5\u5386\u5e74\u5411\u5ba2\u6237\u63a8\u51faPCIe\u4ea7\u54c1\u6837\u54c1\uff0c\u5e76\u9884\u8ba1\u57282026\u5e74\u5b9e\u73b0\u751f\u4ea7\u6536\u5165\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259628570", "pub_date": "2024-12-05 09:52:23"}]}