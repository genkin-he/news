{"data": [{"id": 254922827, "title": "\u3010\u76c8\u559c\u80a1\u3011\u4e2d\u56fd\u4eba\u6c11\u4fdd\u9669\u96c6\u56e2(01339)\u6da85.33% \u6599\u99963\u5b63\u51c0\u5229\u6da6\u540c\u6bd4\u589e\u957f\u81f3\u591a85%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u56fd\u4eba\u6c11\u4fdd\u9669\u96c6\u56e2(01339)\u53d1\u76c8\u559c\u63d0\u632f\u80a1\u4ef7\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a53.95\u6e2f\u5143\uff0c\u6da85.33%\uff0c\u6210\u4ea4\u989d1.43\u4ebf\u6e2f\u5143\u3002<br/><br/>\u636e\u76c8\u559c\u516c\u544a\uff0c\u9884\u671f2024\u5e74\u524d\u4e09\u5b63\u5ea6\u5b9e\u73b0\u5f52\u5c5e\u4e8e\u6bcd\u516c\u53f8\u80a1\u4e1c\u7684\u51c0\u5229\u6da6\u9884\u8ba1\u4e3a338.3\u4ebf\u81f3379.31\u4ebf\u5143\u4eba\u6c11\u5e01\uff0c\u540c\u6bd4\u589e\u957f65%\u81f385%\u3002<br/><br/>\u516c\u544a\u6307\uff0c2024\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u96c6\u56e2\u4e1a\u52a1\u7ed3\u6784\u6301\u7eed\u4f18\u5316\uff0c\u98ce\u9669\u9632\u63a7\u6709\u529b\u6709\u6548\uff0c\u964d\u672c\u589e\u6548\u6210\u679c\u663e\u7740\u3002\u96c6\u56e2\u5728\u592f\u5b9e\u7ecf\u8425\u57fa\u7840\u7684\u540c\u65f6\uff0c\u53e0\u52a0\u8d44\u672c\u5e02\u573a\u56de\u6696\u5f71\u54cd\uff0c\u603b\u6295\u8d44\u6536\u76ca\u540c\u6bd4\u5b9e\u73b0\u5927\u5e45\u589e\u957f\uff0c\u51c0\u5229\u6da6\u8f83\u53bb\u5e74\u540c\u671f\u589e\u5e45\u8f83\u5927\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254922827", "pub_date": "2024-10-16 09:59:33"}, {"id": 254922351, "title": "\u3010\u884c\u4e1a\u98ce\u5411\u3011\u7701\u95f4\u7535\u529b\u73b0\u8d27\u5e02\u573a\u6b63\u5f0f\u8fd0\u884c\uff1b\u6c34\u8d44\u6e90\u8d39\u6539\u7a0e\u8bd5\u70b9\u5c06\u5168\u9762\u5b9e\u65bd", "description": "<p><b>\u7701\u95f4\u7535\u529b\u73b0\u8d27\u5e02\u573a\u6b63\u5f0f\u8fd0\u884c</b><br/><br/>10\u670815\u65e5\uff0c\u7701\u95f4\u7535\u529b\u73b0\u8d27\u5e02\u573a\u8f6c\u5165\u6b63\u5f0f\u8fd0\u884c\uff0c\u4e2d\u56fd\u7535\u529b\u5e02\u573a\u5316\u4ea4\u6613\u8303\u56f4\u8fdb\u4e00\u6b65\u6269\u5927\u3002\u7535\u529b\u73b0\u8d27\u5e02\u573a\u3001\u4e2d\u957f\u671f\u5e02\u573a\u548c\u8f85\u52a9\u670d\u52a1\u5e02\u573a\u4e3a\u7535\u529b\u5e02\u573a\u7684\u57fa\u672c\u529f\u80fd\u6a21\u5757\u3002\u6309\u65f6\u95f4\u5212\u5206\uff0c\u5c06\u65e5\u4ee5\u4e0a\u7684\u4ea4\u6613\u79f0\u4e3a\u7535\u529b\u4e2d\u957f\u671f\u4ea4\u6613\uff0c\u5c06\u65e5\u524d\u53ca\u65e5\u4ee5\u5185\u7684\u4ea4\u6613\u79f0\u4e3a\u7535\u529b\u73b0\u8d27\u4ea4\u6613\u3002<br/><br/>\u7701\u95f4\u7535\u529b\u73b0\u8d27\u5e02\u573a\u8f6c\u5165\u6b63\u5f0f\u8fd0\u884c\uff0c\u5c06\u4f1a\u66f4\u597d\u4fc3\u8fdb\u65b0\u80fd\u6e90\u7684\u6d88\u7eb3\u3002\u4eca\u5e74\u524d8\u4e2a\u6708\u8bd5\u8fd0\u884c\u671f\u95f4\uff0c\u901a\u8fc7\u7701\u95f4\u73b0\u8d27\u5e02\u573a\uff0c\u65b0\u80fd\u6e90\u5229\u7528\u7387\u63d0\u5347\u4e861\u4e2a\u767e\u5206\u70b9\u3002<br/><br/>\u6765\u6e90\uff1a\u592e\u89c6\u65b0\u95fb<br/><br/><b>\u6c34\u8d44\u6e90\u8d39\u6539\u7a0e\u8bd5\u70b9\u5c06\u5168\u9762\u5b9e\u65bd</b><br/><br/>\u4e3a\u52a0\u5f3a\u6c34\u8d44\u6e90\u7ba1\u7406\u548c\u4fdd\u62a4\uff0c\u4fc3\u8fdb\u6c34\u8d44\u6e90\u8282\u7ea6\u96c6\u7ea6\u5b89\u5168\u5229\u7528\uff0c\u8d22\u653f\u90e8\u3001\u56fd\u5bb6\u7a0e\u52a1\u603b\u5c40\u3001\u6c34\u5229\u90e815\u65e5\u5bf9\u5916\u53d1\u5e03\u300a\u6c34\u8d44\u6e90\u7a0e\u6539\u9769\u8bd5\u70b9\u5b9e\u65bd\u529e\u6cd5\u300b\uff0c\u660e\u786e\u81ea2024\u5e7412\u67081\u65e5\u8d77\u5168\u9762\u5b9e\u65bd\u6c34\u8d44\u6e90\u8d39\u6539\u7a0e\u8bd5\u70b9\u3002<br/><br/>\u5168\u9762\u5b9e\u65bd\u6c34\u8d44\u6e90\u8d39\u6539\u7a0e\u8bd5\u70b9\uff0c\u6709\u52a9\u4e8e\u8fdb\u4e00\u6b65\u5de9\u56fa\u548c\u6269\u5927\u6c34\u8d44\u6e90\u7a0e\u6539\u9769\u6210\u679c\uff0c\u63a8\u52a8\u5f62\u6210\u7eff\u8272\u53d1\u5c55\u65b9\u5f0f\u548c\u751f\u6d3b\u65b9\u5f0f\uff0c\u662f\u6df1\u5316\u8d22\u7a0e\u4f53\u5236\u6539\u9769\u548c\u5b8c\u5584\u7eff\u8272\u7a0e\u6536\u4f53\u7cfb\u7684\u91cd\u8981\u6210\u679c\u3002\u636e\u4e09\u90e8\u95e8\u6709\u5173\u53f8\u8d1f\u8d23\u4eba\u4ecb\u7ecd\uff0c\u5168\u9762\u5b9e\u65bd\u6c34\u8d44\u6e90\u8d39\u6539\u7a0e\u8bd5\u70b9\u4e3b\u8981\u9075\u5faa\u56db\u65b9\u9762\u539f\u5219\uff1a\u5b9e\u73b0\u5e73\u7a33\u8f6c\u6362\uff0c\u5f3a\u5316\u5206\u7c7b\u8c03\u63a7\uff0c\u4f53\u73b0\u5730\u533a\u5dee\u5f02\uff0c\u8c03\u52a8\u5730\u65b9\u79ef\u6781\u6027\u3002<br/><br/>\u6765\u6e90\uff1a\u65b0\u534e\u7f51<br/><br/><b>\u963f\u65af\u9ea6\u4e1a\u7ee9\u66b4\u96f7\uff0c\u8ba2\u5355\u4ec5\u5e02\u573a\u9884\u671f\u7684\u4e00\u534a\uff0c\u4e0b\u8c03\u660e\u5e74\u9500\u552e\u76ee\u6807</b><br/><br/>\u6839\u636e\u8d22\u62a5\uff0c\u963f\u65af\u9ea6\u4e09\u5b63\u5ea6\u8ba2\u5355\u91cf\u4ec5\u4e3a26.3\u4ebf\u6b27\u5143\uff0c\u73af\u6bd4\u4e0b\u964d53%\uff0c\u540c\u65f6\u4e0b\u8c03\u4e862025\u5e74\u4e1a\u7ee9\u8425\u6536\u548c\u6bdb\u5229\u9884\u671f\u3002\u8be5\u516c\u53f8\u8868\u793a\uff0cAI\u82af\u7247\u9700\u6c42\u786e\u5b9e\u6fc0\u589e\uff0c\u4f46\u534a\u5bfc\u4f53\u5e02\u573a\u7684\u5176\u4ed6\u90e8\u5206\u6bd4\u9884\u671f\u66f4\u4e3a\u75b2\u5f31\uff0c\u5bfc\u81f4\u903b\u8f91\u82af\u7247\u5236\u9020\u5546\u63a8\u8fdf\u8ba2\u5355\u3002\u7cdf\u7cd5\u4e1a\u7ee9\u5bfc\u81f4\u963f\u65af\u9ea6\u7f8e\u80a1ADR\u8dcc\u8d8517%\uff0c\u5728\u8377\u5170\u5e02\u573a16%\u7684\u8dcc\u5e45\u5219\u521b\u4e0b1998\u5e74\u6765\u6700\u5927\u3002\u963f\u65af\u9ea6\u66b4\u8dcc\u540c\u65f6\u5e26\u5d29\u8d39\u57ce\u534a\u5bfc\u4f53\u6307\u6570\u548c\u82f1\u4f1f\u8fbe\u7b49\u4e00\u4f17\u82af\u7247\u80a1\u3002<br/><br/>\u6765\u6e90\uff1a\u534e\u5c14\u8857\u89c1\u95fb<br/><br/><b>\u4eac\u4e1c\u201c\u53cc11\u201d\u9996\u65e5\u6e2f\u6fb3\u9500\u989d\u540c\u6bd4\u589e\u903e\u4e09\u500d</b><br/><br/>\u4eac\u4e1c\u96c6\u56e214\u65e5\u665a\u542f\u52a8\u201c\u53cc11\u201d\u6d3b\u52a8\uff0c\u4eac\u4e1c\u6e2f\u6fb3\u53f0\u4e1a\u52a1\u8d1f\u8d23\u4eba\u6768\u80af15\u65e5\u5728\u8bb0\u8005\u4f1a\u8868\u793a\uff0c\u4ece\u6d3b\u52a8\u6b63\u5f0f\u5f00\u59cb\u81f315\u65e5\u4e0a\u5348\uff0c\u6e2f\u6fb3\u9500\u552e\u989d\u5df2\u6309\u5e74\u589e\u957f\u8d85\u8fc7\u4e09\u500d\u3002<br/><br/>\u6768\u80af\u8868\u793a\uff0c\u4ece\u76ee\u524d\u201c\u53cc11\u201d\u6218\u51b5\u770b\u6765\uff0c3C\u7535\u5b50\u4ea7\u54c1\u53ca\u5bb6\u7535\u4ea7\u54c1\u9500\u60c5\u6700\u597d\uff0c\u9500\u60c5\u6700\u4f73\u7684\u9996\u4e94\u4f4d\u6709\u56db\u4e2a\u90fd\u662f\u56fd\u4ea7\u4f18\u8d28\u54c1\u724c\u3002<br/><br/>\u6765\u6e90\uff1a\u9999\u6e2f\u4e2d\u901a\u793e<br/><br/><b>\u5168\u7403\u624b\u673a\u5927\u76d8\u7ee7\u7eed\u56de\u6e29\uff1a\u82f9\u679c\u7d27\u8ffd\u4e09\u661f\uff0cvivo\u589e\u957f\u6700\u5feb</b><br/><br/>\u8fd1\u65e5\uff0c\u591a\u5bb6\u5e02\u573a\u8c03\u7814\u673a\u6784\u53d1\u5e032024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u5168\u7403\u667a\u80fd\u624b\u673a\u5e02\u573a\u51fa\u8d27\u91cf\u62a5\u544a\u3002<br/><br/>\u5bf9\u4e8e\u5927\u76d8\u7684\u589e\u957f\u6001\u52bf\uff0cCanalys\u5206\u6790\u79f0\uff0c\u4e3b\u8981\u5f97\u76ca\u4e8e\u65b0\u5174\u7ecf\u6d4e\u4f53\u7684\u5f3a\u52b2\u9700\u6c42\uff0c\u4ee5\u53ca\u5317\u7f8e\u3001\u4e2d\u56fd\u548c\u6b27\u6d32\u7b49\u5730\u533a\u6b63\u5904\u4e8e\u667a\u80fd\u624b\u673a\u66f4\u6362\u5468\u671f\u7684\u65e9\u671f\u9636\u6bb5\u3002<br/><br/>\u6765\u6e90\uff1a\u754c\u9762\u65b0\u95fb</p>", "link": "https://sky.szfiu.com/info/hk/details/254922351", "pub_date": "2024-10-16 09:51:14"}, {"id": 254922350, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u4e2d\u56fd\u4e2d\u514d(01880)\u8dcc\u8d853.6% \u99969\u6708\u51c0\u5229\u6da6\u540c\u6bd4\u4e0b\u6ed124.7%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u56fd\u4e2d\u514d(01880)\u65e9\u76d8\u80a1\u4ef7\u627f\u538b\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a551.9\u6e2f\u5143\uff0c\u8dcc3.62%\uff0c\u6210\u4ea4\u989d6440.35\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u516c\u53f8\u516c\u5e03\uff0c2024\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u5728\u56fd\u5185\u6d88\u8d39\u589e\u957f\u653e\u7f13\u3001\u6d88\u8d39\u610f\u613f\u4e0d\u8db3\u7684\u5927\u73af\u5883\u4e0b\uff0c\u516c\u53f8\u7ecf\u8425\u9762\u4e34\u8bf8\u591a\u56f0\u96be\u548c\u6311\u6218\u3002\u671f\u5185\uff0c\u516c\u53f8\u5b9e\u73b0\u8425\u4e1a\u6536\u5165\u4eba\u6c11\u5e01430.21\u4ebf\u5143\uff0c\u540c\u6bd4\u4e0b\u964d15.38%\uff1b\u5b9e\u73b0\u5f52\u5c5e\u4e8e\u4e0a\u5e02\u516c\u53f8\u80a1\u4e1c\u7684\u51c0\u5229\u6da6\u4eba\u6c11\u5e0139.2\u4ebf\u5143\uff0c\u540c\u6bd4\u4e0b\u964d24.70%\u30022024\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u516c\u53f8\u4e3b\u8425\u4e1a\u52a1\u6bdb\u5229\u7387\u4e3a32.57%\uff0c\u540c\u6bd4\u63d0\u53471.09\u4e2a\u767e\u5206\u70b9\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254922350", "pub_date": "2024-10-16 09:51:18"}, {"id": 254922527, "title": "\u3010\u76c8\u559c\u80a1\u3011\u6cc9\u5cf0\u63a7\u80a1(02285)\u6da86.74% \u6599\u99969\u6708\u7eaf\u5229\u540c\u6bd4\u589e\u957f\u8d85300%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6cc9\u5cf0\u63a7\u80a1(02285)\u53d1\u76c8\u559c\uff0c\u5e26\u52a8\u80a1\u4ef7\u5f3a\u52bf\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a520.6\u6e2f\u5143\uff0c\u6da86.74%\uff0c\u6210\u4ea4\u989d1552.24\u4e07\u6e2f\u5143\u3002<br/><br/>\u636e\u76c8\u559c\u516c\u544a\uff0c\u9884\u671f\u622a\u81f32024\u5e749\u670830\u65e5\u6b629\u4e2a\u6708\u5f55\u5f97\u7eaf\u5229\u7ea61\u4ebf\u7f8e\u5143\uff0c\u8f83\u53bb\u5e74\u540c\u671f\u589e\u957f\u8d85\u8fc7300%\u3002<br/><br/>\u516c\u544a\u6307\uff0c\u9884\u671f\u7eaf\u5229\u589e\u957f\u4e3b\u8981\u7531\u4e8e\u65d7\u8230\u54c1\u724cEGO\u7684\u7ec8\u7aef\u9500\u552e\u8868\u73b0\u5f3a\u52b2\uff1b\u5f97\u76ca\u4e8e\u53bb\u5e93\u5468\u671f\u7684\u7ed3\u675f\uff0c2024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u7684\u6536\u5165\u589e\u957f\u7387\u8fdb\u4e00\u6b65\u52a0\u5feb\uff1b\u89c4\u6a21\u6062\u590d\u53ca\u7ecf\u8425\u6548\u7387\u63d0\u5347\u5bfc\u81f4\u6bdb\u5229\u7387\u63d0\u5347\uff1b\u53ca\u4ee5\u5747\u8861\u53ca\u9ad8\u6548\u7684\u65b9\u5f0f\u6301\u7eed\u4f18\u5316\u8425\u8fd0\u5f00\u652f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254922527", "pub_date": "2024-10-16 09:54:02"}, {"id": 254922236, "title": "\u7269\u7ba1\u80a1\u968f\u5185\u623f\u80a1\u8d70\u5f3a \u78a7\u6842\u56ed\u670d\u52a1(06098)\u6da86.04% \u6469\u901a\u79f0\u5185\u623f\u80a1\u8c03\u6574\u540e\u53ef\u4e8e\u843d\u540e\u7684\u7269\u7ba1\u80a1\u4e2d\u5bfb\u627e\u673a\u9047", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7269\u7ba1\u80a1\u968f\u5185\u623f\u80a1\u8d70\u5f3a\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6717\u8bd7\u7eff\u8272\u751f\u6d3b(01965)\u6da87.27%\uff0c\u6052\u5927\u7269\u4e1a(06666)\u6da87.23%\uff0c\u78a7\u6842\u56ed\u670d\u52a1(06098)\u6da86.04%\uff0c\u96c5\u751f\u6d3b\u670d\u52a1(03319)\u6da85.99%\uff0c\u4e16\u8302\u670d\u52a1(00873)\u6da85.88%\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u5149\u5927\u8bc1\u5238\u7814\u62a5\u6307\u51fa\uff0c\u7f8e\u8054\u50a8\u964d\u606f\u5468\u671f\u5f00\u542f\uff0c\u56fd\u5185\u5730\u4ea7\u653f\u7b56\u6301\u7eed\u4f18\u5316\uff0c\u7269\u4e1a\u7ba1\u7406\u98ce\u9669\u56e0\u5b50\u9010\u6b65\u51fa\u6e05\uff0c\u677f\u5757\u914d\u7f6e\u4ef7\u503c\u51f8\u663e\u3002\u5efa\u8bae\u5173\u6ce8\u4e09\u6761\u4e3b\u7ebf\uff1a1)\u201c\u4f30\u503c\u4fee\u590d\u201d\uff1a\u91cd\u70b9\u5173\u6ce8\u623f\u5730\u4ea7\u884c\u4e1a\u6d41\u52a8\u6027\u56de\u6696\u3001\u6c11\u8425\u623f\u4f01\u4fe1\u7528\u98ce\u9669\u9010\u6b65\u51fa\u6e05\u5e26\u6765\u7684\u98ce\u9669\u6ea2\u4ef7\u4e0b\u964d\u30022)\u201c\u5747\u8861\u53d1\u5c55\u201d\uff1a\u957f\u671f\u770b\u597d\u72ec\u7acb\u53d1\u5c55\u80fd\u529b\u8f83\u5f3a\uff0c\u9879\u76ee\u8d28\u91cf\u8f83\u9ad8\uff0c\u8fd0\u8425\u80fd\u529b\u53ca\u76c8\u5229\u80fd\u529b\u8f83\u5f3a\u7684\u7269\u7ba1\u516c\u53f8\uff0c\u5173\u6ce8\u65b0\u5927\u6b63\u7b49\u30023)\u201c\u7a33\u5065\u56fd\u4f01\u201d\uff1a\u56fd\u4f01\u7269\u7ba1\u516c\u53f8\u7684\u7a33\u5065\u53d1\u5c55\u548c\u4f4e\u98ce\u9669\u5e26\u6765\u4f30\u503c\u6ea2\u4ef7\u3002\u5173\u6ce8\u4fdd\u5229\u7269\u4e1a\u3001\u62db\u5546\u79ef\u4f59\u7b49\u3002<br/><br/>\u6469\u901a\u6b64\u524d\u8ba4\u4e3a\uff0c\u82e5\u6570\u636e\u6216\u653f\u7b56\u7684\u652f\u6301\u900a\u9884\u671f\uff0c\u5185\u623f\u80a1\u6216\u5267\u70c8\u8c03\u6574\uff0c\u4f46\u5efa\u8bae\u53ef\u4e8e\u843d\u540e\u7684\u7269\u7ba1\u80a1\u4e2d\u5bfb\u627e\u673a\u9047\u3002\u661f\u5c55\u5219\u8868\u793a\uff0c\u968f\u8457\u5e02\u573a\u60c5\u7eea\u6062\u590d\u7406\u6027\uff0c\u7269\u7ba1\u80a1\u5c06\u5904\u4e8e\u5f31\u52bf\u5c40\u9762\uff0c\u4f46\u56e0\u884c\u4e1a\u7684\u57fa\u672c\u9762\u7a33\u5b9a\uff0c\u4e14\u80a1\u606f\u7387\u5438\u5f15\uff0c2024\u5e74\u5e73\u5747\u80a1\u606f\u7387\u8d85\u8fc74%\uff0c\u67d0\u4e9b\u9677\u5165\u8d22\u56f0\u7684\u516c\u53f8\u80a1\u606f\u7387\u66f4\u9ad8\u8fbe7%\uff0c\u4e3a\u653f\u7b56\u8f6c\u5411\u63d0\u4f9b\u66f4\u5b89\u5168\u7684\u66ff\u4ee3\u65b9\u6848\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254922236", "pub_date": "2024-10-16 09:49:44"}, {"id": 254921732, "title": "\u5185\u623f\u80a1\u76d8\u521d\u5411\u597d \u9f99\u5149\u96c6\u56e2(03380)\u6da818.39% \u660e\u65e5\u4e94\u90e8\u95e8\u5c31\u623f\u5730\u4ea7\u5e02\u573a\u5e73\u7a33\u53d1\u5c55\u4e3e\u884c\u65b0\u95fb\u53d1\u5e03\u4f1a", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5185\u623f\u80a1\u76d8\u521d\u5411\u597d\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u9f99\u5149\u96c6\u56e2(03380)\u6da818.39%\uff0c\u878d\u521b\u4e2d\u56fd(01918)\u6da810%\uff0c\u9f99\u6e56\u96c6\u56e2(00960)\u6da87.64%\uff0c\u5bcc\u529b\u5730\u4ea7(02777)\u6da86.67%\uff0c\u65b0\u57ce\u53d1\u5c55(01030)\u6da85.41%\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c10\u670815\u65e5\u665a\uff0c\u56fd\u52a1\u9662\u65b0\u95fb\u529e\u516c\u5ba4\u53d1\u5e03\u6d88\u606f\uff1a\u5b9a\u4e8e2024\u5e7410\u670817\u65e5\uff08\u661f\u671f\u56db\uff09\u4e0a\u534810\u65f6\u4e3e\u884c\u65b0\u95fb\u53d1\u5e03\u4f1a\uff0c\u4f4f\u623f\u57ce\u4e61\u5efa\u8bbe\u90e8\u90e8\u957f\u502a\u8679\u548c\u8d22\u653f\u90e8\u3001\u81ea\u7136\u8d44\u6e90\u90e8\u3001\u4e2d\u56fd\u4eba\u6c11\u94f6\u884c\u3001\u56fd\u5bb6\u91d1\u878d\u76d1\u7763\u7ba1\u7406\u603b\u5c40\u8d1f\u8d23\u4eba\u4ecb\u7ecd\u4fc3\u8fdb\u623f\u5730\u4ea7\u5e02\u573a\u5e73\u7a33\u5065\u5eb7\u53d1\u5c55\u6709\u5173\u60c5\u51b5\uff0c\u5e76\u7b54\u8bb0\u8005\u95ee\u3002<br/><br/>\u65e5\u524d\uff0c10\u670812\u65e5\uff0c\u8d22\u653f\u90e8\u5ba3\u5e03\u63a8\u51fa\u4e00\u63fd\u5b50\u8d22\u653f\u589e\u91cf\u653f\u7b56\uff0c\u5305\u62ec\u901a\u8fc7\u53e0\u52a0\u8fd0\u7528\u4e13\u9879\u503a\u5238\u3001\u4e13\u9879\u8d44\u91d1\u3001\u7a0e\u6536\u653f\u7b56\u7b49\u5de5\u5177\u6765\u652f\u6301\u623f\u5730\u4ea7\u5e02\u573a\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254921732", "pub_date": "2024-10-16 09:40:13"}, {"id": 254921677, "title": "\u4e2d\u56fd\u592e\u884c\u4eca\u65e5\u8fdb\u884c6424\u4ebf\u51437\u5929\u671f\u9006\u56de\u8d2d\u64cd\u4f5c", "description": "<p>\u91d1\u543e\u8d22\u8baf | 10\u670816\u65e5\uff0c\u4e2d\u56fd\u592e\u884c\u4eca\u65e5\u8fdb\u884c6424\u4ebf\u51437\u5929\u671f\u9006\u56de\u8d2d\u64cd\u4f5c\uff0c\u4e2d\u6807\u5229\u7387\u4e3a1.50%\uff0c\u4e0e\u6b64\u524d\u6301\u5e73\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/254921677", "pub_date": "2024-10-16 09:39:54"}, {"id": 254921247, "title": "\u6e2f\u80a1\u5ef6\u7eed\u4f4e\u5f00\u6001\u52bf \u6052\u6307\u8dcc0.86% \u4e2d\u82af\u56fd\u9645(00981)\u632b4.21%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6e2f\u80a1\u5ef6\u7eed\u4f4e\u5f00\u6001\u52bf\uff0c\u6052\u6307\u8dcc0.86%\uff0c\u56fd\u4f01\u6307\u6570\u8dcc0.9%\uff0c\u6052\u751f\u79d1\u6280\u6307\u6570\u8dcc1.34%\u3002<br/><br/>\u4e2d\u82af\u56fd\u9645(00981)\u8dcc4.21%\uff0c\u4fe1\u4e49\u5149\u80fd(00968)\u8dcc3.44%\uff0c\u65b0\u5965\u80fd\u6e90(02688)\u8dcc2.91%\uff0c\u53cb\u90a6\u4fdd\u9669(01299)\u8dcc2.59%\u3002\u6da8\u5e45\u65b9\u9762\uff0c\u9f99\u6e56\u96c6\u56e2(00960)\u6da84.84%\uff0c\u4e1c\u65b9\u6d77\u5916\u56fd\u9645(00316)\u6da82.09%\uff0c\u4e07\u6d32\u56fd\u9645(00288)\u6da81.68%\u3002<br/><br/>\u4e2d\u56fd\u4e2d\u514d(01880)\u4f4e\u5f003.44%\uff0c\u516c\u53f8\u516c\u5e03\uff0c2024\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u5728\u56fd\u5185\u6d88\u8d39\u589e\u957f\u653e\u7f13\u3001\u6d88\u8d39\u610f\u613f\u4e0d\u8db3\u7684\u5927\u73af\u5883\u4e0b\uff0c\u516c\u53f8\u7ecf\u8425\u9762\u4e34\u8bf8\u591a\u56f0\u96be\u548c\u6311\u6218\u3002\u671f\u5185\uff0c\u516c\u53f8\u5b9e\u73b0\u8425\u4e1a\u6536\u5165\u4eba\u6c11\u5e01430.21\u4ebf\u5143\uff0c\u540c\u6bd4\u4e0b\u964d15.38%\uff1b\u5b9e\u73b0\u5f52\u5c5e\u4e8e\u4e0a\u5e02\u516c\u53f8\u80a1\u4e1c\u7684\u51c0\u5229\u6da6\u4eba\u6c11\u5e0139.2\u4ebf\u5143\uff0c\u540c\u6bd4\u4e0b\u964d24.70%\u30022024\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u516c\u53f8\u4e3b\u8425\u4e1a\u52a1\u6bdb\u5229\u7387\u4e3a32.57%\uff0c\u540c\u6bd4\u63d0\u53471.09\u4e2a\u767e\u5206\u70b9\u3002<br/><br/>\u6cc9\u5cf0\u63a7\u80a1(02285)\u9ad8\u5f005.7%\uff0c\u516c\u53f8\u53d1\u76c8\u559c\uff0c\u9884\u671f\u622a\u81f32024\u5e749\u670830\u65e5\u6b629\u4e2a\u6708\u5f55\u5f97\u7eaf\u5229\u7ea61\u4ebf\u7f8e\u5143\uff0c\u8f83\u53bb\u5e74\u540c\u671f\u589e\u957f\u8d85\u8fc7300%\u3002\u7eaf\u5229\u589e\u957f\u4e3b\u8981\u7531\u4e8e\u65d7\u8230\u54c1\u724cEGO\u7684\u7ec8\u7aef\u9500\u552e\u8868\u73b0\u5f3a\u52b2\uff1b\u5f97\u76ca\u4e8e\u53bb\u5e93\u5468\u671f\u7684\u7ed3\u675f\uff0c2024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u7684\u6536\u5165\u589e\u957f\u7387\u8fdb\u4e00\u6b65\u52a0\u5feb\uff1b\u89c4\u6a21\u6062\u590d\u53ca\u7ecf\u8425\u6548\u7387\u63d0\u5347\u5bfc\u81f4\u6bdb\u5229\u7387\u63d0\u5347\uff1b\u53ca\u4ee5\u5747\u8861\u53ca\u9ad8\u6548\u7684\u65b9\u5f0f\u6301\u7eed\u4f18\u5316\u8425\u8fd0\u5f00\u652f\u3002<br/><br/>\u4e2d\u56fd\u8d22\u9669(02328)\u9ad8\u5f001.54%\uff0c\u516c\u53f8\u9884\u671f\uff0c2024\u5e741\u67081\u65e5\u81f39\u670830\u65e5\u9884\u8ba1\u51c0\u5229\u6da6\u4e0e2023\u5e74\u540c\u671f\u76f8\u6bd4\u5c06\u589e\u52a0\u7ea620%\u81f340%\u3002\u8be5\u516c\u53f8\u8868\u793a\uff0c2024\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u4e1a\u52a1\u89c4\u6a21\u7a33\u6b65\u589e\u957f\uff0c\u8d44\u4ea7\u914d\u7f6e\u8fdb\u4e00\u6b65\u4f18\u5316\uff0c\u53d7\u8d44\u672c\u5e02\u573a\u56de\u6696\u5f71\u54cd\uff0c\u603b\u6295\u8d44\u6536\u76ca\u540c\u6bd4\u589e\u5e45\u8f83\u5927\u3002<br/><br/>\u9ad8\u946b\u96f6\u552e(06808)\u590d\u724c\u9ad8\u5f0025.14%\uff0c\u516c\u53f8\u53d1\u76c8\u559c\uff0c\u9884\u671f\u622a\u81f32024\u5e749\u670830\u65e5\u6b626\u4e2a\u6708\u7a0e\u540e\u6ea2\u5229\u7ea61.5\u4ebf\u81f32\u4ebf\u5143\u4eba\u6c11\u5e01(\u4e0b\u540c)\uff0c\u53bb\u5e74\u540c\u671f\u5f55\u5f97\u7a0e\u540e\u4e8f\u635f\u989d\u4e3a3.78\u4ebf\u5143\u3002\u9884\u671f\u7a0e\u540e\u6ea2\u5229\u6539\u5584\u4e3b\u8981\u53d7\u76ca\u4e8e\uff1a\u540c\u5e97\u6765\u5ba2\u6570\u4f01\u7a33\uff0c\u540c\u5e97\u9500\u552e\u989d\u5b9e\u73b0\u6b63\u589e\u957f\uff1b\u4ee5\u53ca\u964d\u672c\u589e\u6548\u5feb\u901f\u63a8\u8fdb\uff0c\u6210\u6548\u663e\u7740\u3002<br/><br/>\u5b8f\u6c47\u8d44\u4ea7\u7ba1\u7406\u6295\u8d44\u603b\u76d1 \u90ed\u5bb6\u8000\u8868\u793a\uff0c\u7f8e\u80a1\u5468\u4e8c\u8d70\u52bf\u5411\u4e0b\uff0c\u4f01\u4e1a\u4e1a\u7ee9\u8868\u73b0\u53c2\u5dee\uff0c\u5927\u5e02\u7531\u9ad8\u4f4d\u56de\u843d\uff0c\u4e09\u5927\u6307\u6570\u5747\u5f55\u5f97\u8dcc\u5e45\u6536\u5e02\u3002\u7f8e\u5143\u8d70\u52bf\u5411\u4e0b\uff0c\u7f8e\u56fd\u5341\u5e74\u671f\u503a\u606f\u56de\u843d\u81f34.03\u5398\u6c34\u5e73\uff0c\u91d1\u4ef7\u6301\u7eed\u5411\u597d\uff0c\u6cb9\u4ef7\u8d70\u52bf\u4e0b\u6ed1\u3002\u6e2f\u80a1\u9884\u6258\u8bc1\u5238\u666e\u904d\u4e0b\u8dcc\uff0c\u9884\u6599\u5927\u5e02\u65e9\u6bb5\u8ddf\u968f\u4f4e\u5f00\u3002\u5185\u5730\u80a1\u5e02\u6628\u65e5\u4e0b\u8dcc\uff0c\u6caa\u7efc\u6307\u4f4e\u5f00\u4f4e\u8d70\uff0c\u6536\u5e02\u4e0b\u8dcc2.5%\uff0c\u6caa\u6df1\u4e24\u5e02\u6210\u4ea4\u989d\u7ee7\u7eed\u6d3b\u8dc3\u3002\u6e2f\u80a1\u8868\u73b0\u56de\u843d\uff0c\u6307\u6570\u5931\u5b8821,000\u70b9\u6c34\u5e73\u3002\u5185\u5730\u5b8f\u89c2\u7ecf\u6d4e\u6570\u636e\u8868\u73b0\u4f4e\u4e8e\u9884\u671f\uff0c\u52a0\u4e0a\u4eba\u6c11\u5e01\u8868\u73b0\u5411\u4e0b\uff0c\u62d6\u7d2f\u5927\u5e02\u6c14\u6c1b\uff0c\u6574\u4f53\u6210\u4ea4\u4ea6\u8f83\u524d\u51cf\u5c11\u3002\u5e02\u573a\u89c2\u671b\u66f4\u591a\u653f\u7b56\u843d\u5b9e\uff0c\u6307\u6570\u77ed\u671f\u6216\u8003\u9a8c20,000\u70b9\u652f\u6301\uff0c\u4e0a\u65b9\u963b\u529b\u572821,200\u70b9\u6c34\u5e73\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/254921247", "pub_date": "2024-10-16 09:31:48"}, {"id": 254921246, "title": "\u3010\u65b0\u80a1IPO\u3011\u4e03\u725b\u667a\u80fd(02567)\u9996\u6302\u5f00\u62a51.6\u6e2f\u5143 \u8f83\u62db\u80a1\u4ef7\u4f4e41.82%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e03\u725b\u667a\u80fd(02567)\u9996\u6302\u5f00\u62a51.6\u6e2f\u5143\uff0c\u8f83\u62db\u80a1\u4ef7\u4f4e41.82%\uff0c\u76d8\u524d\u6210\u4ea41406.2\u4e07\u80a1\uff0c\u6210\u4ea4\u989d2577.32\u4e07\u6e2f\u5143\u3002\u6bcf\u624b1000\u80a1\uff0c\u8d26\u9762\u4e8f\u635f1150\u6e2f\u5143\u3002<br/><br/>\u636e\u62db\u80a1\u7ed3\u679c\u663e\u793a\uff0c\u6700\u7ec8\u53d1\u552e\u4ef7\u5b9a\u4e3a\u6bcf\u80a12.75\u6e2f\u5143\uff0c\u96c6\u8d44\u603b\u989d4.39\u4ebf\u6e2f\u5143\uff0c\u51c0\u989d\u7ea63.67\u4ebf\u6e2f\u5143\u3002\u6bcf\u624b\u4e70\u5356\u5355\u4f4d\u4e3a1000\u80a1\uff0c\u4e00\u624b\u4e2d\u7b7e\u7387\u4e3a80%\uff0c\u8ba4\u8d2d2\u624b\u53ef\u7a33\u83b7\u4e00\u624b\u3002\u516c\u5f00\u53d1\u552e\u90e8\u5206\u63a5\u83b715,747\u4efd\u6709\u6548\u7533\u8bf7\uff0c\u8ba4\u8d2d\u6c34\u5e73\u4e3a19.87\u500d\uff0c\u56fd\u9645\u914d\u552e\u8ba4\u8d2d\u6c34\u5e73\u4e3a1.02\u500d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254921246", "pub_date": "2024-10-16 09:31:51"}, {"id": 254921245, "title": "\u3010AH\u4e92\u52a8\u3011A\u80a1\u4e09\u5927\u6307\u6570\u96c6\u4f53\u4f4e\u5f00 \u6caa\u6307\u4f4e\u5f001% \u7b97\u529b\u82af\u7247\u3001\u91d1\u878d\u79d1\u6280\u7b49\u677f\u5757\u8dcc\u5e45\u5c45\u524d", "description": "<p>\u91d1\u543e\u8d22\u8baf | A\u80a1\u4e09\u5927\u6307\u6570\u96c6\u4f53\u4f4e\u5f00\uff0c\u6caa\u6307\u4f4e\u5f001%\uff0c\u6df1\u6210\u6307\u4f4e\u5f001.67%\uff0c\u521b\u4e1a\u677f\u6307\u4f4e\u5f002.31%\u3002<br/><br/>\u76d8\u9762\u4e0a\u770b\uff0c\u7b97\u529b\u82af\u7247\u3001\u91d1\u878d\u79d1\u6280\u3001\u5927\u57fa\u91d1\u7cfb\u7b49\u677f\u5757\u8dcc\u5e45\u5c45\u524d\uff1b\u623f\u5730\u4ea7\u3001\u9517\u9553\u7b49\u677f\u5757\u6709\u652f\u6491\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254921245", "pub_date": "2024-10-16 09:31:56"}]}