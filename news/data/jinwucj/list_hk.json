9e4f\u5728\u7535\u52a8\u8f66\u9886\u57df\u7684\u8fdb\u5c55\u53ca\u5feb\u901f\u4f18\u5316\u6210\u672c\u7684\u80fd\u529b\u8868\u793a\u8d5e\u8d4f\uff0c\u4f46\u8ba4\u4e3a\u5f53\u524d\u80a1\u4ef7\u7684\u6da8\u5e45\u5df2\u7ecf\u5145\u5206\u4f53\u73b0\u5728\u4ef7\u683c\u4e2d\uff0c\u800c\u6f5c\u5728\u7684\u4e0b\u884c\u98ce\u9669\u5c1a\u672a\u5728\u80a1\u4ef7\u4e2d\u5f97\u5230\u53cd\u6620\u3002\u8003\u8651\u5230\u5c0f\u9e4f2024\u5e74\u7684\u9500\u552e\u9884\u6d4b\u4e0a\u8c03\u81f319%\u523030\u4e07\u8f86\uff0c\u745e\u94f6\u56e0\u6b64\u5c06\u5c0f\u9e4f\u7684\u76ee\u6807\u80a1\u4ef7\u4ece8.2\u7f8e\u5143\u8c03\u6574\u81f38.8\u7f8e\u5143\uff0c\u5e76\u5c06\u5176\u80a1\u7968\u8bc4\u7ea7\u4ece\u201c\u4e2d\u6027\u201d\u4e0b\u8c03\u4e3a\u201c\u5356\u51fa\u201d\u3002<br/>\u745e\u94f6\u8fd8\u8868\u8fbe\u4e86\u5bf9\u516c\u53f8\u80fd\u5426\u7ef4\u6301M03\u548cP7+\u6bcf\u6708\u4e00\u4e07\u53f0\u4ea4\u4ed8\u91cf\u7684\u62c5\u5fe7\uff0c\u5e76\u5bf9\u4e8e\u660e\u5e74\u4e0a\u534a\u5e74\u6574\u4f53\u7535\u52a8\u8f66\u5e02\u573a\u7684\u8868\u73b0\u6301\u8c28\u614e\u6001\u5ea6\u3002\u6b64\u5916\uff0c\u745e\u94f6\u6307\u51fa\uff0c\u867d\u7136\u589e\u7a0b\u578b\u7535\u52a8\u8f66\uff08EREV\uff09\u4ea7\u54c1\u7ebf\u53ef\u80fd\u6709\u52a9\u4e8e\u62d3\u5c55\u516c\u53f8\u7684\u5e02\u573a\u4efd\u989d\uff0c\u4f46\u76ee\u524d\u5bf9\u4e8e\u5c0f\u9e4f\u672a\u6765EREV\u4ea7\u54c1\u7684\u89c4\u5212\u4e86\u89e3\u6709\u9650\u3002EREV\u8f66\u578b\u662f\u5426\u80fd\u52a9\u529b\u5c0f\u9e4f\u6269\u5927\u4e1a\u52a1\u89c4\u6a21\u5e76\u51cf\u5c11\u8fd0\u8425\u4e8f\u635f\uff0c\u5c06\u53d6\u51b3\u4e8e\u516c\u53f8\u5bf9\u76ee\u6807\u5ba2\u6237\u7684\u6d1e\u5bdf\u3001\u6267\u884c\u7b56\u7565\u7684\u6709\u6548\u6027\u4ee5\u53caEREV\u54c1\u724c\u5728\u5e02\u573a\u4e0a\u88ab\u8ba4\u77e5\u7684\u7a0b\u5ea6\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259816394", "pub_date": "2024-12-06 15:54:32"}, {"id": 259815649, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u752c\u5174\u8bc1\u5238\u7ef4\u6301\u7f8e\u56e2(03690)\u201c\u4e70\u5165\u201d\u8bc4\u7ea7 \u770b\u597d\u5176\u65b0\u4e1a\u52a1\u7ee7\u7eed\u51cf\u4e8f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u752c\u5174\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u7f8e\u56e2(03690)11\u670829\u65e5\u53d1\u5e032024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u4e1a\u7ee9\u62a5\u544a\u3002\u8d22\u62a5\u663e\u793a\uff0c\u62a5\u544a\u671f\u5185\uff0c\u7f8e\u56e2\u5b9e\u73b0\u8425\u6536935.77\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f22.4%\uff1b\u7ecf\u8c03\u6574\u6ea2\u5229\u51c0\u989d\u4e3a128\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f124%\u3002\u4e09\u5b63\u5ea6\uff0c\u7f8e\u56e2\u95ea\u8d2d\u65e5\u5747\u5355\u91cf\u7a81\u78341000\u4e07\u5355\uff0c\u4ea4\u6613\u7528\u6237\u6570\u548c\u4ea4\u6613\u9891\u6b21\u5747\u5b9e\u73b0\u53cc\u4f4d\u6570\u589e\u957f\u3002\u201c\u4e03\u5915\u201d\u5f53\u65e5\uff0c\u8ba2\u5355\u91cf\u5cf0\u503c\u66f4\u8d85\u8fc7\u4e861600\u4e07\u5355\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u65b0\u4e1a\u52a1\u65b9\u9762\uff0c\u968f\u7740\u5546\u54c1\u96f6\u552e\u4e1a\u52a1\u6548\u7387\u6539\u5584\uff0c\u65b0\u4e1a\u52a1\u5b63\u5ea6\u4e8f\u635f\u8fdb\u4e00\u6b65\u6536\u7a84\u81f310\u4ebf\u5143\u3002\u6839\u636e\u516c\u53f8\u4e09\u5b63\u62a5\uff0c\u5341\u6708\u4efd\uff0cKeeta\u5728\u6c99\u7279\u9996\u90fd\u5229\u96c5\u5f97\u6b63\u5f0f\u4e0a\u7ebf\uff0c\u516c\u53f8\u56fd\u9645\u62d3\u5c55\u8fc8\u51fa\u91cd\u8981\u4e00\u6b65\uff0c\u957f\u671f\u6765\u770b\uff0c\u516c\u53f8\u7684\u6d77\u5916\u4e1a\u52a1\u503c\u5f97\u5173\u6ce8\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u770b\u597d\u7ec4\u7ec7\u67b6\u6784\u6539\u9769\u6301\u7eed\u63a8\u52a8\u4e0b\uff0c\u4e00\u65b9\u9762\u516c\u53f8\u6838\u5fc3\u672c\u5730\u5546\u4e1a\u4e1a\u52a1\u7a33\u5065\u53d1\u5c55\uff0c\u53e6\u4e00\u65b9\u9762\u65b0\u4e1a\u52a1\u7ee7\u7eed\u51cf\u4e8f\u3002\u8be5\u884c\u8c03\u5347\u516c\u53f8\u6536\u5165\u53ca\u5229\u6da6\u9884\u6d4b\u3002\u8be5\u884c\u9884\u6d4b\u516c\u53f82024-2026\u5e74\u8425\u4e1a\u6536\u5165\u5206\u522b\u4e3a3395\u30013920\u30014506\u4ebf\u5143\uff1b\u516c\u53f82024-26\u5e74\u7ecf\u8c03\u6574\u6ea2\u5229\u989d\u5206\u522b\u4e3a430\u3001543\u3001681\u4ebf\u5143\u3002\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259815649", "pub_date": "2024-12-06 15:49:54"}, {"id": 259814613, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u4e2d\u56fd\u4eba\u5bff(02628)\u5347\u903e3% \u8fd1\u65e5\u4e0e\u4e2d\u56fd\u519c\u4e1a\u94f6\u884c\u5728\u4eac\u7b7e\u7f72\u6218\u7565\u5408\u4f5c\u534f\u8bae", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u56fd\u4eba\u5bff(02628)\u80a1\u4ef7\u65e9\u76d8\u9707\u8361\u8d70\u9ad8\uff0c\u5348\u540e\u7ef4\u6301\u9ad8\u4f4d\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da83.07%\uff0c\u62a515.44\u6e2f\u5143\uff0c\u6210\u4ea4\u989d7.32\u4ebf\u6e2f\u5143\u3002</p><p>\u6d88\u606f\u9762\u4e0a\uff0c\u96c6\u56e2\u4e0e\u4e2d\u56fd\u519c\u4e1a\u94f6\u884c\u5728\u4eac\u7b7e\u7f72\u6218\u7565\u5408\u4f5c\u534f\u8bae\uff0c\u53cc\u65b9\u4ee5\u65b0\u4e00\u8f6e\u6218\u7565\u5408\u4f5c\u4e3a\u5951\u673a\uff0c\u6301\u7eed\u6df1\u5316\u5728\u517b\u8001\u91d1\u878d\u3001\u6295\u878d\u8d44\u4e1a\u52a1\u3001\u94f6\u4fdd\u4ee3\u7406\u7b49\u91cd\u70b9\u9886\u57df\u7684\u52a1\u5b9e\u5408\u4f5c\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259814613", "pub_date": "2024-12-06 15:42:49"}, {"id": 259813291, "title": "\u5f18\u6d69\u56fd\u9645\u63a7\u80a1(08375)\u6da8\u5e45\u6269\u81f3411% \u516c\u53f8\u63a7\u80a1\u6743\u53d8\u66f4 \u83b7\u90ed\u51e1\u6ea2\u4ef7\u7ea642.09%\u63d0\u5168\u8d2d\u8981\u7ea6", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5f18\u6d69\u56fd\u9645\u63a7\u80a1(08375)\u80a1\u4ef7\u6301\u7eed\u62c9\u5347\uff0c\u6da8411.63%\uff0c\u62a51.1\u6e2f\u5143\uff0c\u6210\u4ea4\u989d3831.9\u4e07\u6e2f\u5143\uff0c\u5e02\u503c\u4e3a3.17\u4ebf\u6e2f\u5143\u3002<br/></p><p>\u6d88\u606f\u9762\u4e0a\uff0c\u5f18\u6d69\u56fd\u9645\u63a7\u80a1\u53ca\u8981\u7ea6\u4ebaSuper Date Co., Ltd\u8054\u5408\u516c\u5e03\uff0c\u4e8e2024\u5e7412\u67085\u65e5\u8981\u7ea6\u4eba\u5df2\u5b8c\u6210\u5411Vertical Technology Investment Limited\u53ca\u6e29\u6d69\u7136\u8d2d\u4e70\u7ea61.88\u4ebf\u80a1\u516c\u53f8\u80a1\u4efd\uff0c\u5360\u516c\u53f8\u4e8e\u672c\u8054\u5408\u516c\u544a\u65e5\u671f\u5168\u90e8\u5df2\u53d1\u884c\u80a1\u672c\u7ea665.33%\uff0c\u603b\u4ee3\u4ef7\u4e3a\u7ea65747.98\u4e07\u6e2f\u5143\uff0c\u76f8\u7b49\u4e8e\u6bcf\u80a1\u9500\u552e\u80a1\u4efd0.3055\u6e2f\u5143\u3002\u7d27\u968f\u5b8c\u6210\u540e\u53ca\u4e8e\u672c\u8054\u5408\u516c\u544a\u65e5\u671f\uff0c\u8981\u7ea6\u4eba\u53ca\u4e0e\u5176\u4e00\u81f4\u884c\u52a8\u4eba\u58eb\u5c06\u4e8e\u7ea61.88\u4ebf\u80a1\u80a1\u4efd\u4e2d\u62e5\u6709\u6743\u76ca\uff0c\u5360\u516c\u53f8\u5168\u90e8\u5df2\u53d1\u884c\u80a1\u672c\u7ea665.33%\u3002 \u6839\u636e\u6536\u8d2d\u5b88\u5219\u89c4\u521926.1\uff0c\u8981\u7ea6\u4eba\u56e0\u6b64\u5c06\u987b\u5c31\u6240\u6709\u5df2\u53d1\u884c\u80a1\u4efd(\u8981\u7ea6\u4eba\u53ca\u2571\u6216\u4e0e\u5176\u4e00\u81f4\u884c\u52a8\u4eba\u58eb\u5df2\u62e5\u6709\u53ca\u2571\u6216\u540c\u610f\u5c06\u4e88\u6536\u8d2d\u8005\u9664\u5916)\u63d0\u51fa\u5f3a\u5236\u6027\u65e0\u6761\u4ef6\u73b0\u91d1\u8981\u7ea6\u3002 \u6bcf\u80a1\u8981\u7ea6\u80a1\u4efd\u73b0\u91d10.3055\u6e2f\u5143\uff0c\u8f83\u80a1\u4efd\u4e8e2024\u5e7411\u670822\u65e5(\u5373\u6700\u540e\u4ea4\u6613\u65e5)\u5728\u8054\u4ea4\u6240\u6240\u62a5\u7684\u7684\u6536\u5e02\u4ef7\u6bcf\u80a10.2150\u6e2f\u5143\u6ea2\u4ef7\u7ea642.09%\u3002</p><p>\u4e8e\u516c\u544a\u65e5\u671f\uff0c\u8981\u7ea6\u4eba\u7531\u90ed\u51e1\u6700\u7ec8\u5b9e\u76ca\u5168\u8d44\u62e5\u6709\u3002\u8981\u7ea6\u4eba\u7684\u552f\u4e00\u8463\u4e8b\u4e3a\u90ed\u51e1\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259813291", "pub_date": "2024-12-06 15:33:23"}]}