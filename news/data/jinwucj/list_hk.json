/td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">0.9</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">\u5efa\u8bbe\u94f6\u884c</span><span style=\"display: inline-block; vertical-align:middle;\">(00939)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">6.1\uff081.2%\uff09</td></tr></table></div>", "link": "https://sky.szfiu.com/info/hk/details/254945306", "pub_date": "2024-10-16 14:30:04"}, {"id": 254944945, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5f00\u6e90\u8bc1\u5238\u7ef4\u6301361\u5ea6(01361)\u201c\u4e70\u5165\u201d\u8bc4\u7ea7 \u6307Q4\u6d41\u6c34\u589e\u957f\u8d8b\u52bf\u6709\u671b\u5ef6\u7eed", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5f00\u6e90\u8bc1\u5238\u53d1\u7814\u62a5\u6307\uff0c361\u5ea6(01361)2024Q3\u6210\u4eba\u7ebf\u4e0b\u6d41\u6c34\u5f55\u5f97\u7ea610%\u589e\u957f\u3001361\u00b0\u7ae5\u88c5\u7ebf\u4e0b\u6d41\u6c34\u7ea610%\u589e\u957f\u3001\u7535\u5546\u6d41\u6c34\u5f55\u5f9720%\u4ee5\u4e0a\u589e\u957f\u30022024Q3\u6d41\u6c34\u8868\u73b0\u8f83\u4e3a\u575a\u97e7\uff0c\u7ecf\u8425\u6307\u6807\u7a33\u5065\uff0c\u9ec4\u91d1\u5468\u7ebf\u4e0a\u6d41\u6c34\u589e\u957f30%+\uff0c\u7ebf\u4e0b\u6d41\u6c34\u540c\u6bd4\u589e\u957f20%+\u3002<br/><br/>\u8be5\u884c\u7eed\u6307\uff0c\u53d7\u76ca\u4e8e\u6027\u4ef7\u6bd4\u54c1\u724c\u7684\u5b9a\u4ef7\u4f18\u52bf\u53ca\u4ea7\u54c1\u7ade\u4e89\u529b\u63d0\u5347\uff0c2024Q3\u7ecf\u8425\u6307\u6807\u8868\u73b0\u8f83\u4e3a\u5e73\u7a33\uff0c2024Q3\u5e93\u9500\u6bd44.5-5\u4fdd\u6301\u826f\u6027\uff0c\u6298\u6263\u5927\u7ea671\u6298\uff0c\u5f53\u5b63\u65b0\u54c1\u552e\u7f44\u738775%\u3002\u7ebf\u4e0b\u6d41\u6c34\u53d7\u76ca\u4e8e\u5965\u83b1\u5e97\u578b\u53ca\u6539\u6269\u5e97\uff0c\u7ae5\u88c5\u4e94\u4ee3\u5e97\u6301\u7eed\u8fed\u4ee3\uff0c\u622a\u81f32024Q3\uff0c\u7ae5\u88c5\u9762\u79ef\u73af\u6bd4Q2\u51c0\u589e\u52a02\u33a1\u5230110\u33a1\uff0c\u6210\u4eba\u9762\u79ef\u73af\u6bd4Q2\u51c0\u589e\u52a04\u33a1\u5230147\u33a1\uff0c\u9884\u8ba1\u6210\u4eba\u5341\u4ee3\u5e97\u5373\u5c06\u843d\u5730\uff0c\u95e8\u5e97\u5f62\u8c61\u8fed\u4ee3\u6709\u671b\u8fdb\u4e00\u6b65\u63d0\u5347\u5e97\u6548\u3002\u622a\u81f32024Q3\uff0c\u5927\u88c5\u5965\u83b1\u95e8\u5e97196\u95f4\uff0c\u7ae5\u88c5\u5965\u83b1\u95e8\u5e97151\u95f4\uff0c\u8f83Q2\u5747\u4e3a\u51c0\u589e\u52a0\u6001\u52bf\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u5728Q4\u7535\u5546\u65fa\u5b63\u4fc3\u8fdb\u4e0b\u8d8b\u52bf\u6709\u671b\u5ef6\u7eed\uff0c\u8be5\u884c\u7ef4\u6301\u76c8\u5229\u9884\u6d4b\uff0c\u9884\u8ba12024-2026\u5e74\u51c0\u5229\u6da6\u4e3a11.4/13.5/15.8\u4ebf\u5143\uff0c\u5f53\u524d\u80a1\u4ef7\u5bf9\u5e94PE\u4e3a6.8/5.7/4.9\u500d\uff0c\u516c\u53f8\u4ea7\u54c1\u7aef\u6784\u5efa\u8dd1\u6b65\u3001\u7bee\u7403\u7b49\u4e13\u4e1a\u4ea7\u54c1\u77e9\u9635\u5e76\u4e0d\u65ad\u521b\u65b0\uff0c\u6e20\u9053\u7aef\u6539\u6269\u5927\u5e97\u53ca\u65b0\u5e97\u578b\u5347\u7ea7\u63d0\u5347\u5e97\u6548\uff0c\u8425\u9500\u7aef\u54c1\u724c\u8d44\u6e90\u4e0d\u65ad\u4e30\u5bcc\u63d0\u5347\u54c1\u724c\u8ba4\u77e5\u53ca\u5f71\u54cd\u529b\uff0c\u7ee7\u7eed\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254944945", "pub_date": "2024-10-16 14:27:01"}, {"id": 254944944, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u4eac\u4e1c\u7269\u6d41(02618)\u76d8\u4e2d\u6da8\u8d854% \u62df\u5728\u660e\u5e74\u5e95\u5c06\u6d77\u5916\u4ed3\u9762\u79ef\u903e\u500d\u589e\u52a0 \u62db\u94f6\u56fd\u9645\u5347\u5176\u76ee\u6807\u4ef717%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4eac\u4e1c\u7269\u6d41(02618)\u76d8\u4e2d\u6da8\u8d854%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da82.75%\uff0c\u62a514.2\u6e2f\u5143\uff0c\u6210\u4ea4\u989d2.15\u4ebf\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u4eac\u4e1c\u7269\u6d41\u5ba3\u5e03\uff0c\u5168\u7403\u7ec7\u7f51\u8ba1\u5212\u5c06\u5168\u9762\u5347\u7ea7\uff0c\u4e3a\u63d0\u5347\u51fa\u6d77\u54c1\u724c\u3001\u6d77\u5916\u5ba2\u6237\u7684\u670d\u52a1\u4f53\u9a8c\uff0c\u8ba1\u5212\u81f32025\u5e74\u5e95\u5168\u7403\u6d77\u5916\u4ed3\u9762\u79ef\u5c06\u5b9e\u73b0\u8d85\u8fc7100%\u589e\u957f\uff0c\u540c\u65f6\u8fdb\u4e00\u6b65\u5e03\u5c40\u5efa\u8bbe\u4fdd\u7a0e\u4ed3\u53ca\u76f4\u90ae\u4ed3\u3002<br/><br/>\u6b64\u5916\uff0c\u62db\u94f6\u56fd\u9645\u53d1\u5e03\u7814\u7a76\u62a5\u544a\u6307\uff0c\u6599\u4eac\u4e1c\u7b2c\u4e09\u5b63\u6536\u5165\u5c06\u6309\u5e74\u53474.9%\u81f32,600\u4ebf\u5143\uff0c\u8f83\u7b2c\u4e8c\u5b63\u5ea6\u76841.2%\u589e\u957f\u6709\u6240\u52a0\u5feb\uff0c\u4e3b\u8981\u53d7\u60e0\u4e8e\u8f83\u597d\u7684\u5546\u54c1\u6210\u4ea4\u91d1\u989d(GMV)\u589e\u957f\u53ca\u4ee5\u65e7\u6362\u65b0\u653f\u7b56\u3002\u8be5\u884c\u9884\u6d4b2024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u96c6\u56e2\u6bdb\u5229\u7387\u5c06\u6309\u5e74\u6269\u59270.2\u4e2a\u767e\u5206\u70b9\uff0c\u63a8\u52a8\u7b2c\u4e09\u5b63\u5ea6\u96c6\u56e2\u51c0\u5229\u6da6\u6309\u5e74\u589e\u957f3%\uff0c\u8fbe\u5230110\u4ebf\u5143\u3002\u8be5\u884c\u9884\u671f2024\u8d22\u5e74\u96c6\u56e2\u6536\u5165\u4f1a\u6309\u5e74\u589e4.5%\uff0c\u5f53\u4e2d\u4eac\u4e1c\u96f6\u552e\u53ca\u4eac\u4e1c\u7269\u6d41\u6536\u5165\u5206\u522b\u6309\u5e74\u589e5.1%\u53ca9.5%\uff0c\u6599\u4eca\u5e74\u96c6\u56e2\u975e\u901a\u7528\u4f1a\u8ba1\u51c6\u5219\u7eaf\u5229\u6309\u5e74\u589e\u957f20%\u3002\u8be5\u884c\u6307\uff0c\u516c\u53f8\u662f\u8d22\u653f\u523a\u6fc0\u63aa\u65bd\u7684\u4e3b\u8981\u53d7\u60e0\u8005\uff0c\u52a0\u4e0a\u6b63\u9762\u7684\u957f\u671f\u76c8\u5229\u589e\u957f\u5c55\u671b\uff0cH\u80a1\u76ee\u6807\u4ef7\u4ea6\u7531165\u6e2f\u5143\u5347\u81f3194\u6e2f\u5143\uff0c\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002<br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/254944944", "pub_date": "2024-10-16 14:27:13"}, {"id": 254943756, "title": "\u65e5\u7ecf225\u6307\u6570\u6536\u76d8\u8dcc1.83% \u62a539180.3\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u65e5\u7ecf225\u6307\u6570\u6536\u76d8\u8dcc1.83%\uff0c\u62a539180.3\u70b9\u3002<br/><br/>\u65e5\u672c\u653f\u5e9c\u6570\u636e\u663e\u793a\uff0c8\u6708\u6838\u5fc3\u673a\u68b0\u8ba2\u5355\u6309\u6708\u4e0b\u8dcc1.9%\uff0c\u6309\u5e74\u4e0b\u8dcc3.4%\uff0c\u4e24\u8005\u5747\u900a\u4e8e\u5e02\u573a\u9884\u671f\u3002<br/><br/>\u6838\u5fc3\u673a\u68b0\u8ba2\u5355\u88ab\u89c6\u4e3a\u8861\u91cf\u672a\u67656\u81f39\u4e2a\u6708\u8d44\u672c\u5f00\u652f\u7684\u91cd\u8981\u6307\u6807\uff0c\u4f46\u6ce2\u52a8\u6027\u8f83\u5927\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254943756", "pub_date": "2024-10-16 14:15:07"}, {"id": 254942973, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u745e\u6052\uff1a\u7f8e\u5143\u4e0a\u6da8\u884c\u60c5\u544a\u4e00\u6bb5\u843d \u7f8e\u5143\u5151\u65e5\u5143\u6c47\u7387\u6a2a\u76d8\u6574\u7406", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u745e\u6052\u6307\uff0c2024\u5e7410\u670816\u65e5\uff0c\u4e1c\u4eac\u5916\u6c47\u5e02\u573a\u7f8e\u5143\u5151\u65e5\u5143\u6c47\u7387\u65e9\u76d8\u5f00\u76d8\u5728149.1\u65e5\u5143\u9644\u8fd1\uff0c\u8f83\u4e0a\u4e00\u4ea4\u6613\u65e5\u4e0b\u8dcc0.39\u65e5\u5143\u3002<br/><br/>\u6628\u5929\u7684\u4e1c\u4eac\u5916\u6c47\u5e02\u573a\uff0c\u7531\u4e8e\u7f3a\u4e4f\u5173\u952e\u6027\u6750\u6599\uff0c\u7f8e\u5143\u4e0a\u6da8\u884c\u60c5\u544a\u4e00\u6bb5\u843d\u540e\uff0c\u6574\u4f53\u5904\u4e8e\u6a2a\u76d8\u6574\u7406\u7684\u6001\u52bf\u3002\u65e5\u5143\u6c47\u7387\u65b9\u9762\uff0c\u5728150\u65e5\u5143\u6574\u6570\u4f4d\u4e00\u7ebf\u7684\u963b\u529b\u4f9d\u65e7\u5b58\u5728\uff0c\u7f8e\u5143\u5151\u65e5\u5143\u6c47\u7387\u5728\u83b7\u5229\u4e86\u7ed3\u538b\u529b\u4e0b\u4e00\u5ea6\u6765\u5230148\u65e5\u5143\u4e00\u7ebf\u7684\u65e5\u5185\u4f4e\u70b9\u540e\u6700\u540e\u56de\u5230149\u65e5\u5143\u6c34\u5e73\u6536\u76d8\u3002\u8ddd\u79bb\u7f8e\u56fd\u5927\u9009\u53ea\u5269\u4e0b\u6700\u540e\u51e0\u5468\u7684\u65f6\u95f4\uff0c\u6295\u8d44\u8005\u5f00\u59cb\u5c06\u6ce8\u610f\u529b\u8f6c\u5411\u526f\u603b\u7edf\u54c8\u91cc\u65af\u548c\u524d\u603b\u7edf\u7279\u6717\u666e\u4e4b\u95f4\u89d2\u9010\u3002\u6709\u5206\u6790\u8ba4\u4e3a\uff0c\u5982\u679c\u7279\u6717\u666e\u83b7\u80dc\u5c06\u5bfc\u81f4\u7f8e\u5143\u6c47\u7387\u7684\u8d70\u5f3a\u3002\u7279\u6717\u666e\u4e00\u76f4\u575a\u6301\u63d0\u9ad8\u5173\u7a0e\uff0c\u5e76\u8868\u793a\u4f1a\u5c06\u5176\u7b2c\u4e00\u4efb\u671f\u6240\u9881\u5e03\u7684\u5927\u90e8\u5206\u51cf\u7a0e\u653f\u7b56\u6c38\u4e45\u5316\uff0c\u540c\u65f6\u4e5f\u53ef\u80fd\u4f1a\u52a0\u5927\u5bf9\u6b27\u6d32\u7b49\u5176\u4ed6\u540c\u76df\u56fd\u5bb6\u7684\u538b\u529b\u3002\u53e6\u5916\uff0c\u8d22\u653f\u6269\u5f20\u7684\u653f\u7b56\u6709\u53ef\u80fd\u4f1a\u4f7f\u5f97\u901a\u80c0\u518d\u6b21\u4e0a\u5347\uff0c\u800c\u7f8e\u8054\u50a8\u7a81\u7136\u505c\u6b62\u964d\u606f\u5468\u671f\u7684\u53ef\u80fd\u6027\u4e5f\u4f3c\u4e4e\u5f00\u59cb\u8fdb\u5165\u5e02\u573a\u7684\u89c6\u7ebf\u3002\u53e6\u4e00\u65b9\u9762\uff0c\u5c3d\u7ba1\u5e02\u573a\u5bf9\u7f8e\u8054\u50a8\u6e10\u8fdb\u5f0f\u964d\u606f\u6b65\u4f10\u7684\u9884\u671f\u4e0d\u65ad\u53d8\u5316\uff0c\u4f46\u603b\u4f53\u8ba4\u4e3a\u7f8e\u5143\u5728\u77ed\u671f\u5185\u4ecd\u5c06\u4fdd\u6301\u5f3a\u52bf\u3002<br/><br/>\u6280\u672f\u65b9\u9762\u6765\u770b\uff0c\u7f8e\u5143\u5151\u65e5\u5143\u6c47\u7387\u5728\u7a81\u7834\u4e868\u6708\u4efd\u9ad8\u70b9\u7684149\u65e5\u5143\u4e00\u7ebf\u963b\u529b\u540e\uff0c\u5f00\u59cb\u5c1d\u8bd5150\u65e5\u5143\u6574\u6570\u4f4d\u4e00\u7ebf\u7684\u5fc3\u7406\u4ef7\u4f4d\u3002\u7ed3\u5408200\u65e5\u79fb\u52a8\u5747\u7ebf\uff0c\u8be5\u4ef7\u4f4d\u9644\u8fd1\u7684\u4e0a\u884c\u963b\u529b\u4f9d\u65e7\u8f83\u5927\u3002\u8003\u8651\u5230\u7f8e\u56fd\u5927\u9009\u5373\u5c06\u5230\u6765,\u5916\u6c47\u5e02\u573a\u4e0a\u663e\u793a\u51fa\u8f83\u5f3a\u7684\u4e0d\u786e\u5b9a\u6027\u3002\u4ea4\u6613\u7b56\u7565\u4e0a\u5efa\u8bae\u79bb\u573a\u89c2\u671b\u3002<br/><br/><br/></p>", "link": "https://sky.szfiu.com/info/hk/details/254942973", "pub_date": "2024-10-16 14:07:38"}, {"id": 254943070, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u8336\u767e\u9053(02555)\u5348\u540e\u66b4\u6da8\u8d8560% \u9999\u6e2f\u9996\u5e97\u6b63\u5f0f\u5f00\u4e1a \u591a\u4f4dTVB\u827a\u4eba\u6253\u5361\u652f\u6301", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u8336\u767e\u9053(02555)\u5348\u540e\u66b4\u6da8\u8d8560%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da865.01%\uff0c\u62a514.62\u6e2f\u5143\uff0c\u6210\u4ea4\u989d4363\u4e07\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c10\u670811\u65e5\uff0c\u8336\u767e\u9053\u9999\u6e2f\u9996\u5e97\u6b63\u5f0f\u5f00\u4e1a\uff0c\u6d88\u8d39\u8005\u70ed\u60c5\u706b\u7206\uff0c\u5e73\u5747\u7b49\u5f85\u65f6\u957f\u7ea62\u5c0f\u65f6\u3002\u5f00\u4e1a\u5f53\u5929\u5305\u62ec\u9ec4\u5b97\u6cfd\u5728\u5185\u7684\u591a\u4f4dTVB\u827a\u4eba\u73b0\u8eab\u6253\u5361\uff0c\u5c06\u73b0\u573a\u6c14\u6c1b\u63a8\u5411\u9ad8\u6f6e\u3002\u8336\u767e\u9053\u65d7\u4e0b\u7ecf\u5178\u996e\u54c1\u6768\u679d\u7518\u9732\u53d7\u5230\u9999\u6e2f\u5e02\u6c11\u8ffd\u6367\uff0c\u5355\u65e5\u9500\u552e\u5360\u6bd430%\uff0c\u6210\u4e3a\u5e97\u5185\u8d85\u7ea7\u5355\u54c1\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/254943070", "pub_date": "2024-10-16 14:08:50"}]}