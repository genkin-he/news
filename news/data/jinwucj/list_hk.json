5168\u5468\u671fGMV\u540c\u6bd4\u589e\u957f\u5206\u522b\u8fbe\u523080+%/150+%\uff1b\u7531\u5de8\u5b50\u751f\u7269\u4e3b\u5bfc\u5236\u5b9a\u7684\u300a\u53d1\u9175\u4eba\u53c2\u7c89\u300b\u56e2\u4f53\u6807\u51c6\u6b63\u5f0f\u53d1\u5e03\uff0c\u4e3a\u8be5\u9886\u57df\u9996\u4e2a\u56e2\u4f53\u6807\u51c6\u3002\u8be5\u884c\u8868\u793a\uff0c\u516c\u53f8\u4f5c\u4e3a\u91cd\u7ec4\u80f6\u539f\u86cb\u767d\u9f99\u5934\uff0c\u51ed\u501f\u591a\u5143\u5316\u4ea7\u54c1\u77e9\u9635\u548c\u6e20\u9053\u4f18\u52bf\uff0c\u4e1a\u7ee9\u6709\u671b\u6301\u7eed\u9ad8\u589e\u3002\u636e\u516c\u53f82024\u534a\u5e74\u5ea6\u62a5\u544a\uff0c\u8be5\u884c\u8c03\u6574\u516c\u53f8\u7684\u4e1a\u7ee9\u9884\u6d4b\uff0c\u9884\u8ba1\u516c\u53f82024-2026\u5e74\u5f52\u6bcd\u51c0\u5229\u6da6\u5206\u522b\u4e3a20.82\u300127.33\u300135.30\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u901f\u4e3a43%\u300131%\u300129%\uff082024-2026\u5e74\u524d\u503c\u4e3a19.22\u300124.21\u300130.16\u4ebf\u5143\uff09\u3002\u5bf9\u5e94PE\u5206\u522b\u4e3a23\u300118\u300114\u500d\u3002\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259775449", "pub_date": "2024-12-06 09:54:27"}, {"id": 259774417, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u767e\u80dc\u4e2d\u56fd(09987)\u6da83.34% \u4e0e\u9ad8\u76db\u8ba2\u7acb\u80a1\u4efd\u56de\u8d2d\u534f\u8bae 5.5\u4ebf\u6e2f\u5143\u7528\u4e8e\u56de\u8d2d\u6e2f\u80a1", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u767e\u80dc\u4e2d\u56fd(09987)\u76d8\u521d\u80a1\u4ef7\u8d70\u9ad8\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da83.34%\uff0c\u62a5377\u6e2f\u5143\uff0c\u6210\u4ea4\u989d1372.86\u4e07\u6e2f\u5143\u3002</p><p>\u516c\u53f8\u65e5\u524d\u4e0e\u9ad8\u76db\u8ba2\u7acb\u80a1\u4efd\u56de\u8d2d\u534f\u8bae\uff0c\u5c06\u900f\u8fc7\u516c\u5f00\u5e02\u573a\u53ca\u8054\u4ea4\u6240\u7684\u8bbe\u65bd\u6839\u636e\u9884\u8bbe\u53c2\u6570\u56de\u8d2d\u6e2f\u80a1\uff1b\u540c\u65e5\u516c\u53f8\u8fd8\u5c31\u5176\u5728\u7f8e\u4e0a\u5e02\u80a1\u4efd\u8ba2\u7acb\u56de\u8d2d\u534f\u8bae\u3002</p><p>\u767e\u80dc\u4e2d\u56fd\u8868\u793a\uff0c\u534f\u8bae\u6240\u8ba2\u622a\u81f32025\u5e74\u4e0a\u534a\u5e74\u4e4b\u603b\u56de\u8d2d\u91d1\u989d\u4e3a3.6\u4ebf\u7f8e\u5143\uff0c\u5176\u4e2d2.9\u4ebf\u7f8e\u5143\u7528\u4f5c\u56de\u8d2d\u5176\u7f8e\u80a1\uff0c\u5176\u4f595.5\u4ebf\u6e2f\u5143\u7528\u4e8e\u56de\u8d2d\u5176\u6e2f\u80a1\u3002</p><p>\u516c\u53f8\u6307\uff0c\u56de\u8d2d\u534f\u8bae\u662f\u5176\u56de\u8d2d\u8ba1\u5212\u7684\u4e00\u4e2a\u7ec4\u6210\u90e8\u5206\uff0c\u4e5f\u662f\u66f4\u5e7f\u6cdb\u7684\u8d44\u672c\u5206\u914d\u8ba1\u5212\u7684\u4e00\u90e8\u5206\uff0c\u5373\u4ece2024\u5e74\u52302026\u5e74\u901a\u8fc7\u80a1\u606f\u548c\u80a1\u4efd\u56de\u8d2d\u5411\u80a1\u4e1c\u8fd4\u8fd845\u4ebf\u7f8e\u5143\uff0c\u5176\u4e2d\u5305\u62ec2024\u5e74\u5168\u5e74\u768415\u4ebf\u7f8e\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259774417", "pub_date": "2024-12-06 09:40:12"}, {"id": 259774709, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u77e5\u884c\u6c7d\u8f66\u79d1\u6280(01274)\u5927\u6da8\u903e10% \u5ba3\u5e03\u4e0e\u5730\u5e73\u7ebf\u673a\u5668\u4eba(09660)\u8fbe\u6210\u6218\u7565\u5408\u4f5c", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u77e5\u884c\u6c7d\u8f66\u79d1\u6280(01274)\u65e9\u76d8\u80a1\u4ef7\u5f3a\u52bf\uff0c\u6682\u6da810.58%\uff0c\u62a519.86\u6e2f\u5143\uff0c\u6210\u4ea4\u989d5100\u4e07\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u77e5\u884c\u6c7d\u8f66\u79d1\u6280\u5c06\u4e0e\u5730\u5e73\u7ebf\u673a\u5668\u4eba-W(09660)\u8fbe\u6210\u6218\u7565\u5408\u4f5c\uff0c\u53cc\u65b9\u5c06\u57fa\u4e8e\u5730\u5e73\u7ebf\u5f81\u7a0b\u7cfb\u52176E\u82af\u7247(\u7b80\u79f0J6E)\u5f00\u53d1\u667a\u9a7e\u65b9\u6848\uff0c\u76ee\u6807\u5e02\u573a\u4e3a10\u4e07\u81f315\u4e07\u4e2d\u9636\u667a\u9a7e\u5e02\u573a\u3002<br/><br/>\u636e\u6089\uff0c\u5730\u5e73\u7ebfJ6E\u82af\u7247\u5355\u9897\u7b97\u529b80TOPS\uff0c\u53ef\u652f\u6301\u9ad8\u901f\u9886\u822a\u3001\u81ea\u52a8\u6cca\u8f66\u53ca\u57ce\u5e02\u8bb0\u5fc6\u9886\u822a\u7b49\u529f\u80fd\u3002\u57fa\u4e8eJ6E\u6253\u9020\u7684\u6574\u5957\u65b9\u6848\u4ef7\u683c\u57285,000\u5143\u4eba\u6c11\u5e01\u4ee5\u4e0b\uff0c\u652f\u6301\u88ab\u52a8\u6563\u70ed\uff0c\u53ef\u5728\u71c3\u6cb9\u8f66\u4e2d\u4f7f\u7528\uff0c\u4e3a\u6781\u5177\u6027\u4ef7\u6bd4\u7684\u65b9\u6848\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259774709", "pub_date": "2024-12-06 09:44:12"}, {"id": 259774154, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4ea4\u94f6\u56fd\u9645\u7ef4\u6301\u9ad8\u9014(GOTU)\u4e70\u5165\u8bc4\u7ea7 \u65992026\u5e74\u6216\u5c06\u770b\u5230\u516c\u53f8\u6574\u4f53\u626d\u4e8f\u4e3a\u76c8", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4ea4\u94f6\u56fd\u9645\u53d1\u7814\u62a5\u6307\uff0c\u7565\u5fae\u8c03\u6574\u9ad8\u9014(GOTU)\u8d22\u52a1\u9884\u6d4b\uff0c\u9884\u8ba12024/25\u5e74\u516c\u53f8\u6574\u4f53\u6536\u516544.7\u4ebf\u5143/56\u4ebf\u5143\uff0c\u76f8\u6bd4\u6b64\u524d\u9884\u6d4b\u53d8\u52a8\u57281%\u4ee5\u5185\uff0c\u5bf9\u6bd4\u5e02\u573a\u4e00\u81f4\u9884\u671f\uff08VA\uff09\u768444.4\u4ebf\u5143/61.5\u4ebf\u5143\uff0c\u5e02\u573a\u9884\u671f\u6216\u4f1a\u6839\u636e\u516c\u53f8\u8f6c\u5411\u6536\u5165\u589e\u901f\u53ca\u6295\u5165\u5747\u8861\u6218\u7565\uff0c\u4e0b\u8c032025\u5e74\u6536\u5165\u589e\u901f\uff0c\u4f46\u4e5f\u5c06\u8c03\u6574\u4e8f\u635f\u6536\u7a84\u901f\u5ea6\uff0c\u9884\u8ba12026\u5e74\u6216\u5c06\u770b\u5230\u516c\u53f8\u6574\u4f53\u626d\u4e8f\u4e3a\u76c8\u3002\u6839\u636e\u8be5\u884c\u76ee\u524d\u5bf9\u516c\u53f8\u7ebf\u4e0a\u6559\u80b2\u6536\u5165\u9884\u671f\u53ca\u76c8\u5229\u80fd\u529b\u7684\u91ca\u653e\uff0c\u5bf9\u5e94\u7ebf\u4e0a\u6559\u80b215\u500d\u5e02\u76c8\u7387\uff0c\u80a1\u4ef7\u672a\u6765\u6709\u53cd\u5f39\u673a\u4f1a\u3002\u7ef4\u6301\u76ee\u6807\u4ef74.6\u7f8e\u5143\u53ca\u4e70\u5165\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259774154", "pub_date": "2024-12-06 09:36:57"}, {"id": 259773709, "title": "\u3010\u65b0\u80a1IPO\u3011\u591a\u70b9\u6570\u667a(02586)\u9996\u6302\u5f00\u62a521.7\u6e2f\u5143 \u8f83\u62db\u80a1\u4ef7\u4f4e28.17%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u591a\u70b9\u6570\u667a(02586)\u9996\u6302\u5f00\u62a521.7\u6e2f\u5143\uff0c\u8f83\u62db\u80a1\u4ef7\u4f4e28.17%\uff0c\u76d8\u524d\u6210\u4ea4\u989d677.47\u4e07\u6e2f\u5143\uff0c\u4e0d\u8ba1\u624b\u7eed\u8d39\uff0c\u6bcf\u624b100\u80a1\uff0c\u8d26\u9762\u4e8f851\u6e2f\u5143\u3002</p><p>\u6839\u636e\u62db\u80a1\u7ed3\u679c\u663e\u793a\uff0c\u6700\u7ec8\u53d1\u552e\u4ef7\u5b9a\u4e3a\u6bcf\u80a130.21\u6e2f\u5143\uff0c\u96c6\u8d44\u603b\u989d7.79\u4ebf\u6e2f\u5143\uff0c\u51c0\u989d\u7ea66.24\u4ebf\u6e2f\u5143\u3002\u4e00\u624b\u4e2d\u7b7e\u7387100%\uff0c\u4eba\u4eba\u6709\u4efd\u3002\u80a1\u4efd\u4e8e\u516c\u5f00\u53d1\u552e\u90e8\u4efd\u8ba4\u8d2d\u989d1.94\u500d\uff1b\u56fd\u9645\u53d1\u552e\u8ba4\u8d2d\u989d1.36\u500d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259773709", "pub_date": "2024-12-06 09:30:19"}, {"id": 259773708, "title": "\u592e\u884c\u4eca\u65e5\u8fdb\u884c1909\u4ebf\u51437\u5929\u671f\u9006\u56de\u8d2d\u64cd\u4f5c \u4e2d\u6807\u5229\u73871.5%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u592e\u884c\u4eca\u65e5\u8fdb\u884c1909\u4ebf\u51437\u5929\u671f\u9006\u56de\u8d2d\u64cd\u4f5c\uff0c\u4e2d\u6807\u5229\u7387\u4e3a1.50%\uff0c\u4e0e\u6b64\u524d\u6301\u5e73\u3002\u56e0\u4eca\u65e5\u67094790\u4ebf\u51437\u5929\u671f\u9006\u56de\u8d2d\u5230\u671f\uff0c\u5f53\u65e5\u5b9e\u73b0\u51c0\u56de\u7b3c2881\u4ebf\u5143\u3002\u592e\u884c\u672c\u5468\u5171\u5f00\u5c553541\u4ebf\u5143\u9006\u56de\u8d2d\u64cd\u4f5c\uff0c\u56e0\u672c\u5468\u5171\u670914862\u4ebf\u5143\u9006\u56de\u8d2d\uff0c\u672c\u5468\u6574\u4f53\u5b9e\u73b0\u51c0\u56de\u7b3c11321\u4ebf\u5143\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259773708", "pub_date": "2024-12-06 09:30:29"}, {"id": 259774058, "title": "\u3010\u7279\u7ea6\u5927V\u3011\u9093\u58f0\u5174\uff1a\u201c\u4e2d\u7279\u4f30\u201d\u6982\u5ff5\u80a1\u8d70\u52bf\u5f3a\u52b2 \u53ef\u7279\u522b\u7559\u610f\u4e2d\u8d44\u7535\u8baf\u80a1", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6052\u6307\u5468\u56db(5\u65e5)\u6536\u5e02\u62a519560\uff0c\u8dcc182\u70b9\u62160.92%\u3002\u5927\u5e02\u5168\u65e5\u6210\u4ea41093\u4ebf\u5143\u3002\u56fd\u6307\u8dcc70\u70b9\u62161%\uff0c\u62a57014\u3002\u79d1\u6307\u8dcc33\u70b9\u62160.8%\uff0c\u62a54370\u3002\u5185\u5730\u80a1\u5e02\u7a84\u5e45\u4e2a\u522b\u8d70\uff0c\u4e0a\u8bc1\u6307\u6570\u6536\u5e02\u53474\u70b9\uff0c\u62a53368\uff1b\u6caa\u6df1300\u8dcc0.2%\u3002\u6bd4\u7279\u5e01\u7a81\u783410\u4e07\u7f8e\u5143\uff0c\u865a\u62df\u8d27\u5e01ETF\u8ddf\u968f\u663e\u7740\u9020\u597d\u521b\u4e0a\u5e02\u65b0\u9ad8\u3002\u534e\u590f\u6bd4\u7279\u5e01(03042)\u53476.8%\uff0c\u6210\u4ea4\u8fd12.5\u4ebf\u5143\u3002<br/><br/>\u9053\u6307\u5468\u56db(5\u65e5)\u6536\u62a544765\u70b9\uff0c\u8dcc248\u70b9\u62160.55%\u3002\u6807\u6307\u56de\u54100.19%\uff0c\u62a56075\u70b9\uff1b\u7eb3\u6307\u8f6c\u8dcc0.18%\uff0c\u62a519700\u70b9\uff1b\u91cd\u78c5\u80a1\u4ee5\u7279\u65af\u62c9(Tesla)\u6700\u6807\u9752\uff0c\u80a1\u4ef7\u6536\u5e02\u626c\u53473.2%\uff0c\u62a5369.49\u7f8e\u5143\uff0c\u521b2022\u5e744\u6708\u4ee5\u6765\u65b0\u9ad8\uff0c\u76d8\u4e2d\u7834\u9876\u66fe\u89c1375.43\u7f8e\u5143\uff0c\u5347\u5e45\u8fbe\u52304.9%\uff0c\u7f8e\u94f6\u8bc1\u5238\u5c06\u7279\u65af\u62c9\u76ee\u6807\u4ef7\u7531350\u7f8e\u5143\uff0c\u8c03\u9ad8\u81f3400\u7f8e\u5143\uff0c\u7ef4\u6301\u201c\u4e70\u5165\u201d\u6295\u8d44\u8bc4\u7ea7\uff0c\u8ba4\u4e3a\u7279\u65af\u62c9\u7684Optimus\u4eba\u5f62\u673a\u5668\u4eba\uff0c\u548c\u4eba\u5de5\u667a\u80fd(AI)\u6280\u672f\u5305\u62ecDojo\u8d85\u7ea7\u7535\u8111\u548c\u81ea\u4e3b\u7cfb\u7edf\uff0c\u5bf9\u957f\u671f\u4e1a\u52a1\u6709\u4e50\u89c2\u7684\u6f5c\u5728\u5f71\u54cd\u3002\u5fae\u8f6f\u548c\u4e9a\u9a6c\u900a\u5206\u522b\u6500\u53471.2%\u548c1.1%\u3002\u4e9a\u592a\u80a1\u5e02\u4eca\u65e9(6\u65e5)\u4e2a\u522b\u8d70\uff0c\u65e5\u7ecf225\u6307\u6570\u73b0\u65f6\u62a539136\u70b9\uff0c\u8dcc259\u70b9\u62160.66%\u3002\u97e9\u56fd\u7efc\u5408\u6307\u6570\u73b0\u65f6\u62a52433\u70b9\uff0c\u8dcc8\u70b9\u62160.33%\u3002\u8054\u50a8\u5c40\u51cf\u6162\u51cf\u606f\u6b65\u4f10\uff0c\u62d6\u7d2f\u6e2f\u80a1\u6c14\u6c1b\u3002<br/><br/>\u5e02\u573a\u7126\u70b9\uff1a\u4e2d\u56fd\u7535\u4fe1(00728)<br/><br/>11\u670815\u65e5\uff0c\u4e2d\u8bc1\u76d1\u53d1\u5e03\u5e02\u503c\u7ba1\u7406\u65b0\u6307\u5f15\uff0c\u8981\u6c42\u4e0a\u5e02\u516c\u53f8\u4ee5\u63d0\u9ad8\u516c\u53f8\u54c1\u8d28\u4e3a\u57fa\u7840\uff0c\u63d0\u5347\u7ecf\u8425\u6548\u7387\u548c\u76c8\u5229\u80fd\u529b\u7b49\uff0c\u63a8\u52a8\u4e0a\u5e02\u516c\u53f8\u6295\u8d44\u4ef7\u503c\u5408\u7406\u53cd\u6620\u4e0a\u5e02\u516c\u53f8\u8d28\u91cf\u3002\u6b64\u5916\uff0c\u4e0b\u5468\u4e09(11\u65e5)\u5c06\u53ec\u5f00\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\uff0c\u5e02\u573a\u9884\u671f\u4e2d\u592e\u5c06\u6709\u66f4\u591a\u523a\u6fc0\u7ecf\u6d4e\u653f\u7b56\u51fa\u53f0\uff0c\u201c\u4e2d\u7279\u4f30\u201d\u6982\u5ff5\u80a1\u8d70\u52bf\u5f3a\u52b2\uff0c\u53ef\u7279\u522b\u7559\u610f\u4e2d\u8d44\u7535\u8baf\u80a1\u3002\u636e\u5de5\u4fe1\u90e8\u6570\u636e\uff0c\u622a\u81f310\u6708\u5e95\uff0c\u5185\u57305G\u57fa\u7ad9\u603b\u6570\u8fbe\u5230414.1\u4e07\u4e2a\uff0c\u5168\u56fd\u4e92\u8054\u7f51\u5bbd\u5e26\u63a5\u5165\u7aef\u53e3\u6570\u91cf\u8fbe\u523012\u4ebf\u4e2a\u3002\u4e92\u8054\u7f51\u5bbd\u5e26\u63a5\u5165\u7528\u6237\u603b\u6570\u8fbe\u52306.68\u4ebf\u6237\uff0c\u5176\u4e2d\u5343\u5146\u7528\u6237\u5360\u6bd4\u8d85\u8fc7\u4e09\u6210\uff0c5G\u79fb\u52a8\u7535\u8bdd\u7528\u6237\u8fbe\u52309.95\u4ebf\u6237\u3002\u770b\u597d\u4e2d\u56fd\u7535\u4fe1\u30022024\u5e7410\u6708\uff0c\u4e2d\u7535\u4fe1\u79fb\u52a8\u7528\u6237\u603b\u6570\u4e3a4.23\u4ebf\u6237\uff0c\u5f53\u6708\u51c0\u589e76\u4e07\u6237\uff0c\u5e74\u5ea6\u7d2f\u8ba1\u51c0\u589e1566\u4e07\u6237\u3002\u5176\u4e2d\uff0c5G\u5957\u9910\u7528\u6237\u6570\u8fbe\u52303.48\u4ebf\u6237\uff0c\u5f53\u6708\u51c0\u589e247\u4e07\u6237\uff0c\u5e74\u5ea6\u7d2f\u8ba1\u51c0\u589e2887\u4e07\u6237\uff0c5G\u5957\u9910\u7528\u6237\u6e17\u900f\u738782.3%\u3002\u96c6\u56e2\u4e00\u76f4\u52a0\u5f3a\u6570\u5b57\u5316\u4e1a\u52a1\u7684\u6295\u8d44\u53ca\u957f\u671f\u53d1\u5c55\u6f5c\u529b\uff0c\u518d\u52a0\u4e0a\u6709\u6e05\u6670\u7684\u6d3e\u606f\u7387\u76ee\u6807\uff0c\u5177\u6709\u7a33\u5b9a\u7684\u4e1a\u52a1\u53ca\u76c8\u5229\u589e\u957f\u7ec4\u5408\uff0c\u503c\u5f97\u957f\u7ebf\u6301\u6709\u3002\u76ee\u6807\u4ef7$6\uff0c\u6b62\u8680\u4ef7$3.9\u3002<br/><br/>(\u7b14\u8005\u4e3a\u8bc1\u76d1\u4f1a\u6301\u724c\u4eba\u58eb\u53ca\u7b14\u8005\u672a\u6301\u6709\u4e0a\u8ff0\u80a1\u4efd)</p><p>\u4f5c\u8005\uff1b\u9999\u6e2f\u80a1\u7968\u5206\u6790\u5e08\u534f\u4f1a\u4e3b\u5e2d\u9093\u58f0\u5174\u535a\u58eb</p>", "link": "https://sky.szfiu.com/info/hk/details/259774058", "pub_date": "2024-12-06 09:35:18"}, {"id": 259773574, "title": "\u3010\u65b0\u80a1IPO\u3011\u91cd\u5851\u80fd\u6e90(02570)\u9996\u6302\u5f00\u62a5148.9\u6e2f\u5143 \u8f83\u62db\u80a1\u4ef7\u9ad81.29%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u91cd\u5851\u80fd\u6e90(02570)\u9996\u6302\u5f00\u62a5148.9\u6e2f\u5143\uff0c\u8f83\u62db\u80a1\u4ef7\u9ad81.29%\uff0c\u76d8\u524d\u6210\u4ea4\u989d1475.33\u4e07\u6e2f\u5143\uff0c\u4e0d\u8ba1\u624b\u7eed\u8d39\uff0c\u6bcf\u624b20\u80a1\uff0c\u8d26\u9762\u8d5a38\u6e2f\u5143\u3002</p><p>\u6839\u636e\u62db\u80a1\u7ed3\u679c\u663e\u793a\uff0c\u6700\u7ec8\u53d1\u552e\u4ef7\u5b9a\u4e3a\u6bcf\u80a1147\u6e2f\u5143\uff0c\u96c6\u8d44\u603b\u989d7.097\u4ebf\u6e2f\u5143\uff0c\u51c0\u989d\u7ea66.29\u4ebf\u6e2f\u5143\u3002\u4e00\u624b\u4e2d\u7b7e\u738756.81%\uff0c\u8ba4\u8d2d2\u53ef\u7a33\u83b7\u4e00\u624b\u3002\u80a1\u4efd\u4e8e\u516c\u5f00\u53d1\u552e\u90e8\u4efd\u8ba4\u8d2d\u989d1.55\u500d\uff1b\u56fd\u9645\u53d1\u552e\u8ba4\u8d2d\u989d1.33\u500d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259773574", "pub_date": "2024-12-06 09:28:28"}]}