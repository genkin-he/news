b63\u5728\u8be2\u95ee\u82f1\u4f1f\u8fbe\u7684\u5ba2\u6237\uff0c\u4ed6\u4eec\u5728\u8d2d\u4e70\u8be5\u516c\u53f8\u56fe\u5f62\u5904\u7406\u5668(GPU)\u8f6f\u4ef6\u4ea7\u54c1\u548c\u786c\u4ef6\u65f6\u662f\u5426\u83b7\u5f97\u4e86\u6298\u6263\u3002\u76d1\u7763\u673a\u6784\u91cd\u70b9\u8c03\u67e5\u4e86\u53ef\u80fd\u52a0\u5f3a\u82f1\u4f1f\u8fbe\u5bf9\u56fe\u5f62\u5904\u7406\u5668\u63a7\u5236\u7684\u6f5c\u5728\u505a\u6cd5\uff0c\u56e0\u4e3a\u82f1\u4f1f\u8fbe\u5728\u56fe\u5f62\u5904\u7406\u5668\u9886\u57df\u51e0\u4e4e\u5904\u4e8e\u5784\u65ad\u5730\u4f4d\uff0c\u5e02\u573a\u4efd\u989d\u9ad8\u8fbe84%\uff0c\u8fdc\u8fdc\u8d85\u8fc7\u7ade\u4e89\u5bf9\u624b\u82f1\u7279\u5c14\u548cAMD\u3002\u6b27\u76df\u59d4\u5458\u4f1a\u6b64\u524d\u66fe\u8b66\u544a\u79f0\uff0c\u8be5\u4ea4\u6613\u5a01\u80c1\u5230\u4e24\u5bb6\u516c\u53f8\u6240\u5728\u5e02\u573a\u7684\u7ade\u4e89\uff0c\u5e76\u5df2\u5c06\u521d\u6b65\u5ba1\u67e5\u7684\u622a\u6b62\u65e5\u671f\u5b9a\u572812\u670820\u65e5\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259589005", "pub_date": "2024-12-04 22:11:49"}, {"id": 259585554, "title": "\u793c\u6765(LLY)\u76d8\u524d\u6da8\u8d851% \u65d7\u4e0b\u51cf\u80a5\u836fZepbound\u5728\u5bf9\u6bd4\u8bd5\u9a8c\u4e2d\u4f18\u4e8e\u8bfa\u548c\u8bfa\u5fb7(NVO)\u7684Wegovy", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u793c\u6765(LLY)\u76d8\u524d\u6da8\u8d851%\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a5826.83\u7f8e\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u793c\u6765\u8868\u793a\uff0c\u5176\u51cf\u80a5\u836fZepbound\u5728\u9996\u6b21\u5934\u5bf9\u5934\u8bd5\u9a8c(head-to-head trial)\u4e2d\u8868\u73b0\u4f18\u4e8e\u7ade\u4e89\u5bf9\u624b\u8bfa\u548c\u8bfa\u5fb7(NVO)\u7684Wegovy\u3002\u5728\u793c\u6765\u8d5e\u52a9\u7684\u4e00\u9879\u7814\u7a76\u4e2d\uff0c\u63a5\u53d7Zepbound\u6cbb\u7597\u7684\u4eba\u572872\u5468\u5185\u5e73\u5747\u51cf\u6389\u4e86\u4f53\u91cd\u768420%\uff0c\u7ea650\u78c5\uff0c\u800c\u63a5\u53d7Wegovy\u6cbb\u7597\u7684\u4eba\u53ea\u51cf\u6389\u4e8614%\u3002\u8be5\u7ed3\u679c\u8bc1\u5b9e\u4e86\u4e4b\u524d\u8bd5\u9a8c\u6240\u663e\u793a\u7684\u8868\u660eZepbound\u5177\u6709\u66f4\u5f3a\u6548\u679c\u7684\u7ed3\u8bba\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/259585554", "pub_date": "2024-12-04 21:54:30"}]}