服务</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">1.1</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">京东健康</span><span style=\"display: inline-block; vertical-align:middle;\">(06618)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">33.65（-2%）</td></tr><tr><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">工业机械与设备</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">1.1</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">中国重汽</span><span style=\"display: inline-block; vertical-align:middle;\">(03808)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">22.55（-0.4%）</td></tr><tr><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">建筑</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">1</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">中国建筑国际</span><span style=\"display: inline-block; vertical-align:middle;\">(03311)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">12.88（-1.2%）</td></tr></table></div>",
