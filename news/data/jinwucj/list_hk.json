8e\u5378\u4efb \u79bb\u804c\u540e\u5c06\u56de\u5f52\u767e\u4e8b\u516c\u53f8", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u77e5\u540d\u5de7\u514b\u529b\u5236\u9020\u5546\u597d\u65f6(HSY)\u8fd1\u65e5\u5ba3\u5e03\uff0c\u5176\u7f8e\u56fd\u7cd6\u679c\u4e1a\u52a1\u7684\u8d1f\u8d23\u4ebaMichael Del Pozzo\u5c06\u4e8e2024\u5e7412\u670812\u65e5\u6b63\u5f0f\u5378\u4efb\u3002</p><p>\u5728\u6b64\u671f\u95f4\uff0c\u597d\u65f6\u516c\u53f8\u603b\u88c1\u517cCEO Michele Buck\u5c06\u4e34\u65f6\u63a5\u7ba1\u7f8e\u56fd\u7cd6\u679c\u4e1a\u52a1\u7684\u9886\u5bfc\u5de5\u4f5c\uff0c\u516c\u53f8\u4e5f\u5df2\u542f\u52a8\u5bfb\u627eDel Pozzo\u7ee7\u4efb\u8005\u7684\u7a0b\u5e8f\uff0c\u8003\u8651\u7684\u4eba\u9009\u65e2\u5305\u62ec\u516c\u53f8\u5185\u90e8\u6210\u5458\uff0c\u4e5f\u5305\u62ec\u5916\u90e8\u5019\u9009\u4eba\u3002</p><p>Del Pozzo\u79bb\u804c\u540e\u5c06\u56de\u5f52\u767e\u4e8b\u516c\u53f8\uff0c\u5e76\u62c5\u4efb\u65b0\u7684\u9ad8\u7ba1\u804c\u4f4d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260198261", "pub_date": "2024-12-10 22:22:04"}, {"id": 260193581, "title": "\u53d7\u539f\u6750\u6599\u4ef7\u683c\u4e0a\u6da8\u548c\u7f8e\u5143\u8d70\u5f3a\u5f71\u54cd \u6c7d\u8f66\u96f6\u90e8\u4ef6\u96f6\u552e\u5546AutoZone(AZO)\u7b2c\u4e00\u5b63\u5ea6\u5229\u6da6\u548c\u6536\u5165\u4e0d\u53ca\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u53d7\u539f\u6750\u6599\u4ef7\u683c\u4e0a\u6da8\u548c\u7f8e\u5143\u8d70\u5f3a\u7684\u5f71\u54cd\uff0c\u6c7d\u8f66\u96f6\u90e8\u4ef6\u96f6\u552e\u5546AutoZone(AZO)\u5468\u4e8c\u516c\u5e03\u7684\u7b2c\u4e00\u5b63\u5ea6\u5229\u6da6\u548c\u6536\u5165\u4e0d\u53ca\u9884\u671f\u3002<br/><br/>\u5728\u65b0\u8f66\u5e02\u573a\u4ef7\u683c\u6602\u8d35\u7684\u60c5\u51b5\u4e0b\uff0c\u6d88\u8d39\u8005\u8d2d\u4e70\u66f4\u591a\u6c7d\u8f66\u96f6\u90e8\u4ef6\u4ee5\u7ef4\u6301\u8001\u65e7\u6c7d\u8f66\u7684\u6b63\u5e38\u884c\u9a76\uff0c\u7531\u6b64\u5e26\u6765\u7684 DIY \u6c7d\u8f66\u96f6\u90e8\u4ef6\u9700\u6c42\u63a8\u52a8\u4e86\u6c7d\u8f66\u96f6\u90e8\u4ef6\u96f6\u552e\u5546\u7684\u5229\u6da6\u589e\u957f\u3002\u5c3d\u7ba1\u5982\u6b64\uff0c\u539f\u6750\u6599\u4ef7\u683c\u4e0a\u6da8\u5df2\u7ecf\u5f71\u54cd\u4e86\u5305\u62ec\u6c7d\u8f66\u96f6\u90e8\u4ef6\u5728\u5185\u7684\u4e00\u7cfb\u5217\u4ea7\u54c1\u7684\u4ef7\u683c\u3002\u6b64\u5916\uff0c\u7f8e\u56fd\u5f53\u9009\u603b\u7edf\u5510\u7eb3\u5fb7\u00b7\u7279\u6717\u666e\u63d0\u51fa\u63d0\u9ad8\u8fdb\u53e3\u5173\u7a0e\u7684\u5a01\u80c1\u4e5f\u53ef\u80fd\u635f\u5bb3\u6c7d\u8f66\u96f6\u90e8\u4ef6\u7684\u4ef7\u683c\u3002<br/><br/>AutoZone \u9996\u5e2d\u6267\u884c\u5b98\u83f2\u5229\u666e\u00b7\u4e39\u5c3c\u5c14 (Philip Daniele) \u5728 9 \u6708\u4efd\u66fe\u8868\u793a\uff1a\u201c\u5982\u679c\u6211\u4eec\u5f81\u6536\u5173\u7a0e\uff0c\u6211\u4eec\u4f1a\u628a\u8fd9\u4e9b\u5173\u7a0e\u6210\u672c\u8f6c\u5ac1\u7ed9\u6d88\u8d39\u8005\u3002\u201d</p>", "link": "https://sky.szfiu.com/info/hk/details/260193581", "pub_date": "2024-12-10 21:58:09"}, {"id": 260191448, "title": "\u7f8e\u56fd\u7b2c\u4e09\u5b63\u5ea6\u975e\u519c\u751f\u4ea7\u529b\u7ec8\u503c\u7ef4\u63012.2% \u7b26\u5408\u9884\u671f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u7b2c\u4e09\u5b63\u5ea6\u975e\u519c\u751f\u4ea7\u529b\u7ec8\u503c\u5f55\u5f972.2%\uff0c\u524d\u503c2.2%\uff0c\u9884\u671f2.2%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260191448", "pub_date": "2024-12-10 21:47:59"}, {"id": 260191641, "title": "\u7f8e\u56fd\u7b2c\u4e09\u5b63\u5ea6\u975e\u519c\u5355\u4f4d\u52b3\u52a8\u529b\u6210\u672c\u7ec8\u503c\u4e3a0.8% \u524d\u503c1.9%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7f8e\u56fd\u7b2c\u4e09\u5b63\u5ea6\u975e\u519c\u5355\u4f4d\u52b3\u52a8\u529b\u6210\u672c\u7ec8\u503c\u4e3a0.8%\uff0c\u524d\u503c1.90%\uff0c\u9884\u671f1.5%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260191641", "pub_date": "2024-12-10 21:48:41"}, {"id": 260189528, "title": "\u673a\u6784\uff1a\u7f8e\u56fd\u5173\u7a0e\u4e0e\u79fb\u6c11\u653f\u7b56\u53ef\u80fd\u589e\u52a0\u6210\u672c \u5c0f\u4f01\u4e1a\u7684\u60c5\u7eea\u53ef\u80fd\u4f1a\u8fc5\u901f\u6076\u5316", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e07\u795e\u6bbf\u5b8f\u89c2\u7ecf\u6d4e\u7684\u5206\u6790\u5e08Samuel Tombs\u6307\u51fa\uff0c\u7f8e\u56fd\u5c0f\u578b\u5bb6\u5ead\u4f01\u4e1a\u666e\u904d\u652f\u6301\u7279\u6717\u666e\uff0c\u4f46\u5982\u679c\u4ed6\u7684\u7ecf\u6d4e\u548c\u793e\u4f1a\u653f\u7b56\u6700\u7ec8\u5bf9\u4ed6\u4eec\u7684\u8d22\u52a1\u72b6\u51b5\u4ea7\u751f\u8d1f\u9762\u5f71\u54cd\uff0c\u4ed6\u4eec\u7684\u6001\u5ea6\u53ef\u80fd\u4f1a\u8fc5\u901f\u8f6c\u53d8\u3002</p><p>\u7f8e\u56fd\u5168\u56fd\u5c0f\u4f01\u4e1a\u8054\u5408\u4f1a\u7684\u6708\u5ea6\u8c03\u67e5\u7ed3\u679c\u663e\u793a\uff0c\u5728\u7279\u6717\u666e\u8d62\u5f97\u603b\u7edf\u9009\u4e3e\u5e76\u627f\u8bfa\u5b9e\u65bd\u66f4\u4f18\u60e0\u7684\u7a0e\u6536\u653f\u7b56\u548c\u51cf\u5c11\u7e41\u7410\u7684\u884c\u653f\u7a0b\u5e8f\u540e\uff0c\u5c0f\u4f01\u4e1a\u4e3b\u4eec\u666e\u904d\u611f\u5230\u4e50\u89c2\u3002\u7136\u800c\uff0c\u7279\u6717\u666e\u5728\u7ade\u9009\u671f\u95f4\u627f\u8bfa\u8981\u9a71\u9010\u975e\u6cd5\u79fb\u6c11\u5e76\u63d0\u9ad8\u5bf9\u8fdb\u53e3\u5546\u54c1\u7684\u60e9\u7f5a\u6027\u5173\u7a0e\uff0c\u8fd9\u53ef\u80fd\u4f1a\u5bf9\u5c0f\u4f01\u4e1a\u4ea7\u751f\u6291\u5236\u6548\u679c\u3002Tombs\u5728\u5176\u62a5\u544a\u4e2d\u5411\u5ba2\u6237\u89e3\u91ca\u8bf4\uff1a\u201c\u5982\u679c\u5176\u4ed6\u56fd\u5bb6\u91c7\u53d6\u62a5\u590d\u63aa\u65bd\uff0c\u5173\u7a0e\u548c\u79fb\u6c11\u653f\u7b56\u53ef\u80fd\u4f1a\u589e\u52a0\u5c0f\u4f01\u4e1a\u7684\u6210\u672c\uff0c\u5e76\u5bf9\u5176\u56fd\u9645\u9500\u552e\u9020\u6210\u5f71\u54cd\u3002\u5c0f\u4f01\u4e1a\u7684\u60c5\u7eea\u53ef\u80fd\u4f1a\u8fc5\u901f\u6076\u5316\uff0c\u98ce\u9669\u5f88\u9ad8\u3002\u201d</p>", "link": "https://sky.szfiu.com/info/hk/details/260189528", "pub_date": "2024-12-10 21:37:57"}]}