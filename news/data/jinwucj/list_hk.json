b9\u9762\uff0c\u8be5\u884c\u770b\u597d\u6d59\u6c5f\u9f0e\u529b(603338 CH\uff0c\u4e70\u5165)\uff0c\u56e0\u4e3a\u5176\u6d77\u5916\u9500\u552e\u6bd4\u4f8b\u8f83\u9ad8\uff0c\u4f46\u8be5\u884c\u5efa\u8bae\u5728\u7f8e\u56fd\u603b\u7edf\u5927\u9009\u540e\u624d\u5e03\u5c40\uff0c\u4ee5\u907f\u514d\u5982\u679c\u7531\u7279\u6717\u666e\u80dc\u51fa\u540e\u51fa\u73b0\u5173\u7a0e\u4e0a\u8c03\u7684\u98ce\u9669\u3002\u8be5\u884c\u4ecd\u8ba4\u4e3a\u4e2d\u8054\u91cd\u79d1(01157/ 000157 CH, \u4e70\u5165)\u5b58\u5728\u4e00\u4e9b\u4e0b\u884c\u98ce\u9669\uff0c\u4e3b\u8981\u7531\u4e8e\u56fd\u5185\u8d77\u91cd\u673a\u9700\u6c42\u6076\u5316\u53ef\u80fd\u62b5\u6d88\u6d77\u5916\u589e\u957f\u3002\u8be5\u884c\u5bf9\u4e09\u4e00\u91cd\u5de5(600031 CH\uff0c\u6301\u6709)\u6301\u4fdd\u5b88\u770b\u6cd5\uff0c\u4e3b\u8981\u7531\u4e8e\u5e02\u573a\u5171\u8bc6\u9884\u671f\u4ecd\u7136\u8f83\u9ad8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255042675", "pub_date": "2024-10-17 10:50:15"}, {"id": 255042674, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u6c47\u4e30\u7814\u7a76\u5347\u5eb7\u5e08\u5085\u63a7\u80a1(00322)\u76ee\u6807\u4ef724.5% \u6307\u5176\u6d3e\u606f\u6bd4\u7387\u663e\u7740\u9ad8\u4e8e\u884c\u4e1a\u5e73\u5747\u6c34\u5e73", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6c47\u4e30\u73af\u7403\u7814\u7a76\u53d1\u8a00\u554a\u62a5\u7eb8\uff0c\u81ea2024\u5e748\u6708\u4ee5\u6765\uff0c\u5eb7\u5e08\u5085\u63a7\u80a1(00322)\u80a1\u4ef7\u5df2\u4e0a\u6da831%\uff0c\u8dd1\u8d62\u6052\u751f\u6307\u6570\u548c\u540c\u4e1a\u5e73\u5747\u3002\u8be5\u884c\u8ba4\u4e3a\u662f\u7531\u4e8e\u76c8\u5229\u80fd\u529b\u7684\u63d0\u9ad8\u548c\u6d3e\u606f\u7387100%\uff0c\u5728\u5f53\u524d\u6d88\u8d39\u5e02\u573a\u4e0a\u5f88\u5c11\u89c1\uff0c\u56e0\u6b64\u53d7\u5230\u6295\u8d44\u8005\u7684\u9752\u7750\u3002\u76f8\u4fe1\u5728\u65c5\u6e38\u4eba\u6d41\u91cf\u6301\u7eed\u589e\u957f\u7684\u8d8b\u52bf\u4f46\u4eba\u5747\u6d88\u8d39\u8f83\u4f4e\u4e0b\uff0c\u5eb7\u5e08\u5085\u4ecd\u662f\u4e3b\u8981\u53d7\u76ca\u8005\u4e4b\u4e00\u3002<br/><br/>\u8be5\u884c\u9884\u671f2023-26\u5e74\u516c\u53f8\u7684\u51c0\u5229\u590d\u5408\u5e74\u589e\u957f\u7387\u5c06\u8fbe\u523014.8%\u3002\u8be5\u884c\u5c062025/26\u5e74\u51c0\u5229\u9884\u6d4b\u5206\u522b\u4e0a\u8c030.4%\u53ca6.4%\u3002\u8be5\u884c\u8ba4\u4e3a\uff0c\u5f53\u524d\u7684\u5e02\u573a\u73af\u5883\u6709\u5229\u4e8e\u5eb7\u5e08\u5085\u5e02\u573a\u4efd\u989d\u7684\u7a33\u5b9a\u6062\u590d\uff0c\u56e0\u6b64\u4e0a\u8c032025-26\u5e74\u6ce1\u9762\u548c\u996e\u6599\u4e1a\u52a1\u7684\u6536\u5165\u9884\u6d4b\uff0c\u5e76\u76f8\u5e94\u4e0a\u8c032025-26\u5e74\u6574\u4f53\u6536\u5165\u9884\u6d4b0.4-0.9%\u3002\u7531\u4e8e\u996e\u6599\u4e1a\u52a1\u76c8\u5229\u80fd\u529b\u7684\u89c4\u6a21\u6548\u5e94\u8f83\u597d\uff0c\u56e0\u6b64\u4e0a\u8c032026\u5e74\u7efc\u5408\u6bdb\u5229\u7387\u9884\u6d4b\u3002<br/><br/>\u8be5\u884c\u5c06\u516c\u53f8\u76ee\u6807\u4ef7\u4ece11\u6e2f\u5143\u4e0a\u8c0324.5%\u81f313.7\u6e2f\u5143\uff0c\u5e76\u7ef4\u6301\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0c\u56e0\u4e3a\u8be5\u516c\u53f8\u6d3e\u606f\u6bd4\u7387\u4ecd\u7ef4\u6301100%\uff0c\u5bf9\u5e942025\u5e74\u80a1\u606f\u6536\u76ca\u7387\u4e3a6.7%\uff0c\u663e\u7740\u9ad8\u4e8e\u884c\u4e1a\u5e73\u5747\u6c34\u5e73\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255042674", "pub_date": "2024-10-17 10:50:31"}]}