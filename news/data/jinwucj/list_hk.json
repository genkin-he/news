53f0\uff0c\u4fc3\u4f7f\u4eac\u4e1c\u5065\u5eb7\u836f\u54c1\u9500\u91cf\u4e0a\u5347\u3002\u8be5\u884c\u9884\u8ba1\u4eac\u4e1c\u5065\u5eb7\u7b2c\u4e09\u5b63\u5ea6\u6536\u5165\u540c\u6bd4\u589e\u957f22%\uff0c\u8f83\u7b2c\u4e8c\u5b63\u5ea6\u768414.6%\u589e\u901f\u52a0\u5feb\uff0c\u4e3b\u8981\u5f97\u76ca\u4e8e\u6d88\u8d39\u8005\u4ece\u7ebf\u4e0b\u5411\u7ebf\u4e0a\u8f6c\u79fb\u53ca\u4e0b\u534a\u5e74\u4fc3\u9500\u6d3b\u52a8\u3002</p><p>\u4e0d\u8fc7\uff0c\u8003\u8651\u5230\u6d88\u8d39\u8005\u51cf\u5c11\u5728\u7f8e\u5bb9\u548c\u5176\u4ed6\u975e\u5fc5\u9700\u533b\u7597\u8bbe\u5907\u4e0a\u7684\u652f\u51fa\uff0c\u5efa\u94f6\u56fd\u9645\u4e0b\u8c03\u4e86\u4eac\u4e1c\u5065\u5eb7\u4eca\u5e74\u7684\u9500\u552e\u9884\u6d4b1.8%\uff0c\u5e76\u8c03\u964d\u975e\u56fd\u9645\u8d22\u52a1\u62a5\u544a\u51c6\u5219\u5229\u6da6\u9884\u6d4b11.3%\uff0c\u5f52\u56e0\u4e8e\u836f\u7269\u9500\u552e\u589e\u52a0\u5f71\u54cd\u6bdb\u5229\u7387\u3002\u5efa\u94f6\u56fd\u9645\u5c06\u4eac\u4e1c\u5065\u5eb7\u7684\u76ee\u6807\u4ef7\u4ece37.3\u5143\u4e0b\u8c03\u81f337\u5143\uff0c\u5bf9\u5e941.8\u500d\u9884\u6d4b\u5e02\u9500\u7387\uff0c\u4f4e\u4e8e\u4e09\u5e74\u5e73\u5747\u503c\u7ea6\u4e00\u4e2a\u6807\u51c6\u5dee\uff0c\u5e76\u7ef4\u6301\u201c\u8dd1\u8d62\u5927\u5e02\u201d\u7684\u8bc4\u7ea7\uff0c\u9884\u8ba12025\u5e74\u9884\u6d4b\u5e02\u76c8\u7387\u4e3a19.5\u500d\uff0c\u914d\u5408\u9884\u671f\u6bcf\u80a1\u76c8\u5229\u589e\u957f19.1%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255316393", "pub_date": "2024-10-21 13:46:03"}, {"id": 255316219, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u53cb\u5b9d\u5728\u7ebf(02429)\u8dcc4.57% \u63a5\u83b7\u9488\u5bf9\u516c\u53f8\u4ef2\u88c1 \u7533\u7d221.45\u4ebf\u4eba\u6c11\u5e01", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u53cb\u5b9d\u5728\u7ebf(02429)\u65e9\u76d8\u80a1\u4ef7\u53d7\u538b\u8d70\u4f4e\uff0c\u5348\u540e\u7ef4\u6301\u4f4e\u4f4d\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a59.81\u6e2f\u5143\uff0c\u8dcc4.57%\uff0c\u6210\u4ea4\u989d666.07\u4e07\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u516c\u53f8\u516c\u5e03\uff0c10\u670816\u65e5\uff0c\u6536\u5230\u5e7f\u5dde\u5bcc\u5b8f\u667a\u80fd\u79d1\u6280(\u7533\u8bf7\u4eba)\u5411\u4e2d\u56fd\u56fd\u9645\u7ecf\u6d4e\u8d38\u6613\u4ef2\u88c1\u59d4\u5458\u4f1a\u63d0\u4ea4\u7684\u4ef2\u88c1\u901a\u77e5\u4e66\uff0c\u6d89\u53ca\u6307\u63a7\u516c\u53f8\u9644\u5c5e\u6df1\u5733\u53cb\u5bcc\u7684\u7ba1\u7406\u53ca\u4e8b\u52a1\u800c\u5f15\u8d77\u7684\u82e5\u5e72\u4e89\u8bae\uff0c\u5411\u516c\u53f8\u7533\u7d22\u6743\u76ca\u4ee3\u4ef71.45\u4ebf\u4eba\u6c11\u5e01\u8fde\u8fdd\u7ea6\u5229\u606f\uff1b\u5f8b\u5e08\u8d39\u53ca\u4ef2\u88c1\u6210\u672c\u3002\u516c\u53f8\u73b0\u6b63\u5c31\u4e0a\u8ff0\u4ef2\u88c1\u7a0b\u5e8f\u5bfb\u6c42\u6cd5\u5f8b\u610f\u89c1\u3002\u81f3\u4eca\uff0c\u4ef2\u88c1\u7a0b\u5e8f\u5bf9\u96c6\u56e2\u4e1a\u52a1\u53ca\u4e00\u822c\u8fd0\u8425\u5e76\u65e0\u4ea7\u751f\u91cd\u5927\u4e0d\u5229\u5f71\u54cd\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255316219", "pub_date": "2024-10-21 13:43:05"}, {"id": 255315698, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u56fd\u6cf0\u541b\u5b89\u7ef4\u6301\u53f0\u79ef\u7535(TSM)\u201c\u589e\u6301\u201d\u8bc4\u7ea7 \u63072025\u5e74CoWoS\u4ea7\u80fd\u6709\u671b\u7ee7\u7eed\u7ffb\u500d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u56fd\u6cf0\u541b\u5b89\u8868\u793a\uff0c\u7b2c\u4e09\u5b63\u5ea6\uff0c\u53f0\u79ef\u7535(TSM)\u5b9e\u73b0\u6bdb\u5229\u738757.8%\uff0c\u6309\u5e74\u589e\u957f3.5\u4e2a\u767e\u5206\u70b9\uff0c\u6309\u5b63\u589e\u957f4.6\u4e2a\u767e\u5206\u70b9\uff0c\u8fdc\u9ad8\u4e8e\u5e02\u573a\u4e00\u81f4\u9884\u671f\u768454.8%\u3002\u4e3b\u8981\u539f\u56e0\u662f\u4ea7\u80fd\u5229\u7528\u7387\u63d0\u5347\uff1b\u6307\u5f15\u7b2c\u56db\u5b63\u5ea6\u6bdb\u5229\u7387\u9884\u8ba1\u572857%\u81f359%\u4e4b\u95f4\uff0c\u5927\u5e45\u9ad8\u4e8e\u5e02\u573a\u4e00\u81f4\u9884\u671f\u768454.7%\uff0c\u540e\u7eed\u4ecd\u7136\u6709\u4e0a\u884c\u7a7a\u95f4\u3002AI\u9700\u6c42\u5f97\u5230\u786e\u8ba4\uff0c\u4e14\u6676\u5706\u4ee3\u5de5\u7ade\u4e89\u683c\u5c40\u51fa\u73b0\u8fb9\u9645\u53d8\u5316\uff0c\u53f0\u79ef\u7535\u7684\u7ade\u4e89\u4f18\u52bf\u5f97\u4ee5\u8fdb\u4e00\u6b65\u5f3a\u5316\u30022025\u5e74CoWoS\u4ea7\u80fd\u6709\u671b\u7ee7\u7eed\u7ffb\u500d\uff0c\u6d77\u5916Fab\u8fdb\u5c55\u52a0\u901f\u3002<br/><br/>\u8be5\u884c\u4e0a\u8c03\u53f0\u79ef\u75352024\u5e74\u81f32026\u5e74\u7684\u8425\u4e1a\u6536\u5165\u9884\u6d4b\u81f328,858\u4ebf\u300137,517\u4ebf\u53ca43,758\u4ebf\u65b0\u53f0\u5e01(\u524d\u503c\u4e3a28,198\u4ebf\u300134,970\u4ebf\u53ca40,570\u4ebf\u65b0\u53f0\u5e01)\uff0c\u4e0a\u8c03GAAP\u51c0\u5229\u6da6\u9884\u6d4b\u81f311,844\u4ebf\u300116,757\u4ebf\u53ca19,916\u4ebf\u65b0\u53f0\u5e01(\u524d\u503c\u4e3a11,142\u4ebf\u300114,376\u4ebf\u53ca16,911\u4ebf\u65b0\u53f0\u5e01)\u3002\u5c06\u516c\u53f8\u76ee\u6807\u4ef7\u4e0a\u8c03\u81f3238\u7f8e\u5143\uff0c\u7ef4\u6301\u201c\u589e\u6301\u201d\u8bc4\u7ea7\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255315698", "pub_date": "2024-10-21 13:33:04"}, {"id": 255315649, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5929\u98ce\u8bc1\u5238\u7ef4\u6301\u5929\u7acb\u56fd\u9645\u63a7\u80a1(01773)\u201c\u4e70\u5165\u201d\u8bc4\u7ea7 \u6307\u4f18\u8d28\u6559\u80b2\u5177\u5907\u5e7f\u6cdb\u7684\u9700\u6c42\u5e02\u573a", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5929\u98ce\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u8fd1\u671f\u5929\u7acb\u56fd\u9645\u63a7\u80a1(01773)\uff08\u539f\u516c\u53f8\u540d\uff1a\u5929\u7acb\u6559\u80b2\uff09\u4e0e\u5317\u4eac\u56db\u4e2d\u547c\u548c\u6d69\u7279\u5206\u6821\u7b7e\u8ba2\u9879\u76ee\u5408\u4f5c\u534f\u8bae\u3002\u6b64\u6b21\u7531\u53cc\u65b9\u7684\u5408\u4f5c\u7531\u5b66\u6821\u8d1f\u8d23\u51c6\u5907\u4e00\u5957\u5e08\u8d44\uff0c\u5e38\u6001\u6559\u5b66\u7ba1\u7406\u56de\u5f52\u5b66\u6821\u4e3a\u4e3b\u4f53\uff1b\u5929\u7acb\u6559\u80b2\u8d1f\u8d23\u914d\u5907\u96c6\u56e2\u9996\u5e2d\u3001\u5929\u7acb\u540d\u5e08\u3001\u5fc3\u7406\u54a8\u8be2\u5e08\u3001\u8d4b\u80fd\u6559\u7ec3\u3001\u8fd0\u8425\u4eba\u5458\u4ee5\u53ca\u76f8\u5173\u8f6f\u786c\u4ef6\u8fdb\u884c\u8d4b\u80fd\uff0c\u8d1f\u8d23\u7ed3\u679c\u4ea4\u4ed8\uff1b\u540c\u65f6\u5efa\u7acb\u53cc\u65b9\u9886\u5bfc\u5b9a\u671f\u4f1a\u6664\u5236\u5ea6\u548c\u5de5\u4f5c\u4eba\u5458\u5b9a\u671f\u8054\u5e2d\u4f1a\u8bae\u5236\u5ea6\uff0c\u63a8\u52a8\u5408\u4f5c\u5173\u7cfb\u4e0d\u65ad\u53d1\u5c55\u548c\u6df1\u5316\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u516c\u53f8\u65d7\u4e0b\u542f\u9e23\u516c\u53f8\u63a8\u51fa\u7684\u201cAI\u201d\u667a\u4e60\u5ba4\u89e3\u51b3\u516d\u5927\u95ee\u9898\uff1a\uff081\uff09\u5e2e\u52a9\u5b66\u751f\u7cbe\u51c6\u63d0\u5206\uff0c\u79d1\u5b66\u8bad\u7ec3\u63d0\u5347\u6210\u7ee9\u3002\uff082\uff09\u89e3\u51b3\u5b66\u751f\u8bfe\u540e\u4e2a\u6027\u5316\u8865\u5f31\u7684\u5b66\u4e60\u9700\u6c42\u3002\uff083\uff09\u5e2e\u52a9\u5b66\u751f\u5feb\u901f\u7b5b\u9009\u5b66\u4e60\u8d44\u6e90\uff0c\u8282\u7701\u65f6\u95f4\u3002\uff084\uff09\u89e3\u51b3\u5b66\u751f\u8bfe\u540e\u5c11\u601d\u8003\u3001\u5c11\u8bad\u7ec3\u7684\u95ee\u9898\u3002\uff085\uff09\u5e2e\u52a9\u5b66\u751f\u6811\u7acb\u5b66\u4e60\u76ee\u6807\uff0c\u6784\u5efa\u4e2a\u6027\u5316\u5b66\u4e60\u8def\u5f84\u3002\uff086\uff09\u5e2e\u52a9\u5b66\u751f\u5efa\u7acb\u5b66\u4e60\u4fe1\u5fc3\uff0c\u589e\u5f3a\u5b66\u4e1a\u6210\u5c31\u611f\u3002<br/><br/>\u8be5\u884c\u8ba4\u4e3a\uff0c\u672c\u6b21\u4e0e\u5317\u4eac\u56db\u4e2d\u547c\u548c\u6d69\u7279\u5206\u6821\u7684\u5408\u4f5c\u4ee5\u53caAI\u667a\u4e60\u5ba4\u7684\u63a8\u51fa\uff0c\u5747\u8f83\u597d\u4f53\u73b0\u51fa\u529e\u5b66\u6c89\u6dc0\u4ee5\u53ca\u8f93\u51fa\u80fd\u529b\uff1b\u4f18\u8d28\u6559\u80b2\u5177\u5907\u5e7f\u6cdb\u7684\u9700\u6c42\u5e02\u573a\uff0c\u5305\u62ec\u516c\u529e\u9662\u6821\u4ee5\u53ca\u8bfe\u540e\u670d\u52a1\uff1b\u5929\u7acb\u7684\u4f18\u8d28\u6559\u80b2\u8d44\u6e90\u6709\u671b\u83b7\u5f97\u66f4\u591a\u5b66\u6821\u53ca\u5bb6\u957f\u7684\u8ba4\u53ef\u3002<br/><br/>\u8be5\u884c\u7ef4\u6301\u516c\u53f8\u76c8\u5229\u9884\u6d4b\uff0c\u7ef4\u6301\u201c\u