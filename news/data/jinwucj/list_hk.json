er: 1px solid#999; padding: 7px 0;\">92.8\uff083.5%\uff09</td></tr></table></div>", "link": "https://sky.szfiu.com/info/hk/details/259783867", "pub_date": "2024-12-06 11:30:05"}, {"id": 259784019, "title": "\u6e2f\u5143\u62c6\u606f\u591a\u6570\u4e0b\u8dcc 1\u4e2a\u6708\u62c6\u606f\u8dcc\u81f34.31042\u5398", "description": "<p>\u91d1\u543e\u8d22\u8baf | 2024\u5e7412\u67086\u65e5\uff0c\u6e2f\u5143\u62c6\u606f\u591a\u6570\u4e0b\u8dcc\uff0c\u9694\u591c\u62c6\u606f\u5347\u81f33.70000\u5398\uff1b1\u661f\u671f\u62c6\u606f\u8dcc\u81f33.89071\u5398\uff1b2\u661f\u671f\u62c6\u606f\u8dcc\u81f33.96417\u5398\u3002<br/><br/>\u53e6\u5916\uff0c\u4e0e\u697c\u6309\u76f8\u5173\u76841\u4e2a\u6708\u62c6\u606f\u8dcc\u81f34.31042\u5398\uff1b\u53cd\u6620\u94f6\u884c\u8d44\u91d1\u6210\u672c\u76843\u4e2a\u6708\u62c6\u606f\u8dcc\u81f34.32893\u5398\u3002<br/><br/>\u957f\u606f\u65b9\u9762\uff0c6\u4e2a\u6708\u62c6\u606f\u8dcc\u81f34.12637\u5398\uff1b1\u5e74\u671f\u62c6\u606f\u7ef4\u63014.10000\u5398\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259784019", "pub_date": "2024-12-06 11:32:30"}, {"id": 259784018, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u9ea6\u683c\u7406\u9884\u8ba12025\u5e74\u5168\u7403\u77f3\u6cb9\u5e02\u573a\u4ecd\u5c06\u9762\u4e34\u8d85\u8fc7100\u4e07\u6876/\u5929\u7684\u4f9b\u5e94\u8fc7\u5269", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9ea6\u683c\u7406\u8868\u793a\uff0c\u5373\u4fbf\u6c99\u7279\u963f\u62c9\u4f2f\u5b9e\u65bd\u4ea7\u91cf\u9650\u5236\u63aa\u65bd\uff0c\u9884\u8ba12025\u5e74\u5168\u7403\u77f3\u6cb9\u5e02\u573a\u4ecd\u5c06\u9762\u4e34\u8d85\u8fc7100\u4e07\u6876/\u5929\u7684\u4f9b\u5e94\u8fc7\u5269\u3002\u8fd9\u79cd\u8fc7\u5269\u9884\u671f\u4e3b\u8981\u57fa\u4e8e\u975e\u6b27\u4f69\u514b\uff08OPEC\uff09\u56fd\u5bb6\u7684\u77f3\u6cb9\u4f9b\u5e94\u589e\u957f\u9884\u8ba1\u5c06\u80fd\u591f\u6ee1\u8db3\u9700\u6c42\u7684\u589e\u957f\uff0c\u800c\u540e\u8005\u4f4e\u4e8e\u957f\u671f\u8d8b\u52bf\u6c34\u5e73\u3002\u8fd9\u5c06\u51cf\u5c11\u5bf9\u6b27\u4f69\u514b\u6210\u5458\u56fd\u77f3\u6cb9\u7684\u9700\u6c42\uff0c\u5e76\u964d\u4f4e\u6b27\u4f69\u514b+\u8054\u76df\u9006\u8f6c\u5176\u81ea\u613f\u51cf\u4ea7\u51b3\u5b9a\u7684\u53ef\u80fd\u6027\u3002</p><p>\u62a5\u544a\u8fd8\u6307\u51fa\uff0c\u7531\u4e8e\u4f9b\u5e94\u8fc7\u5269\u7684\u98ce\u9669\u589e\u52a0\uff0c\u7f8e\u56fd\u53ef\u80fd\u52a0\u5f3a\u5bf9\u4f0a\u6717\u548c\u59d4\u5185\u745e\u62c9\u8fd9\u4e24\u4e2a\u53d7\u5236\u88c1\u56fd\u5bb6\u7684\u77f3\u6cb9\u884c\u4e1a\u7684\u538b\u529b\uff0c\u4ee5\u8fdb\u4e00\u6b65\u5f71\u54cd\u5168\u7403\u77f3\u6cb9\u5e02\u573a\u7684\u52a8\u6001\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259784018", "pub_date": "2024-12-06 11:32:44"}, {"id": 259783039, "title": "xAI\u5b8c\u6210\u65b0\u4e00\u8f6e\u878d\u8d44 \u7b79\u5f9760\u4ebf\u7f8e\u5143\u8d44\u91d1", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5168\u7403\u9996\u5bcc\u9a6c\u65af\u514b\u652f\u6301\u7684\u4eba\u5de5\u667a\u80fd(AI)\u521d\u521b\u516c\u53f8xAI\u5b8c\u6210\u65b0\u4e00\u8f6e\u878d\u8d44\uff0c\u7b79\u5f9760\u4ebf\u7f8e\u5143\u8d44\u91d1\u3002xAI\u672a\u6709\u63d0\u53ca\u672c\u8f6e\u878d\u8d44\u7684\u4f01\u4e1a\u4f30\u503c\u3002\u7f8e\u56fd\u5a92\u4f53CNBC\u4e0a\u6708\u62a5\u9053\uff0cxAI\u7684\u878d\u8d44\u884c\u52a8\u662f\u4ee5\u4f01\u4e1a\u4f30\u503c\u903e500\u4ebf\u7f8e\u5143\u4e3a\u57fa\u51c6\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259783039", "pub_date": "2024-12-06 11:22:36"}, {"id": 259783038, "title": "\u636e\u62a5\u7279\u65af\u62c9(TSLA)\u65e0\u4eba\u9a7e\u9a76\u51fa\u79df\u8f66Cybercab\u8f66\u8eab\u7ed3\u6784\u7ec4\u4ef6\u6570\u91cf\u6bd4ModelY\u51cf\u5c1160%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7279\u65af\u62c9(TSLA)\u7684\u65e0\u4eba\u9a7e\u9a76\u51fa\u79df\u8f66Cybercab\u6700\u65b0\u8bbe\u8ba1\u7ec6\u8282\u66dd\u5149\uff0c\u5c55\u793a\u4e86\u5176\u5728\u7ed3\u6784\u4f18\u5316\u4e0a\u7684\u663e\u8457\u8fdb\u6b65\u3002\u636e\u62a5\u9053\uff0cCybercab\u7684\u96f6\u90e8\u4ef6\u6570\u91cf\u5c06\u6bd4Model3\u51cf\u5c11\u7ea650%\uff0c\u8f66\u8eab\u7ed3\u6784\u7ec4\u4ef6\u6570\u91cf\u66f4\u662f\u6bd4ModelY\u51cf\u5c1160%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259783038", "pub_date": "2024-12-06 11:22:54"}, {"id": 259782596, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u6ce1\u6ce1\u739b\u7279(09992)\u5347\u903e3.6% \u82b1\u65d7\u6599\u5176IP\u5546\u4e1a\u5316\u4f1a\u5ef6\u4f38\u81f3\u6d41\u884c\u73a9\u5177\u4ee5\u5916\u9886\u57df", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6ce1\u6ce1\u739b\u7279(09992)\u80a1\u4ef7\u9707\u8361\u626c\u5347\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da83.62%\uff0c\u62a592.95\u6e2f\u5143\uff0c\u6210\u4ea4\u989d2.4\u4ebf\u6e2f\u5143\uff0c<br/><br/>\u82b1\u65d7\u53d1\u7814\u6307\uff0c\u6ce1\u6ce1\u739b\u7279\u662f\u4e2d\u56fd\u6700\u5927\u7684\u6d41\u884c\u73a9\u5177\u516c\u53f8\uff0c\u62e5\u6709\u5f3a\u5927\u7684IP\u5b75\u5316\u548c\u53d8\u73b0\u80fd\u529b\uff0c\u4ee5\u53ca\u4e0d\u65ad\u589e\u957f\u7684\u5168\u7403\u8db3\u8ff9\u548c\u77e5\u540d\u5ea6\u3002\u51ed\u501f\u5176\u591a\u5143\u5316\u7684IP\u89d2\u8272\u548c\u5185\u5bb9\u9a71\u52a8\u7684\u5e02\u573a\u7b56\u7565\uff0c\u516c\u53f8\u770b\u6765\u5df2\u51c6\u5907\u597d\u6355\u6349\u5e74\u8f7b\u6d88\u8d39\u8005\u7684\u65b0\u5174\u201c\u7cbe\u795e\u6d88\u8d39\u201d\u3002\u82b1\u65d7\u8ba4\u4e3a\uff0c\u6ce1\u6ce1\u739b\u7279\u7684IP\u5546\u4e1a\u5316\u5e94\u8be5\u4f1a\u5ef6\u4f38\u81f3\u6d41\u884c\u73a9\u5177\u4ee5\u5916\u7684\u9886\u57df\u3002\u6d41\u884c\u73a9\u5177\u662f\u6d88\u8d39\u8005\u8d1f\u62c5\u5f97\u8d77\u7684\u5a31\u4e50\u9009\u62e9\uff0c\u4ea6\u662f\u8be5\u884c\u6700\u770b\u597d\u7684\u6d88\u8d39\u54c1\u7c7b\u522b\u4e4b\u4e00\u3002<br/><br/>\u8be5\u884c\u9996\u6b21\u8986\u76d6\uff0c\u7ed9\u4e88\u201c\u4e70\u5165\u201d\u8bc4\u7ea7\uff0c\u76ee\u6807\u4ef7105\u5143\uff0c\u76f8\u5f53\u4e8e\u9884\u6d4b\u660e\u5e74\u5e02\u76c8\u738735\u500d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259782596", "pub_date": "2024-12-06 11:18:31"}, {"id": 259782595, "title": "\u673a\u6784\uff1a2024\u5e74\u5168\u7403\u667a\u80fd\u624b\u673a\u51fa\u8d27\u91cf\u9884\u8ba1\u4e3a12.2\u4ebf\u53f0 \u6309\u5e74\u53476%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u5e02\u573a\u8c03\u7814\u673a\u6784Canalys\u62a5\u544a\u663e\u793a\uff0c2024\u5e74\u5168\u7403\u667a\u80fd\u624b\u673a\u51fa\u8d27\u91cf\u9884\u8ba1\u4e3a12.2\u4ebf\u53f0\uff0c\u540c\u6bd4\u4e0a\u53476%\u3002\u957f\u671f\u6765\u770b\uff0c\u667a\u80fd\u624b\u673a\u5e02\u573a\u7684\u589e\u957f\u5c06\u4ece2025\u5e74\u5f00\u59cb\u6b65\u5165\u5e73\u53f0\u671f\uff0c2024\u5e74\u81f32028\u5e74\u7684\u5e74\u590d\u5408\u589e\u957f\u7387\u8fdb\u4e00\u6b65\u4e0b\u8c03\u81f31%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259782595", "pub_date": "2024-12-06 11:18:49"}, {"id": 259782594, "title": "\u9694\u591cshibor\u62a51.4780% \u4e0b\u8dcc0.1\u4e2a\u57fa\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf | 2024\u5e7412\u67086\u65e5\uff0c\u9694\u591cshibor\u62a51.4780%\uff0c\u4e0b\u8dcc0.1\u4e2a\u57fa\u70b9\uff1b7\u5929shibor\u62a51.6860%\uff0c\u4e0b\u8dcc0.2\u4e2a\u57fa\u70b9\uff0c14\u5929shibor\u62a51.8010%\uff0c\u4e0a\u6da80.2\u57fa\u70b9\uff1b1\u6708shibor\u62a51.7110%\uff0c\u4e0e\u6b64\u524d\u6301\u5e73\uff1b3\u4e2a\u6708shibor\u62a51.7550%\uff0c\u4e0b\u8dcc0.7\u4e2a\u57fa\u70b9\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259782594", "pub_date": "2024-12-06 11:18:52"}, {"id": 259780581, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u836f\u660e\u751f\u7269(02269)\u5347\u903e4% \u5ba3\u5e03\u7231\u5c14\u5170\u5148\u8fdb\u7eff\u8272\u751f\u4ea7\u57fa\u5730\u591a\u9879\u91cd\u8981\u4e1a\u52a1\u8fdb\u5c55", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u836f\u660e\u751f\u7269(02269)\u80a1\u4ef7\u53cd\u590d\u626c\u5347\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da84.38%\uff0c\u62a517.16\u6e2f\u5143\uff0c\u6210\u4ea4\u989d4\u4ebf\u6e2f\u5143\u3002<br/><br/>\u516c\u53f8\u8fd1\u65e5\u5ba3\u5e03\u5176\u4f4d\u4e8e\u7231\u5c14\u5170\u7684\u5148\u8fdb\u7eff\u8272\u751f\u4ea7\u57fa\u5730\u7684\u591a\u9879\u91cd\u8981\u4e1a\u52a1\u8fdb\u5c55\u3002\u516c\u53f8\u751f\u7269\u836f\u539f\u6db2\u751f\u4ea7\u4e03\u5382\uff08MFG7\uff09\u5b8c\u6210\u591a\u627916000\u5347\u89c4\u6a21\u5de5\u827a\u6027\u80fd\u786e\u8ba4\uff08PPQ\uff09\u751f\u4ea7\u3002\u8be5\u57fa\u5730\u76ee\u524d\u5df2\u7ecf\u4ee5100%\u6210\u529f\u7387\u5b8c\u6210\u4e24\u4e2a\u9879\u76ee\u7684PPQ\u751f\u4ea7\uff0c\u5e76\u540c\u65f6\u83b7\u5f97\u7231\u5c14\u5170\u5065\u5eb7\u4ea7\u54c1\u76d1\u7763\u7ba1\u7406\u5c40\uff08HPRA\uff09\u5bf9\u6240\u6709\u4e09\u4e2a\u751f\u7269\u836f\u539f\u6db2\u751f\u4ea7\u5382\u7684GMP\u8ba4\u8bc1\u3002\u8fd9\u4e9b\u91cc\u7a0b\u7891\u4e5f\u51f8\u663e\u4e86\u7231\u5c14\u5170\u57fa\u5730\u5728\u836f\u660e\u751f\u7269\u5168\u7403\u751f\u4ea7\u7f51\u7edc\u4e2d\u63d0\u4f9b\u4e16\u754c\u4e00\u6d41\u7684\u751f\u7269\u5236\u836f\u89e3\u51b3\u65b9\u6848\u7684\u5173\u952e\u4f5c\u7528\u3002<br/><br/>\u901a\u8fc7\u7ec4\u54084\u4e2a4000\u5347\u4e00\u6b21\u6027\u751f\u7269\u53cd\u5e94\u5668\uff0c\u836f\u660e\u751f\u7269\u7231\u5c14\u5170\u57fa\u5730PPQ\u751f\u4ea7\u8fbe\u5230\u5355\u6279\u6b2116000\u5347\u7684\u751f\u4ea7\u89c4\u6a21\uff0c\u8fd9\u4e5f\u662f\u5168\u7403\u4f7f\u7528\u4e00\u6b21\u6027\u751f\u7269\u53cd\u5e94\u5668\u7684\u6700\u5927\u89c4\u6a21\u8865\u6599\u5206\u6279\u7ec6\u80de\u57f9\u517b\u5de5\u827a\u4e4b\u4e00\u3002\u53e6\u5916\uff0c\u5728\u4eca\u5e7410\u6708\uff0c\u836f\u660e\u751f\u7269\u7231\u5c14\u5170\u591a\u4ea7\u54c1\u751f\u4ea7\u57fa\u5730\u987a\u5229\u901a\u8fc7HPRA\u7684\u5168\u9762\u73b0\u573a\u68c0\u67e5\uff0c\u68c0\u67e5\u8303\u56f4\u8986\u76d6\u6570\u636e\u7ba1\u7406\u3001\u5de5\u827a\u63a7\u5236\u3001\u4eba\u5458\u7ba1\u7406\u3001\u751f\u4ea7\u3001\u5b58\u50a8\u53ca\u5206\u6790\u7b49\u5168\u6d41\u7a0b\u7684GMP\u5408\u89c4\u6027\u8981\u6c42\uff0c\u5e76\u83b7\u5f97\u4e86GMP\u8ba4\u8bc1\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259780581", "pub_date": "2024-12-06 10:57:01"}, {"id": 259780675, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u91d1\u8776\u56fd\u9645(00268)\u6da8\u8fd15% \u91ce\u6751\u6599\u4e2d\u56fd\u8f6f\u4ef6\u4e1a\u4ece\u660e\u5e74\u6b21\u5b63\u5f00\u59cb\u590d\u82cf", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u91d1\u8776\u56fd\u9645(00268)\u65e9\u76d8\u53d1\u529b\u8d70\u9ad8\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u62a59.56\u6e2f\u5143\uff0c\u6da84.94%\uff0c\u6210\u4ea4\u989d1.52\u4ebf\u6e2f\u5143\u3002<br/><br/>\u91ce\u6751\u53d1\u7814\u62a5\u8868\u793a\uff0c\u523a\u6fc0\u653f\u7b56\u3001\u672c\u5730\u5316\u548c\u4eba\u5de5\u667a\u80fd\u6295\u8d44\uff0c\u5c06\u652f\u6491\u4e2d\u56fd\u8f6f\u4ef6\u884c\u4e1a\u4ece\u660e\u5e74\u6b21\u5b63\u5f00\u59cb\u590d\u82cf\u3002\u8be5\u884c\u8ba4\u4e3a\uff0c\u7531\u4e8e\u5bf9\u653f\u5e9c\u8d22\u653f\u523a\u6fc0\u7684\u5f3a\u70c8\u60c5\u7eea\uff0c\u4e2d\u56fd\u8f6f\u4ef6\u6307\u6570\u5728\u8fc7\u53bb60\u5929\u5185\u4e0a\u6da876%\uff0c\u6536\u590d2024\u5e74\u7684\u5931\u5730\u3002\u53e6\u5916\uff0c\u8be5\u884c\u8ba4\u4e3a\u5728\u8d44\u8baf\u79d1\u6280\u652f\u51fa\u56de\u5347\u4e4b\u524d\uff0c\u7ecf\u6d4e\u523a\u6fc0\u8ba1\u5212\u8fd8\u9700\u8981\u4e00\u6bb5\u65f6\u95f4\u624d\u80fd\u53d1\u6325\u4f5c\u7528\u3002<br/><br/>\u8003\u8651\u5230\u660e\u5e74\u9996\u5b63\u7684\u5f31\u5b63\u8282\u6027\uff0c\u82e5\u5b8f\u89c2\u7ecf\u6d4e\u51fa\u73b0\u660e\u663e\u7684\u590d\u82cf\u8ff9\u8c61\uff0c\u91ce\u6751\u8ba4\u4e3a\u4e2d\u56fd\u8f6f\u4ef6\u884c\u4e1a\u7684\u57fa\u672c\u9762\u590d\u82cf\u53ef\u80fd\u4f1a\u4ece2025\u5e74\u7b2c2\u5b63\u5f00\u59cb\u52a0\u901f\u3002\u8be5\u884c\u8ba4\u4e3a\uff0c\u56fd\u5185\u66ff\u4ee3\u548c\u4eba\u5de5\u667a\u80fd\u5c06\u6210\u4e3a2025\u5e74\u8be5\u884c\u4e1a\u7684\u4e24\u4e2a\u5173\u952e\u9a71\u52a8\u529b\uff0c\u524d\u8005\u7531\u5916\u90e8\u56e0\u7d20\uff0c\u5373\u5730\u7f18\u653f\u6cbb\u98ce\u9669\u9a71\u52a8\uff0c\u800c\u540e\u8005\u5219\u7531\u5185\u90e8\u56e0\u7d20\u9a71\u52a8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259780675", "pub_date": "2024-12-06 10:58:44"}]}