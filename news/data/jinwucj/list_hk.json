u6307\u51762024\u5e74\u8d77\u5c06\u5168\u9762\u8fdb\u5165\u76c8\u5229\u533a\u95f4", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4ea4\u94f6\u56fd\u9645\u53d1\u7814\u62a5\u6307\uff0c\u91d1\u65af\u745e\u751f\u7269\u79d1\u6280(01548)\u516c\u544a\uff0c\u63a7\u5236\u4f20\u5947\u751f\u7269\u7684\u6295\u7968\u6743\u6bd4\u4f8b\u5c06\u4ece50%\u4ee5\u4e0a\u964d\u81f347.56%\uff0c\u540c\u65f6\u4e27\u5931\u5728\u4f20\u5947\u751f\u7269\u80a1\u4e1c\u5927\u4f1a\u4e0a\u6295\u51fa\u591a\u6570\u7968\u7684\u6743\u529b\u3001\u4ee5\u53ca\u5355\u65b9\u9762\u7ba1\u7406\u4f20\u5947\u8d22\u52a1\u548c\u8425\u8fd0\u653f\u7b56\u7684\u6743\u529b\u3002\u56e0\u6b64\uff0c\u516c\u53f8\u51b3\u5b9a\u81ea2024\u5e7410\u670818\u65e5\u8d77\uff0c\u5c06\u4f20\u5947\u89e3\u9664\u5408\u5e76\uff0c\u5e76\u5c06\u5176\u89c6\u4e3a\u5bf9\u8054\u8425\u516c\u53f8\u7684\u6295\u8d44\u3002\u5728\u89e3\u9664\u5408\u5e76\u65e5\u671f\uff0c\u516c\u53f8\u5bf9\u4e8e\u4f20\u5947\u751f\u7269\u6295\u8d44\u7684\u8d26\u9762\u4ef7\u503c\u5c06\u53cd\u6620\u5176\u6240\u6301\u6709\u4f20\u5947\u751f\u7269\u80a1\u4efd\u7684\u516c\u5141\u5e02\u573a\u4ef7\u503c\uff08\u5f53\u65e5\u6536\u76d8\u5e02\u503c\u7ea679\u4ebf\u7f8e\u5143\uff09\uff1b\u8be5\u8d26\u9762\u4ef7\u503c\u4e0e\u516c\u53f8\u6240\u5360\u4f20\u5947\u751f\u7269\u51c0\u8d44\u4ea7\uff08\u622a\u81f31H24\u672b\u7ea611.6\u4ebf\u7f8e\u5143\uff09\u4efd\u989d\u7684\u5dee\u989d\uff0c\u6263\u9664\u65e0\u5f62\u8d44\u4ea7\u548c\u5546\u8a89\u8c03\u6574\u9879\u76ee\u540e\u5c06\u57282024\u5e74\u786e\u8ba4\u4e3a\u4e00\u6b21\u6027\u975e\u73b0\u91d1\u514d\u7a0e\u6536\u76ca\uff08\u516c\u53f8\u9884\u8ba1\u6700\u7ec8\u6570\u989d\u5c06\u8fbe\u523020-30\u4ebf\u7f8e\u5143\uff09\u3002<br/><br/>\u8be5\u884c\u5c06\u516c\u53f82024-26\u5e74\u6536\u5165\u9884\u6d4b\u4e0b\u8c03\u81f310.6\u4ebf/7.1\u4ebf/8.4\u4ebf\u7f8e\u5143\uff0c\u5e76\u5c062024\u5e74\u51c0\u5229\u6da6\u9884\u6d4b\u4e0a\u8c03\u81f322.9\u4ebf\u7f8e\u5143\uff0c202526\u5e74\u51c0\u5229\u6da6\u9884\u6d4b\u5c06\u57fa\u672c\u4fdd\u6301\u4e0d\u53d8\uff1b\u8be5\u884c\u7ef4\u6301\u516c\u53f828.75\u6e2f\u5143\u76ee\u6807\u4ef7\u53ca\u4e70\u5165\u8bc4\u7ea7\u3002<br/><br/>\u8be5\u884c\u8ba4\u4e3a\uff0c\u89e3\u9664\u5408\u5e76\u4f20\u5947\u540e\uff0c\u91d1\u65af\u745e\u7684\u7ecf\u8425\u5c42\u9762\u5229\u6da6\u5c06\u66f4\u51c6\u786e\u5730\u53cd\u6620\u975e\u7ec6\u80de\u6cbb\u7597\u4e1a\u52a1\u60c5\u51b5\uff0c\u968f\u77402025-26\u5e74\u975e\u7ec6\u80de\u4e1a\u52a1\u6536\u5165\u589e\u901f\u590d\u82cf\u81f320%\u5de6\u53f3\uff0c\u626d\u4e8f\u4e3a\u76c8\u8def\u5f84\u5c06\u8fdb\u4e00\u6b65\u6e05\u6670\u3002\u8be5\u884c\u9884\u8ba1\uff0c\u5728\u51c0\u5229\u6da6\u5c42\u9762\uff0c2024\u5e74\u8d77\u91d1\u65af\u745e\u5c06\u5168\u9762\u8fdb\u5165\u76c8\u5229\u533a\u95f4\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255517860", "pub_date": "2024-10-23 10:00:17"}, {"id": 255517662, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u7b2c\u4e00\u592a\u5e73(00142)\u6da8\u8fd13%  \u65d7\u4e0b\u516c\u53f8\u51fa\u552e\u83f2\u5f8b\u5bbe\u77f3\u6cb9\u4ea7\u54c1\u8fdb\u53e3\u7801\u593450%\u6743\u76ca", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u7b2c\u4e00\u592a\u5e73(00142)\u80a1\u4ef7\u8d70\u9ad8\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da82.9%\uff0c\u62a54.61\u6e2f\u5143\uff0c\u6210\u4ea4\u989d935.29\u4e07\u6e2f\u5143\u3002<br/><br/>\u96c6\u56e2\u6301\u6709\u7ea646.3%\u7ecf\u6d4e\u6743\u76ca\u7684\u83f2\u5f8b\u5bbe\u8054\u53f7\u516c\u53f8MPIC\uff0c\u5c06\u51fa\u552ePCSPC\u4e4b50%\u95f4\u63a5\u6743\u76ca\uff0c\u4ee3\u4ef71.48\u4ebf\u7f8e\u5143(11.544\u4ebf\u6e2f\u5143)\uff0c\u8fde\u540c\u53ef\u80fd\u7684\u989d\u5916\u83b7\u5229\u4ed8\u6b3e\u6700\u591a2500\u4e07\u7f8e\u5143(1.95\u4ebf\u6e2f\u5143)\u3002PCSPC\u4e3a\u83f2\u5f8b\u5bbe\u6700\u5927\u578b\u72ec\u7acb\u77f3\u6cb9\u4ea7\u54c1\u8fdb\u53e3\u7801\u5934\uff0c\u5904\u65bc\u83f2\u5f8b\u5bbe\u82cf\u6bd4\u514b\u6e7e\u81ea\u7531\u6e2f\u533a\u7684\u6218\u7565\u4f4d\u7f6e\u3002\u9884\u671f\u51fa\u552e\u4e8b\u9879\u4e4b\u5b8c\u6210\u5c06\u65bc2025\u5e74\u521d\u53d1\u751f\u3002<br/><br/>\u51fa\u552e\u4e8b\u9879\u5b8c\u6210\u5f8c\uff0cPCSPC\u4e4b\u8d22\u52a1\u4e1a\u7ee9\u5c06\u4e0d\u518d\u4e3a\u96c6\u56e2\u6309\u6743\u76ca\u6cd5\u5165\u8d26\u4e4b\u5171\u540c\u63a7\u5236\u5b9e\u4f53\u3002\u96c6\u56e2\u9884\u671f\u4ece\u51fa\u552e\u4e8b\u9879\u83b7\u5f97\u7ea64000\u4e07\u7f8e\u5143(3.12\u4ebf\u6e2f\u5143)\u4e4b\u6536\u76ca\uff0c\u4e43\u6839\u636e\u51fa\u552e\u6240\u5f97\u6536\u76ca\u51cf\u6295\u8d44\u4e4b\u8d26\u9762\u6210\u672c\u8ba1\u7b97\u3002MPIC\u62df\u5c06\u53ef\u5f97\u4e4b\u51fa\u552e\u6240\u5f97\u6b3e\u9879\u7528\u65bc\u63a8\u52a8\u5176\u6838\u5fc3\u4e1a\u52a1\u4e4b\u6301\u7eed\u53d1\u5c55\uff0c\u8fdb\u4e00\u6b65\u5de9\u56fa\u5176\u5728\u83f2\u5f8b\u5bbe\u7ecf\u6d4e\u4e3b\u8981\u9886\u57df\u7684\u5730\u4f4d\uff0c\u5e76\u7528\u65bc\u51cf\u5c11\u5176\u73b0\u6709\u503a\u52a1\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255517662", "pub_date": "2024-10-23 09:58:05"}, {"id": 255517142, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u6ce1\u6ce1\u739b\u7279(09992)\u7ee9\u540e\u5347\u903e18% \u7b2c\u4e09\u5b63\u5ea6\u6574\u4f53\u6536\u76ca\u8f83\u6309\u5e74\u5347120%-125%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6ce1\u6ce1\u739b\u7279(09992)\u7ee9\u540e\u80a1\u4ef7\u5e94\u58f0\u4e0a\u6da8\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da818.44%\uff0c\u62a575.15\u6e2f\u5143\uff0c\u6210\u4ea4\u989d7.16\u4ebf\u6e2f\u5143\u3002<br/><br/>\u516c\u53f82024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u6574\u4f53\u6536\u76ca\u8f832023\u5e74\u7b2c\u4e09\u5b63\u5ea6\u589e\u957f120%-125%\uff0c\u5176\u4e2d\u4e2d\u56fd\u5185\u5730\u6536\u76ca\u589e\u957f55%-60%\uff0c\u6e2f\u6fb3\u53f0\u53ca\u6d77\u5916\u6536\u76ca\u589e\u957f440%-445%\u3002\u7b2c\u4e09\u5b63\u5ea6\u4e2d\u56fd\u5185\u5730\u5404\u6e20\u9053\u6536\u76ca\u4e0e\u4e0a\u5e74\u540c\u671f\u76f8\u6bd4\uff0c\u96f6\u552e\u5e97\u540c\u6bd4\u589e\u957f30%-35%\uff1b\u673a\u5668\u4eba\u5546\u5e97\u540c\u6bd4\u589e\u957f20%-25%\uff1b\u6ce1\u6ce1\u739b\u7279\u62bd\u76d2\u673a\u540c\u6bd4\u589e\u957f55%-60%\uff1b\u7535\u5546\u5e73\u53f0\u53ca\u5176\u4ed6\u7ebf\u4e0a\u5e73\u53f0\u540c\u6bd4\u589e\u957f135%-140%\uff08\u5176\u4e2d\u6296\u97f3\u5e73\u53f0\u540c\u6bd4\u589e\u957f115%120%\u3001\u5929\u732b\u65d7\u8230\u5e97\u540c\u6bd4\u589e\u957f155%-160%\uff09\uff1b \u53ca\u6279\u53d1\u53ca\u5176\u5b83\u6e20\u9053\u540c\u6bd4\u589e\u957f45%-50%\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255517142", "pub_date": "2024-10-23 09:49:22"}, {"id": 255516503, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u5468\u5927\u798f(01929)\u6da8\u903e7% \u4e2d\u91d1\u6599\u91d1\u4ef7\u4e0a\u6da8\u548c\u5b9a\u4ef7\u9ec4\u91d1\u4ea7\u54c1\u5360\u6bd4\u63d0\u5347\u4fc3\u5176\u6bdb\u5229\u7387\u540c\u6bd4\u63d0\u5347", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5468\u5927\u798f(01929)\u76c8\u8b66\u540e\u4ecd\u4e0a\u6da8\uff0c\u622a\u6b62\u53d1\u7a3f\uff0c\u6da87.01%\uff0c\u62a57.79\u6e2f\u5143\uff0c\u6210\u4ea4\u989d2060.48\u4e07\u6e2f\u5143\u3002<br/><br/>\u516c\u53f8\u9884\u8ba1\u4e0a\u534a\u5e74\u7684\u8425\u4e1a\u989d\u8f83\u53bb\u5e74\u540c\u671f\u4e0b\u964d\u7ea618%\u81f322%\uff0c\u800c\u51c0\u6ea2\u5229\u5219\u4e0b\u964d\u7ea642%\u81f346%\u3002\u5728\u5206\u6790\u4e0a\u534a\u5e74\u53ca\u53bb\u5e74\u540c\u671f\u7684\u5b9e\u9645\u7ecf\u8425\u8868\u73b0\u65f6\u5e94\u5254\u9664\u9ec4\u91d1\u501f\u8d37\u91cd\u4f30\u7684\u5f71\u54cd\uff0c\u8fd9\u6837\u7ecf\u8c03\u6574\u540e\u4e0a\u534a\u5e74\u7684\u51c0\u6ea2\u5229\u964d\u5e45\u5c06\u4f1a\u6536\u7a84\u81f3\u7ea612%\u81f316%\u3002\u7531\u4e8e\u6bdb\u5229\u7387\u53d7\u76ca\u4e8e\u4e0a\u534a\u5e74\u6240\u51fa\u552e\u9ec4\u91d1\u4ea7\u54c1\u7684\u5e73\u5747\u552e\u4ef7\u8f83\u9ad8\u4ee5\u53ca\u4ea7\u54c1\u4f18\u5316\u53ca\u5b9a\u4ef7\u7b56\u7565\uff0c\u52a0\u4e0a\u516c\u53f8\u7075\u6d3b\u6267\u884c\u5404\u9879\u63aa\u65bd\u589e\u5f3a\u4e1a\u52a1\u97e7\u6027\u548c\u7ade\u4e89\u529b\uff0c\u4ece\u800c\u7f13\u51cf\u4e86\u4e0a\u534a\u5e74\u5916\u90e8\u73af\u5883\u6311\u6218\u6240\u5e26\u6765\u7684\u5f71\u54cd\uff0c\u4ee4\u7ecf\u8c03\u6574\u540e\u51c0\u6ea2\u5229\u7684\u8dcc\u5e45\u7f29\u5c11\u3002<br/><br/>\u4e2d\u91d1\u53d1\u62a5\u79f0\uff0c\u6839\u636e\u516c\u53f8\u516c\u5e032QFY25(7-9\u6708)\u7ecf\u8425\u6570\u636e\uff0c\u5468\u5927\u798f\u6574\u4f53\u96f6\u552e\u989d\u540c\u6bd4\u4e0b\u6ed121%\uff0c\u5176\u4e2d\u4e2d\u56fd\u5185\u5730\u96f6\u552e\u989d\u540c\u6bd4\u4e0b\u6ed119%\uff0c\u4e2d\u56fd\u9999\u6e2f\u3001\u4e2d\u56fd\u6fb3\u95e8\u53ca\u5176\u4ed6\u5e02\u573a\u96f6\u552e\u989d\u540c\u6bd4\u4e0b\u6ed131%\u3002\u516c\u53f8\u9884\u8ba11HFY25\u6536\u5165\u540c\u6bd4\u4e0b\u964d18-22%\uff0c\u51c0\u5229\u6da6\u4e0b\u964d42-46%\uff0c\u4f46\u82e5\u5254\u9664\u9ec4\u91d1\u501f\u8d37\u635f\u76ca\u5f71\u54cd\u540e\uff0c\u516c\u53f8\u9884\u8ba1\u8c03\u6574\u540e\u51c0\u5229\u6da6\u540c\u6bd4\u4e0b\u964d12-16%\u53cd\u6620\u8c03\u6574\u540e\u51c0\u5229\u7387\u4ecd\u6709\u5c0f\u5e45\u540c\u6bd4\u63d0\u5347\u3002\u8be5\u884c\u9884\u8ba1\u56e0\u91d1\u4ef7\u4e0a\u6da8\u548c\u5b9a\u4ef7\u9ec4\u91d1\u4ea7\u54c1\u5360\u6bd4\u63d0\u5347\u5e26\u6765\u6bdb\u5229\u7387\u540c\u6bd4\u63d0\u5347\u3002\u8be5\u884c\u57fa\u672c\u7ef4\u6301\u5468\u5927\u798fFY25/26\u5e74EPS\u9884\u6d4b0.58/0.69\u6e2f\u5143\uff0c\u7ef4\u6301\u201c\u8dd1\u8d62\u884c\u4e1a\u201d\u8bc4\u7ea7\u548c\u76ee\u6807\u4ef77.82\u6e2f\u5143\u4e0d\u53d8\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255516503", "pub_date": "2024-10-23 09:39:06"}]}