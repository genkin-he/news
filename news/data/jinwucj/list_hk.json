{"data": [{"id": 260087584, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u9ad8\u76db\u770b\u597d\u5c0f\u7c73(01810)YU7\u7684\u9700\u6c42\u524d\u666f \u6599YU7\u7684\u5e73\u5747\u552e\u4ef7\u5047\u8bbe\u4ecd\u6709\u4e0a\u5347\u6f5c\u529b", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u9ad8\u76db\u53d1\u7814\u62a5\u6307\uff0c\u5c0f\u7c73\u96c6\u56e2(01810)\u7b2c\u4e8c\u6b3e\u7535\u52a8\u8f66\u5c0f\u7c73YU7\u5df2\u5728\u5de5\u4fe1\u90e8\u63d0\u4ea4\u7533\u8bf7\uff0c\u7ba1\u7406\u5c42\u9884\u8ba1\u5c06\u57282025\u5e746\u30017\u6708\u63a8\u51fa\uff0c\u4e0e\u8be5\u884c\u5047\u8bbe\u4e00\u81f4\uff0c\u5373\u7b2c\u4e8c\u6b3e\u8f66\u578b\u5c06\u4ece2025\u5e747\u6708\u5f00\u59cb\u91cf\u4ea7\u3002<br/><br/>\u8be5\u884c\u770b\u597d\u5c0f\u7c73YU7\u7684\u9700\u6c42\u524d\u666f\uff0c\u8ba4\u4e3a\u8be5\u8f66\u578b\u6709\u6f5c\u529b\u6210\u4e3a\u4e2d\u56fd\u6700\u7545\u9500\u7684\u9ad8\u7aef\u65b0\u80fd\u6e90\u8f66SUV\u4e4b\u4e00\uff0c\u5e76\u76f8\u4fe1\u5176\u5bf9\u5c0f\u7c73YU7\u7684\u5e73\u5747\u552e\u4ef7\u5047\u8bbe\u4ecd\u6709\u4e0a\u5347\u6f5c\u529b\u3002<br/><br/>\u8be5\u884c\u5c06\u7b49\u5f85\u672a\u67656\u4e2a\u6708\u5185\u66f4\u591a\u5173\u4e8e\u5c0f\u7c73YU7\u89c4\u683c\u4e0e\u5b9a\u4ef7\u7684\u7ec6\u8282\u3002\u5c3d\u7ba1\u9884\u5b9a\u7684\u53d1\u552e\u65f6\u95f4\u4e0e\u8be5\u884c\u5047\u8bbe\u53ca\u5c0f\u7c73\u7535\u52a8\u8f66\u4e8c\u671f\u5de5\u5382\u7684\u5b8c\u5de5\u65f6\u95f4\u57fa\u672c\u4e00\u81f4\uff0c\u4f46\u76f8\u4fe1SU7\u548cYU7\u5c06\u5171\u4eab\u5c0f\u7c73\u7684Moderna\u5236\u9020\u5e73\u53f0\uff0c\u8fd9\u53ef\u80fd\u4f1a\u63a8\u52a8\u89c4\u6a21\u7ecf\u6d4e\u5e76\u6539\u5584\u96c6\u56e2\u6bdb\u5229\u7387\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260087584", "pub_date": "2024-12-10 09:53:22"}, {"id": 260087583, "title": "\u3010\u7279\u7ea6\u5927V\u3011\u9093\u58f0\u5174\uff1a\u4e2d\u592e\u52a0\u7801\u51fa\u53f0\u7a33\u4f4f\u697c\u5e02\u53ca\u80a1\u5e02\uff0c\u5e02\u573a\u6c14\u6c1b\u5927\u589e", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6052\u6307\u5468\u4e00(9\u65e5)\u6536\u5e02\u62a520414\uff0c\u5347548\u70b9\u62162.8%\uff0c\u5927\u5e02\u5168\u65e5\u6210\u4ea42065\u4ebf\u5143\u3002\u56fd\u6307\u7092\u9ad83.1%\uff0c\u62a57360\uff1b\u79d1\u6307\u6025\u53474.3%\uff0c\u62a54656\u70b9\uff0c\u4e24\u65e5\u6025\u53476.6%\u3002\u7f8e\u56fd\u751f\u7269\u5b89\u5168\u6cd5\u6848\u672a\u6709\u7eb3\u5165\u56fd\u9632\u6388\u6743\u6cd5\u6848(NDAA)\u6700\u7ec8\u534f\u8bae\u6587\u672c\uff0cCRO\u80a1\u83b7\u7092\u4e0a\uff0c\u5f53\u4e2d\u836f\u660e\u5eb7\u5fb7(02359)\u66f4\u662f\u5347\u5e45\u6700\u5927\u84dd\u7b79\uff0c\u5168\u65e5\u6025\u53479.6%\uff0c\u4e3a\u8868\u73b0\u6700\u4f73\u84dd\u7b79\uff1b\u4e2d\u5171\u4e2d\u592e\u653f\u6cbb\u5c40\u8981\u5927\u529b\u63d0\u632f\u6d88\u8d39\u3001\u63d0\u9ad8\u6295\u8d44\u6548\u76ca\uff0c\u5168\u65b9\u4f4d\u6269\u5927\u56fd\u5185\u9700\u6c42\uff0c\u9910\u996e\u80a1\u7206\u4e0a\u3002\u6d77\u4f26\u53f8(09869)\u5927\u534725.1%\uff1b<br/><br/>\u9053\u6307\u5468\u4e00(9\u65e5)\u6536\u62a544401\u70b9\uff0c\u8dcc240\u70b9\u62160.54%\u3002\u6807\u6307\u6ed1\u843d0.61%\uff0c\u62a56052\u70b9\uff1b\u7eb3\u6307\u4ea6\u56de\u54100.62%\uff0c\u62a519736\u70b9\u3002\u91cd\u78c5\u80a1\u4e2d\uff0c\u8f89\u8fbe(Nvidia)\u56e0\u6d89\u5acc\u8fdd\u53cd\u53cd\u5784\u65ad\u6cd5\uff0c\u906d\u4e2d\u56fd\u5e02\u573a\u76d1\u7ba1\u603b\u5c40\u7acb\u6848\u8c03\u67e5\uff0c\u80a1\u4ef7\u6536\u5e02\u632b2.6%\uff0c\u7279\u65af\u62c9(Tesla)\u80a1\u4ef7\u66fe\u62bd\u9ad84%\uff0c\u9ad8\u89c1404.8\u7f8e\u5143\uff0c\u6536\u5e02\u53cd\u8986\u5fae\u5f390.2%\uff0c\u62a5389.79\u7f8e\u5143\u3002\u82f9\u679c\u53cd\u5f391.6%\u3002UnitedHealth\u62bd\u9ad82.4%\uff0c\u4e3a\u8868\u73b0\u6700\u5f3a\u9053\u6307\u6210\u4efd\u80a1\uff1bTravelers\u8d70\u4f4e3.5%\uff0c\u4e3a\u8dcc\u5e45\u6700\u5927\u9053\u6307\u6210\u4efd\u80a1\u3002\u4e9a\u592a\u80a1\u5e02\u4eca\u65e9(10\u65e5)\u4e2a\u522b\u8d70\uff0c\u65e5\u7ecf225\u6307\u6570\u73b0\u65f6\u62a539259\u70b9\uff0c\u534799\u70b9\u62160.25%\u3002\u5357\u97e9\u7efc\u5408\u6307\u6570\u73b0\u65f6\u62a52415\u70b9\uff0c\u534754\u70b9\u62162%\u3002\u4e2d\u592e\u52a0\u7801\u51fa\u53f0\u7a33\u4f4f\u697c\u5e02\u53ca\u80a1\u5e02\uff0c\u5e02\u573a\u6c14\u6c1b\u5927\u589e\u3002<br/><br/>(\u7b14\u8005\u4e3a\u8bc1\u76d1\u4f1a\u6301\u724c\u4eba\u58eb\u53ca\u7b14\u8005\u672a\u6301\u6709\u4e0a\u8ff0\u80a1\u4efd)<br/><br/>\u5e02\u573a\u7126\u70b9\uff1a\u65f6\u4ee3\u7535\u6c14(03898\uff09<br/><br/>\u96c6\u56e2\u516c\u5e03\uff0c\u4e3a\u52a0\u5f3a\u8d44\u672c\u5e02\u573a\u4ef7\u503c\u7ba1\u7406\uff0c\u8463\u4e8b\u4f1a\u4f1a\u8bae\u540c\u610f\u5229\u7528\u81ea\u6709\u8d44\u91d1\uff0c\u56de\u8d2d5426\u4e07\u80a1H\u80a1\uff0c\u56de\u8d2d\u4ef7\u683c\u4e0d\u8d85\u8fc7\u6bcf\u80a131.38\u5143\u4eba\u6c11\u5e01\uff0c\u91d1\u989d\u5219\u4e0d\u9ad8\u4e8e17\u4ebf\u5143\u4eba\u6c11\u5e01\u3002\u6d88\u606f\u523a\u6fc0\u80a1\u4ef7\u6301\u7eed\u8d70\u9ad8\uff0c\u6599\u5347\u52bf\u6301\u7eed\u3002\u4f5c\u4e3a\u8f68\u4ea4\u7535\u5668\u88c5\u5907\u9f99\u5934\uff0c\u96c6\u56e2\u57fa\u672c\u9762\u826f\u597d\u3002\u65f6\u4ee3\u7535\u6c14\u516c\u5e03\u4e862024\u5e74\u7b2c\u4e09\u5b63\u5ea6\u62a5\u544a\u30022024\u5e74Q3\uff0c\u96c6\u56e2\u5b9e\u73b0\u8425\u653659.73\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f8.10%\uff1b\u5f52\u6bcd\u51c0\u5229\u6da69.94\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f10.61%\uff1b\u5f52\u6bcd\u6263\u975e\u51c0\u5229\u6da68.89\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f18.27%\u30022024\u5e74\u9996\u4e09\u5b63\u516c\u53f8\u8f68\u9053\u4ea4\u901a\u88c5\u5907\u4e1a\u52a1\u5b9e\u73b0\u8425\u653694.34\u4ebf\u5143\uff0c\u6309\u5e74\u589e\u957f22.17%\u3002\u5728\u78b3\u5316\u7845\u4e1a\u52a1\u65b9\u9762\uff0c\u65f6\u4ee3\u7535\u6c14\u8868\u793a\uff0c\u5176\u76ee\u524d\u5177\u5907\u5e74\u4ea72.5\u4e07\u72476\u82f1\u5bf8\u78b3\u5316\u7845\u7684\u4ea7\u80fd\uff0c\u5e76\u5df2\u53d1\u5e03\u57fa\u4e8e\u78b3\u5316\u7845\u5668\u4ef6\u7684\u7535\u9a71\u7cfb\u7edf\uff0c\u9884\u8ba1\u4eca\u5e74\u5f62\u6210\u9500\u552e\uff0c\u660e\u5e74\u5b9e\u73b0\u6279\u91cf\u63a8\u5e7f\u3002\u6b64\u5916\uff0c\u4eca\u5e749\u6708\uff0c\u56fd\u5bb6\u94c1\u8def\u5c40\u53d1\u5e03\u300a\u8001\u65e7\u578b\u94c1\u8def\u5185\u71c3\u673a\u8f66\u6dd8\u6c70\u66f4\u65b0\u76d1\u7763\u7ba1\u7406\u529e\u6cd5\u300b\u660e\u786e\u8001\u65e7\u578b\u94c1\u8def\u5185\u71c3\u673a\u8f66\u62a5\u5e9f\u8fd0\u7528\u5e74\u9650\uff0c\u786e\u5b9a\u81f32027\u5e74\u5e74\u5e95\u91cd\u70b9\u533a\u57df\u8001\u65e7\u578b\u94c1\u8def\u5185\u71c3\u673a\u8f66\u5c06\u5168\u90e8\u9000\u51fa\u94c1\u8def\u8fd0\u8f93\u5e02\u573a\u3002\u5728\u94c1\u8def\u673a\u8f66\u7eff\u8272\u4f4e\u78b3\u8f6c\u578b\u5927\u80cc\u666f\u4e0b\uff0c\u516c\u53f8\u5df2\u62e5\u6709\u8986\u76d61000kw\u30011500kw\u53ca2000kw\u4e09\u79cd\u529f\u7b49\u7ea7\u7684\u673a\u8f66\u5e73\u53f0\uff0c\u52a8\u529b\u6e90\u8986\u76d6\u5e7f\u6cdb\uff0c\u8f68\u4ea4\u4e1a\u52a1\u589e\u957f\u52a8\u529b\u5f3a\u52b2\u3002\u4ea6\u6301\u7eed\u770b\u597d\u96c6\u56e2\u4e0d\u65ad\u4ee5\u521b\u65b0\u8d4b\u80fd\u4ea7\u54c1\uff0c\u5728\u7a33\u56fa\u5e02\u573a\u5730\u4f4d\u540c\u65f6\u52a9\u529b\u672c\u571f\u6574\u8f66\u5382\u51fa\u6d77\u3002\u76ee\u6807\u4ef7$40\uff0c\u6b62\u8680\u4ef7$25\u3002<br/><br/>(\u7b14\u8005\u4e3a\u8bc1\u76d1\u4f1a\u6301\u724c\u4eba\u58eb\u53ca\u7b14\u8005\u672a\u6301\u6709\u4e0a\u8ff0\u80a1\u4efd)</p><p>\u4f5c\u8005\uff1b\u9999\u6e2f\u80a1\u7968\u5206\u6790\u5e08\u534f\u4f1a\u4e3b\u5e2d\u9093\u58f0\u5174\u535a\u58eb</p>", "link": "https://sky.szfiu.com/info/hk/details/260087583", "pub_date": "2024-12-10 09:53:38"}, {"id": 260087213, "title": "\u5185\u623f\u80a1\u80a1\u4ef7\u53d1\u529b \u9f99\u6e56\u96c6\u56e2(00960)\u6da83.02% \u653f\u6cbb\u5c40\u4f1a\u8bae\u5f3a\u8c03\u7a33\u4f4f\u697c\u5e02", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5185\u623f\u80a1\u53d1\u529b\u8d70\u9ad8\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u878d\u4fe1\u4e2d\u56fd(03301)\u6da89.8%\uff0c\u5bcc\u529b\u5730\u4ea7(02777)\u6da85.59%\uff0c\u4e2d\u6881\u63a7\u80a1(02772)\u6da85.22%\uff0c\u4e16\u8302\u96c6\u56e2(00813)\u6da84.41%\uff0c\u9f99\u6e56\u96c6\u56e2(00960)\u6da83.02%\uff0c\u534e\u6da6\u7f6e\u5730(01109)\u6da81.83%\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u4e2d\u5171\u4e2d\u592e\u653f\u6cbb\u5c4012\u67089\u65e5\u53ec\u5f00\u4f1a\u8bae\uff0c\u5206\u6790\u7814\u7a762025\u5e74\u7ecf\u6d4e\u5de5\u4f5c\u3002\u623f\u5730\u4ea7\u76f8\u5173\u653f\u7b56\u65b9\u9762\uff0c\u5f3a\u8c03\u7a33\u4f4f\u697c\u5e02\uff0c\u9632\u8303\u5316\u89e3\u91cd\u70b9\u9886\u57df\u98ce\u9669\u548c\u5916\u90e8\u51b2\u51fb\u3002</p><p>\u534e\u91d1\u8bc1\u5238\u8868\u793a\uff0c\u653f\u6cbb\u5c40\u4f1a\u8bae\u9996\u6b21\u5766\u7387\u52a1\u5b9e\u5730\u63d0\u51fa\u7a33\u5b9a\u697c\u5e02\u80a1\u5e02\u7684\u660e\u786e\u8981\u6c42\uff0c\u9884\u8ba1\u623f\u5730\u4ea7\u5e02\u573a\u4f9b\u9700\u4e24\u65b9\u9762\u5747\u6709\u589e\u91cf\u653f\u7b56\u53ef\u671f\uff0c\u673a\u6784\u957f\u671f\u8d44\u91d1\u5165\u5e02\u548c\u4e0a\u5e02\u516c\u53f8\u5e76\u8d2d\u4f18\u826f\u8d44\u4ea7\u5c06\u5f97\u5230\u6301\u7eed\u7684\u653f\u7b56\u9f13\u52b1\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260087213", "pub_date": "2024-12-10 09:48:53"}, {"id": 260086779, "title": "\u4e2d\u8d44\u5238\u5546\u80a1\u76d8\u521d\u5f3a\u52bf \u5e7f\u53d1\u8bc1\u5238(01776)\u6da84.31% \u653f\u6cbb\u4f1a\u8bae\u6307\u51fa\u8981\u7a33\u5b9a\u80a1\u5e02", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u8d44\u5238\u5546\u80a1\u76d8\u521d\u5f3a\u52bf\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u5e7f\u53d1\u8bc1\u5238(01776)\u6da84.31%\uff0c\u5174\u8bc1\u56fd\u9645(06058)\u6da84.26%\uff0c\u4e2d\u5dde\u8bc1\u5238(01375)\u6da82.15%\uff0c\u534e\u6cf0\u8bc1\u5238(06886)\u6da82.36%\uff0c\u62db\u5546\u8bc1\u5238(06099)\u6da81.23%\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u4e2d\u56fd\u9ad8\u5c42\u9886\u5bfc\u8ba1\u5212\u660e\u5e74\u653e\u677e\u8d27\u5e01\u653f\u7b56\u5e76\u6269\u5927\u8d22\u653f\u652f\u51fa\u3002\u4f1a\u8bae\u4e2d\u6307\u51fa\uff1a2025\u5e74\u8d27\u5e01\u653f\u7b56\u5c06\u91c7\u53d6\u201c\u9002\u5ea6\u5bbd\u677e\u201d\u7684\u7b56\u7565\uff0c\u8fd9\u662f\u81ea2011\u5e74\u4ee5\u6765\u9996\u6b21\u91cd\u5927\u653f\u7b56\u7acb\u573a\u8f6c\u53d8\u3002\u4f1a\u8bae\u4e2d\u8fd8\u627f\u8bfa\u201c\u7a33\u5b9a\u623f\u5730\u4ea7\u548c\u80a1\u5e02\u201d\uff0c\u5e76\u52a0\u5927\u201c\u975e\u5e38\u89c4\u9006\u5468\u671f\u653f\u7b56\u8c03\u6574\u201d\u529b\u5ea6\u3002<br/><br/>\u5f00\u6e90\u8bc1\u5238\u6307\u51fa\uff0c\u5e02\u573a\u6210\u4ea4\u989d\u8fde\u7eed3\u5468\u73af\u6bd4\u56de\u843d\uff0c\u4f46\u6574\u4f53\u4fdd\u6301\u8f83\u9ad8\u6d3b\u8dc3\u5ea6\u3002\u5238\u5546\u548c\u4fdd\u9669\u677f\u5757beta\u5c5e\u6027\u7a81\u51fa\uff0c\u673a\u6784\u914d\u7f6e\u548c\u4f30\u503c\u4ecd\u504f\u4f4e\uff0c\u5f53\u4e0b\u9636\u6bb5\u5efa\u8bae\u79ef\u6781\u589e\u914d\uff1b\u4e2a\u4eba\u6295\u8d44\u8005\u4ea4\u6613\u5360\u6bd4\u5927\u5e45\u63d0\u5347\uff0c\u4ea4\u6613\u91cf\u8d85\u9884\u671f\uff0c\u4ece\u4e1a\u7ee9\u548c\u4ea4\u6613\u7aef\u5747\u5229\u597d\u5238\u5546\u677f\u5757\uff0c\u91cd\u89c6\u5238\u5546\u677f\u5757\u6218\u7565\u6027\u673a\u4f1a\uff1b\u4e2a\u80a1\u5c42\u9762\uff0c\u5f53\u4e0b\u5e02\u573a\u60c5\u7eea\u548c\u98ce\u683c\u5f71\u54cd\u5f3a\u4e8e\u57fa\u672c\u9762\u903b\u8f91\uff0c\u770b\u597d\u4f4e\u4f30\u503c\u3001\u96f6\u552e\u4f18\u52bf\u7a81\u51fa\u7684\u4f20\u7edf\u5238\u5546\uff0c\u76c8\u5229\u540c\u6bd4\u9ad8\u589e\u53ef\u671f\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260086779", "pub_date": "2024-12-10 09:42:35"}, {"id": 260086921, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u91ce\u6751\uff1a\u5bf9\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\u5e94\u964d\u4f4e\u671f\u671b \u4e2d\u592e\u4ecd\u53ef\u80fd\u4f1a\u5c06GDP\u589e\u957f\u76ee\u6807\u8bbe\u5b9a\u4e3a\u201c\u5927\u7ea65%\u201d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u91ce\u6751\u53d1\u7814\u62a5\u6307\uff0c\u5bf9\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\u5e94\u964d\u4f4e\u671f\u671b\u3002\u63a5\u4e0b\u6765\u51e0\u5929\u9884\u8ba1\u5c06\u53ec\u5f00\u5e74\u5ea6\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae(CEWC)\uff0c\u7531\u4e8e\u4f1a\u8bae\u901a\u5e38\u662f\u7528\u4e8e\u786e\u7acb\u653f\u7b56\u57fa\u8c03\uff0c\u800c\u975e\u786e\u5b9a\u5177\u4f53\u653f\u7b56\u7ec6\u8282\uff0c\u5e76\u4e14\u81ea9\u6708\u5e95\u4ee5\u6765\u5df2\u7ecf\u660e\u663e\u8f6c\u5411\u4e86\u65b0\u7684\u653f\u7b56\u65b9\u5411\uff0c\u56e0\u6b64\u6211\u4eec\u9884\u671f\u6b64\u6b21\u4f1a\u8bae\u4e0d\u4f1a\u5e26\u6765\u592a\u591a\u65b0\u5185\u5bb9\uff0c\u5c3d\u7ba1\u80a1\u5e02\u6295\u8d44\u8005\u4e2d\u5b58\u5728\u4e00\u4e9b\u88ab\u7092\u4f5c\u7684\u5e02\u573a\u9884\u671f\u3002<br/><br/>\u8be5\u884c\u6307\uff0c2025\u5e74\u7684\u589e\u957f\u76ee\u6807\u5c06\u5728CEWC\u4e0a\u8ba8\u8bba\uff0c\u4f46\u53ef\u80fd\u8981\u52302025\u5e743\u6708\u624d\u4f1a\u6700\u7ec8\u786e\u5b9a\u3002\u4e3a\u4e86\u663e\u793a\u4e2d\u592e\u4fc3\u8fdb\u7ecf\u6d4e\u589e\u957f\u7684\u51b3\u5fc3\uff0c\u5373\u4f7f\u8003\u8651\u5230\u7279\u6717\u666e\u7b2c\u4e8c\u4efb\u671f\u5185\u7f8e\u56fd\u53ef\u80fd\u91c7\u53d6\u7684\u653f\u7b56\uff0c\u4e2d\u592e\u4ecd\u53ef\u80fd\u4f1a\u5c062025\u5e74\u7684GDP\u589e\u957f\u76ee\u6807\u8bbe\u5b9a\u4e3a\u201c\u5927\u7ea65%\u201d\uff0c\u4f46\u4e5f\u6709\u53ef\u80fd\u4e0b\u8c03\u81f3\u201c\u5927\u7ea64.5%\u201d\u3002\u53e6\u5916\uff0c\u4f1a\u8bae\u53ef\u80fd\u4f1a\u518d\u6b21\u53d1\u51fa\u5173\u4e8e2025\u5e74\u5927\u89c4\u6a21\u501f\u8d37\u8ba1\u5212\u7684\u4fe1\u53f7\uff0c\u4f46\u4e0d\u592a\u53ef\u80fd\u5728\u6b64\u5ba3\u5e03\u5177\u4f53\u7ec6\u8282\u3002<br/><br/>\u8be5\u884c\u63d0\u5230\uff0c\u9884\u8ba1\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\u5f88\u53ef\u80fd\u4f1a\u518d\u6b21\u627f\u8bfa\u7a33\u5b9a\u623f\u5730\u4ea7\u884c\u4e1a\u3002\u4f1a\u8bae\u4e5f\u53ef\u80fd\u63d0\u53ca\u4e00\u4e9b\u9488\u5bf9\u5730\u65b9\u571f\u5730\u9500\u552e\u6536\u5165\u9510\u51cf\u540e\u4fee\u8865\u7834\u8d25\u8d22\u653f\u7cfb\u7edf\u7684\u63aa\u65bd\u3002\u6b64\u5916\uff0cCEWC\u8fd8\u53ef\u80fd\u63d0\u5230\u901a\u8fc7\u589e\u52a0\u4f4e\u6536\u5165\u5bb6\u5ead\u7684\u793e\u4f1a\u4fdd\u969c\u652f\u51fa\u6765\u652f\u6301\u6d88\u8d39\uff0c\u4ee5\u53ca\u9f13\u52b1\u751f\u80b2\u7684\u653f\u7b56\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260086921", "pub_date": "2024-12-10 09:44:06"}, {"id": 260086949, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u4e2d\u91d1\u516c\u53f8\u6599\u7f8e\u8054\u50a8\u6709\u671b\u5728\u672c\u6708\u518d\u6b21\u964d\u606f25\u4e2a\u57fa\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u91d1\u516c\u53f8\u53d1\u7814\u62a5\u6307\uff0c\u5728\u53d7\u5230\u98d3\u98ce\u548c\u7f62\u5de5\u7684\u4e25\u91cd\u963b\u788d\u540e\uff0c\u7f8e\u56fd11\u6708\u65b0\u589e\u5c31\u4e1a\u4eba\u6570\u5927\u5e45\u4e0a\u5347\u81f322.7\u4e07\u4eba\uff0c\u4f46\u5931\u4e1a\u7387\u4e5f\u5347\u81f34.2%\uff0c\u8868\u660e\u52b3\u52a8\u529b\u5e02\u573a\u6b63\u5728\u653e\u7f13\u3002\u603b\u4f53\u4e0a\uff0c\u52b3\u52a8\u529b\u5e02\u573a\u4ecd\u5904\u4e8e\u201c\u5c31\u4e1a\u589e\u957f\u52bf\u5934\u51cf\u5f31\uff0c\u4f46\u5c31\u4e1a\u5e02\u573a\u672c\u8eab\u5e76\u4e0d\u5f31\u201d\u7684\u72b6\u6001\uff0c\u8fd9\u5c06\u4e3a\u7f8e\u8054\u50a812\u6708\u518d\u6b21\u964d\u606f\u63d0\u4f9b\u7406\u7531\u3002</p><p>\u4f46\u8be5\u884c\u4e5f\u9884\u6d4b\uff0c\u7f8e\u8054\u50a8\u5c06\u57282025\u5e74\u653e\u7f13\u964d\u606f\u6b65\u4f10\uff0c\u56e0\u4e3a\u968f\u7740\u5229\u7387\u63a5\u8fd1\u4e2d\u6027\u6c34\u5e73\uff0c\u51b3\u7b56\u8005\u4e5f\u5c06\u53d8\u5f97\u66f4\u52a0\u8c28\u614e\u3002\u4e00\u4e2a\u9884\u6d4b\u98ce\u9669\u662f\u7279\u6717\u666e\u63d0\u51fa\u7684\u79fb\u6c11\u653f\u7b56\u5bf9\u52b3\u52a8\u529b\u5e02\u573a\u7684\u5f71\u54cd\uff0c\u76ee\u524d\u8be5\u884c\u503e\u5411\u4e8e\u5f71\u54cd\u8f83\u4e3a\u6e29\u548c\uff0c\u4f46\u4e5f\u9700\u8981\u5bc6\u5207\u5173\u6ce8\u6781\u7aef\u60c5\u5f62\u7684\u53ef\u80fd\u6027\u3002\u57fa\u4e8e\u975e\u519c\u6570\u636e\uff0c\u8be5\u884c\u8ba4\u4e3a\u7f8e\u8054\u50a8\u6709\u671b\u5728\u672c\u6708\u518d\u6b21\u964d\u606f25\u4e2a\u57fa\u70b9\u3002<br/></p>", "link": "https://sky.szfiu.com/info/hk/details/260086949", "pub_date": "2024-12-10 09:44:25"}, {"id": 260085801, "title": "\u3010\u65b0\u80a1IPO\u3011\u6bdb\u6208\u5e73(01318)\u9996\u6302\u5f00\u62a547.65\u6e2f\u5143 \u8f83\u62db\u80a1\u4ef7\u9ad859.9%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6bdb\u6208\u5e73(01318)\u9996\u6302\u5f00\u62a547.65\u6e2f\u5143\uff0c\u8f83\u62db\u80a1\u4ef7\u9ad859.9%\uff0c\u76d8\u524d\u6210\u4ea4\u989d12.59\u4ebf\u6e2f\u5143\uff0c\u4e0d\u8ba1\u624b\u7eed\u8d39\uff0c\u6bcf\u624b100\u80a1\uff0c\u8d26\u9762\u8d5a1785\u6e2f\u5143\u3002<br/><br/>\u6839\u636e\u62db\u80a1\u7ed3\u679c\u663e\u793a\uff0c\u6700\u7ec8\u53d1\u552e\u4ef7\u5b9a\u4e3a\u6bcf\u80a129.8\u6e2f\u5143\uff0c\u96c6\u8d4423.37\u4ebf\u6e2f\u5143\uff0c \u51c0\u989d\u7ea621.87\u4ebf\u6e2f\u5143\u3002\u4e00\u624b\u4e2d\u7b7e\u7387100%\u3002\u80a1\u4efd\u4e8e\u516c\u5f00\u53d1\u552e\u90e8\u4efd\u8ba4\u8d2d\u989d\u8fbe919.18\u500d\uff0c\u56fd\u9645\u914d\u552e\u90e8\u4efd\u8ba4\u8d2d\u989d30.34\u500d\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260085801", "pub_date": "2024-12-10 09:28:50"}, {"id": 260085870, "title": "\u3010AH\u4e92\u52a8\u3011A\u80a1\u5f00\u76d8\u5f3a\u52bf \u6caa\u6307\u9ad8\u5f002.58% \u8bc1\u5238\u3001\u623f\u5730\u4ea7\u7b49\u677f\u5757\u8dcc\u5e45\u5c45\u524d", "description": "<p>\u91d1\u543e\u8d22\u8baf | A\u80a1\u5f00\u76d8\u5f3a\u52bf\uff0c\u6caa\u6307\u9ad8\u5f002.58%\uff0c\u6df1\u6210\u6307\u9ad8\u5f003.66%\uff0c\u521b\u4e1a\u677f\u6307\u9ad8\u5f004.88%\u3002<br/><br/>\u76d8\u9762\u4e0a\u770b\uff0c\u4fdd\u9669\u3001\u8bc1\u5238\u3001\u623f\u5730\u4ea7\u3001\u767d\u9152\u3001\u534a\u5bfc\u4f53\u3001\u8f6f\u4ef6\u5f00\u53d1\u7b49\u677f\u5757\u8dcc\u5e45\u5c45\u524d\u3002\u6682\u65e0\u677f\u5757\u53d7\u538b\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260085870", "pub_date": "2024-12-10 09:29:29"}, {"id": 260085869, "title": "\u6e2f\u80a1\u65e9\u76d8\u8df3\u7a7a\u9ad8\u5f00 \u6052\u6307\u53473.21% \u534e\u6da6\u5564\u9152(00291)\u6da87.86%", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u53d7\u76ca\u4e8e\u4e2d\u592e\u653f\u6cbb\u5c40\u4f1a\u8bae\u6d88\u606f\u63d0\u632f\uff0c\u6e2f\u80a1\u65e9\u76d8\u8df3\u7a7a\u9ad8\u5f00\uff0c\u6052\u6307\u53473.21%\uff0c\u56fd\u4f01\u6307\u6570\u53473.46%\uff0c\u6052\u751f\u79d1\u6280\u6307\u6570\u9ad8\u5f004.24%\u3002<br/><br/>\u534e\u6da6\u5564\u9152(00291)\u9ad8\u5f007.86%\uff0c\u5b89\u8e0f\u4f53\u80b2(02020)\u6da87.46%\uff0c\u7533\u6d32\u56fd\u9645(02313)\u6da86.46%\uff0c\u9f99\u6e56\u96c6\u56e2(00960)\u6da86.03%\u3002\u6ca1\u6709\u84dd\u7b79\u4f4e\u5f00\u3002<br/><br/>\u76d8\u9762\u4e0a\u770b\uff0c\u5185\u9700\u80a1\u3001\u5238\u5546\u3001\u533b\u7597\u4fdd\u5065\u3001\u5185\u623f\u80a1\u5747\u5f3a\u52bf\u9ad8\u5f00\u3002<br/><br/>\u6e2f\u6e7e\u5bb6\u65cf\u529e\u516c\u5ba4\u4e1a\u52a1\u53d1\u5c55\u603b\u76d1 \u90ed\u5bb6\u8000\u8868\u793a\uff0c\u7f8e\u80a1\u5468\u4e00\u8868\u73b0\u5411\u4e0b\uff0c\u5927\u5e02\u8fde\u5347\u591a\u65e5\u540e\u7531\u9ad8\u4f4d\u56de\u843d\uff0c\u4e09\u5927\u6307\u6570\u5747\u5f55\u5f97\u8dcc\u5e45\u6536\u5e02\u3002\u7f8e\u5143\u53cd\u8986\u9760\u7a33\uff0c\u7f8e\u56fd\u5341\u5e74\u671f\u503a\u606f\u56de\u5347\u81f34.19\u5398\u6c34\u5e73\uff0c\u91d1\u4ef7\u8868\u73b0\u5411\u597d\uff0c\u6cb9\u4ef7\u8d70\u52bf\u4ea6\u53d7\u5730\u7f18\u653f\u5c40\u6d88\u606f\u652f\u6301\u3002\u6e2f\u80a1\u9884\u6258\u8bc1\u5238\u666e\u904d\u4e0a\u5347\uff0c\u9884\u6599\u5927\u5e02\u65e9\u6bb5\u8ddf\u968f\u5927\u5e45\u9ad8\u5f00\u3002\u5185\u5730\u80a1\u5e02\u6628\u65e5\u9760\u7a33\uff0c\u6caa\u7efc\u6307\u9ad8\u5f00\u4f4e\u8d70\uff0c\u6536\u5e02\u5fae\u8dcc1\u70b9\uff0c\u6caa\u6df1\u4e24\u5e02\u6210\u4ea4\u989d\u4ea6\u7565\u4e3a\u7f29\u51cf\u3002\u6e2f\u80a1\u8d70\u52bf\u663e\u7740\u56de\u5347\uff0c\u5927\u5e02\u4f4e\u5f00\u540e\u53cd\u8986\u5411\u4e0a\uff0c\u4e2d\u592e\u653f\u6cbb\u5c40\u4f1a\u8bae\u8868\u793a\u5c06\u79ef\u6781\u5b9e\u65bd\u8d22\u653f\u653f\u7b56\u53ca\u9002\u5ea6\u653e\u5bbd\u8d27\u5e01\u653f\u7b56\uff0c\u7a33\u4f4f\u697c\u5e02\u53ca\u80a1\u5e02\u8868\u73b0\uff0c\u523a\u6fc0\u5927\u5e02\u6389\u5934\u5411\u4e0a\uff0c\u91cd\u4e0a20,000\u70b9\u6c34\u5e73\uff0c\u6574\u4f53\u6210\u4ea4\u4ea6\u6025\u589e\u81f32,000\u4ebf\u5143\u4ee5\u4e0a\u3002\u5e02\u573a\u61a7\u61ac\u4e2d\u592e\u7ecf\u6d4e\u5de5\u4f5c\u4f1a\u8bae\u5c06\u6709\u66f4\u591a\u5177\u4f53\u653f\u7b56\u843d\u5b9e\uff0c\u6307\u6570\u6709\u671b\u8fdb\u4e00\u6b65\u6311\u621821,500\u70b9\u963b\u529b\uff0c\u4e0b\u65b9\u652f\u6301\u5728 20,500\u70b9\u6c34\u5e73\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260085869", "pub_date": "2024-12-10 09:29:54"}, {"id": 260085535, "title": "\u4eba\u6c11\u5e01\u5151\u7f8e\u5143\u4e2d\u95f4\u4ef7\u62a57.1896 \u4e0b\u8c0326\u70b9", "description": "<p>\u91d1\u543e\u8d22\u8baf |&nbsp;12\u670810\u65e5\uff0c\u4eba\u6c11\u5e01\u5151\u7f8e\u5143\u4e2d\u95f4\u4ef7\u62a57.1896\uff0c\u4e0b\u8c0326\u70b9\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/260085535", "pub_date": "2024-12-10 09:24:52"}]}