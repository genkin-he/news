833</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">6.65</td></tr><tr><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">恒生中国企业</span><span style=\"display: inline-block; vertical-align:middle;\">(02828)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">1069.38901</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">23.410</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">4.59</td></tr><tr><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">小米集团－Ｗ</span><span style=\"display: inline-block; vertical-align:middle;\">(01810)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">1021.34261</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">21.294</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">4.39</td></tr><tr><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">泡泡玛特</span><span style=\"display: inline-block; vertical-align:middle;\">(09992)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">797.32524</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">24.858</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">3.42</td></tr></table></div>",
