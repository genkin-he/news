5e7f\u5ea6\u5927\u5e45\u6539\u5584\uff0c\u6d77\u5916\u4efd\u989d\u4ecd\u6709\u660e\u786e\u63d0\u5347\u7a7a\u95f4\u3002\u9884\u8ba1\u56fd\u4ea7\u91cd\u5361\u9500\u91cf\u8ddd\u79bb\u957f\u671f\u4e2d\u67a2(\u56fd\u5185\u4e2d\u67a2+\u6d77\u5916\u505a\u5230\u6210\u719f)\u670938%\u7a7a\u95f4\u3002\u5efa\u8bae\u5173\u6ce8\uff1a\u4e2d\u56fd\u91cd\u6c7d\u3001\u6f4d\u67f4\u52a8\u529b\u3001\u4e00\u6c7d\u89e3\u653e\u7b49\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255039747", "pub_date": "2024-10-17 10:04:32"}, {"id": 255039093, "title": "\u3010AH\u4e92\u52a8\u3011\u8d63\u950b\u9502\u4e1a(01772)\u6da82.84% \u8fd1\u65e5\u7ade\u6807\u667a\u5229\u5927\u578b\u9502\u76d0\u6e56\u9879\u76ee", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u8d63\u950b\u9502\u4e1a(01772)\u9707\u8361\u8d70\u5f3a\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u6da82.84%\uff0c\u62a520.3%\uff0c\u6210\u4ea4\u989d1420\u4e07\u6e2f\u5143\u3002\u5bf9\u5e94A\u80a1\uff0c\u8d63\u950b\u9502\u4e1a(002460)\u6da81.49%\uff0c\u62a530.74\u5143\u4eba\u6c11\u5e01\uff0c\u6210\u4ea4\u989d1.52\u4ebf\u4eba\u6c11\u5e01\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u667a\u5229\u56fd\u5bb6\u94dc\u4e1a\u516c\u53f8\u6b63\u5c31\u5f53\u5730\u9ad8\u54c1\u4f4d\u5927\u578b\u9502\u76d0\u6e56Maricunga\u5bfb\u627e\u5408\u8425\u4f19\u4f34\u3002\u636e\u6089\uff0c\u4e2d\u56fd\u8d63\u950b\u9502\u4e1a\u3001\u4e2d\u56fd\u4e94\u77ff\u90fd\u53c2\u4e0e\u4e86\u7ade\u6807\uff0c\u9996\u8f6e\u610f\u5411\u65b9\u201c\u77ed\u540d\u5355\u201d\u9884\u8ba1\u8fd1\u65e5\u51fa\u7089\uff0c\u4f46\u672a\u5fc5\u4f1a\u4e88\u4ee5\u516c\u5e03\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/255039093", "pub_date": "2024-10-17 09:52:53"}]}