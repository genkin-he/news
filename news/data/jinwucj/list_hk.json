ock; vertical-align:middle;\">\u4e2d\u56fd\u6d77\u6d0b\u77f3\u6cb9</span><span style=\"display: inline-block; vertical-align:middle;\">(00883)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">17.86\uff082.6%\uff09</td></tr><tr><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">\u7164\u70ad</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">1.7</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">\u4e2d\u56fd\u795e\u534e</span><span style=\"display: inline-block; vertical-align:middle;\">(01088)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">33.95\uff083.8%\uff09</td></tr><tr><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">\u9152\u5e97\u3001\u9910\u9986\u4e0e\u4f11\u95f2</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">0.9</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">\u643a\u7a0b\u96c6\u56e2\uff0d\uff33</span><span style=\"display: inline-block; vertical-align:middle;\">(09961)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">529.5\uff082.5%\uff09</td></tr><tr><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">\u652f\u63f4\u670d\u52a1</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">0.6</td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\"><span style=\"display: inline-block; vertical-align:middle;\">\u65b0\u4e1c\u65b9\uff0d\uff33</span><span style=\"display: inline-block; vertical-align:middle;\">(09901)</span></td><td style=\"vertical-align: middle; border: 1px solid#999; padding: 7px 0;\">49.85\uff084.9%\uff09</td></tr></table></div>", "link": "https://sky.szfiu.com/info/hk/details/259507586", "pub_date": "2024-12-04 14:30:05"}, {"id": 259507370, "title": "\u3010\u6e2f\u80a1\u901a\u3011\u4e2d\u56fd\u8054\u901a(00762)\u66fe\u5347\u903e3% \u745e\u94f6\u6307\u6d88\u8d39\u8005\u4e1a\u52a1\u7ade\u4e89\u529b\u548c\u8d44\u672c\u652f\u51fa\u9884\u671f\u662f\u5e02\u573a\u5173\u952e", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u4e2d\u56fd\u8054\u901a(00762)\u5348\u540e\u9707\u8361\u62c9\u5347\uff0c\u4e00\u5ea6\u53473.08%\uff0c\u9ad8\u89c16.7\u6e2f\u5143\uff0c\u622a\u81f3\u53d1\u7a3f\uff0c\u4ecd\u6da82.62%\uff0c\u62a56.67\u6e2f\u5143\uff0c\u6210\u4ea4\u989d2.28\u4ebf\u6e2f\u5143\u3002<br/><br/>\u6d88\u606f\u9762\u4e0a\uff0c\u8fd1\u65e5\u4e2d\u56fd\u8054\u901a\u4e0e\u4e2d\u5f71\u80a1\u4efd\u5728\u5317\u4eac\u4e3e\u884c\u5408\u4f5c\u4ea4\u6d41\u4f1a\u8c08\u5e76\u4e3e\u529e\u6218\u7565\u5408\u4f5c\u7b7e\u7ea6\u4eea\u5f0f\u3002\u6839\u636e\u534f\u8bae\uff0c\u53cc\u65b9\u5c06\u5728\u7f51\u7edc\u901a\u4fe1\u8bbe\u65bd\u5efa\u8bbe\u548c\u7535\u5f71\u4ea7\u4e1a\u79d1\u6280\u521b\u65b0\u7b49\u65b9\u9762\u52a0\u5f3a\u5408\u4f5c\u3002<br/><br/>\u745e\u94f6\u8fd1\u65e5\u5728\u5173\u4e8e\u4e2d\u56fd\u7535\u4fe1\u884c\u4e1a\u7684\u7814\u62a5\u4e2d\u6307\u51fa\uff0c\u6839\u636e\u4e2d\u56fd\u5de5\u4fe1\u90e8\u7684\u6570\u636e\uff0c2024\u5e7410\u6708\u7535\u4fe1\u884c\u4e1a\u670d\u52a1\u6536\u5165\u540c\u6bd4\u589e\u957f2.6%\uff0c\u8f83\u7b2c\u4e09\u5b63\u5ea6\u76841.8%\u6709\u6240\u56de\u5347\uff0c\u4f46\u4e0e\u53bb\u5e74\u540c\u671f\u76841.6%\u76f8\u6bd4\u4ecd\u663e\u6e29\u548c\u3002\u745e\u94f6\u8ba4\u4e3a\uff0c\u5c3d\u7ba15G\u7528\u6237\u6570\u91cf\u548c1000M+\u56fa\u5b9a\u5bbd\u5e26\u6e17\u900f\u7387\u7a33\u6b65\u589e\u957f\uff0c\u4f46\u6d88\u8d39\u8005\u4e1a\u52a1\u7684\u7ade\u4e89\u529b\u548c\u8d44\u672c\u652f\u51fa\uff08capex\uff09\u7684\u9884\u671f\u53d8\u5316\u4ecd\u5c06\u662f\u5f71\u54cd\u884c\u4e1a\u672a\u6765\u589e\u957f\u7684\u5173\u952e\u56e0\u7d20\u3002<br/><br/>\u8be5\u884c\u9884\u8ba1\u7535\u4fe1\u516c\u53f8\u5c06\u66f4\u52a0\u5173\u6ce8\u4f01\u4e1a\u4e1a\u52a1\u7684\u76c8\u5229\u80fd\u529b\u548c\u73b0\u91d1\u6d41\uff0c\u800c\u4e0d\u4ec5\u4ec5\u662f\u8ffd\u6c42\u6536\u5165\u589e\u957f\u3002\u6b64\u5916\uff0c\u8be5\u884c\u8ba4\u4e3a\uff0c\u5c3d\u7ba1\u884c\u4e1a\u670d\u52a1\u6536\u5165\u589e\u957f\u653e\u7f13\uff0c\u4f46\u7535\u4fe1\u516c\u53f8\u6709\u671b\u5b9e\u73b0\u5168\u5e74\u5229\u6da6\u6307\u5bfc\uff0c\u5f97\u76ca\u4e8e\u8fd0\u8425\u6760\u6746\u7684\u6539\u5584\u3001\u9700\u6c42\u9a71\u52a8\u7684\u8d44\u672c\u652f\u51fa\u6295\u8d44\uff0c\u4ee5\u53ca\u5c06\u76c8\u5229\u80fd\u529b\u4f5c\u4e3a\u4f01\u4e1a\u4e1a\u52a1\u7684\u9996\u8981\u4efb\u52a1\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259507370", "pub_date": "2024-12-04 14:29:44"}, {"id": 259506322, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5929\u98ce\u8bc1\u5238\u7ef4\u6301\u4e2d\u56fd\u79d1\u57f9(01890)\u4e70\u5165\u8bc4\u7ea7 \u6307\u5b66\u751f\u4eba\u6570\u7a33\u6b65\u589e\u957f", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5929\u98ce\u8bc1\u5238\u53d1\u7814\u6307\uff0c\u4e2d\u56fd\u79d1\u57f9(01890)FY24\u6536\u516516.93\u4ebf\u5143\u540c\u589e11.6%\uff0c\u8c03\u540e\u5f52\u6bcd\u51c0\u52298.3\u4ebf\u5143\u540c\u589e5.1%\u3002\u516c\u53f8\u4fdd\u6301\u7a33\u5b9a\u5206\u7ea2\u6bd4\u4f8b\uff0c\u8ba1\u5212\u6d3e\u53d1\u672b\u671f\u6bcf\u80a1\u80a1\u606f0.06\u6e2f\u5143\uff0c\u4e2d\u671f\u80a1\u606f0.07\u6e2f\u5143\uff0c\u80a1\u606f\u6bd4\u4f8b\u7ea6\u4e3a\u7ecf\u8c03\u6574\u5f52\u6bcd\u51c0\u5229\u6da6\u768428%\u3002<br/><br/>\u8be5\u884c\u6307\uff0c\u6536\u5165\u62c6\u5206\u6765\u770b\uff0c\u516c\u53f8\u5411\u5b66\u751f\u6536\u53d6\u8d39\u7528\u901a\u5e38\u5305\u62ec\u5b66\u8d39\u3001\u4f4f\u5bbf\u8d39\u53ca\u5176\u4ed6\u6559\u80b2\u670d\u52a1\u8d39\u3002\u5b66\u8d39\u4e3a\u4e3b\u8981\u6536\u76ca\uff0c\u622a\u81f32024\u5e748\u670831\u65e5\u6b62\u5e74\u5ea6\u5360\u516c\u53f8\u603b\u6536\u5165\u768493.8%\u3002\u5b66\u8d39/\u4f4f\u5bbf\u8d39/\u5176\u4ed6\u6559\u80b2\u670d\u52a1\u8d39\u6536\u516515.87/0.97/0.08\u4ebf\uff0c\u540c\u6bd4\u589e\u957f+12.4%/+5.1%/-34.2%\uff0c\u6536\u76ca\u589e\u52a0\u4e3b\u8981\u662f\u7531\u4e8e\u4e2d\u56fd\u5b66\u6821\u7684\u5165\u5b66\u5b66\u751f\u4eba\u6570\u53ca\u5e73\u5747\u5b66\u8d39\u7a33\u5b9a\u589e\u957f\u3002<br/><br/>\u8be5\u884c\u8868\u793a\uff0c\u7ef4\u6301\u516c\u53f8\u4e70\u5165\u8bc4\u7ea7\u3002\u57fa\u4e8eFY24\u4e1a\u7ee9\u8868\u73b0\uff0c\u516c\u53f8\u52a0\u5f3a\u6559\u80b2\u8d44\u6e90\u6295\u5165\uff0c\u8be5\u884c\u8c03\u6574FY25-26\u5e74\u76c8\u5229\u9884\u6d4b\uff0c\u5e76\u65b0\u589eFY27\u5e74\u76c8\u5229\u9884\u6d4b\uff1b\u8be5\u884c\u9884\u8ba1FY25-26\u5e74\u6536\u5165\u4e3a17.8\u4ebf\u4eba\u6c11\u5e01\u300118.7\u4ebf\u4eba\u6c11\u5e01\uff08\u539f\u503c\u4e3a17.6\u4ebf\u4eba\u6c11\u5e01\u300119.2\u4ebf\u4eba\u6c11\u5e01\uff09\uff0cFY25-26\u5e74\u8c03\u540e\u5f52\u6bcd\u51c0\u52298.72\u4ebf\u4eba\u6c11\u5e01\u30019.2\u4ebf\u4eba\u6c11\u5e01\uff08\u539f\u503c\u4e3a8.3\u4ebf\u4eba\u6c11\u5e01\u30019.0\u4ebf\u4eba\u6c11\u5e01\uff09\uff0cFY25-26\u5e74EPS\u4e3a0.43\u5143\u4eba\u6c11\u5e01\u30010.46\u5143\u4eba\u6c11\u5e01\uff08\u539f\u503c\u4e3a0.41\u5143\u4eba\u6c11\u5e01\u30010.45\u5143\u4eba\u6c11\u5e01\uff09\uff1bFY27\u5e74\u6536\u5165\u4e3a19.6\u4ebf\u4eba\u6c11\u5e01\uff1b\u8c03\u540e\u5f52\u6bcd\u51c0\u5229\u4e3a9.7\u4ebf\u4eba\u6c11\u5e01\uff1bEPS\u4e3a0.48\u5143\u4eba\u6c11\u5e01\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259506322", "pub_date": "2024-12-04 14:21:10"}, {"id": 259504305, "title": "\u6c99\u7279\u963f\u7f8e\u5b8c\u6210\u5bf9\u96f7\u8bfa\u3001\u5409\u5229\u5408\u8d44\u516c\u53f810%\u7684\u80a1\u6743\u6536\u8d2d", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6c99\u7279\u963f\u7f8e\u4e8e12\u67082\u65e5\u900f\u9732\uff0c\u5176\u5168\u8d44\u5b50\u516c\u53f8Aramco Asia Singapore Pte. Ltd.\u5df2\u7ecf\u987a\u5229\u5b8c\u6210\u4e86\u5bf9Horse\u52a8\u529b\u603b\u6210\u516c\u53f810%\u80a1\u4efd\u7684\u6536\u8d2d\u3002\u6b64\u6b21\u4ea4\u6613\u57fa\u4e8e2024\u5e746\u670828\u65e5\u7b7e\u8ba2\u7684\u6700\u7ec8\u534f\u8bae\uff0c\u5e76\u5df2\u83b7\u5f97\u4e86\u6240\u6709\u5fc5\u8981\u7684\u76d1\u7ba1\u673a\u6784\u6279\u51c6\u3002\u6c99\u7279\u963f\u7f8e\u4f9d\u636e\u516c\u53f874\u4ebf\u6b27\u5143\u7684\u4f30\u503c\u8fdb\u884c\u4e86\u6295\u8d44\uff0c\u800c\u96f7\u8bfa\u96c6\u56e2\u548c\u5409\u5229\u96c6\u56e2\uff08\u901a\u8fc7\u6d59\u6c5f\u5409\u5229\u63a7\u80a1\u96c6\u56e2\u53ca\u5409\u5229\u6c7d\u8f66\u63a7\u80a1\u6709\u9650\u516c\u53f8\uff09\u5404\u6301\u6709Horse\u52a8\u529b\u603b\u6210\u516c\u53f845%\u7684\u80a1\u4efd\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259504305", "pub_date": "2024-12-04 14:05:58"}, {"id": 259504434, "title": "\u767e\u5ea6(BIDU)\u6b63\u5f0f\u53d1\u5e03Apollo\u5f00\u653e\u5e73\u53f010.0\u7248\u672c", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u767e\u5ea6(BIDU)\u6b63\u5f0f\u53d1\u5e03Apollo\u5f00\u653e\u5e73\u53f0\u7684\u5168\u65b0\u5347\u7ea7\u7248\u672c\u2014\u2014Apollo\u5f00\u653e\u5e73\u53f010.0\u3002</p><p>Apollo\u5f00\u653e\u5e73\u53f010.0\u4e0d\u4ec5\u5728\u8f6f\u4ef6\u6838\u5fc3\u5c42\u3001\u5e94\u7528\u8f6f\u4ef6\u5c42\u3001\u5de5\u5177\u670d\u52a1\u5c42\u8fdb\u884c\u4e86\u91cd\u5927\u5347\u7ea7\uff0c\u8fd8\u901a\u8fc7\u81ea\u52a8\u9a7e\u9a76\u5927\u6a21\u578bADFM\u91cd\u6784\u7b97\u6cd5\uff0c\u63d0\u5347\u4e86\u6838\u5fc3\u7b97\u6cd5\u6a21\u5757\u6548\u679c\u3002</p>", "link": "https://sky.szfiu.com/info/hk/details/259504434", "pub_date": "2024-12-04 14:06:15"}, {"id": 259504433, "title": "\u3010\u5238\u5546\u805a\u7126\u3011\u5df4\u514b\u83b1\u94f6\u884c\uff1a\u82f1\u7279\u5c14(INTC)CEO\u66f4\u8fed\u4e0e\u8fc8\u5a01\u5c14(MRVL)/\u4e9a\u9a6c\u900a(AMZN)\u5408\u4f5c \u91cd\u5851\u534a\u5bfc\u4f53\u884c\u4e1a\u683c\u5c40", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5df4\u514b\u83b1\u94f6\u884c\u9488\u5bf9\u82f1\u7279\u5c14\u516c\u53f8CEO Pat Gelsinger\u7684\u9000\u4f11\u4ee5\u53ca\u8fc8\u5a01\u5c14\u4e0e\u4e9a\u9a6c\u900a\u7684\u6218\u7565\u8054\u76df\u8fdb\u884c\u4e86\u6df1\u5165\u5206\u6790\u3002\u62a5\u544a\u63d0\u5230\uff0c\u82f1\u7279\u5c14CEO Pat Gelsinger\u5df2\u4e8e2024\u5e7412\u67081\u65e5\u6b63\u5f0f\u9000\u4f11\uff0c\u5e76\u79bb\u5f00\u4e86\u8463\u4e8b\u4f1a\uff0c\u76ee\u524d\u7531Michelle Johnston Holthaus\u548cCFO David Zinsner\u62c5\u4efb\u4e34\u65f6\u8054\u5e2dCEO\uff0c\u76f4\u81f3\u9009\u51fa\u65b0\u7684CEO\u3002<br/><br/>\u4e0e\u6b64\u540c\u65f6\uff0c\u8fc8\u5a01\u5c14\u79d1\u6280(MRVL)\u4e0e\u4e9a\u9a6c\u900a(AMZN)\u8fbe\u6210\u4e86\u4e3a\u671f\u4e94\u5e74\u7684\u5408\u4f5c\u534f\u8bae\uff0c\u53cc\u65b9\u5c06\u56f4\u7ed5AWS\u4ea7\u54c1\u5c55\u5f00\u591a\u4ee3\u6846\u67b6\u5408\u4f5c\uff0c\u6d89\u53ca\u5b9a\u5236AI\u4ea7\u54c1\u3001\u5149\u5b50DSP\u3001AEC DSP\u3001PCIe\u91cd\u5b9a\u65f6\u5668\u3001DCI\u5149\u6a21\u5757\u548c\u4ee5\u592a\u7f51\u4ea4\u6362\u7845\u7b49\u3002\u6839\u636e\u534f\u8bae\uff0c\u8fc8\u5a01\u5c14\u5c06\u5411\u4e9a\u9a6c\u900a\u53d1\u884c\u4e00\u4efd\u6743\u8bc1\uff0c\u4f7f\u5176\u80fd\u591f\u6536\u8d2d\u9ad8\u8fbe418\u4e07\u80a1\u7684\u8fc8\u5a01\u5c14\u666e\u901a\u80a1\uff0c\u5176\u4e2d390\u4e07\u80a1\u7684\u5f52\u5c5e\u5c06\u57fa\u4e8e\u4e9a\u9a6c\u900a\u4e0e\u8fc8\u5a01\u5c14\u7684\u5408\u4f5c\u652f\u51fa\u3002<br/><br/>\u5df4\u514b\u83b1\u94f6\u884c\u7684\u5206\u6790\u5e08\u8ba4\u4e3a\uff0c\u82f1\u7279\u5c14\u572818A\u5de5\u827a\u8282\u70b9\u4e0a\u7684\u6311\u6218\u9884\u793a\u7740Gelsinger\u65f6\u4ee3\u7684\u7ed3\u675f\uff0c\u800cZinsner\u7684\u63d0\u5347\u53cd\u6620\u4e86\u4ed6\u5728\u516c\u53f8\u672a\u6765\u53d1\u5c55\u4e2d\u7684\u5173\u952e\u4f5c\u7528\u3002\u5206\u6790\u5e08\u9884\u6d4b\uff0c\u82f1\u7279\u5c14\u76844\u8282\u70b9\u6218\u7565\uff0c\u4f5c\u4e3aGelsinger\u65f6\u4ee3\u7684\u6807\u5fd7\u6027\u627f\u8bfa\uff0c\u5176\u6210\u529f\u4e0e\u5426\u5c06\u5bf9IFS\u548c\u82f1\u7279\u5c14\u4ea7\u54c1\u96c6\u56e2\u4ea7\u751f\u91cd\u5927\u5f71\u54cd\u3002\u5bf9\u4e8e\u8fc8\u5a01\u5c14\u800c\u8a00\uff0c\u4e0e\u4e9a\u9a6c\u900a\u7684\u5408\u4f5c\u4e0d\u4ec5\u5de9\u56fa\u4e86\u5176\u5728AWS\u4f9b\u5e94\u94fe\u4e2d\u7684