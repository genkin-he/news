1c5.6\u201d \u516c\u53f8\u5728\u85fb\u6cb9DHA\u5e02\u573a\u4e2d\u5e02\u5360\u7387\u7b2c\u4e00", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u56fd\u8bc1\u56fd\u9645\u53d1\u7814\u6307\uff0c\u7ebd\u66fc\u601d(02530)\u662f\u4e00\u5bb6\u8425\u517b\u54c1\u9500\u552e\u516c\u53f8\uff0c\u4e3b\u8981\u4ea7\u54c1\u4e3a\u201c\u7ebd\u66fc\u601d\u85fb\u6cb9DHA\u201d\uff0c\u4e3b\u8981\u9488\u5bf9\u5b55\u4ea7\u5987\u3001\u5a74\u5e7c\u513f\u5ba2\u7fa4\u3002\u5176\u4ed6\u4ea7\u54c1\u5305\u62ec\u76ca\u751f\u83cc\u3001\u7ef4\u751f\u7d20\u3001\u591a\u7ef4\u8425\u517b\u7d20\u3001\u85fb\u9499\u3001\u5976\u7c89\u7b49\u4ea7\u54c1\u30022022\u30012023\u5168\u5e74\u548c2024\u5e74\u524d\u516d\u4e2a\u6708\uff0c\u516c\u53f8\u7684\u6536\u5165\u5206\u522b\u4e3a\u4eba\u6c11\u5e013.7\u4ebf\u30014.3\u4ebf\u548c1.5\u4ebf\u4eba\u6c11\u5e01\uff0c\u540c\u6bd4\u589e\u957f8.8%\u300116.1%\u548c-23.9%;\u51c0\u5229\u6da6\u5206\u522b\u4e3a0.87\u4ebf\u30011.59\u4ebf\u30010.45\u4ebf\u4eba\u6c11\u5e01\uff0c\u540c\u6bd4\u589e\u957f-26.8%\u300182%\u3001-41%\u300224\u5e74\u7531\u4e8e\u5b8f\u89c2\u73af\u5883\u8f83\u5f31\uff0c\u516c\u53f8\u7684\u4e1a\u7ee9\u51fa\u73b0\u4e0b\u6ed1\u3002</p><p>\u8be5\u884c\u6307\uff0c2023\u5e74\u4e2d\u56fd\u8425\u517b\u54c1\u5e02\u573a\u89c4\u6a21\u4e3a2601\u4ebf\uff0c\u8fc7\u53bb\u4e94\u5e74\u5e74\u5316\u589e\u901f\u4e3a10%\u3002\u6bcd\u5a74\u8425\u517b\u54c1\u5e02\u573a\u5360\u6bd4\u7ea639%\uff0c\u89c4\u6a21\u4e3a1017\u4ebf\uff0c\u8fc7\u53bb\u4e94\u5e74\u589e\u901f10.8%\u3002\u85fb\u6cb9DHA\u5e02\u573a\u662f\u5176\u4e2d\u7684\u4e00\u4e2a\u7ec6\u5206\u8d5b\u9053\uff0c2023\u5e74\u5e02\u573a\u89c4\u6a21\u4e3a140\u4ebf\uff0c\u8fc7\u53bb\u4e94\u5e74\u589e\u901f15%\uff0c\u589e\u901f\u8f83\u9ad8\u3002\u800c\u516c\u53f8\u7684\u4ea7\u54c1\u4e3a\u56fd\u5185\u54c1\u724c\uff08\u8fdb\u53e3\u539f\u6750\u6599\uff09\u8fd9\u4e00\u7c7b\u3002\u6bcd\u5a74\u85fb\u6cb9DHA\u884c\u4e1a\u53c2\u4e0e\u8005\u6709100\u591a\u5bb6\uff0c\u7ade\u4e89\u8f83\u4e3a\u6fc0\u70c8\uff0c\u516c\u53f8\u5e02\u5360\u7387\u4e3a20.5%\uff0c\u6392\u540d\u7b2c\u4e00\u3002\u524d\u4e94\u5927\u73a9\u5bb6\u5e02\u5360\u7387\u4e3a62%\u3002\u5728\u85fb\u6cb9DHA\u884c\u4e1a\u4e2d\uff0c\u516c\u53f8\u7684\u5e02\u5360\u7387\u4e3a4.7%\uff0c\u6392\u540d\u7b2c\u4e00\uff0c\u5177\u6709\u54c1\u724c\u77e5\u540d\u5ea6\uff0c\u524d\u4e94\u5927\u5e02\u5360\u738718.4%\u3002\u6574\u4f53\u6765\u770b\uff0c\u7ade\u4e89\u683c\u5c40\u8fd8\u662f\u6bd4\u8f83\u5206\u6563\u3002</p><p>\u8be5\u884c\u8868\u793a\uff0c\u6b64\u6b21\u4e0a\u5e02\u6ca1\u6709\u57fa\u77f3\u6295\u8d44\u4eba\u3002\u72ec\u5bb6\u4fdd\u8350\u4eba\u4e3a\u8d22\u901a\u56fd\u9645\u3002\u516c\u53f8\u6b64\u6b21IPO\u53d1\u884c\u4ef7\u4e3a0.8-1.09\u6e2f\u5143\uff0c\u53d1\u884c\u540e\u603b\u5e02\u503c\u7ea6\u4e3a8-10.9\u4ebf\u6e2f\u5143\uff08\u4e0d\u5305\u62ec\u8d85\u989d\u914d\u552e\uff09\u3002\u8003\u8651\u523024\u5e74\u51fa\u73b0\u4e86\u6bd4\u8f83\u660e\u663e\u7684\u4e0b\u6ed1\uff0c\u8be5\u884c\u6309\u7167\u540c\u6837\u7684\u4e0b\u6ed1\u5e45\u5ea6\u4f30\u7b97\u5168\u5e74\u51c0\u5229\u6da6\uff0c\u5e76\u5c31\u6b64\u8ba1\u7b97\u7684IPOPE\u500d\u6570\u4e3a8.5-11.6x\uff0c\u4f30\u503c\u8f83\u4e3a\u5408\u7406\u3002\u8fd1\u671f\u6e2f\u80a1\u5e02\u573a\u6253\u65b0\u70ed\u60c5\u8f83\u4e3a\u9ad8\u6da8\uff0c\u7efc\u5408\u8003\u8651\u8be5\u884c\u7ed9\u4e88IPO\u4e13\u7528\u8bc4\u7ea7\u201c5.6\u201d\u3002<br/><br/></p>", "link": "https://ipo.jinwucj.com/info/infoDetails/6113", "pub_date": "2025-01-03 16:00:37", "source": "jinwucj", "kind": 1, "language": "zh-CN"}, {"id": 6112, "title": "\u3010\u65b0\u80a1IPO\u3011\u4e0d\u540c\u96c6\u56e2\u5411\u6e2f\u4ea4\u6240\u4e3b\u677f\u63d0\u4ea4\u4e0a\u5e02\u7533\u8bf7", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u6e2f\u4ea4\u62401\u67082\u65e5\u62ab\u9732\uff0c\u4e0d\u540c\u96c6\u56e2\u5411\u6e2f\u4ea4\u6240\u4e3b\u677f\u63d0\u4ea4\u4e0a\u5e02\u7533\u8bf7\uff0c\u4e2d\u4fe1\u8bc1\u5238\u3001\u6d77\u901a\u56fd\u9645\u4e3a\u8054\u5e2d\u4fdd\u8350\u4eba\u3002<br/><br/>\u516c\u53f8\u662f\u4e00\u5bb6\u65b0\u5174\u7684\u5bb6\u5ead\u751f\u6d3b\u4ea7\u54c1\u79d1\u6280\u516c\u53f8\uff0c\u81f4\u529b\u4e8e\u901a\u8fc7\u5bf9\u7528\u6237\u7684\u524d\u77bb\u6d1e\u5bdf\u548c\u524d\u6cbf\u6750\u6599\u3001\u5de5\u827a\u53ca\u6280\u672f\u7684\u521b\u65b0\u5e94\u7528\uff0c\u4e3a\u5bb6\u5ead\u591a\u751f\u6d3b\u573a\u666f\u521b\u9020\u5177\u6709\u72ec\u7279\u7528\u6237\u4ef7\u503c\u7684\u4ea7\u54c1\u3002<br/><br/>\u8d22\u52a1\u65b9\u9762\uff0c\u516c\u53f8\u4e8e2022\u5e74\u30012023\u5e74\u53ca2024\u5e74\u622a\u81f39\u670830\u65e5\u6b62\u4e5d\u4e2a\u6708\uff0c\u5206\u522b\u5f55\u5f97\u6536\u51655.07\u4ebf\u5143(\u4eba\u6c11\u5e01\uff0c\u4e0b\u540c)\u30018.52\u4ebf\u5143\u30018.84\u4ebf\u5143\u3002\u5bf9\u5e94\u540c\u671f\uff0c(\u4e8f\u635f)\uff0f\u6ea2\u5229\u5206\u522b\u4e3a(2122.9\u4e07\u5143)\u30012722.4\u4e07\u5143\u30014642.1\u4e07\u5143\u3002</p>", "link": "https://ipo.jinwucj.com/info/infoDetails/6112", "pub_date": "2025-01-02 22:56:56", "source": "jinwucj", "kind": 1, "language": "zh-CN"}, {"id": 6111, "title": "\u3010\u65b0\u80a1IPO\u3011\u201c\u4e2d\u56fd\u7248\u4e50\u9ad8\u201d\u5e03\u9c81\u53ef(00325)IPO\u53d7\u6563\u6237\u8ffd\u6367 \u6682\u5f55\u5b56\u5c55\u989d\u903e4578\u4ebf\u6e2f\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u5e03\u9c81\u53ef(00325)\u4e8e12\u670831\u65e5\u8d77\u62db\u80a1\uff0c\u6295\u8d44\u8005\u7533\u8d2d\u60c5\u7eea\u6d53\u539a\u3002\u622a\u81f31\u67082\u65e5\u4e2d\u534812:08\u5206\uff0c\u5e03\u9c81\u53ef\u5df2\u5f55\u5f97\u5b56\u5c55\u989d4578.41\u4ebf\u6e2f\u5143\uff0c\u8ba4\u8d2d\u500d\u6570\u8fbe3144.89\u500d\u3002</p><p>\u5176\u4e2d\uff0c\u5bcc\u9014\u8bc1\u5238\u501f\u51fa2507.85\u4ebf\u6e2f\u5143\uff0c\u5360\u6bd454.59%\uff1b\u8f89\u7acb\u8bc1\u5238\u501f\u51fa1460\u4ebf\u6e2f\u5143\uff1b\u4fe1\u8bda\u8bc1\u5238\u501f\u51fa300\u4ebf\u6e2f\u5143\uff1b\u8000\u624d\u8bc1\u5238\u501f\u51fa150\u4ebf\u5143\u3002</p><p>\u56fd\u8bc1\u56fd\u9645\u53d1\u7814\u62a5\u6307\uff0c\u516c\u53f8\u6210\u7acb\u4e8e2014\u5e74\uff0c\u4e3b\u8981\u4ea7\u54c1\u662f\u62fc\u642d\u89d2\u8272\u7c7b\u73a9\u5177\uff0c\u6709\u7740\u201c\u4e2d\u56fd\u7248\u4e50\u9ad8\u201d\u4e4b\u79f0\u3002\u622a\u81f32024\u5e746\u670830\u65e5\uff0c\u516c\u53f8\u5171\u6709431\u6b3e\u5728\u552eSKU\uff0c\u5305\u62ec\u4e3b\u8981\u9762\u54116\u5c81\u4ee5\u4e0b\u513f\u7ae5\u7684116\u6b3eSKU\u3001\u4e3b\u8981\u9762\u54116\u81f316\u5c81\u4eba\u7fa4\u7684295\u6b3eSKU\uff0c\u4ee5\u53ca\u4e3b\u8981\u9762\u541116\u5c81\u4ee5\u4e0a\u4eba\u7fa4\u768420\u6b3eSKU\u3002\u4e3b\u6d41\u4ea7\u54c1\u4ef7\u683c\u57289.9\u5143\u81f3399\u5143\u4e0d\u7b49\uff0c\u70ed\u9500\u7684\u5927\u4f17\u4ef7\u683c\u5e26\u4ea7\u54c1\u5b9a\u4ef7\u4e3a39\u5143\uff0c\u5e73\u4ef7\u4ef7\u683c\u5e26\u4ea7\u54c1\u5b9a\u4ef7\u4e3a9.9\u5143\u81f319.9\u5143\u3002</p><p>\u8be5\u884c\u6307\uff0c\u6b64\u6b21\u4e0a\u5e02\u57fa\u77f3\u6295\u8d44\u4eba\u6709\u666f\u6797\u3001UBS AM\u3001\u5bcc\u56fd\u57fa\u91d1\u3001\u5bcc\u56fd\u9999\u6e2f\uff0c\u5408\u8ba1\u7533\u8d2d\u5360\u6bd4\u7ea6\u4e09\u6210\u3002\u516c\u53f8\u6b64\u6b21IPO\u53d1\u884c\u4ef7\u4e3a55.65-60.35\u6e2f\u5143\uff0c\u53d1\u884c\u540e\u603b\u5e02\u503c\u7ea6\u4e3a134.38-145.73\u4ebf\u6e2f\u5143\uff08\u4e0d\u5305\u62ec\u8d85\u989d\u914d\u552e\uff09\uff0c\u6839\u636e2023\u53ca2024\u5e74\u4e0a\u534a\u5e74\u7ecf\u8c03\u6574\u51c0\u5229\u6da6\u8ba1\u7b97\uff0cPE-TTM\u4e3a35.7-38.7x\u3002\u8c37\u5b50\u7ecf\u6d4e\u5e26\u52a8\u6f6e\u6d41\u73a9\u5177\u5e02\u573a\u70ed\u5ea6\u63d0\u5347\uff0c\u53e0\u52a0\u8fd1\u671f\u6e2f\u80a1\u6253\u65b0\u60c5\u7eea\u76f8\u5bf9\u8f83\u597d\uff0c\u7efc\u5408\u8003\u8651\u8be5\u884c\u7ed9\u4e88IPO\u4e13\u7528\u8bc4\u7ea7\u201c5.8\u201d\uff0c\u5efa\u8bae\u7533\u8d2d\u3002&nbsp;</p>", "link": "https://ipo.jinwucj.com/info/infoDetails/6111", "pub_date": "2025-01-02 14:39:22", "source": "jinwucj", "kind": 1, "language": "zh-CN"}, {"id": 6110, "title": "\u3010\u65b0\u80a1IPO\u3011\u871c\u96ea\u51b0\u57ce\u5411\u6e2f\u4ea4\u6240\u4e3b\u677f\u63d0\u4ea4\u4e0a\u5e02\u7533\u8bf7", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u6e2f\u4ea4\u62401\u67081\u65e5\u62ab\u9732\uff0c\u871c\u96ea\u51b0\u57ce\u5411\u6e2f\u4ea4\u6240\u4e3b\u677f\u63d0\u4ea4\u4e0a\u5e02\u7533\u8bf7\uff0c\u7f8e\u94f6\u3001\u9ad8\u76db\u3001\u745e\u94f6\u4e3a\u8054\u5e2d\u4fdd\u8350\u4eba\u3002<br/><br/>\u516c\u53f8\u662f\u4e00\u5bb6\u73b0\u5236\u996e\u54c1\u4f01\u4e1a\uff0c\u65d7\u4e0b\u6709\u73b0\u5236\u8336\u996e\u54c1\u724c\u201c\u871c\u96ea\u51b0\u57ce\u201d\u548c\u73b0\u78e8\u5496\u5561\u54c1\u724c\u201c\u5e78\u8fd0\u5496\u201d\u3002<br/><br/>\u622a\u81f32024\u5e749\u6708\u5e95,\u8be5\u516c\u53f8\u901a\u8fc7\u52a0\u76df\u6a21\u5f0f\u53d1\u5c55\u7684\u95e8\u5e97\u7f51\u7edc\u62e5\u6709\u8d85\u8fc74.5\u4e07\u5bb6\u95e8\u5e97,\u8986\u76d6\u4e2d\u56fd\u53ca\u6d77\u591611\u4e2a\u56fd\u5bb6,\u5305\u62ec\u5370\u5c3c\u3001\u8d8a\u5357\u3001\u9a6c\u6765\u897f\u4e9a\u3001\u6cf0\u56fd\u3001\u83f2\u5f8b\u5bbe\u3001\u67ec\u57d4\u5be8\u3001\u8001\u631d\u3001\u65b0\u52a0\u5761\u3001\u6fb3\u6d32\u3001\u5357\u97e9\u53ca\u65e5\u672c\u3002<br/><br/>\u8d22\u52a1\u65b9\u9762\uff0c\u516c\u53f8\u4e8e2021\u5e74\u81f32023\u5e74\u53ca2024\u5e74\u99969\u6708\uff0c\u5206\u522b\u5f55\u5f97\u6536\u5165103.51\u4ebf\u3001135.56\u4ebf\u3001203.02\u4ebf\u53ca186.6\u4ebf\u5143\u4eba\u6c11\u5e01\uff1b\u540c\u671f\u5bf9\u5e94\u671f\u5185\u5229\u6da619.12\u4ebf\u300120.1\u4ebf\u300131.87\u4ebf\u53ca34.91\u4ebf\u5143\u4eba\u6c11\u5e01\u3002</p>", "link": "https://ipo.jinwucj.com/info/infoDetails/6110", "pub_date": "2025-01-02 08:24:41", "source": "jinwucj", "kind": 1, "language": "zh-CN"}, {"id": 6109, "title": "\u3010\u65b0\u80a1IPO\u3011\u5317\u4eac\u540c\u4ec1\u5802\u533b\u517b\u6295\u8d44\u80a1\u4efd\u5411\u6e2f\u4ea4\u6240\u4e3b\u677f\u63d0\u4ea4\u4e0a\u5e02\u7533\u8bf7", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u6e2f\u4ea4\u624012\u670831\u65e5\u62ab\u9732\uff0c\u5317\u4eac\u540c\u4ec1\u5802\u533b\u517b\u6295\u8d44\u80a1\u4efd\u5411\u6e2f\u4ea4\u6240\u4e3b\u677f\u63d0\u4ea4\u4e0a\u5e02\u7533\u8bf7\uff0c\u4e2d\u91d1\u516c\u53f8\u4e3a\u72ec\u5bb6\u4fdd\u8350\u4eba\u3002<br/><br/>\u516c\u53f8\u662f\u4e00\u5bb6\u9886\u5148\u7684\u4e2d\u533b\u533b\u7597\u96c6\u56e2\uff0c\u6309\u7167\u8fde\u9501\u533b\u9662\u3001\u57fa\u5c42\u8fde\u9501\u533b\u7597\u673a\u6784(\u5305\u62ec\u95e8\u8bca\u90e8\u3001\u8bca\u6240\u53ca\u793e\u533a\u536b\u751f\u673a\u6784\uff0c\u5747\u4e3a\u4e2d\u56fd\u72ec\u7acb\u533b\u7597\u673a\u6784\uff0c\u6301\u6709\u4e0d\u540c\u7c7b\u522b\u7684\u6267\u7167\u6216\u8bc1\u4e66\u8fdb\u884c\u6267\u4e1a)\u53ca\u4e92\u8054\u7f51\u533b\u9662\u4e09\u4e2a\u5c42\u7ea7\u6784\u6210\u81ea\u6709\u548c\u7ba1\u7406\u533b\u7597\u673a\u6784\u3002\u7ed3\u5408\u201c\u533b\u201d\u4e0e\u201c\u517b\u201d\uff0c\u516c\u53f8\u63d0\u4f9b\u73b0\u4ee3\u5316\u3001\u5b9a\u5236\u5316\u7684\u4e2d\u533b\u533b\u7597\u670d\u52a1\uff0c\u4ee5\u6807\u51c6\u5316\u7ba1\u7406\u8986\u76d6\u5168\u573a\u666f\uff0c\u5229\u7528\u4f18\u52bf\u4e13\u79d1\u5e76\u91c7\u7528\u4e2d\u533b\u836f\u7269\u548c\u975e\u836f\u7269\u6cbb\u7597\u76f8\u7ed3\u5408\u7684\u65b9\u5f0f\uff0c\u4e3a\u5ba2\u6237\u63d0\u4f9b\u6700\u5408\u9002\u7684\u65b9\u6848\u3002\u622a\u81f3\u6700\u540e\u5b9e\u9645\u53ef\u884c\u65e5\u671f\uff0c\u516c\u53f8\u5df2\u5efa\u7acb\u5206\u7ea7\u533b\u7597\u670d\u52a1\u7f51\u7edc\uff0c\u5305\u62ec11\u5bb6\u81ea\u6709\u7ebf\u4e0b\u533b\u7597\u673a\u6784\u53ca\u4e00\u5bb6\u4e92\u8054\u7f51\u533b\u9662\uff0c\u4ee5\u53ca11\u5bb6\u7ebf\u4e0b\u7ba1\u7406\u533b\u7597\u673a\u6784\u3002\u901a\u8fc7\u7ebf\u4e0b\u7ebf\u4e0a\u4e00\u4f53\u5316\u670d\u52a1\u7f51\u7edc\uff0c\u516c\u53f8\u89e6\u8fbe\u548c\u670d\u52a1\u904d\u53ca\u5168\u56fd\u5404\u5730\u7684\u5ba2\u6237\u3002<br/><br/>\u8d22\u52a1\u65b9\u9762\uff0c\u516c\u53f8\u4e8e2021\u5e74\u81f32023\u5e74\u53ca2024\u5e74\u622a\u81f36\u670830\u65e5\u6b62\u4e5d\u4e2a\u6708\u5206\u522b\u5f55\u5f97\u6536\u51656.9\u4ebf\u5143(\u4eba\u6c11\u5e01\uff0c\u4e0b\u540c)\u30019.11\u4ebf\u5143\u300111.53\u4ebf\u5143\u30018.33\u4ebf\u5143\u3002\u5bf9\u5e94\u540c\u671f\u6bcd\u516c\u53f8\u62e5\u6709\u4eba\u5e94\u5360\u5229\u6da6/(\u4e8f\u635f)\u4e3a(47)\u4e07\u5143\u3001(1629.6)\u4e07\u5143\u30012233.8\u4e07\u5143\u30012249.9\u4e07\u5143\u3002</p>", "link": "https://ipo.jinwucj.com/info/infoDetails/6109", "pub_date": "2024-12-31 23:07:47", "source": "jinwucj", "kind": 1, "language": "zh-CN"}, {"id": 6108, "title": "\u3010\u65b0\u80a1IPO\u3011\u91cf\u5316\u6d3e\u79d1\u6280\u5411\u6e2f\u4ea4\u6240\u4e3b\u677f\u63d0\u4ea4\u4e0a\u5e02\u7533\u8bf7", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u6e2f\u4ea4\u624012\u670831\u65e5\u62ab\u9732\uff0c\u91cf\u5316\u6d3e\u79d1\u6280\u5411\u6e2f\u4ea4\u6240\u4e3b\u677f\u63d0\u4ea4\u4e0a\u5e02\u7533\u8bf7\uff0c\u4e2d\u4fe1\u8bc1\u5238\u548c\u4e2d\u91d1\u516c\u53f8\u4e3a\u8054\u5e2d\u4fdd\u8350\u4eba\u3002<br/><br/>\u516c\u53f8\u662f\u4e00\u5bb6\u4e2d\u56fd\u7684\u7cbe\u51c6\u64ae\u5408\u89e3\u51b3\u65b9\u6848\u63d0\u4f9b\u5546\uff0c\u8fd0\u7528\u516c\u53f8\u7684\u6280\u672f\u53ca\u4e13\u6709\u7f51\u7ad9\u53ca\u5e94\u7528\u7a0b\u5e8f(\u5373\u7f8a\u5c0f\u54a9\u53ca\u6d88\u8d39\u5730\u56fe)\u4e3a\u4e0d\u540c\u4e1a\u52a1\u4f19\u4f34\u63d0\u4f9b\u6d88\u8d39\u76f8\u5173\u7cbe\u51c6\u64ae\u5408\u89e3\u51b3\u65b9\u6848\uff0c\u5373\uff1a(1)\u516c\u53f8\u4e3a\u5546\u54c1\u4f9b\u5e94\u5546\u7684\u6d88\u8d39\u54c1\u5339\u914d\u7ec8\u7aef\u8d2d\u4e70\u8005\uff1b(2)\u516c\u53f8\u4e3a\u672c\u5730\u5546\u6237(\u5c24\u5176\u662f4S\u5e97)\u7684\u5546\u54c1\u53ca\u670d\u52a1\u5339\u914d\u7ec8\u7aef\u6d88\u8d39\u8005\uff1b\u53ca(3)\u516c\u53f8\u4e3a\u91d1\u878d\u673a\u6784\u5339\u914d\u6f5c\u5728\u7ec8\u7aef\u501f\u6b3e\u4eba\u3002\u6839\u636e\u5f17\u82e5\u65af\u7279\u6c99\u5229\u6587\u7684\u8d44\u6599\uff0c\u4e8e2023\u5e74\u6309\u6536\u5165\u8ba1\uff0c\u516c\u53f8\u5728\u4e2d\u56fd\u57fa\u4e8e\u4e13\u6709\u5e94\u7528\u7a0b\u5e8f\u2571\u7f51\u7ad9\u7684\u6d88\u8d39\u5e02\u573a\u7cbe\u51c6\u64ae\u5408\u89e3\u51b3\u65b9\u6848\u7684\u63d0\u4f9b\u5546\u4e2d\u6392\u540d\u7b2c\u4e03\uff0c\u5360\u5e02\u573a\u4efd\u989d\u76840.7%\u3002\u4e8e2023\u5e74\uff0c\u57fa\u4e8e\u4e13\u6709\u5e94\u7528\u7a0b\u5e8f\u2571\u7f51\u7ad9\u7684\u6d88\u8d39\u5e02\u573a\u7cbe\u51c6\u64ae\u5408\u89e3\u51b3\u65b9\u6848\u7684\u5e02\u573a\u5360\u6574\u4e2a\u7cbe\u51c6\u64ae\u5408\u89e3\u51b3\u65b9\u6848\u5e02\u573a\u768419.0%\u3002<br/><br/>\u8d22\u52a1\u65b9\u9762\uff0c\u516c\u53f8\u4e8e2021\u5e74\u81f32023\u5e74\u53ca2024\u5e74\u622a\u81f36\u670830\u65e5\u6b62\u516d\u4e2a\u6708\u5206\u522b\u5f55\u5f97\u6536\u51653.51\u4ebf\u5143(\u4eba\u6c11\u5e01\uff0c\u4e0b\u540c)\u30014.75\u4ebf\u5143\u30015.3\u4ebf\u5143\u30013.82\u4ebf\u5143\u3002\u5bf9\u5e94\u540c\u671f\u516c\u53f8\u6743\u76ca\u80a1\u4e1c\u5e94\u5360\u6ea2\u5229/(\u4e8f\u635f)5400.9\u4e07\u5143\u3001(28.3\u4e07\u5143)\u3001364.3\u4e07\u5143\u30014593.6\u4e07\u5143\u3002</p>", "link": "https://ipo.jinwucj.com/info/infoDetails/6108", "pub_date": "2024-12-31 22:50:57", "source": "jinwucj", "kind": 1, "language": "zh-CN"}, {"id": 6107, "title": "\u3010\u65b0\u80a1IPO\u3011\u5317\u4eac\u9996\u94a2\u6717\u6cfd\u79d1\u6280\u80a1\u4efd\u5411\u6e2f\u4ea4\u6240\u4e3b\u677f\u63d0\u4ea4\u4e0a\u5e02\u7533\u8bf7", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u636e\u6e2f\u4ea4\u624012\u670831\u65e5\u62ab\u9732\uff0c\u5317\u4eac\u9996\u94a2\u6717\u6cfd\u79d1\u6280\u80a1\u4efd\u5411\u6e2f\u4ea4\u6240\u4e3b\u677f\u63d0\u4ea4\u4e0a\u5e02\u7533\u8bf7\uff0c\u56fd\u6cf0\u541b\u5b89\u56fd\u9645\u4e3a\u72ec\u5bb6\u4fdd\u8350\u4eba\u3002<br/><br/>\u516c\u53f8\u81f4\u529b\u4e8e\u63a8\u8fdb\u4e2d\u56fd\u5b9e\u73b0\u53cc\u78b3\u76ee\u6807\uff0c\u5e2e\u52a9\u5168\u7403\u5e94\u5bf9\u6c14\u5019\u53d8\u5316\uff0c\u4ee5\u53ca\u4e3a\u5168\u7403\u63d0\u4f9b\u7eff\u8272\u3001\u7ecf\u6d4e\u53ca\u4f18\u8d28\u7684\u4f4e\u78b3\u4ea7\u54c1\u3002\u6839\u636e\u5f17\u82e5\u65af\u7279\u6c99\u5229\u6587\u7684\u8d44\u6599\uff0c\u622a\u81f3\u6700\u540e\u5b9e\u9645\u53ef\u884c\u65e5\u671f\uff0c\u516c\u53f8\u662f\u5168\u7403CCUS\u884c\u4e1a\u4e2d\u552f\u4e00\u4e00\u5bb6\u5229\u7528\u7ecf\u8fc7\u9a8c\u8bc1\u7684\u5408\u6210\u751f\u7269\u6280\u672f\u5b9e\u73b0\u4f4e\u78b3\u4ea7\u54c1\u751f\u4ea7\u5546\u4e1a\u5316\u53ca\u89c4\u6a21\u5316\u7684\u516c\u53f8\u3002\u6839\u636e\u5f17\u82e5\u65af\u7279\u6c99\u5229\u6587\u7684\u8d44\u6599\uff0c\u516c\u53f8\u5b9e\u73b0\u4e86\u591a\u4e2a\u7a81\u7834\u6027\u521b\u65b0(\u6bd4\u5982\u5b8c\u6210\u4e86\u5168\u7403\u9996\u5957\u5229\u7528\u94a2\u94c1\u5382\u3001\u94c1\u5408\u91d1\u5382\u4ea7\u751f\u7684\u542b\u78b3\u5de5\u4e1a\u5c3e\u6c14\u901a\u8fc7\u751f\u7269\u53d1\u9175\u5de5\u827a\u751f\u4ea7\u4e59\u9187\u53ca\u5fae\u751f\u7269\u86cb\u767d\u7684\u5de5\u4e1a\u5316\u88c5\u7f6e)\u3002\u622a\u81f3\u6700\u540e\u5b9e\u9645\u53ef\u884c\u65e5\u671f\uff0c\u516c\u53f8\u5728\u4e2d\u56fd\u6210\u529f\u6295\u5165\u8fd0\u8425\u56db\u5957\u89c4\u6a21\u5316\u751f\u4ea7\u8bbe\u65bd\uff0c\u8bc1\u660e\u4e86\u516c\u53f8\u80fd\u591f\u5b9e\u73b0\u4e13\u6709\u6280\u672f\u4ea7\u4e1a\u5316\u5e94\u7528\u7684\u5feb\u901f\u590d\u5236\u3002\u516c\u53f8\u76f8\u4fe1\u516c\u53f8\u7684\u6280\u672f\u80fd\u591f\u52a0\u901f\u5168\u7403CCUS\u884c\u4e1a\u7684\u53d1\u5c55\u8fdb\u7a0b\uff0c\u4e3a\u78b3\u51cf\u6392\u548c\u53ef\u6301\u7eed\u53d1\u5c55\u505a\u51fa\u8d21\u732e\u3002<br/><br/>\u8d22\u52a1\u65b9\u9762\uff0c\u516c\u53f8\u4e8e2021\u5e74\u81f32023\u5e74\u53ca2024\u5e74\u622a\u81f36\u670830\u65e5\u6b62\u516d\u4e2a\u6708\u5206\u522b\u5f55\u5f97\u6536\u51652.58\u4ebf\u5143(\u4eba\u6c11\u5e01\uff0c\u4e0b\u540c)\u30013.9\u4ebf\u5143\u30015.93\u4ebf\u5143\u30012.62\u4ebf\u5143\u3002\u5bf9\u5e94\u540c\u671f\u6bcd\u516c\u53f8\u64c1\u6709\u4eba\u5e94\u5360\u4e8f\u635f4573.4\u4e07\u5143\u30012045.5\u4e07\u5143\u30016644.7\u4e07\u5143\u30014387.8\u4e07\u5143\u3002</p>", "link": "https://ipo.jinwucj.com/info/infoDetails/6107", "pub_date": "2024-12-31 22:50:12", "source": "jinwucj", "kind": 1, "language": "zh-CN"}, {"id": 6105, "title": "\u3010\u65b0\u80a1IPO\u3011\u6d77\u87ba\u6750\u6599\u79d1\u6280(02560)\u4eca\u65e5\u8d77\u62db\u80a1 \u5165\u573a\u8d393,333.28\u6e2f\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6d77\u87ba\u6750\u6599\u79d1\u6280(02560)\u4eca\u65e5\u8d77\u62db\u80a1\uff0c\u62df\u53d1\u884c1.45\u4ebf\u80a1H\u80a1\uff0c\u5176\u4e2d10%\u4e3a\u9999\u6e2f\u516c\u5f00\u53d1\u552e\uff0c\u5176\u4f59\u4e3a\u56fd\u9645\u914d\u552e\uff0c\u53e6\u670915%\u8d85\u989d\u914d\u80a1\u6743\u3002\u6bcf\u80a1\u62db\u80a1\u4ef7\u4e3a3-3.3\u6e2f\u5143\uff0c\u6bcf\u624b1000\u80a1\uff0c\u5165\u573a\u8d393,333.28\u6e2f\u5143\u3002\u4e2d\u4fe1\u5efa\u6295\u56fd\u9645\u4e3a\u72ec\u5bb6\u4fdd\u8350\u4eba\u3002\u80a1\u4efd\u9884\u671f\u5c06\u4e8e2025\u5e741\u67089\u65e5\u6302\u724c\u4e0a\u5e02\u3002</p><p>\u5047\u8bbe\u53d1\u552e\u4ef7\u4e3a3.15\u6e2f\u5143\uff083-3.3\u6e2f\u5143\u4e2d\u4f4d\u6570\uff09\uff0c\u516c\u53f8\u9884\u671f\u96c6\u8d44\u51c0\u989d\u7ea64.18\u4ebf\u6e2f\u5143\uff0c\u62df\u5c06\u7ea635.0%\u7528\u4e8e\u4f18\u5316\u672c\u96c6\u56e2\u7684\u4ea7\u80fd\uff0c\u540c\u65f6\u6709\u6548\u6269\u5927\u516c\u53f8\u5728\u4e2d\u56fd\u53ca\u82e5\u5e72\u6d77\u5916\u56fd\u5bb6\u7684\u5730\u7406\u8986\u76d6\u8303\u56f4\uff1b\u7ea610.0%\u7528\u4e8e\u5b9e\u65bd\u8425\u9500\u8ba1\u5212\uff0c\u4ee5\u589e\u52a0\u53ca\u5de9\u56fa\u516c\u53f8\u5728\u4e2d\u56fd\u53ca\u5168\u7403\u6c34\u6ce5\u53ca\u6df7\u51dd\u571f\u5236\u9020\u884c\u4e1a\u7684\u5e02\u573a\u4efd\u989d\uff1b\u7ea615.0%\u7528\u4e8e\u8fdb\u4e00\u6b65\u6295\u5165\u8d44\u6e90\u5230\u652f\u6301\u516c\u53f8\u5e02\u573a\u5730\u4f4d\u7684\u7814\u53d1\u8ba1\u5212\u4e2d\uff1b\u7ea615.0%\u7528\u4e8e\u507f\u8fd8\u90e8\u5206\u94f6\u884c\u8d37\u6b3e\uff1b\u7ea615.0%\u7528\u4e8e\u901a\u8fc7\u6536\u8d2d\u516c\u53f8\u6216\u6210\u7acb\u5408\u8d44\u516c\u53f8\uff1b\u7ea610.0%\u7528\u4f5c\u8425\u8fd0\u8d44\u91d1\u548c\u5176\u4ed6\u4e00\u822c\u4f01\u4e1a\u7528\u9014\u3002</p>", "link": "https://ipo.jinwucj.com/info/infoDetails/6105", "pub_date": "2024-12-31 08:55:32", "source": "jinwucj", "kind": 1, "language": "zh-CN"}, {"id": 6106, "title": "\u3010\u65b0\u80a1IPO\u3011\u6c47\u8238\u73af\u4fdd(02613)\u4eca\u65e5\u8d77\u62db\u80a1 \u5165\u573a\u8d394,020.14\u6e2f\u5143", "description": "<p>\u91d1\u543e\u8d22\u8baf | \u6c47\u8238\u73af\u4fdd(02613)\u4eca\u65e5\u8d77\u62db\u80a1\uff0c\u62df\u53d1\u884c1000\u4e07\u80a1H\u80a1\uff0c\u5176\u4e2d10%\u4e3a\u9999\u6e2f\u516c\u5f00\u53d1\u552e\uff0c\u5176\u4f59\u4e3a\u56fd\u9645\u914d\u552e\u3002\u6bcf\u80a1\u62db\u80a1\u4ef7\u4ecb\u4e8e31.8\u6e2f\u5143\u81f339.8\u6e2f\u5143\uff0c\u6bcf\u624b100\u80a1\uff0c\u5165\u573a\u8d394,020.14\u6e2f\u5143\u3002\u4e2d\u4fe1\u8bc1\u5238\u3001\u4e2d\u56fd\u94f6\u6cb3\u56fd\u9645\u4e3a\u8054\u5e2d\u4fdd\u8350\u4eba\u3002\u80a1\u4efd\u9884\u671f\u5c06\u4e8e1\u67089\u65e5\u6302\u724c\u4e0a\u5e02\u3002<br/><br/>\u4ee5\u62db\u80a1\u4ef7\u4e2d\u95f4\u4ef735.8\u6e2f\u5143\u8ba1\u7b97\uff0c\u9884\u671f\u96c6\u8d44\u51c0\u989d\u7ea63.12\u4ebf\u6e2f\u5143\uff0c\u62df\u5c06\u5176\u4e2d\u7ea650%\u5c06\u7528\u4e8e\u6709\u5173\u96c6\u56e2\u7684\u7814\u53d1\uff1b\u7ea615%\u5c06\u7528\u4e8e\u6f5c\u5728\u5e76\u8d2d\uff1b\u7ea615%\u5c06\u7528\u4e8e\u5728\u4e2d\u56fd\u5185\u5730\u6216\u4e1c\u5357\u4e9a\u79df\u8d41\u751f\u4ea7\u8bbe\u65bd\uff1b\u7ea610%\u5c06\u7528\u4e8e\u5efa\u7acb\u65b0\u670d\u52a1\u4e2d\u5fc3\u53ca\u5347\u7ea7\u73b0\u6709\u670d\u52a1\u4e2d\u5fc3\uff1b\u7ea610%\u5c06\u7528\u4f5c\u8425\u8fd0\u8d44\u91d1\u53ca\u5176\u4ed6\u4e00\u822c\u4f01\u4e1a\u7528\u9014\u3002</p>", "link": "https://ipo.jinwucj.com/info/infoDetails/6106", "pub_date": "2024-12-31 08:55:57", "source": "jinwucj", "kind": 1, "language": "zh-CN"}]}