{"data": [{"title": "\u4f20\u878d\u4fe1\u4e2d\u56fd(03301)\u62df10\u6708\u5de6\u53f3\u63a8\u65b0\u5883\u5185\u503a\u52a1\u91cd\u7ec4\u65b9\u6848", "description": "<div id=\"newsBody\">\n<span class=\"newsDetail\" style=\"font-size: 13px; font-family:MingLiu;Arial;\">\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u5185\u5730\u4f20\u5a92\u5f15\u8ff0\u6d88\u606f\u62a5\u9053\uff0c\u878d\u4fe1\u4e2d\u56fd(03301)\u8ba1\u5212\u4eca\u5e7410\u6708\u5de6\u53f3\u63a8\u51fa\u65b0\u7684\u5883\u5185\u503a\u52a1\u91cd\u7ec4\u65b9\u6848\uff0c\u8bd5\u56fe\u524a\u503a\u51cf\u8f7b\u8d1f\u62c5\u3002\u00a0(ST)<br/><br/>#\u878d\u4fe1\u4e2d\u56fd<br/></span>\n</div>", "pub_date": "2025-01-03 17:30:52", "link": "https://www.infocastfn.com/fn/ajax/news/newsDetail?newsId=4416389&locale=zh_CN", "source": "infocastfn", "kind": 2, "language": "zh-CN", "id": "4416389"}, {"title": "\u6296\u97f3\u652f\u4ed8\u56de\u5e94\u300c\u589e\u8d44\u81f331.5\u4ebf\u5143\u300d\uff1a\u6709\u52a9\u65bc\u66f4\u7a33\u5065\u5730\u5f00\u5c55\u4e1a\u52a1", "description": "<div id=\"newsBody\">\n<span class=\"newsDetail\" style=\"font-size: 13px; font-family:MingLiu;Arial;\">\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u4eca\u65e5\uff0c\u4e2d\u56fd\u56fd\u5bb6\u4f01\u4e1a\u4fe1\u7528\u8d44\u8baf\u516c\u793a\u7cfb\u7edf\u663e\u793a\uff0c\u6296\u97f3\u652f\u4ed8\u79d1\u6280\u6709\u9650\u516c\u53f8\u7684\u6ce8\u518c\u8d44\u672c\u75311.5\u4ebf\u5143\u589e\u81f331.5\u4ebf\u5143\u4eba\u6c11\u5e01\u3002<br/><br/>\u5bf9\u6b64\uff0c\u6296\u97f3\u652f\u4ed8\u76f8\u5173\u8d1f\u8d23\u4eba\u56de\u5e94\u79f0\uff0c\u6b64\u6b21\u589e\u8d44\u662f\u6839\u636e\u65b0\u751f\u6548\u7684\u300a\u975e\u94f6\u884c\u652f\u4ed8\u673a\u6784\u76d1\u7763\u7ba1\u7406\u6761\u4f8b\u300b\u63a8\u8fdb\uff0c\u5e76\u5df2\u901a\u8fc7\u76d1\u7ba1\u90e8\u95e8\u5ba1\u6279\uff0c\u589e\u8d44\u6709\u52a9\u65bc\u6296\u97f3\u652f\u4ed8\u66f4\u7a33\u5065\u5730\u5f00\u5c55\u4e1a\u52a1\uff0c\u63d0\u4f9b\u5e7f\u5927\u7528\u6237\u53ca\u5546\u5bb6\u5b89\u5168\u4fbf\u6377\u7684\u652f\u4ed8\u670d\u52a1\u3002<br/><br/>#\u6296\u97f3\u652f\u4ed8\u00a0(CW)</span>\n</div>", "pub_date": "2025-01-03 17:30:51", "link": "https://www.infocastfn.com/fn/ajax/news/newsDetail?newsId=4416387&locale=zh_CN", "source": "infocastfn", "kind": 2, "language": "zh-CN", "id": "4416387"}, {"title": "\u5357\u97e9\u603b\u7edf\u5e9c\u4e3e\u62a5\u591a\u5bb6\u97e9\u56fd\u5a92\u4f53", "description": "<div id=\"newsBody\">\n<span class=\"newsDetail\" style=\"font-size: 13px; font-family:MingLiu;Arial;\">\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u636e\u5357\u97e9\u603b\u7edf\u5e9c\u6d88\u606f\uff0c\u603b\u7edf\u5e9c\u4ee5\u300c\u6d89\u5acc\u8fdd\u53cd\u300a\u519b\u4e8b\u57fa\u5730\u53ca\u519b\u4e8b\u8bbe\u65bd\u4fdd\u62a4\u6cd5\u300b\u300d\u4e3a\u7531\uff0c\u4e3e\u62a5\u5f53\u5730JTBC\u3001MBC\u3001SBS\u7535\u89c6\u53f0\u4ee5\u53ca\u8eab\u4efd\u4e0d\u660e\u7684\u4e92\u8054\u7f51\u89c6\u9891\u535a\u4e3b\uff0c\u56e0\u5176\u300c\u672a\u7ecf\u8bb8\u53ef\u52a8\u7528\u76f4\u5347\u673a\u7b49\u8bbe\u5907\u62cd\u6444\u603b\u7edf\u5b98\u90b8\u300d\u3002<br/><br/>\u603b\u7edf\u5e9c\u8868\u793a\uff0c\u603b\u7edf\u5b98\u90b8\u5468\u8fb9\u5730\u533a\u5c5e\u65bc\u519b\u4e8b\u8bbe\u65bd\u4fdd\u62a4\u533a\uff0c\u4e0e\u56fd\u5bb6\u5b89\u5168\u76f4\u63a5\u76f8\u5173\uff0c\u662f\u91cd\u8981\u7684\u4fdd\u5bc6\u8bbe\u65bd\uff0c\u672a\u7ecf\u8bb8\u53ef\u4e25\u7981\u62cd\u6444\u3002<br/><br/>\u5f53\u5730\u8c03\u67e5\u90e8\u95e8\u4eca\u65e9\u524d\u5f80\u4f4d\u65bc\u9996\u5c14\u5e02\u9f99\u5c71\u533a\u6c49\u5357\u6d1e\u7684\u603b\u7edf\u5b98\u90b8\u6267\u884c\u9488\u5bf9\u603b\u7edf\u5c39\u9521\u60a6\u7684\u902e\u6355\u4ee4\uff0c\u906d\u5230\u603b\u7edf\u8b66\u536b\u4eba\u5458\u62b5\u5236\u672a\u679c\u3002<br/><br/>#\u5357\u97e9\u00a0#\u6212\u4e25\u4ee4\u00a0#\u5c39\u9521\u60a6\u00a0(CW)</span>\n</div>", "pub_date": "2025-01-03 17:30:50", "link": "https://www.infocastfn.com/fn/ajax/news/newsDetail?newsId=4416388&locale=zh_CN", "source": "infocastfn", "kind": 2, "language": "zh-CN", "id": "4416388"}, {"title": "\u636e\u4f20\u5c0f\u7ea2\u4e66\u5546\u4e1a\u5316\u67b6\u6784\u8c03\u6574  \u5b98\u65b9\u6682\u65e0\u56de\u5e94", "description": "<div id=\"newsBody\">\n<span class=\"newsDetail\" style=\"font-size: 13px; font-family:MingLiu;Arial;\">\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u5f15\u8ff0\u5185\u5a92\u6d88\u606f\uff0c\u636e\u5e02\u573a\u6d88\u606f\uff0c\u5c0f\u7ea2\u4e66\u5546\u4e1a\u5316\u67b6\u6784\u8c03\u6574\uff0c\u5546\u4e1a\u5316KA(\u5927\u5ba2\u6237)\u548c\u751f\u6001(SME\u4e2d\u5c0f\u5ba2\u6237)\u4e1a\u52a1\u6574\u5408\uff0c\u540c\u65f6\uff0c\u539f\u6765\u6309\u7167\u884c\u4e1a\u8fdb\u884c\u5212\u5206\u7684\u5404\u4e2a\u4e8b\u4e1a\u7fa4\u66f4\u540d\u4e3a\u5546\u4e1a\u5316\u4e00\u90e8\u5230\u4e5d\u90e8\u3002<br/><br/>\u5bf9\u6b64\uff0c\u5c0f\u7ea2\u4e66\u5b98\u65b9\u6682\u65e0\u56de\u5e94\u3002<br/><br/>#\u5c0f\u7ea2\u4e66\u00a0(CW)</span>\n</div>", "pub_date": "2025-01-03 17:30:50", "link": "https://www.infocastfn.com/fn/ajax/news/newsDetail?newsId=4416390&locale=zh_CN", "source": "infocastfn", "kind": 2, "language": "zh-CN", "id": "4416390"}, {"title": "\u300a\u4e00\u5468\u653b\u7565\u300b2025\u6682\u65f6\u7f3a\u4e4f\u6570\u636e\u652f\u6301 \u5185\u9700\u53ca\u7535\u52a8\u8f66\u4e0e\u4e0a\u6e38\u76f8\u5173\u4ea7\u4e1a\u53ef\u7559\u610f", "description": "<div id=\"newsBody\">\n<span class=\"newsDetail\" style=\"font-size: 13px; font-family:MingLiu;Arial;\">2025\u00a0\u6682\u65f6\u7f3a\u4e4f\u6570\u636e\u652f\u6301\uff0c\u4f46\u5185\u9700\u53ca\u7535\u52a8\u6c7d\u8f66\u4e0e\u4e0a\u6e38\u76f8\u5173\u4ea7\u4e1a\u53ef\u7559\u610f\u3002<br/><br/>\u5927\u5e02\u6309\u5468\u8dcc330\u70b9\u62161.64%\u3002\u5168\u5468\u572819542\u70b9\u81f320193\u70b9\u95f4\u6ce2\u52a8\uff0c\u65e5\u5747\u6210\u4ea4\u7ea61320\u4ebf\u5143\u3002\u6052\u6307\u5468\u4e00(30\u65e5)\u6536\u5e02\u62a520041\uff0c\u8dcc49\u70b9\u62160.24%\u3002\u5927\u5e02\u5168\u65e5\u6210\u4ea41285\u4ebf\u5143\u3002\u56fd\u6307\u8dcc24\u70b9\u62160.34%\uff0c\u62a57280\u70b9\u3002\u79d1\u6307\u8dd1\u8f93\uff0c\u8dcc37\u70b9\u62160.8%\uff0c\u62a54500\u70b9\u30023\u53ea\u65b0\u80a1\u4eca\u65e5\u6302\u724c\u8d70\u9ad8\uff0c\u5176\u4e2d\u767e\u5ea6\u6709\u4efd\u6295\u8d44\u7684\u5185\u5730\u533b\u7597\u670d\u52a1\u5e73\u53f0\u5065\u5eb7\u4e4b\u8def(02587)\u8868\u73b0\u6700\u597d\uff0c\u6536\u62a510.66\u5143\uff0c\u8f83\u62db\u80a1\u4ef77.8\u5143\uff0c\u534736.7%\u3002\u5185\u5730\u6c2e\u5316\u9553\u6676\u5706\u5236\u9020\u5546\u82f1\u8bfa\u8d5b\u79d1(02577)\u8f83\u62db\u80a1\u4ef7\u9ad80.5%\u3002\u8baf\u98de\u533b\u7597\u79d1\u6280(02506)\u8f83\u62db\u80a1\u4ef7\u9ad85.1%\u3002\u6052\u6307\u5468\u4e8c(31\u65e5)\u5927\u9664\u5915\u53ea\u6709\u534a\u65e5\u5e02\uff0c\u6536\u5e02\u62a520059\uff0c\u534718\u70b9\u62160.1%\u3002\u5927\u5e02\u5168\u65e5\u6210\u4ea4745\u4ebf\u5143\u3002\u56fd\u6307\u6536\u53479\u70b9\u62160.1%\uff0c\u62a57289\u3002\u79d1\u6307\u4eca\u65e5\u8dd1\u8f93\uff0c\u6536\u8dcc32\u70b9\u62160.7%\uff0c\u62a54468\uff1b\u52a0\u5bc6\u8d27\u5e01\u300c\u4e00\u54e5\u300d\u6bd4\u7279\u5e01\u4eca\u5e74\u8868\u73b0\u7a81\u51fa\uff0c\u76f8\u5173ETF\u5347\u5e45\u5c45\u524d\uff0c\u5176\u4e2d\u4e09\u661f\u6bd4\u7279\u5e01(03135)\u4eca\u5e74\u5347\u5e45\u8fbe93%\uff1b\u300c\u76f2\u76d2\u80a1\u300d\u6ce1\u6ce1\u739b\u7279(09992)\u8fde\u65e5\u56de\u843d\u5f8c\uff0c\u4eca\u65e5\u5f39\u53474.1%\uff0c\u6ce1\u6ce1\u739b\u7279\u4e3a\u4eca\u5e74\u8868\u73b0\u6700\u597d\u7684\u300c\u6e2f\u80a1\u901a\u300d\u80a1\u4efd\uff0c\u671f\u5185\u5927\u5347\u7ea63.5\u500d\u3002\u6052\u6307\u5468\u4e091(\u65e5)\u4e3a\u65b0\u5e74\u5047\u671f\uff0c\u5168\u65e5\u4f11\u5e02\u3002\u6052\u6307\u5468\u56db(2\u65e5)\u6536\u5e02\u62a519623\uff0c\u8dcc436\u70b9\u62162.2%\u3002\u5927\u5e02\u5168\u65e5\u6210\u4ea41647\u4ebf\u5143\u3002\u56fd\u6307\u8dcc2.7%\uff0c\u62a57090\uff1b\u79d1\u6307\u8dcc2.5%\uff0c\u62a54357\u3002\u5185\u5730\u80a1\u5e02\u6025\u632b\uff0c\u4e0a\u8bc1\u6307\u6570\u4e0e\u6df1\u6210\u6307\u632b2.7%\u548c3.1%\uff0c\u5185\u5730\u5238\u5546\u80a1\u6cbd\u538b\u5927\u3002\u91d1\u4ef7\u8fdb\u4e00\u6b65\u9020\u597d\u3002\u91d1\u77ff\u80a1\u9006\u5e02\u8d70\u9ad8\u3002\u7d2b\u91d1(02899)\u53470.3%\uff0c\u66f4\u662f\u552f\u4e00\u5f55\u5f97\u5347\u5e45\u84dd\u7b79\uff1b\u6052\u6307\u5468\u4e94(3\u65e5)\u6536\u5e02\u62a519760\uff0c\u5347136\u70b9\u62160.7%\u3002\u5927\u5e02\u5168\u65e5\u6210\u4ea41603\u4ebf\u5143\u3002\u56fd\u6307\u534768\u70b9\u62161%\uff0c\u62a57159\u3002\u79d1\u6307\u534745\u70b9\u62161%\uff0c\u62a54403\u3002\u53d1\u6539\u59d4\u79f0\u5b9e\u65bd\u624b\u673a\u7b49\u6570\u7801\u4ea7\u54c1\u8d2d\u65b0\u8865\u8d34\uff0c\u624b\u673a\u80a1\u53d7\u8ffd\u6367\u3002\u5c0f\u7c73(01810)\u521b\u65b0\u9ad8\uff0c\u6536\u5e02\u53476.6%\uff0c\u62a536.25\u5143\uff0c\u4e3a\u6700\u5927\u5347\u5e45\u84dd\u7b79\uff0c\u6210\u4ea4\u8fbe120.5\u4ebf\u5143\u3002\u4e2d\u5347\u63a7\u80a1(00881)\u632b3.8%\uff0c\u4e3a\u8868\u73b0\u6700\u5dee\u84dd\u7b79\u3002<br/><br/>\u5f8c\u5e02\u8bc4\u8bba\uff1a<br/><br/>\u603b\u7ed3\u672c\u5468\uff0c\u6caa\u6307\u8dcc5.6%\u3002\u6e2f\u80a1\u5927\u5e02\u6309\u5468\u8dcc330\u70b9\u62161.64%\u3002\u5168\u5468\u572819542\u70b9\u81f320193\u70b9\u95f4\u6ce2\u52a8\uff0c\u4e0a\u4e0b\u6ce2\u5e45651\u70b9\u3002\u653f\u5e9c\u7edf\u8ba1\u5904\u516c\u5e03\uff0c2024\u5e7411\u6708\u7684\u96f6\u552e\u4e1a\u603b\u9500\u8d27\u4ef7\u503c\u7684\u4e34\u65f6\u4f30\u8ba1\u4e3a317\u4ebf\u5143\uff0c\u6309\u5e74\u4e0b\u8dcc7.3%\uff0c\u900a\u65bc\u5e02\u573a\u9884\u671f\u8dcc3.4%\u3002\u6263\u9664\u5176\u95f4\u4ef7\u683c\u53d8\u52a8\u5f8c\uff0c\u96f6\u552e\u4e1a\u603b\u9500\u8d27\u6570\u91cf\u7684\u4e34\u65f6\u4f30\u8ba1\u6309\u5e74\u8dcc8.3%\uff0c\u4ea6\u900a\u65bc\u5e02\u573a\u9884\u671f\u8dcc5.4%\u3002\u91d1\u7ba1\u5c40\u516c\u5e03\u4f4f\u5b85\u6309\u63ed\u7edf\u8ba1\u8c03\u67e5\u7ed3\u679c\uff0c11\u6708\u4efd\u65b0\u7533\u8bf7\u8d37\u6b3e\u4e2a\u6848\u6309\u6708\u589e\u52a09.7%\uff0c\u81f37995\u5b97\u3002\u8d22\u65b0\u4e2d\u56fd\u5236\u9020\u4e1a\u91c7\u8d2d\u7ecf\u7406\u6307\u6570(PMI)\u8fde\u7eed3\u4e2a\u6708\u6269\u5f20\uff0c\u4f46\u901f\u5ea6\u653e\u7f13\u30022024\u5e7412\u6708\u8d22\u65b0\u4e2d\u56fd\u5236\u9020\u4e1aPMI\u5f55\u5f9750.5\uff0c\u8f8311\u6708\u56de\u843d1\u4e2a\u767e\u5206\u70b9\uff0c\u900a\u65bc\u5e02\u573a\u9884\u671f\u768451.7\u300212\u6708\u4efd\uff0c\u975e\u5236\u9020\u4e1a\u5546\u52a1\u6d3b\u52a8\u6307\u6570\u5347\u81f352.2\uff0c\u6bd4\u4e0a\u6708\u53472.2\u4e2a\u767e\u5206\u70b9\uff0c\u9ad8\u65bc\u5e02\u573a\u9884\u671f\u768450.2\u3002\u5236\u9020\u4e1a\u91c7\u8d2d\u7ecf\u7406\u6307\u6570(PMI)\u56de\u843d\u81f350.1\uff0c\u6bd4\u4e0a\u6708\u4e0b\u964d0.2\u4e2a\u767e\u5206\u70b9\uff0c\u7565\u900a\u9884\u671f\u768450.2\uff0c\u4f46\u4ecd\u8fde\u7eed3\u4e2a\u6708\u5904\u65bc\u6269\u5f20\u6c34\u5e73\u3002\u6fb3\u95e8\u535a\u5f69\u76d1\u5bdf\u534f\u8c03\u5c40\u516c\u5e03\uff0c\u53bb\u5e7412\u6708\u4efd\u535a\u5f69\u6536\u5165182.02\u4ebf\u5143(\u6fb3\u95e8\u5143\u2022\u4e0b\u540c)\uff0c\u6309\u5e74\u8dcc2%\uff1b\u6309\u6708\u5219\u8dcc1.28%\u3002\u7f8e\u56fd\u52b3\u5de5\u90e8\u516c\u5e03\uff0c\u622a\u81f3\u53bb\u5e7412\u670828\u65e5\u6b62\u4e00\u5468\u7684\u9996\u6b21\u7533\u9886\u5931\u4e1a\u6551\u6d4e\u4eba\u6570\u51cf\u5c119000\u4eba\uff0c\u62a521.1\u4e07\u4eba\uff0c\u5c5e8\u4e2a\u6708\u65b0\u4f4e\uff0c\u5e76\u5c11\u8fc7\u9884\u671f\u768422.1\u4e07\u4eba\uff1b\u800c\u622a\u81f312\u670821\u65e5\u6b62\u4e00\u5468\u7684\u6301\u7eed\u7533\u9886\u6551\u6d4e\u4eba\u6570\u9510\u964d5.2\u4e07\u4eba\uff0c\u81f3184.4\u4e07\u4eba\u76843\u4e2a\u6708\u4f4e\u4f4d\uff0c\u5c11\u8fc7\u9884\u671f\u7684189\u4e07\u4eba\u3002\u7f8e\u56fd\u4e0a\u6708\u5236\u9020\u4e1a\u91c7\u8d2d\u7ecf\u7406\u6307\u6570(PMI)\u7ec8\u503c\u4e3a49.4\uff0c\u4f4e\u8fc7\u524d\u4e00\u4e2a\u6708\u768449.7\uff1b\u53bb\u5e7411\u6708\u5efa\u7b51\u5f00\u652f\u7ef4\u6301\u4e0d\u53d8\uff0c\u5dee\u8fc7\u9884\u671f\u53470.3%\u3002\u4e0b\u5468\u5173\u6ce8\uff1a1\u67086\u65e5\uff0c\u4e2d\u56fd\u516c\u5e03\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u8d22\u65b0\u670d\u52a1\u4e1aPMI\u30021\u67087\u65e5\uff0c\u7f8e\u56fd\u5c06\u516c\u5e03\u51fa\u5165\u53e3\u6570\u5b57\u53caISM\u975e\u5236\u9020\u4e1aPMI\u30021\u67089\u65e5\uff0c\u7f8e\u56fd\u5c06\u516c\u5e03\u6301\u7eed\u7533\u8bf7\u5931\u4e1a\u6551\u6d4e\u4eba\u6570\u3002<br/><br/>\u00a0<br/>\u9999\u6e2f\u80a1\u7968\u5206\u6790\u5e08\u534f\u4f1a\u4e3b\u5e2d\u00a0\u9093\u58f0\u5174\u535a\u58eb<br/>(\u7b14\u8005\u4e3a\u8bc1\u76d1\u4f1a\u6301\u724c\u4eba\u58eb\u53ca\u7b14\u8005\u672a\u6301\u6709\u4e0a\u8ff0\u80a1\u4efd)<br/><br/>#\u9093\u58f0\u5174<br/></span>\n</div>", "pub_date": "2025-01-03 17:20:42", "link": "https://www.infocastfn.com/fn/ajax/news/newsDetail?newsId=4416368&locale=zh_CN", "source": "infocastfn", "kind": 2, "language": "zh-CN", "id": "4416368"}, {"title": "\u9093\u58f0\u5174\uff1a\u6d77\u4fe1\u5bb6\u7535(00921) \u76ee\u6807\u4ef733\u5143 \u6b62\u8680\u4ef721.4\u5143", "description": "<div id=\"newsBody\">\n<span class=\"newsDetail\" style=\"font-size: 13px; font-family:MingLiu;Arial;\">\u7126\u70b9\u80a1\u4efd\uff1a<br/><br/>\u6d77\u4fe1\u5bb6\u7535(00921)<br/><br/>\u4eca\u5e74\u4ee5\u6765\uff0c\u6d88\u8d39\u54c1\u4ee5\u65e7\u6362\u65b0\u653f\u7b56\u4e0d\u65ad\u6269\u56f4\u52a0\u529b\uff0c\u6301\u7eed\u91ca\u653e\u5de8\u5927\u5185\u9700\u5e02\u573a\u6f5c\u529b\u3002\u5bb6\u7535\u662f\u63a8\u8fdb\u6d88\u8d39\u54c1\u300c\u4ee5\u65e7\u6362\u65b0\u300d\u7684\u91cd\u70b9\u9886\u57df\u3002\u6839\u636e\u7edf\u8ba1\u5c40\u6570\u636e\uff0c2024\u5e7411\u6708\u5bb6\u7535\u793e\u6d88\u96f6\u552e\u989d\u8fbe1200\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f22.20%\uff0c8\u6708\u4ee5\u65e7\u6362\u65b0\u4e2d\u592e\u8865\u8d34\u8d44\u91d1\u5230\u4f4d\u5f8c\uff0c\u5bb6\u7535\u793e\u6d88\u8fde\u7eed3\u4e2a\u6708\u540c\u6bd4\u589e\u957f20%\u4ee5\u4e0a\u3002\u540c\u65f6\uff0c\u623f\u5730\u4ea7\u7684\u56de\u6696\u4e5f\u4e3a\u5bb6\u7535\u6d88\u8d39\u5e26\u6765\u9700\u6c42\u3002\u5bb6\u7535\u884c\u4e1a\u9700\u6c42\u663e\u8457\u6539\u5584\uff0c\u4f30\u503c\u89e6\u5e95\u53cd\u5f39\uff0c\u677f\u5757\u4f30\u503c\u663e\u8457\u4fee\u590d\uff0c\u4ecd\u5177\u5907\u8f83\u9ad8\u914d\u7f6e\u6027\u4ef7\u6bd4\uff0c\u770b\u597d\u6d77\u4fe1\u5bb6\u7535\u3002\u4eca\u5e74\u524d\u4e09\u5b63\u5ea6\u6d77\u4fe1\u5bb6\u7535\u5b9e\u73b0\u8425\u4e1a\u6536\u5165705.79\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f8.75%\uff1b\u5f52\u6bcd\u51c0\u5229\u6da627.93\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f15.13%\uff1b\u6263\u975e\u5f52\u6bcd\u51c0\u5229\u6da622.89\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f10.99%\u3002\u5176\u4e2d\u96c6\u56e2\u5916\u9500\u589e\u957f\u4eae\u773c\uff0c\u5176\u591a\u8054\u673a2024\u00a0\u5e741-9\u00a0\u6708\u5916\u9500\u91d1\u989d\u4e3a10.39\u00a0\u4ebf\u5143\uff0c\u540c\u6bd4\u589e\u957f\u589e\u957f23%\u3002\u76f8\u4fe1\u96c6\u56e2\u4f1a\u6301\u7eed\u52a0\u5f3a\u6d77\u5916\u5e02\u573a\u5e03\u5c40\uff0c\u9884\u8ba1\u5f8c\u7eed\u516c\u53f8\u89c4\u6a21\u4e0e\u4e1a\u7ee9\u5c06\u56de\u5f52\u8f83\u9ad8\u589e\u957f\u6001\u52bf\u3002\u76ee\u6807\u4ef7$33\uff0c\u6b62\u8680\u4ef7$21.4\u3002<br/><br/><br/>\u9999\u6e2f\u80a1\u7968\u5206\u6790\u5e08\u534f\u4f1a\u4e3b\u5e2d\u00a0\u9093\u58f0\u5174\u535a\u58eb<br/>(\u7b14\u8005\u4e3a\u8bc1\u76d1\u4f1a\u6301\u724c\u4eba\u58eb\u53ca\u7b14\u8005\u672a\u6301\u6709\u4e0a\u8ff0\u80a1\u4efd)<br/><br/>#\u9093\u58f0\u5174<br/></span>\n</div>", "pub_date": "2025-01-03 17:20:42", "link": "https://www.infocastfn.com/fn/ajax/news/newsDetail?newsId=4416367&locale=zh_CN", "source": "infocastfn", "kind": 2, "language": "zh-CN", "id": "4416367"}, {"title": "\u4e2d\u539f\u4e3a\u534f\u6210\u884c\u7b72\u7b95\u6e7e\u300c\u50b2\u534e\u300d\u63d0\u4f9b\u4f4e\u81f3 H+1.3%\u6309\u63ed\u4f18\u60e0", "description": "<div id=\"newsBody\">\n<span class=\"newsDetail\" style=\"font-size: 13px; font-family:MingLiu;Arial;\">\u00a0\u00a0\u00a0\u00a0\u7531\u534f\u6210\u884c\u53d1\u5c55\u4f4d\u65bc\u6e2f\u5c9b\u7b72\u7b95\u6e7e\u4e1c\u5927\u8857\u73b0\u697c\u9879\u76ee\u300cORIA\u00a0\u50b2\u534e\u300d\uff0c\u4e3a\u914d\u5408\u7269\u4e1a\u6700\u65b0\u73b0\u697c\u63a8\u552e\u5b89\u6392\uff0c\u4e2d\u539f\u5730\u4ea7\u53ca\u4e2d\u539f\u6309\u63ed\u7279\u522b\u4e3a\u300c\u50b2\u534e\u300d\u4e70\u5bb6\u63d0\u4f9b\u5168\u65b0\u6309\u63ed\u4f18\u60e0\u8f6c\u4ecb\u3002<br/><br/>\u4e2d\u539f\u6309\u63ed\u8463\u4e8b\u603b\u7ecf\u7406\u738b\u7f8e\u51e4\u516c\u5e03\uff0c\u662f\u6b21\u7279\u522b\u4e3a\u4e70\u5bb6\u63a8\u51fa\u300c\u50b2\u534e\u7f6e\u4e1a\u6309\u63ed\u4f18\u60e0\u300d\uff0c\u51e1\u7ecf\u4e2d\u539f\u6309\u63ed\u8f6c\u4ecb\u5747\u53ef\u7533\u8bf7\u662f\u6b21\u4f18\u60e0\uff0c\u5168\u671f\u6309\u606f\u4f4e\u81f3H+1.3%\uff0c\u5c01\u9876\u606f\u7387\u4f4e\u81f3P-2%(P:5.5%)\uff0c\u57fa\u65bc2024\u5e74\u672c\u6e2f\u94f6\u884c\u4e09\u5ea6\u51cfP\uff0c\u5b9e\u9645\u6309\u606f\u73b0\u4f4e\u81f33.5%\uff0c\u8ba1\u5212\u8bbe\u6709\u7279\u9ad8\u73b0\u91d1\u56de\u8d60\u9ad8\u8fbe\u8d37\u6b3e\u989d1%\uff0c\u5e76\u7279\u8bbe\u00a0Mortgage\u2013Link\u00a0\u9ad8\u5b58\u606f\u6237\u53e3\uff0c\u5b58\u606f\u4e0e\u6309\u606f\u4e00\u81f4\u73b0\u4e3a3.5%\uff0c\u5584\u7528\u9ad8\u5b58\u606f\u6237\u53e3\u4ee5\u5b58\u606f\u56de\u62a5\u62b5\u9500\u6309\u606f\u652f\u51fa\uff0c\u6709\u6548\u964d\u4f4e\u51c0\u6309\u606f\u3002\u5ba2\u6237\u53ef\u900f\u8fc7\u6309\u4fdd\u627f\u9020\u9ad8\u8fbe9\u6210\u6309\u63ed\uff0c\u4ee5\u300c\u50b2\u534eORIA\u300d\u6700\u65b0\u4ef7\u5355\u5165\u573a\u5355\u4f4d5\u697cC\u5ba4\u4e3a\u4f8b\uff0c\u6298\u5b9e\u552e\u4ef7335.1\u4e07\u5143\uff0c\u5373\u9996\u671f\u4f4e\u81f333\u4e07\u591a\u5143\u4fbf\u53ef\u4e0a\u8f66\u3002<br/><br/>\u738b\u7f8e\u51e4\u6307\u51fa\uff0c\u53bb\u5e74\u7f8e\u56fd\u51cf\u606f\u5f8c\u672c\u6e2f\u94f6\u884c\u63d0\u901f\u51cfP\uff0c\u6309\u606f\u63d0\u65e9\u52a0\u5feb\u4e0b\u8dcc\uff0c\u4f18\u65bc\u5e02\u573a\u9884\u671f\uff0c\u53bb\u5e74\u75319\u6708\u4e2d\u51cf\u606f\u5468\u671f\u5f00\u59cb\u81f3\u4eca\u7d2f\u79ef\u51cf\u00a0P\u4e09\u6b21\uff0c\u4ee4\u6309\u606f\u7d2f\u8dcc0.625\u5398\uff0c\u4f9b\u697c\u4eba\u58eb\u6708\u4f9b\u5df2\u7d2f\u8ba1\u51cf\u5c11\u7ea67.3%\uff0c\u4ee5\u5e02\u573a\u5e73\u5747\u6309\u63ed\u989d\u7ea6450\u4e07\u5143\u8ba1\uff0c\u6bcf\u6708\u4f9b\u6b3e\u5df2\u51cf\u5c111602\u5143\uff0c\u7269\u4e1a\u4e70\u5bb6\u6b63\u53ef\u53d7\u60e0\u51cf\u8f7b\u4f9b\u6b3e\u8d1f\u62c5\u3002\u968f\u7740\u672c\u6e2f\u51cf\u606f\u671f\u5ef6\u7eed\uff0c\u672a\u6765\u6309\u606f\u8d70\u52bf\u5411\u4e0b\uff0c\u52a0\u4e0a\u697c\u6309\u5df2\u5168\u9762\u653e\u5bbd\u7b49\u5229\u597d\u56e0\u7d20\uff0c\u76f8\u4fe1\u6709\u5229\u5de9\u56fa2025\u697c\u5e02\u5411\u597d\u53d1\u5c55\u3002(\u4e0a\u8ff0\u4f8b\u5b50\uff1a\u4ee5\u76ee\u524d\u65b0\u9020\u5e73\u5747\u6309\u63ed\u989d\u7ea6450\u4e07\u5143\u8ba1\uff0c\u6309\u606f\u7531\u53bb\u5e749\u6708\u51cf\u606f\u524d4.125%\u964d\u81f3\u73b0\u4e3a3.5%\uff0c\u6bcf\u6708\u4f9b\u6b3e\u7d2f\u51cf1602\u5143\uff0c\u51cf\u5e457.3%\u3002)\u3002<br/><br/>#\u4e2d\u539f\u00a0\u00a0\u00a0#\u534f\u6210\u884c\u00a0\u00a0\u00a0#\u7b72\u7b95\u6e7e\u00a0\u00a0#\u50b2\u534e\u00a0(SY)</span>\n</div>", "pub_date": "2025-01-03 17:20:41", "link": "https://www.infocastfn.com/fn/ajax/news/newsDetail?newsId=4416369&locale=zh_CN", "source": "infocastfn", "kind": 2, "language": "zh-CN", "id": "4416369"}, {"title": "1\u6708\u591c\u671f\u5f00\u5e02\u62a519754\u70b9\u3000\u4f4e\u6c346\u70b9", "description": "<div id=\"newsBody\">\n<span class=\"newsDetail\" style=\"font-size: 13px; font-family:MingLiu;Arial;\">\u00a0\u00a0\u00a0\u00a01\u6708\u591c\u671f\u671f\u6307\u5f00\u5e02\u62a519754\u70b9\uff0c\u8f83\u300c\u65e5\u671f\u300d\u6700\u5f8c\u6210\u4ea4\u65e0\u5347\u8dcc\uff0c\u4f4e\u6c346\u70b9\uff1b2\u6708\u591c\u671f\u671f\u6307\u5f00\u5e02\u62a519815\u70b9\uff0c\u8f83\u300c\u65e5\u671f\u300d\u6700\u5f8c\u6210\u4ea4\u534710\u70b9\uff0c\u9ad8\u6c3455\u70b9\u3002</span>\n</div>", "pub_date": "2025-01-03 17:20:40", "link": "https://www.infocastfn.com/fn/ajax/news/newsDetail?newsId=4416385&locale=zh_CN", "source": "infocastfn", "kind": 2, "language": "zh-CN", "id": "4416385"}, {"title": "\u6fb3\u95e8\u8d4c\u573a\u53d1\u73b0\u4f4e\u5ea6\u4eff\u5236\u9762\u989d1\u4e07\u6e2f\u5143\u5047\u7b79\u7801 \u62d8\u63553\u5185\u5730\u7537\u5b50\u79fb\u9001\u68c0\u5bdf\u9662\u4fa6\u529e", "description": "<div id=\"newsBody\">\n<span class=\"newsDetail\" style=\"font-size: 13px; font-family:MingLiu;Arial;\">\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u6fb3\u95e8\u8def\u51fc\u4e00\u4e2a\u8d4c\u573a\u53d1\u73b0\u4e00\u6279\u4f4e\u5ea6\u4eff\u5236\u9762\u989d1\u4e07\u6e2f\u5143\u7684\u5047\u7b79\u7801\uff0c\u53f8\u8b66\u7ecf\u8c03\u67e5\u5f8c\uff0c\u5728\u573a\u5185\u8d77\u51fa\u517170\u591a\u679a\u5047\u7b79\u7801\uff0c\u62d8\u63553\u4eba\u6d89\u5acc\u89e6\u72af\u8bc8\u9a97\u7f6a\uff0c\u4e0b\u5348\u79fb\u9001\u68c0\u5bdf\u9662\u4fa6\u529e\u3002<br/><br/>\u53f8\u8b66\u8868\u793a\uff0c\u5143\u65e6\u65e5\u665a\u4e0a\u63a5\u5230\u8d4c\u573a\u62a5\u6848\uff0c\u6307\u8d26\u623f\u4e3a\u5ba2\u4eba\u300c\u6253\u6563\u300d\u4e00\u679a\u9762\u503c1\u4e07\u6e2f\u5143\u7684\u7b79\u7801\u65f6\u6000\u7591\u662f\u4f2a\u9020\uff0c\u7ecf\u4fa6\u67e5\u5458\u5230\u573a\u8c03\u67e5\uff0c\u9646\u7eed\u53d1\u73b0\u5728\u8d4c\u67b1\u73e0\u76d8\u4ea6\u67092\u4e2a\u5047\u7b79\u7801\uff0c\u5e76\u572811\u4eba\u8eab\u4e0a\u627e\u5230\u5047\u7b79\u7801\u3002<br/><br/>\u53f8\u8b66\u6839\u636e\u73b0\u573a\u7ebf\u7d22\uff0c\u622a\u83b73\u540d\u5e74\u9f84\u4ecb\u4e4e29\u81f333\u5c81\u65e0\u4e1a\u5185\u5730\u7537\u5b50\uff0c\u5728\u5404\u4eba\u8eab\u4e0a\u627e\u51fa\u5c5e\u540c\u4e00\u6279\u7684\u4f2a\u9020\u7b79\u7801\u3002\u53f8\u8b66\u8868\u793a\uff0c3\u4eba\u5f53\u5929\u5148\u5f8c\u4ece\u5185\u5730\u5165\u5883\uff0c\u5728\u5f53\u665a\u7ea68\u65f6\u534a\u8fdb\u5165\u8d4c\u573a\u3002\u6709\u4eba\u5c06\u5047\u7b79\u7801\u6df7\u5728\u771f\u7b79\u7801\u4e2d\u8fdb\u884c\u8d4c\u535a\uff0c\u4ea6\u6709\u4eba\u5728\u8d4c\u573a\u5468\u8fb9\u5c06\u7b79\u7801\u4e0e\u300c\u975e\u6cd5\u6362\u94b1\u515a\u300d\u5151\u6362\uff0c\u7136\u5f8c\u6d41\u5165\u8d4c\u5ba2\u624b\u4e0a\u3002<br/><br/>\u6848\u4ef6\u4e2d\uff0c\u8d4c\u573a\u62a5\u8b66\u635f\u59312\u4e07\u6e2f\u5143\uff1b11\u540d\u7537\u5973\u4e8b\u4e3b\u5408\u5171\u62a5\u79f0\u635f\u593158\u4e07\u6e2f\u5143\uff0c\u4f46\u5f53\u4e2d\u6709\u4eba\u6000\u7591\u662f\u300c\u6362\u94b1\u515a\u300d\uff0c\u4f1a\u53e6\u4f5c\u5904\u7406\u3002\u00a0(ST)</span>\n</div>", "pub_date": "2025-01-03 17:10:43", "link": "https://www.infocastfn.com/fn/ajax/news/newsDetail?newsId=4416363&locale=zh_CN", "source": "infocastfn", "kind": 2, "language": "zh-CN", "id": "4416363"}, {"title": "\u4fe1\u5229\u56fd\u9645(00732)\u7ec8\u6b62\u4fe1\u5229\u5de5\u4e1a(\u6c55\u5c3e)\u4e0a\u5e02\u8f85\u5bfc\u5907\u6848", "description": "<div id=\"newsBody\">\n<span class=\"newsDetail\" style=\"font-size: 13px; font-family:MingLiu;Arial;\">\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u4fe1\u5229\u56fd\u9645(00732)\u516c\u5e03\u5206\u62c6\u95f4\u63a5\u5168\u8d44\u9644\u5c5e\u4fe1\u5229\u5de5\u4e1a(\u6c55\u5c3e)\u5185\u5730\u72ec\u7acb\u4e0a\u5e02\u7684\u8fdb\u5c55\u3002\u6309\u7167\u73b0\u884c\u5e02\u51b5\u4f5c\u51fa\u8c03\u6574\u5f8c\uff0c\u8463\u4e8b\u4f1a\u51b3\u5b9a\u7ec8\u6b62\u4e0a\u5e02\u8f85\u5bfc\u5907\u6848\u5e76\u65bc2025\u5e741\u67083\u65e5\u5411\u4e2d\u56fd\u8bc1\u76d1\u4f1a\u5e7f\u4e1c\u76d1\u7ba1\u5c40\u4f5c\u51fa\u7ec8\u6b62\u7533\u8bf7\u3002<br/><br/>\u4e0a\u8ff0\u6709\u5173\u7ec8\u6b62\u4e0a\u5e02\u8f85\u5bfc\u5907\u6848\u7684\u7533\u8bf7\u4e0d\u4f1a\u5bf9\u516c\u53f8\u7684\u8d22\u653f\u72b6\u51b5\u6216\u8425\u8fd0\u6784\u6210\u91cd\u5927\u4e0d\u5229\u5f71\u54cd\u3002\u516c\u53f8\u5c06\u7ee7\u7eed\u76d1\u5bdf\u5e02\u573a\u53d8\u52a8\u5e76\u636e\u6b64\u5236\u8ba2\u5efa\u8bae\u5206\u62c6\u7684\u7b56\u7565\u3002<br/><br/>\u00a0(ST)</span>\n</div>", "pub_date": "2025-01-03 17:10:42", "link": "https://www.infocastfn.com/fn/ajax/news/newsDetail?newsId=4416364&locale=zh_CN", "source": "infocastfn", "kind": 2, "language": "zh-CN", "id": "4416364"}]}