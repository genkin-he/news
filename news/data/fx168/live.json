f0c\u4e0b\u964d5.4%\u3002</p>", "id": 787223, "description": "<p>\u30109\u6708\u65b0\u80fd\u6e90\u8f66\u9500\u91cf\u8fbe130.8\u4e07\u8f86\uff0c\u540c\u6bd4\u6fc0\u589e48.5%\u3011\u6700\u65b0\u62a5\u9053\uff0c\u56fd\u5bb6\u7edf\u8ba1\u5c4010\u670818\u65e5\u516c\u5e03\u7684\u6570\u636e\u663e\u793a\uff0c9\u6708\u4efd\u89c4\u6a21\u4ee5\u4e0a\u5de5\u4e1a\u589e\u52a0\u503c\u540c\u6bd4\u589e\u957f5.4%\uff0c\u589e\u901f\u8f83\u4e0a\u6708\u63d0\u53470.9\u4e2a\u767e\u5206\u70b9\u3002\u5728\u89c4\u6a21\u4ee5\u4e0a\u5de5\u4e1a\u751f\u4ea7\u7684619\u79cd\u4ea7\u54c1\u4e2d\uff0c\u6709345\u79cd\u4ea7\u54c1\u7684\u4ea7\u91cf\u5b9e\u73b0\u4e86\u540c\u6bd4\u589e\u957f\u3002\u5177\u4f53\u6765\u770b\uff0c\u94a2\u6750\u4ea7\u91cf\u4e3a11731\u4e07\u5428\uff0c\u540c\u6bd4\u4e0b\u964d2.4%\uff1b\u6c34\u6ce5\u4ea7\u91cf\u4e3a16847\u4e07\u5428\uff0c\u4e0b\u964d10.3%\uff1b\u5341\u79cd\u6709\u8272\u91d1\u5c5e\u4ea7\u91cf\u4e3a664\u4e07\u5428\uff0c\u589e\u957f2.2%\uff1b\u4e59\u70ef\u4ea7\u91cf\u4e3a267\u4e07\u5428\uff0c\u4e0b\u964d1.3%\uff1b\u6c7d\u8f66\u4ea7\u91cf\u4e3a283.9\u4e07\u8f86\uff0c\u4e0b\u964d1.0%\uff0c\u5176\u4e2d\u65b0\u80fd\u6e90\u6c7d\u8f66\u4ea7\u91cf\u4e3a130.8\u4e07\u8f86\uff0c\u540c\u6bd4\u589e\u957f48.5%\uff1b\u53d1\u7535\u91cf\u4e3a8024\u4ebf\u5343\u74e6\u65f6\uff0c\u589e\u957f6.0%\uff1b\u539f\u6cb9\u52a0\u5de5\u91cf\u4e3a5873\u4e07\u5428\uff0c\u4e0b\u964d5.4%\u3002</p>", "link": "https://www.fx168news.com/express/fastnews/787223", "pub_date": "2024-10-18 10:06:05"}, {"title": "<p>\u3010\u56fd\u5bb6\u7edf\u8ba1\u5c40\u53d1\u5e03\uff1a\u4eca\u5e74\u524d\u4e09\u5b63\u5ea6GDP\u540c\u6bd4\u589e\u957f4.8%\u3011\u6839\u636e\u56fd\u5bb6\u7edf\u8ba1\u5c4010\u670818\u65e5\u516c\u5e03\u7684\u521d\u6b65\u6838\u7b97\u6570\u636e\uff0c\u4eca\u5e74\u524d\u4e09\u5b63\u5ea6\u56fd\u5185\u751f\u4ea7\u603b\u503c\uff08GDP\uff09\u8fbe\u5230949746\u4ebf\u5143\uff0c\u4ee5\u4e0d\u53d8\u4ef7\u683c\u8ba1\u7b97\uff0c\u540c\u6bd4\u589e\u957f\u7387\u4e3a4.8%\u3002\u5177\u4f53\u5230\u5404\u4ea7\u4e1a\uff