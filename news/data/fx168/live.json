728\u65e9\u76d8\u4ea4\u6613\u4e2d\u4e0b\u8dcc\u4e860.8%\u3002", "id": 788880, "description": "\u3010\u6fb3\u5927\u5229\u4e9a\u80a1\u5e02\u9884\u8ba1\u9ad8\u5f00\uff0c\u9ec4\u91d1\u80a1\u6216\u9886\u6da8\u301110\u670821\u65e5\uff0c\u6fb3\u5927\u5229\u4e9a\u80a1\u5e02\u5728\u5468\u4e00\u5f00\u76d8\u65f6\u6709\u671b\u8fce\u6765\u4e0a\u6da8\uff0c\u8fd9\u4e3b\u8981\u5f97\u76ca\u4e8e\u9ec4\u91d1\u80a1\u7684\u6f5c\u5728\u4e0a\u6da8\uff0c\u8fd9\u53ef\u80fd\u4f1a\u62b5\u6d88\u77ff\u4e1a\u548c\u80fd\u6e90\u80a1\u56e0\u5927\u5b97\u5546\u54c1\u4ef7\u683c\u4e0b\u8dcc\u800c\u53ef\u80fd\u51fa\u73b0\u7684\u4e0b\u8dcc\u3002\u6fb3\u5927\u5229\u4e9a\u7684\u80a1\u6307\u671f\u8d27\u5df2\u7ecf\u4e0a\u6da8\u4e860.5%\uff0c\u6bd4S&P/ASX200\u6307\u6570\u7684\u6536\u76d8\u4ef7\u9ad8\u51fa81.8\u70b9\u3002\u503c\u5f97\u6ce8\u610f\u7684\u662f\uff0c\u8be5\u6307\u6570\u5728\u4e0a\u5468\u4e94\u4e0b\u8dcc\u4e860.9%\u3002\u4e0e\u6b64\u540c\u65f6\uff0c\u65b0\u897f\u5170\u7684\u6807\u51c6\u666e\u5c14/NZX50\u6307\u6570\u5728\u65e9\u76d8\u4ea4\u6613\u4e2d\u4e0b\u8dcc\u4e860.8%\u3002", "link": "https://www.fx168news.com/express/fastnews/788880", "pub_date": "2024-10-21 05:38:27"}, {"title": "\u8054\u5408\u56fd\u5728\u9ece\u5df4\u5ae9\u7684\u4e34\u65f6\u90e8\u961f\uff08\u8054\u9ece\u90e8\u961f\uff09\u4e8e20\u65e5\u5bf9\u5916\u5ba3\u5e03\uff0c\u5bf9\u4ee5\u8272\u5217\u519b\u961f\u5f53\u5929\u6545\u610f\u62c6\u9664\u4f4d\u4e8e\u9ece\u5df4\u5ae9\u5357\u90e8\u8fb9\u754c\u7684\u8054\u9ece\u90e8\u961f\u54e8\u6240\u7684\u884c\u4e3a\u8868\u793a\u8c34\u8d23\u3002", "id": 788878, "description": "\u8054\u5408\u56fd\u5728\u9ece\u5df4\u5ae9\u7684\u4e34\u65f6\u90e8\u961f\uff08\u8054\u9ece\u90e8\u961f\uff09\u4e8e20\u65e5\u5bf9\u5916\u5ba3\u5e03\uff0c\u5bf9\u4ee5\u8272\u5217\u519b\u961f\u5f53\u5929\u6545\u610f\u62c6\u9664\u4f4d\u4e8e\u9ece\u5df4\u5ae9\u5357\u90e8\u8fb9\u754c\u7684\u8054\u9ece\u90e8\u961f\u54e8\u6240\u7684\u884c\u4e3a\u8868\u793a\u8c34\u8d23\u3002", "link": "https://www.fx168news.com/express/fastnews/788878", "pub_date": "2024-10-21 05:30:57"}, {"title": "\u3010\u666e\u4eac\u5f3a\u8c03\u4fc4\u963f\u6218\u7565\u4f19\u4f34\u5173\u7cfb\u301110\u670821\u65e5\uff0c\u4fc4\u7f57\u65af\u603b\u7edf\u666e\u4eac\u5728\u4f1a\u89c1\u963f\u8054\u914b\u603b\u7edf\u65f6\uff0c\u79f0\u8d5e\u4e24\u56fd\u5173\u7cfb\u4e3a\u201c\u6218\u7565\u4f19\u4f34\u5173\u7cfb\u201d\u3002\u666e\u4eac\u5bf9\u963f\u8054\u914b\u603b\u7edf\u5728\u4fc4\u4e4c\u6218\u4fd8\u4ea4\u6362\u4e2d\u7684\u8c03\u89e3\u4f5c\u7528\u8868\u793a\u611f\u8c22\u3002\u666e\u4eac\u8fd8\u63d0\u5230\u4e2d\u4e1c\u5c40\u52bf\u590d\u6742\uff0c\u4ee5\u8272\u5217\u5bf9\u52a0\u6c99\u548c\u9ece\u5df4\u5ae9\u5357\u90e8\u7684\u519b\u4e8b\u884c\u52a8\u3002\u666e\u4eac\u5bf9\u963f\u8054\u914b\u603b\u7edf\u5728\u4fc4\u4e4c\u51b2\u7a81\u4e2d\u534f\u52a9\u5b89\u6392\u56da\u72af\u4ea4\u6362\u8868\u793a\u611f\u6fc0\u3002", "id": 788871, "description": "\u3010\u666e\u4eac\u5f3a\u8c03\u4fc4\u963f\u6218\u7565\u4f19\u4f34\u5173\u7cfb\u301110\u670821\u65e5\uff0c\u4fc4\u7f57\u65af\u603b\u7edf\u666e\u4eac\u5728\u4f1a\u89c1\u963f\u8054\u914b\u603b\u7edf\u65f6\uff0c\u79f0\u8d5e\u4e24\u56fd\u5173\u7cfb\u4e3a\u201c\u6218\u7565\u4f19\u4f34\u5173\u7cfb\u201d\u3002\u666e\u4eac\u5bf9\u963f\u8054\u914b\u603b\u7edf\u5728\u4fc4\u4e4c\u6218\u4fd8\u4ea4\u6362\u4e2d\u7684\u8c03\u89e3\u4f5c\u7528\u8868\u793a\u611f\u8c22\u3002\u666e\u4eac\u8fd8\u63d0\u5230\u4e2d\u4e1c\u5c40\u52bf\u590d\u6742\uff0c\u4ee5\u8272\u5217\u5bf9\u52a0\u6c99\u548c\u9ece\u5df4\u5ae9\u5357\u90e8\u7684\u519b\u4e8b\u884c\u52a8\u3002\u666e\u4eac\u5bf9\u963f\u8054\u914b\u603b\u7edf\u5728\u4fc4\u4e4c\u51b2\u7a81\u4e2d\u534f\u52a9\u5b89\u6392\u56da\u72af\u4ea4\u6362\u8868\u793a\u611f\u6fc0\u3002", "link": "https://www.fx168news.com/express/fastnews/788871", "pub_date": "2024-10-21 05:27:11"}]}