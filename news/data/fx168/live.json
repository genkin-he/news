u5728\u5854\u65af\u793e\u7684\u8bbf\u8c08\u4e2d\u6307\u51fa\uff0c\u6b27\u6d32\u7684\u7eb3\u7a0e\u4eba\u672a\u6765\u5c06\u4e0d\u5f97\u4e0d\u4e3a\u6b27\u76df\u548c\u6b27\u6d32\u8bae\u4f1a\u7a83\u53d6\u4fc4\u7f57\u65af\u8d44\u4ea7\u7684\u884c\u4e3a\u627f\u62c5\u540e\u679c\u3002\u4ed6\u6240\u6307\u7684\u662f\u6b27\u6d32\u6279\u51c6\u5411\u4e4c\u514b\u5170\u63d0\u4f9b\u9ad8\u8fbe350\u4ebf\u6b27\u5143\u7684\u8d37\u6b3e\uff0c\u540c\u65f6\u5c06\u51bb\u7ed3\u7684\u4fc4\u7f57\u65af\u8d44\u4ea7\u7684\u518d\u6295\u8d44\u6536\u76ca\u4f5c\u4e3a\u6536\u5165\u6765\u6e90\u3002", "id": 791113, "description": "\u3010\u4fc4\u5b98\u5458\uff1a\u6b27\u6d32\u540e\u4ee3\u6216\u4e3a\u6b27\u76df\u7a83\u53d6\u4fc4\u8d44\u4ea7\u4ed8\u51fa\u4ee3\u4ef7\u301110\u670822\u65e5\uff0c\u4fc4\u7f57\u65af\u9a7b\u6b27\u76df\u7279\u4f7f\u57fa\u91cc\u5c14\u00b7\u6d1b\u683c\u7ef4\u8bfa\u592b\u5728\u5854\u65af\u793e\u7684\u8bbf\u8c08\u4e2d\u6307\u51fa\uff0c\u6b27\u6d32\u7684\u7eb3\u7a0e\u4eba\u672a\u6765\u5c06\u4e0d\u5f97\u4e0d\u4e3a\u6b27\u76df\u548c\u6b27\u6d32\u8bae\u4f1a\u7a83\u53d6\u4fc4\u7f57\u65af\u8d44\u4ea7\u7684\u884c\u4e3a\u627f\u62c5\u540e\u679c\u3002\u4ed6\u6240\u6307\u7684\u662f\u6b27\u6d32\u6279\u51c6\u5411\u4e4c\u514b\u5170\u63d0\u4f9b\u9ad8\u8fbe350\u4ebf\u6b27\u5143\u7684\u8d37\u6b3e\uff0c\u540c\u65f6\u5c06\u51bb\u7ed3\u7684\u4fc4\u7f57\u65af\u8d44\u4ea7\u7684\u518d\u6295\u8d44\u6536\u76ca\u4f5c\u4e3a\u6536\u5165\u6765\u6e90\u3002", "link": "https://www.fx168news.com/express/fastnews/791113", "pub_date": "2024-10-22 23:22:23"}, {"title": "<p>\u3010\u5206\u6790\u9884\u6d4b\uff1a\u7f8e\u56fd\u623f\u4ea7\u5e02\u573a\u6301\u7eed\u5347\u6e29\u301110\u670822\u65e5\u7684\u62a5\u9053\u6307\u51fa\uff0c\u5c3d\u7ba1\u62b5\u62bc\u8d37\u6b3e\u5229\u7387\u6709\u6240\u56de\u843d\uff0c\u7f8e\u56fd\u623f\u4ef7\u4f9d\u7136\u5448\u73b0\u4e0a\u5347\u8d8b\u52bf\u3002\u6839\u636eRedfin\u7684\u6570\u636e\uff0c9\u6708\u4efd\u7f8e\u56fd\u623f\u4ef7\u73af\u6bd4\u589e\u957f\u4e860.5%\uff0c\u521b\u4e0b\u81ea4\u6708\u4ee5\u6765\u7684\u6700\u9ad8\u6708\u5ea6\u589e\u5e45\uff0c\u5e76\u8fde\u7eed\u4e09\u4e2a\u6708\u5b9e\u73b0\u589e\u957f\u3002\u5c3d\u7ba1\u5982\u6b64\uff0c\u623f\u4ef7\u540c\u6bd4\u589e\u957f\u7387\u4e3a6%\uff0c\u8fd9\u662f\u81ea\u53bb\u5e7412\u6708\u4ee5\u6765\u7684\u6700\u4f4e\u5e74\u589e\u957f\u7387\u30029\u6708\u4efd\uff0c\u7531\u4e8e\u5229\u7387\u4e0b\u964d\u81f36.08%\uff0c\u62b5\u62bc\u8d37\u6b3e\u7684\u8d1f\u62c5\u80fd\u529b\u6709\u6240\u63d0\u5347\uff0c\u4f46\u623f\u6e90\u7d27\u5f20\u5bfc\u81f4\u623f\u4ef7\u7ee7\u7eed\u4e0a\u5347\u3002Redfin\u6307\u51fa\uff0c\u5f53\u524d\u5e02\u573a\u4e0a\u7684\u623f\u6e90\u6570\u91cf\u8f83\u4e94\u5e74\u524d\u51cf\u5c11\u4e86\u7ea620%\uff0c\u8fd9\u4e3b\u8981\u662f\u7531\u4e8e\u75ab\u60c5\u671f\u95f4\u8bb8\u591a\u623f\u4e3b\u9009\u62e9\u9501\u5b9a\u4e86\u8f83\u4f4e\u7684\u62b5\u62bc\u8d37\u6b3e\u5229\u7387\u3002\u5728\u6625\u5b63\u66f4\u591a\u623f\u6e90\u4e0a\u5e02\u524d\uff0c\u9884\u8ba1\u623f\u4ef7\u5c06\u7ee7\u7eed\u4e0a\u6da8\u3002</p>", "id": 791105, "description": "<p>\u3010\u5206\u6790\u9884\u6d4b\uff1a\u7f8e\u56fd\u623f\u4ea7\u5e02\u573a\u6301\u7eed\u5347\u6e29\u301110\u670822\u65e5\u7684\u62a5\u9053\u6307\u51fa\uff0c\u5c3d\u7ba1\u62b5\u62bc\u8d37\u6b3e\u5229\u7387\u6709\u6240\u56de\u843d\uff0c\u7f8e\u56fd\u623f\u4ef7\u4f9d\u7136\u5448\u73b0\u4e0a\u5347\u8d8b\u52bf\u3002\u6839\u636eRedfin\u7684\u6570\u636e\uff0c9\u6708\u4efd\u7f8e\u56fd\u623f\u4ef7\u73af\u6bd4\u589e\u957f\u4e860.5%\uff0c\u521b\u4e0b\u81ea4\u6708\u4ee5\u6765\u7684\u6700\u9ad8\u6708\u5ea6\u589e\u5e45\uff0c\u5e76\u8fde\u7eed\u4e09\u4e2a\u6708\u5b9e\u73b0\u589e\u957f\u3002\u5c3d\u7ba1\u5982\u6b64\uff0c\u623f\u4ef7\u540c\u6bd4\u589e\u957f\u7387\u4e3a6%\uff0c\u8fd9\u662f\u81ea\u53bb\u5e7412\u6708\u4ee5\u6765\u7684\u6700\u4f4e\u5e74\u589e\u957f\u7387\u30029\u6708\u4efd\uff0c\u7531\u4e8e\u5229\u7387\u4e0b\u964d\u81f36.08%\uff0c\u62b5\u62bc\u8d37\u6b3e\u7684\u8d1f\u62c5\u80fd\u529b\u6709\u6240\u63d0\u5347\uff0c\u4f46\u623f\u6e90\u7d27\u5f20\u5bfc\u81f4\u623f\u4ef7\u7ee7\u7eed\u4e0a\u5347\u3002Redfin\u6307\u51fa\uff0c\u5f53\u524d\u5e02\u573a\u4e0a\u7684\u623f\u6e90\u6570\u91cf\u8f83\u4e94\u5e74\u524d\u51cf\u5c11\u4e86\u7ea620%\uff0c\u8fd9\u4e3b\u8981\u662f\u7531\u4e8e\u75ab\u60c5\u671f\u95f4\u8bb8\u591a\u623f\u4e3b\u9009\u62e9\u9501\u5b9a\u4e86\u8f83\u4f4e\u7684\u62b5\u62bc\u8d37\u6b3e\u5229\u7387\u3002\u5728\u6625\u5b63\u66f4\u591a\u623f\u6e90\u4e0a\u5e02\u524d\uff0c\u9884\u8ba1\u623f\u4ef7\u5c06\u7ee7\u7eed\u4e0a\u6da8\u3002</p>", "link": "https://www.fx168news.com/express/fastnews/791105", "pub_date": "2024-10-22 23:15:58"}]}