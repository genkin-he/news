168news.com/express/fastnews/833692", "pub_date": "2024-12-20 17:24:03", "source": "fx168", "kind": 2, "language": "en"}, {"title": "\u6bd4\u7279\u5e01\u65e5\u5185\u8dcc\u8d855%\uff0c\u903c\u8fd195000\u7f8e\u5143\u3002\u52a0\u5bc6\u8d27\u5e01\u6982\u5ff5\u80a1\u76d8\u524d\u8d70\u4f4e\uff0cBit Digital\u8dcc\u903e7%\uff0cMicroStrategy\u8dcc\u8d855%\uff0cCoinbase\u8dcc\u903e4%\u3002", "id": 833684, "description": "", "link": "https://www.fx168news.com/express/fastnews/833684", "pub_date": "2024-12-20 17:19:02", "source": "fx168", "kind": 2, "language": "en"}, {"title": "\u4ee3\u8868\u661f\u5df4\u514b1\u4e07\u591a\u540d\u5496\u5561\u5e08\u7684\u5de5\u4f1a\u8868\u793a\uff0c\u5176\u6210\u5458\u5c06\u4ece\u5f53\u5730\u65f6\u95f412\u670820\u65e5\u5f00\u59cb\u5728\u6d1b\u6749\u77f6\u3001\u829d\u52a0\u54e5\u548c\u897f\u96c5\u56fe\u7684\u95e8\u5e97\u4e3e\u884c\u4e3a\u671f\u4e94\u5929\u7684\u7f62\u5de5\uff0c\u7406\u7531\u662f\u5de5\u8d44\u3001\u4eba\u5458\u914d\u5907\u548c\u65e5\u7a0b\u5b89\u6392\u7b49\u95ee\u9898\u5c1a\u672a\u89e3\u51b3\u3002\u4ee3\u8868\u5168\u7f8e525\u5bb6\u661f\u5df4\u514b\u95e8\u5e97\u5458\u5de5\u7684\u5de5\u4eba\u8054\u5408\u5de5\u4f1a19\u65e5\u665a\u8868\u793a\uff0c\u7f62\u5de5\u6bcf\u5929\u90fd\u5728\u5347\u7ea7\uff0c\u5230\u5e73\u5b89\u591c\u65f6\u53ef\u80fd\u4f1a\u8fbe\u5230\u5168\u56fd\u201c\u6570\u767e\u5bb6\u95e8\u5e97\u201d\u3002\u661f\u5df4\u514b\u79f0\uff0c\u5de5\u4f1a\u4ee3\u8868\u63d0\u524d\u7ed3\u675f\u4e86\u672c\u5468\u7684\u8c08\u5224\u4f1a\u8bae\uff0c\u516c\u53f8\u5df2\u51c6\u5907\u597d\u7ee7\u7eed\u8c08\u5224\u3002", "id": 833685, "description": "", "link": "https://www.fx168news.com/express/fastnews/833685", "pub_date": "2024-12-20 17:19:02", "source": "fx168", "kind": 2, "language": "en"}, {"title": "\u4fc4\u7f57\u65af\u56fd\u9632\u90e8\uff1a\u4fc4\u7f57\u65af\u519b\u961f\u63a7\u5236\u4e86\u4e4c\u514b\u5170\u4e1c\u90e8\u7684\u4e4c\u65af\u6f58\u5c3c\u592b\u5361\u548c\u8bfa\u6c83\u666e\u65af\u5ef7\u5361\uff08Uspenivka,\u3001Novopustynka\u