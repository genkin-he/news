4e3a7044\u4e07\u5428\uff0c\u540c\u6bd4\u4e0a\u53471.0%\u3002\u5177\u4f53\u6765\u770b\uff0c\u725b\u8089\u548c\u79bd\u8089\u4ea7\u91cf\u5206\u522b\u589e\u957f\u4e864.6%\u548c6.4%\uff0c\u800c\u732a\u8089\u548c\u7f8a\u8089\u4ea7\u91cf\u5219\u5206\u522b\u4e0b\u964d\u4e861.4%\u548c2.2%\u3002\u725b\u5976\u4ea7\u91cf\u5fae\u964d0.1%\uff0c\u79bd\u86cb\u4ea7\u91cf\u5219\u589e\u957f\u4e863.5%\u3002\u81f3\u4e09\u5b63\u5ea6\u672b\uff0c\u751f\u732a\u5b58\u680f\u91cf\u4e3a42694\u4e07\u5934\uff0c\u540c\u6bd4\u51cf\u5c11\u4e863.5%\uff1b\u524d\u4e09\u5b63\u5ea6\u751f\u732a\u51fa\u680f\u91cf\u4e3a52030\u4e07\u5934\uff0c\u540c\u6bd4\u51cf\u5c11\u4e863.2%\u3002</p>", "id": 787233, "description": "<p>\u3010\u56fd\u5bb6\u7edf\u8ba1\u5c40\u6700\u65b0\u6570\u636e\uff1a\u524d\u4e09\u5b63\u5ea6\u751f\u732a\u51fa\u680f\u91cf\u51cf\u5c113.2%\u3011\u636e10\u670818\u65e5\u56fd\u5bb6\u7edf\u8ba1\u5c40\u516c\u5e03\u7684\u4fe1\u606f\uff0c\u4eca\u5e74\u524d\u4e09\u5b63\u5ea6\uff0c\u4e2d\u56fd\u519c\u4e1a\uff08\u79cd\u690d\u4e1a\uff09\u589e\u52a0\u503c\u5b9e\u73b0\u4e863.7%\u7684\u589e\u957f\u3002\u590f\u7cae\u548c\u65e9\u7a3b\u7684\u603b\u4ea7\u91cf\u8fbe\u5230\u4e8617795\u4e07\u5428\uff0c\u76f8\u8f83\u53bb\u5e74\u540c\u671f\u589e\u52a0\u4e86346\u4e07\u5428\uff0c\u589e\u957f\u7387\u4e3a2.0%\u3002\u76ee\u524d\u79cb\u6536\u5de5\u4f5c\u8fdb\u5c55\u987a\u5229\uff0c\u9884\u8ba1\u5168\u5e74\u7cae\u98df\u4ea7\u91cf\u5c06\u518d\u6b21\u8fce\u6765\u4e30\u6536\u3002\u5728\u8089\u7c7b\u4ea7\u91cf\u65b9\u9762\uff0c\u524d\u4e09\u5b63\u5ea6\u732a\u725b\u7f8a\u79bd\u8089\u603b\u4ea7\u91cf\u4e3a7044\u4e07\u5428\uff0c\u540c\u6bd4\u4e0a\u53471.0%\u3002\u5177\u4f53\u6765\u770b\uff0c\u725b\u8089\u548c\u79bd\u8089\u4ea7\u91cf\u5206\u522b\u589e\u957f\u4e864.6%\u548c6.4%\uff0c\u800c\u732a\u8089\u548c\u7f8a\u8089\u4ea7\u91cf\u5219\u5206\u522b\u4e0b\u964d\u4e861.4%\u548c2.2%\u3002\u725b\u5976\u4ea7\u91cf\u5fae\u964d0.1%\uff0c\u79bd\u86cb\u4ea7\u91cf\u5219\u589e\u957f\u4e863.5%\u3002\u81f3\u4e09\u5b63\u5ea6\u672b\uff0c\u751f\u