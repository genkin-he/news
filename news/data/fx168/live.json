{"data": [{"title": "\u6b27\u5143\uff1a\u7f8e\u8054\u50a8\u4f1a\u8bae\u540e\u7684\u8dcc\u52bf\u6301\u7a33\u5728 11 \u6708\u4f4e\u70b9\u9644\u8fd1 - \u4e30\u4e1a\u94f6\u884c", "id": 832690, "description": "", "link": "https://www.fx168news.com/express/fastnews/832690", "pub_date": "2024-12-19 21:22:14"}, {"title": "\u6c47\u4e30\u8d44\u4ea7\u7ba1\u7406\u516c\u53f8\u5206\u6790\u5e08\u8fc8\u8d6b\u8fea\u5728\u4e00\u4efd\u62a5\u544a\u4e2d\u8bf4\uff0c\u7531\u4e8e\u82f1\u56fd\u592e\u884c\u5bf9\u5bbd\u677e\u653f\u7b56\u4ecd\u6301\u8c28\u614e\u6001\u5ea6\uff0c\u82f1\u56fd\u7ecf\u6d4e\u53ef\u80fd\u9700\u8981\u9002\u5e94\u66f4\u957f\u65f6\u95f4\u5185\u4fdd\u6301\u66f4\u9ad8\u7684\u5229\u7387\u3002\u82f1\u56fd\u592e\u884c\u5468\u56db\u4ee56\u6bd43\u7684\u6295\u7968\u7ed3\u679c\u51b3\u5b9a\u7ef4\u6301\u5229\u7387\u4e0d\u53d8\uff0c\u5e76\u91cd\u7533\u9010\u6b65\u964d\u606f\u7684\u6b65\u4f10\u4ecd\u662f\u5408\u9002\u7684\u3002\u5e02\u573a\u9884\u8ba12025\u5e74\u53ea\u4f1a\u6709\u4e24\u6b21\u964d\u606f\u3002\u867d\u7136\u6211\u4eec\u8ba4\u4e3a\u5728\u52b3\u52a8\u529b\u9700\u6c42\u51cf\u5f31\u7684\u8ff9\u8c61\u4e0b\uff0c\u98ce\u9669\u503e\u5411\u4e8e\u8fdb\u4e00\u6b65\u964d\u606f\uff0c\u4f46\u73b0\u5b9e\u60c5\u51b5\u662f\uff0c\u901a\u80c0\u88ab\u8bc1\u660e\u662f\u987d\u56fa\u548c\u6301\u7eed\u7684\u3002\u5229\u7387\u4e0d\u592a\u53ef\u80fd\u964d\u52304%\u4ee5\u4e0b\u3002", "id": 832691, "description": "", "link": "https://www.fx168news.com/express/fastnews/832691", "pub_date": "2024-12-19 21:23:02"}, {"title": "\u5f53\u5730\u65f6\u95f412\u670819\u65e5\uff0c\u7f8e\u56fd\u5546\u52a1\u90e8\u786e\u8ba4\u9488\u5bf9\u97e9\u56fd\u82af\u7247\u5236\u9020\u5546SK\u6d77\u529b\u58eb\u7684\u300a\u82af\u7247\u4e0e\u79d1\u5b66\u6cd5\u6848\u300b\u6fc0\u52b1\u63aa\u65bd\uff0c\u5c06\u5411\u5176\u63d0\u4f9b4.58\u4ebf\u7f8e\u5143\u7684\u76f4\u63a5\u8865\u8d34\u3002\u636e\u4ecb\u7ecd\uff0c\u8fd9\u7b14\u8d44\u91d1\u65e8\u5728\u652f\u6301SK\u6d77\u529b\u58eb\u5728\u5370\u7b2c\u5b89\u7eb3\u5dde\u65b0\u5efa\u4eba\u5de5\u667a\u80fd\u82af\u7247\u5148\u8fdb\u5c01\u88c5\u751f\u4ea7\u57fa\u5730\u3002\u4f5c\u4e3a\u82f1\u4f1f\u8fbe\u7684\u4f9b\u5e94\u5546\uff0cSK\u6d77\u529b\u58eb4\u6708\u5ba3\u5e03\u5c06\u65a5\u8d4438.7\u4ebf\u7f8e\u5143\u5728\u5370\u7b2c\u5b89\u7eb3\u5dde\u5efa\u9020\u9002\u4e8eAI\u7684\u82af\u7247\u5c01\u88c5\u5382\u3002\u9664\u4e86\u8865\u52a9\u91d1\u5916\uff0c\u7f8e\u5546\u52a1\u90e8\u8fd8\u8ba1\u5212\u4e3aSK\u6d77\u529b\u58eb\u9879\u76ee\u63d0\u4f9b\u6700\u9ad85\u4ebf\u7f8e\u5143\u7684\u653f\u5e9c\u8d37\u6b3e\u3002", "id": 832692, "description": "", "link": "https://www.fx168news.com/express/fastnews/832692", "pub_date": "2024-12-19 21:23:02"}, {"title": "<div>\u7f8e\u5143/\u52a0\u5143\u76d8\u4e2d\u7a81\u7834\u6708\u7b2c\u4e8c\u963b\u529b\u4f4d1.43600\uff0c\u73b0\u62a51.43601\uff0c\u4e0b\u4e00\u963b\u529b\u4f4d\u4e3a1.45425</div>", "id": 832686, "description": "", "link": "https://www.fx168news.com/express/fastnews/832686", "pub_date": "2024-12-19 21:15:00"}, {"title": "\u4fc4\u7f57\u65af\u603b\u7edf\u666e\u4eac\uff1a\u6211\u4eec\u5c06\u6269\u5927\u5728\u5168\u7403\u6db2\u5316\u5929\u7136\u6c14\u5e02\u573a\u7684\u4efd\u989d\u3002", "id": 832687, "description": "", "link": "https://www.fx168news.com/express/fastnews/832687", "pub_date": "2024-12-19 21:15:02"}, {"title": "12 \u6708\uff0c\u94c0\u671f\u8d27\u4ef7\u683c\u8dcc\u81f3\u6bcf\u78c5 75 \u7f8e\u5143\u4ee5\u4e0b\uff0c\u521b\u4e00\u5e74\u591a\u4ee5\u6765\u7684\u6700\u4f4e\u6c34\u5e73\uff0c\u56e0\u4e3a\u5e02\u573a\u6301\u7eed\u8ba4\u4e3a\u94c0\u77ff\u4f9b\u5e94\u5145\u8db3\u3002\u5c3d\u7ba1\u6700\u8fd1\u5728\u786b\u9178\u4f9b\u5e94\u65b9\u9762\u9047\u5230\u56f0\u96be\uff0c\u4f46\u4e16\u754c\u6700\u5927\u94c0\u751f\u4ea7\u5546 Kazatomprom \u660e\u5e74\u4ecd\u5c06\u63d0\u9ad8\u94c0\u4ea7\u91cf\u3002\u897f\u65b9\u77ff\u5546\u4e5f\u5c06\u589e\u52a0\u5e02\u573a\u4f9b\u5e94\uff0c\u745e\u94f6\u9884\u6d4b Paladin Energy \u548c Boss Energy \u7684\u4f9b\u5e94\u5c06\u589e\u52a0\u3002\u6b64\u524d\uff0c\u4fc4\u7f57\u65af\u7981\u6b62\u5411\u7f8e\u56fd\u51fa\u552e\u6d53\u7f29\u94c0\uff0c\u4ee5\u56de\u5e94\u534e\u76db\u987f\u7981\u6b62\u8fdb\u53e3\u4fc4\u7f57\u65af\u6838\u71c3\u6599\u7684\u51b3\u5b9a\u3002\u4e0d\u8fc7\uff0c\u53cc\u65b9\u7684\u9650\u5236\u90fd\u5f88\u7075\u6d3b\uff0c\u5728\u5e02\u573a\u7d27\u5f20\u7684\u60c5\u51b5\u4e0b\u5141\u8bb8\u8c41\u514d\uff0c\u4ece\u800c\u9650\u5236\u4e86\u653f\u7b56\u5bf9\u5168\u7403\u4f9b\u5e94\u9020\u6210\u7684\u5371\u5bb3\u3002\u5c3d\u7ba1\u81ea\u4fc4\u7f57\u65af\u5165\u4fb5\u4e4c\u514b\u5170\u4ee5\u6765\uff0c\u7531\u4e8e\u4f9b\u5e94\u94fe\u4e2d\u65ad\uff0c\u5c06\u94c0\u8f6c\u5316\u4e3a\u6838\u71c3\u6599\u7684\u6d53\u7f29\u4ef7\u683c\u5f98\u5f8a\u5728\u5386\u53f2\u9ad8\u4f4d\u9644\u8fd1\uff0c\u4f46\u76f8\u5bf9\u5145\u8db3\u7684\u9ec4\u997c\u4f9b\u5e94\u4f7f\u4ef7\u683c\u7ef4\u6301\u5728\u8fd1\u671f\u4f4e\u70b9\u3002", "id": 832688, "description": "", "link": "https://www.fx168news.com/express/fastnews/832688", "pub_date": "2024-12-19 21:15:03"}, {"title": "\u8d1d\u83b1\u5fb7\u6bd4\u7279\u5e01\u6301\u4ed3\u7a81\u783455\u4e07\u679aBTC\uff0c\u5e02\u503c\u8d85560\u4ebf\u7f8e\u5143", "id": 832682, "description": "", "link": "https://www.fx168news.com/express/fastnews/832682", "pub_date": "2024-12-19 21:07:03"}, {"title": "\u4fc4\u7f57\u65af \u4fc4\u7f57\u65af\u592e\u884c\u50a8\u5907\uff08\u7f8e\u5143\uff09: $618.2B  vs $614.4B", "id": 832683, "description": "", "link": "https://www.fx168news.com/express/fastnews/832683", "pub_date": "2024-12-19 21:08:13"}, {"title": "\u609f\u7a7a\u6295\u8d44\u6295\u7814\u603b\u88c1\u6c5f\u656c\u658712\u670819\u65e5\u8868\u793a\uff0c\u76ee\u524dA\u80a1\u5e02\u573a\u5904\u4e8e\u9707\u8361\u4e0a\u884c\u7684\u56de\u5347\u5468\u671f\u4e2d\uff0c\u7ee7\u7eed\u5411\u4e0a\u53ef\u4ee5\u671f\u5f85\u3002\u4e00\u65b9\u9762\uff0c\u8fd1\u51e0\u5e74\u5e02\u573a\u8d70\u52bf\u8f83\u5f31\uff0c\u52309\u6708\u5e95\u5e02\u573a\u63a2\u5e95\uff0c\u6295\u8d44\u8005\u4fe1\u5fc3\u4e5f\u5904\u4e8e\u5e95\u90e8\uff0c\u5404\u79cd\u5229\u7a7a\u56e0\u7d20\u57fa\u672c\u5df2\u7ecf\u5728\u80a1\u4ef7\u4e2d\u5145\u5206\u53cd\u6620\uff0c\u56e0\u6b64\u5e02\u573a\u7ee7\u7eed\u4e0b\u884c\u7684\u7a7a\u95f4\u4e0d\u5927\uff1b\u53e6\u4e00\u65b9\u9762\uff0c\u968f\u7740\u653f\u7b56\u9646\u7eed\u51fa\u53f0\uff0c\u6295\u8d44\u8005\u7684\u4fe1\u5fc3\u5f97\u5230\u626d\u8f6c\uff0c\u80fd\u591f\u5438\u5f15\u5230\u66f4\u591a\u573a\u5916\u8d44\u91d1\u5165\u573a\uff0c\u6574\u4e2a\u5e02\u573a\u5177\u5907\u4e86\u91cd\u65b0\u5411\u4e0a\u7684\u57fa\u7840\u3002\u63a5\u4e0b\u6765\uff0c\u5e02\u573a\u5411\u4e0a\u7684\u7a7a\u95f4\u9700\u8981\u7b49\u5f85\u540e\u7eed\u57fa\u672c\u9762\u7684\u9a8c\u8bc1\u60c5\u51b5\u3002", "id": 832679, "description": "", "link": "https://www.fx168news.com/express/fastnews/832679", "pub_date": "2024-12-19 21:02:02"}, {"title": "\u82f1\u9551/\u7f8e\u5143\uff1a\u82f1\u56fd\u592e\u884c\u6309\u5175\u4e0d\u52a8 - \u52a0\u62ff\u5927\u4e30\u4e1a\u94f6\u884c", "id": 832680, "description": "", "link": "https://www.fx168news.com/express/fastnews/832680", "pub_date": "2024-12-19 21:02:13"}]}