u529b\u3002", "id": 790361, "description": "\u65e5\u672c\u592e\u884c\u9ad8\u7ea7\u5b98\u5458\u52a0\u85e4\u80dc\u4fe1\u8868\u793a\uff0c\u4ed6\u4eec\u671f\u671b\u5bf9\u7f8e\u56fd\u7684\u7ecf\u6d4e\u72b6\u51b5\u3001\u5373\u5c06\u5230\u6765\u7684\u9009\u4e3e\u4ee5\u53ca\u7f8e\u8054\u50a8\u7684\u653f\u7b56\u8d70\u5411\u8fdb\u884c\u8be6\u5c3d\u7684\u5206\u6790\u3002\u4ed6\u5f3a\u8c03\uff0c\u65e5\u672c\u592e\u884c\u5e76\u4e0d\u65e8\u5728\u5e72\u9884\u5916\u6c47\u5e02\u573a\u7684\u6c47\u7387\u6c34\u5e73\uff0c\u4f46\u4f1a\u6301\u7eed\u5173\u6ce8\u56e0\u8fdb\u53e3\u6210\u672c\u4e0a\u5347\u53ef\u80fd\u5f15\u53d1\u7684\u901a\u8d27\u81a8\u80c0\u538b\u529b\u3002", "link": "https://www.fx168news.com/express/fastnews/790361", "pub_date": "2024-10-22 11:44:39"}, {"title": "\u3010\u5317\u8bc150\u6307\u657015\u5929\u7ffb\u500d\u540e\u906d\u9047\u5267\u70c8\u6ce2\u52a8\u301110\u670822\u65e5\u65b0\u95fb\u62a5\u9053\uff0c\u5317\u8bc150\u6307\u6570\u5728\u5f00\u76d8\u540e\u8fc5\u901f\u4e0b\u8dcc\uff0c\u6700\u5927\u8dcc\u5e45\u8d85\u8fc78%\uff0c\u5176\u4e2d\u827e\u878d\u8f6f\u4ef6\u8fd9\u4e00\u5927\u725b\u80a1\u8dcc\u5e45\u4e00\u5ea6\u8d85\u8fc720%\uff0c\u4e91\u521b\u6570\u636e\u3001\u5764\u535a\u7cbe\u5de5\u3001\u51ef\u534e\u6750\u6599\u3001\u9752\u77e9\u6280\u672f\u3001\u6d77\u6607\u836f\u4e1a\u7b49\u8d85\u8fc770\u53ea\u5317\u4ea4\u6240\u80a1\u7968\u4e00\u5ea6\u8dcc\u5e45\u8d85\u8fc710%\u3002\u4e0d\u4e45\u540e\uff0c\u8d44\u91d1\u6d41\u5165\uff0c\u5317\u8bc150\u6307\u6570\u5f97\u4ee5\u56de\u5347\u81f3\u7ea2\u8272\u533a\u57df\u3002\u7136\u800c\uff0c\u591a\u5934\u529b\u91cf\u4f3c\u4e4e\u6709\u6240\u51cf\u5f31\uff0c\u6307\u6570\u518d\u6b21\u56de\u843d\uff0c\u591a\u5934\u529b\u91cf\u660e\u663e\u51cf\u5f31\u3002\u90a3\u4e48\uff0c\u8fd9\u80cc\u540e\u7684\u539f\u56e0\u662f\u4ec0\u4e48\u5462\uff1f\u5206\u6790\u4eba\u58eb\u6307\u51fa\uff0c\u4e00\u65b9\u9762\uff0c\u7531\u4e8e\u83b7\u5229\u76d8\u8fc7\u591a\uff0c\u5317\u8bc150\u6307\u6570\u5728\u6628\u65e5\u518d\u6b21\u5927\u5e45\u4e0a\u6da8\uff0c\u4eca\u65e5\u65e9\u76d8\u66f4\u662f\u521b\u4e0b\u5386\u53f2\u65b0\u9ad8\u3002\u540c\u65f6\uff0c\u4e2a\u80a1\u8868\u73b0\u4e5f\u975e\u5e38\u5f3a\u52b2\uff0c\u8fc7\u53bb\u4e00\u4e2a\u6708\u4e2d\u8868\u73b0\u6700\u597d\u7684\u80a1\u7968\u4e5f\u5728\u5317\u4ea4\u6240\u8bde\u751f\uff1b\u53e6\u4e00\u65b9\u9762\uff0c\u5e02\u573a\u98ce\u683c\u53d1\u751f\u4e86\u53d8\u5316\uff0c\u6628\u65e5\u79d1\u521b\u677f\u51b2\u9ad8\u540e\u56de\u843d\uff0c\u52a0\u4e0a\u6628\u665a\u7f57\u7d202000\u6307\u6570\u7a81\u7136\u4e0b\u8dcc1.65%\u3002\u5728\u4e4b\u524d\u7684\u884c\u60c5\u4e2d\uff0c\u5317\u4ea4\u6240\u4e0e\u7f57\u7d202000\u6307\u6570\u4e4b\u95f4\u5b58\u5728\u4e00\u5b9a\u7684\u76f8\u5173\u6027\u3002", "id": 790355, "description": "\u3010\u5317\u8bc150\u6307\u657015\u5929\u7ffb\u500d\u540e\u906d\u9047\u5267\u70c8\u6ce2\u52a8\u301110\u670822\u65e5\u65b0\u95fb\u62a5\u9053\uff0c\u5317\u8bc150\u6307\u6570\u5728\u5f00\u76d8\u540e\u8fc5\u901f\u4e0b\u8dcc\uff0c\u6700\u5927\u8dcc\u5e45\u8d85\u8fc78%\uff0c\u5176\u4e2d\u827e\u878d\u8f6f\u4ef6\u8fd9\u4e00\u5927\u725b\u80a1\u8dcc\u5e45\u4e00\u5ea6\u8d85\u8fc720%\uff0c\u4e91\u521b\u6570\u636e\u3001\u5764\u535a\u7cbe\u5de5\u3001\u51ef\u534e\u6750\u6599\u3001\u9752\u77e9\u6280\u672f\u3001\u6d77\u6607\u836f\u4e1a\u7b49\u8d85\u8fc770\u53ea\u5317\u4ea4\u6240\u80a1\u7968\u4e00\u5ea6\u8dcc\u5e45\u8d85\u8fc710%\u3002\u4e0d\u4e45\u540e\uff0c\u8d44\u91d1\u6d41\u5165\uff0c\u5317\u8bc150\u6307\u6570\u5f97\u4ee5\u56de\u5347\u81f3\u7ea2\u8272\u533a\u57df\u3002\u7136\u800c\uff0c\u591a\u5934\u529b\u91cf\u4f3c\u4e4e\u6709\u6240\u51cf\u5f31\uff0c\u6307\u6570\u518d\u6b21\u56de\u843d\uff0c\u591a\u5934\u529b\u91cf\u660e\u663e\u51cf\u5f31\u3002\u90a3\u4e48\uff0c\u8fd9\u80cc\u540e\u7684\u539f\u56e0\u662f\u4ec0\u4e48\u5462\uff1f\u5206\u6790\u4eba\u58eb\u6307\u51fa\uff0c\u4e00\u65b9\u9762\uff0c\u7531\u4e8e\u83b7\u5229\u76d8\u8fc7\u591a\uff0c\u5317\u8bc150\u6307\u6570\u5728\u6628\u65e5\u518d\u6b21\u5927\u5e45\u4e0a\u6da8\uff0c\u4eca\u65e5\u65e9\u76d8\u66f4\u662f\u521b\u4e0b\u5386\u53f2\u65b0\u9ad8\u3002\u540c\u65f6\uff0c\u4e2a\u80a1\u8868\u73b0\u4e5f\u975e\u5e38\u5f3a\u52b2\uff0c\u8fc7\u53bb\u4e00\u4e2a\u6708\u4e2d\u8868\u73b0\u6700\u597d\u7684\u80a1\u7968\u4e5f\u5728\u5317\u4ea4\u6240\u8bde\u751f\uff1b\u53e6\u4e00\u65b9\u9762\uff0c\u5e02\u573a\u98ce\u683c\u53d1\u751f\u4e86\u53d8\u5316\uff0c\u6628\u65e5\u79d1\u521b\u677f\u51b2\u9ad8\u540e\u56de\u843d\uff0c\u52a0\u4e0a\u6628\u665a\u7f57\u7d202000\u6307\u6570\u7a81\u7136\u4e0b\u8dcc1.65%\u3002\u5728\u4e4b\u524d\u7684\u884c\u60c5\u4e2d\uff0c\u5317\u4ea4\u6240\u4e0e\u7f57\u7d202000\u6307\u6570\u4e4b\u95f4\u5b58\u5728\u4e00\u5b9a\u7684\u76f8\u5173\u6027\u3002", "link": "https://www.fx168news.com/express/fastnews/790355", "pub_date": "2024-10-22 11:37:31"}, {"title": "\u622a\u81f32024\u5e747\u6708\u672b\uff0c\u8d8a\u5357\u5df4\u5730\u5934\u987f\u7701\u7684\u6295\u8d44\u989d\u5df2\u8d85\u51fa\u5168\u5e74\u9884\u5b9a\u76ee\u6807\uff0c\u6301\u7eed\u5438\u5f15\u7740\u56fd\u5185\u5916\u6295\u8d44\u8005\u7684\u76ee\u5149\u3002\u76ee\u524d\uff0c\u8be5\u5730\u533a\u5df2\u6279\u51c6\u5e76\u589e\u8d44\u4e8634\u4e2a\u65b0\u9879\u76ee\u3002\u5df4\u5730\u5934\u987f\u7701\u8ba1\u5212\u96c6\u4e2d\u5438\u5f15\u8d44\u91d1\uff0c\u4ee5\u4fc3\u8fdb\u56db\u5927\u7ecf\u6d4e\u652f\u67f1\u4ea7\u4e1a\u7684\u53d1\u5c55\uff0c\u8fd9\u56db\u5927\u4ea7\u4e1a\u5206\u522b\u662f\uff1a\u5de5\u4e1a\u3001\u6e2f\u53e3\u7269\u6d41\u3001\u65c5\u6e38\u4e1a\u4ee5\u53ca\u63d0\u4f9b\u9ad8\u8d28\u91cf\u7684\u670d\u52a1\u3002", "id": 790356, "description": "\u622a\u81f32024\u5e747\u6708\u672b\uff0c\u8d8a\u5357\u5df4\u5730\u5934\u987f\u7701\u7684\u6295\u8d44\u989d\u5df2\u8d85\u51fa\u5168\u5e74\u9884\u5b9a\u76ee\u6807\uff0c\u6301\u7eed\u5438\u5f15\u7740\u56fd\u5185\u5916\u6295\u8d44\u8005\u7684\u76ee\u5149\u3002\u76ee\u524d\uff0c\u8be5\u5730\u533a\u5df2\u6279\u51c6\u5e76\u589e\u8d44\u4e8634\u4e2a\u65b0\u9879\u76ee\u3002\u5df4\u5730\u5934\u987f\u7701\u8ba1\u5212\u96c6\u4e2d\u5438\u5f15\u8d44\u91d1\uff0c\u4ee5\u4fc3\u8fdb\u56db\u5927\u7ecf\u6d4e\u652f\u67f1\u4ea7\u4e1a\u7684\u53d1\u5c55\uff0c\u8fd9\u56db\u5927\u4ea7\u4e1a\u5206\u522b\u662f\uff1a\u5de5\u4e1a\u3001\u6e2f\u53e3\u7269\u6d41\u3001\u65c5\u6e38\u4e1a\u4ee5\u53ca\u63d0\u4f9b\u9ad8\u8d28\u91cf\u7684\u670d\u52a1\u3002", "link": "https://www.fx168news.com/express/fastnews/790356", "pub_date": "2024-10-22 11:38:06"}]}