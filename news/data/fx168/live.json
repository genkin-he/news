u573a\u62a5\u4ef7\u5229\u7387", "id": 788951, "description": "\u4e00\u5e74\u671f\u8d37\u6b3e\u5e02\u573a\u62a5\u4ef7\u5229\u7387", "link": "https://www.fx168news.com/express/fastnews/788951", "pub_date": "2024-10-21 09:00:01"}, {"title": "\u4e94\u5e74\u671f\u8d37\u6b3e\u5e02\u573a\u62a5\u4ef7\u5229\u7387", "id": 788952, "description": "\u4e94\u5e74\u671f\u8d37\u6b3e\u5e02\u573a\u62a5\u4ef7\u5229\u7387", "link": "https://www.fx168news.com/express/fastnews/788952", "pub_date": "2024-10-21 09:00:02"}, {"title": "\u3010\u5e7f\u4e1c\u8bc1\u76d1\u5c40\u7ec4\u7ec7\u5e02\u503c\u7ba1\u7406\u7814\u8ba8\u4f1a\u301110\u670821\u65e5\uff0c\u5e7f\u4e1c\u8bc1\u76d1\u5c40\u643a\u624b\u5e7f\u4e1c\u4e0a\u5e02\u516c\u53f8\u534f\u4f1a\uff0c\u4e3e\u529e\u4e86\u4e00\u573a\u5173\u4e8e\u4e0a\u5e02\u516c\u53f8\u5e02\u503c\u7ba1\u7406\u7684\u7814\u8ba8\u4f1a\u3002\u4f1a\u8bae\u9080\u8bf7\u4e86\u8f96\u533a\u5185\u4e3b\u8981\u6307\u6570\u6210\u5206\u80a1\u516c\u53f8\u53ca\u5176\u4ed6\u4e0a\u5e02\u516c\u53f8\u7684\u8d1f\u8d23\u4eba\u3002\u5728\u4f1a\u4e0a\uff0c\u5e7f\u4e1c\u8bc1\u76d1\u5c40\u7684\u8d1f\u8d23\u4eba\u63d0\u51fa\u4e86\u51e0\u70b9\u8981\u6c42\uff1a\u9996\u5148\uff0c\u8981\u8fc5\u901f\u5411\u516c\u53f8\u7684\u5173\u952e\u51b3\u7b56\u8005\u4f20\u8fbe\u5e76\u89e3\u91ca\u592e\u884c\u7684\u56de\u8d2d\u589e\u6301\u4e13\u9879\u518d\u8d37\u6b3e\u3001\u5e76\u8d2d\u91cd\u7ec4\u516d\u9879\u63aa\u65bd\u4ee5\u53ca\u5e02\u503c\u7ba1\u7406\u7684\u6307\u5bfc\u65b9\u9488\u7b49\u6700\u65b0\u653f\u7b56\u3002\u5176\u6b21\uff0c\u4e3b\u8981\u6307\u6570\u6210\u5206\u80a1\u516c\u53f8\u548c\u957f\u671f\u4f4e\u4e8e\u51c0\u8d44\u4ea7\u7684\u516c\u53f8\u9700\u8981\u8ba4\u771f\u89c4\u5212\u5e76\u5b9e\u65bd\u5e02\u503c\u7ba1\u7406\u7684\u6307\u5bfc\u65b9\u9488\u3002\u7b2c\u4e09\uff0c\u516c\u53f8\u5e94\u5efa\u7acb\u6b63\u786e\u7684\u5e02\u503c\u7ba1\u7406\u89c2\u5ff5\uff0c\u4ee5\u63d0\u5347\u516c\u53f8\u8d28\u91cf\u4e3a\u6838\u5fc3\uff0c\u4e13\u6ce8\u4e8e\u63d0\u9ad8\u7ecf\u8425\u6548\u7387\u548c\u76c8\u5229\u80fd\u529b\uff0c\u5e76\u79ef\u6781\u91c7\u7528\u5e76\u8d2d\u91cd\u7ec4\u3001\u80a1\u6743\u6fc0\u52b1\u3001\u73b0\u91d1\u5206\u7ea2\u3001\u6295\u8d44\u8005\u5173\u7cfb\u7ba1\u7406\u3001\u4fe1\u606f\u62ab\u9732\u3001\u80a1\u4efd\u56de\u8d2d\u7b49\u624b\u6bb5\uff0c\u4ee5\u6301\u7eed\u589e\u5f3a\u516c\u53f8\u7684\u6295\u8d44\u5438\u5f15\u529b\uff0c\u540c\u65f6\u4e25\u7981\u4ee5\u5e02\u503c\u7ba1\u7406\u4e3a\u501f\u53e3\u8fdb\u884c\u4efb\u4f55\u8fdd\u6cd5\u8fdd\u89c4\u884c\u4e3a\u3002", "id": 788948, "description": "\u3010\u5e7f\u4e1c\u8bc1\u76d1\u5c40\u7ec4\u7ec7\u5e02\u503c\u7ba1\u7406\u7814\u8ba8\u4f1a\u301110\u670821\u65e5\uff0c\u5e7f\u4e1c\u8bc1\u76d1\u5c40\u643a\u624b\u5e7f\u4e1c\u4e0a\u5e02\u516c\u53f8\u534f\u4f1a\uff0c\u4e3e\u529e\u4e86\u4e00\u573a\u5173\u4e8e\u4e0a\u5e02\u516c\u53f8\u5e02\u503c\u7ba1\u7406\u7684\u7814\u8ba8\u4f1a\u3002\u4f1a\u8bae\u9080\u8bf7\u4e86\u8f96\u533a\u5185\u4e3b\u8981\u6307\u6570\u6210\u5206\u80a1\u516c\u53f8\u53ca\u5176\u4ed6\u4e0a\u5e02\u516c\u53f8\u7684\u8d1f\u8d23\u4eba\u3002\u5728\u4f1a\u4e0a\uff0c\u5e7f\u4e1c\u8bc1\u76d1\u5c40\u7684\u8d1f\u8d23\u4eba\u63d0\u51fa\u4e86\u51e0\u70b9\u8981\u6c42\uff1a\u9996\u5148\uff0c\u8981\u8fc5\u901f\u5411\u516c\u53f8\u7684\u5173\u952e\u51b3\u7b56\u8005\u4f20\u8fbe\u5e76\u89e3\u91ca\u592e\u884c\u7684\u56de\u8d2d\u589e\u6301\u4e13\u9879\u518d\u8d37\u6b3e\u3001\u5e76\u8d2d\u91cd\u7ec4\u516d\u9879\u63aa\u65bd\u4ee5\u53ca\u5e02\u503c\u7ba1\u7406\u7684\u6307\u5bfc\u65b9\u9488\u7b49\u6700\u65b0\u653f\u7b56\u3002\u5176\u6b21\uff0c\u4e3b\u8981\u6307\u6570\u6210\u5206\u80a1\u516c\u53f8\u548c\u957f\u671f\u4f4e\u4e8e\u51c0\u8d44\u4ea7\u7684\u516c\u53f8\u9700\u8981\u8ba4\u771f\u89c4\u5212\u5e76\u5b9e\u65bd\u5e02\u503c\u7ba1\u7406\u7684\u6307\u5bfc\u65b9\u9488\u3002\u7b2c\u4e09\uff0c\u516c\u53f8\u5e94\u5efa\u7acb\u6b63\u786e\u7684\u5e02\u503c\u7ba1\u7406\u89c2\u5ff5\uff0c\u4ee5\u63d0\u5347\u516c\u53f8\u8d28\u91cf\u4e3a\u6838\u5fc3\uff0c\u4e13\u6ce8\u4e8e\u63d0\u9ad8\u7ecf\u8425\u6548\u7387\u548c\u76c8\u5229\u80fd\u529b\uff0c\u5e76\u79ef\u6781\u91c7\u7528\u5e76\u8d2d\u91cd\u7ec4\u3001\u80a1\u6743\u6fc0\u52b1\u3001\u73b0\u91d1\u5206\u7ea2\u3001\u6295\u8d44\u8005\u5173\u7cfb\u7ba1\u7406\u3001\u4fe1\u606f\u62ab\u9732\u3001\u80a1\u4efd\u56de\u8d2d\u7b49\u624b\u6bb5\uff0c\u4ee5\u6301\u7eed\u589e\u5f3a\u516c\u53f8\u7684\u6295\u8d44\u5438\u5f15\u529b\uff0c\u540c\u65f6\u4e25\u7981\u4ee5\u5e02\u503c\u7ba1\u7406\u4e3a\u501f\u53e3\u8fdb\u884c\u4efb\u4f55\u8fdd\u6cd5\u8fdd\u89c4\u884c\u4e3a\u3002", "link": "https://www.fx168news.com/express/fastnews/788948", "pub_date": "2024-10-21 08:25:49"}, {"title": "\u3010\u97e9\u56fd\u51fa\u53e3\u589e\u901f\u51cf\u7f13 \u534a\u5bfc\u4f53\u9700\u6c42\u6216\u9047\u6311\u6218\u3011\u6700\u65b0\u62a5\u9053\u663e\u793a\uff0c\u97e9\u56fd\u8fd1\u671f\u516c\u5e03\u7684\u8d38\u6613\u7edf\u8ba1\u6570\u636e\u63ed\u793a\u4e86\u672c\u6708\u51fa\u53e3\u589e\u901f\u7684\u51cf\u7f13\uff0c\u8fd9\u53ef\u80fd\u53cd\u6620\u51fa\u5168\u7403\u534a\u5bfc\u4f53\u9700\u6c42\u7684\u589e\u957f\u52bf\u5934\u6b63\u5728\u51cf\u5f31\u3002\u6839\u636e\u97e9\u56fd\u6d77\u5173\u572810\u670821\u65e5\u516c\u5e03\u7684\u6570\u636e\uff0c10\u6708\u7684\u524d20\u5929\uff0c\u7ecf\u8fc7\u5de5\u4f5c\u65e5\u8c03\u6574\u540e\u7684\u51fa\u53e3\u603b\u989d\u540c\u6bd4\u4ec5\u5fae\u5e45\u4e0a\u53471%\uff0c\u800c9\u6708\u4efd\u5168\u6708\u7684\u589e\u957f\u5e45\u5ea6\u4e3a7.5%\u3002\u97e9\u56fd\u4f5c\u4e3a\u5168\u7403\u4e3b\u8981\u7684\u5b58\u50a8\u82af\u7247\u751f\u4ea7\u5730\uff0c\u4eca\u5e74\u501f\u52a9\u5168\u7403\u5bf9\u4eba\u5de5\u667a\u80fd\u6280\u672f\u53d1\u5c55\u7684\u5f3a\u70c8\u9700\u6c42\uff0c\u5411\u7f8e\u56fd\u53ca\u5176\u4ed6\u53d1\u8fbe\u7ecf\u6d4e\u4f53\u51fa\u53e3\u4e86\u5927\u91cf\u9ad8\u7aef\u534a\u5bfc\u4f53\u4ea7\u54c1\u3002\u7136\u800c\uff0c\u8fd1\u51e0\u5468\u6765\uff0c\u5e02\u573a\u5bf9\u82af\u7247\u9500\u552e\u662f\u5426\u5df2\u8fbe\u9876\u5cf0\u7684\u62c5\u5fe7\u9010\u6e10\u589e\u52a0\u3002\u4e8b\u5b9e\u4e0a\uff0c\u97e9\u56fd\u534a\u5bfc\u4f53\u51fa\u53e3\u7684\u6708\u5ea6\u589e\u957f\u901f\u5ea6\u5df2\u7ecf\u8fde\u7eed\u6570\u6708\u5448\u73b0\u4e0b\u964d\u8d8b\u52bf\u3002\u6b64\u5916\uff0c9\u6708\u4efd\u5b58\u50a8\u82af\u7247\u7684\u51fa\u8d27\u4ef7\u683c\u6da8\u5e45\u4e5f\u6709\u6240\u51cf\u7f13\u3002", "id": 788950, "description": "\u3010\u97e9\u56fd\u51fa\u53e3\u589e\u901f\u51cf\u7f13 \u534a\u5bfc\u4f53\u9700\u6c42\u6216\u9047\u6311\u6218\u3011\u6700\u65b0\u62a5\u9053\u663e\u793a\uff0c\u97e9\u56fd\u8fd1\u671f\u516c\u5e03\u7684\u8d38\u6613\u7edf\u8ba1\u6570\u636e\u63ed\u793a\u4e86\u672c\u6708\u51fa\u53e3\u589e\u901f\u7684\u51cf\u7f13\uff0c\u8fd9\u53ef\u80fd\u53cd\u6620\u51fa\u5168\u7403\u534a\u5bfc\u4f53\u9700\u6c42\u7684\u589e\u957f\u52bf\u5934\u6b63\u5728\u51cf\u5f31\u3002\u6839\u636e\u97e9\u56fd\u6d77\u5173\u572810\u670821\u65e5\u516c\u5e03\u7684\u6570\u636e\uff0c10\u6708\u7684\u524d20\u5929\uff0c\u7ecf\u8fc7\u5de5\u4f5c\u65e5\u8c03\u6574\u540e\u7684\u51fa\u53e3\u603b\u989d\u540c\u6bd4\u4ec5\u5fae\u5e45\u4e0a\u53471%\uff0c\u800c9\u6708\u4efd\u5168\u6708\u7684\u589e\u957f\u5e45\u5ea6\u4e3a7.5%\u3002\u97e9\u56fd\u4f5c\u4e3a\u5168\u7403\u4e3b\u8981\u7684\u5b58\u50a8\u82af\u7247\u751f\u4ea7\u5730\uff0c\u4eca\u5e74\u501f\u52a9\u5168\u7403\u5bf9\u4eba\u5de5\u667a\u80fd\u6280\u672f\u53d1\u5c55\u7684\u5f3a\u70c8\u9700\u6c42\uff0c\u5411\u7f8e\u56fd\u53ca\u5176\u4ed6\u53d1\u8fbe\u7ecf\u6d4e\u4f53\u51fa\u53e3\u4e86\u5927\u91cf\u9ad8\u7aef\u534a\u5bfc\u4f53\u4ea7\u54c1\u3002\u7136\u800c\uff0c\u8fd1\u51e0\u5468\u6765\uff0c\u5e02\u573a\u5bf9\u82af\u7247\u9500\u552e\u662f\u5426\u5df2\u8fbe\u9876\u5cf0\u7684\u62c5\u5fe7\u9010\u6e10\u589e\u52a0\u3002\u4e8b\u5b9e\u4e0a\uff0c\u97e9\u56fd\u534a\u5bfc\u4f53\u51fa\u53e3\u7684\u6708\u5ea6\u589e\u957f\u901f\u5ea6\u5df2\u7ecf\u8fde\u7eed\u6570\u6708\u5448\u73b0\u4e0b\u964d\u8d8b\u52bf\u3002\u6b64\u5916\uff0c9\u6708\u4efd\u5b58\u50a8\u82af\u7247\u7684\u51fa\u8d27\u4ef7\u683c\u6da8\u5e45\u4e5f\u6709\u6240\u51cf\u7f13\u3002", "link": "https://www.fx168news.com/express/fastnews/788950", "pub_date": "2024-10-21 08:26:23"}]}