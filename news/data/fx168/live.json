5230\u653f\u5e9c\u652f\u6301\u7684\u4f01\u4e1a\uff0c\u8be5\u4f01\u4e1a\u5c06\u81f4\u529b\u4e8e\u6838\u53cd\u5e94\u5806\u7684\u5236\u9020\u3002", "link": "https://www.fx168news.com/express/fastnews/789564", "pub_date": "2024-10-21 18:37:32"}, {"title": "WTI\u539f\u6cb9\u4ef7\u683c\u7a81\u783470\u7f8e\u5143/\u6876\u5173\u53e3\uff0c\u6da8\u5e45\u8fbe\u52301.75%\u3002\u540c\u65f6\uff0c\u5e03\u4f26\u7279\u539f\u6cb9\u4ef7\u683c\u4e5f\u6500\u5347\u81f374\u7f8e\u5143/\u6876\uff0c\u6da8\u5e45\u4e3a1.56%\u3002", "id": 789566, "description": "WTI\u539f\u6cb9\u4ef7\u683c\u7a81\u783470\u7f8e\u5143/\u6876\u5173\u53e3\uff0c\u6da8\u5e45\u8fbe\u52301.75%\u3002\u540c\u65f6\uff0c\u5e03\u4f26\u7279\u539f\u6cb9\u4ef7\u683c\u4e5f\u6500\u5347\u81f374\u7f8e\u5143/\u6876\uff0c\u6da8\u5e45\u4e3a1.56%\u3002", "link": "https://www.fx168news.com/express/fastnews/789566", "pub_date": "2024-10-21 18:38:05"}, {"title": "\u7f8e\u56fd\u80fd\u6e90\u5b89\u5168\u7279\u4f7fHochstein\u8868\u793a\uff0c\u7f8e\u56fd\u8ba1\u5212\u4e0e\u9ece\u5df4\u5ae9\u548c\u4ee5\u8272\u5217\u653f\u5e9c\u5c55\u5f00\u6df1\u5165\u7684\u5bf9\u8bdd\uff0c\u65e8\u5728\u63a2\u8ba8\u5982\u4f55\u7ec8\u6b62\u53cc\u65b9\u7684\u654c\u5bf9\u884c\u4e3a\uff0c\u5e76\u5bfb\u6c42\u89e3\u51b3\u957f\u671f\u51b2\u7a81\u7684\u6709\u6548\u9014\u5f84\u3002", "id": 789567, "description": "\u7f8e\u56fd\u80fd\u6e90\u5b89\u5168\u7279\u4f7fHochstein\u8868\u793a\uff0c\u7f8e\u56fd\u8ba1\u5212\u4e0e\u9ece\u5df4\u5ae9\u548c\u4ee5\u8272\u5217\u653f\u5e9c\u5c55\u5f00\u6df1\u5165\u7684\u5bf9\u8bdd\uff0c\u65e8\u5728\u63a2\u8ba8\u5982\u4f55\u7ec8\u6b62\u53cc\u65b9\u7684\u654c\u5bf9\u884c\u4e3a\uff0c\u5e76\u5bfb\u6c42\u89e3\u51b3\u957f\u671f\u51b2\u7a81\u7684\u6709\u6548\u9014\u5f84\u3002", "link": "https://www.fx168news.com/express/fastnews/789567", "pub_date": "2024-10-21 18:38:11"}, {"title": "\u3010\u72ec\u5bb6\uff01\u592e\u884c\u9996\u6b21\u5b9e\u65bd\u4e92\u6362\u4fbf\u5229\u64cd\u4f5c\uff0c\u4e2d\u91d1\u516c\u53f8\u5b8c\u6210\u9996\u5355\u8d28\u62bc\u56de\u8d2d\u301110\u670821\u65e5\uff0c\u4e2d\u56fd\u4eba\u6c11\u94f6\u884c\u9996\u6b21\u8fdb\u884c\u4e86\u9488\u5bf9\u8bc1\u5238\u3001\u57fa\u91d1\u3001\u4fdd\u9669\u516c\u53f8\u7684\u4e92\u6362\u4fbf\u5229\u64cd\u4f5c\u3002\u6b64\u6b21\u64cd\u4f5c\u6d89\u53ca\u91d1\u989d\u8fbe500\u4ebf\u5143\uff0c\u901a\u8fc7\u8d39\u7387\u62db\u6807\u65b9\u5f0f\u8fdb\u884c\uff0c\u5438\u5f15\u4e8620\u5bb6\u673a\u6784\u53c2\u4e0e\u7ade\u6807\u3002\u6295\u6807\u8d39\u7387\u8303\u56f4\u4ece10bp\u523050bp\u4e0d\u7b49\uff0c\u6700\u7ec8\u4e2d\u6807\u8d39\u7387\u4e3a20bp\u3002\u636e\u6700\u65b0\u62a5\u9053\uff0c\u4e2d\u91d1\u516c\u53f8\u5728\u4eca\u65e5\u5b8c\u6210\u4e86\u9996\u7b14\u57fa\u4e8e\u201c\u8bc1\u5238\u3001\u57fa\u91d1\u3001\u4fdd\u9669\u516c\u53f8\u4e92\u6362\u4fbf\u5229\u201d\u7684\u8d28\u62bc\u5f0f\u56de\u8d2d\u4ea4\u6613\uff0c\u8d28\u62bc\u7684\u503a\u5238\u4e3a2024\u5e74\u7b2c\u4e00\u671f\u4e92\u6362\u4fbf\u5229\u592e\u884c\u503a\u5238\u3002\u4e2d\u91d1\u516c\u53f8\u8868\u793a\uff0c\u5c06\u7ee7\u7eed\u9075\u5faa\u4e2d\u592e\u653f\u7b56\u6307\u5bfc\uff0c\u53d1\u6325\u5e02\u573a\u7a33\u5b9a\u5668\u7684\u4f5c\u7528\uff0c\u5168\u9762\u652f\u6301\u5b8f\u89c2\u7ecf\u6d4e\u653f\u7b56\u7684\u6267\u884c\u3002", "id": 789568, "description": "\u3010\u72ec\u5bb6\uff01\u592e\u884c\u9996\u6b21\u5b9e\u65bd\u4e92\u6362\u4fbf\u5229\u64cd\u4f5c\uff0c\u4e2d\u91d1\u516c\u53f8\u5b8c\u6210\u9996\u5355\u8d28\u62bc\u56de\u8d2d\u301110\u670821\u65e5\uff0c\u4e2d\u56fd\u4eba\u6c11\u94f6\u884c\u9996\u6b21\u8fdb\u884c\u4e86\u9488\u5bf9\u8bc1\u5238\u3001\u57fa\u91d1\u3001\u4fdd\u9669\u516c\u53f8\u7684\u4e92\u6362\u4fbf\u5229\u64cd\u4f5c\u3002\u6b64\u6b21\u64cd\u4f5c\u6d89\u53ca\u91d1\u989d\u8fbe500\u4ebf\u5143\uff0c\u901a\u8fc7\u8d39\u7387\u62db\u6807\u65b9\u5f0f\u8fdb\u884c\uff0c\u5438\u5f15\u4e8620\u5bb6\u673a\u6784\u53c2\u4e0e\u7ade\u6807\u3002\u6295\u6807\u8d39\u7387\u8303\u56f4\u4ece10bp\u523050bp\u4e0d\u7b49\uff0c\u6700\u7ec8\u4e2d\u6807\u8d39\u7387\u4e3a20bp\u3002\u636e\u6700\u65b0\u62a5\u9053\uff0c\u4e2d\u91d1\u516c\u53f8\u5728\u4eca\u65e5\u5b8c\u6210\u4e86\u9996\u7b14\u57fa\u4e8e\u201c\u8bc1\u5238\u3001\u57fa\u91d1\u3001\u4fdd\u9669\u516c\u53f8\u4e92\u6362\u4fbf\u5229\u201d\u7684\u8d28\u62bc\u5f0f\u56de\u8d2d\u4ea4\u6613\uff0c\u8d28\u62bc\u7684\u503a\u5238\u4e3a2024\u5e74\u7b2c\u4e00\u671f\u4e92\u6362\u4fbf\u5229\u592e\u884c\u503a\u5238\u3002\u4e2d\u91d1\u516c\u53f8\u8868\u793a\uff0c\u5c06\u7ee7\u7eed\u9075\u5faa\u4e2d\u592e\u653f\u7b56\u6307\u5bfc\uff0c\u53d1\u6325\u5e02\u573a\u7a33\u5b9a\u5668\u7684\u4f5c\u7528\uff0c\u5168\u9762\u652f\u6301\u5b8f\u89c2\u7ecf\u6d4e\u653f\u7b56\u7684\u6267\u884c\u3002", "link": "https://www.fx168news.com/express/fastnews/789568", "pub_date": "2024-10-21 18:38:42"}, {"title": "\u7f8e\u56fd\u80fd\u6e90\u5b89\u5168\u7279\u4f7fHochstein\u8868\u793a\uff0c\u62dc\u767b\u603b\u7edf\u7684\u653f\u5e9c\u81f4\u529b\u4e8e\u786e\u4fdd\u9ece\u5df4\u5ae9\u672a\u6765\u51e0\u4ee3\u4eba\u4e0d\u518d\u7ecf\u5386\u51b2\u7a81\u3002", "id": 789551, "description": "\u7f8e\u56fd\u80fd\u6e90\u5b89\u5168\u7279\u4f7fHochstein\u8868\u793a\uff0c\u62dc\u767b\u603b\u7edf\u7684\u653f\u5e9c\u81f4\u529b\u4e8e\u786e\u4fdd\u9ece\u5df4\u5ae9\u672a\u6765\u51e0\u4ee3\u4eba\u4e0d\u518d\u7ecf\u5386\u51b2\u7a81\u3002", "link": "https://www.fx168news.com/express/fastnews/789551", "pub_date": "2024-10-21 18:30:32"}]}