{"data": [{"title": "<b>\u56fd\u9645\u91d1\u4ef7\u8dcc\u78342720\u7f8e\u5143/\u76ce\u53f8\u5173\u53e3\uff0c\u8f83\u5386\u53f2\u6700\u9ad8\u70b9\u4e0b\u8dcc20\u7f8e\u5143\u3002</b>", "id": 789814, "description": "<b>\u56fd\u9645\u91d1\u4ef7\u8dcc\u78342720\u7f8e\u5143/\u76ce\u53f8\u5173\u53e3\uff0c\u8f83\u5386\u53f2\u6700\u9ad8\u70b9\u4e0b\u8dcc20\u7f8e\u5143\u3002</b>", "link": "https://www.fx168news.com/express/fastnews/789814", "pub_date": "2024-10-21 23:10:55"}, {"title": "\u3010\u201c\u56de\u8d2d\u589e\u6301\u8d37\u201d\u4e1a\u52a1\u53d7\u70ed\u6367\uff0c\u5238\u5546\u7eb7\u7eb7\u5e03\u5c40\u301110\u670821\u65e5\uff0c\u591a\u5bb6\u5238\u5546\u7eb7\u7eb7\u63a8\u51fa\u9488\u5bf9\u4e0a\u5e02\u516c\u53f8\u7684\u80a1\u4efd\u56de\u8d2d\u548c\u589e\u6301\u7efc\u5408\u670d\u52a1\u65b9\u6848\uff0c\u79ef\u6781\u5e03\u5c40\u201c\u56de\u8d2d\u589e\u6301\u8d37\u201d\u4e1a\u52a1\u3002\u76ee\u524d\u5238\u5546\u63d0\u4f9b\u7684\u670d\u52a1\u65b9\u6848\u5927\u81f4\u76f8\u4f3c\uff1a\u5728\u524d\u671f\u63d0\u4f9b\u65b9\u6848\u8bbe\u8ba1\u548c\u5408\u89c4\u6027\u5efa\u8bae\uff0c\u5728\u4ea4\u6613\u6267\u884c\u9636\u6bb5\u63d0\u4f9b\u652f\u6301\uff0c\u5e76\u5728\u540e\u671f\u63d0\u4f9b\u80a1\u6743\u6fc0\u52b1\u548c\u8d22\u5bcc\u7ba1\u7406\u7b49\u7efc\u5408\u670d\u52a1\u3002\u5317\u4eac\u4e00\u5bb6\u5927\u578b\u5238\u5546\u7684\u4e1a\u52a1\u8d1f\u8d23\u4eba\u900f\u9732\uff0c\u76ee\u524d\u662f\u6295\u884c\u90e8\u95e8\u5728\u79ef\u6781\u68b3\u7406\u4f01\u4e1a\u5ba2\u6237\u60c5\u51b5\uff0c\u62d3\u5c55\u76f8\u5173\u4e1a\u52a1\u3002\u4ed6\u6307\u51fa\uff0c\u6295\u884c\u4e1a\u52a1\u5b9e\u529b\u8f83\u5f3a\u7684\u5238\u5546\u7531\u4e8e\u5730\u7406\u4f4d\u7f6e\u4f18\u52bf\uff0c\u52a0\u4e0a\u7efc\u5408\u670d\u52a1\u80fd\u529b\u8f83\u5f3a\uff0c\u6709\u671b\u5728\u5e02\u573a\u4e2d\u5360\u636e\u6709\u5229\u5730\u4f4d\u3002\u6b64\u5916\uff0c\u91d1\u878d\u79d1\u6280\u5b9e\u529b\u5f3a\u3001\u667a\u80fd\u4ea4\u6613\u6280\u672f\u9886\u5148\u7684\u5238\u5546\u4e5f\u6709\u671b\u83b7\u5f97\u66f4\u591a\u5ba2\u6237\u9752\u7750\u3002", "id": 789815, "description": "\u3010\u201c\u56de\u8d2d\u589e\u6301\u8d37\u201d\u4e1a\u52a1\u53d7\u70ed\u6367\uff0c\u5238\u5546\u7eb7\u7eb7\u5e03\u5c40\u301110\u670821\u65e5\uff0c\u591a\u5bb6\u5238\u5546\u7eb7\u7eb7\u63a8\u51fa\u9488\u5bf9\u4e0a\u5e02\u516c\u53f8\u7684\u80a1\u4efd\u56de\u8d2d\u548c\u589e\u6301\u7efc\u5408\u670d\u52a1\u65b9\u6848\uff0c\u79ef\u6781\u5e03\u5c40\u201c\u56de\u8d2d\u589e\u6301\u8d37\u201d\u4e1a\u52a1\u3002\u76ee\u524d\u5238\u5546\u63d0\u4f9b\u7684\u670d\u52a1\u65b9\u6848\u5927\u81f4\u76f8\u4f3c\uff1a\u5728\u524d\u671f\u63d0\u4f9b\u65b9\u6848\u8bbe\u8ba1\u548c\u5408\u89c4\u6027\u5efa\u8bae\uff0c\u5728\u4ea4\u6613\u6267\u884c\u9636\u6bb5\u63d0\u4f9b\u652f\u6301\uff0c\u5e76\u5728\u540e\u671f\u63d0\u4f9b\u80a1\u6743\u6fc0\u52b1\u548c\u8d22\u5bcc\u7ba1\u7406\u7b49\u7efc\u5408\u670d\u52a1\u3002\u5317\u4eac\u4e00\u5bb6\u5927\u578b\u5238\u5546\u7684\u4e1a\u52a1\u8d1f\u8d23\u4eba\u900f\u9732\uff0c\u76ee\u524d\u662f\u6295\u884c\u90e8\u95e8\u5728\u79ef\u6781\u68b3\u7406\u4f01\u4e1a\u5ba2\u6237\u60c5\u51b5\uff0c\u62d3\u5c55\u76f8\u5173\u4e1a\u52a1\u3002\u4ed6\u6307\u51fa\uff0c\u6295\u884c\u4e1a\u52a1\u5b9e\u529b\u8f83\u5f3a\u7684\u5238\u5546\u7531\u4e8e\u5730\u7406\u4f4d\u7f6e\u4f18\u52bf\uff0c\u52a0\u4e0a\u7efc\u5408\u670d\u52a1\u80fd\u529b\u8f83\u5f3a\uff0c\u6709\u671b\u5728\u5e02\u573a\u4e2d\u5360\u636e\u6709\u5229\u5730\u4f4d\u3002\u6b64\u5916\uff0c\u91d1\u878d\u79d1\u6280\u5b9e\u529b\u5f3a\u3001\u667a\u80fd\u4ea4\u6613\u6280\u672f\u9886\u5148\u7684\u5238\u5546\u4e5f\u6709\u671b\u83b7\u5f97\u66f4\u591a\u5ba2\u6237\u9752\u7750\u3002", "link": "https://www.fx168news.com/express/fastnews/789815", "pub_date": "2024-10-21 23:13:20"}, {"title": "\u5370\u5ea6\u7164\u70ad\u90e8\u957f\u5f3a\u8c03\uff0c\u8bc6\u522b\u5e76\u5f00\u53d1\u5173\u952e\u77ff\u7269\u8d44\u6e90\u662f\u4e00\u9879\u7d27\u8feb\u7684\u4efb\u52a1\u3002", "id": 789817, "description": "\u5370\u5ea6\u7164\u70ad\u90e8\u957f\u5f3a\u8c03\uff0c\u8bc6\u522b\u5e76\u5f00\u53d1\u5173\u952e\u77ff\u7269\u8d44\u6e90\u662f\u4e00\u9879\u7d27\u8feb\u7684\u4efb\u52a1\u3002", "link": "https://www.fx168news.com/express/fastnews/789817", "pub_date": "2024-10-21 23:14:18"}, {"title": "\u7f8e\u5143\u5bf9\u52a0\u62ff\u5927\u5143\u6c47\u7387USD/CAD\u6500\u5347\u81f3\u8fd111\u5468\u7684\u9ad8\u4f4d\uff0c\u89e6\u53ca1.3844\u7684\u6c34\u5e73\u3002", "id": 789818, "description": "\u7f8e\u5143\u5bf9\u52a0\u62ff\u5927\u5143\u6c47\u7387USD/CAD\u6500\u5347\u81f3\u8fd111\u5468\u7684\u9ad8\u4f4d\uff0c\u89e6\u53ca1.3844\u7684\u6c34\u5e73\u3002", "link": "https://www.fx168news.com/express/fastnews/789818", "pub_date": "2024-10-21 23:15:13"}, {"title": "<p>\u53e6\u7c7b\u8d44\u4ea7\u7ba1\u7406\u5de8\u5934\u963f\u6ce2\u7f57\u9996\u5e2d\u7ecf\u6d4e\u5b66\u5bb6Torsten Slok\uff1a\u9274\u4e8e\u7f8e\u56fd\u7ecf\u6d4e\u5f62\u52bf\uff0c\u7f8e\u8054\u50a8\u572811\u6708\u4efd\u6309\u5175\u4e0d\u52a8\u7684\u53ef\u80fd\u6027\u4e0a\u5347\u3002</p>", "id": 789809, "description": "<p>\u53e6\u7c7b\u8d44\u4ea7\u7ba1\u7406\u5de8\u5934\u963f\u6ce2\u7f57\u9996\u5e2d\u7ecf\u6d4e\u5b66\u5bb6Torsten Slok\uff1a\u9274\u4e8e\u7f8e\u56fd\u7ecf\u6d4e\u5f62\u52bf\uff0c\u7f8e\u8054\u50a8\u572811\u6708\u4efd\u6309\u5175\u4e0d\u52a8\u7684\u53ef\u80fd\u6027\u4e0a\u5347\u3002</p>", "link": "https://www.fx168news.com/express/fastnews/789809", "pub_date": "2024-10-21 23:09:22"}, {"title": "\u636e\u59d4\u5458\u4f1a\u5ba3\u5e03\uff0c\u4f0a\u62c9\u514b\u5e93\u5c14\u5fb7\u5730\u533a\u7684\u8bae\u4f1a\u9009\u4e3e\u521d\u6b65\u7ed3\u679c\u663e\u793a\uff0c\u5e93\u5c14\u5fb7\u65af\u5766\u6c11\u4e3b\u515a\u5904\u4e8e\u9886\u5148\u5730\u4f4d\u3002", "id": 789810, "description": "\u636e\u59d4\u5458\u4f1a\u5ba3\u5e03\uff0c\u4f0a\u62c9\u514b\u5e93\u5c14\u5fb7\u5730\u533a\u7684\u8bae\u4f1a\u9009\u4e3e\u521d\u6b65\u7ed3\u679c\u663e\u793a\uff0c\u5e93\u5c14\u5fb7\u65af\u5766\u6c11\u4e3b\u515a\u5904\u4e8e\u9886\u5148\u5730\u4f4d\u3002", "link": "https://www.fx168news.com/express/fastnews/789810", "pub_date": "2024-10-21 23:09:25"}, {"title": "\u5370\u5ea6\u7164\u70ad\u90e8\u957f\u8868\u793a\uff0c\u5fc5\u987b\u5bf9\u7164\u70ad\u9700\u6c42\u8fdb\u884c\u8bc4\u4f30\uff0c\u5e76\u5236\u5b9a\u4e00\u9879\u5f3a\u6709\u529b\u7684\u751f\u4ea7\u8ba1\u5212\uff0c\u4ee5\u786e\u4fdd\u52302030\u5e74\u80fd\u6ee1\u8db3\u56fd\u5bb6\u7684\u9700\u6c42\u3002", "id": 789812, "description": "\u5370\u5ea6\u7164\u70ad\u90e8\u957f\u8868\u793a\uff0c\u5fc5\u987b\u5bf9\u7164\u70ad\u9700\u6c42\u8fdb\u884c\u8bc4\u4f30\uff0c\u5e76\u5236\u5b9a\u4e00\u9879\u5f3a\u6709\u529b\u7684\u751f\u4ea7\u8ba1\u5212\uff0c\u4ee5\u786e\u4fdd\u52302030\u5e74\u80fd\u6ee1\u8db3\u56fd\u5bb6\u7684\u9700\u6c42\u3002", "link": "https://www.fx168news.com/express/fastnews/789812", "pub_date": "2024-10-21 23:10:06"}, {"title": "\u6bd4\u7279\u5e01\u4ef7\u683c\u4e00\u5ea6\u4e0b\u63a2\u81f367000\u7f8e\u5143\u5173\u53e3\uff0c\u5355\u65e5\u8dcc\u5e45\u7ea6\u4e3a2.96%\u3002", "id": 789806, "description": "\u6bd4\u7279\u5e01\u4ef7\u683c\u4e00\u5ea6\u4e0b\u63a2\u81f367000\u7f8e\u5143\u5173\u53e3\uff0c\u5355\u65e5\u8dcc\u5e45\u7ea6\u4e3a2.96%\u3002", "link": "https://www.fx168news.com/express/fastnews/789806", "pub_date": "2024-10-21 23:02:48"}, {"title": "\u3010\u91d1\u4ef7\u98d9\u5347\u81f3800\u5143/\u514b\u4ee5\u4e0a\uff0c\u4e13\u5bb6\u9884\u6d4b\u4ecd\u6709\u4e0a\u5347\u6f5c\u529b\u301110\u670821\u65e5\uff0c\u9ec4\u91d1\u5e02\u573a\u518d\u6b21\u8fce\u6765\u5f3a\u52b2\u4e0a\u6da8\uff0c\u8fde\u7eed\u521b\u4e0b\u5386\u53f2\u65b0\u9ad8\u3002\u56fd\u5185\u91d1\u9970\u4ef7\u683c\u7ef4\u6301\u5728\u8f83\u9ad8\u6c34\u5e73\uff0c\u5468\u5927\u798f\u3001\u8001\u51e4\u7965\u3001\u5468\u5927\u751f\u7b49\u8457\u540d\u91d1\u5e97\u7684\u91d1\u9970\u4ef7\u683c\u62a5\u51fa806\u5143/\u514b\uff0c\u800c\u5468\u5927\u798f\u7684\u91d1\u6761\u4ef7\u683c\u5219\u4e3a708\u5143/\u514b\u3002\u5bf9\u4e8e\u672a\u6765\u9ec4\u91d1\u4ef7\u683c\u548c\u76f8\u5173\u80a1\u7968\u7684\u8d70\u52bf\uff0c\u516c\u52df\u57fa\u91d1\u4e13\u5bb6\u8ba4\u4e3a\uff0c\u77ed\u671f\u5185\u9ec4\u91d1\u6295\u8d44\u53ef\u5173\u6ce8\u5730\u7f18\u653f\u6cbb\u52a8\u6001\uff0c\u4e2d\u671f\u5728\u91d1\u4ef7\u8fbe\u52303000\u7f8e\u5143/\u76ce\u53f8\u4e4b\u524d\u53ef\u653e\u5fc3\u6301\u6709\u3002\u9ec4\u91d1\u4f5c\u4e3a\u8d35\u91d1\u5c5e\uff0c\u5177\u6709\u6295\u8d44\u5438\u5f15\u529b\uff0c\u968f\u7740\u91d1\u4ef7\u7684\u4e0a\u6da8\uff0c\u76f8\u5173\u4f01\u4e1a\u7684\u76c8\u5229\u80fd\u529b\u6709\u671b\u663e\u8457\u63d0\u5347\u3002\u6b64\u5916\uff0c\u5728\u80a1\u5e02\u5feb\u901f\u4e0a\u6da8\u671f\u95f4\uff0c\u8d35\u91d1\u5c5e\u7684\u6da8\u5e45\u76f8\u5bf9\u8f83\u5c0f\uff0c\u56e0\u6b64\u5b58\u5728\u4e00\u5b9a\u7684\u8865\u6da8\u673a\u4f1a\u3002\u9ec4\u91d1\u4ef7\u683c\u7684\u5f3a\u52bf\u8868\u73b0\u548cA\u80a1\u5e02\u573a\u7684\u6d41\u52a8\u6027\u5145\u88d5\uff0c\u53ef\u80fd\u4f1a\u63a8\u52a8\u9ec4\u91d1\u80a1\u7684\u8fdb\u4e00\u6b65\u4e0a\u6da8\u3002", "id": 789802, "description": "\u3010\u91d1\u4ef7\u98d9\u5347\u81f3800\u5143/\u514b\u4ee5\u4e0a\uff0c\u4e13\u5bb6\u9884\u6d4b\u4ecd\u6709\u4e0a\u5347\u6f5c\u529b\u301110\u670821\u65e5\uff0c\u9ec4\u91d1\u5e02\u573a\u518d\u6b21\u8fce\u6765\u5f3a\u52b2\u4e0a\u6da8\uff0c\u8fde\u7eed\u521b\u4e0b\u5386\u53f2\u65b0\u9ad8\u3002\u56fd\u5185\u91d1\u9970\u4ef7\u683c\u7ef4\u6301\u5728\u8f83\u9ad8\u6c34\u5e73\uff0c\u5468\u5927\u798f\u3001\u8001\u51e4\u7965\u3001\u5468\u5927\u751f\u7b49\u8457\u540d\u91d1\u5e97\u7684\u91d1\u9970\u4ef7\u683c\u62a5\u51fa806\u5143/\u514b\uff0c\u800c\u5468\u5927\u798f\u7684\u91d1\u6761\u4ef7\u683c\u5219\u4e3a708\u5143/\u514b\u3002\u5bf9\u4e8e\u672a\u6765\u9ec4\u91d1\u4ef7\u683c\u548c\u76f8\u5173\u80a1\u7968\u7684\u8d70\u52bf\uff0c\u516c\u52df\u57fa\u91d1\u4e13\u5bb6\u8ba4\u4e3a\uff0c\u77ed\u671f\u5185\u9ec4\u91d1\u6295\u8d44\u53ef\u5173\u6ce8\u5730\u7f18\u653f\u6cbb\u52a8\u6001\uff0c\u4e2d\u671f\u5728\u91d1\u4ef7\u8fbe\u52303000\u7f8e\u5143/\u76ce\u53f8\u4e4b\u524d\u53ef\u653e\u5fc3\u6301\u6709\u3002\u9ec4\u91d1\u4f5c\u4e3a\u8d35\u91d1\u5c5e\uff0c\u5177\u6709\u6295\u8d44\u5438\u5f15\u529b\uff0c\u968f\u7740\u91d1\u4ef7\u7684\u4e0a\u6da8\uff0c\u76f8\u5173\u4f01\u4e1a\u7684\u76c8\u5229\u80fd\u529b\u6709\u671b\u663e\u8457\u63d0\u5347\u3002\u6b64\u5916\uff0c\u5728\u80a1\u5e02\u5feb\u901f\u4e0a\u6da8\u671f\u95f4\uff0c\u8d35\u91d1\u5c5e\u7684\u6da8\u5e45\u76f8\u5bf9\u8f83\u5c0f\uff0c\u56e0\u6b64\u5b58\u5728\u4e00\u5b9a\u7684\u8865\u6da8\u673a\u4f1a\u3002\u9ec4\u91d1\u4ef7\u683c\u7684\u5f3a\u52bf\u8868\u73b0\u548cA\u80a1\u5e02\u573a\u7684\u6d41\u52a8\u6027\u5145\u88d5\uff0c\u53ef\u80fd\u4f1a\u63a8\u52a8\u9ec4\u91d1\u80a1\u7684\u8fdb\u4e00\u6b65\u4e0a\u6da8\u3002", "link": "https://www.fx168news.com/express/fastnews/789802", "pub_date": "2024-10-21 22:50:41"}, {"title": "\u3010\u4e2d\u56fdPCT\u4e13\u5229\u7533\u8bf7\u8fde\u7eed\u4e94\u5e74\u5168\u7403\u9886\u5148\u301110\u670821\u65e5\uff0c\u636e\u56fd\u5bb6\u77e5\u8bc6\u4ea7\u6743\u5c40\u6d88\u606f\uff0c2024\u5e74\u6807\u5fd7\u7740\u4e2d\u56fd\u52a0\u5165\u300a\u4e13\u5229\u5408\u4f5c\u6761\u7ea6\u300b\uff08PCT\uff09\u4e09\u5341\u5468\u5e74\u3002PCT\u662f\u77e5\u8bc6\u4ea7\u6743\u9886\u57df\u7684\u4e00\u9879\u5173\u952e\u56fd\u9645\u534f\u8bae\uff0c\u81ea1970\u5e74\u7b7e\u8ba2\u4ee5\u6765\uff0c\u5df2\u6709158\u4e2a\u56fd\u5bb6\u52a0\u5165\u3002\u901a\u8fc7PCT\uff0c\u7533\u8bf7\u4eba\u53ea\u9700\u63d0\u4ea4\u4e00\u4efd\u7533\u8bf7\uff0c\u5373\u53ef\u5728\u591a\u4e2a\u6210\u5458\u56fd\u5bfb\u6c42\u4e13\u5229\u6743\u3002\u81ea1994\u5e74\u4ec5\u670998\u9879PCT\u7533\u8bf7\u4ee5\u6765\uff0c\u52302023\u5e74\uff0c\u4e2d\u56fd\u7533\u8bf7\u4eba\u63d0\u4ea4\u7684PCT\u7533\u8bf7\u6570\u91cf\u5df2\u63a5\u8fd17\u4e07\uff0c\u8fde\u7eed\u4e94\u5e74\u4f4d\u5c45\u5168\u7403\u9996\u4f4d\u3002\u4e2d\u56fd\u56fd\u5bb6\u77e5\u8bc6\u4ea7\u6743\u5c40\u5904\u7406\u7684PCT\u7533\u8bf7\u91cf\u5360\u5168\u7403\u603b\u91cf\u7684\u56db\u5206\u4e4b\u4e00\u4ee5\u4e0a\uff0c\u5176\u4e2d\u4e00\u4e9b\u4e2d\u56fd\u7533\u8bf7\u4eba\u7684PCT\u7533\u8bf7\u91cf\u5728\u5168\u7403\u6392\u540d\u9760\u524d\u3002", "id": 789804, "description": "\u3010\u4e2d\u56fdPCT\u4e13\u5229\u7533\u8bf7\u8fde\u7eed\u4e94\u5e74\u5168\u7403\u9886\u5148\u301110\u670821\u65e5\uff0c\u636e\u56fd\u5bb6\u77e5\u8bc6\u4ea7\u6743\u5c40\u6d88\u606f\uff0c2024\u5e74\u6807\u5fd7\u7740\u4e2d\u56fd\u52a0\u5165\u300a\u4e13\u5229\u5408\u4f5c\u6761\u7ea6\u300b\uff08PCT\uff09\u4e09\u5341\u5468\u5e74\u3002PCT\u662f\u77e5\u8bc6\u4ea7\u6743\u9886\u57df\u7684\u4e00\u9879\u5173\u952e\u56fd\u9645\u534f\u8bae\uff0c\u81ea1970\u5e74\u7b7e\u8ba2\u4ee5\u6765\uff0c\u5df2\u6709158\u4e2a\u56fd\u5bb6\u52a0\u5165\u3002\u901a\u8fc7PCT\uff0c\u7533\u8bf7\u4eba\u53ea\u9700\u63d0\u4ea4\u4e00\u4efd\u7533\u8bf7\uff0c\u5373\u53ef\u5728\u591a\u4e2a\u6210\u5458\u56fd\u5bfb\u6c42\u4e13\u5229\u6743\u3002\u81ea1994\u5e74\u4ec5\u670998\u9879PCT\u7533\u8bf7\u4ee5\u6765\uff0c\u52302023\u5e74\uff0c\u4e2d\u56fd\u7533\u8bf7\u4eba\u63d0\u4ea4\u7684PCT\u7533\u8bf7\u6570\u91cf\u5df2\u63a5\u8fd17\u4e07\uff0c\u8fde\u7eed\u4e94\u5e74\u4f4d\u5c45\u5168\u7403\u9996\u4f4d\u3002\u4e2d\u56fd\u56fd\u5bb6\u77e5\u8bc6\u4ea7\u6743\u5c40\u5904\u7406\u7684PCT\u7533\u8bf7\u91cf\u5360\u5168\u7403\u603b\u91cf\u7684\u56db\u5206\u4e4b\u4e00\u4ee5\u4e0a\uff0c\u5176\u4e2d\u4e00\u4e9b\u4e2d\u56fd\u7533\u8bf7\u4eba\u7684PCT\u7533\u8bf7\u91cf\u5728\u5168\u7403\u6392\u540d\u9760\u524d\u3002", "link": "https://www.fx168news.com/express/fastnews/789804", "pub_date": "2024-10-21 22:52:29"}]}