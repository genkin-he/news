{"data": [{"title": "\u65e5\u672c\u6700\u9ad8\u5916\u6c47\u4e8b\u52a1\u5b98\u5458\u4e09\u6751\u6df3\uff1a\u9274\u4e8e\u65e5\u672c\u592e\u884c\u7684\u72ec\u7acb\u6027\uff0c\u4e0d\u4f1a\u5bf9\u5176\u6c9f\u901a\u53d1\u8868\u8bc4\u8bba\u3002", "id": 833367, "description": "", "link": "https://www.fx168news.com/express/fastnews/833367", "pub_date": "2024-12-20 11:36:02"}, {"title": "\u7f8e\u56fd\u6838\u5fc3 PCE \u4ef7\u683c\u6307\u6570\u516c\u5e03\u524d\uff0c\u7f8e\u5143/\u5370\u5ea6\u5362\u6bd4\u4e0b\u8dcc", "id": 833368, "description": "", "link": "https://www.fx168news.com/express/fastnews/833368", "pub_date": "2024-12-20 11:38:16"}, {"title": "\u5468\u4e94\uff0c\u6fb3\u5143\u5151\u7f8e\u5143\u8dcc\u81f3 0.62 \u7f8e\u5143\uff0c\u521b\u4e0b 2022 \u5e74 10 \u6708\u4ee5\u6765\u7684\u6700\u4f4e\u6c34\u5e73\uff0c\u56e0\u4e3a\u5728\u7ecf\u6d4e\u6d3b\u52a8\u653e\u7f13\u7684\u8ff9\u8c61\u4e0b\uff0c\u6295\u8d44\u8005\u63d0\u524d\u9884\u671f\u6fb3\u5927\u5229\u4e9a\u50a8\u5907\u94f6\u884c\u5c06\u9996\u6b21\u964d\u606f\u3002\u5e02\u573a\u73b0\u5728\u62bc\u6ce8\u6fb3\u5927\u5229\u4e9a\u50a8\u5907\u94f6\u884c\u53ef\u80fd\u6700\u65e9\u5728 2 \u6708\u4efd\u5f00\u59cb\u4e0b\u8c03\u5176 4.35% \u7684\u73b0\u91d1\u5229\u7387\uff0c\u5373\u5c06\u53d1\u5e03\u7684\u4f1a\u8bae\u7eaa\u8981\u9884\u8ba1\u5c06\u63d0\u4f9b\u8fdb\u4e00\u6b65\u7684\u89c1\u89e3\u3002\u4e0e\u6b64\u540c\u65f6\uff0c\u6570\u636e\u663e\u793a\uff0c11 \u6708\u6fb3\u5927\u5229\u4e9a\u79c1\u8425\u90e8\u95e8\u4fe1\u8d37\u73af\u6bd4\u589e\u957f 0.5%\uff0c\u521b\u4e0b\u56db\u4e2a\u6708\u4ee5\u6765\u6700\u5feb\u7684\u6708\u5ea6\u589e\u957f\u3002\u5916\u90e8\u56e0\u7d20\uff0c\u6fb3\u5143\u4ecd\u9762\u4e34\u5f3a\u52bf\u7f8e\u5143\u7684\u538b\u529b\uff0c\u6b64\u524d\u7f8e\u8054\u50a8\u5468\u4e09\u5ba3\u5e03\u4e86\u666e\u904d\u9884\u671f\u7684 25 \u4e2a\u57fa\u70b9\u7684\u964d\u606f\uff0c\u540c\u65f6\u6697\u793a 2025 \u5e74\u964d\u606f\u6b21\u6570\u51cf\u5c11\u3002\u6b64\u5916\uff0c\u4e2d\u56fd\u592e\u884c\u7ef4\u6301\u5173\u952e\u8d37\u6b3e\u5229\u7387\u7a33\u5b9a\uff0c\u6ca1\u6709\u4e3a\u6fb3\u5927\u5229\u4e9a\u6700\u5927\u7684\u8d38\u6613\u4f19\u4f34\u63d0\u4f9b\u65b0\u7684\u7ecf\u6d4e\u523a\u6fc0\u63aa\u65bd\u3002", "id": 833369, "description": "", "link": "https://www.fx168news.com/express/fastnews/833369", "pub_date": "2024-12-20 11:40:04"}, {"title": "\u65e5\u672c\u6700\u9ad8\u5916\u6c47\u4e8b\u52a1\u5b98\u5458\u4e09\u6751\u6df3\uff1a\u975e\u5e38\u5173\u6ce8\u5916\u6c47\u8d70\u52bf\u3002\u5c06\u91c7\u53d6\u9002\u5f53\u63aa\u65bd\u9632\u6b62\u8fc7\u5ea6\u7684\u5916\u6c47\u6ce2\u52a8\u3002", "id": 833365, "description": "", "link": "https://www.fx168news.com/express/fastnews/833365", "pub_date": "2024-12-20 11:33:02"}, {"title": "\u7f8e\u5143\u5151\u65e5\u5143USD/JPY\u77ed\u7ebf\u8d70\u4f4e30\u70b9\u540e\u5c0f\u5e45\u56de\u5347\uff0c\u65e5\u5185\u8dcc\u5e45\u8fbe0.50%\uff0c\u73b0\u62a5156.97\u3002", "id": 833366, "description": "", "link": "https://www.fx168news.com/express/fastnews/833366", "pub_date": "2024-12-20 11:34:02"}, {"title": "\u6e2f\u80a1\u4e2d\u82af\u56fd\u9645\u6da8\u5e45\u6269\u5927\u81f39%\uff0c\u73b0\u62a528.5\u6e2f\u5143\uff0c\u6210\u4ea4\u989d\u8d8543\u4ebf\u6e2f\u5143\u3002", "id": 833362, "description": "", "link": "https://www.fx168news.com/express/fastnews/833362", "pub_date": "2024-12-20 11:30:03"}, {"title": "\u65b0\u897f\u5170\u5143\u4ecd\u5904\u4e8e\u4e24\u5e74\u591a\u4f4e\u70b9\uff0c\u5468\u4e94\u4ea4\u6613\u4ef7\u7ea6\u4e3a 0.562 \u7f8e\u5143\uff0c\u6709\u671b\u8fde\u7eed\u7b2c\u4e09\u5468\u4e0b\u8dcc\u3002\u7b2c\u4e09\u5b63\u5ea6 GDP \u6570\u636e\u5f31\u4e8e\u9884\u671f\uff0c\u4ee4\u65b0\u897f\u5170\u5143\u627f\u538b\uff0c\u8fd9\u52a0\u5267\u4e86\u4eba\u4eec\u5bf9\u65b0\u897f\u5170\u50a8\u5907\u94f6\u884c\u5c06\u91c7\u53d6\u66f4\u6fc0\u8fdb\u7684\u8d27\u5e01\u653f\u7b56\u5bbd\u677e\u63aa\u65bd\u7684\u9884\u671f\u3002\u5e02\u573a\u5df2\u5b8c\u5168\u6d88\u5316\u4e86\u592e\u884c\u5728 2 \u6708\u4efd\u4f1a\u8bae\u4e0a\u5927\u5e45\u964d\u606f 50 \u4e2a\u57fa\u70b9\u7684\u9884\u671f\u3002\u5728\u5176\u4ed6\u7ecf\u6d4e\u65b0\u95fb\u4e2d\uff0c\u65b0\u897f\u5170 11 \u6708\u4efd\u7684\u8d38\u6613\u9006\u5dee\u6536\u7a84\uff0c\u63a8\u52a8\u56e0\u7d20\u5305\u62ec\u51fa\u53e3\u589e\u52a0\u800c\u8fdb\u53e3\u4e0b\u964d\u3002\u5916\u90e8\u56e0\u7d20\uff0c\u5728\u7f8e\u8054\u50a8\u53d1\u8868\u9e70\u6d3e\u5c55\u671b\u540e\uff0c\u65b0\u897f\u5170\u5143\u4ecd\u9762\u4e34\u5f3a\u52bf\u7f8e\u5143\u7684\u538b\u529b\u3002\u672c\u5468\u8fc4\u4eca\u4e3a\u6b62\uff0c\u65b0\u897f\u5170\u5143\u5df2\u4e0b\u8dcc 2.3%\uff0c\u521b\u4e0b\u4e24\u4e2a\u591a\u6708\u4ee5\u6765\u7684\u6700\u5dee\u5468\u5ea6\u8868\u73b0\u3002", "id": 833363, "description": "", "link": "https://www.fx168news.com/express/fastnews/833363", "pub_date": "2024-12-20 11:30:04"}, {"title": "A\u80a1\u4e2d\u82af\u56fd\u9645\u65e5\u5185\u6da8\u8d8510%\uff0c\u6210\u4ea4\u989d\u8d8590\u4ebf\u5143\u3002H\u80a1\u4e2d\u82af\u56fd\u9645(00981.HK)\u73b0\u6da89.5%\u3002", "id": 833364, "description": "", "link": "https://www.fx168news.com/express/fastnews/833364", "pub_date": "2024-12-20 11:31:02"}, {"title": "\u9884\u6d4b\u5e02\u573a\u5e73\u53f0PolyMarket\u7684\u6570\u636e\u663e\u793a\uff0c\u9884\u6d4b\u7f8e\u56fd\u653f\u5e9c\u5c06\u4f1a\u505c\u6446\u7684\u53ef\u80fd\u6027\u572865%\u5de6\u53f3\u3002", "id": 833355, "description": "", "link": "https://www.fx168news.com/express/fastnews/833355", "pub_date": "2024-12-20 11:24:03"}, {"title": "\u5728\u7ebf\u65c5\u884c\u5e73\u53f0\u98de\u732a20\u65e5\u53d1\u5e03\u7684\u300a2024\u79df\u8f66\u81ea\u9a7e\u6e38\u62a5\u544a\u300b\u663e\u793a\uff0c2024\u5e74\u56fd\u5185\u79df\u8f66\u8ba2\u5355\u91cf\u540c\u6bd4\u53bb\u5e74\u589e\u957f\u7ea680%\uff0c\u4eba\u5747\u79df\u8f66\u6d88\u8d39\u540c\u6bd4\u63d0\u5347\u7ea630%\u3002\u56fd\u5e86\u5047\u671f\u521b\u4e0b\u5e74\u5185\u79df\u8f66\u9884\u8ba2\u91cf\u5cf0\u503c\uff0c\u4e94\u4e00\u5047\u671f\u3001\u6691\u671f\u3001\u6625\u8282\u5047\u671f\u7b49\u4e5f\u662f\u5e74\u5185\u79df\u8f66\u70ed\u95e8\u65f6\u6bb5\u3002\u6b64\u5916\uff0c\u5e74\u8f7b\u4eba\u662f\u56fd\u5185\u79df\u8f66\u6d88\u8d39\u201c\u4e3b\u529b\u519b\u201d\u3002\u98de\u732a\u6570\u636e\u663e\u793a\uff0c2024\u5e74\uff0c\u201c90\u540e\u201d\u548c\u201c00\u540e\u201d\u79df\u8f66\u81ea\u9a7e\u6e38\u8ba2\u5355\u5360\u6bd4\u8fd1\u516d\u6210\uff0c\u5176\u4e2d\u201c00\u540e\u201d\u8ba2\u5355\u5360\u6bd4\u8f83\u53bb\u5e74\u63d0\u5347\u4e862\u4e2a\u767e\u5206\u70b9\u3002\u503c\u5f97\u4e00\u63d0\u7684\u662f\uff0c\u4f5c\u4e3a\u81ea\u9a7e\u6e38\u7684\u4e8c\u5e74\u7ea7\u201c\u840c\u65b0\u9009\u624b\u201d\uff0c\u201c05\u540e\u201d\u79df\u8f66\u8ba2\u5355\u91cf\u540c\u6bd4\u6fc0\u589e\u8fd15\u500d\u3002", "id": 833356, "description": "", "link": "https://www.fx168news.com/express/fastnews/833356", "pub_date": "2024-12-20 11:25:02"}]}