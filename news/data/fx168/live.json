u524d\u4ef7\u683c\u4e3a32.67\u7f8e\u5143/\u76ce\u53f8\u3002", "id": 788336, "description": "10\u670818\u65e5\uff0c\u73b0\u8d27\u767d\u94f6\u4ef7\u683c\u5927\u5e45\u6500\u5347\uff0c\u6da8\u5e45\u8d85\u8fc73%\uff0c\u5f53\u524d\u4ef7\u683c\u4e3a32.67\u7f8e\u5143/\u76ce\u53f8\u3002", "link": "https://www.fx168news.com/express/fastnews/788336", "pub_date": "2024-10-18 23:49:03"}, {"title": "\u3010\u5206\u6790\uff1a\u7f8e\u5143\u5728\u672c\u6708\u5916\u6c47\u5e02\u573a\u4e0a\u72ec\u5360\u9ccc\u5934\u3011\u636e10\u670818\u65e5\u7684\u62a5\u9053\uff0cJ. Safra Sarasin\u7684\u53ef\u6301\u7eed\u8d44\u4ea7\u7ba1\u7406\u7b56\u7565\u5e08Claudio Wewel\u6307\u51fa\uff0c10\u6708\u4efd\u7684\u524d\u534a\u4e2a\u6708\uff0c\u7f8e\u5143\u6c47\u7387\u663e\u8457\u4e0a\u5347\u3002\u8fd9\u79cd\u5f3a\u52bf\u4e3b\u8981\u5f97\u76ca\u4e8e\u7f8e\u56fd\u8fd1\u671f\u53d1\u5e03\u7684\u7ecf\u6d4e\u6570\u636e\u8d85\u51fa\u9884\u671f\u3002\u5e02\u573a\u56e0\u6b64\u5bf9\u7f8e\u56fd\u672a\u6765\u7684\u964d\u606f\u9884\u671f\u8fdb\u884c\u4e86\u663e\u8457\u8c03\u6574\u3002\u6b64\u5916\uff0c\u7531\u4e8e\u7f8e\u56fd\u603b\u7edf\u9009\u4e3e\u7ed3\u679c\u7684\u4e0d\u786e\u5b9a\u6027\uff0c\u6295\u8d44\u8005\u5728\u9009\u4e3e\u524d\u7eb7\u7eb7\u9009\u62e9\u8d2d\u5165\u7f8e\u5143\u3002", "id": 788330, "description": "\u3010\u5206\u6790\uff1a\u7f8e\u5143\u5728\u672c\u6708\u5916\u6c47\u5e02\u573a\u4e0a\u72ec\u5360\u9ccc\u5934\u3011\u636e10\u670818\u65e5\u7684\u62a5\u9053\uff0cJ. Safra Sarasin\u7684\u53ef\u6301\u7eed\u8d44\u4ea7\u7ba1\u7406\u7b56\u7565\u5e08Claudio Wewel\u6307\u51fa\uff0c10\u6708\u4efd\u7684\u524d\u534a\u4e2a\u6708\uff0c\u7f8e\u5143\u6c47\u7387\u663e\u8457\u4e0a\u5347\u3002\u8fd9\u79cd\u5f3a\u52bf\u4e3b\u8981\u5f97\u76ca\u4e8e\u7f8e\u56fd\u8fd1\u671f\u53d1\u5e03\u7684\u7ecf\u6d4e\u6570\u636e\u8d85\u51fa\u9884\u671f\u3002\u5e02\u573a\u56e0\u6b64\u5bf9\u7f8e\u56fd\u672a\u6765\u7684\u964d\u606f\u9884\u671f\u8fdb\u884c\u4e86\u663e\u8457\u8c03\u6574\u3002\u6b64\u5916\uff0c\u7531\u4e8e\u7f8e\u56fd\u603b\u7edf\u9009\u4e3e\u7ed3\u679c\u7684\u4e0d\u786e\u5b9a\u6027\uff0c\u6295\u8d44\u8005\u5728\u9009\u4e3e\u524d\u7eb7\u7eb7\u9009\u62e9\u8d2d\u5165\u7f8e\u5143\u3002", "link": "https://www.fx168news.com/express/fastnews/788330", "pub_date": "2024-10-18 23:35:50"}, {"title": "\u3010\u6c11\u751f\u8bc1\u5238\u5206\u6790\uff1a\u4eca\u5e74\u7b2c\u56db\u5b63\u5ea6\u7ecf\u6d4e\u6709\u671b\u5b9e\u73b0\u7a33\u5b9a\u589e\u957f\u3011\u6839\u636e10\u670818\u65e5\u7684\u62a5\u9053\uff0c\u6c11\u751f\u8bc1\u5238\u53d1\u5e03\u7684\u7814\u7a76\u62a5\u544a\u6307\u51fa\uff0c\u5728\u5f53\u524d\u653f\u7b56\u9891\u7e41\u63a8\u51fa\u7684\u60c5\u51b5\u4e0b\uff0c\u9884\u8ba1\u201c\u4eca\u5e74\u7b2c\u56db\u5b63\u5ea6\u7ecf\u6d4e\u7a33\u5b9a\u589e\u957f\u7684\u53ef\u80fd\u6027\u5f88\u5927\u201d\u3002\u5982\u679c\u7b2c\u56db\u5b63\u5ea6\u7684\u7ecf\u6d4e\u589e\u901f\u80fd\u591f\u8fbe\u52304.7%\uff0c\u90a3\u4e48\u5168\u5e74\u7684GDP\u589e\u901f\u5c06\u80fd\u591f\u8fbe\u52304.8%\u3002\u7136\u800c\uff0c\u82e5\u8981\u5b9e\u73b0\u7b2c\u56db\u5b63\u5ea6\u589e\u901f\u8d85\u8fc75%\uff0c\u5c31\u9700\u8981\u65b0\u7684\u653f\u7b56\u63aa\u65bd\u80fd\u591f\u8fc5\u901f\u4e14\u6709\u6548\u5730\u5b9e\u65bd\u3002\u5bf9\u4e8e\u660e\u5e74\u7684\u7ecf\u6d4e\u524d\u666f\uff0c\u62a5\u544a\u8ba4\u4e3a\uff0c\u76ee\u524d\u7684\u653f\u7b56\u529b\u5ea6\u53ef\u80fd\u8fd8\u4e0d\u8db3\u4ee5\u5f25\u5408\u540d\u4e49GDP\u4e0e\u5b9e\u9645GDP\u589e\u901f\u4e4b\u95f4\u7684\u5dee\u8ddd\uff0c\u56e0\u6b64\uff0c\u8d22\u653f\u653f\u7b56\u5728\u5404\u90e8\u95e8\u8d44\u4ea7\u8d1f\u503a\u8868\u7684\u4fee\u590d\u4e0a\u9700\u8981\u52a0\u5feb\u6b65\u4f10\u3002", "id": 788332, "description": "\u3010\u6c11\u751f\u8bc1\u5238\u5206\u6790\uff1a\u4eca\u5e74\u7b2c\u56db\u5b63\u5ea6\u7ecf\u6d4e\u6709\u671b\u5b9e\u73b0\u7a33\u5b9a\u589e\u957f\u3011\u6839\u636e10\u670818\u65e5\u7684\u62a5\u9053\uff0c\u6c11\u751f\u8bc1\u5238\u53d1\u5e03\u7684\u7814\u7a76\u62a5\u544a\u6307\u51fa\uff0c\u5728\u5f53\u524d\u653f\u7b56\u9891\u7e41\u63a8\u51fa\u7684\u60c5\u51b5\u4e0b\uff0c\u9884\u8ba1\u201c\u4eca\u5e74\u7b2c\u56db\u5b63\u5ea6\u7ecf\u6d4e\u7a33\u5b9a\u589e\u957f\u7684\u53ef\u80fd\u6027\u5f88\u5927\u201d\u3002\u5982\u679c\u7b2c\u56db\u5b63\u5ea6\u7684\u7ecf\u6d4e\u589e\u901f\u80fd\u591f\u8fbe\u52304.7%\uff0c\u90a3\u4e48\u5168\u5e74\u7684GDP\u589e\u901f\u5c06\u80fd\u591f\u8fbe\u52304.8%\u3002\u7136\u800c\uff0c\u82e5\u8981\u5b9e\u73b0\u7b2c\u56db\u5b63\u5ea6\u589e\u901f\u8d85\u8fc75%\uff0c\u5c31\u9700\u8981\u65b0\u7684\u653f\u7b56\u63aa\u65bd\u80fd\u591f\u8fc5\u901f\u4e14\u6709\u6548\u5730\u5b9e\u65bd\u3002\u5bf9\u4e8e\u660e\u5e74\u7684\u7ecf\u6d4e\u524d\u666f\uff0c\u62a5\u544a\u8ba4\u4e3a\uff0c\u76ee\u524d\u7684\u653f\u7b56\u529b\u5ea6\u53ef\u80fd\u8fd8\u4e0d\u8db3\u4ee5\u5f25\u5408\u540d\u4e49GDP\u4e0e\u5b9e\u9645GDP\u589e\u901f\u4e4b\u95f4\u7684\u5dee\u8ddd\uff0c\u56e0\u6b64\uff0c\u8d22\u653f\u653f\u7b56\u5728\u5404\u90e8\u95e8\u8d44\u4ea7\u8d1f\u503a\u8868\u7684\u4fee\u590d\u4e0a\u9700\u8981\u52a0\u5feb\u6b65\u4f10\u3002", "link": "https://www.fx168news.com/express/fastnews/788332", "pub_date": "2024-10-18 23:39:47"}]}