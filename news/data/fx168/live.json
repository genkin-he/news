3e\u989d\u5ea6\u4e0a\u9650\u4e3a60\u4e07\u5143\u3002\u5bf9\u4e8e\u7b26\u5408\u7279\u5b9a\u4e0a\u6d6e\u653f\u7b56\u7684\u804c\u5de5\uff0c\u8d37\u6b3e\u989d\u5ea6\u6700\u9ad8\u53ef\u8fbe120\u4e07\u5143\u3002\u6b64\u5916\uff0c\u821f\u5c71\u5e02\u8fd8\u9f13\u52b1\u6539\u5584\u578b\u4f4f\u623f\u6d88\u8d39\uff0c\u5bf9\u4e8e\u9996\u6b21\u8d2d\u623f\u4e14\u5df2\u7ed3\u6e05\u516c\u79ef\u91d1\u8d37\u6b3e\u7684\u5bb6\u5ead\uff0c\u5c06\u6267\u884c\u9996\u5957\u623f\u8d37\u6b3e\u653f\u7b56\u3002\u5bb6\u5ead\u4f4f\u623f\u5957\u6570\u7684\u8ba4\u5b9a\u5c06\u4f9d\u636e\u4e0d\u52a8\u4ea7\u767b\u8bb0\u90e8\u95e8\u7684\u8bb0\u5f55\u3002\u540c\u65f6\uff0c\u653e\u5bbd\u4e86\u516c\u79ef\u91d1\u8d37\u6b3e\u7684\u6309\u6708\u51b2\u8fd8\u8d37\u9650\u5236\uff0c\u804c\u5de5\u53ef\u6309\u6708\u63d0\u53d6\u516c\u79ef\u91d1\u7528\u4e8e\u507f\u8fd8\u8d37\u6b3e\uff0c\u65e0\u9700\u4fdd\u7559\u6700\u4f4e\u4f59\u989d\u3002\u5bf9\u4e8e\u653f\u7b56\u5b9e\u65bd\u524d\u5df2\u7559\u5b58\u6700\u4f4e\u4f59\u989d\u7684\u804c\u5de5\uff0c\u5176\u539f\u6700\u4f4e\u4f59\u989d\u53ef\u7ee7\u7eed\u7528\u4e8e\u6bcf\u6708\u8fd8\u6b3e\u62b5\u6263\u3002", "id": 787511, "description": "\u3010\u821f\u5c71\u5e02\u63d0\u9ad8\u516c\u79ef\u91d1\u8d37\u6b3e\u4e0a\u9650\u81f380\u4e07\uff0c\u7279\u5b9a\u60c5\u51b5\u4e0b\u53ef\u8fbe120\u4e07\u301110\u670818\u65e5\uff0c\u821f\u5c71\u5e02\u4f4f\u623f\u516c\u79ef\u91d1\u7ba1\u7406\u4e2d\u5fc3\u5ba3\u5e03\u8c03\u6574\u516c\u79ef\u91d1\u8d37\u6b3e\u53ca\u63d0\u53d6\u653f\u7b56\u3002\u6839\u636e\u65b0\u89c4\u5b9a\uff0c\u9996\u5957\u623f\u516c\u79ef\u91d1\u8d37\u6b3e\u989d\u5ea6\u4e0a\u9650\u63d0\u5347\u81f380\u4e07\u5143\uff0c\u4e8c\u5957\u623f\u8d37\u6b3e\u989d\u5ea6\u4e0a\u9650\u4e3a60\u4e07\u5143\u3002\u5bf9\u4e8e\u7b26\u5408\u7279\u5b9a\u4e0a\u6d6e\u653f\u7b56\u7684\u804c\u5de5\uff0c\u8d37\u6b3e\u989d\u5ea6\u6700\u9ad8\u53ef\u8fbe120\u4e07\u5143\u3002\u6b64\u5916\uff0c\u821f\u5c71\u5e02\u8fd8\u9f13\u52b1\u6539\u5584\u578b\u4f4f\u623f\u6d88\u8d39\uff0c\u5bf9\u4e8e\u9996\u6b21\u8d2d\u623f\u4e14\u5df2\u7ed3\u6e05\u516c\u79ef\u91d1\u8d37\u6b3e\u7684\u5bb6\u5ead\uff0c\u5c06\u6267\u884c\u9996\u5957\u623f\u8d37\u6b3e\u653f\u7b56\u3002\u5bb6\u5ead\u4f4f\u623f\u5957\u6570\u7684\u8ba4\u5b9a\u5c06\u4f9d\u636e\u4e0d\u52a8\u4ea7\u767b\u8bb0\u90e8\u95e8\u7684\u8bb0\u5f55\u3002\u540c\u65f6\uff0c\u653e\u5bbd\u4e86\u516c\u79ef\u91d1\u8d37\u6b3e\u7684\u6309\u6708\u51b2\u8fd8\u8d37\u9650\u5236\uff0c\u804c\u5de5\u53ef\u6309\u6708\u63d0\u53d6\u516c\u79ef\u91d1\u7528\u4e8e\u507f\u8fd8\u8d37\u6b3e\uff0c\u65e0\u9700\u4fdd\u7559\u6700\u4f4e\u4f59\u989d\u3002\u5bf9\u4e8e\u653f\u7b56\u5b9e\u65bd\u524d\u5df2\u7559\u5b58\u6700\u4f4e\u4f59\u989d\u7684\u804c\u5de5\uff0c\u5176\u539f\u6700\u4f4e\u4f59\u989d\u53ef\u7ee7\u7eed\u7528\u4e8e\u6bcf\u6708\u8fd8\u6b3e\u62b5\u6263\u3002", "link": "https://www.fx168news.com/express/fastnews/787511", "pub_date": "2024-10-18 14:15:05"}, {"title": "\u3010\u4e2d\u4fe1\u8bc1\u5238A\u80a1\u4ea4\u6613\u989d\u7a81\u7834\u767e\u4ebf\u301110\u670818\u65e5\uff0c\u4e2d\u4fe1\u8bc1\u5238\u5728A\u80a1\u5e02\u573a\u7684\u4ea4\u6613\u989d\u8fbe\u5230\u4e86100\u4ebf\u5143\u7684\u91cc\u7a0b\u7891\uff0c\u80a1\u4ef7\u6da8\u5e45\u8d85\u8fc77%\u3002", "id": 787512, "description": "\u3010\u4e2d\u4fe1\u8bc1\u5238A\u80a1\u4ea4\u6613\u989d\u7a81\u7834\u767e\u4ebf\u301110\u670818\u65e5\uff0c\u4e2d\u4fe1\u8bc1\u5238\u5728A\u80a1\u5e02\u573a\u7684\u4ea4\u6613\u989d\u8fbe\u5230\u4e86100\u4ebf\u5143\u7684\u91cc\u7a0b\u7891\uff0c\u80a1\u4ef7\u6da8\u5e45\u8d85\u8fc77%\u3002", "link": "https://www.fx168news.com/express/fastnews/787512", "pub_date": "2024-10-18 14:15:16"}, {"title": "\u82f1\u56fd\u56fd\u5bb6\u7edf\u8ba1\u5c40\u53d1\u5e03\u7684\u6570\u636e\u663e\u793a\uff0c\u7b2c\u4e09\u5b63\u5ea6\u7684\u9500\u552e\u989d\u6bd4\u7b2c\u4e8c\u5b63\u5ea6\u4e0a\u5347\u4e861.9\u4e2a\u767e\u5206\u70b9\u3002", "id": 787500, "description": "\u82f1\u56fd\u56fd\u5bb6\u7edf\u8ba1\u5c40\u53d1\u5e03\u7684\u6570\u636e\u663e\u793a\uff0c\u7b2c\u4e09\u5b63\u5ea6\u7684\u9500\u552e\u989d\u6bd4\u7b2c\u4e8c\u5b63\u5ea6\u4e0a\u5347\u4e861.9\u4e2a\u767e\u5206\u70b9\u3002", "link": "https://www.fx168news.com/express/fastnews/787500", "pub_date": "2024-10-18 14:06:24"}, {"title": "\u636e\u82f1\u56fd\u56fd\u5bb6\u7edf\u8ba1\u5c40\u6700\u65b0\u6570\u636e\u663e\u793a\uff0c\u622a\u81f32024\u5e749\u6708\u768412\u4e2a\u6708\u5185\uff0c\u9500\u552e\u91cf\u5b9e\u73b0\u4e863.9%\u7684\u589e\u957f\uff0c\u521b\u4e0b\u81ea2022\u5e742\u6708\u4ee5\u6765\u7684\u6700\u9ad8\u540c\u6bd4\u6da8\u5e45\u3002", "id": 787501, "description": "\u636e\u82f1\u56fd\u56fd\u5bb6\u7edf\u8ba1\u5c40\u6700\u65b0\u6570\u636e\u663e\u793a\uff0c\u622a\u81f32024\u5e749\u6708\u768412\u4e2a\u6708\u5185\uff0c\u9500\u552e\u91cf\u5b9e\u73b0\u4e863.9%\u7684\u589e\u957f\uff0c\u521b\u4e0b\u81ea2022\u5e742\u6708\u4ee5\u6765\u7684\u6700\u9ad8\u540c\u6bd4\u6da8\u5e45\u3002", "link": "https://www.fx168news.com/express/fastnews/787501", "pub_date": "2024-10-18 14:06:41"}, {"title": "\u3010\u6df1\u5ea6\u5206\u6790\uff1a\u592e\u884c\u65b0\u4e3e\u63aa\u4fc3\u8fdb\u4e0a\u5e02\u516c\u53f8\u56de\u8d2d\u589e\u6301\u301110\u670818\u65e5\uff0c\u592e\u884c\u5ba3\u5e03\u63a8\u51fa\u4e00\u9879\u65b0\u653f\u7b56\u2014\u2014\u80a1\u7968\u56de\u8d2d\u589e\u6301\u518d\u8d37\u6b3e\uff0c\u65e8\u5728\u6fc0\u52b1\u4e0a\u5e02\u516c\u53f8\u53ca\u5176\u4e3b\u8981\u80a1\u4e1c\u589e\u52a0\u80a1\u7968\u56de\u8d2d\u548c\u589e\u6301\u6d3b\u52a8\u3002\u6839\u636e\u89c4\u5b9a\uff0c\u91d1\u878d\u673a\u6784\u63d0\u4f9b\u7684\u8d37\u6b3e\u5229\u7387\u4e0a\u9650\u4e3a2.25%\uff0c\u8fd9\u4e00\u76f8\u5bf9\u8f83\u4f4e\u7684\u5229\u7387\u6c34\u5e73\u65e8\u5728\u9f13\u52b1\u4f01\u4e1a\u5229\u7528\u8d37\u6b3e\u8fdb\u884c\u80a1\u7968\u56de\u8d2d\u548c\u589e\u6301\u3002\u5e02\u573a\u5206\u6790\u4eba\u58eb\u8ba4\u4e3a\uff0c\u8fd9\u4e00\u653f\u7b56\u4f53\u73b0\u4e86\u592e\u884c\u5bf9\u8d44\u672c\u5e02\u573a\u7a33\u5b9a\u7684\u652f\u6301\u3002\u518d\u8d37\u6b3e\u673a\u5236\u6d89\u53ca\u591a\u4e2a\u73af\u8282\uff0c\u5305\u62ec\u80a1\u7968\u589e\u6301\u56de\u8d2d\u3001\u94f6\u884c\u8d37\u6b3e\u53d1\u653e\u4ee5\u53ca\u592e\u884c\u7684\u518d\u8d37\u6b3e\u64cd\u4f5c\u3002\u592e\u884c\u660e\u786e\u6307\u51fa\uff0c21\u5bb6\u91d1\u878d\u673a\u6784\u7684\u8d37\u6b3e\u8d44\u91d1\u5fc5\u987b\u4e13\u95e8\u7528\u4e8e\u80a1\u7968\u56de\u8d2d\u548c\u589e\u6301\uff0c\u5e76\u4e14\u5b9e\u884c\u201c\u4e13\u6b3e\u4e13\u7528\uff0c\u5c01\u95ed\u8fd0\u884c\u201d\u7684\u539f\u5219\u3002\u5728\u8d37\u6b3e\u672a\u5b8c\u5168\u507f\u8fd8\u4e4b\u524d\uff0c\u76f8\u5173\u8d44\u91d1\u8d26\u6237\u4e0d\u5f97\u63d0\u53d6\u73b0\u91d1\u6216\u8fdb\u884c\u5bf9\u5916\u8f6c\u8d26\u3002\u4e13\u5bb6\u5f3a\u8c03\uff0c\u786e\u4fdd\u94f6\u884c\u4fe1\u8d37\u8d44\u91d1\u4e0d\u8fdd\u89c4\u6d41\u5165\u80a1\u5e02\u662f\u91d1\u878d\u76d1\u7ba1\u5fc5\u987b\u575a\u5b88\u7684\u5e95\u7ebf\u3002", "id": 787503, "description": "\u3010\u6df1\u5ea6\u5206\u6790\uff1a\u592e\u884c\u65b0\u4e3e\u63aa\u4fc3\u8fdb\u4e0a\u5e02\u516c\u53f8\u56de\u8d2d\u589e\u6301\u301110\u670818\u65e5\uff0c\u592e\u884c\u5ba3\u5e03\u63a8\u51fa\u4e00\u9879\u65b0\u653f\u7b56\u2014\u2014\u80a1\u7968\u56de\u8d2d\u589e\u6301\u518d\u8d37\u6b3e\uff0c\u65e8\u5728\u6fc0\u52b1\u4e0a\u5e02\u516c\u53f8\u53ca\u5176\u4e3b\u8981\u80a1\u4e1c\u589e\u52a0\u80a1\u7968\u56de\u8d2d\u548c\u589e\u6301\u6d3b\u52a8\u3002\u6839\u636e\u89c4\u5b9a\uff0c\u91d1\u878d\u673a\u6784\u63d0\u4f9b\u7684\u8d37\u6b3e\u5229\u7387\u4e0a\u9650\u4e3a2.25%\uff0c\u8fd9\u4e00\u76f8\u5bf9\u8f83\u4f4e\u7684\u5229\u7387\u6c34\u5e73\u65e8\u5728\u9f13\u52b1\u4f01\u4e1a\u5229\u7528\u8d37\u6b3e\u8fdb\u884c\u80a1\u7968\u56de\u8d2d\u548c\u589e\u6301\u3002\u5e02\u573a\u5206\u6790\u4eba\u58eb\u8ba4\u4e3a\uff0c\u8fd9\u4e00\u653f\u7b56\u4f53\u73b0\u4e86\u592e\u884c\u5bf9\u8d44\u672c\u5e02\u573a\u7a33\u5b9a\u7684\u652f\u6301\u3002\u518d\u8d37\u6b3e\u673a\u5236\u6d89\u53ca\u591a\u4e2a\u73af\u8282\uff0c\u5305\u62ec\u80a1\u7968\u589e\u6301\u56de\u8d2d\u3001\u94f6\u884c\u8d37\u6b3e\u53d1\u653e\u4ee5\u53ca\u592e\u884c\u7684\u518d\u8d37\u6b3e\u64cd\u4f5c\u3002\u592e\u884c\u660e\u786e\u6307\u51fa\uff0c21\u5bb6\u91d1\u878d\u673a\u6784\u7684\u8d37\u6b3e\u8d44\u91d1\u5fc5\u987b\u4e13\u95e8\u7528\u4e8e\u80a1\u7968\u56de\u8d2d\u548c\u589e\u6301\uff0c\u5e76\u4e14\u5b9e\u884c\u201c\u4e13\u6b3e\u4e13\u7528\uff0c\u5c01\u95ed\u8fd0\u884c\u201d\u7684\u539f\u5219\u3002\u5728\u8d37\u6b3e\u672a\u5b8c\u5168\u507f\u8fd8\u4e4b\u524d\uff0c\u76f8\u5173\u8d44\u91d1\u8d26\u6237\u4e0d\u5f97\u63d0\u53d6\u73b0\u91d1\u6216\u8fdb\u884c\u5bf9\u5916\u8f6c\u8d26\u3002\u4e13\u5bb6\u5f3a\u8c03\uff0c\u786e\u4fdd\u94f6\u884c\u4fe1\u8d37\u8d44\u91d1\u4e0d\u8fdd\u89c4\u6d41\u5165\u80a1\u5e02\u662f\u91d1\u878d\u76d1\u7ba1\u5fc5\u987b\u575a\u5b88\u7684\u5e95\u7ebf\u3002", "link": "https://www.fx168news.com/express/fastnews/787503", "pub_date": "2024-10-18 14:09:51"}]}