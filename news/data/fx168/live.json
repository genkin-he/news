7\u78b3\u4ef7\u5f53\u524d\u6bcf\u54285\u7f8e\u5143\u592a\u4f4e\uff0c2030\u5e74\u672b\u5e94\u5347\u81f385\u7f8e\u5143\u4e0a\u65b9\u3011 2024 ESG\u5168\u7403\u9886\u5bfc\u8005\u5927\u4f1a10\u670816\u65e5-18\u65e5\u5728\u4e0a\u6d77\u53ec\u5f00\uff0c\u56fd\u9645\u8d27\u5e01\u57fa\u91d1\u7ec4\u7ec7(IMF)\u603b\u88c1\u683c\u5965\u5c14\u57fa\u8036\u5a03(Kristalina Georgieva)\u6f14\u8bb2\u3002\u5979\u8ba4\u4e3a\uff0c\u5404\u56fd\u53ef\u4ee5\u91c7\u53d6\u7684\u6700\u91cd\u8981\u63aa\u65bd\u4e4b\u4e00\u662f\u63a8\u884c\u78b3\u5b9a\u4ef7\u3002\u5b83\u80fd\u4e3a\u7eff\u8272\u6280\u672f\u521b\u9020\u516c\u5e73\u7684\u7ade\u4e89\u73af\u5883\uff0c\u5e76\u80fd\u9f13\u52b1\u4f01\u4e1a\u548c\u5bb6\u5ead\u4f5c\u51fa\u4f4e\u78b3\u8282\u80fd\u7684\u9009\u62e9\u3002\u201c\u5f53\u524d\u5168\u7403\u6bcf\u54285\u7f8e\u5143\u7684\u5e73\u5747\u78b3\u4ef7\u592a\u4f4e\u4e86\u3002\u4e3a\u4e86\u6709\u6548\u6291\u5236\u5168\u7403\u5347\u6e29\uff0c\u5230\u672c\u5341\u5e74\u672b\uff0c\u5168\u7403\u5e73\u5747\u78b3\u4ef7\u5e94\u4ece5\u7f8e\u5143\u4e0a\u5347\u5230\u81f3\u5c1185\u7f8e\u5143\u201d\uff0c\u683c\u5965\u5c14\u57fa\u8036\u5a03\u8bf4\u3002</p>", "id": 786403, "description": "<p>\u3010IMF\u603b\u88c1\uff1a\u5e73\u5747\u78b3\u4ef7\u5f53\u524d\u6bcf\u54285\u7f8e\u5143\u592a\u4f4e\uff0c2030\u5e74\u672b\u5e94\u5347\u81f385\u7f8e\u5143\u4e0a\u65b9\u3011 2024 ESG\u5168\u7403\u9886\u5bfc\u8005\u5927\u4f1a10\u670816\u65e5-18\u65e5\u5728\u4e0a\u6d77\u53ec\u5f00\uff0c\u56fd\u9645\u8d27\u5e01\u57fa\u91d1\u7ec4\u7ec7(IMF)\u603b\u88c1\u683c\u5965\u5c14\u57fa\u8036\u5a03(Kristalina Georgieva)\u6f14\u8bb2\u3002\u5979\u8ba4\u4e3a\uff0c\u5404\u56fd\u53ef\u4ee5\u91c7\u53d6\u7684\u6700\u91cd\u8981\u63aa\u65bd\u4e4b\u4e00\u662f\u63a8\u884c\u78b3\u5b9a\u4ef7\u3002\u5b83\u80fd\u4e3a\u7eff\u8272\u6280\u672f\u521b\u9020\u516c\u5e73\u7684\u7ade\u4e89\u73af\u5883\uff0c\u5e76\u80fd\u9f13\u52b1\u4f01\u4e1a\u548c\u5bb6\u5ead\u4f5c\u51fa\u4f4e\u78b3\u8282\u80fd\u7684\u9009\u62e9\u3002\u201c\u5f53\u524d\u5168\u7403\u6bcf\u54285\u7f8e\u5143\u7684\u5e73\u5747\u78b3\u4ef7\u592a\u4f4e\u4e86\u3002\u4e3a\u4e86\u6709\u6548\u6291\u5236\u5168\u7403\u5347\u6e29\uff0c\u5230\u672c\u5341\u5e74\u672b\uff0c\u5168\u7403\u5e73\u5747\u78b3\u4ef7\u5e94\u4ece5\u7f8e\u5143\u4e0a\u5347\u5230\u81f3\u5c1185\u7f8e\u5143\u201d\uff0c\u683c\u5965\u5c14\u57fa\u8036\u5a03\u8bf4\u3002</p>", "link": "https://www.fx168news.com/express/fastnews/786403", "pub_date": "2024-10-16 10:22:23"}, {"title": "<p>\u3010\u4ee5\u8272\u5217\u603b\u7406\u5185\u5854\u5c3c\u4e9a\u80e1\u5728\u901a\u8bdd\u4e2d\u544a\u8bc9\u9a6c\u514b\u9f99\uff0c\u4ed6\u53cd\u5bf9\u201c\u5355\u65b9\u9762\u505c\u706b\u201d\u3011 \u8def\u900f\u793e\u62a5\u9053\uff0c\u4ee5\u8272\u5217\u603b\u7406\u5185\u5854\u5c3c\u4e9a\u80e110\u670815\u65e5\u4e0e\u6cd5\u56fd\u603b\u7edf\u9a6c\u514b\u9f99\u901a\u8bdd\u544a\u77e5\uff0c\u4ed6\u53cd\u5bf9\u201c\u5355\u65b9\u9762\u505c\u706b\u201d\uff0c\u56e0\u4e3a\u8fd9\u4e0d\u4f1a\u6539\u53d8\u9ece\u5df4\u5ae9\u7684\u5b89\u5168\u5c40\u52bf\u3002\u6b64\u5916\uff0c\u5185\u5854\u5c3c\u4e9a\u80e1\u5f3a\u8c03\uff0c\u4ed6\u4e0d\u4f1a\u540c\u610f\u4e0d\u80fd\u963b\u6b62\u9ece\u5df4\u5ae9\u771f\u4e3b\u515a\u91cd\u65b0\u6b66\u88c5\u548c\u91cd\u7ec4\u7684\u505c\u706b\u534f\u8bae\u3002</p>", "id": 786404, "description": "<p>\u3010\u4ee5\u8272\u5217\u603b\u7406\u5185\u5854\u5c3c\u4e9a\u80e1\u5728\u901a\u8bdd\u4e2d\u544a\u8bc9\u9a6c\u514b\u9f99\uff0c\u4ed6\u53cd\u5bf9\u201c\u5355\u65b9\u9762\u505c\u706b\u201d\u3011 \u8def\u900f\u793e\u62a5\u9053\uff0c\u4ee5\u8272\u5217\u603b\u7406\u5185\u5854\u5c3c\u4e9a\u80e110\u670815\u65e5\u4e0e\u6cd5\u56fd\u603b\u7edf\u9a6c\u514b\u9f99\u901a\u8bdd\u544a\u77e5\uff0c\u4ed6\u53cd\u5bf9\u201c\u5355\u65b9\u9762\u505c\u706b\u201d\uff0c\u56e0\u4e3a\u8fd9\u4e0d\u4f1a\u6539\u53d8\u9ece\u5df4\u5ae9\u7684\u5b89\u5168\u5c40\u52bf\u3002\u6b64\u5916\uff0c\u5185\u5854\u5c3c\u4e9a\u80e1\u5f3a\u8c03\uff0c\u4ed6\u4e0d\u4f1a\u540c\u610f\u4e0d\u80fd\u963b\u6b62\u9ece\u5df4\u5ae9\u771f\u4e3b\u515a\u91cd\u65b0\u6b66\u88c5\u