{"data": [{"title": "\u82f1\u56fd\u8d22\u653f\u5927\u81e3\u91cc\u592b\u65af\u5f3a\u8c03\uff0c\u4ed6\u6240\u5236\u5b9a\u7684\u8d22\u653f\u653f\u7b56\u65e8\u5728\u786e\u4fdd\u7ecf\u6d4e\u7684\u6301\u7eed\u7a33\u5b9a\uff0c\u4e3a\u589e\u957f\u63d0\u4f9b\u5fc5\u8981\u7684\u652f\u6491\u3002\u4ed6\u63d0\u51fa\u7684\u7a33\u5b9a\u63aa\u65bd\u5c06\u5305\u62ec\u5bf9\u56fd\u5bb6\u503a\u52a1\u5229\u606f\u7684\u5168\u9762\u8986\u76d6\u3002", "id": 793752, "description": "", "link": "https://www.fx168news.com/express/fastnews/793752", "pub_date": "2024-10-24 21:03:57"}, {"title": "\u82f1\u56fd\u8d22\u653f\u5927\u81e3\u91cc\u592b\u65af\u6307\u51fa\uff0c\u653f\u5e9c\u63a5\u624b\u65f6\u53d1\u73b0\u516c\u5171\u8d22\u653f\u5b58\u5728\u9ad8\u8fbe220\u4ebf\u82f1\u9551\u7684\u8d64\u5b57\uff0c\u800c\u4e14\u5927\u90e8\u5206\u8d64\u5b57\u5c06\u6301\u7eed\u81f3\u672a\u6765\u6570\u5e74\u3002", "id": 793753, "description": "", "link": "https://www.fx168news.com/express/fastnews/793753", "pub_date": "2024-10-24 21:04:18"}, {"title": "\u3010\u52a0\u62ff\u59278\u6708\u4efd\u9886\u53d6\u5931\u4e1a\u4fdd\u9669\u4eba\u6570\u521b25\u4e2a\u6708\u65b0\u9ad8\uff0c\u53cd\u6620\u5c31\u4e1a\u5e02\u573a\u75b2\u5f31\u3011\u6700\u65b0\u62a5\u9053\u6307\u51fa\uff0c\u52a0\u62ff\u59278\u6708\u4efd\u9886\u53d6\u5931\u4e1a\u4fdd\u9669\u7684\u4eba\u6570\u5347\u81f325\u4e2a\u6708\u6765\u7684\u6700\u9ad8\u70b9\uff0c\u8fdb\u4e00\u6b65\u7a81\u663e\u4e86\u8be5\u56fd\u5c31\u4e1a\u5e02\u573a\u7684\u4e0d\u666f\u6c14\u3002\u6839\u636e\u52a0\u62ff\u5927\u7edf\u8ba1\u5c40\u7684\u62a5\u544a\uff0c8\u6708\u4efd\u9886\u53d6\u5c31\u4e1a\u4fdd\u9669\u7684\u4eba\u6570\u589e\u957f\u4e861.5%\uff0c\u8fbe\u523049.4\u4e07\uff0c\u8fd9\u662f\u8fd1\u56db\u4e2a\u6708\u5185\u7b2c\u4e09\u6b21\u51fa\u73b0\u589e\u957f\u3002\u4ece2023\u5e749\u6708\u81f32024\u5e744\u6708\uff0c\u9886\u53d6\u5931\u4e1a\u4fdd\u9669\u7684\u4eba\u6570\u5927\u81f4\u4fdd\u6301\u572846\u4e07\u5de6\u53f3\u3002\u6b64\u5916\uff0c\u4e0e\u53bb\u5e74\u540c\u671f\u76f8\u6bd4\uff0c8\u6708\u4efd\u7533\u8bf7\u5931\u4e1a\u6551\u6d4e\u7684\u4eba\u6570\u4e5f\u4e0a\u5347\u4e863.2%\u3002\u4e3a\u4e86\u5e94\u5bf9\u5c31\u4e1a\u5e02\u573a\u7684\u75b2\u8f6f\uff0c\u52a0\u62ff\u5927\u592e\u884c\u672c\u5468\u51b3\u5b9a\u5c06\u653f\u7b56\u5229\u7387\u4e0b\u8c0350\u4e2a\u57fa\u70b9\u81f33.75%\u3002", "id": 793754, "description": "", "link": "https://www.fx168news.com/express/fastnews/793754", "pub_date": "2024-10-24 21:05:16"}, {"title": "\u7f8e\u8054\u50a8\u5b98\u5458\u54c8\u739b\u514b\u6f84\u6e05\uff0c\u8be5\u673a\u6784\u5e76\u672a\u5ba3\u5e03\u201c\u5df2\u7ecf\u5b9e\u73b0\u4e86\u901a\u80c0\u76ee\u6807\u201d\u3002", "id": 793737, "description": "", "link": "https://www.fx168news.com/express/fastnews/793737", "pub_date": "2024-10-24 20:56:39"}, {"title": "\u6cd5\u56fd\u5916\u957f\u5df4\u7f57\u5ba3\u5e03\uff0c\u5df2\u6210\u529f\u4e3a\u9ece\u5df4\u5ae9\u7b79\u96c6\u4e868\u4ebf\u7f8e\u5143\u7684\u8d44\u91d1\u3002", "id": 793738, "description": "", "link": "https://www.fx168news.com/express/fastnews/793738", "pub_date": "2024-10-24 20:59:11"}, {"title": "\u636e\u6b27\u6d32\u4fe1\u7528\u8bc4\u7ea7\u673a\u6784Scope Ratings\u6700\u65b0\u5206\u6790\uff0c\u7f8e\u56fd\u8d22\u653f\u8d64\u5b57\u7684\u589e\u957f\u8d8b\u52bf\u6b63\u9010\u6e10\u6210\u4e3a\u5e02\u573a\u5173\u6ce8\u7684\u7126\u70b9\u3002", "id": 793742, "description": "", "link": "https://www.fx168news.com/express/fastnews/793742", "pub_date": "2024-10-24 21:00:17"}, {"title": "\u3010\u534f\u521b\u6570\u636e\u5b50\u516c\u53f8\u7b7e\u8ba2\u5de8\u989dGPU\u670d\u52a1\u5668\u91c7\u8d2d\u5408\u540c\u301110\u670824\u65e5\uff0c\u534f\u521b\u6570\u636e\u53d1\u5e03\u516c\u544a\u79f0\uff0c\u5176\u5b50\u516c\u53f8\u5e7f\u5dde\u5965\u4f73\u8f6f\u4ef6\u6280\u672f\u6709\u9650\u516c\u53f8\u4e0e\u4e0a\u6d77\u57df\u5141\u4fe1\u606f\u6280\u672f\u6709\u9650\u516c\u53f8\u7b7e\u8ba2\u4e86GPU\u670d\u52a1\u5668\u91c7\u8d2d\u6846\u67b6\u5408\u540c\u3002\u6b64\u6b21\u91c7\u8d2d\u65e8\u5728\u652f\u6301\u516c\u53f8\u5efa\u8bbe\u5927\u578b\u7b97\u529b\u670d\u52a1\u96c6\u7fa4\uff0c\u9884\u8ba1\u91c7\u8d2d\u603b\u989d\u4e0d\u8d85\u8fc79\u4ebf\u5143\u4eba\u6c11\u5e01\u3002\u5408\u540c\u6d89\u53ca\u7684\u4ea7\u54c1\u5305\u62ecH20NVLINK\u578bAIGPU\u670d\u52a1\u5668\u3002\u8fd9\u4e00\u5408\u4f5c\u5c06\u52a9\u529b\u534f\u521b\u6570\u636e\u7684\u4e91\u670d\u52a1\u4e1a\u52a1\u8fdb\u4e00\u6b65\u53d1\u5c55\u3002", "id": 793726, "description": "", "link": "https://www.fx168news.com/express/fastnews/793726", "pub_date": "2024-10-24 20:54:11"}, {"title": "\u3010\u4e34\u8fd1\u7f8e\u56fd\u5927\u9009\uff0c\u5bf9\u51b2\u6b27\u5143\u6210\u672c\u5347\u81f37\u5e74\u9ad8\u70b9\u301110\u670824\u65e5\uff0c\u968f\u7740\u7f8e\u56fd\u603b\u7edf\u9009\u4e3e\u7684\u4e34\u8fd1\uff0c\u5bf9\u51b2\u6b27\u5143\u7684\u6210\u672c\u8fbe\u5230\u4e862017\u5e74\u4ee5\u6765\u7684\u6700\u9ad8\u70b9\u3002\u81ea2017\u5e74\u6cd5\u56fd\u5927\u9009\u5f15\u53d1\u7684\u5e02\u573a\u52a8\u8361\u4ee5\u6765\uff0c\u5bf9\u51b2\u6b27\u5143\u7684\u6210\u672c\u4ece\u672a\u5982\u6b64\u4e4b\u9ad8\uff0c\u8fd9\u5f15\u53d1\u4e86\u5e02\u573a\u5bf9\u6b27\u5143\u7a33\u5b9a\u6027\u7684\u62c5\u5fe7\u3002\u76f8\u5bf9\u6ea2\u4ef7\u82e5\u4e3a\u6b63\u503c\uff0c\u5219\u610f\u5473\u7740\u5bf9\u51b2\u6210\u672c\u88ab\u9ad8\u4f30\u3002\u6295\u8d44\u8005\u6b63\u5728\u5bfb\u6c42\u907f\u9669\u8d44\u4ea7\uff0c\u56e0\u4e3a\u6b27\u6d32\u548c\u7f8e\u56fd\u5728\u964d\u606f\u6b65\u4f10\u4e0a\u7684\u4e0d\u540c\u3002\u6b27\u5143\u533a\u7ecf\u6d4e\u589e\u957f\u653e\u7f13\uff0c\u5e02\u573a\u9884\u671f\u6b27\u6d32\u592e\u884c\u53ef\u80fd\u4f1a\u5927\u5e45\u964d\u606f\uff0c\u540c\u65f6\u6295\u8d44\u8005\u9884\u8ba1\u7279\u6717\u666e\u5f53\u9009\u53ef\u80fd\u4f1a\u5f15\u53d1\u901a\u80c0\u4e0a\u5347\uff0c\u8fdb\u800c\u4fc3\u4f7f\u7f8e\u8054\u50a8\u52a0\u606f\uff0c\u63a8\u52a8\u7f8e\u5143\u5347\u503c\u3002\u6b27\u5143\u7684\u9690\u542b\u6ce2\u52a8\u7387\u56e0\u6b64\u521b\u4e0b\u81ea\u6b27\u6d32\u4e3b\u6743\u503a\u52a1\u5371\u673a\u4ee5\u6765\u7684\u7b2c\u516b\u5927\u5355\u65e5\u6da8\u5e45\u3002\u6839\u636e\u7f8e\u56fd\u5b58\u7ba1\u4fe1\u6258\u53ca\u6e05\u7b97\u516c\u53f8\u7684\u6570\u636e\uff0c\u5e02\u573a\u9884\u6d4b\u82e5\u7f8e\u5143\u7ee7\u7eed\u8d70\u5f3a\uff0c\u6b27\u5143\u5151\u7f8e\u5143\u53ef\u80fd\u8dcc\u81f31.05\uff0c\u800c\u4e00\u4e9b\u5206\u6790\u5e08\u8ba4\u4e3a\u8be5\u8d27\u5e01\u5bf9\u53ef\u80fd\u8fdb\u4e00\u6b65\u8dcc\u81f3\u5e73\u4ef7\u6c34\u5e73\u3002", "id": 793727, "description": "", "link": "https://www.fx168news.com/express/fastnews/793727", "pub_date": "2024-10-24 20:54:29"}, {"title": "\u5df4\u897f\u4e2d\u592e\u94f6\u884c\u8d1f\u8d23\u7ecf\u6d4e\u653f\u7b56\u7684\u5b98\u5458Guillen\u9884\u6d4b\uff0c\u52302025\u5e74\u7684\u67d0\u4e2a\u65f6\u523b\uff0c\u4ea7\u51fa\u7f3a\u53e3\u5c06\u8fbe\u5230\u5e73\u8861\uff0c\u800c\u57282026\u5e74\u7684\u65e9\u671f\u9636\u6bb5\uff0c\u8be5\u7f3a\u53e3\u5c06\u5f00\u59cb\u51fa\u73b0\u8d1f\u503c\u3002", "id": 793728, "description": "", "link": "https://www.fx168news.com/express/fastnews/793728", "pub_date": "2024-10-24 20:55:11"}, {"title": "\u6b27\u6d32\u4e2d\u592e\u94f6\u884c\u7684\u7ba1\u7406\u59d4\u5458\u4f1a\u6210\u5458\u5185\u683c\u5c14\u8b66\u544a\u79f0\uff0c\u5f81\u6536\u5173\u7a0e\u53ef\u80fd\u4f1a\u5f15\u53d1\u4e25\u91cd\u7684\u8d1f\u9762\u6548\u5e94\u3002", "id": 793716, "description": "", "link": "https://www.fx168news.com/express/fastnews/793716", "pub_date": "2024-10-24 20:49:20"}]}