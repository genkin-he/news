62ff\u9a6c\u578b\u8239\u53ea\u9700\u6c42\u4e0b\u964d\u3002\u8be5\u6307\u6570\u4e0b\u8dcc30\u70b9\uff0c\u964d\u81f31546\u70b9\uff0c\u521b\u4e0b\u516b\u4e2a\u6708\u6700\u4f4e\u3002\u6d77\u5cac\u578b\u8239\u8fd0\u4ef7\u6307\u6570\u4e0b\u964d85\u70b9\uff0c\u62a52191\u70b9\uff0c\u65e5\u5747\u6536\u76ca\u51cf\u5c11701\u7f8e\u5143\uff0c\u81f318174\u7f8e\u5143\u3002\u5df4\u62ff\u9a6c\u578b\u8239\u8fd0\u4ef7\u6307\u6570\u4e0b\u6ed17\u70b9\uff0c\u81f31278\u70b9\uff0c\u65e5\u5747\u6536\u76ca\u51cf\u5c1160\u7f8e\u5143\uff0c\u81f311502\u7f8e\u5143\u3002\u8d85\u7075\u4fbf\u578b\u6563\u8d27\u8239\u8fd0\u4ef7\u6307\u6570\u4fdd\u6301\u4e0d\u53d8\uff0c\u62a51250\u70b9\u3002", "id": 789766, "description": "\u3010\u6ce2\u7f57\u7684\u6d77\u5e72\u6563\u8d27\u6307\u6570\u964d\u81f3\u516b\u4e2a\u6708\u65b0\u4f4e\u301110\u670821\u65e5\uff0c\u6ce2\u7f57\u7684\u6d77\u5e72\u6563\u8d27\u6307\u6570\u8dcc\u81f32\u6708\u521d\u4ee5\u6765\u7684\u6700\u4f4e\u70b9\uff0c\u4e3b\u8981\u7531\u4e8e\u6d77\u5cac\u578b\u548c\u5df4\u62ff\u9a6c\u578b\u8239\u53ea\u9700\u6c42\u4e0b\u964d\u3002\u8be5\u6307\u6570\u4e0b\u8dcc30\u70b9\uff0c\u964d\u81f31546\u70b9\uff0c\u521b\u4e0b\u516b\u4e2a\u6708\u6700\u4f4e\u3002\u6d77\u5cac\u578b\u8239\u8fd0\u4ef7\u6307\u6570\u4e0b\u964d85\u70b9\uff0c\u62a52191\u70b9\uff0c\u65e5\u5747\u6536\u76ca\u51cf\u5c11701\u7f8e\u5143\uff0c\u81f318174\u7f8e\u5143\u3002\u5df4\u62ff\u9a6c\u578b\u8239\u8fd0\u4ef7\u6307\u6570\u4e0b\u6ed17\u70b9\uff0c\u81f31278\u70b9\uff0c\u65e5\u5747\u6536\u76ca\u51cf\u5c1160\u7f8e\u5143\uff0c\u81f311502\u7f8e\u5143\u3002\u8d85\u7075\u4fbf\u578b\u6563\u8d27\u8239\u8fd0\u4ef7\u6307\u6570\u4fdd\u6301\u4e0d\u53d8\uff0c\u62a51250\u70b9\u3002", "link": "https://www.fx168news.com/express/fastnews/789766", "pub_date": "2024-10-21 22:08:22"}]}