\u7684\u91cd\u8981\u6027\uff0c\u4e24\u5bb6\u516c\u53f8\u5747\u8058\u8bf7\u4e86\u6295\u8d44\u94f6\u884c\u63d0\u4f9b\u4e13\u4e1a\u54a8\u8be2\u3002\u5fae\u8f6f\u9009\u62e9\u4e86\u6469\u6839\u58eb\u4e39\u5229\uff0c\u800cOpenAI\u5219\u4e0e\u9ad8\u76db\u5408\u4f5c\u3002\u9664\u4e86\u786e\u5b9a\u5fae\u8f6f\u5728\u91cd\u7ec4\u540e\u6240\u5360\u80a1\u4efd\u6bd4\u4f8b\uff0c\u8fd8\u9700\u660e\u786e\u5fae\u8f6f\u5c06\u83b7\u5f97\u7684\u6cbb\u7406\u6743\u9650\u3002", "id": 787794, "description": "\u3010OpenAI\u548c\u5fae\u8f6f\u5c31\u80a1\u6743\u8f6c\u6362\u8fdb\u884c\u6df1\u5165\u8ba8\u8bba\u3011\u6700\u65b0\u62a5\u9053\u6307\u51fa\uff0cOpenAI\u4e0e\u5fae\u8f6f\u6b63\u5728\u5c31\u4e00\u9879\u521b\u65b0\u8bae\u9898\u8fdb\u884c\u9ad8\u98ce\u9669\u5546\u8c08\uff1a\u5982\u4f55\u5c06\u5bf9\u4e00\u5bb6\u975e\u76c8\u5229\u673a\u6784\u8fd1140\u4ebf\u7f8e\u5143\u7684\u6295\u8d44\u8f6c\u53d8\u4e3a\u5bf9\u4e00\u5bb6\u76c8\u5229\u4f01\u4e1a\u7684\u80a1\u4efd\u3002OpenAI\u6700\u8fd1\u5b8c\u6210\u4e86\u4e00\u8f6e\u4f30\u503c\u9ad8\u8fbe1570\u4ebf\u7f8e\u5143\u7684\u878d\u8d44\uff0c\u6807\u5fd7\u7740\u5176\u4ece\u975e\u76c8\u5229\u7ec4\u7ec7\u5411\u76c8\u5229\u516c\u53f8\u7684\u8f6c\u53d8\u3002\u5728\u8fd9\u4e00\u8f6c\u578b\u8fc7\u7a0b\u4e2d\uff0c\u80a1\u6743\u5206\u914d\u95ee\u9898\u6210\u4e3a\u5176\u9762\u4e34\u7684\u4e3b\u8981\u6311\u6218\u3002\u5fae\u8f6f\u4f5c\u4e3aOpenAI\u7684\u4e3b\u8981\u6295\u8d44\u8005\uff0c\u6709\u671b\u83b7\u5f97\u8be5\u516c\u53f8\u7684\u5927\u91cf\u80a1\u4efd\u3002\u9274\u4e8e\u8c08\u5224\u7ed3\u679c\u5bf9\u53cc\u65b9\u7684\u91cd\u8981\u6027\uff0c\u4e24\u5bb6\u516c\u53f8\u5747\u8058\u8bf7\u4e86\u6295\u8d44\u94f6\u884c\u63d0\u4f9b\u4e13\u4e1a\u54a8\u8be2\u3002\u5fae\u8f6f\u9009\u62e9\u4e86\u6469\u6839\u58eb\u4e39\u5229\uff0c\u800cOpenAI\u5219\u4e0e\u9ad8\u76db\u5408\u4f5c\u3002\u9664\u4e86\u786e\u5b9a\u5fae\u8f6f\u5728\u91cd\u7ec4\u540e\u6240\u5360\u80a1\u4efd\u6bd4\u4f8b\uff0c\u8fd8\u9700\u660e\u786e\u5fae\u8f6f\u5c06\u83b7\u5f97\u7684\u6cbb\u7406\u6743\u9650\u30