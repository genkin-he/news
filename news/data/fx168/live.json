{"data": [{"title": "\u767d\u4fc4\u7f57\u65af\u9886\u5bfc\u4eba\u5362\u5361\u7533\u79d1\u5ba3\u5e03\uff0c\u8be5\u56fd\u5df2\u505a\u597d\u5145\u5206\u51c6\u5907\uff0c\u4ee5\u52a0\u5165\u91d1\u7816\u56fd\u5bb6\u5408\u4f5c\u673a\u5236\u3002", "id": 793551, "description": "", "link": "https://www.fx168news.com/express/fastnews/793551", "pub_date": "2024-10-24 19:49:09"}, {"title": "\u7f8e\u56fd9\u6708\u4efd\u7684\u5efa\u7b51\u8bb8\u53ef\u5e74\u5316\u7387\u7531\u539f\u5148\u7684-2.9%\u8c03\u6574\u4e3a-3.1%\uff0c\u76f8\u5e94\u7684\u5e74\u5316\u8bb8\u53ef\u6570\u91cf\u4e5f\u4ece142.8\u4e07\u5957\u8c03\u6574\u4e3a142.5\u4e07\u5957\u3002", "id": 793552, "description": "", "link": "https://www.fx168news.com/express/fastnews/793552", "pub_date": "2024-10-24 19:50:01"}, {"title": "\u4f0a\u62c9\u514b\u80fd\u6e90\u90e8\u95e8\u5ba3\u5e03\uff0c\u8be5\u56fd\u57289\u6708\u4efd\u7684\u77f3\u6cb9\u65e5\u5747\u51fa\u53e3\u91cf\u8fbe\u5230\u4e86331\u4e07\u6876\u3002", "id": 793547, "description": "", "link": "https://www.fx168news.com/express/fastnews/793547", "pub_date": "2024-10-24 19:43:01"}, {"title": "\u6807\u666e\u5168\u7403\u5206\u6790\u6307\u51fa\uff0c\u6301\u7eed\u7684\u7f62\u5de5\u53ef\u80fd\u4f1a\u963b\u788d\u6ce2\u97f3\u516c\u53f8\u7684\u590d\u82cf\u8fdb\u7a0b\uff0c\u5e76\u5bf9\u5176\u8d22\u52a1\u72b6\u51b5\u53ca\u4fe1\u7528\u8bc4\u7ea7\u9020\u6210\u989d\u5916\u8d1f\u62c5\u3002\u82e5\u7f62\u5de5\u7684\u6839\u6e90\u5728\u4e8e\u517b\u8001\u91d1\u95ee\u9898\u7684\u89e3\u51b3\uff0c\u90a3\u4e48\u62d2\u7edd\u76f8\u5173\u63d0\u8bae\u53ef\u80fd\u4f1a\u52a0\u5927\u957f\u671f\u7f62\u5de5\u7684\u98ce\u9669\u3002\u9274\u4e8e\u6210\u672c\u65b9\u9762\u7684\u8003\u91cf\uff0c\u6ce2\u97f3\u516c\u53f8\u53ef\u80fd\u4e0d\u4f1a\u63a5\u53d7\u6062\u590d\u517b\u8001\u91d1\u7684\u8981\u6c42\u3002", "id": 793548, "description": "", "link": "https://www.fx168news.com/express/fastnews/793548", "pub_date": "2024-10-24 19:43:41"}, {"title": "\u636e\u4ee5\u8272\u5217\u56fd\u9632\u519b\u5ba3\u5e03\uff0c\u4ed6\u4eec\u6210\u529f\u6467\u6bc1\u4e86\u4f4d\u4e8e\u52a0\u6c99\u5730\u5e26\u52aa\u585e\u62c9\u7279\u5730\u533a\u7684\u4e00\u4e2a\u54c8\u9a6c\u65af\u7684\u6307\u6325\u4e0e\u63a7\u5236\u4e2d\u5fc3\uff0c\u8be5\u4e2d\u5fc3\u66fe\u88ab\u7528\u4f5c\u5b66\u6821\u7684\u5efa\u7b51\u3002", "id": 793549, "description": "", "link": "https://www.fx168news.com/express/fastnews/793549", "pub_date": "2024-10-24 19:45:10"}, {"title": "\u3010ING\uff1a\u97e9\u56fd\u7b2c\u4e09\u5b63\u5ea6\u7ecf\u6d4e\u52c9\u5f3a\u8eb2\u8fc7\u8870\u9000\uff0c\u592e\u884c\u964d\u606f\u6301\u8c28\u614e\u6001\u5ea6\u3011\u636e10\u670824\u65e5\u7684\u62a5\u9053\uff0c\u8377\u5170\u56fd\u9645\u96c6\u56e2\uff08ING\uff09\u7684\u5206\u6790\u5e08Min Joo Kang\u6307\u51fa\uff0c\u97e9\u56fd\u7ecf\u6d4e\u5728\u7b2c\u4e09\u5b63\u5ea6\u4ec5\u4ee50.1%\u7684\u5fae\u5c0f\u73af\u6bd4\u589e\u957f\u52c9\u5f3a\u907f\u514d\u4e86\u6280\u672f\u6027\u8870\u9000\uff0c\u8fd9\u4e00\u589e\u957f\u5e45\u5ea6\u672a\u8fbe\u5230\u5e02\u573a\u9884\u671f\u3002\u5979\u63d0\u5230\uff0c\u97e9\u56fd\u592e\u884c\u57282022\u5e7410\u6708\u5b9e\u65bd\u4e86\u8f83\u4e3a\u6fc0\u8fdb\u7684\u964d\u606f\u653f\u7b56\uff0c\u5e76\u4e14\u5bf9\u4e8e\u672a\u6765\u8fdb\u4e00\u6b65\u964d\u606f\u7684\u6697\u793a\u6301\u8c28\u614e\u7acb\u573a\u3002\u5c3d\u7ba1\u5982\u6b64\uff0c\u7531\u4e8eGDP\u589e\u957f\u672a\u8fbe\u9884\u671f\uff0c\u592e\u884c\u5bf9\u7ecf\u6d4e\u653e\u7f13\u7684\u62c5\u5fe7\u53ef\u80fd\u4f1a\u589e\u52a0\u3002ING\u9884\u8ba1\u97e9\u56fd\u592e\u884c\u572811\u6708\u4e0d\u4f1a\u964d\u606f\uff0c\u4f46\u53ef\u80fd\u4f1a\u91c7\u53d6\u66f4\u6e29\u548c\u7684\u653f\u7b56\u7acb\u573a\u3002\u6b64\u5916\uff0c\u8003\u8651\u5230\u901a\u80c0\u7387\u9884\u8ba1\u5728\u4e00\u6bb5\u65f6\u95f4\u5185\u5c06\u4fdd\u6301\u57282%\u4ee5\u4e0b\uff0c\u653f\u7b56\u5e94\u66f4\u591a\u5730\u5173\u6ce8\u652f\u6301\u7ecf\u6d4e\u589e\u957f\u3002", "id": 793542, "description": "", "link": "https://www.fx168news.com/express/fastnews/793542", "pub_date": "2024-10-24 19:30:50"}, {"title": "\u3010\u5a01\u58eb\u987f\uff1a\u8463\u4e8b\u957f\u8306\u5b87\u5fe0\u7ed3\u675f\u7559\u7f6e\u72b6\u6001\u301110\u670824\u65e5\uff0c\u5a01\u58eb\u987f\u53d1\u5e03\u516c\u544a\u79f0\uff0c\u516c\u53f8\u8463\u4e8b\u957f\u517c\u5b9e\u9645\u63a7\u5236\u4eba\u8306\u5b87\u5fe0\u5148\u751f\u7684\u7559\u7f6e\u72b6\u6001\u5df2\u4e8e2024\u5e7410\u670823\u65e5\u7ed3\u675f\u3002\u76ee\u524d\uff0c\u8306\u5b87\u5fe0\u5148\u751f\u5df2\u6062\u590d\u5176\u8463\u4e8b\u957f\u804c\u52a1\uff0c\u6bb7\u519b\u666e\u5148\u751f\u4e0d\u518d\u62c5\u4efb\u4ee3\u7406\u804c\u8d23\u3002", "id": 793540, "description": "", "link": "https://www.fx168news.com/express/fastnews/793540", "pub_date": "2024-10-24 19:29:10"}, {"title": "\u7f8e\u56fd\u94f6\u884c\u7684\u5168\u7403\u7814\u7a76\u90e8\u95e8\u6700\u8fd1\u8c03\u6574\u4e86\u5bf9\u7279\u65af\u62c9\u516c\u53f8\u80a1\u7968\u7684\u76ee\u6807\u4ef7\u683c\uff0c\u4ece\u4e4b\u524d\u7684255\u7f8e\u5143\u63d0\u5347\u81f3265\u7f8e\u5143\u3002", "id": 793541, "description": "", "link": "https://www.fx168news.com/express/fastnews/793541", "pub_date": "2024-10-24 19:29:25"}, {"title": "\u3010\u65e5\u672c\u592e\u884c\uff1a\u65e5\u672c\u80a1\u5e02\u4ea4\u6613\u6d3b\u8dc3\uff0c\u4f30\u503c\u6c34\u5e73\u672a\u8fbe\u8fc7\u70ed\uff0c\u5173\u6ce8\u8d44\u4ea7\u4ef7\u683c\u8d70\u52bf\u301110\u670824\u65e5\uff0c\u65e5\u672c\u592e\u884c\u5728\u6700\u65b0\u53d1\u5e03\u7684\u300a\u91d1\u878d\u4f53\u7cfb\u62a5\u544a\u300b\u4e2d\u6307\u51fa\uff0c2023\u5e74\u65e5\u672c\u80a1\u5e02\u7684\u4ea4\u6613\u6d3b\u8dc3\u5ea6\u6301\u7eed\u8d85\u8fc7\u5386\u53f2\u5e73\u5747\u6c34\u5e73\uff0c\u4f46\u80a1\u7968\u4f30\u503c\u5e76\u672a\u663e\u8457\u504f\u9ad8\u3002\u592e\u884c\u6307\u51fa\uff0c\u5e02\u76c8\u7387\u7ef4\u6301\u5728\u5386\u53f2\u5747\u503c\u9644\u8fd1\u3002\u540c\u65f6\uff0c\u65e5\u672c\u592e\u884c\u5f3a\u8c03\uff0c\u9274\u4e8e\u65e5\u672c\u94f6\u884c\u6301\u6709\u80a1\u7968\u5b58\u5728\u4e00\u5b9a\u5e02\u573a\u98ce\u9669\uff0c\u8d44\u4ea7\u4ef7\u683c\u7684\u53d8\u52a8\u8d8b\u52bf\u9700\u8981\u5bc6\u5207\u5173\u6ce8\u3002", "id": 793536, "description": "", "link": "https://www.fx168news.com/express/fastnews/793536", "pub_date": "2024-10-24 19:22:21"}, {"title": "\u8054\u5408\u56fd\u79d8\u4e66\u957f\u5b89\u4e1c\u5c3c\u5965\u00b7\u53e4\u7279\u96f7\u65af\u547c\u5401\uff0c\u5728\u52a0\u6c99\u5730\u5e26\u5fc5\u987b\u7acb\u5373\u5b9e\u73b0\u505c\u706b\uff0c\u5e76\u8981\u6c42\u65e0\u6761\u4ef6\u91ca\u653e\u6240\u6709\u88ab\u6263\u62bc\u7684\u4eba\u8d28\u3002", "id": 793538, "description": "", "link": "https://www.fx168news.com/express/fastnews/793538", "pub_date": "2024-10-24 19:23:45"}]}