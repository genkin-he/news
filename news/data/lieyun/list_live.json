{"data": [{"title": "\u53ef\u70751.6\u6a21\u578b\u4e0a\u7ebf \u6587\u672c\u54cd\u5e94\u5ea6\u3001\u8fd0\u52a8\u5408\u7406\u6027\u7b49\u663e\u8457\u63d0\u5347", "description": "12\u670819\u65e5\uff0c\u5feb\u624b\u53ef\u7075AI\u5ba3\u5e03\u57fa\u5ea7\u6a21\u578b\u518d\u5347\u7ea7\uff0c\u89c6\u9891\u751f\u6210\u63a8\u51fa\u53ef\u70751.6\u6a21\u578b\uff0c\u6548\u679c\u5927\u5e45\u63d0\u5347\u3002\u636e\u6089\uff0c1.6\u6a21\u578b\u5728\u6587\u672c\u54cd\u5e94\u5ea6\u4e0a\u63d0\u5347\u660e\u663e\uff0c\u5bf9\u8fd0\u52a8\u3001\u65f6\u5e8f\u7c7b\u52a8\u4f5c\u3001\u8fd0\u955c\u7b49\u6587\u5b57\u63cf\u8ff0\u54cd\u5e94\u66f4\u597d\uff1b\u52a8\u6001\u8d28\u91cf\u8fdb\u4e00\u6b65\u589e\u5f3a\uff1a\u8fd0\u52a8\u66f4\u52a0\u5408\u7406\uff0c\u4eba\u7269\u8868\u60c5\u66f4\u81ea\u7136\uff1b\u540c\u65f6\uff0c1.6\u6a21\u578b\u753b\u9762\u8d28\u91cf\u4e5f\u518d\u6b21\u8fdb\u5316\uff1a\u8272\u5f69\u3001\u5149\u5f71\u3001\u7ec6\u8282\u8868\u73b0\u5747\u660e\u663e\u63d0\u5347\u3002\u6570\u636e\u663e\u793a\uff0c\u53ef\u7075AI\u53d1\u5e03\u534a\u5e74\u6765\uff0c\u5df2\u62e5\u6709\u8d85\u8fc7600\u4e07\u7528\u6237\uff0c\u7d2f\u8ba1\u751f\u6210\u8d856500\u4e07\u4e2a\u89c6\u9891\u548c\u8d851.75\u4ebf\u5f20\u56fe\u7247\u3002", "link": "https://www.lieyunpro.com/news/116916"}, {"title": "\u534e\u4e3a\u7533\u8bf7\u591a\u679aMate70\u7cfb\u5217\u914d\u8272\u5546\u6807", "description": "\u5929\u773c\u67e5\u77e5\u8bc6\u4ea7\u6743\u4fe1\u606f\u663e\u793a\uff0c\u8fd1\u65e5\uff0c\u534e\u4e3a\u6280\u672f\u6709\u9650\u516c\u53f8\u7533\u8bf7\u6ce8\u518c\u201c\u58a8\u97f5\u9ed1\u201d\u201c\u91d1\u4e1d\u94f6\u9526\u201d\u201c\u98de\u5929\u9752\u201d\u201c\u7693\u767d\u201d\u201c\u7fbd\u8863\u767d\u201d\u5546\u6807\uff0c\u56fd\u9645\u5206\u7c7b\u4e3a\u79d1\u5b66\u4eea\u5668\uff0c\u5f53\u524d\u5546\u6807\u72b6\u6001\u5747\u4e3a\u7b49\u5f85\u5b9e\u8d28\u5ba1\u67e5\u3002\u636e\u6089\uff0c\u58a8\u97f5\u9ed1\u3001\u7fbd\u8863\u767d\u3001\u91d1\u4e1d\u94f6\u9526\u3001\u98de\u5929\u9752\u5747\u4e3a\u534e\u4e3aMate70 Pro+\u914d\u8272\uff0c\u5176\u4e2d\uff0c\u91d1\u4e1d\u94f6\u9526\u914d\u8272\u66fe\u4e00\u5ea6\u5f15\u53d1\u70ed\u8bae\u3002", "link": "https://www.lieyunpro.com/news/116914"}, {"title": "\u5de8\u5b50\u751f\u7269\u589e\u8d44\u81f36.9\u4ebf", "description": "\u5929\u773c\u67e5App\u663e\u793a\uff0c\u8fd1\u65e5\uff0c\u5de8\u5b50\u751f\u7269\uff08HK.02367\uff09\u53d1\u751f\u5de5\u5546\u53d8\u66f4\uff0c\u6ce8\u518c\u8d44\u672c\u7531\u7ea63.3\u4ebf\u4eba\u6c11\u5e01\u589e\u81f3\u7ea66.9\u4ebf\u4eba\u6c11\u5e01\uff0c\u589e\u5e45\u7ea6110%\u3002\u897f\u5b89\u5de8\u5b50\u751f\u7269\u57fa\u56e0\u6280\u672f\u80a1\u4efd\u6709\u9650\u516c\u53f8\u6210\u7acb\u4e8e2001\u5e749\u6708\uff0c\u6cd5\u5b9a\u4ee3\u8868\u4eba\u4e3a\u4e25\u5efa\u4e9a\uff0c\u7ecf\u8425\u8303\u56f4\u542b\u7b2c\u4e00\u7c7b\u533b\u7597\u5668\u68b0\u751f\u4ea7\u3001\u751f\u7269\u57fa\u6750\u6599\u5236\u9020\u3001\u65e5\u7528\u5316\u5b66\u4ea7\u54c1\u5236\u9020\u3001\u5316\u5de5\u4ea7\u54c1\u751f\u4ea7\u3001\u7b2c\u4e00\u7c7b\u533b\u7597\u5668\u68b0\u9500\u552e\u3001\u7b2c\u4e8c\u7c7b\u533b\u7597\u5668\u68b0\u9500\u552e\u3001\u536b\u751f\u7528\u54c1\u548c\u4e00\u6b21\u6027\u4f7f\u7528\u533b\u7597\u7528\u54c1\u9500\u552e\u7b49\uff0c\u73b0\u7531\u8303\u4ee3\u5a23\u3001\u5e7f\u4e1c\u91d1\u8354\u6295\u8d44\u6709\u9650\u8d23\u4efb\u516c\u53f8\u3001\u4e2d\u6da6\u7ecf\u6d4e\u53d1\u5c55\u6709\u9650\u8d23\u4efb\u516c\u53f8\u7b49\u5171\u540c\u6301\u80a1\u3002", "link": "https://www.lieyunpro.com/news/116915"}, {"title": "\u97e9\u56fd\u4e09\u517b\u98df\u54c1\u62df\u6295\u7ea610\u4ebf\u5143\u5728\u534e\u5efa\u5382\u751f\u4ea7\u201c\u706b\u9e21\u9762\u201d", "description": "\u4ee5\u751f\u4ea7\u201c\u706b\u9e21\u9762\u201d\u800c\u95fb\u540d\u7684\u97e9\u56fd\u4e09\u517b\u98df\u54c1\u516c\u53f8\u5468\u56db\u8868\u793a\uff0c\u5c06\u6295\u8d442014\u4ebf\u97e9\u5143\uff08\u7ea6\u5408\u4eba\u6c11\u5e0110\u4ebf\u5143\uff09\uff0c\u4e8e2027\u5e74\u521d\u5728\u4e2d\u56fd\u5efa\u7acb\u9996\u5bb6\u6d77\u5916\u5de5\u5382\uff0c\u4ee5\u6ee1\u8db3\u5f53\u5730\u5bf9\u5176\u4ea7\u54c1\u4e0d\u65ad\u589e\u957f\u7684\u9700\u6c42\u3002\u8be5\u516c\u53f8\u53d1\u8a00\u4eba\u79f0\uff0c\u4e09\u517b\u8ba1\u5212\u660e\u5e74\u4e0a\u534a\u5e74\u5728\u65b0\u52a0\u5761\u5efa\u7acb\u4e00\u5bb6\u5b50\u516c\u53f8\uff0c\u5e76\u4e8e\u660e\u5e74\u5e74\u5e95\u5f00\u59cb\u5728\u4e2d\u56fd\u4e1c\u90e8\u6d59\u6c5f\u7701\u5609\u5174\u5e02\u5efa\u8bbe\u5de5\u5382\u3002", "link": "https://www.lieyunpro.com/news/116912"}, {"title": "\u70b9\u77f3\u822a\u7a7a\u5b8c\u6210\u6570\u5343\u4e07\u5143A\u8f6e\u878d\u8d44", "description": "\u8fd1\u65e5\uff0c\u70b9\u77f3\u822a\u7a7a\u5b8c\u6210\u6570\u5343\u4e07\u5143A\u8f6e\u878d\u8d44\uff0c\u672c\u8f6e\u878d\u8d44\u7531\u57fa\u77f3\u8d44\u672c\u9886\u6295\u3002\u636e\u6089\uff0c\u65b0\u4e00\u8f6e\u878d\u8d44\u7684\u5b8c\u6210\uff0c\u5c06\u52a9\u529b\u4f01\u4e1a\u52a0\u901f\u4ea7\u54c1\u7814\u53d1\uff0c\u6269\u5927\u4ea7\u80fd\u3002\u70b9\u77f3\u822a\u7a7a\u4e13\u6ce8\u4e8e\u5c0f\u578b\u822a\u7a7a\u53d1\u52a8\u673a\u7814\u53d1\u4e0e\u4ea7\u4e1a\u5316\uff0c\u4e3b\u8981\u4ece\u4e8b\u6c11\u7528\u822a\u7a7a\u5668\u53ca\u5176\u96f6\u90e8\u4ef6\u7684\u7814\u53d1\u3001\u751f\u4ea7\u548c\u9500\u552e\uff0c\u5e76\u63d0\u4f9b\u5355\u8f74\u6da1\u55b7\u53d1\u52a8\u673a\u3001\u87ba\u65cb\u6868\u7b49\u4ea7\u54c1\uff0c\u81f4\u529b\u4e8e\u4e3a\u884c\u4e1a\u7528\u6237\u63d0\u4f9b\u76f8\u5173\u7684\u822a\u7a7a\u88c5\u5907\u53ca\u670d\u52a1\u3002", "link": "https://www.lieyunpro.com/news/116911"}, {"title": "\u8682\u8681\u96c6\u56e2\uff1a\u76ee\u524d\u6ca1\u6709\u4e0a\u5e02\u8ba1\u5212\uff0c\u66f4\u4e0d\u5b58\u5728\u6240\u8c13\u201c\u501f\u58f3\u4e0a\u5e02\u201d", "description": "12\u670819\u65e5\uff0c\u8682\u8681\u96c6\u56e2\u5728\u5b98\u65b9\u5fae\u535a\u6f84\u6e05\uff1a\u6700\u8fd1\u5173\u6ce8\u5230\u6709\u673a\u6784\u5728\u591a\u4e2a\u5e73\u53f0\u5ba3\u79f0\u201c\u8682\u8681\u96c6\u56e2\u5373\u5c06\u501f\u58f3\u4e0a\u5e02\uff0c\u5176\u638c\u63e1\u5185\u90e8\u4fe1\u606f\u201d\uff0c\u5e76\u4ee5\u6b64\u8bf1\u5bfc\u7f51\u53cb\u52a0\u7fa4\u83b7\u5f97\u63a8\u8350\u80a1\u7968\u4fe1\u606f\u3002\u8682\u8681\u96c6\u56e2\u76ee\u524d\u6ca1\u6709\u4e0a\u5e02\u8ba1\u5212\uff0c\u66f4\u4e0d\u5b58\u5728\u6240\u8c13\u7684\u201c\u501f\u58f3\u4e0a\u5e02\u201d\u3002", "link": "https://www.lieyunpro.com/news/116910"}, {"title": "\u8349\u59ec\u96c6\u56e2\u9999\u6e2fIPO\u9762\u5411\u6563\u6237\u90e8\u5206\u83b7\u5f97\u7ea66084\u500d\u8ba4\u8d2d", "description": "\u636e\u6e2f\u4ea4\u6240\uff0c\u6309\u7167\u8d85\u989d\u8ba4\u8d2d\u60c5\u51b5\u4e0b\u7684\u56de\u62e8\u673a\u5236\uff0c\u8349\u59ec\u96c6\u56e2\u5c06\u5206\u914d\u7ed9\u9999\u6e2f\u6563\u6237\u6295\u8d44\u8005\u7684IPO\u80a1\u4efd\u6570\u91cf\u83b7\u5f97\u7ea66084\u500d\u8ba4\u8d2d\uff0c\u4ece333\u4e07\u80a1\u589e\u52a0\u5230\u7ea61670\u4e07\u80a1\uff0c\u5206\u914d\u7ed9\u673a\u6784\u6295\u8d44\u8005\u7684\u80a1\u7968\u6570\u91cf\u4ece\u6700\u521d\u76843000\u4e07\u80a1\u51cf\u5c11\u52301670\u4e07\u80a1\uff0c\u56fd\u9645\u53d1\u552e\u83b7\u5f971.79\u500d\u8ba4\u8d2d\u3002\u9999\u6e2fIPO\u5b9a\u4ef7\u4e3a\u6bcf\u80a13.75\u6e2f\u5143\uff0c\u4f4d\u4e8e\u6307\u5bfc\u533a\u95f4\u5e95\u90e8\uff0c\u53d1\u552e\u4ef7\u8303\u56f4\u4e3a\u6bcf\u80a13.75-4.15\u6e2f\u5143\u3002", "link": "https://www.lieyunpro.com/news/116908"}, {"title": "\u7f8e\u8054\u50a8\u5ba3\u5e03\u964d\u606f25\u4e2a\u57fa\u70b9", "description": "\u7f8e\u56fd\u8054\u90a6\u50a8\u5907\u59d4\u5458\u4f1a\u5f53\u5730\u65f6\u95f412\u670818\u65e5\u5ba3\u5e03\uff0c\u5c06\u8054\u90a6\u57fa\u91d1\u5229\u7387\u76ee\u6807\u533a\u95f4\u4e0b\u8c0325\u4e2a\u57fa\u70b9\u52304.25%\u81f34.50%\u4e4b\u95f4\uff0c\u7b26\u5408\u5e02\u573a\u666e\u904d\u9884\u671f\u3002\u7f8e\u8054\u50a8\u4e3b\u5e2d\u9c8d\u5a01\u5c14\u5f53\u5929\u5c31\u964d\u606f\u51b3\u5b9a\u53ec\u5f00\u65b0\u95fb\u53d1\u5e03\u4f1a\uff0c\u4ed6\u8868\u793a\uff0c\u7f8e\u8054\u50a8\u4eca\u540e\u8003\u8651\u8c03\u6574\u653f\u7b56\u5229\u7387\u65f6\u5e94\u8be5\u4f1a\u201c\u66f4\u52a0\u8c28\u614e\u201d\u3002\u9c8d\u5a01\u5c14\u79f0\uff0c12\u6708\u7684\u964d\u606f\u51b3\u5b9a\u66f4\u5177\u6709\u6311\u6218\u6027\uff0c\u4f46\u5374\u662f\u201c\u6b63\u786e\u7684\u51b3\u5b9a\u201d\u3002\u4ed6\u8868\u793a\uff0c2025\u5e74\u7f8e\u8054\u50a8\u662f\u5426\u964d\u606f\u5c06\u57fa\u4e8e\u672a\u6765\u7684\u6570\u636e\uff0c\u800c\u4e0d\u662f\u5f53\u524d\u7684\u9884\u6d4b\u7ed3\u679c\uff0c\u7f8e\u8054\u50a8\u5c06\u5728\u901a\u80c0\u6539\u5584\u540e\u518d\u8003\u8651\u8fdb\u4e00\u6b65\u964d\u606f\u3002", "link": "https://www.lieyunpro.com/news/116909"}, {"title": "\u4eca\u65e5\u8d44\u672c\u539f\u5408\u4f19\u4eba\u6234\u4e3d\u4e39\u52a0\u76df\u5c0f\u7ea2\u4e66\u4efb\u6218\u7565\u8d1f\u8d23\u4eba", "description": "\u636e\u665a\u70b9LatePost\u6d88\u606f\uff0c\u4eca\u65e5\u8d44\u672c\u539f\u5408\u4f19\u4eba\u6234\u4e3d\u4e39\u8fd1\u671f\u5df2\u52a0\u5165\u5c0f\u7ea2\u4e66\uff0c\u8d1f\u8d23\u6218\u7565\uff0c\u5411\u5c0f\u7ea2\u4e66\u6838\u5fc3\u7ba1\u7406\u5c42\u6c47\u62a5\u3002\u5728\u5979\u52a0\u5165\u524d\uff0c\u5c0f\u7ea2\u4e66\u4e0d\u540c\u6218\u7565\u65b9\u5411\u5404\u6709\u8d1f\u8d23\u4eba\uff0c\u73b0\u5728\u7edf\u4e00\u5411\u6234\u4e3d\u4e39\u6c47\u62a5\uff1b\u5c0f\u7ea2\u4e66\u540c\u65f6\u8ba1\u5212\u7ec4\u5efa\u6218\u7565\u6295\u8d44\u56e2\u961f\uff0c\u7531\u6234\u4e3d\u4e39\u8d1f\u8d23\uff0c\u4e3b\u8981\u6295\u8d44\u786c\u79d1\u6280\u8d5b\u9053\uff0c\u5c24\u5176\u662f AI \u5e94\u7528\uff1b\u5c0f\u7ea2\u4e66\u539f\u6295\u8d44\u56e2\u961f\u4e0d\u53d8\uff0c\u7ee7\u7eed\u505a\u8d22\u52a1\u6295\u8d44\u3002\u6234\u4e3d\u4e39\u6bd5\u4e1a\u4e8e\u5317\u4eac\u5927\u5b66\uff0c\u540e\u52a0\u5165\u767e\u5ea6\u4efb\u767e\u5ea6\u5730\u56fe\u4ea7\u54c1\u7ecf\u7406\uff1b2013 \u5e74-2015 \u5e74\uff0c\u5979\u5728\u54c8\u4f5b\u5546\u5b66\u9662\u653b\u8bfb MBA\uff0c\u6b64\u540e\uff0c\u6234\u4e3d\u4e39\u52a0\u5165\u7531 \u201c\u98ce\u6295\u5973\u738b\u201d \u5f90\u65b0\u521b\u529e\u7684\u4eca\u65e5\u8d44\u672c\uff0c\u4e8e 2022 \u5e74\u5347\u4efb\u4eca\u65e5\u8d44\u672c\u5408\u4f19\u4eba\u3002", "link": "https://www.lieyunpro.com/news/116907"}, {"title": "\u6709\u6d88\u606f\u79f0\u963f\u91cc\u201c\u901a\u4e49\u201d\u4ece\u963f\u91cc\u4e91\u5206\u62c6\uff0c\u5e76\u5165\u963f\u91cc\u667a\u80fd\u4fe1\u606f\u4e8b\u4e1a\u7fa4", "description": "12\u670818\u65e5\uff0c\u6709\u6d88\u606f\u79f0\uff0c\u963f\u91cc\u65d7\u4e0bAI\u5e94\u7528\u201c\u901a\u4e49\u201d\u8fd1\u671f\u6b63\u5f0f\u4ece\u963f\u91cc\u4e91\u5206\u62c6\uff0c\u5e76\u5165\u963f\u91cc\u667a\u80fd\u4fe1\u606f\u4e8b\u4e1a\u7fa4\u3002\u636e\u77e5\u60c5\u4eba\u58eb\u900f\u9732\uff0c\u6b64\u6b21\u8c03\u6574\u5305\u62ec\u901a\u4e49To C\u65b9\u5411\u7684\u4ea7\u54c1\u7ecf\u7406\uff0c\u4ee5\u53ca\u76f8\u5173\u7684\u5de5\u7a0b\u56e2\u961f\uff0c\u4e00\u5e76\u8c03\u6574\u81f3\u963f\u91cc\u667a\u80fd\u4fe1\u606f\u4e8b\u4e1a\u7fa4\u3002\u8c03\u6574\u540e\uff0c\u901a\u4e49PC\u53caApp\u56e2\u961f\u4e0e\u667a\u80fd\u641c\u7d22\u4ea7\u54c1\u201c\u5938\u514b\u201d\u5e73\u7ea7\uff0c\u539f\u6709\u7684\u901a\u4e49\u5b9e\u9a8c\u5ba4\uff0c\u4ecd\u7136\u7559\u5728\u963f\u91cc\u4e91\u4f53\u7cfb\u5185\u3002", "link": "https://www.lieyunpro.com/news/116906"}, {"title": "\u667a\u8c31\u5728\u73e0\u6d77\u6210\u7acb\u667a\u8c31\u9886\u822a\u79d1\u6280\u516c\u53f8\uff0c\u542b\u591a\u9879AI\u4e1a\u52a1", "description": "\u5929\u773c\u67e5App\u663e\u793a\uff0c\u8fd1\u65e5\uff0c\u73e0\u6d77\u667a\u8c31\u9886\u822a\u79d1\u6280\u6709\u9650\u516c\u53f8\u6210\u7acb\uff0c\u6cd5\u5b9a\u4ee3\u8868\u4eba\u4e3a\u5218\u5fb7\u5175\uff0c\u6ce8\u518c\u8d44\u672c500\u4e07\u4eba\u6c11\u5e01\uff0c\u7ecf\u8425\u8303\u56f4\u542b\u4eba\u5de5\u667a\u80fd\u57fa\u7840\u8f6f\u4ef6\u5f00\u53d1\u3001\u4eba\u5de5\u667a\u80fd\u5e94\u7528\u8f6f\u4ef6\u5f00\u53d1\u3001\u4eba\u5de5\u667a\u80fd\u53cc\u521b\u670d\u52a1\u5e73\u53f0\u3001\u6570\u636e\u5904\u7406\u548c\u5b58\u50a8\u652f\u6301\u670d\u52a1\u3001\u6570\u636e\u5904\u7406\u670d\u52a1\u3001\u4eba\u5de5\u667a\u80fd\u7406\u8bba\u4e0e\u7b97\u6cd5\u8f6f\u4ef6\u5f00\u53d1\u7b49\uff0c\u7531\u667a\u8c31AI\u5173\u8054\u516c\u53f8\u5317\u4eac\u667a\u8c31\u534e\u7ae0\u79d1\u6280\u6709\u9650\u516c\u53f8\u5168\u8d44\u6301\u80a1\u3002", "link": "https://www.lieyunpro.com/news/116905"}, {"title": "\u4e66\u7b54\u79d1\u6280\u5b8c\u6210\u8fd1\u5343\u4e07\u5143\u5929\u4f7f\u8f6e\u878d\u8d44", "description": "\u4e66\u7b54\u79d1\u6280\u5ba3\u5e03\u5b8c\u6210\u8fd1\u5343\u4e07\u5143\u5929\u4f7f\u8f6e\u878d\u8d44\uff0c\u7531\u6155\u534e\u79d1\u521b\u9886\u6295\uff0c\u540c\u6768\u57fa\u91d1\u548c\u4e0a\u6d77\u5170\u5c1a\u633a\u79c0\u79d1\u6280\u670d\u52a1\u80a1\u4efd\u6709\u9650\u516c\u53f8\uff08\u7b80\u79f0\u4e3a\u5170\u5c1a\u633a\u79c0\uff09\u8ddf\u6295\u3002\u4e66\u7b54\u79d1\u6280\u662f\u601d\u8def\u8fea\u8bca\u65ad\u65d7\u4e0b\u4e00\u4e2a\u521b\u65b0\u578b\u75c5\u7406AI\u5e73\u53f0\uff0c\u4e13\u6ce8\u4e8e\u4e3a\u4e34\u5e8a\u673a\u6784\u63d0\u4f9b\u533b\u5b66\u56fe\u50cfAI\u8bca\u65ad\u4ea7\u54c1\u548c\u6574\u4f53\u89e3\u51b3\u65b9\u6848\u3002\u5e73\u53f0\u7ed3\u5408\u4e86\u591a\u79cd\u6280\u672f\uff0c\u5305\u62ecNGS\u6d4b\u5e8f\u3001\u5916\u6ccc\u4f53\u6280\u672f\uff0c\u4ee5\u53ca\u5148\u8fdb\u7684\u6570\u5b57\u5316\u56fe\u50cfAI\u5904\u7406\u6280\u672f\uff0c\u81f4\u529b\u4e8e\u4e3a\u5e7f\u5927\u7684\u533b\u5b66\u5de5\u4f5c\u8005\u548c\u79d1\u7814\u5de5\u4f5c\u8005\u63d0\u4f9b\u667a\u80fd\u5316\u5168\u6d41\u7a0b\u75c5\u7406\u56fe\u50cf\u5206\u6790\u89e3\u51b3\u65b9\u6848\u3002\u5176\u65d7\u8230\u4ea7\u54c1APTime\u4f5c\u4e3a\u4e00\u6b3e\u9ad8\u6027\u4ef7\u6bd4\u7684\u75c5\u7406\u56fe\u50cfAI\u5206\u6790\u7cfb\u7edf\uff0c\u5728\u80bf\u7624\u3001\u514d\u75ab\u6027\u75be\u75c5\u3001\u5fc3\u8840\u7ba1\u3001\u795e\u7ecf\u7cfb\u7edf\u548c\u5185\u5206\u6ccc\u7b49\u591a\u4e2a\u533b\u5b66\u9886\u57df\u5f97\u5230\u4e86\u5e7f\u6cdb\u5e94\u7528\u3002\u4e3a\u4e34\u5e8a\u673a\u6784\u63d0\u4f9b\u533b\u5b66\u56fe\u50cfAI\u8bca\u65ad\u4ea7\u54c1\u548c\u6574\u4f53\u89e3\u51b3\u65b9\u6848\u3002", "link": "https://www.lieyunpro.com/news/116904"}, {"title": "\u8482\u84dd\u751f\u7269\u5b8c\u62109000\u4e07A\u8f6e\u878d\u8d44", "description": "\u8fd1\u65e5\uff0c\u91cd\u5e86\u8482\u84dd\u751f\u7269\u79d1\u6280\u6709\u9650\u516c\u53f8\uff08\u7b80\u79f0\u4e3a\u8482\u84dd\u751f\u7269\uff09\u5ba3\u5e03\u6210\u529f\u5b8c\u62109000\u4e07\u5143A\u8f6e\u878d\u8d44\uff0c\u7531\u56fd\u5185\u77e5\u540d\u6295\u8d44\u673a\u6784\u521b\u5bcc\u6295\u8d44\u72ec\u5bb6\u9886\u6295\uff0c\u65e8\u5728\u52a0\u901f\u516c\u53f8\u5728\u751f\u7269\u6280\u672f\u9886\u57df\u7684\u7814\u53d1\u548c\u5e02\u573a\u6269\u5c55\u3002\u8482\u84dd\u751f\u7269\u662f\u4e00\u5bb6\u536b\u751f\u4fdd\u5065\u53ca\u5316\u5986\u54c1\u7814\u53d1\u9500\u552e\u5546\u3002\u516c\u53f8\u4e13\u6ce8\u4e8e\u751f\u7269\u6280\u672f\u7814\u7a76\u3001\u5f00\u53d1\u4e0e\u5e94\u7528\uff0c\u4e3b\u8981\u4ece\u4e8b\u536b\u751f\u7528\u54c1\u3001\u517b\u751f\u4fdd\u5065\u670d\u52a1\u53ca\u5316\u5986\u54c1\u7684\u9500\u552e\u4e0e\u5f00\u53d1\u3002", "link": "https://www.lieyunpro.com/news/116903"}, {"title": "\u5927\u9ea6\u201c\u9177\u5c0f\u9ea6\u201d\u4e0e\u661f\u54c6\u5267\u573a\u8fbe\u6210\u6218\u7565\u5408\u4f5c\uff0c\u5c06\u8054\u5408\u8fd0\u84251000\uff0b\u7ec8\u7aef\u5f71\u9662\u5c0f\u5267\u573a", "description": "\u65e5\u524d\uff0c\u5927\u9ea6\u65d7\u4e0b\u4eb2\u5b50\u5382\u724c\u9177\u5c0f\u9ea6\u6210\u7acb\u6ee1\u4e00\u5e74\uff0c\u5ba3\u5e03\u4e0e\u661f\u54c6\u5267\u573a\u8fbe\u6210\u6218\u7565\u5408\u4f5c\uff0c\u53cc\u65b9\u5c06\u57fa\u4e8e\u5404\u81ea\u4f18\u52bf\u5408\u5236\u8054\u540d\u5267\u76ee\uff0c\u540c\u65f6\u56f4\u7ed5\u661f\u54c6\u5267\u573a\u65d7\u4e0b\u76841000+\u7ec8\u7aef\u5f71\u9662\u5c0f\u5267\u573a\uff0c\u5171\u540c\u8fd0\u8425\u5c0f\u7a7a\u95f4\u513f\u7ae5\u5267\u6f14\u51fa\u3002", "link": "https://www.lieyunpro.com/news/116902"}, {"title": "\u871c\u96ea\u51b0\u57ce\u6da8\u4ef7", "description": "12\u670816\u65e5\uff0c\u5e7f\u5dde\u591a\u5bb6\u871c\u96ea\u51b0\u57ce\u95e8\u5e97\u5728\u5c0f\u7a0b\u5e8f\u4e0a\u53d1\u5e03\u516c\u544a\u79f0\uff0c\u201c\u7efc\u5408\u95e8\u5e97\u7ecf\u8425\u60c5\u51b5\uff0c12\u670816\u65e5\u8d77\uff0c\u672c\u5e97\u5802\u98df\uff0c\u5c0f\u7a0b\u5e8fAPP\u996e\u54c1\uff08\u542b\u51b0\u6dc7\u6dcb\u7cfb\u5217\uff09\u95e8\u5e02\u4ef7\u52a01\u5143\u201d\u3002\u636e\u5357\u90fd\u6d88\u606f\uff0c\u9488\u5bf9\u6700\u65b0\u6da8\u4ef7\u539f\u56e0\uff0c\u871c\u96ea\u51b0\u57ce\u603b\u90e8\u5ba2\u670d\u56de\u5e94\u79f0\uff0c\u201c\u7efc\u5408\u8003\u8651\u5e02\u573a\u56e0\u7d20\u548c\u95e8\u5e97\u7ecf\u8425\uff0c\u6211\u4eec\u9488\u5bf9\u4e2a\u522b\u533a\u57df\u4ea7\u54c1\u8fdb\u884c\u4e86\u7edf\u4e00\u8c03\u6574\uff0c\u5176\u4ed6\u533a\u57df\u7684\u4ef7\u683c\u7ef4\u6301\u4e0d\u53d8\u3002\u201d\u9488\u5bf9\u540e\u7eed\u662f\u5426\u4f1a\u7ee7\u7eed\u8c03\u6574\u548c\u6062\u590d\u539f\u4ef7\uff0c\u871c\u96ea\u51b0\u57ce\u5b98\u65b9\u5ba2\u670d\u5219\u79f0\uff0c\u6682\u65f6\u672a\u63a5\u5230\u901a\u77e5\u3002", "link": "https://www.lieyunpro.com/news/116901"}, {"title": "\u5317\u5916\u62a5\u544a\uff1a\u8fd19\u6210\u5165\u5883\u65c5\u5ba2\u60f3\u5c1d\u8bd5\u4e2d\u56fd\u79fb\u52a8\u652f\u4ed8\u65b0\u670d\u52a1\u201c\u78b0\u4e00\u4e0b\u201d", "description": "2024\u5e74\uff0c\u4e2d\u56fd\u514d\u7b7e\u670b\u53cb\u5708\u8fdb\u4e00\u6b65\u6269\u5927\uff0c\u4e2d\u56fd\u8fc7\u5883\u514d\u7b7e\u653f\u7b56\u5168\u9762\u653e\u5bbd\u4f18\u5316\uff0c\u5438\u5f15\u7740\u8d8a\u6765\u8d8a\u591a\u5916\u56fd\u6e38\u5ba2\u6765\u534e\u65c5\u884c\uff1b\u4e2d\u56fd\u4fbf\u6377\u7684\u652f\u4ed8\u670d\u52a1\u52a9\u529b\u5168\u7403\u6e38\u5ba2\u5728\u534e\u7545\u6e38\u7545\u4e70\uff0c\u8fde\u63a5\u4e2d\u5916\u3001\u4fc3\u5165\u5883\u6e38\u6d88\u8d39\u7684\u540c\u65f6\uff0c\u4e5f\u7ed9\u56fd\u9645\u53cb\u4eba\u7559\u4e86\u6df1\u523b\u5370\u8c61\u3002 12\u670817\u65e5\uff0c\u5317\u4eac\u5916\u56fd\u8bed\u5927\u5b66\u4e1d\u7ef8\u4e4b\u8def\u7814\u7a76\u9662\u8bfe\u9898\u7ec4\u57fa\u4e8e\u5bf9111\u4e2a\u56fd\u5bb62000\u591a\u4f4d\u5916\u56fd\u65c5\u5ba2\u7684\u8c03\u7814\uff0c\u53d1\u5e03\u6700\u65b0\u62a5\u544a\uff1a\u8fd17\u6210\u53d7\u8bbf\u65c5\u5ba2\u4e3a\u9996\u6b21\u6765\u534e\uff1b99%\u7684\u53d7\u8bbf\u5916\u56fd\u65c5\u5ba2\u4f1a\u5411\u670b\u53cb\u63a8\u8350\u6765\u4e2d\u56fd\u65c5\u884c\uff1b\u5916\u56fd\u65c5\u5ba2\u5728\u534e\u4f7f\u7528\u7684\u652f\u4ed8\u670d\u52a1\u548c\u7ec4\u5408\u591a\u5143\uff1b\u8d85\u4e5d\u6210\u6709\u8fc7\u6765\u534e\u7ecf\u5386\u7684\u5916\u56fd\u65c5\u5ba2\u611f\u53d7\u4e2d\u56fd\u79fb\u52a8\u652f\u4ed8\u4fbf\u5229\u8fdb\u4e00\u6b65\u63d0\u5347\uff1b\u4f7f\u7528\u8fc7\u652f\u4ed8\u5b9d\u7684\u5916\u56fd\u65c5\u5ba2\u4e2d\uff0c99%\u8fd8\u4f1a\u63a8\u8350\u670b\u53cb\u4f7f\u7528\u3002 12\u670817\u65e5\uff0c\u56fd\u5bb6\u79fb\u6c11\u7ba1\u7406\u5c40\u53d1\u5e03\u516c\u544a\uff0c\u5373\u65e5\u8d77\u5168\u9762\u653e\u5bbd\u4f18\u5316\u8fc7\u5883\u514d\u7b7e\u653f\u7b56\uff0c\u5c06\u8fc7\u5883\u514d\u7b7e\u5916\u56fd\u4eba\u5728\u5883\u5185\u505c\u7559\u65f6\u95f4\u7531\u539f72\u5c0f\u65f6\u548c144\u5c0f\u65f6\u5747\u5ef6\u957f\u4e3a240\u5c0f\u65f6\uff0810\u5929\uff09\uff0c\u540c\u65f6\u65b0\u589e21\u4e2a\u53e3\u5cb8\u4e3a\u8fc7\u5883\u514d\u7b7e\u4eba\u5458\u5165\u51fa\u5883\u53e3\u5cb8\uff0c\u5e76\u8fdb\u4e00\u6b65\u6269\u5927\u505c\u7559\u6d3b\u52a8\u533a\u57df\u3002\u6b64\u524d\uff0c\u4e2d\u56fd72/144\u5c0f\u65f6\u8fc7\u5883\u514d\u7b7e\u653f\u7b56\u5df2\u9002\u752854\u4e2a\u56fd\u5bb6\u3002\u81ea2024\u5e7411\u670830\u65e5\u8d77\uff0c38\u4e2a\u514d\u7b7e\u56fd\u5bb6\u6301\u666e\u901a\u62a4\u7167\u4eba\u5458\u6765\u534e\u7ecf\u5546\u3001\u65c5\u6e38\u89c2\u5149\u3001\u63a2\u4eb2\u8bbf\u53cb\u3001\u4ea4\u6d41\u8bbf\u95ee\u3001\u8fc7\u5883\u4e0d\u8d85\u8fc730\u5929\uff0c\u53ef\u514d\u7b7e\u5165\u5883\u3002\u514d\u7b7e\u653f\u7b56\u6b63\u5438\u5f15\u8d8a\u6765\u8d8a\u591a\u5916\u56fd\u6e38\u5ba2\u6765\u8bbf\u4e2d\u56fd\u884c\u3002\u8c03\u7814\u663e\u793a\uff0c\u6765\u81ea72/144\u5c0f\u65f6\u8fc7\u5883\u514d\u7b7e\u56fd\u5bb6\u7684\u65c5\u5ba2\u9996\u6b21\u8bbf\u534e\u7684\u6bd4\u4f8b\u9ad8\u8fbe 71%\u3002\u5404\u5e74\u9f84\u6bb5\u8bbf\u534e\u5916\u56fd\u65c5\u5ba2\u7fa4\u4f53\u4e2d\uff0c\u9996\u6b21\u8bbf\u534e\u5916\u56fd\u65c5\u5ba2\u5360\u6bd4\u5747\u8d85\u8fc750%\uff0c\u5176\u4e2d90\u540e\u9996\u6b21\u8bbf\u534e\u5916\u56fd\u65c5\u5ba2\u5360\u6bd4\u6700\u9ad8\uff0c\u8fbe76%\u3002\u4e2d\u56fd\u8f89\u714c\u707f\u70c2\u7684\u53e4\u5178\u6587\u5316\u3001\u58ee\u4e3d\u79c0\u7f8e\u7684\u81ea\u7136\u98ce\u5149\u3001\u5145\u6ee1\u6d3b\u529b\u7684\u5546\u4e1a\u8857\u533a\u3001\u6781\u5177\u70df\u706b\u6c14\u7684\u751f\u6d3b\u573a\u666f\u3001\u65e5\u65b0\u6708\u5f02\u7684\u79d1\u6280\u5e94\u7528\u4ee5\u53ca\u4fbf\u6377\u7684\u79fb\u52a8\u652f\u4ed8\uff0c\u90fd\u8ba9\u5916\u56fd\u65c5\u5ba2\u8fde\u8fde\u70b9\u8d5e\uff0c\u6b64\u6b21\u8c03\u7814\u7684\u5916\u56fd\u6e38\u5ba2\u63a8\u8350\u4e2d\u56fd\u884c\u7684\u6bd4\u4f8b\u63a5\u8fd1100%\uff0899.23%\uff09\u3002 \u8fc7\u53bb\u4e00\u5e74\uff0c\u5728\u76d1\u7ba1\u90e8\u95e8\u548c\u5404\u7ea7\u653f\u5e9c\u6307\u5bfc\u4e0b\uff0c\u5404\u673a\u6784\u6301\u7eed\u4f18\u5316\u652f\u4ed8\u670d\u52a1\uff0c\u6765\u534e\u5916\u56fd\u6e38\u5ba2\u7684\u652f\u4ed8\u4fbf\u5229\u4e0d\u65ad\u63d0\u5347\u3002 \u6b64\u6b21\u53d7\u8bbf\u5916\u56fd\u6e38\u5ba2\u6765\u534e\u65c5\u884c\u4f7f\u7528\u7684\u652f\u4ed8\u670d\u52a1\u591a\u5143\u53c8\u4e30\u5bcc\uff0c\u65e2\u5305\u62ec\u5355\u72ec\u4f7f\u7528\u94f6\u884c\u5361\u3001\u79fb\u52a8\u652f\u4ed8\u3001\u73b0\u91d1\uff0c\u4e5f\u5305\u62ec\u94f6\u884c\u5361+\u79fb\u52a8\u652f\u4ed8\u3001\u94f6\u884c\u5361+\u73b0\u91d1\u3001\u79fb\u52a8\u652f\u4ed8+\u73b0\u91d1\u7684\u591a\u5143\u7ec4\u5408\uff0c\u4e5f\u6709\u4e09\u79cd\u652f\u4ed8\u65b9\u5f0f\u90fd\u4f7f\u7528\u7684\uff0c\u4f53\u73b0\u4e2d\u56fd\u652f\u4ed8\u4fbf\u5229\u7684\u591a\u65b9\u4f4d\u63d0\u5347\u3002 \u5176\u4e2d\uff0c\u4e2d\u56fd\u79fb\u52a8\u652f\u4ed8\u670d\u52a1\u53d7\u5916\u56fd\u65c5\u5ba2\u6b22\u8fce\uff0c\u7ea691%\u6709\u8fc7\u6765\u534e\u7ecf\u5386\u7684\u5916\u56fd\u65c5\u5ba2\u611f\u53d7\u4e2d\u56fd\u79fb\u52a8\u652f\u4ed8\u4fbf\u5229\u8fdb\u4e00\u6b65\u63d0\u5347\u300299%\u7528\u8fc7\u652f\u4ed8\u5b9d\u7684\u5916\u56fd\u65c5\u5ba2\u4f1a\u63a8\u8350\u670b\u53cb\u4f7f\u7528\u3002\u6b64\u5916\uff0c\u4e2d\u56fd\u79fb\u52a8\u652f\u4ed8\u7684\u521b\u65b0\u3001\u4fbf\u6377\u548c\u591a\u5143\u5f97\u5230\u5165\u5883\u65c5\u5ba2\u7684\u9ad8\u5ea6\u8ba4\u53ef\u3002\u9664\u4e86\u5728\u5927\u8857\u5c0f\u5df7\u53ef\u4ee5\u4f53\u9a8c\u7684\u626b\u4e00\u626b\u652f\u4ed8\u4e4b\u5916\uff0c\u8fd190%\u7684\u6765\u534e\u5916\u56fd\u65c5\u5ba2\u60f3\u5c1d\u8bd5\u201c\u78b0\u4e00\u4e0b\u652f\u4ed8\u201d\u3002\u201c\u78b0\u4e00\u4e0b\u201d\u53ef\u4ee5\u8ba9\u7528\u6237\u89e3\u9501\u624b\u673a\u540e\u5728\u5546\u5bb6\u6536\u6b3e\u8bbe\u5907\u4e0a\u78b0\u4e00\u4e0b\u5c31\u80fd\u652f\u4ed8\u3001\u70b9\u9910\u7b49\u3002\u79fb\u52a8\u652f\u4ed8\u6b63\u6210\u4e3a\u6570\u5b57\u5316\u65f6\u4ee3\u8fde\u901a\u5168\u7403\u7684\u65b0\u6570\u5b57\u8bed\u8a00\uff0c\u8c03\u7814\u663e\u793a\uff0c\u4e0d\u540c\u56fd\u5bb6\u7684\u5e74\u8f7b\u4eba\u90fd\u7231\u7528\u79fb\u52a8\u652f\u4ed8\uff0c90\u540e\u548c00\u540e\u5916\u56fd\u65c5\u5ba2\u5728\u534e\u79fb\u52a8\u652f\u4ed8\u4f7f\u7528\u8f6c\u5316\u7387\u5747\u8f83\u9ad8\uff0c\u7ea6 90%\uff0c\u8fd9\u4e5f\u610f\u5473\u7740\u79fb\u52a8\u652f\u4ed8\u5728\u5168\u7403\u5e74\u8f7b\u4eba\u4e2d\u90fd\u5f88\u6d41\u884c\uff0c\u4e2d\u56fd\u7684\u652f\u4ed8\u4fbf\u5229\u63d0\u5347\u4e5f\u5728\u7f29\u5c0f\u4e2d\u5916\u652f\u4ed8\u201c\u4e60\u60ef\u843d\u5dee\u201d\u3002\u4e0d\u8bba\u662f\u6765\u81ea\u91d1\u7816\u56fd\u5bb6\u3001\u201c\u4e00\u5e26\u4e00\u8def\u201d\u5171\u5efa\u56fd\u5bb6\uff0c\u8fd8\u662f\u4e2d\u56fd 72/144\u5c0f\u65f6\u8fc7\u5883\u514d\u7b7e\u56fd\u5bb6\u7684\u53d7\u8bbf\u65c5\u5ba2\uff0c\u8ba4\u4e3a\u4e2d\u56fd\u79fb\u52a8\u652f\u4ed8\u6539\u5584\u7684\u6bd4\u4f8b\u5747\u4e0d\u4f4e\u4e8e 90%\uff1b\u5176\u4e2d\uff0c\u91d1\u7816\u56fd\u5bb6\u65c5\u5ba2\u7684\u8fd9\u4e00\u6bd4\u4f8b\u66f4\u662f\u8d85\u8fc7 94%\u3002\u62a5\u544a\u8fd8\u5efa\u8bae\uff0c\u6df1\u5165\u8d2f\u5f7b\u843d\u5b9e\u300a\u5173\u4e8e\u8fdb\u4e00\u6b65\u4f18\u5316\u670d\u52a1\u63d0\u5347\u652f\u4ed8\u4fbf\u5229\u6027\u7684\u610f\u89c1\u300b\uff0c\u5de9\u56fa\u65e2\u6709\u7684\u653f\u7b56\u6210\u679c\uff0c\u8fdb\u4e00\u6b65\u4f18\u5316\u5916\u56fd\u65c5\u5ba2\u5165\u5883\u7684\u5404\u7c7b\u670d\u52a1\uff0c\u5b8c\u5584\u5916\u56fd\u65c5\u5ba2\u5728\u534e\u652f\u4ed8\u4fbf\u5229\u6027\u4e3e\u63aa\uff0c\u6301\u7eed\u4f18\u5316\u4f7f\u7528\u4f53\u9a8c\uff1b\u7ee7\u7eed\u6269\u5927\u201c\u5916\u5305\u5185\u7528\u201d\u201c\u5916\u5361\u5185\u7ed1\u201d\u652f\u6301\u8303\u56f4\uff0c\u63a8\u52a8\u94f6\u884c\u5361\u652f\u4ed8\u670d\u52a1\u3001\u79fb\u52a8\u652f\u4ed8\u6269\u9762\u63d0\u8d28\u589e\u6548\uff1b\u7ee7\u7eed\u52a0\u5f3a\u5bf9\u79fb\u52a8\u652f\u4ed8\u7684\u63a8\u5e7f\u548c\u5ba3\u4f20\u7684\u529b\u5ea6\uff1b\u7ee7\u7eed\u63d0\u5347\u79fb\u52a8\u652f\u4ed8\u670d\u52a1\u7684\u4fbf\u5229\u6027\u3001\u521b\u65b0\u6027\u548c\u4e30\u5bcc\u6027\u3002", "link": "https://www.lieyunpro.com/news/116900"}, {"title": "\u4fdd\u65f6\u6377\u5458\u5de5\u786e\u8ba4\u516c\u53f8\u88c1\u5458\uff0c\u8d54\u507f\u6216\u6309N+6", "description": "\u636e\u7b2c\u4e00\u8d22\u7ecf\uff0c12\u670817\u65e5\uff0c\u636e\u591a\u5bb6\u5a92\u4f53\u62a5\u9053\uff0c\u8c6a\u534e\u6c7d\u8f66\u54c1\u724c\u4fdd\u65f6\u6377\u5f00\u542f\u4e2d\u56fd\u533a\u88c1\u5458\uff0c\u5305\u542b\u6b63\u5f0f\u3001\u5916\u5305\u7b49\u5c97\u4f4d\uff0c\u8d54\u507f\u6216\u6309N+6\u7684\u6807\u51c6\u6267\u884c\u3002\u7ecf\u5411\u4fdd\u65f6\u6377\u5185\u90e8\u5458\u5de5\u6838\u5b9e\uff0c\u8be5\u5458\u5de5\u79f0\u60c5\u51b5\u5c5e\u5b9e\uff0c\u516c\u53f8\u8ba1\u5212\u88c1\u545830%\u3002", "link": "https://www.lieyunpro.com/news/116899"}, {"title": "\u8302\u62d3\u9510\u83b7\u5f97\u6570\u5343\u4e07\u5143\u5929\u4f7f\u8f6e\u878d\u8d44\uff0c\u4e1c\u65b9\u5bcc\u6d77\u72ec\u5bb6\u6295\u8d44", "description": "12\u670817\u65e5\u6d88\u606f\uff0c\u8302\u62d3\u9510\u79d1\u6280\uff08\u4e0a\u6d77\uff09\u6709\u9650\u516c\u53f8\uff08\u4ee5\u4e0b\u7b80\u79f0\u201c\u8302\u62d3\u9510\u201d\uff09\u5b8c\u6210\u4e86\u6570\u5343\u4e07\u5143\u5929\u4f7f\u8f6e\u878d\u8d44\u3002\u672c\u8f6e\u7531\u4e1c\u65b9\u5bcc\u6d77\u7ba1\u7406\u7684\u4e2d\u5c0f\u4f01\u4e1a\u53d1\u5c55\u57fa\u91d1\u72ec\u5bb6\u6295\u8d44\uff0c\u8fdc\u5c71\u8d44\u672c\u62c5\u4efb\u72ec\u5bb6\u8d22\u52a1\u987e\u95ee\u3002\u8d44\u91d1\u5c06\u7528\u4e8e\u7ebf\u63a7\u5e95\u76d8\u7535\u673a\u91cf\u4ea7\u4ea7\u7ebf\u5efa\u8bbe\u53ca\u524d\u6cbf\u7535\u673a\u6280\u672f\u5f00\u53d1\u3002\u8302\u62d3\u9510\u662f\u4e00\u5bb6\u7ebf\u63a7\u5e95\u76d8\u7535\u673a\u4f9b\u5e94\u5546\uff0c\u4ee5\u7814\u53d1\u9500\u552e\u6c7d\u8f66\u6838\u5fc3\u96f6\u90e8\u4ef6\u7ebf\u63a7\u5e95\u76d8\u7535\u673a\u4e3a\u4e3b\u8425\u4e1a\u52a1\uff0c\u670d\u52a1\u65b0\u80fd\u6e90\u6c7d\u8f66\u4ea7\u4e1a\u94fe\u3002", "link": "https://www.lieyunpro.com/news/116897"}, {"title": "\u540c\u7a0b\u65c5\u884c\uff1a\u4e2d\u56fd\u8fc7\u5883\u514d\u7b7e\u5ef6\u957f\u81f310\u5929\uff0c\u6d77\u5916\u6e38\u5ba2\u62a2\u8ba2\u65b0\u5e74\u9152\u5e97", "description": "\u56fd\u5bb6\u79fb\u6c11\u7ba1\u7406\u5c4012\u670817\u65e5\u53d1\u5e03\u516c\u544a\uff0c\u5c06\u8fc7\u5883\u514d\u7b7e\u5916\u56fd\u4eba\u5728\u5883\u5185\u505c\u7559\u65f6\u95f4\u5ef6\u957f\u81f3240\u5c0f\u65f6\uff0810\u5929\uff09\uff0c\u5e76\u65b0\u589e21\u4e2a\u53e3\u5cb8\u4f5c\u4e3a\u8fc7\u5883\u514d\u7b7e\u4eba\u5458\u51fa\u5165\u5883\u53e3\u5cb8\uff0c\u8fdb\u4e00\u6b65\u6269\u5927\u505c\u7559\u6d3b\u52a8\u533a\u57df\u3002\u6d88\u606f\u516c\u5e03\u540e\uff0c\u4f17\u591a\u5916\u56fd\u6e38\u5ba2\u901a\u8fc7\u540c\u7a0b\u65c5\u884c\u53ca\u65d7\u4e0b\u56fd\u9645\u65c5\u884c\u9884\u8ba2\u5e73\u53f0HopeGoo\u5173\u6ce8\u548c\u9884\u8ba2\u5165\u5883\u673a\u7968\u3001\u9152\u5e97\u7b49\u4ea7\u54c1\u3002\u540c\u7a0b\u65c5\u884c\u6570\u636e\u663e\u793a\uff0c\u6d88\u606f\u516c\u5e03\u4e00\u5c0f\u65f6\u5185\uff0c\u6d77\u5916\u6e38\u5ba2\u641c\u7d22\u56fd\u5185\u9152\u5e97\u548c\u5165\u5883\u673a\u7968\u7684\u641c\u7d22\u70ed\u5ea6\u8f83\u524d\u65e5\u540c\u4e00\u65f6\u6bb5\u4e0a\u6da887%\u3002\u65b0\u5e74\u5bf9\u5916\u56fd\u6e38\u5ba2\u5177\u6709\u8f83\u9ad8\u7684\u5438\u5f15\u529b\uff0c\u6d77\u5916\u6e38\u5ba2\u9884\u8ba2\u5143\u65e6\u524d\u540e\u5165\u4f4f\u7684\u9152\u5e97\u9884\u8ba2\u70ed\u5ea6\u8f83\u524d\u65e5\u540c\u4e00\u65f6\u6bb5\u4e0a\u6da8\u8d85\u8fc75\u500d\u3002\u540c\u7a0b\u7814\u7a76\u9662\u5206\u6790\u8ba4\u4e3a\uff0c\u8fc7\u5883\u514d\u7b7e\u653f\u7b56\u65f6\u95f4\u5ef6\u957f\u548c\u6d3b\u52a8\u8303\u56f4\u6269\u5927\uff0c\u5c06\u5438\u5f15\u66f4\u591a\u7b26\u5408\u6761\u4ef6\u7684\u5916\u56fd\u4eba\u901a\u8fc7\u8fc7\u5883\u514d\u7b7e\u6765\u4e2d\u56fd\u65c5\u6e38\uff0c\u4ece\u800c\u4fc3\u8fdb\u4e2d\u56fd\u5165\u5883\u65c5\u6e38\u5e02\u573a\u7684\u8fdb\u4e00\u6b65\u589e\u957f\u3002\u672c\u6b21\u65b0\u589e\u7684\u592a\u539f\u3001\u626c\u5dde\u3001\u9ec4\u5c71\u3001\u5f20\u5bb6\u754c\u7b49\u53e3\u5cb8\u57ce\u5e02\u90fd\u662f\u4e2d\u56fd\u8457\u540d\u7684\u6587\u5316\u65c5\u6e38\u57ce\u5e02\uff0c\u8fd9\u4e9b\u53e3\u5cb8\u7684\u5f00\u653e\uff0c\u4e0d\u4ec5\u80fd\u591f\u5e26\u52a8\u5f53\u5730\u5165\u5883\u6e38\u5e02\u573a\u589e\u957f\uff0c\u4e5f\u6709\u5229\u4e8e\u589e\u8fdb\u56fd\u9645\u6587\u5316\u4ea4\u6d41\uff0c\u8ba9\u66f4\u591a\u5916\u56fd\u6e38\u5ba2\u6df1\u5165\u4f53\u9a8c\u4e2d\u56fd\u6587\u5316\u3002", "link": "https://www.lieyunpro.com/news/116896"}, {"title": "\u5357\u7f51\u6218\u65b0\u4ea7\u4e1a\u6295\u8d44\u57fa\u91d1\u6210\u7acb", "description": "\u8fd1\u65e5\uff0c\u5357\u7f51\u80fd\u6e90\u516c\u544a\u79f0\uff0c\u8be5\u516c\u53f8\u4e0e\u4e2d\u56fd\u5357\u65b9\u7535\u7f51\u6709\u9650\u8d23\u4efb\u516c\u53f8\u90e8\u5206\u63a7\u80a1\u6216\u5168\u8d44\u5b50\u516c\u53f8\u53ca\u5176\u4ed6\u5916\u90e8\u5408\u4f19\u4eba\u5171\u540c\u51fa\u8d44\u8bbe\u7acb\u5357\u7f51\u6218\u65b0\u4ea7\u4e1a\u6295\u8d44\u57fa\u91d1\uff08\u5e7f\u5dde\uff09\u5408\u4f19\u4f01\u4e1a\uff08\u6709\u9650\u5408\u4f19\uff09\uff0c\u8be5\u57fa\u91d1\u603b\u89c4\u6a2150\u4ebf\u5143\uff0c\u9996\u671f\u8ba4\u7f34\u89c4\u6a2120\u4ebf\u5143\u3002", "link": "https://www.lieyunpro.com/news/116894"}]}