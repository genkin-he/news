et=\"_self\">4772-TW</a>)、達興材 (<a data-ga-click-item=\"TWS:5234:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/5234\" rel=\"noopener noreferrer\" target=\"_self\">5234-TW</a>)</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>CPO</strong><strong>：環宇 - KY(<a data-ga-click-item=\"TWS:4991:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/4991\" rel=\"noopener noreferrer\" target=\"_self\">4991-TW</a>)、IET-KY(<a data-ga-click-item=\"TWS:4971:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/4971\" rel=\"noopener noreferrer\" target=\"_self\">4971-TW</a>)、上詮 (<a data-ga-click-item=\"TWS:3363:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/3363\" rel=\"noopener noreferrer\" target=\"_self\">3363-TW</a>)、波若威 (<a data-ga-click-item=\"TWS:3163:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/3163\" rel=\"noopener noreferrer\" target=\"_self\">3163-TW</a>)、聯鈞 (<a data-ga-click-item=\"TWS:3450:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/3450\" rel=\"noopener noreferrer\" target=\"_self\">3450-TW</a>)、華星光 (<a data-ga-click-item=\"TWS:4979:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/4979\" rel=\"noopener noreferrer\" target=\"_self\">4979-TW</a>)、訊芯 - KY(<a data-ga-click-item=\"TWS:6451:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/6451\" rel=\"noopener noreferrer\" target=\"_self\">6451-TW</a>)、眾達 - KY(<a data-ga-click-item=\"TWS:4977:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/4977\" rel=\"noopener noreferrer\" target=\"_self\">4977-TW</a>)、光聖 (<a data-ga-click-item=\"TWS:6442:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/6442\" rel=\"noopener noreferrer\" target=\"_self\">6442-TW</a>)、聯亞 (<a data-ga-click-item=\"TWS:3081:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/3081\" rel=\"noopener noreferrer\" target=\"_self\">3081-TW</a>)</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>個股詳細解析：</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>貿聯 - KY(<a data-ga-click-item=\"TWS:3665:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/3665\" rel=\"noopener noreferrer\" target=\"_self\">3665-TW</a>)：AEC(主動電纜) 與 Power Whip(電源線) 核心供應商。與美國高速連接方案商 Credo 深化合作。AI 伺服器架構導入大量 AEC。</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>健策 (<a data-ga-click-item=\"TWS:3653:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/3653\" rel=\"noopener noreferrer\" target=\"_self\">3653-TW</a>)：均熱片、導線架、ILM (伺服器 CPU/GPU 扣件)、以及水冷散熱模組等。大園三廠預計 2025 年第四季完工投產。</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>致茂 (<a data-ga-click-item=\"TWS:2360:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2360\" rel=\"noopener noreferrer\" target=\"_self\">2360-TW</a>)：自動化檢測解決方案供應商，產品廣泛用於：晶圓廠、IC 封測廠、AI、儲能與電動車等。台積電封測設備供應商。輝達 AI 晶片檢測設備商。</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>華景電 (<a data-ga-click-item=\"TWS:6788:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/6788\" rel=\"noopener noreferrer\" target=\"_self\">6788-TW</a>)：晶圓製程 AMC 微污染防治設備和 RFID 整合派工系統。AMC 設備 3 奈米滲透率預估 60% 左右，2 奈米滲透率可望更高。</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>新應材 (<a data-ga-click-item=\"TWG:4749:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/4749\" rel=\"noopener noreferrer\" target=\"_self\">4749-TW</a>)：台積電特化供應鏈；台積電佔營收 70% 以上，台積電 2 奈米將量產，清洗劑、洗邊劑、Rinse、BARC 需求量爆增。高雄廠二期預計 2026 年進入量產。</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>台特化 (<a data-ga-click-item=\"TWS:4772:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/4772\" rel=\"noopener noreferrer\" target=\"_self\">4772-TW</a>)：邏輯 IC 先進製程用矽乙烷的供應量佔全球第一。無水氟化氫(AHF) 通過客戶驗證。矽丙烷產品，全球僅有的兩家具備合成與量產技術廠商之一。</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>環宇 - KY(<a data-ga-click-item=\"TWS:4991:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/4991\" rel=\"noopener noreferrer\" target=\"_self\">4991-TW</a>)：800G PD 全球市佔第一。切入矽光子應用的 CW Laser 市場。供應鏈 AAOI 主要 PD 晶片供應商。800G 及 1.6T 光模組需求強勁。</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>IET-KY(<a data-ga-click-item=\"TWS:4971:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/4971\" rel=\"noopener noreferrer\" target=\"_self\">4971-TW</a>)</strong><strong>：為 IDM 業者做磊晶片代工，廣泛應用於 AI、5G、光通訊、國防軍工、汽車防撞雷達及高頻元件等領域。</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>上詮 (<a data-ga-click-item=\"TWS:3363:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/3363\" rel=\"noopener noreferrer\" target=\"_self\">3363-TW</a>)：AI 帶旺 CPO 高速傳輸，具獨家光柵技術，為台積電、輝達 CPO 主要合作夥伴。</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p><strong>葉俊敏分析師提醒投資朋友，AI 產業即使長期看漲，但個股位階不同，有不同的投資策略，並應等待轉強的技術性買點出現，否則追高風險大。如 IET-KY(<a data-ga-click-item=\"TWS:4971:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/4971\" rel=\"noopener noreferrer\" target=\"_self\">4971-TW</a>)，這三個交易日的大漲大跌，考驗投資人的持股信心。想要掌握最新個股訊息及最新投資策略，請加入 Line @</strong></p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><figure><img src=\"https://cimg.cnyes.cool/prod/news/6132485/l/ff66d4c56fe9a03faccab55eba03a39c.jpg\"/></figure></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><figure><img src=\"https://cimg.cnyes.cool/prod/news/6132485/l/0d555c0d815c5e7586fe696dbbf9fd49.jpg\"/></figure></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><figure><img src=\