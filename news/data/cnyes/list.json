ock/2344\" rel=\"noopener noreferrer\" target=\"_self\">2344-TW</a>)、台化 (<a data-ga-click-item=\"TWS:1326:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/1326\" rel=\"noopener noreferrer\" target=\"_self\">1326-TW</a>)、力積電 (<a data-ga-click-item=\"TWS:6770:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/6770\" rel=\"noopener noreferrer\" target=\"_self\">6770-TW</a>)、大成鋼 (<a data-ga-click-item=\"TWS:2027:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2027\" rel=\"noopener noreferrer\" target=\"_self\">2027-TW</a>)<br/> </p></section></main>",
