 left;\">2022/12/22</td> <td style=\"text-align: right;\">63.6</td> <td style=\"text-align: right;\">3.0</td> <td style=\"text-align: right;\">4.72%</td> <td style=\"text-align: right;\">0.0</td> </tr> <tr> <td style=\"text-align: left;\">2022/07/20</td> <td style=\"text-align: right;\">77.7</td> <td style=\"text-align: right;\">2.0</td> <td style=\"text-align: right;\">2.57%</td> <td style=\"text-align: right;\">0.0</td> </tr> </tbody></table></section></main>",
