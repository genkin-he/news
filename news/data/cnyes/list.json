td style=\"text-align: left;\">\n<p>群益台 ESG 低碳 50</p>\n</td>\n<td style=\"text-align: left;\">\n<p>27.83</p>\n</td>\n<td style=\"text-align: left;\">\n<p>219.1</p>\n</td>\n</tr>\n<tr>\n<td style=\"text-align: left;\">\n<p>00913</p>\n</td>\n<td style=\"text-align: left;\">\n<p>兆豐台灣晶圓製造</p>\n</td>\n<td style=\"text-align: left;\">\n<p>28.2</p>\n</td>\n<td style=\"text-align: left;\">\n<p>3</p>\n</td>\n</tr>\n<tr>\n<td style=\"text-align: left;\">\n<p>00894</p>\n</td>\n<td style=\"text-align: left;\">\n<p>中信小資高價 30</p>\n</td>\n<td style=\"text-align: left;\">\n<p>29.68</p>\n</td>\n<td style=\"text-align: left;\">\n<p>41.4</p>\n</td>\n</tr>\n<tr>\n<td style=\"text-align: left;\">\n<p>00935</p>\n</td>\n<td style=\"text-align: left;\">\n<p>野村臺灣新科技 50</p>\n</td>\n<td style=\"text-align: left;\">\n<p>33.2</p>\n</td>\n<td style=\"text-align: left;\">\n<p>139.1</p>\n</td>\n</tr>\n<tr>\n<td style=\"text-align: left;\">\n<p>00881</p>\n</td>\n<td style=\"text-align: left;\">\n<p>國泰台灣科技龍頭</p>\n</td>\n<td style=\"text-align: left;\">\n<p>35.39</p>\n</td>\n<td style=\"text-align: left;\">\n<p>834.2</p>\n</td>\n</tr>\n<tr>\n<td style=\"text-align: left;\">\n<p>00690</p>\n</td>\n<td style=\"text-align: left;\">\n<p>兆豐藍籌 30</p>\n</td>\n<td style=\"text-align: left;\">\n<p>47.65</p>\n</td>\n<td style=\"text-align: left;\">\n<p>36.4</p>\n</td>\n</tr>\n<tr>\n<td style=\"text-align: left;\">\n<p>00850</p>\n</td>\n<td style=\"text-align: left;\">\n<p>元大臺灣 ESG 永續</p>\n</td>\n<td style=\"text-align: left;\">\n<p>58.8</p>\n</td>\n<td style=\"text-align: left;\">\n<p>259.9</p>\n</td>\n</tr>\n<tr>\n<td style=\"text-align: left;\">\n<p>00692</p>\n</td>\n<td style=\"text-align: left;\">\n<p>富邦公司治理</p>\n</td>\n<td style=\"text-align: left;\">\n<p>62.05</p>\n</td>\n<td style=\"text-align: left;\">\n<p>407.7</p>\n</td>\n</tr>\n<tr>\n<td style=\"text-align: left;\">\n<p>0051</p>\n</td>\n<td style=\"text-align: left;\">\n<p>元大中型 100</p>\n</td>\n<td style=\"text-align: left;\">\n<p>99.35</p>\n</td>\n<td style=\"text-align: left;\">\n<p>23.3</p>\n</td>\n</tr>\n<tr>\n<td style=\"text-align: left;\">\n<p>006208</p>\n</td>\n<td style=\"text-align: left;\">\n<p>富邦台 50</p>\n</td>\n<td style=\"text-align: left;\">\n<p>162.3</p>\n</td>\n<td style=\"text-align: left;\">\n<p>3063.6</p>\n</td>\n</tr>\n<tr>\n<td style=\"text-align: left;\">\n<p>0057</p>\n</td>\n<td style=\"text-align: left;\">\n<p>富邦摩台</p>\n</td>\n<td style=\"text-align: left;\">\n<p>207</p>\n</td>\n<td style=\"text-align: left;\">\n<p>3.1</p>\n</td>\n</tr>\n</tbody>\n</table></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p>資料來源 : CMoney，2026/01/14，排除主動型台股 ETF</p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p class=\"warning\">※免責聲明：文中所提的個股、基金、期貨商品內容僅供參考，並非投資建議，投資人應獨立判斷，審慎評估風險，自負盈虧。</p></section><section style=\"margin-top:30px\">\n</section></main>",
