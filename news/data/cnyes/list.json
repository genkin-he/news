ww.cnyes.com/twstock/3481\" rel=\"noopener noreferrer\" target=\"_self\">3481-TW</a>)</p></section><section><p>4. 外資累計賣超 2 日的股票<br/>友達 (<a data-ga-click-item=\"TWS:2409:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2409\" rel=\"noopener noreferrer\" target=\"_self\">2409-TW</a>)、大同 (<a data-ga-click-item=\"TWS:2371:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2371\" rel=\"noopener noreferrer\" target=\"_self\">2371-TW</a>)、東元 (<a data-ga-click-item=\"TWS:1504:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/1504\" rel=\"noopener noreferrer\" target=\"_self\">1504-TW</a>)、華通 (<a data-ga-click-item=\"TWS:2313:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2313\" rel=\"noopener noreferrer\" target=\"_self\">2313-TW</a>)、元大台灣50 (<a data-ga-click-item=\"TWS:0050:STOCK:ETF\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/0050\" rel=\"noopener noreferrer\" target=\"_self\">0050-TW</a>)</p></section><section style=\"margin-top:30px\"><p>5. 外資當日 (15) 賣超的股票<br/>友達 (<a data-ga-click-item=\"TWS:2409:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2409\" rel=\"noopener noreferrer\" target=\"_self\">2409-TW</a>)、東元 (<a data-ga-click-item=\"TWS:1504:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/1504\" rel=\"noopener noreferrer\" target=\"_self\">1504-TW</a>)、元大台灣50 (<a data-ga-click-item=\"TWS:0050:STOCK:ETF\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/0050\" rel=\"noopener noreferrer\" target=\"_self\">0050-TW</a>)、﻿宏碁 (<a data-ga-click-item=\"TWS:2353:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2353\" rel=\"noopener noreferrer\" target=\"_self\">2353-TW</a>)、主動元大AI新經濟 (<a data-ga-click-item=\"TWS:00990A:STOCK:ETF\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/00990A\" rel=\"noopener noreferrer\" target=\"_self\">00990A-TW</a>)<br/> </p></section></main>",
