self\">2887-TW</a>)、大成鋼 (<a data-ga-click-item=\"TWS:2027:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2027\" rel=\"noopener noreferrer\" target=\"_self\">2027-TW</a>)、中鋼 (<a data-ga-click-item=\"TWS:2002:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2002\" rel=\"noopener noreferrer\" target=\"_self\">2002-TW</a>)、強茂 (<a data-ga-click-item=\"TWS:2481:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2481\" rel=\"noopener noreferrer\" target=\"_self\">2481-TW</a>)<br/> </p></section></main>",
