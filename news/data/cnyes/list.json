n: right;\">36.96億</td><td style=\"text-align: right;\">42.41億</td><td style=\"text-align: right;\">51.41億</td></tr></tbody></table></section><section style=\"margin-top:30px\"><p>詳細資訊請看美股內頁：<br/>英賽德(<a data-ga-click-item=\"USS:INCY:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://invest.cnyes.com/usstock/detail/INCY\" rel=\"noopener noreferrer\" target=\"_self\">INCY-US</a>)</p></section><section style=\"margin-top:30px\"><p>資料來源：Factset，數據僅供參考，不作為投資建議。</p></section></main>",
