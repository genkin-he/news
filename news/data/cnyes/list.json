left;\">2022/08/23</td> <td style=\"text-align: right;\">15.4</td> <td style=\"text-align: right;\">0.19</td> <td style=\"text-align: right;\">1.23%</td> <td style=\"text-align: right;\">0.0</td> </tr> <tr> <td style=\"text-align: left;\">2008/08/19</td> <td style=\"text-align: right;\">6.5999999</td> <td style=\"text-align: right;\">0.20103656</td> <td style=\"text-align: right;\">3.03%</td> <td style=\"text-align: right;\">0.0</td> </tr> </tbody></table></section></main>",
