https://www.cnyes.com/hkstock/quote/01398\" rel=\"noopener noreferrer\" target=\"_self\">01398-HK</a>)</td><td>6.11</td><td>-0.65</td></tr><tr><td>中國中免(<a data-ga-click-item=\"HKS:01880:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/01880\" rel=\"noopener noreferrer\" target=\"_self\">01880-HK</a>)</td><td>60.40</td><td>-6.21</td></tr><tr><td>國壽(<a data-ga-click-item=\"HKS:02628:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/02628\" rel=\"noopener noreferrer\" target=\"_self\">02628-HK</a>)</td><td>23.00</td><td>+2.91</td></tr><tr><td>中金(<a data-ga-click-item=\"HKS:03908:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/03908\" rel=\"noopener noreferrer\" target=\"_self\">03908-HK</a>)</td><td>21.60</td><td>-0.92</td></tr></table></section><section style=\"margin-top:30px\"><p class=\"\">　　(ed)</p></section><section style=\"margin-top:30px\"><p class=\"\"></p></section></main>",
