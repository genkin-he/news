www.cnyes.com/twstock/5475\" rel=\"noopener noreferrer\" target=\"_self\">5475-TW</a>) 漲逾 1%。 </p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p>營建類股今天表現同樣亮眼，工信 (<a data-ga-click-item=\"TWS:5521:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/5521\" rel=\"noopener noreferrer\" target=\"_self\">5521-TW</a>) 漲逾半根停板，寶徠 (<a data-ga-click-item=\"TWS:1805:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/1805\" rel=\"noopener noreferrer\" target=\"_self\">1805-TW</a>) 漲逾 4%，日勝生 (<a data-ga-click-item=\"TWS:2547:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2547\" rel=\"noopener noreferrer\" target=\"_self\">2547-TW</a>)、京城 (<a data-ga-click-item=\"TWS:2524:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2524\" rel=\"noopener noreferrer\" target=\"_self\">2524-TW</a>) 漲逾 3%，愛山林 (<a data-ga-click-item=\"TWS:2540:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2540\" rel=\"noopener noreferrer\" target=\"_self\">2540-TW</a>)、達麗 (<a data-ga-click-item=\"TWS:6177:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/6177\" rel=\"noopener noreferrer\" target=\"_self\">6177-TW</a>)、長虹 (<a data-ga-click-item=\"TWS:5534:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/5534\" rel=\"noopener noreferrer\" target=\"_self\">5534-TW</a>)、華固 (<a data-ga-click-item=\"TWS:2548:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2548\" rel=\"noopener noreferrer\" target=\"_self\">2548-TW</a>)、宏璟 (<a data-ga-click-item=\"TWS:2527:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/2527\" rel=\"noopener noreferrer\" target=\"_self\">2527-TW</a>)、華友聯 (<a data-ga-click-item=\"TWS:1436:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/1436\" rel=\"noopener noreferrer\" target=\"_self\">1436-TW</a>) 皆漲逾 2%。 </p></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><p>生技族群今天表現相對弱勢，禾榮科 (<a data-ga-click-item=\"TWS:7799:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/7799\" rel=\"noopener noreferrer\" target=\"_self\">7799-TW</a>) 跌逾 4%，泰福 - KY(<a data-ga-click-item=\"TWS:6541:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/6541\" rel=\"noopener noreferrer\" target=\"_self\">6541-TW</a>)、光麗 - KY(<a data-ga-click-item=\"TWS:6431:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/6431\" rel=\"noopener noreferrer\" target=\"_self\">6431-TW</a>) 跌逾 3%，金萬林 (<a data-ga-click-item=\"TWG:6645:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/6645\" rel=\"noopener noreferrer\" target=\"_self\">6645-TW</a>)、北極星藥業 (<a data-ga-click-item=\"TWG:6555:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/6555\" rel=\"noopener noreferrer\" target=\"_self\">6555-TW</a>)、康霈 *(<a data-ga-click-item=\"TWS:6919:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/twstock/6919\" rel=\"noopener noreferrer\" target=\"_self\">6919-TW</a>) 皆有超過 2% 跌福。 </p></section><section style=\"margin-top:30px\">\n</section></main>",
