\"height:22px; width:76px\">\n<p>1.08</p>\n</td>\n<td style=\"height:22px; width:84px\">\n<p>0.19</p>\n</td>\n<td style=\"height:22px; width:72px\">\n<p>5.39</p>\n</td>\n</tr>\n<tr>\n<td style=\"height:22px; width:72px\">\n<p>00981B</p>\n</td>\n<td style=\"height:22px; width:149px\">\n<p>第一金優選非投債</p>\n</td>\n<td style=\"height:22px; width:62px\">\n<p>9.22</p>\n</td>\n<td style=\"height:22px; width:66px\">\n<p>0.22</p>\n</td>\n<td style=\"height:22px; width:76px\">\n<p>1.06</p>\n</td>\n<td style=\"height:22px; width:84px\">\n<p>0.82</p>\n</td>\n<td style=\"height:22px; width:72px\">\n<p>5.89</p>\n</td>\n</tr>\n</tbody>\n</table></section><section style=\"margin-top:30px\">\n</section><section style=\"margin-top:30px\"><div style=\"clear:both;\">資料來源：Cmoney，2025.09.25。主動中信非投等債於 2025/9/16 掛牌</div></section><section style=\"margin-top:30px\">\n</section></main>",
