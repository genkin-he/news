</tr><tr><td>華潤燃氣(<a data-ga-click-item=\"HKS:01193:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/01193\" rel=\"noopener noreferrer\" target=\"_self\">01193-HK</a>)</td><td>19.56</td><td>-0.86</td></tr><tr><td>新奧能源(<a data-ga-click-item=\"HKS:02688:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/02688\" rel=\"noopener noreferrer\" target=\"_self\">02688-HK</a>)</td><td>64.30</td><td>-0.16</td></tr><tr><td>中裕能源(<a data-ga-click-item=\"HKS:03633:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/03633\" rel=\"noopener noreferrer\" target=\"_self\">03633-HK</a>)</td><td>3.26</td><td>-6.32</td></tr></table></section><section style=\"margin-top:30px\"><p class=\"\">　　(ed)</p></section><section style=\"margin-top:30px\"><p class=\"\"></p></section></main>",
