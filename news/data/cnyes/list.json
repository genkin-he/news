yes.com/hkstock/quote/01398\" rel=\"noopener noreferrer\" target=\"_self\">01398-HK</a>)</td><td>5.60</td><td>-1.23</td></tr><tr><td>國壽(<a data-ga-click-item=\"HKS:02628:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/02628\" rel=\"noopener noreferrer\" target=\"_self\">02628-HK</a>)</td><td>16.06</td><td>-5.42</td></tr><tr><td>紫金(<a data-ga-click-item=\"HKS:02899:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/02899\" rel=\"noopener noreferrer\" target=\"_self\">02899-HK</a>)</td><td>18.18</td><td>+0.66</td></tr><tr><td>中行(<a data-ga-click-item=\"HKS:03988:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/03988\" rel=\"noopener noreferrer\" target=\"_self\">03988-HK</a>)</td><td>4.70</td><td>-1.26</td></tr></table></section><section style=\"margin-top:30px\"><p class=\"\">　　(ed)</p></section><section style=\"margin-top:30px\"><p class=\"\"></p></section></main>",
