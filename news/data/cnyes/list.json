oreferrer\" target=\"_self\">03690-HK</a>)</td><td>174.40</td><td>+6.02</td></tr><tr><td>京東集團(<a data-ga-click-item=\"HKS:09618:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/09618\" rel=\"noopener noreferrer\" target=\"_self\">09618-HK</a>)</td><td>166.40</td><td>+5.85</td></tr><tr><td>小鵬汽車(<a data-ga-click-item=\"HKS:09868:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/09868\" rel=\"noopener noreferrer\" target=\"_self\">09868-HK</a>)</td><td>92.10</td><td>-3.56</td></tr><tr><td>阿里(<a data-ga-click-item=\"HKS:09988:STOCK:COMMON\" data-ga-event-name=\"Click_Quote\" data-ga-section=\"News_Article_文中行情\" data-ga-target=\"news\" href=\"https://www.cnyes.com/hkstock/quote/09988\" rel=\"noopener noreferrer\" target=\"_self\">09988-HK</a>)</td><td>136.40</td><td>+3.73</td></tr></table></section><section style=\"margin-top:30px\"><p class=\"\">　　(ed)</p></section><section style=\"margin-top:30px\"><p class=\"\"></p></section></main>",
